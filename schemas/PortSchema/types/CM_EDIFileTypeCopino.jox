<Class name="CM_EDIFileTypeCopino" id="50316144-e62e-4f99-a0a6-d91cd1e0f616">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="b457ccb8-a29e-40d5-aeb8-9a4b8dedf44e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "COPINO - Container Prenotification";
	self.type	:= EDIFileType_Copino;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractTIData" id="a7bd86b3-0bcf-48c1-be55-473edee6078c">
        <updating/>
        <source>extractTIData(ti : CM_TrackedItem; _ediFile: CM_EDIFile input) : String updating;
/*NFS 3833 AA 23/10/01: This method extracts all the details for a passed
in TI and adds the appropriate messages to the output file.

07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

*/
vars
	str, fullMTStr, iMEXStr, 
	isoStr, port, sealNum	: String;
	voyageObj				: CM_Voyage;
	int						: Integer;
	cont					: CM_Container;
	foundMatch				: Boolean;
begin
	if ti.isKindOf(CM_Container) then
		if ti.CM_Container.monitorConnection = true then
			str := "AM";		//Reefer container
		else
			str := "CN";
		endif;
		isoStr := ti.CM_Container.isoType;
	elseif ti.isKindOf(CM_Generator) then
		str := "RG";
		isoStr := "";		
	else
		str := "AH";		//Indicates cargo is nothing special
		isoStr := "";
	endif;
		
   	if ti.isFull then
       	fullMTStr := "5";
   	else
       	fullMTStr := "4"; 
    endif;   
        	
	iMEXStr := ti.statusToUNEDIFACTCode; 	
			
	//102:5 denotes ISO type
	str := str &amp; "EQD+" &amp; str &amp; "+" &amp; ti.id &amp; "+" &amp; isoStr &amp; ":102:5++" &amp; iMEXStr &amp; "+" &amp; fullMTStr &amp; "'" &amp; CrLf;
		
	if ti.bookingReference.trimBlanks &lt;&gt; null then
		str := str &amp; "RFF+BN:" &amp; ti.bookingReference.trimBlanks &amp; "'" &amp; CrLf;
	endif;
	
	if ti.deliveryRelease.trimBlanks &lt;&gt; null then
		//+DQ denotes delivery note number.
		str := str &amp; "RFF+DQ:" &amp; ti.deliveryRelease.trimBlanks &amp; "'" &amp; CrLf;
	endif;
			
	//STF is not an official code to represent commodity. This is the way
	//my sample file arived, so I have used it for extract too
	str := str &amp; "RFF+STF:" &amp; ti.commodity &amp; "'" &amp; CrLf;

	//Denotes measurement, weight, gross, in kilos
	//str := str &amp; "MEA+WT+G+KGM:" &amp; ti.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;					//-cnwml2 MSL CCMS 1017
	str := str &amp; "MEA+WT+G+KGM:" &amp; ti.totalWeight.asStringWeightJMT() &amp; "'" &amp; CrLf;				//+cnwml2 MSL CCMS 1017

	if ti.isKindOf(CM_Container) then
		cont := ti.CM_Container;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
		if cont.getSealNum.trimBlanks &lt;&gt; null then
			sealNum := cont.getSealNum.trimBlanks;
		//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
		elseif cont.getSealNumCustomsFirst.trimBlanks &lt;&gt; null then
			sealNum := cont.getSealNumCustomsFirst.trimBlanks;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
		elseif cont.getSealNumShipper.trimBlanks &lt;&gt; null then
			sealNum := cont.getSealNumShipper.trimBlanks;
		endif;
	endif;
	
	if sealNum &lt;&gt; null then
		str := str &amp; "SEL+" &amp; sealNum &amp; "'" &amp; CrLf;
	endif;

	if ti.isOverDimensions then
		str := str &amp; "DIM+9+CMT:" &amp; ti.length.asStringMeasurementJMT() &amp; ":" &amp; ti.width.asStringMeasurementJMT() &amp; ":" &amp; ti.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
	endif;
		
	//Also attached equip, num of units, free text, handling instructs
		
	//Transport Sub Group

	voyageObj := ti.myVoyage;
	//if voyageObj.code &lt;&gt; NULL_VOYAGE_CODE then
	if (not voyageObj.isNullVoyage()) then
		str := str &amp; "TDT+20+" &amp; ti.voyageCode &amp; "+1+8+" &amp; voyageObj.myOperator.code &amp; ":172:20+++" &amp; voyageObj.callSign.trimRight &amp; ":103:11:" &amp; ti.vesselName.trimBlanks &amp; "'" &amp; CrLf;
	endif;

	//Transport Details sub group
	if ti.loadPort &lt;&gt; null then
		if ti.myOperator = null then
			str := str &amp; "LOC+9+" &amp; ti.loadPort.trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		else
			str := str &amp; "LOC+9+" &amp; ti.myOperator.getXlationForeignCode(ti.loadPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		endif;
	endif;
	if ti.dischargePort &lt;&gt; null then
		if ti.myOperator = null then
			str := str &amp; "LOC+11+" &amp; ti.dischargePort.trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		else
			str := str &amp; "LOC+11+" &amp; ti.myOperator.getXlationForeignCode(ti.dischargePort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		endif;
	endif;
	int := 0;
	foreach port in ti.allDischargePorts do
		int := int + 1;
		if int = 1 then
			if ti.myOperator = null then
				str := str &amp; "LOC+64+" &amp; ti.allDischargePorts[int].trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			else
				str := str &amp; "LOC+64+" &amp; ti.myOperator.getXlationForeignCode(ti.allDischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			endif;
		elseif int = 2 then
			if ti.myOperator = null then
				str := str &amp; "LOC+68+" &amp; ti.allDischargePorts[int].trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			else
				str := str &amp; "LOC+68+" &amp; ti.myOperator.getXlationForeignCode(ti.allDischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			endif;
		elseif int = 3 then
			if ti.myOperator = null then
				str := str &amp; "LOC+70+" &amp; ti.allDischargePorts[int].trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			else
				str := str &amp; "LOC+70+" &amp; ti.myOperator.getXlationForeignCode(ti.allDischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
			endif;
		else
			break;		//Give up if more than 3
		endif;
	endforeach;
	if ti.destinationPort &lt;&gt; null then
		if ti.myOperator = null then
			str := str &amp; "LOC+83+" &amp; ti.destinationPort.trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		else
			str := str &amp; "LOC+83+" &amp; ti.myOperator.getXlationForeignCode(ti.destinationPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
		endif;
	endif;

	//Name and Address sub group
	if ti.operatorCode &lt;&gt; null then
		str := str &amp; "NAD+OP+" &amp; ti.operatorCode.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;
	if ti.consignee &lt;&gt; null then
		str := str &amp; "NAD+CN+" &amp; ti.consignee.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;
	if ti.consignor &lt;&gt; null then
		str := str &amp; "NAD+CZ+" &amp; ti.consignor.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;		
	return str;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractTIsAsFile" id="1f202b6d-7995-473a-9857-beb8908f43ee">
        <updating/>
        <source>extractTIsAsFile(_ediFile: CM_EDIFile input; pTIs : CM_TISet; pConsigneeCode : String) updating;
/* 
NFS 3833 AJA 23/10/01: Extract the listed TIs as a new COPINO file.
This would get e-mailed to the consignee
*/
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
//	longString	: CM_LongString;
	ediTI		: CM_EDITrackedItem;
//	tisByLocation: CM_EDITIByLocation;
	file		: File;
	operatorOid	: CM_Operator;
	voyageOid	: CM_Voyage;
	now			: TimeStamp;
	ti			: CM_TrackedItem;
	str, fullMTStr, iMEXStr, senderStr : String;
	cont		: CM_Container;
	haz			: CM_Hazard;
	terminal	: CM_Terminal;
begin
	terminal := app.myPassport.myTerminal;
	
	senderStr := terminal.getConfig(PortDestCode).String.trimBlanks;
	
	now := app.actualTimeServer;//getServerTimestamp;
	
	//Not sure what the +114 code signifies
	str := str &amp; "UNB+UNOA:2+" &amp; senderStr &amp; "+" &amp; pConsigneeCode &amp; "+" &amp; now.date.shortYearEDI() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; "114'" &amp; CrLf;
	
	//Document Header Messages
	
	//Message type COPINO, version 00A (yr 2000), compilied by UN committee ITG10
	str := str &amp; "UNH+" &amp; "2" &amp; "+COPINO:D:00A:UN:ITG10'" &amp; CrLf;
	
	//+111 is code for outward cargo movement that has been picked up by an inland carrier
	//Not sure about significance of +1+9
	str := str &amp; "BGM+111+1+9'" &amp; CrLf;
	
	//137 = time of issue of message. :201 = DT format YYMMDDHHMM
	str := str &amp; "DTM+137:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	
	//Group 1: Reference applying to whole document or all items
	//RFF and DTM
	
	//Group 2: Transport Mode and expected date time of arrival
	//TDT &amp; DTM
	
	//+31 = truck. Not sure if other fields should be applied
	str := str &amp; "TDT+1++31'" &amp; CrLf;
	
	//132 = ETA of cargo at consignee (assume instant!). :201 = DT format YYMMDDHHMM
	str := str &amp; "DTM+132:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	
	//Group 3: LOC &amp; DTM: Location of place of arrival and ETA (ignore: we don't know) 
		
	//Group 4: Name and address
	str := str &amp; "NAD+MS+" &amp; senderStr &amp; "'" &amp; CrLf;		//Sender
	
	str := str &amp; "NAD+MR+" &amp; pConsigneeCode &amp; "'" &amp; CrLf;		//Recipient
	
	//Group 5: Contact information (ignore)
	
	//Group 6: Goods items instructions	(temperature in ths case)
	foreach ti in pTIs do
		if ti.isKindOf(CM_Container) then
			cont := ti.CM_Container;
			if cont.monitorConnection = true and 
			   cont.getTemperature &lt;&gt; NULL_TEMPERATURE then
				//Don't think this is really the correct GID message format,
				//but that's how the sample file is laid out
				str := str &amp; "GID+1'" &amp; CrLf;
	
				//Temperature
				if cont.myOperator.displayTempFahrenheit = false then
					if cont.myOperator.getConfig(EDITempFormat).Boolean then //par16227 cnwrs1 mar 2008
						if cont.getTemperature &lt; 0 then
							str := str &amp; "TMP+2+-" &amp; cont.getTemperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
						else
							str := str &amp; "TMP+2+" &amp; cont.getTemperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
						endif;
					else
						str := str &amp; "TMP+2+" &amp; cont.getTemperature.String &amp; ":CEL'" &amp; CrLf;
					endif;
				else
					if cont.myOperator.getConfig(EDITempFormat).Boolean then //par16227 cnwrs1 mar 2008
						if cont.getTemperature &lt; 0 then
							str := str &amp; "TMP+2+" &amp; cont.getTemperature.Integer.positive.stringWithLeadingZeros(3) &amp; "-:FAH'" &amp; CrLf;
						else
							str := str &amp; "TMP+2+" &amp; cont.getTemperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":FAH'" &amp; CrLf;
						endif;
					else
						str := str &amp; "TMP+2+" &amp; cont.temperatureInFahrenheit.String &amp; ":FAH'" &amp; CrLf;
					endif;
				endif;
	
				str := str &amp; "SGP+" &amp; cont.id &amp; "'" &amp; CrLf;
			endif;
		endif;
	endforeach;
	
	//Group 7: Documents relating to the cargo items (ignore)
	
	//Group 8: Dangerous goods
	foreach ti in pTIs do
		if ti.isHazardous then
			str := str &amp; "GID+1'" &amp; CrLf;
	
			foreach haz in ti.allTIHazards do
				if haz.CM_TIHazard.allUNDGCodes.isEmpty then
					str := str &amp; "DGS+IMD+" &amp; haz.code.trimRight &amp; ":+++'" &amp; CrLf;			
				else
					foreach str in haz.CM_TIHazard.allUNDGCodes do
						str := str &amp; "DGS+IMD+" &amp; haz.code.trimRight &amp; ":+" &amp; str &amp; "++'" &amp; CrLf;		
					endforeach;
				endif;
			endforeach;
			
			str := str &amp; "SGP+" &amp; ti.id &amp; "'" &amp; CrLf;
		endif;
	endforeach;
	
	//Group 9: Contact details for hazardous cargo (ignore)
	
	//Group 10: Details of the cargo items
	foreach ti in pTIs do
		str := str &amp; self.extractTIData(ti, _ediFile);
	endforeach;	
	
	//Group 13 Dangerous goods (ignore)
	//Group 14 Contact details &amp; trailer

	//+16 signifies that this segment denotes the number of equipment items
	str := str &amp; "CNT+16:" &amp; (pTIs.size).String &amp;"'" &amp; CrLf;
			
	//Number of code segments
	str := str &amp; "UNT+" &amp; (str.countOccurrences("'")).String &amp; "+1'" &amp; CrLf;
	
	str := str &amp; "UNZ+1+1'" &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
		
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="pTIs" type="CM_TISet"/>
        <Parameter name="pConsigneeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="0c2bb328-2995-4882-b511-fc244eb28f19">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass 	:= CM_EDIDataPrenote;
	_dataType := EDIDataType_Prenote;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACT_FTX" id="e658b3e9-b270-4979-870e-c9b5a2930c3a">
        <source>processEDIFACT_FTX(_msgHelper: CMIF_EDIFACTHelper input; _preNote : CM_EDIPrenoteTI input) protected;
/*

/*

Purpose:	//cnwrd1 par #36639		

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2015	cnwrd1	Initial creation

*/

vars
	text010, commodityDescription, 
	text040			:String;
	ruleFunction 	:Integer;
begin	
	
	_msgHelper.setNextField();				// 010 Text subject qualifier
	
	text010 := _msgHelper.currentField;

	_msgHelper.setNextField();				// 020 Text function coded
	_msgHelper.setNextField();				// 030 Text reference
	_msgHelper.setNextField();				// 040 Text literal

	if text010 &lt;&gt; "AAA" then
		// not one we are expecting
		return;
	endif;
	

	if text010 = "AAA" then 	// goods description
		// store 040 text literal on EDI booking item - ALWAYS
		commodityDescription := _msgHelper.currentSubItem[1:30];
		
		_preNote.commodityDescription := commodityDescription;

	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="input"/>
        <Parameter name="_preNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="5add7849-7e80-4ffb-ae6b-b628d34e1032">
        <updating/>
        <source>processFile(_ediFile : CM_EDIFile input) protected, updating;
// NFS 3833 AA 15/10/01: Process the COPINO message
// 02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 16 Sep 2013 cnwah9 removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
// 27 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	container				: CM_EDIPrenoteTI;
	child					: CM_EDIPrenoteTI;
	ediDataPreNote			: CM_EDIDataPrenote;
	lineStr					: String;
	message					: String;
	tStr					: String;
	voyageCode				: String;
	operatorVoyageCode		: String;				// cnwrl1 19/07/2010 PAR 25046
	lloydsNumber			: String;				// cnwrl1 19/07/2010 PAR 25046
	callSign				: String;				// cnwrl1 19/07/2010 PAR 25046
	vesselName				: String;				// cnwrl1 19/07/2010 PAR 25046
	int						: Integer;
	generatedContainerNo	: Integer;
	transportMode			: String;
	consignorStr			: String;
	transportField			: String;
	carrierCode				: String;
	vehicle					: String;
	wagonNumber				: String;
	group					: Integer;
	tiType					: Integer;
	code					: String;
	containerId				: String;
	temperature				: Real;
	tmpConsignor			: CM_ConsigneeConsignor;
	isoType					: String;
	operatorSenderCode		: String;				// cnwrl1 21/07/2010 PAR 25093
	operatorSender			: CM_Operator;			// cnwrl1 21/07/2010 PAR 25093
	operatorVoyage			: CM_Operator;
	haz						: String;
	undg					: String;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	msgHelper				: CMIF_EDIFACTHelper;
	terminal				: CM_Terminal;
	loadPort				: String;
//	binaryLine				: Binary;
	messageMode				: String;
	untCount : Integer;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
	foundMatch				: Boolean;
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	contRange : CM_ContRange;
	sealNumber : String;
	sealType : String;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport		:=	app.myPassport;
	terminal		:=	passport.myTerminal;
	transportMode	:=	TI_TRANSMODE_ROAD_STR;
	ediDataPreNote	:=	_ediFile.ediData.CM_EDIDataPrenote;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		untCount := untCount + 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
//BGM
		if msgHelper.currentTag = "BGM" then//
			if group = 0 then
				msgHelper.setNextField;
				msgHelper.setNextField;
				msgHelper.setNextField;
				// CCMS1807 cnwrs1 Feb 2009 PAR19528
				if msgHelper.currentField = "1" then
					messageMode := CM_EDITrackedItem.EDI_ACTION_DELETE;
				elseif msgHelper.currentField = "5" then
					messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
				elseif msgHelper.currentField = "9" then
					messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
				else
					// Behaviour as previous 
					 messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
				endif;
			endif;
//CTA
	
//CNT
		elseif msgHelper.currentTag = "CNT" then
			if group = 5 or
			   group = 4 then
				group := 0;
			endif;
		
//DGS
		elseif msgHelper.currentTag = "DGS" then//
			if group = 3 or 
			   group = 4 then	//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
				msgHelper.setNextField;
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField;
					haz := msgHelper.currentSubItem;
					msgHelper.setNextField;
					undg := msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
					container.imCodes.add(haz &amp; ":+" &amp; undg);
				endif;
			endif;
//DIM
		elseif msgHelper.currentTag = "DIM" then//
			if group = 4 then
				msgHelper.setNextField;
				code := msgHelper.currentField;
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "CMT" or
				   msgHelper.currentSubItem = "CM" then //valid baplie 1 still used by some systems
					msgHelper.setNextSubItem;
					container.length := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
					container.width := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
					container.height := msgHelper.currentSubItem.Integer;
				endif;
			endif;
//DTM
	
//EQA
		elseif msgHelper.currentTag = "EQA" then		//Attached equipment
			if group = 4 then
				msgHelper.setNextField;
				
				//Work out cargo type
				tStr := msgHelper.currentField;
				if tStr = "CN" 				//Container
					or tStr = "AJ"			//Flat Rack
					or tStr = "AM"			//Reefer
					or tStr = null then		//No info: set as default
						tiType := TI_CargoType_Container;
				elseif tStr = "RG" then
					tiType := TI_CargoType_Generator;
				else
					//There are a lot of other cargo codes, lump them in as BB type
					tiType := TI_CargoType_BreakBulk;
				endif;

				//Get the cargo ID
				msgHelper.setNextField;
				if msgHelper.currentField.length &gt; 11 then
					containerId := msgHelper.currentField[1:4] &amp; msgHelper.currentField[6:7];
				else
					containerId := msgHelper.currentField;
				endif;
				
				if container &lt;&gt; null and //first time through
				   container.id = null then // if the last container has no id
					//self.addFileErrors("Container has no id, using generated number" &amp; Tab &amp; group.String &amp; Tab &amp; msgHelper.currentMessage, msgHelper.currentMessageNumber, _ediFile );
					generatedContainerNo := generatedContainerNo + 1;
					container.setIdDefault(generatedContainerNo.String);
				endif;
				
				//Create EDI TI and set basic details
				ediDataPreNote.createPrenoteTI(child, containerId);
				child.consignor := consignorStr;
				child.setCargoType(tiType);
				
				if container &lt;&gt; null then
					child.myParent := container;
				endif;	
			endif;
//EQD
		elseif msgHelper.currentTag = "EQD" then	//Equipment Details: Most of the essential stuff
			if group &lt;= 3 or
			   group = 5 then
				group := 4;
			endif;

			if group = 4 then
				msgHelper.setNextField;
				
				//Work out cargo type
				tStr := msgHelper.currentField;
				if tStr = "CN" 				//Container
					or tStr = "AJ"			//Flat Rack
					or tStr = "AM"			//Reefer
					or tStr = null then		//No info: set as default
						tiType := TI_CargoType_Container;
				elseif tStr = "RG" then
					tiType := TI_CargoType_Generator;
				else
					//There are a lot of other cargo codes, lump them in as BB type
					tiType := TI_CargoType_BreakBulk;
				endif;
				
				//Get the cargo ID
				msgHelper.setNextField;
				
				//cnwmc5 - 8 June 2016 - TFS 2121 - changed to use 'msgHelper.currentSubItem'
				//if msgHelper.currentField.length &gt; 11 then
				//	containerId := msgHelper.currentField[1:4] &amp; msgHelper.currentField[6:7];
				//else
				//	containerId := msgHelper.currentField;
				//endif;
				if msgHelper.currentSubItem.length &gt; 11 then
					containerId := msgHelper.currentSubItem[1:4] &amp; msgHelper.currentSubItem[6:7];
				else
					containerId := msgHelper.currentSubItem;
				endif;
				
				if container &lt;&gt; null and //first time through
				   container.id = null then // if the last container has no id
					generatedContainerNo := generatedContainerNo + 1;
					container.setIdDefault(generatedContainerNo.String);
				endif;
				
				//Create EDI TI and set basic details
				ediDataPreNote.createPrenoteTI(container, containerId);
				container.consignor := consignorStr;
				//ccms1077
				tmpConsignor := app.myRoot.allConsigneeConsignors[consignorStr.trimBlanks];
				if tmpConsignor &lt;&gt; null then
					container.customExportEntryNumber := tmpConsignor.derogationNumber;
				endif;
				container.setCargoType(tiType);
				container.transportMode := transportMode;
				if transportMode = null then
					container.transportMode := TI_TRANSMODE_ROAD_STR;
				endif;
				if operatorSender &lt;&gt; null then
					container.carrierCode := operatorSender.getXlationSystemCode(carrierCode, XLATION_TYPE_CARRIER_BYOP, foundMatch)[1:30]; //ccms 1726 cnwrs1 sep 2008
				else
					container.carrierCode := carrierCode[1:30];
				endif;
				// cnwrl1 19/07/2010 PAR 25046 - start of coding
				// Use the operator voyage code translation if it exists.
				voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																	operatorVoyage,
																	voyageCode,
																	vesselName,
																	lloydsNumber,
																	callSign );
//				container.voyageCode := voyageCode; //par23541	// cnwrl1 09/06/2010 PAR 24299 - what it was
				// make sure the manual collection on CM_EDIConfig gets maintained
				container.setVoyageCode( voyageCode );
				container.vehicle := vehicle;
				container.wagonNumber := wagonNumber;
				
				//ISO type
				msgHelper.setNextField;
				//container.isoType := msgHelper.currentSubItem;
				isoType := msgHelper.currentSubItem;
				if operatorSender &lt;&gt; null then
					container.isoType := operatorSender.getXlationSystemCode(isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
				else
					container.isoType := isoType[1:4];
				endif;
				contRange := container.getContRange();
				if contRange &lt;&gt; null then
					if container.isoType = null then
						container.isoType := contRange.isoType;
					endif;
					container.coolingType := contRange.coolingType;
				endif;
				msgHelper.setNextField;
				msgHelper.setNextField;
				
				//IMEX Status
				tStr := msgHelper.currentField;
				if tStr = "2" then
					container.statusString := "Export";
				elseif tStr = "3" then
					container.statusString := "Import";
				else		//The other 12 codes
					container.statusString := "Storage";
				endif;
				msgHelper.setNextField;
				
				//Full or empty
				if msgHelper.currentField = "4" then
					container.fullOrMT := "E";
					container.commodity := terminal.getDefaultEmptyCommodity();		//Default, maybe overwritten
				elseif msgHelper.currentField = "5" then
					container.fullOrMT := "F";
				endif;

				int := int + 1;
				transportMode := null; //ccmw1726 cnwrs1 sep 2008
				consignorStr := null;
				transportField := null;
				carrierCode := null;
//				voyageCode := null; //par 23541		// cnwrl1 20/07/2010 PAR 25046 - what it was
				vehicle := null;
				wagonNumber := null;
				container.messageMode := messageMode;
			endif;
//EQN

//FTX
		elseif msgHelper.currentTag = "FTX" then
		
			self.processEDIFACT_FTX(msgHelper, container);


//GID
		elseif msgHelper.currentTag = "GID" then//
			if group = 2 then
				group := 3;
			endif;
			if group = 3 then
				msgHelper.setNextField;
				if msgHelper.currentField = "1" then
					if msgHelper.currentField.length &gt; 11 then
						containerId := msgHelper.currentField[1:4] &amp; msgHelper.currentField[6:7];
					else
						containerId := msgHelper.currentField;
					endif;
					ediDataPreNote.createPrenoteTI(container, containerId);
					container.consignor := consignorStr;
				endif;
			endif;
//HAN

//LOC
		elseif msgHelper.currentTag = "LOC" then//
			if group = 1 or
			   group = 4 or
			   group = 5 then
				msgHelper.setNextField;
				tStr := msgHelper.currentField;
				if tStr = "11" 
				or tStr = "12"
				or tStr = "64"
				or tStr = "65"
				or tStr = "62"		//These codes are synonymous with discharge port
					then
					msgHelper.setNextField;
					container.dischargePort := msgHelper.currentSubItem[1:5];
				
				elseif tStr = "9" then
					msgHelper.setNextField;
					if container &lt;&gt; null then
						container.loadPort := msgHelper.currentSubItem[1:5];
					else
						loadPort := msgHelper.currentSubItem[1:5];
					endif;
				elseif tStr = "7"
				or tStr = "8" then
					msgHelper.setNextField;
					container.destinationPort := msgHelper.currentSubItem[1:5];				
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then	//Measurements
			if group = 4 then
				msgHelper.setNextField;		
				tStr := msgHelper.currentField;
				if tStr = "WT" or tStr = "AAI" or tStr =  "AAE" or tStr = "CHW" then
					//These codes represent weight		
					msgHelper.setNextField;		//Check for 'G' Gross to be strict
					msgHelper.setNextField;
					if msgHelper.currentSubItem = "KGM" then		//NFS 3833 AA: Look for weight field
						msgHelper.setNextSubItem;
						container.weight := msgHelper.currentSubItem.Integer;
					endif;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then		//Name and address
			if group = 1 then
				group := 2;
			endif;
			if group = 5 then
				group := 4;
			endif;
			if group = 2 then			//Sender &amp; recipient
				msgHelper.setNextField;
				if msgHelper.currentField = "MR" then
					msgHelper.setNextField;
				elseif msgHelper.currentField = "MS" then		//Message sender
					msgHelper.setNextField;
					consignorStr := msgHelper.currentField[1:5];
				endif;
			elseif group = 4 then		//Parties having some connection with the cargo
				msgHelper.setNextField;
				tStr := msgHelper.currentField;
				if tStr = "CF"						// container operator
				or tStr = "OP" then					// equipment operator
					// NOTE: Even though this should be the operatorVoyage set up the operatorSender for compatablity with 7.8.2 etc.
					msgHelper.setNextField;
					/* cnwrl1 26/07/2010 PAR 25093 - what it was
					container.operatorCode := msgHelper.currentSubItem[1:4];
					operator := app.myRoot.allOperators[container.operatorCode];
					cnwrl1 26/07/2010 PAR 25093 - end of what it was */
					
					// cnwrl1 26/07/2010 PAR 25093 - start of replacement coding
					// NOTE: Also fixed the potential bug where only using the first 4 bytes for the translation!
					operatorSenderCode		:= msgHelper.currentSubItem;	// use all characters here chop after translation!
					operatorSenderCode		:= app.myRoot.getXlationSystemOperatorCode( operatorSender, operatorSenderCode, foundMatch)[1:4];
					operatorSender			:= app.myRoot.allOperators[ operatorSenderCode ];
					container.operatorCode	:= operatorSenderCode;
					// cnwrl1 26/07/2010 PAR 25093 - end of coding
					
					// cnwrl1 19/07/2010 PAR 25046 - start of coding
					// Use the operator voyage code translation if it exists.
					voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																		operatorVoyage,
																		voyageCode,
																		vesselName,
																		lloydsNumber,
																		callSign );
					if container.getVoyageCode() &lt;&gt; voyageCode then
						// make sure the manual collection on CM_EDIConfig gets maintained
						container.setVoyageCode( voyageCode );
					endif;
					// cnwrl1 19/07/2010 PAR 25046 - end of coding
				endif;
				if tStr = "CN" or tStr = "ST" then
					msgHelper.setNextField;
					container.consignee := msgHelper.currentSubItem;
                    if container.consignee = null then //cnwgb1 PAR 27580 30.5.2011
                        msgHelper.setNextField;
                        msgHelper.setNextField;
                        container.consignee := msgHelper.currentSubItem;
                    endif;
				endif;
				if tStr = "CZ" or tStr = "SF" then
					msgHelper.setNextField;
					container.consignor := msgHelper.currentSubItem;
				endif;
			endif;
//RNG

//RFF
		elseif msgHelper.currentTag = "RFF" then//
			if group = 4 then
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "STF" then		//commodity element
					msgHelper.setNextSubItem;						
					container.commodity := msgHelper.currentSubItem[1:5];		
					container.commodityDescription := msgHelper.currentSubItem[1:30];
				endif;
				if msgHelper.currentSubItem = "BN" then		//Booking ref element
					msgHelper.setNextSubItem;
					container.bookingRef := msgHelper.currentSubItem[1:30];
				endif;
				//Ignore CU, FF, UCN for the moment which are consignor forwarder references
			endif;
//SEL
		elseif msgHelper.currentTag = "SEL" then		//SEAL: Untested. No sample file available !!
			if group = 4 then
				msgHelper.setNextField;
				sealNumber := msgHelper.currentField;
				msgHelper.setNextField();
				sealType := msgHelper.currentSubItem;
				if sealType = "CA" or sealType = null then
					container.sealNum := sealNumber;
				elseif sealType = "SH" then
					container.sealShipper := sealNumber;
				elseif sealType = "CU" then
					container.customsSeal := sealNumber;
				elseif sealType = "TO" then
					container.sealTerminalOperator := sealNumber;
				else
					container.sealUnknown := sealNumber;
				endif;
			endif;
//SGP
		elseif msgHelper.currentTag = "SGP" then//
			if group = 3 then
				msgHelper.setNextField;
				container.setId(msgHelper.currentField);
			endif;
//TDT
		elseif msgHelper.currentTag = self.TDT then//
			if group = 0 or
			   group = 4 then
				group := group + 1;
			endif;
			if group = 1 or group = 5 then //ccms1726
				msgHelper.setNextField;
				if msgHelper.currentField = "1" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					transportField := msgHelper.currentField;
					//FD for ccms 1068
					if transportField = '2' then
						transportMode := TI_TRANSMODE_RAIL_STR;
						msgHelper.setNextField;
						msgHelper.setNextField;
						carrierCode := msgHelper.currentField; //ccms 1726 sept 2008
						msgHelper.setNextField;
						msgHelper.setNextField;
						msgHelper.setNextField;
						wagonNumber := msgHelper.currentField;
					 else
						transportMode := TI_TRANSMODE_ROAD_STR;
						msgHelper.setNextField;
						msgHelper.setNextField;
						carrierCode := msgHelper.currentField; //ccms 1726 sept 2008
						msgHelper.setNextField;
						msgHelper.setNextField;
						msgHelper.setNextField;
						vehicle := msgHelper.currentField; //ccms 1726 sept 2008
					endif;
				elseif msgHelper.currentField = "20" then		
					//This is the main carriage transport
					//so we assume that the sender means voyage.

					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
													vesselName,
													lloydsNumber,
													callSign );

					// cnwrl1 26/07/2010 PAR 25093 - start of coding
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up.
					if operatorSender = null then
						operatorSender		:= operatorVoyage;
						operatorSenderCode	:= operatorVoyageCode;
					endif;
					// cnwrl1 26/07/2010 PAR 25093 - end of coding
				endif;
			endif;
//TMP
		elseif msgHelper.currentTag = "TMP" then	//Temperature
			if group &lt;= 3 then
				msgHelper.setNextField;
				tStr := msgHelper.currentField;
				if tStr = "1" or tStr = "2" or tStr = "3" then		//Storage, transport and cargo handling temps
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					if msgHelper.currentSubItem = "CEL" then
						container.temperature := temperature;
					elseif msgHelper.currentSubItem = "FAH" then
						container.temperature := app.temperatureConversion(false,temperature);
					endif;
				endif;
			endif;

//UNA

//UNB
		elseif msgHelper.currentTag = self.UNB then
			self.getUNB_ElementData(	msgHelper,
										operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
			ediDataPreNote.setXlationOperator(operatorSender);

//UNH
		elseif msgHelper.currentTag = "UNH" then
			untCount := 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediDataPreNote.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
			//UNH+2+COPINO (format):D:95B (year and version):UN:ITG10
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
		endif;

//UNZ        
	endforeach;
	
	//cnwrd1 par 36639
//	self.doTranslations(_ediFile, null);
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
