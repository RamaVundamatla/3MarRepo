<CollClass name="CM_TIByIdCargoTypeDict" id="13d3f1a3-9f57-418b-8a98-0c1bfd25463d">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TIDictByIdCargoType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tiDicts"/>
    <MemberKey>
        <property name="CM_TrackedItem::id"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_TrackedItem::cargoType"/>
    </MemberKey>
    <JadeMethod name="lookupByIDExactMatch" id="b6c0ecf0-404d-4ca9-87ed-92d676f532ab">
        <source>lookupByIDExactMatch(_id : String; _cargoType : Integer; _passport : CM_Passport; 
			_checkAccess, _includeInTransit : Boolean; _allTIs : Collection input);
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:   
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys    
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpTI	: CM_TrackedItem;
	keyID		: String;
	keyCargoType	: Integer;
	tmpDAC	: CM_DataAccessController;

begin
	if _cargoType &lt;&gt; null then
		tmpTI := self[_id, _cargoType];
		if tmpTI &lt;&gt; null and 
		   (_includeInTransit or (not tmpTI.isInTransitOnShip)) and
		   ((not _checkAccess) or (_checkAccess and tmpTI.canUserAccessSelf(null, tmpDAC, _passport)))
		   then
			_allTIs.add(tmpTI);
		endif;
	else
		iter := self.createIterator();
		self.startKeyGeq(_id, null, iter);
		while iter.next(tmpTI) do
			iter.getCurrentKeys(keyID,keyCargoType); //MTN-35226
			if keyID &lt;&gt; _id then
				break;
			endif;
			if _checkAccess and (not tmpTI.canUserAccessSelf(null, tmpDAC, _passport)) or
			   (not _includeInTransit and tmpTI.isInTransitOnShip) then
				continue;
			endif;
			_allTIs.add(tmpTI);
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_checkAccess" type="Boolean"/>
        <Parameter name="_includeInTransit" type="Boolean"/>
        <Parameter name="_allTIs" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupByIdPartialMatch" id="d188303d-a884-4bbb-9462-748c9e9940c9">
        <source>lookupByIdPartialMatch(_id : String; _cargoType : Integer; _passport : CM_Passport; 
			_checkAccess, _includeInTransit : Boolean; _allTIs : Collection input);
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:  
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpTI	: CM_TrackedItem;
	keyID		: String;
	keyCargoType	: Integer;
	tmpDAC	: CM_DataAccessController;

begin
	
	iter := self.createIterator();
	self.startKeyGeq(_id, _cargoType, iter);
	while iter.next(tmpTI) do
		iter.getCurrentKeys(keyID,keyCargoType); //MTN-35226
		if _id &lt;&gt; null and (not keyID.startsWith(_id))  then
			break;
		endif;
		if _cargoType &lt;&gt; TI_CargoType_Null and keyCargoType &lt;&gt; _cargoType then
			continue;
		endif;
		if _checkAccess and (not tmpTI.canUserAccessSelf(null, tmpDAC, _passport)) or
		   (not _includeInTransit and tmpTI.isInTransitOnShip) then
			continue;
		endif;
		_allTIs.add(tmpTI);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_checkAccess" type="Boolean"/>
        <Parameter name="_includeInTransit" type="Boolean"/>
        <Parameter name="_allTIs" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIdCargoTypeBook" id="b865e1ca-76bb-4312-9b55-e96ba4569dbf">
        <source>lookupTIUsingIdCargoTypeBook(_id : String; _cargoType : Integer; _bookingId : String) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2024	navhn30	Initial creation

*/

vars
	tmpTI	: CM_TrackedItem;
	iter : Iterator;	
begin
	iter := self.createIterator;
	self.startKeyGeq(_id, _cargoType, iter);
	while iter.next(tmpTI) do
		if tmpTI.bookingReference = _bookingId then
			return tmpTI;
		endif;
		if  tmpTI.id &lt;&gt; _id or tmpTI.cargoType &lt;&gt; _cargoType then
			break;
		endif;
	endwhile;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_bookingId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
