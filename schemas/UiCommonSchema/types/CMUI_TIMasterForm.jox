    <JadeMethod name="initTblData" id="fd78381d-e7fe-4cca-bfde-71d51a4302cf">
        <updating/>
        <source>initTblData() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//30 Apr 2018	NDL	TFS 38313
// 15/05/2024	navcs2	MTN-34843 Development - Fleet file Form implementation
//--------------------------------------------------
vars
	entDef	: EntTableDef;
	index	: Integer;
	xmlStr	: String;

begin

	if self.isWagonMaster() then	// 03 Jul 2009	NDL	CCMS 1067
		entDef	:= app.myController.getEntTableDef(ETDef_WagonMasterView);
		self.tblData.setMyDataClass(CM_WagonMaster);
	elseif self.isTILC() or self.isMAFI() then									// 15/05/2024	navcs2	MTN-34843
		entDef	:= app.myController.getEntTableDef(ETDef_TIMasterItemMaint);
		self.tblData.setMyDataClass(CM_TIMasterTILC);
	elseif self.isGenerator() then
		entDef := app.myController.getEntTableDef(ETDef_TIMasterGenSetMain);
		self.tblData.setMyDataClass(CM_TIMasterGenerator);
	else
		entDef := app.myController.getEntTableDef(ETDef_TIMasterContMaint);
		self.tblData.setMyDataClass(CM_TIMasterContainer);
	endif;
	
	// setting columns from XML
	index := self.modeStr.Integer;
	if index = 1 then
		xmlStr := self.xmlStrTblDataGen.trimBlanks;
	elseif index = 2 then
		xmlStr := self.xmlStrTblDataCont.trimBlanks;
	elseif index = 3 then
		xmlStr := self.xmlStrTblDataTrailer.trimBlanks;
	elseif index = 4 then
		xmlStr := self.xmlStrTblDataWagon.trimBlanks;
	endif;
//	if index &lt;= self.xmlStrTblDataArray.size then
//		xmlStr := self.xmlStrTblDataArray[index];
//	endif;
	
	if xmlStr &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromXML(entDef, xmlStr);	
	else	
		self.tblData.setTblDataEntRowsFromDef(entDef);
	endif;
	
	self.myCurrentTiMaster := null; // cnwrd1 par #18152 10.10.08
	self.myCurrentWagonMaster := null;
	
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_None;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	//self.tblData.optimiseColumnWidths( 20,200,30,'');
	/*(minTableWidth,
					 maxTableWidth,
					 defaultColumnWidth : Integer;
					 criticalColumns : String) updating;
	*/
	//fitColumnWidths();
	//cnAdjustColumnWidths();
	
end;</source>
    </JadeMethod>
