    <JadeMethod name="logTxnTypesEnumToString" id="78a744e6-446e-4c39-94a1-75b3b783d1dd">
        <source>logTxnTypesEnumToString(logTxnType : Integer):String;
// ---------------------------------------------------------------------------
// Created:     23 November 2004	cnwhjg1
// ---------------------------------------------------------------------------
vars
	retStr 		: String;
begin
    
    if logTxnType = TRANS_TYPE_REC_ROAD then
    	retStr := app.getErrorString(ReceiveRoad);
    
    elseif logTxnType = TRANS_TYPE_REC_RAIL then 
      retStr := app.getErrorString(ReceiveRail);
    
    elseif logTxnType = TRANS_TYPE_REC_SHIP then 
    	retStr := app.getErrorString(ReceiveShip);
    	
    elseif logTxnType = TRANS_TYPE_REL_ROAD then 
    	retStr := app.getErrorString(ReleaseRoad);
    
    elseif logTxnType = TRANS_TYPE_REL_RAIL then 
    	retStr :=app.getErrorString(Release_Rail);
      
    elseif logTxnType = TRANS_TYPE_REL_SHIP then 
    	retStr := app.getErrorString(ReleaseShip);
  
    elseif logTxnType = TRANS_TYPE_OperatorChange then 
    	retStr := app.getErrorString(Operator_Change);
    
    elseif logTxnType = TRANS_TYPE_ProductCodeChange then 
    	retStr := app.getErrorString(Product_Change);  
    
    elseif logTxnType= TRANS_TYPE_EDIT	then 
    	retStr := app.getErrorString(Edit);
    
    elseif logTxnType = TRANS_TYPE_DISASSEMBLY	then 
    	retStr := app.getErrorString(Disassembly); 	

    elseif logTxnType = TRANS_TYPE_LogNoNumberOffload then 
      retStr := app.getErrorString(No_Number_Offload);
    
    elseif logTxnType = TRANS_TYPE_LogNoNumberRetain then 
    	retStr := app.getErrorString(No_Number_Retain);
    	
    elseif logTxnType = TRANS_TYPE_LogNoNumberSwap then 
    	retStr := app.getErrorString(No_Number_Swap);
    	
    elseif logTxnType = TRANS_TYPE_MOVE then 
    	retStr :=app.getErrorString(Move);

    elseif logTxnType = TRANS_TYPE_REJECT then 
    	retStr := app.getErrorString(Reject_Transactions);
    	    	
    elseif logTxnType = TRANS_TYPE_ReinstateReject then 
    	retStr := app.getErrorString(Re_Instate_Reject);
    	
    else
    	retStr := app.getErrorString(Unknown);
    	
    endif;
	
	return retStr;
end;</source>
        <Parameter name="logTxnType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="logTxnTypesStringToEnum" id="2e97746c-8a1d-4be8-a746-7ead64ccee16">
        <source>logTxnTypesStringToEnum(_logTxnTypeStr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     23 November 2004	cnwhjg1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	retState 		: Integer;
begin
    
    if _logTxnTypeStr =app.getErrorString(ReceiveRoad) then
    	retState := TRANS_TYPE_REC_ROAD;
    
    elseif _logTxnTypeStr = app.getErrorString(ReceiveRail) then 
      retState := TRANS_TYPE_REC_RAIL;
    
    elseif _logTxnTypeStr = app.getErrorString(ReceiveShip) then 
    	retState := TRANS_TYPE_REC_SHIP;
    
    elseif _logTxnTypeStr = app.getErrorString(ReleaseRoad) then 
    	retState := TRANS_TYPE_REL_ROAD;
    
    elseif _logTxnTypeStr = app.getErrorString(Release_Rail) then 
    	retState := TRANS_TYPE_REL_RAIL; 	
    
    elseif _logTxnTypeStr =  app.getErrorString(ReleaseShip) then 
    	retState := TRANS_TYPE_REL_SHIP;
    
    elseif _logTxnTypeStr = app.getErrorString(Operator_Change) then 
    	retState := TRANS_TYPE_OperatorChange;
    
    elseif _logTxnTypeStr = app.getErrorString(Product_Change) then 
    	retState := TRANS_TYPE_ProductCodeChange;
    
    elseif _logTxnTypeStr= app.getErrorString(Edit)	then 
    	retState := TRANS_TYPE_EDIT;
    
    elseif _logTxnTypeStr = app.getErrorString(Disassembly)	then 
    	retState := TRANS_TYPE_DISASSEMBLY;
    	
    	    elseif _logTxnTypeStr = app.getErrorString(No_Number_Offload) then 
    	retState := TRANS_TYPE_LogNoNumberOffload;
    
    elseif _logTxnTypeStr = app.getErrorString(No_Number_Retain) then 
    	retState := TRANS_TYPE_LogNoNumberRetain;
    
    elseif _logTxnTypeStr = app.getErrorString(No_Number_Swap) then 
    	retState := TRANS_TYPE_LogNoNumberSwap;
    
    elseif _logTxnTypeStr =  app.getErrorString(Move) then 
    	retState := TRANS_TYPE_MOVE;
    
    elseif _logTxnTypeStr = app.getErrorString(Reject_Transactions) then 
    	retState := TRANS_TYPE_REJECT;
    
    elseif _logTxnTypeStr = app.getErrorString(Re_Instate_Reject) then 
    	retState := TRANS_TYPE_ReinstateReject;
    
    else
    	retState := -1;
    	
    endif;
	
	return retState;
end;</source>
        <Parameter name="_logTxnTypeStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="maxTableRowExHandler" id="857c6b84-7224-4536-ae3d-ce7108ba4ffe">
        <source>maxTableRowExHandler(_exObj : Exception; _jmtError : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _exObj.errorCode = 14051 then
		if _jmtError = ERR_MAX_TABLE_ROW_EXCEEDED then
			app.raiseCMException(_jmtError, null, null);
		endif;
		return Ex_Abort_Action;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_jmtError" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
