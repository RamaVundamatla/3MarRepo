    <JadeMethod name="shouldAuditProperty" id="a1e36f22-9f93-46ad-9b4f-aab3d0696e4d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = CM_EventType::allEventTransactions.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;
</source>
