<Class name="BGP_ReeferRunnerWSRequest" id="0ed8e0dc-3732-4925-b321-e8941c3ae45f">
    <superclass name="BGP_ExternalWSRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Reefer Runner Integration Web Service&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <Constant name="Message_Visit" id="e27107fe-bfb6-40c1-9e58-8a84bbc95241">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Message_VisitDelete" id="7a3c86ca-2b8a-4ee1-a9a4-b4d6bbd2ed1e">
        <source>4</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Message_WorkOrderConnect" id="9c1481fd-633e-4d22-8feb-c96fb37dc02f">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Message_WorkOrderDisconnect" id="aae8b805-53a6-4ef5-8535-148e8d8af6b9">
        <source>3</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="messageType" id="788775ce-8184-4bda-9e5a-11fb17a08d11">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myTrackedItem" id="774c7e8b-b600-4ead-8c53-bebe4d339186">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWLE" id="8833f78a-6cfb-4399-8a4b-ef0a87da515c">
        <embedded/>
        <type name="CM_WorkListEntry"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="cf0ff125-4f5c-48a8-8707-870e272673ab">
        <updating/>
        <source>action(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	errCode : Integer;
	errTxt : String;
	agent : CM_ReeferRunnerConsumerAgent;

begin
	app.writeLog(method.qualifiedName &amp; Tab &amp; app.cnGetServerTime.formatAsYYYYMMDDHHMMSSMMM &amp; " Start", LogTRACE);
	
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	if self.myTerminal &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);     
	endif;
	
	self.setUser();
	
	create agent transient;
	if not agent.setupFromBGPRequest(self.messageType, self.myTerminal) then
		return true;
	endif;
	
	if self.messageType = self.Message_Visit then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing a PUT Visits message", LogDEBUG);
		agent.sendVisitsMessage(self.myTrackedItem);
	elseif self.messageType = self.Message_VisitDelete then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing a DELETE Visits message", LogDEBUG);
		agent.sendVisitsDeleteMessage(self.myTrackedItem);
	elseif self.messageType = self.Message_WorkOrderConnect then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing a PUT WorkOrder Connect message", LogDEBUG);
		agent.sendWorkOrderMessage(self.myTrackedItem, false);
	elseif self.messageType = self.Message_WorkOrderDisconnect then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing a PUT WorkOrder Disconnect message", LogDEBUG);
		agent.sendWorkOrderMessage(self.myTrackedItem, true);
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Unknown message type - " &amp; self.messageType.String &amp; " - aborting", LogERROR);
	endif;

epilog	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	delete agent;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="f7011928-6873-4495-9060-04842e3ac852">
        <source>getDisplay(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	dispString : String;
	thisString : String;
	ti : CM_TrackedItem;

begin
	dispString := inheritMethod();
	
	if self.myTerminal &lt;&gt; null then
		thisString := self.myTerminal.code;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
	endif;
	
	if self.myWLE &lt;&gt; null and self.myWLE.myTrackedItem &lt;&gt; null then
		ti := self.myWLE.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		if thisString &lt;&gt; null then
			thisString := thisString &amp; Space &amp; Forward_Slash &amp; Space &amp; ti.id;
		else
			thisString := ti.myTerminal.code &amp; Space &amp; Forward_Slash &amp; Space &amp; ti.id;
		endif;
	endif;
	if self.messageType = self.Message_Visit then
		thisString := thisString &amp; Space &amp; "Visit";
	elseif self.messageType = self.Message_VisitDelete then
		thisString := thisString &amp; Space &amp; "Visit Delete";
	elseif self.messageType = self.Message_WorkOrderConnect then
		thisString := thisString &amp; Space &amp; "WorkOrder" &amp; Space &amp; app.getErrorString(ConnectPower);
	elseif self.messageType = self.Message_WorkOrderDisconnect then
		thisString := thisString &amp; Space &amp; "WorkOrder" &amp; Space &amp; app.getErrorString(DisconnectPower);
	endif;
	
	return dispString &amp; Tab &amp; thisString;	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="88d17d5b-430b-4256-a3ff-1d2fe1650f7b">
        <updating/>
        <source>setDetails(_ti : CM_TrackedItem; _messageType : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.myTrackedItem := _ti;
	self.messageType := _messageType;
	if _ti &lt;&gt; null then
		self.myTerminal := _ti.myTerminal;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageType" type="Integer"/>
    </JadeMethod>
</Class>
