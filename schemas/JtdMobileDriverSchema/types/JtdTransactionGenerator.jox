    <JadeMethod name="unexpected" id="618ded57-af0c-4ce3-bc84-be6d36685ba6">
        <source>unexpected(id:Integer; formName,controlName,propName,expected:String; form:Form; control:Window; methName:String):Boolean;

vars
	s,t:String;
begin
	if form = null or not app.isValidObject(form) then
		s:="form "&amp;formName&amp;" is null or invalid";
	endif;
	
	if propName &lt;&gt; "FormNotNull" then
		if control = null or not app.isValidObject(control) then
			s:="control "&amp;controlName&amp;" is null or invalid";
		else
			t:=control.getPropertyValue(propName).String;
			if t &lt;&gt; expected then
				s:="on form "&amp;formName&amp;", "&amp;controlName&amp;"."&amp;propName&amp;" should be '"&amp;expected&amp;"', but it is '"&amp;t&amp;"'";
			endif;
		endif;
	endif;

	if s &lt;&gt; null then
		s:="Error "&amp;id.String&amp;" in "&amp;methName&amp;": "&amp;s;
		app.logMessage(s);
		app.atcgReplayFailure:=true;
		return true;
	else
		return false;
	endif;
end;
</source>
        <Parameter name="id" type="Integer"/>
        <Parameter name="formName" type="String"/>
        <Parameter name="controlName" type="String"/>
        <Parameter name="propName" type="String"/>
        <Parameter name="expected" type="String"/>
        <Parameter name="form" type="Form"/>
        <Parameter name="control" type="Window"/>
        <Parameter name="methName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
