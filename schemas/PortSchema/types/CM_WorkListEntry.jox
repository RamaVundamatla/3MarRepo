    <JadeMethod name="getLocationForDDMove" id="5b50ccab-f952-496e-92fc-3cb2b83ae334">
        <source>getLocationForDDMove(_ti : CM_TrackedItem; _wle : CM_WorkListEntry output) : CM_LocationsController;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 01/12/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	terminal : CM_Terminal;
	fm : CM_FutureMove;
	toLocn : CM_LocationsController;
	tiToCheck : CM_TrackedItem;

begin
	terminal := self.getMyTerminal;
	//if not terminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
	if self.job = null or not self.job.isDirectDeliveryJob then			// TFS 52293
		return null;
	endif;
	
	tiToCheck := terminal.allNotifiedTIsByIdCargoType[_ti.id, _ti.cargoType];
	if tiToCheck = null then
		tiToCheck := _ti;
	endif;
	foreach fm in tiToCheck.allPlannedFutureMoves do 
		//if not fm.myWorkListEntry.isCompleteForJob() then								// TFS 52360
		if fm.myWorkListEntry = null or not fm.myWorkListEntry.isCompleteForJob() then	// TFS 52360
			toLocn := fm.CM_FutureMovePlanned.allLocationsControllers.first;
			_wle := fm.myWorkListEntry;
			break;
		endif;
	endforeach;
	
	return toLocn;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationForMode" id="108dae64-1811-4820-bada-a04f6882113d">
        <source>getLocationForMode(_mode : Integer) : CM_LocationsController;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 Jun 2019	jlgzm1		TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk
// ---------------------------------------------------------------------------
vars
	location	: CM_LocationsController;
	aFutureMove : CM_FutureMove;
	fmIndex : Integer;
	isLoad : Boolean;
	theTI : CM_TrackedItem;
begin

	if self.myBOL &lt;&gt; null and _mode = PLANNING_MODE then
		location := self.myBOL.myPlannedLocation;
	endif;
	if location &lt;&gt; null then
		return location;
	endif;
	
	// tfs42863 start
	if _mode &lt;&gt; REAL_MODE then 
		if self.myFutureMove &lt;&gt; null then
			if _mode = QUEUE_MODE and self.myFutureMove.isKindOf(CM_FutureMoveQueued) then
				location := self.myFutureMove.getPrimaryLocation();
			elseif _mode = PLANNING_MODE then
				location := self.myFutureMove.getPrimaryLocation();
			endif;
		elseif self.myFutureMoveDR &lt;&gt; null then
			if _mode = QUEUE_MODE and self.myFutureMoveDR.isKindOf(CM_FutureMoveQueued) then
				location := self.myFutureMoveDR.getPrimaryLocation();
			elseif _mode = PLANNING_MODE then
				location := self.myFutureMoveDR.getPrimaryLocation();
			endif;
		endif;
	endif;
	// tfs42863 end

	if location &lt;&gt; null then
		return location;
	endif;
	
	theTI := self.myTrackedItem;
//	if theTI &lt;&gt; null then
	if theTI &lt;&gt; null and ( not theTI.canMergeBreakBulk ) then	//16 Sep 2013	NDL	Par 32479
		// ### PAR 10836
		// ### Had to add this in because DLRs can now have only the LOAD part planned. 
		//			If the voyage ops queues the discharge part this code was gettinmg the load planned FM and queueing to the ship
		if _mode = PLANNING_MODE then
			isLoad := not self.isReceipt;
			aFutureMove := theTI.getFutureMovePlanned(isLoad);
			if aFutureMove &lt;&gt; null then
				location := aFutureMove.getPrimaryLocation();
			endif;
		else
			location := theTI.getPrimaryLocation(_mode);
		endif;
	endif;

	return location;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationForWOMove" id="59522a94-8cf6-491b-bfc4-8d95274cc92c">
