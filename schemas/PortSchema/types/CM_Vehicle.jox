    <JadeMethod name="setForUpdate" id="d9474160-cb80-4f98-99d4-6c4dddf5cf44">
        <updating/>
        <source>setForUpdate(pProxyVehicle:CM_Vehicle) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/12/2016 cnwrh7	TFS	3032
// ---------------------------------------------------------------------------
vars
	vehicleController	: CM_VehicleController;
begin
	//self.regNumber 				:= pProxyVehicle.regNumber;											//-TFS3032
	self.regNumber 				:= pProxyVehicle.regNumber.removeTabCrLfs();		//+TFS3032
	self.state								:= pProxyVehicle.state;
	// ccms1035 cnwjk3
	//self.setCode(self.regNumber);
	self.setCode(self.regNumber &amp; self.state);
	self.batNumber 		:= pProxyVehicle.batNumber;
	self.carrier 					:= pProxyVehicle.carrier;
	self.tareKilos				:= pProxyVehicle.tareKilos;
	self.maxGrossLadenWeight	:= pProxyVehicle.maxGrossLadenWeight;
	self.isNotAvailableForEntry := pProxyVehicle.isNotAvailableForEntry;

	if self.locationsController = null then
		create vehicleController persistent;
		self.locationsController := vehicleController;		//Also sets inverse 'vehicle'
	endif;

end;</source>
        <Parameter name="pProxyVehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="setFromRoadJob" id="18a95c64-e132-4703-a4eb-7f88baef43c6">
        <updating/>
        <source>setFromRoadJob(_roadJob : CM_RoadJob) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs2
//
// Purpose:     
// 02 Jan 2025	navnk30		MTN-33172: POL - Truck Carrier changed without Audit Entry
// ---------------------------------------------------------------------------
vars
	tmpCarrier	: CM_Carrier;
	tmpLC		: CM_VehicleController;
	pxyVehicle	: CM_Vehicle;
begin

	if _roadJob = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Parameter roadJob is null');
		return;
	endif;
	
	exclusiveLock(self);
	
	tmpCarrier := _roadJob.myCarrier;
	if self.carrier &lt;&gt; tmpCarrier then
		//self.carrier := tmpCarrier;										//02.01.2025 navnk30 JIRA 33172 START
		pxyVehicle := self.pxyCreateUpdateProxy();
		pxyVehicle.setProxy(self.regNumber,
							self.batNumber,
							self.tareKilos,
							self.maxGrossLadenWeight,
							tmpCarrier,
							self.state,
							self.isNotAvailableForEntry,
							self.myTerminal);
		app.myUtilityUA.utlUpdateVehicle(pxyVehicle, app.myPassport);		//02.01.2025 navnk30 JIRA 33172 END
	endif;
	
	tmpLC := self.locationsController;

	//Set the location of the vehicle to the appointed VTA and check it's valid !!
	
	/*  cnwer1 changed 21/8/2006
	tmpLC.setMyTerminalArea(_roadJob.myTerminal.lookupTerminalArea(_roadJob.roadTransAreaId));
	if tmpLC.myTerminalArea = null then
		app.raiseCMException1(NoParentForController, tmpLC.getFullId, "", null);
	endif;*/

	self.batNumber := _roadJob.batNumber;
	
epilog
	delete pxyVehicle;
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setMyInTerminalJobSheet" id="a6ed214f-a4aa-4886-a564-a3d4ed83393c">
        <updating/>
        <source>setMyInTerminalJobSheet( _value : CM_RoadJobSheet) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myInTerminalJobSheet &lt;&gt; _value then
		self.myInTerminalJobSheet:=_value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_RoadJobSheet"/>
    </JadeMethod>
    <JadeMethod name="setMyPrimaryActualLocation" id="a9a3cf1a-017f-485b-a659-c3def3479eb2">
        <updating/>
        <source>setMyPrimaryActualLocation(_newLocation: CM_YardController; _doLog : Boolean) updating;
/*
Purpose:			
Return Value:		

Date			Who		Reason
05 nov 2008		concms1	Initial creation
18 may 2009		concms1	Par 19715
18 Jun 2013		cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
06 Apr 2023		navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
17 Apr 2023		navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023		navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
*/
vars
	ta					: CM_TerminalArea;
	oldLocation			: CM_YardController;
	oldType, newType	: Integer;
	visitRecord 		: CM_VehicleVisitRecord;
	lastDetail			: CM_VehicleVisitRecordDetail;
	callingMethod		: String;
	
	rjob				: CM_RoadJob;
	wle					: CM_WorkListEntry;
	wsRequest			: BGP_EDBICWSRequest;	// ### TFS 55215 01Dec2022 NAVPW1
	extWebService		: CM_ExternalWebServiceDef;		// TFS 58722
	
begin
	if _newLocation &lt;&gt; null then
		ta := _newLocation.myTerminalArea;
		
		if ta = null or
		//	(not ta.isInterchangeArea and not ta.isGateArea) then
			(not ta.isInterchangeArea and not ta.isGateArea and not ta.isKindOf(CM_CraneTransferArea) ) then	//31 Jan 2013	NDL	Par 31102
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid location for vehicle move');
		endif;
	endif;
	
	visitRecord	 :=	self.visitRecords.last;
	
	// we only want to create a VVRD if out new location type is different to the old type.
	// we don't want 2x gate-in VVRDs but it would be valid to have gate-in, trouble, gate-in
	if visitRecord &lt;&gt; null then
		// get the detail record that will tell us where we are in the terminal
		lastDetail 	:= visitRecord.getCurrentVisitDetailStage();
		
		if lastDetail &lt;&gt; null then
			oldType	:= lastDetail.recordType;
		endif;
	endif;
				
	oldLocation := self.myPrimaryActualLocation;
	
	if _newLocation &lt;&gt; null and _newLocation &lt;&gt; oldLocation then 
		if _newLocation.isAGateLane then
			newType := VisitRecord_Arrive_AGate;
			
		elseif _newLocation.isPGateLane then
			if _newLocation.CM_GateAreaLaneController.isIn then
				newType := VisitRecord_Arrive_PGate_In;
			elseif _newLocation.CM_GateAreaLaneController.isOut then
				newType := VisitRecord_Arrive_PGate_Out;
			endif;	
			
		elseif _newLocation.isTroubleLane then
			if oldLocation &lt;&gt; null and not oldLocation.isTroubleLane then
				newType := VisitRecord_Trouble;
			endif;
		endif;
		//jlier1 58617 19/6/23
		if visitRecord &lt;&gt; null then
			// only create the visit detail record if it is different from the previous visit stage
			if newType &lt;&gt; null and newType &lt;&gt; oldType then			
				visitRecord.createVisitRecordDetail(newType, _newLocation, null);	// par 31670
			endif;
			
			if oldLocation &lt;&gt; null and oldLocation.isAGateLane then //cnwrd1 ccms 1862 par 27435 2.5.2011
				visitRecord.createVisitRecordDetail(VisitRecord_Complete_AGate_In, _newLocation, null);	// par 31670
			endif;
		endif;
		
		// Refactored to make sure gate Complete happens before Yard on single gate 35384
		newType := null;
		if _newLocation.isInsideYard then
			if oldLocation &lt;&gt; null and not oldLocation.isInsideYard then
				newType := VisitRecord_Yard;
			endif;
			
		elseif CM_BlockController.hasInstance (_newLocation) and _newLocation.CM_BlockController.isInTransitTo then
			// the VVRD should have been created from the transaction that moved the vehicle to this location
			// its type is transaction dependant, not location dependant
			if _newLocation.isYardInterchangeAreaLocation then
				newType := VisitRecord_Yard;
			endif;
			// if we are in transit to a gate area then no VVRD gets created
			
		elseif CM_BlockController.hasInstance (_newLocation) and _newLocation.CM_BlockController.isInTransitFrom then
			// we really expect the ready to leave VVRD to be created when the last pickup/dropoff is done
			if _newLocation.isYardInterchangeAreaLocation then
				newType := VisitRecord_Yard;
			endif;
		endif;
		// only create the visit detail record if it is different from the previous visit stage
		if visitRecord &lt;&gt; null then
			if newType &lt;&gt; null and newType &lt;&gt; oldType then			
				visitRecord.createVisitRecordDetail(newType, _newLocation, null);	// par 31670
			endif;
		endif;
		
	endif;
	
	if _newLocation &lt;&gt; null then
		if _newLocation.isInsideYard or
			(_newLocation.isYardInterchangeAreaLocation and 
			(_newLocation.isInTransitTo or _newLocation.isInTransitFrom ))then
			// make them show in the yard pane of the road ops form
			if self.myInTerminalJobSheet = null then
				self.setMyInTerminalJobSheet(self.myTerminal.myRoadJobSheet);
			endif;
		else
			if self.myInTerminalJobSheet &lt;&gt; null then
				// stop them showing on the yard pane in the road ops form
				self.setMyInTerminalJobSheet(null);	
			endif;	
		endif;
	else
		//22 Nov 2017	NDL	TFS 7460
		if _doLog then
			callingMethod := app.getCallingMethod(3);
			app.writeLog("myPrimaryActualLocation set to null for " &amp; self.regNumber &amp; " in " &amp; callingMethod, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		endif;
		if self.myInTerminalJobSheet &lt;&gt; null then
			//22 Nov 2017	NDL	TFS 7460
			if _doLog then
				app.writeLog("myInTerminalJobSheet set to null for " &amp; self.regNumber &amp; " in " &amp; callingMethod, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			endif;
			// stop them showing on the yard pane in the road ops form
			self.setMyInTerminalJobSheet(null);	
		endif;	
	endif;
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Vehicle_Move_Prior), self.myPrimaryActualLocation);
	
	// this part does the actual setting of the location
	inheritMethod(_newLocation, _doLog );
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Vehicle_VTA_Area_Update), self);
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Vehicle_Move_Current), self.myPrimaryActualLocation);
	
	 // ### TFS 52914 02MAR2022 NAVAB1
	rjob := self.getCurrentRoadJob();
	if rjob &lt;&gt; null then
		if app.myPassport.isOpsViewEnabled(self.myTerminal) then
			foreach wle in rjob.workListEntries discreteLock do
				wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, wle);		
			endforeach;
		endif;
	endif;
	
	// ### TFS 55215 10Nov2022 NAVPW1 - START
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_RoadReceivalEDBIC );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC and not app.isJMTUnitTest then		// TFS 58722
		if oldType &lt;&gt; newType and newType = VisitRecord_Yard then
			create wsRequest persistent;
			wsRequest.setDetails(null,										//_trackedItem	: CM_TrackedItem;
									visitRecord,							//_vehicleVisit	: CM_VehicleVisitRecord;
									null, 									//_train		: CM_Train		// TFS 57362
									null,									//_voyage		: CM_Voyage		// TFS 57362
									self.myTerminal,						//_terminal		: CM_Terminal
									BGP_EDBICWSRequest.Type_TruckReceival	//_dataType		: Integer
								);
			wsRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
			
		endif;
	endif;
	// ### TFS 55215 10Nov2022 NAVPW1 - END
	
epilog

end;</source>
        <Parameter name="_newLocation" type="CM_YardController"/>
        <Parameter name="_doLog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="1278bf69-2489-4759-b9cc-9547fd1da1cb">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myTerminal := _terminal;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7b068e89-ee64-4459-8faf-15a1548806dd">
        <updating/>
        <source>setProxy(pRegNumber,
		pBatNumber				: String;
		_tareKilos				: Decimal;
		_maxGrossLadenWeight	: Decimal;
		pCarrier				: CM_Carrier; 
		_state					: String;
		_isNotAvailableEntry	: Boolean;
		_terminal				: CM_Terminal) updating;
// 06/12/2016 cnwrh7	TFS	3032
vars
	vehicleController : CM_VehicleController;
begin

	self.raiseExceptionIfNotTransient(method);

	//self.regNumber := pRegNumber[1:12]; //PAR16155				//-TFS3032
	self.regNumber := pRegNumber[1:12].removeTabCrLfs; 	//+TFS3032
	self.state := _state[1:10];
	// ccms1035 cnwjk3
	//self.setCode(self.regNumber);
	self.setCode(self.regNumber &amp; self.state);
	self.batNumber := pBatNumber[1:4];
	self.carrier := pCarrier;
	self.tareKilos := _tareKilos;
	self.maxGrossLadenWeight := _maxGrossLadenWeight;
	self.isNotAvailableForEntry := _isNotAvailableEntry;
	self.myTerminal := _terminal;
	
end;</source>
        <Parameter name="pRegNumber" type="String"/>
        <Parameter name="pBatNumber" type="String"/>
        <Parameter name="_tareKilos" type="Decimal"/>
        <Parameter name="_maxGrossLadenWeight" type="Decimal"/>
        <Parameter name="pCarrier" type="CM_Carrier"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_isNotAvailableEntry" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setRegNumber" id="5bbcfeec-9fa0-489d-965b-a553d4e4aea9">
        <updating/>
        <source>setRegNumber(_regNumber, _state : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx
16 October 2009	cnwdap1	PAR #21320 Allow change of State with Reg Number
// 06/12/2016 cnwrh7	TFS	3032
*/
vars

begin
	if self.regNumber = _regNumber and self.state = _state then
		return;
	endif;
	if self.state &lt;&gt; _state then
		self.state := _state[1:10];
	endif;
	if self.regNumber &lt;&gt; _regNumber then
		//self.regNumber :=_regNumber[1:12];										//-TFS3032
		self.regNumber :=_regNumber[1:12].removeTabCrLfs();	//+TFS3032
	endif;
	// ccms1035 cnwjk3
	//self.setCode(self.regNumber);
	self.setCode(self.regNumber &amp; self.state);
	
epilog

end;</source>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_state" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateBOLNumber" id="e1f609a7-1b24-45e3-918d-2925298dc46f">
        <source>validateBOLNumber(_transientBOL : CM_BOL);
//--------------------------------------------------------------
//Created: 23 May 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	job : CM_Job;
	bolNum : String;
	req : CM_Request;
	bol				: CM_BOL;
	invalid 		: Boolean;
	
begin
	
	if _transientBOL = null then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, bol, invalid);
	
	foreach job in self.allRoadJobs do
		foreach req in job.allRequests do
			if not req.isKindOf(CM_BOLYardRequest) then
				continue;
			endif;
			
			bol := req.CM_BOLYardRequest.myBOL;
			if bol = null then
				continue;
			endif;
			
//				(not global.isValidObject(req.CM_BOLYardRequest.myBOL)) or
//				req.CM_BOLYardRequest.myBOL = null then
				//continue;
//			endif;

			invalid := false;
			bolNum := bol.number;
			if invalid then
				continue;
			endif;
			
			if _transientBOL.number = bolNum then
				app.raiseCMException2(ERR_DUPLICATE_CHILD, req.CM_BOLYardRequest.myBOL.bolTypeDesc &amp; ' ' &amp; _transientBOL.number, 'vehicle ' &amp; self.regNumber, null, null);
				return;
			endif;
		endforeach;
	endforeach;
			
end;</source>
        <Parameter name="_transientBOL" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="75f128a6-e086-4217-86a4-8e667df0c42a">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myTerminal.vehicles[self.regNumber, self.state] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.regNumber, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="322de53f-c746-4f43-8e99-acbdbbab5a40">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	
begin
	//epr par 11893 14/6/2006
	if self.allRoadJobs.size &gt; 0 then
		//app.raiseCMException2(ERR_CANNOT_DELETE, self.regNumber,"Cannot delete vechicles with road jobs attached",null, null);	
		//cnwjo3 par 25928
		app.raiseCMException1(ERR_CANT_DEL_VEHCILE_JOBS, self.regNumber,null, null);	
	endif;

	//cnwjo3 par 25928
	if self.visitRecords.size &gt; 0 then
		app.raiseCMException1(ERR_CANT_DEL_VEHCILE_VISITS, self.regNumber,null, null);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="46d50311-7d9e-4adb-b552-5fd8ce8a9cb7">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fa11bdf7-62f9-4c5f-be3f-8063c06f3b00">
        <source>validateMe() protected;

vars
	term 	 : CM_Terminal;
	ta   	 : CM_TerminalArea;
	spacePos : Integer;
begin
	if self.regNumber = null then
		app.raiseCMException(Input_required_field_VehRegNum, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.carrier = null then
		app.raiseCMException(Input_required_field_vehCar, null, null);
	endif;
	
	term := self.myTerminal;
	if term = null then
		term := app.myPassport.myTerminal;
	endif;
	if self.batNumber &lt;&gt; null 
	and (not term.batNumbers.includesKey(self.batNumber)) then
		app.raiseCMException2(ERR_FIELD_BATNO, self.batNumber, 'Bat Number', null, null);
	endif;	
	
	/* 
		epr par 30116 22/8/12 reg numbers can't have spaces will cause terminal.findLocation not to find the vehicle	
	*/
	spacePos:=self.regNumber.pos(Space,1);
	if spacePos &gt; 0 then
		app.raiseCMException1(RegNum_cannot_have_space,self.regNumber,null,null);
	endif;
	

	ta := term.allTerminalAreas[self.regNumber];
	if ta &lt;&gt; null then
		app.raiseCMException3(ERR_DUPLICATE_VEHICLE_TA_ID, ta.typeString, term.code, self.regNumber, null, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
