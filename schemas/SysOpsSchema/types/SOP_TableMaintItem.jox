    <JadeMethod name="setupMultiSelect4" id="d7959a3d-4773-4f2d-a4fd-5e3ae8dd931a">
        <source>setupMultiSelect4(_name,
					_list1Name,
					_list2Name : String;
					_collection1,
					_collection2 : Collection; 
					_displayMethod1,
					_displayMethod2 : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2009	cnwer1	Initial creation

*/

vars

begin
	self.myForm.shtMultiSelect4.visible := true;
	
	self.myForm.shtMultiSelect4.caption:=_name;
	if _displayMethod1 &lt;&gt; null then
		self.myForm.mulSelect41.visible:=true;
		self.myForm.mulSelect41.setupControl(_list1Name,_collection1,_displayMethod1);
	endif;

	if _displayMethod2 &lt;&gt; null then
		self.myForm.mulSelect42.visible:=true;
		self.myForm.mulSelect42.setupControl(_list2Name,_collection2,_displayMethod2);
	endif;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_list1Name" type="String"/>
        <Parameter name="_list2Name" type="String"/>
        <Parameter name="_collection1" type="Collection"/>
