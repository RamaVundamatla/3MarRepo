    <JadeMethod name="handleUserInterrupt" id="6f7fbdf5-a533-4942-b1ce-69a3abda88b2">
        <source>handleUserInterrupt(_exc : Exception; _interrupted : Boolean io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		`	Who		Reason
24 June 2023	navmd1	Initial creation

*/

constants
	ProcessInterrupted = 4035;
vars
	ret : Integer;
begin
	ret := Ex_Pass_Back;
	
	if not _exc.continuable then
		return ret;
	endif;
	
	if _exc.errorCode = ProcessInterrupted then
		_interrupted := true;
		return Ex_Resume_Next;
	endif;
	
epilog
	return ret;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_interrupted" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
