    <JadeMethod name="initSearcher" id="93a21fc5-3583-4a75-a8ad-a217a39d8a67">
        <source>initSearcher();
// ---------------------------------------------------------------------------
// Created:	29 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops

vars
	iter			: Iterator;
	typeKey,
	type			: Integer;
	nameKey			: String;
	fileType		: CM_EDIFileType;
	fileTypeDict	: CM_EDIFileTypeByTypeNameDict;
begin
	self.cmbFileType.clear();
	self.cmbFileType.sorted := true;
	
	fileTypeDict := app.myRoot.allEDIFileTypes;
	//cnwmc5 - 11 July 2014 - CCMS 2353 PEN
	//fileType:= fileTypeDict.getAtKeyGeq(EDIFileTypeX12_350_4010, "");
	//if fileType &lt;&gt; null and fileType.type = EDIFileTypeX12_350_4010 then
	//	self.cmbFileType.itemObject[cmbFileType.addItem(fileType.name)] := fileType;
	//endif;
	
	fileType:= fileTypeDict.getAtKeyGeq(EDIFileType_XMLOneStopCust, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileType_XMLOneStopCust then
	//	if fileType.name &lt;&gt; "One Stop Customs" then
	//		self.cmbFileType.itemObject[cmbFileType.addItem("AUS Customs Response")] := fileType;
	//	else
	//		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.name)] := fileType;
	//	endif;
		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.getCustomActionsName)] := fileType; //26 Sep 2018	NDL	TFS 40940
	endif;
	
	fileType:= fileTypeDict.getAtKeyGeq(EDIFileType_CusRes, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileType_CusRes then
	//	if fileType.name &lt;&gt; "CUSRES - Customs Response" then
	//		self.cmbFileType.itemObject[cmbFileType.addItem("NZ Customs Response")] := fileType;
	//	else
	//		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.name)] := fileType;
	//	endif;
		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.getCustomActionsName)] := fileType; //26 Sep 2018	NDL	TFS 40940
	endif;
	//cnwmc5 - 10 July 2013 - CCMS 2353 PEN
	fileType:= fileTypeDict.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileTypeCAMIR_CustomsStatus then
		//self.cmbFileType.itemObject[cmbFileType.addItem("US Customs Status Message")] := fileType;
		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.getCustomActionsName)] := fileType; //26 Sep 2018	NDL	TFS 40940
	endif;

	fileType:= fileTypeDict.getAtKeyGeq(EDIFileType_JMTInternal, ""); // TFS 39133
	if fileType &lt;&gt; null and fileType.type = EDIFileType_JMTInternal then // TFS 39133
	//	self.cmbFileType.itemObject[cmbFileType.addItem("NZ Customs TSW Response")] := fileType; // TFS 39133
		self.cmbFileType.itemObject[cmbFileType.addItem(fileType.getCustomActionsName)] := fileType; //26 Sep 2018	NDL	TFS 40940
	endif; // TFS 39133

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="65a3fea1-dff2-47c7-a193-19970fb8f991">
        <source>inspectObject();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		19 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	int : Integer;
begin
	int := self.tblActions.row;
	
	if int &gt; self.tblActions.fixedRows then
		self.tblActions.accessRow(int).itemObject.inspect;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="ddb826a0-db60-41c9-9e0b-4714c19961f1">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:	05 October 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if keyCode = CMUI_Key_F3 then	
		if not self.frmSearchFType.visible then 
			self.showSearcher();
			return;
		else
			self.hideSearcher();
		endif;
	endif;
	
	if keyCode = CMUI_Key_Esc then
		if self.frmSearchFType.visible then 
			self.hideSearcher();
		endif;
	endif;
	
	if keyCode = CMUI_Key_Enter then
		if self.frmSearchFType.visible then 
			self.btnSearchSearch.click(self.btnSearchSearch);
			return;
		endif;
	endif;
	
	/*if keyCode = CMUI_Key_F11 and shift = 0 then
		self.inspectObject();
		return;
	endif;
	*/
	inheritMethod(keyCode, shift );
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="77b3f192-d08e-4b55-bd70-929af49c7f5e">
        <source>loadTable();
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	ediAction : CM_EDIAction;
	numRows : Integer;
	aRow : Integer;
begin
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	self.tblActions.rows := self.tblActions.fixedRows;
	foreach ediAction in app.myRoot.allEDIActions where ediAction.myEDIFileType.type = self.ediFileType do
		self.tblActions.addItemObject(ediAction, ediAction.getAttributeStringForDefArray(self.tblActions.allTblDataEntRows));
	endforeach;
	self.tblActions.sortColumn[1] := 2;	//27 Sep 2018	NDL	TFS 41141
	self.tblActions.resort;
	
epilog
end;	
	/*numRows := self.tblActions.rows;
	foreach aRow in self.tblActions.fixedRows+1 to numRows do
		self.tblActions.removeItem(self.tblActions.fixedRows+1);
	endforeach;
	
	if self.ediFileType = EDIFileTypeX12_350_4010 then
		foreach ediAction in app.myRoot.allEDIActions do 
			if ediAction.myEDIFileType.type = self.ediFileType then  
				self.tblActions.addItemObject(ediAction, ediAction.getAttributeStringForDefArray(self.tblActions.allTblDataEntRows));
				//self.tblActions.addItemObject( ediAction, ediAction.keyword &amp; Tab &amp; ediAction.description &amp; Tab &amp; ediAction.actionType &amp; Tab &amp; ediAction.getDataDisplay());
			endif;
		endforeach;
	elseif self.ediFileType = EDIFileType_CusRes then
		foreach ediAction in app.myRoot.allEDIActions do 
			if ediAction.myEDIFileType.type = self.ediFileType then  
				self.tblActions.addItemObject( ediAction, ediAction.name &amp; Tab &amp; ediAction.keyword &amp; Tab &amp; ediAction.keyFileSegment &amp; Tab &amp; ediAction.actionType &amp; Tab &amp; ediAction.getDataDisplay());
			endif;
		endforeach;
	endif;
*/</source>
    </JadeMethod>
    <JadeMethod name="mnuCAAudits_click" id="d2fa8942-9e58-4764-ab7a-5a1a2e5e9616">
