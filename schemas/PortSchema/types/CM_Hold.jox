    <JadeMethod name="updateBayLinks" id="c18b2144-7c49-4f8a-a152-0b51a736d738">
        <source>updateBayLinks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwer1	Initial creation 

*/

vars
	bay,forwardBay : CM_Bay;
	holdOrd : Integer;
begin
	foreach bay in self.allBays do
		holdOrd := holdOrd + 1;
		if holdOrd = 1 then
			forwardBay := bay;
			if self.allBays.size = 1 then
				bay.setBayType(BAY_TYPE_SINGLE);
			endif;
		else
			bay.setAftFromForward(forwardBay);
		endif;
	endforeach;	
epilog

end;</source>
    </JadeMethod>
