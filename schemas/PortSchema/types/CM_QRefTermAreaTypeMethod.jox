    <JadeMethod name="create" id="7363482b-747b-4bad-bd69-72d4434d25d0">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);


end;</source>
    </JadeMethod>
    <JadeMethod name="getDependentProperties" id="2bc0781d-99d4-473a-ab92-d9ffc6b048d6">
        <source>getDependentProperties(_dependentPropNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25  Nov 2019 jlger1	Initial creation TFS 47132

*/

vars

begin
	if _dependentPropNames &lt;&gt; null then
		_dependentPropNames.add(CM_TrackedItem::myTerminalArea.name);
	endif;

epilog

end;</source>
        <Parameter name="_dependentPropNames" type="StringArray" usage="input"/>
    </JadeMethod>
