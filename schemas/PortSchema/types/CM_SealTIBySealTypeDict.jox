<CollClass name="CM_SealTIBySealTypeDict" id="01354939-1766-4253-8d64-1cbb5c278523">
    <loadFactor>66</loadFactor>
    <memberType name="CM_SealTI"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="trakitem"/>
    <MemberKey>
        <property name="CM_SealTI::sealType"/>
    </MemberKey>
    <JadeMethod name="getSealTI" id="43c58eda-fe17-4161-b545-853a73907d34">
        <source>getSealTI(_sealType : CM_SealType): CM_SealTI;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation	Par 25608
19 Jun 2025	 jlier1 MTN-34771 - performance improvements this is a dictionary by seal type just get it by key
*/

vars

	seal : CM_SealTI;
	invalidObject : Boolean;
	
begin

	on Exception do app.handleDeletedObject( exception, seal, invalidObject );

	
	seal:=self.getAtKey(_sealType.sealType);
	
	if seal &lt;&gt; null then
		seal.edition();
		if invalidObject then
			return null;
		endif;
	endif;
	
	return seal;
	
epilog

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <ReturnType type="CM_SealTI"/>
    </JadeMethod>
</CollClass>
