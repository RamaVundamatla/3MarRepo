<Class name="CM_WodHMSRequestCancel" id="d3b6bea4-153f-4d7e-a9c1-455e49c13221">
    <superclass name="CM_WorkOrderVoyageDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ImplicitInverseRef name="myWorkOrderToCancel" id="b7be84f4-89e5-4cf8-8e33-ad2562d90d6d">
        <embedded/>
        <type name="CM_WorkOrder"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="actionItems" id="6f5d03f5-6bcf-476d-86e3-572d1a97209e">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work Order Transactions
//
vars
	workOrder : CM_WorkOrder;
	workOrderCode : String;
	invalid : Boolean;
	pxyCancel : CM_WorkOrderVoyage;

begin
	on Exception do app.handleDeletedObject(exception, workOrder, invalid);
	
	// cancel a work order
	workOrder := self.myWorkOrderToCancel;
	if workOrder &lt;&gt; null then
		workOrderCode := workOrder.id;
	endif;
	if workOrder = null or invalid then
		// work order no longer exists or has been deleted
		self.setIsComplete;
		return;
	endif;
	
	pxyCancel := app.createUpdateProxy(self.myWorkOrderToCancel).CM_WorkOrderVoyage;
	pxyCancel.setTaskStatus(WO_STATUS_CANCELLED);
	
	app.myUtilityUA.utlUpdateWorkOrder(pxyCancel, false, _passport);
	
	if _passport.noErrors then
		self.setIsComplete;
		// create appropriate transaction for billing purposes
		//self.createHMSResource(WO_TASK_VOY_HMSREQCANCEL);		// TFS 39165
		self.createWorkOrderTransaction(TRANS_TYPE_WO_CANCEL);		// TFS 39165
	endif;
epilog
	delete pxyCancel;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
