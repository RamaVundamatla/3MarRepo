    <JadeMethod name="loadSetValue" id="c8b68d82-c938-4a0a-857f-6effe54f73f3">
        <source>loadSetValue(_load : Boolean; _entRowName : String) protected;
/* ---------------------------------------------------------------------------
Created:	28 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
15/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
28 Nov 2013		cnwmc5		PAR 33074
------------------------------------------------------------------------------*/
vars
	measure 			: CM_MeasurementType;
begin
	measure := self.myCurrentProdAttr.myMeasurementType;
	
	if _load then	//loading value for control on the screen
		self.txtValue.text := self.myCurrentProdAttr.getDisplayStringForAttribute(_entRowName, true);
		
		if measure&lt;&gt; null and measure.isFeetAndInches then
			self.txtFeetAndInches.text := self.myCurrentProdAttr.getDisplayStringForAttribute(_entRowName, true).asFeetInchesForMask();
		endif;
		
	else	//getting value from the screen
		if measure &lt;&gt; null then
			self.myCurrentProdAttr.setValue(app.convertMeasurementForStorage(measure.shortName, self.txtValue.text.Decimal));
			if measure.isFeetAndInches then
				self.myCurrentProdAttr.setValue(app.convertMeasurementForStorage(measure.shortName, self.txtFeetAndInches.getFeetInches().Decimal));
			endif;
		else
			//epr par 34310  21/7/14 type product attributes can be a string i.e. CM_ProdAttrString so dont cast to decimal
			self.myCurrentProdAttr.setValue(self.txtValue.text);
		endif;
	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="saveDataForProdAttribute" id="08543608-bd32-478e-9ab0-7f930425298b">
        <updating/>
        <source>saveDataForProdAttribute() updating, protected;
/* ---------------------------------------------------------------------------
Created:	29 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
14/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
------------------------------------------------------------------------------*/
vars
	entDef		: EntTableDef;
	entRow		: EntTableRow;
	
begin

	if self.myCurrentProdAttr = null then
		return;
	endif;
	
	entDef := app.myController.getEntTableDef(ETDef_ProdAttrEntry);
	
	foreach entRow in entDef.allEntTableRows do
		
		if entRow.name = ETRow_IsViewable then
			self.loadSetIsViewable(false);
		
		elseif entRow.name = ETRow_DisplayName then
			self.loadSetDisplayName(false, entRow.name);
		
		elseif entRow.name = ETRow_ValidationType then
			self.loadSetValidationType(false);
			
		elseif entRow.name = ETRow_ColumnCode then
			self.loadSetCode(false);

		elseif entRow.name = ETRow_Range then
			self.loadSetRange(false, entRow.name);
		
		elseif entRow.name = ETRow_Value then
			self.loadSetValue(false, entRow.name);
		
		elseif entRow.name = ETRow_Multiplier then
			self.loadSetMultiplier(false, entRow.name);
		
		elseif entRow.name = ETRow_DisplayValue then
			self.loadSetDisplayValue(false, entRow.name);
		
		elseif entRow.name = ETRow_MeasurementType then					// PAR #31155
			self.loadSetMeasurementType(false, entRow.name);			// PAR #31155
			
		endif;
		
	endforeach;
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCmbCode" id="7c187837-5c94-4518-aa69-8aa112fe4544">
        <source>setCmbCode() protected;
/* ---------------------------------------------------------------------------
Created:	28 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	code	: CM_ProductAttributeCode;
	idx		: Integer;

begin

	self.cmbCode.clear();

	if self.myCurrentProdAttr.validationType &lt;&gt; self.myCurrentProdAttr.ValidationType_Codes then
		return;
	endif;
	
	self.cmbCode.addItem(Any_String);
	self.cmbCode.addItem(EditCodeString);
	
	idx := 2;
	foreach code in self.myCurrentProdAttr.allCodes do
		idx := idx + 1;
		self.cmbCode.addItem(code.code &amp; ' - ' &amp; code.description);
		self.cmbCode.itemObject[idx] := code;
	endforeach;

	if self.myCurrentProdAttr.validationType = CM_ProductAttr.ValidationType_Codes then
		code := self.myCurrentProdAttr.myCode;
		if code &lt;&gt; null then
//			cmbCode.listObject :=  code;
			// changed to this as if selected code has been changed in code edit, then an exception occurs. 
			cmbCode.listIndex := cmbCode.findObject(code);
			//table.setCellText(table.row, table.getColumnByRowName(ETRow_ColumnCode), code.code);
		else
			cmbCode.listIndex := 1;
			//table.setCellText(table.row, table.getColumnByRowName(ETRow_ColumnCode), Any_String);
		endif;
	endif;

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCmbMeasureType" id="6ebc1baf-8f0b-40c6-834c-8be38e9f11a7">
        <updating/>
        <source>setCmbMeasureType(_entRowName : String) protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
11/06/2013	cnwdap1	PAR #31767 Clear measurement combo regardless
20/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
*/
vars
	defaultType, measureType	: CM_MeasurementType;
	idx, default	 			: Integer;

begin
	self.cmbMeasureType.clear;								// PAR #31767
	if _entRowName = null then
//		self.cmbMeasureType.clear;							// PAR #31767
		self.cmbMeasureType.enabled := false;
		return;
	endif;
	
	self.cmbMeasureType.enabled := true;
	if _entRowName = ETRow_MyWeight then
		defaultType := app.getDefaultMeasurementForType(Type_Weight);
	elseif _entRowName = ETRow_MyVolume then
		defaultType := app.getDefaultMeasurementForType(Type_Volume);
	elseif _entRowName = ETRow_MyDensity then
		defaultType := app.getDefaultMeasurementForType(Type_Density);
	elseif _entRowName = ETRow_MyLength then
		defaultType := app.getDefaultMeasurementForType(Type_Length);
	elseif _entRowName = ETRow_MyWidth then
		defaultType := app.getDefaultMeasurementForType(Type_Width);
	elseif _entRowName = ETRow_MyHeight then
		defaultType := app.getDefaultMeasurementForType(Type_Height);
	elseif _entRowName = ETRow_MyStowageFactor then								// PAR #33606
		defaultType := app.getDefaultMeasurementForType(Type_StowageFactor);	// PAR #33606
	endif;
	
	foreach measureType in app.myRoot.allMeasurementTypesByShortName where measureType.isAvailableForEntry and measureType.isDisplay do
		if measureType.measurementType = defaultType.measurementType then
			idx := self.cmbMeasureType.addItem(measureType.measurementType &amp; " - " &amp; measureType.shortName);
			self.cmbMeasureType.itemObject[idx] := measureType;
			if defaultType = measureType then
				default := idx;
			endif;
		endif;
	endforeach;
	
	if default &lt;&gt; null then
		self.cmbMeasureType.listIndex := default;
		self.cmbMeasureType_click(self.cmbMeasureType);
	else
		self.cmbMeasureType.listIndex := 1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
