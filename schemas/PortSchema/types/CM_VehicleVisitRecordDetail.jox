    <JadeMethod name="isCargoMove" id="ea0d4483-ca41-47c8-8837-f71108c81b8b">
        <source>isCargoMove():Boolean;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.recordType = VisitRecord_CargoPlaced or
		self.recordType = VisitRecord_CargoRemoved or
		self.recordType = VisitRecord_CargoDiscrepancy; //epr par 33221 3/3/2014
epilog

