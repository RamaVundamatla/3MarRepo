    <JadeMethod name="buildWorkOrderMenu" id="7c18951b-fbd6-45f9-8db7-3015b0361776">
        <updating/>
        <source>buildWorkOrderMenu( _woSet : CM_WorkOrderSet) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwrd1	Initial creation

*/

vars
	mnuChild,
	mnuMaster,
	mnuShowWO,
	mnuShowSched : MenuItem;
	mnuIndex : Integer;	
	workOrder : CM_WorkOrder;
	showMenu : Boolean;
begin

	showMenu := false;
	
	mnuMaster := self.mnuWorkOrderMain;
	//mnuShowWO := self.mnuWorkOrderStub;
	//mnuShowSched := self.mnuShowWorkOrderSched;
	
	//mnuMaster.visible := false;
	//mnuMaster.enabled := false;
	//mnuMaster.userObject := _wle;
	self.mnuWorkOrderStub.visible := false;

	
	
	foreach workOrder in _woSet do
			
			//clone main work order menu
			showMenu := true;
			mnuIndex := mnuIndex + 1;
			mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
			endif;
			mnuChild.caption := app.getErrorString(WorkOrder) &amp; workOrder.id;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			
			//clone child menus

			mnuIndex := mnuIndex + 1;
			mnuShowWO := mnuChild.getMenuItem(mnuIndex); // check if the menu is already cloned
			if mnuShowWO = null then
				mnuShowWO := mnuChild.loadSubMenu( mnuIndex );
			endif;				
			mnuShowWO.caption := self.mnuShowWorkOrder.caption;			
			mnuShowWO.userObject := workOrder;
			mnuShowWO.visible := true;
			mnuShowWO.enabled := true;
			mnuShowWO.setEventMapping("click", "mnuShowWorkOrder_click");
			
			mnuIndex := mnuIndex + 1;
			mnuShowWO := mnuChild.getMenuItem(mnuIndex); // check if the menu is already cloned
			if mnuShowWO = null then
				mnuShowWO := mnuChild.loadSubMenu( mnuIndex );
			endif;				
			mnuShowWO.caption := self.mnuShowWorkOrderSched.caption;			
			mnuShowWO.userObject := workOrder;
			mnuShowWO.visible := true;
			mnuShowWO.enabled := true;
			mnuShowWO.setEventMapping("click", "mnuShowWorkOrderSched_click");	
	endforeach;
	
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	

	self.mnuWorkOrderMain.visible := false;
	
epilog

end;
</source>
        <Parameter name="_woSet" type="CM_WorkOrderSet"/>
    </JadeMethod>
    <JadeMethod name="clearRowOnSchedule" id="3f7c2e66-ad28-43ac-a367-606adaaa76cd">
        <source>clearRowOnSchedule(_rowDT : TimeStamp);
// -----------------------------------------------------------------------------
// Created:		21 August 2009 by consw1
//
// Purpose:		Clear all values for row
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	oldNumber : Integer;
	tbl : CM_BaseTable;
	
begin
	tbl := self.tblSchedule;
	
	row := tbl.rows;
	
	while row &gt; tbl.fixedRows and _rowDT &lt; self.getScheduledDT(row) do
		row := row - 1;
	endwhile;
	
	if row &lt;= tbl.fixedRows or _rowDT &lt;&gt; self.getScheduledDT(row) then
		return;
	endif;
	
	col := tbl.fixedColumns + 1;
	
	while col &lt; tbl.columns do
		oldNumber := tbl.accessCell(row, col).text.asIntegerJMT();
		tbl.accessedCell.text := null;
		tbl.accessedCell.itemObject := null;
		if self.tblSummary.accessCell(self.TotalRow, col).text &lt;&gt; null then
			self.tblSummary.accessedCell.text := (self.tblSummary.accessedCell.text.asIntegerJMT() - oldNumber).asStringJMT();
		endif;
		col := col + 1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_rowDT" type="TimeStamp"/>
    </JadeMethod>
