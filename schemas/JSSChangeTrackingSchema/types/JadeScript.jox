    <JadeMethod name="updateAuditLogNumber" id="310c5a55-b4ce-4b7d-a876-5deaf8e2e41d">
        <updating/>
        <source>updateAuditLogNumber() updating;

vars
	mgr, mgrT: JSSCTNibblerManager;
	num: Integer;
begin

	mgr := JSSCTNibblerManager.firstInstance;

	if mgr &lt;&gt; null then
		num := mgr.lastAuditFileNumber;
		beginTransaction;
		exclusiveLock (mgr);
		mgr.setPropertyValue("lastAuditFileNumber", 53663);
		mgr.setPropertyValue("lastJade5Log", 0);
		commitTransaction;
//		mgr.inspect;

		write "audit number was "&amp;num.String&amp;" is now  " &amp; mgr.lastAuditFileNumber.String;
	else
	 	write "Nibbler manager not found";
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeChangeTrackingObject" id="a7fe4c60-1e31-4098-b858-344eb4386601">
        <source>writeChangeTrackingObject();

vars
	file: File;
	obj: Object;
	oid: String;
	changeClass: JSSCTChangeTrackingClass;
	changeInstance: JSSCTChangeTrackingObject;

begin

	read oid;

	create file;
	//file.fileName := 'c:\temp\KCDPDAVE time' &amp; app.relativeMachineTime.String.padLeadingZeros(18) &amp; '.log';
	file.fileName := 'c:\temp\JSSCT oid ' &amp; oid &amp;  '.log';
	file.mode := File.Mode_Output;

	changeClass := JSSCTChangeTrackingRoot.firstInstance.allChangeClasses["DVPickupSchedule", false];
	if changeClass &lt;&gt; null then
		changeInstance := changeClass.allChangesByOid[oid];
		if changeInstance &lt;&gt; null then
			file.writeLine("Created " &amp; changeInstance.creationTime.String &amp; CrLf &amp; changeInstance.display);
		else
			file.writeLine("Object not tracked " &amp; oid);
		endif;
	else
		file.writeLine("class not tracked");
	endif;
	file.close;

epilog
	delete file;
end;</source>
    </JadeMethod>
</Class>
