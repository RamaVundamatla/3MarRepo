    <JadeMethod name="splitShipNameToTwoStrings" id="6469c490-2b29-47b5-ba3d-a31f4b35f44c">
        <updating/>
        <source>splitShipNameToTwoStrings(_shipName:String; _partA:String io; _partB:String io) updating;

vars
	midPosn:			Real;
	tmpStr:				String;
	shipName:			String;
	shipNameLen:		Integer;
	locnOfFirstSpace:	Integer;
	posn:				Integer;
	spaceAtPos:			Integer;
	spaceNrHalfOnLeft:	Integer;
	spaceNrHalfOnRight:	Integer;
	weightingLHS:		Real;
	numOfSpaces:		Integer;
begin
  	// This method takes a string of the ship's name and 
  	// splits it into two strings (if appropriate) for 
  	// display on the main graphical view

  	shipName:=_shipName.trimBlanks;
  	shipNameLen:=shipName.length;
  	midPosn:=shipNameLen/2;
  	spaceNrHalfOnLeft:=0;
  	spaceNrHalfOnRight:=shipNameLen;
  	weightingLHS:=1.5;	// LHS bias - 150%

  	// Find location of space in string
  	numOfSpaces:=0;
  	posn:=1;
  	while posn&gt;0 and posn&lt;=shipNameLen do
  		posn:=shipName.pos(" ",posn);
  		if posn&gt;0 then
  			if locnOfFirstSpace=0 then
  				locnOfFirstSpace:=posn;
  			endif;
  			numOfSpaces:=numOfSpaces+1;
  			if posn&lt;=midPosn and posn&gt;=spaceNrHalfOnLeft then
  				spaceNrHalfOnLeft:=posn;
  			elseif posn&gt;midPosn and posn&lt;spaceNrHalfOnRight then
  				spaceNrHalfOnRight:=posn;
  			endif;
  			posn:=posn+1;	
  		endif;
  	endwhile;

  	if numOfSpaces&gt;0 then
  		// One or more spaces in name
  		if numOfSpaces=1 then
  			// Only one space
  			spaceAtPos:=locnOfFirstSpace;
  			if spaceAtPos&lt;=3 then
  				// Don't split string - first word is less than 2 chars
  				_partA:=shipName;
  			else
  				// Split string at space (if reqd)
  				if spaceAtPos+1&gt;=shipNameLen then
  					// Space at end - dont split string
  					_partA:=shipName;
  				else	
  					_partA:=shipName[1:spaceAtPos];
  					_partB:=shipName[spaceAtPos+1:end];
  				endif;
  			endif;
  		else
  			// Two or more spaces
  			if spaceNrHalfOnLeft=0 and spaceNrHalfOnRight&lt;shipNameLen then
  				// CASE A: No spaces to left of halfway 
  				_partA:=shipName[1:spaceNrHalfOnRight];
  				_partB:=shipName[(spaceNrHalfOnRight+1):end];
  			elseif spaceNrHalfOnLeft&gt;0 and spaceNrHalfOnRight=shipNameLen then
  				// CASE B: No spaces to right of halfway
  				_partA:=shipName[1:spaceNrHalfOnLeft];
  				_partB:=shipName[(spaceNrHalfOnLeft+1):end];
  			elseif spaceNrHalfOnLeft&gt;0 and spaceNrHalfOnRight&lt;shipNameLen then
  				// CASE C: Spaces either side of halfway - select space
  				// closest to halfway with a bias towards the LHS
  				if midPosn-spaceNrHalfOnLeft&lt;=((spaceNrHalfOnRight-midPosn)*weightingLHS) then
  					// Split at LHS space
  					_partA:=shipName[1:spaceNrHalfOnLeft];
  					_partB:=shipName[(spaceNrHalfOnLeft+1):end];
  				else
  					// Split at RHS space
  					_partA:=shipName[1:spaceNrHalfOnRight];
  					_partB:=shipName[(spaceNrHalfOnRight+1):end];
  				endif;
			else
  				_partA:=shipName;	
  			endif;
  		endif;

  	else
  		// No spaces in name - return shipName in string A
		_partA:=shipName;
  	endif;

end;</source>
        <Parameter name="_shipName" type="String"/>
        <Parameter name="_partA" type="String" usage="io"/>
        <Parameter name="_partB" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="1b1fecb2-be1a-4f3f-8d3b-bbef1aa4102e">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	create self.myLaycanPic transient;
	
	cntrl.autoRedraw	:= true;
	cntrl.drawWidth		:= 2;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="z_colourSelectedMovement" id="0bced4a8-a89c-492b-a38a-951611e42db1">
        <updating/>
        <source>z_colourSelectedMovement(	_selectedMovement : CMIF_HMS_WorkingMovement;
						_scrollToSelected : Boolean;
						_allRestrictedObj:CMIF_HMS_WorkingVoyageSet)updating, protected;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin

	// draw the indicator bar across the top or bottom of the sprite to indicate the selected movement (selected either by
	// mousedown or selection from a text view)
	if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myNextWorkingMovement = _selectedMovement then
			
			if _selectedMovement.moveType = HMSMovementTypeArrival then
				self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Red);
				
			elseif _selectedMovement.moveType = HMSMovementTypeShift then
				if self.myNextWorkingMovement = _selectedMovement then
					self.drawLine(0, 1, self.width, 1, Red);
				else
					self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Red);
				endif;
				
			elseif _selectedMovement.moveType = HMSMovementTypeDeparture then
				self.drawLine(0, 1, self.width, 1, Red);
			endif;		

		endif;
	endif;

	workingVoyage := self.myWorkingMovement.myWorkingVoyage;	
	if workingVoyage &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement 
		or self.myNextWorkingMovement = _selectedMovement 
		or (_selectedMovement &lt;&gt; null and workingVoyage.allWorkingMovements.includes(_selectedMovement)) then

			self.backColor := MovementIsSelected;
			if self.myWorkingMovement.myPersistentMovement = null then
				self.backColor := Yellow;
			endif;			
			if self.myWorkingMovement = _selectedMovement 
			or self.myNextWorkingMovement = _selectedMovement then						
				self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
			endif;

			if _scrollToSelected then
				self.myGraphicalViewForm.scrollToSelectedSprite(self);
			endif;
		else
			if self.myWorkingMovement.notYetSaved then
				self.backColor := MovementNotYetSaved;
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor := Mauve;
				endif;
			
			elseif self.myNextWorkingMovement &lt;&gt; null // PAR11586
			and self.myNextWorkingMovement.notYetSaved then
				self.backColor := MovementNotYetSaved;			
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor := Mauve;
				endif;
												
			elseif workingVoyage.voyageStatus = HMS_VoyageIsLocked then  	
				self.backColor := White;

			elseif workingVoyage.myHMSVoyageData.excludeReport then
				self.backColor := VoyageConfidential;
			
			elseif workingVoyage.myHMSVoyageData.getStatusForVoyage = Voyage_Status_Closed then
				self.drawFillColor := DarkGray;
				self.drawFillStyle := self.DrawFillStyle_DownDiagonal;
				self.backColor := MovementIsSaved;				
				self.drawFilledRectangle(-2, -2, self.width, self.height, DarkGray);

			else	
				self.backColor := MovementIsSaved;
			endif;
		endif;	
	else
		self.backColor := Red;		
		self.drawTextAt(method.name &amp; ' Voyage missing', 0, self.height/2, White);
	endif;

	// if there is a user requirement to keep working with a particular movement, set up the selectedShip indicator
	/*if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement 
		or self.myWorkingVoyage.code = _selectedMovement.myWorkingVoyage.code
		or self.myNextWorkingMovement = _selectedMovement then
			self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
		endif;
	endif;*/	
end;</source>
        <access>protected</access>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
    <JadeMethod name="z_colourSelectedMovementNew" id="7a4897e4-aec1-47f2-b315-33abcc972461">
        <updating/>
        <source>z_colourSelectedMovementNew(	_selectedMovement : CMIF_HMS_WorkingMovement;
							_scrollToSelected : Boolean;
							_allRestrictedObj:CMIF_HMS_WorkingVoyageSet) updating, protected;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//
// This method controls the eventual colors of the
// sprite.  There is a default selected or unselected
// color.  For Comalco, the default unselected color
// comes from the color defined on the applicable
// CM_Voyage object.
//
// Once the default color is set, then "voyage state"
// colors are applied to indicate the current state
// of the Voyage - generally the Voyage won't have a
// state, so the Voyage will retain its default color.
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	workingVoyageObj	: CMIF_HMS_WorkingVoyage;
	voyageObj			: CM_Voyage;
	voyageHeight		: Real;
	//laycanTop			: Real;
	
begin
	if _selectedMovement &lt;&gt; null then
		self.laycanHeight	:=	_selectedMovement.getLaycanDifference () / self.myGraphicalViewForm.minutesPerPixel;
	endif;
	
	voyageHeight	:=	self.height - self.laycanHeight;
	//laycanTop		:=	self.height - self.laycanHeight;
	
	// draw the indicator bar across the top or bottom of the sprite to indicate the selected movement (selected either by
	// mousedown or selection from a text view)
	if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myNextWorkingMovement = _selectedMovement
		then
			if _selectedMovement.moveType = HMSMovementTypeArrival then
				self.drawLine(0, voyageHeight - self.drawWidth, self.width, voyageHeight - self.drawWidth, Red);
				
			elseif _selectedMovement.moveType = HMSMovementTypeShift then
				if self.myNextWorkingMovement = _selectedMovement then
					self.drawLine(0, 1, self.width, 1, Red);
				else
					self.drawLine(0, voyageHeight - self.drawWidth, self.width, voyageHeight - self.drawWidth, Red);
				endif;
				
			elseif _selectedMovement.moveType = HMSMovementTypeDeparture then
				self.drawLine(0, 1, self.width, 1, Red);
			endif;

		endif;
	endif;

	workingVoyageObj	:=	self.myWorkingMovement.myWorkingVoyage;
	
	if self.myWorkingMovement.myHMSVoyageData &lt;&gt; null then
		voyageObj	:=	self.myWorkingMovement.myHMSVoyageData.myVoyage;		// cnwdad1 02/02/2007.
	endif;
	
	if workingVoyageObj &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myNextWorkingMovement = _selectedMovement
		or (_selectedMovement &lt;&gt; null and workingVoyageObj.allWorkingMovements.includes(_selectedMovement))
		then
			// Set the default color for a selected Voyage, then apply any applicable "voyage state" color.
			
			self.backColor	:=	MovementIsSelected;
			
			if self.myWorkingMovement.myPersistentMovement = null then
				self.backColor	:=	Yellow;
			endif;
			
			if self.myWorkingMovement = _selectedMovement
			or self.myNextWorkingMovement = _selectedMovement
			then
				self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
			endif;

			if _scrollToSelected then
				self.myGraphicalViewForm.scrollToSelectedSprite(self);
			endif;
		else
			// Set the color for an unselected Voyage.  For Comalco, the default color will come from that
			// defined on the CM_Voyge object, then any "voyage state" colors will be applied if required.
			
			if voyageObj &lt;&gt; null then
				self.backColor	:=	voyageObj.colour;		// cnwdad1 02/02/2007.
			endif;
			
			if self.myWorkingMovement.notYetSaved then
				self.backColor	:=	MovementNotYetSaved;
				
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor	:=	Mauve;
				endif;
			
			elseif self.myNextWorkingMovement &lt;&gt; null // PAR11586
			and self.myNextWorkingMovement.notYetSaved
			then
				self.backColor	:=	MovementNotYetSaved;
				
				if self.myWorkingMovement.myPersistentMovement = null then
					self.backColor	:=	Mauve;
				endif;
				
			elseif workingVoyageObj.voyageStatus = HMS_VoyageIsLocked then
				self.backColor	:=	White;
				
			elseif workingVoyageObj.myHMSVoyageData.excludeReport then
				self.backColor	:=	VoyageConfidential;
			
			elseif workingVoyageObj.myHMSVoyageData.getStatusForVoyage = Voyage_Status_Closed then
				self.drawFillColor	:=	DarkGray;
				self.drawFillStyle	:=	self.DrawFillStyle_DownDiagonal;
				self.backColor		:=	MovementIsSaved;
				self.drawFilledRectangle(-2, -2, self.width, voyageHeight, DarkGray);
				
			else
				self.backColor	:=	MovementIsSaved;
			endif;
			
			if self.backColor = MovementIsSaved and _allRestrictedObj.includes(workingVoyageObj) then
				self.backColor	:= DarkGray;
			endif;
		endif;
	else
		self.backColor	:=	Red;
		self.drawTextAt(method.name &amp; ' Voyage missing', 0, voyageHeight/2, White);
	endif;
	// if there is a user requirement to keep working with a particular movement, set up the selectedShip indicator
	/*if _selectedMovement &lt;&gt; null then
		if self.myWorkingMovement = _selectedMovement
		or self.myWorkingVoyage.code = _selectedMovement.myWorkingVoyage.code
		or self.myNextWorkingMovement = _selectedMovement
		then
			self.myGraphicalViewForm.setCurrentSelectedDragPicture(self, null, self.left, self.top);
		endif;
	endif;*/
end;</source>
        <access>protected</access>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
    <JadeMethod name="z_colourSelectedSprite" id="bbc953a1-fc16-4d76-b3b7-0ace804401c5">
        <updating/>
        <source>z_colourSelectedSprite(	_selectedMovement : CMIF_HMS_WorkingMovement;
						_scrollToSelected : Boolean;
						_allRestrictedObj:CMIF_HMS_WorkingVoyageSet) updating;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	yPos,
	h : Real;
	workingMove : CMIF_HMS_WorkingMovement;
	nextWorkingMove : CMIF_HMS_WorkingMovement;
	shipNamePartA,
	vesselName,
	shipNamePartB,
	eta,
	vesselRemarks : String;
	drawETA : Boolean;
	bowColour : Integer;
	
begin
	// use this method to dynamically label controls and draw the coloured bar onto the sprite that shows which movement has been selected
	self.visible := false;
	self.clearGraphics;
	self.autoRedraw			:= true;
	self.drawTextAlign 		:= DrawTextAlign_Left;
	self.drawFontName		:= 'Arial';
	self.drawFontSize		:= 8;
	self.drawFillColor		:= Red;
	self.drawWidth			:= 4;

	// rename the sprite with the ships name - top and bottom
	workingMove := self.myWorkingMovement;
	
	if workingMove = null then
		return;
	endif;	
	
	vesselName := workingMove.myWorkingVoyage.myHMSVoyageData.vesselName;
	eta := workingMove.myWorkingVoyage.arrivedDT.Date.format("dd/MM");
	h := self.drawTextHeight(vesselName);

	if workingMove.moveType = HMSMovementTypeShift then
		//Ship's first movement was before this, so draw in date of ETA
		drawETA := true;
	else
		drawETA := false;
	endif;

	if self.height &gt; ((2 * h) + (1)) then // NB 1 pixel offsets at top
		// Enough room for two labels if required			
		// Get ship name as two parts
		self.splitShipNameToTwoStrings(vesselName, shipNamePartA, shipNamePartB);
		
		if shipNamePartB &lt;&gt; "" or shipNamePartB &lt;&gt; null then
			// Two names
			self.drawTextAt(shipNamePartA, 3, 1, Black);
			self.drawTextAt(shipNamePartB, 3, (self.height - (3 + h)), Black);
			
			if drawETA then
				yPos	:=	(self.height - (3 + h) - (h));
				
				if yPos &gt; 2 then
					self.drawTextAt(eta, 3, yPos, Black);
				endif;
			endif;
		else
			// Only one name
			self.drawTextAt(vesselName, 3, 1, Black);
			
			if drawETA then
				self.drawTextAt(eta, 3, (self.height - (3 + h)), Black);
			endif;
		endif;
	else
		// Enough room for only ONE label
		self.drawTextAt(vesselName, 3, 1, Black);
	endif;

	// Set actual time indication for movement at bottom of sprite
	self.drawWidth := 3;
	
	if workingMove &lt;&gt; _selectedMovement 
	and workingMove.moveStatus = MovementStatus_Actual
	then
		self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Blue);
	endif;

	// Set actual time indication for movement at top of sprite
	nextWorkingMove := self.myNextWorkingMovement;
	
	if nextWorkingMove &lt;&gt; null then
		if nextWorkingMove &lt;&gt; _selectedMovement 
		and nextWorkingMove.moveStatus = MovementStatus_Actual
		then
			self.drawLine(0,0,self.width,0,Blue);
		endif;
	endif;
	
	//Set the bow indicator rectangle
	if workingMove.sideTo = OrientPortSideTo then
		bowColour := Red;
	else
		bowColour := Green;
	endif;	
	
	if self.bowOnLeft then
		self.drawRectangle(0, (self.height / 2) - 2, 2, (self.height / 2) + 2, bowColour);
	else
		self.drawRectangle(self.width - 3, (self.height / 2) - 2, self.width, (self.height / 2) + 2, bowColour);
	endif;

	self.z_colourSelectedMovement(_selectedMovement, _scrollToSelected, _allRestrictedObj);
epilog	
	self.visible := true;
end;</source>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
    <JadeMethod name="z_colourSelectedSpriteNew" id="6272faa7-eeab-43d3-9bae-fc5e2f03b114">
        <updating/>
        <source>z_colourSelectedSpriteNew(_selectedMovement : CMIF_HMS_WorkingMovement; _scrollToSelected : Boolean; _allRestrictedObj:CMIF_HMS_WorkingVoyageSet)updating;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	yPos			: Real;
	textHeight		: Real;
	workingMove		: CMIF_HMS_WorkingMovement;
	nextWorkingMove	: CMIF_HMS_WorkingMovement;
	harbourObj		: HMS_Harbour;
	shipNamePartA	: String;
	vesselName		: String;
	shipNamePartB	: String;
	etArrival		: String;
	drawETA			: Boolean;
	bowColour		: Integer;
	voyageHeight	: Real;
	laycanTop		: Real;
	
begin
	workingMove	:=	self.myWorkingMovement;
	
	if workingMove = null then
		return;
	endif;
	
	if workingMove.getLaycanDifference() &gt; 0 then
		self.laycanHeight	:=	workingMove.getLaycanDifference() / self.myGraphicalViewForm.minutesPerPixel;
	endif;
	
	voyageHeight	:=	self.height - self.laycanHeight;
	laycanTop		:=	self.height - self.laycanHeight;

	// use this method to dynamically label controls and draw the coloured bar onto the sprite that shows which movement has been selected
	self.visible		:=	false;
	self.clearGraphics();
	self.autoRedraw		:=	true;
	self.drawTextAlign 	:=	Window.DrawTextAlign_Left;
	self.drawFontName	:=	'Arial';
	self.drawFontSize	:=	8;
	self.drawFillColor	:=	Red;
	self.drawWidth		:=	4;

	// rename the sprite with the ships name - top and bottom
	harbourObj	:=	workingMove.myHarbour;
	vesselName	:=	workingMove.myWorkingVoyage.myHMSVoyageData.vesselName;
	etArrival	:=	workingMove.myWorkingVoyage.arrivedDT.Date.format("dd/MM");
	textHeight	:=	self.drawTextHeight(vesselName);

	if workingMove.moveType = HMSMovementTypeShift then
		//Ship's first movement was before this, so draw in date of ETA
		drawETA	:=	true;
	else
		drawETA	:=	false;
	endif;

	if voyageHeight &gt; ((2 * textHeight) + (1)) then // NB 1 pixel offsets at top
		// Enough room for two labels if required
		
		if harbourObj.isSplitVesselNames then		// cnwdad1 27/02/2007.
			// Get ship name as two parts
			self.splitShipNameToTwoStrings(vesselName, shipNamePartA, shipNamePartB);
			
			if shipNamePartB &lt;&gt; "" or shipNamePartB &lt;&gt; null then
				// Two names
				self.drawTextAt(shipNamePartA, 3, 1, Black);
				self.drawTextAt(shipNamePartB, 3, (voyageHeight - (3 + textHeight)), Black);
				
				if drawETA then
					yPos	:=	(voyageHeight - (3 + textHeight) - (textHeight));
					
					if yPos &gt; 2 then
						self.drawTextAt(etArrival, 3, yPos, Black);
					endif;
				endif;
			else
				// Only one name
				self.drawTextAt(vesselName, 3, 1, Black);
				
				if drawETA then
					self.drawTextAt(etArrival, 3, (voyageHeight - (3 + textHeight)), Black);
				endif;
			endif;
		else
			// Only one name
			self.drawTextAt(vesselName, 3, 1, Black);
			
			if drawETA then
				self.drawTextAt(etArrival, 3, (voyageHeight - (3 + textHeight)), Black);
			endif;
		endif;
	else
		// Enough room for only ONE label
		self.drawTextAt(vesselName, 3, 1, Black);
	endif;

	// Set actual time indication for movement at bottom of sprite
	self.drawWidth	:=	3;
	
	if workingMove &lt;&gt; _selectedMovement
	and workingMove.moveStatus = MovementStatus_Actual
	then
		self.drawLine(0, self.height - self.drawWidth, self.width, self.height - self.drawWidth, Blue);
	endif;

	// Set actual time indication for movement at top of sprite
	nextWorkingMove	:=	self.myNextWorkingMovement;
	
	if nextWorkingMove &lt;&gt; null then
		if nextWorkingMove &lt;&gt; _selectedMovement
		and nextWorkingMove.moveStatus = MovementStatus_Actual
		then
			self.drawLine(0,0,self.width,0,Blue);
		endif;
	endif;
	
	//Set the bow indicator rectangle
	if workingMove.sideTo = OrientPortSideTo then
		bowColour := Red;
	else
		bowColour := Green;
	endif;
	
	if self.bowOnLeft then
		self.drawRectangle(0, (voyageHeight / 2) - 2, 2, (voyageHeight / 2) + 2, bowColour);
	else
		self.drawRectangle(self.width - 3, (voyageHeight / 2) - 2, self.width,(voyageHeight / 2) + 2, bowColour);
	endif;
	
	//draw laycan
	if self.laycanHeight &gt; 0.0 then
		self.drawFillColor	:=	self.myCurrentWharfDrawControl.myScrollingFrame.backColor;
		
		self.drawFilledRectangle(-2, laycanTop, self.width, laycanTop + self.laycanHeight, White);
		self.drawLine(0, laycanTop, self.width, laycanTop, Green);
		self.drawLine(self.width / 2, laycanTop, self.width / 2, laycanTop + self.laycanHeight, Green);
		self.drawLine(self.width / 4, laycanTop + self.laycanHeight - 4, (self.width / 4) * 3, laycanTop + self.laycanHeight - 4, Green);
	endif;
	
	// The following will apply fill colors to the sprite.
	self.z_colourSelectedMovementNew(_selectedMovement, _scrollToSelected, _allRestrictedObj);
epilog
	self.visible := true;
end;</source>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
    </JadeMethod>
