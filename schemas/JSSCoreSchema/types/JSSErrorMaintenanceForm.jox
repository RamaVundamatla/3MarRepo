    </JadeMethod>
    <JadeMethod name="resize" id="fb6d3fbc-bde5-4c47-acd5-f7acf0609cfc">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		15 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnClose.move((self.width - btnClose.width - 17), (self.height - btnClose.height - 38), btnClose.width, btnClose.height);
	btnSave.move((btnClose.left - btnSave.width - 3), btnClose.top, btnSave.width, btnSave.height);
	btnRefresh.move(btnRefresh.left, btnClose.top, btnRefresh.width, btnRefresh.height);
	btnFindNext.move(btnFindNext.left, btnClose.top, btnFindNext.width, btnFindNext.height);
	btnSearch.move(btnSearch.left, btnClose.top, btnSearch.width, btnSearch.height);
	lstConstant.move(lstConstant.left, lstConstant.top, lstConstant.width, (self.height - lstConstant.top - 69));
	txtText.move(txtText.left, txtText.top, (self.width - txtText.left - 17), (self.height - txtText.top - 69));
end;</source>
    </JadeMethod>
    <JadeMethod name="showConstantText" id="e67b4540-efd3-4ceb-86c8-c71bced69963">
        <source>showConstantText() protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTextbox		: TextBox;
	theConstant		: Constant;
	constantText	: String;
	
begin
	theTextbox		:=	txtText;
	theTextbox.text	:=	null;
	theConstant		:=	lstConstant.listObject.Constant;
	
	if theConstant = null then
		return;
	endif;
	
	theTextbox.text	:=	theConstant.text;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
