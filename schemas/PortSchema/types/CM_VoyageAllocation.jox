    <JadeMethod name="getDefaultColour" id="a8997254-7411-4b35-bc27-77939837bcd9">
        <source>getDefaultColour() : Integer;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	port : CM_Port;
	criteria : CM_YACriteria;	
begin
	
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_DischargePort);
	if criteria &lt;&gt; null then
		port := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Port;
		if port &lt;&gt; null then
			return port.colour;
		endif;
	endif;

	return Red;

epilog

end;</source>
        <ReturnType type="Integer"/>
