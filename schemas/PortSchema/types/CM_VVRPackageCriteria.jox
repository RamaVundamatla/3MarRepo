<Class name="CM_VVRPackageCriteria" id="c1a21d03-f7c5-4b58-814e-274fe63e2ed3">
    <superclass name="CM_ObjectMatchCriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vehicleVisit"/>
    <ExplicitInverseRef name="myVVRPackage" id="13707b57-a21b-4f5c-b245-29ffb863978e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_PackageVVR"/>
        <access>readonly</access>
        <Inverse name="CM_PackageVVR::myVVRCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForUpdate" id="9c932162-a795-4e46-ad6c-f87a55d1e8fd">
        <updating/>
        <source>setForUpdate(_proxy: CM_VVRPackageCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars

	realPackage: CM_PackageVVR;

begin

	if not self.isTransient then
		if _proxy.myVVRPackage &lt;&gt; null and _proxy.myVVRPackage.isTransient then
			realPackage := _proxy.myVVRPackage.pxyGetRealObject();
		endif;
		if realPackage = null then
			if not _proxy.myVVRPackage.isTransient then
				realPackage := _proxy.myVVRPackage;
			endif;
		endif;
		self.myVVRPackage := realPackage;
	else
		self.myVVRPackage := _proxy.myVVRPackage;
	endif;
	
	inheritMethod(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VVRPackageCriteria"/>
    </JadeMethod>
    <JadeMethod name="setMyVVRPackage" id="5324eae4-451e-451e-8855-e797134e3507">
        <updating/>
        <source>setMyVVRPackage(_package: CM_PackageVVR) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars

begin
	self.myVVRPackage := _package;
epilog

end;</source>
        <Parameter name="_package" type="CM_PackageVVR"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="7e24c5cf-fdf2-4f15-817f-d2ab51c04513">
        <updating/>
        <source>setProxyBaseData(_vvrPackage: CM_PackageVVR) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars

begin
	self.setMyVVRPackage(_vvrPackage);
epilog

end;</source>
        <Parameter name="_vvrPackage" type="CM_PackageVVR"/>
    </JadeMethod>
</Class>
