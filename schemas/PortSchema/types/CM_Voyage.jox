Purpose:			Get the number of tugs assigned to the first movement to a real Berth


Return Value:		Number of tugs


Date		Who		Reason
18 Apr 2008	cnwkpd1	PAR #16521 - Short Term Movements report

*/

vars
	movement		: HMS_VoyageMovement;
	
begin
	movement := self.getMovementFirstRealBerth();
	if movement = null then
		return 0;
	endif;
	
	return movement.getNumTugsUsed();
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
