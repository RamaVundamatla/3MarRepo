    <JadeMethod name="buildCombosForDeckingOpts" id="0e46c65f-bf7f-47b4-987d-a753dbb25a36">
        <source>buildCombosForDeckingOpts(_gridArea: CM_GridArea; _level: Integer; _yaDeckingOptions: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _gridArea.type = TA_TYPE_STRADDLE_STACK 
	   or _gridArea.type = TA_TYPE_FORK_LIFT_STACK
	   or _gridArea.type = TA_TYPE_RTG
	   or  _gridArea.type = TA_TYPE_RMG then
		self.myAssistant.comboBoxInDeckGridArea(self.cmbInOptions, _level, _gridArea.type, _yaDeckingOptions);
		self.myAssistant.comboBoxOutDeckGridArea(self.cmbOutOptions, _level, _gridArea.type, _yaDeckingOptions);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'unexpected terminal area type');
	endif;

end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_yaDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="buildCombosForGridRow" id="d8a979bf-8ea2-4632-8f0c-2c286aecee67">
        <source>buildCombosForGridRow(_yaDeckingOptions: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
begin

	gridArea := _yaDeckingOptions.getGridArea();
	
	if gridArea = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'grid object with no grid area');
		return;
	endif;

	self.buildCombosForDeckingOpts(gridArea, DeckingLevel_Row, _yaDeckingOptions);

end;</source>
        <Parameter name="_yaDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="buildCombosForYABlock" id="4f44a8d3-a560-41f7-8646-23b17758cf26">
        <source>buildCombosForYABlock(_yaDeckingOptions: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
begin
	
	gridArea := _yaDeckingOptions.getGridArea();
	
	if gridArea = null then
//	here it is
//		app.raiseUnexpectedProgramError(class.name, method.name, 'grid object with no grid area');
		return;
	endif;
	
	self.buildCombosForDeckingOpts(gridArea, DeckingLevel_YA, _yaDeckingOptions);
	

end;</source>
        <Parameter name="_yaDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="chkOutUseRevOfIn_click" id="f88c8133-dc58-4dba-81ca-1ab93ce6cf7d">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkOutUseRevOfIn_click(checkbox: CheckBox input) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if checkbox.value then
		if app.msgBox(app.getErrorString(DeckingOptionsRemoveOut) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			checkbox.value := false; //undo 	
			return;
		endif;
		self.initTable(self.tblOutOptions);
	endif;
	
	self.setOutControlsForReverseOfIn();
	
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkShowHeights_click" id="41c5e40a-bf48-4afc-9fae-97ec8d15875d">
