    <JadeMethod name="setMyLayoutGraphic" id="08ce1843-3ce0-41f9-83e1-d4ed3c1415fb">
        <updating/>
        <source>setMyLayoutGraphic(pProxy : CM_TerminalArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpPxyTA	: CM_TerminalArea;
	tmpTA		: CM_TerminalArea;
begin

	tmpPxyTA := pProxy;		// done as call to initDefaultLayout below is updating
	
	if self.myLayoutGraphic = null then
		// need to create
		create self.myLayoutGraphic persistent;
/*WAS		if tmpPxyTA.myLayoutGraphic &lt;&gt; null then
			self.myLayoutGraphic.setForCreate(tmpPxyTA.myLayoutGraphic);
		else
			if tmpPxyTA &lt;&gt; null then
				tmpPxyTA.initDefaultLayout();
				self.myLayoutGraphic.setForCreate(tmpPxyTA.myLayoutGraphic);
			else
				self.initDefaultLayout();
			endif;
			
		endif;			NOW */
		if tmpPxyTA &lt;&gt; null then
			if tmpPxyTA.myLayoutGraphic &lt;&gt; null then
				self.myLayoutGraphic.setForCreate(tmpPxyTA.myLayoutGraphic);
			else
				tmpPxyTA.initDefaultLayout();
				self.myLayoutGraphic.setForCreate(tmpPxyTA.myLayoutGraphic);
			endif;
		else
			create tmpTA as self.class transient;
			tmpTA.initDefaultLayout();
			self.myLayoutGraphic.setForCreate(tmpTA.myLayoutGraphic);
		endif;
	elseif tmpPxyTA &lt;&gt; null then
		if tmpPxyTA.myLayoutGraphic &lt;&gt; null and tmpPxyTA.myLayoutGraphic.isTransient then
			self.myLayoutGraphic.setForUpdate(tmpPxyTA.myLayoutGraphic);
		endif;
	endif;
epilog
	delete tmpTA;
end;</source>
        <access>protected</access>
        <Parameter name="pProxy" type="CM_TerminalArea"/>
    </JadeMethod>
