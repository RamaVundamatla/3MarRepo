    <JadeMethod name="getBalanceAsST" id="4c964561-be7c-4227-83e2-ebb8a7bfb40f">
        <source>getBalanceAsST():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	measure : CM_MeasurementType;
	retVal : String;


begin

	measure := CM_Root.firstInstance.allMeasurementTypesByShortName["ST"];
	if measure &lt;&gt; null then
		retVal := measure.convertMeasurementForDisplay( self.balance );
	endif;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
