    <JadeMethod name="trxUpdateActivityHistory" id="3509871c-1b88-4326-b474-ded989779c96">
        <updating/>
        <source>trxUpdateActivityHistory(_activityHistory : CM_ActivityHistory input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation

*/

vars
	realActivity :CM_ActivityHistory;
begin	
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	
	realActivity:=_activityHistory.pxyGetRealObject();
	self.raiseExceptionIfNull(realActivity, 'Activity History');
	
	if not _passport.noErrors then
		return;
	endif;
	
	realActivity.setForUpdate(_activityHistory);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
