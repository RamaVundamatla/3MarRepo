    <JadeMethod name="doMnuContextVisibility" id="da4fe635-8620-4bcc-b49c-c17cd57c6059">
        <source>doMnuContextVisibility(_value : Boolean; table : Table)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation

*/

vars

begin
	self.mnuInspectObject.visible := app.isAllowedToInspect and _value;
	
	self.mnuContextPrintReceipt.visible := _value;
	self.mnuInvRefresh.visible := _value;
	self.mnuContextSep01.visible := _value;
	
	if table = self.tblCharges then
		self.mnuContextViewTxns.visible := _value;
	else
		self.mnuContextViewTxns.visible := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="table" type="Table"/>
