    <JadeMethod name="setComboValues" id="dfe4308d-6b28-4334-9da8-c6782111b2e5">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	calc : CM_CalculationType;
	dict : CM_CalculationTypeByCodeDict;

begin
	_combo.clear;
	dict := app.myRoot.allCalculationTypesByCode;
	
	foreach calc in dict discreteLock do
		if self.propertyClassName = "CM_InvoiceContract" then // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			if not calc.isCargoCalcType then // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
				continue; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			endif; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
		endif;
		_combo.itemObject[_combo.addItem(calc.code &amp; Tab &amp; calc.description)] := calc;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="2b2bc4d5-bef0-46bc-9f30-e709a60f57d9">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	calc 	 		: CM_CalculationType;
	calcDict 		: CM_CalculationTypeByCodeDict;
	selectionValue,
	idx 			: Integer;
	array 			: ObjectArray;

begin
	calcDict := app.myRoot.allCalculationTypesByCode;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach calc in calcDict discreteLock do
		if self.propertyClassName = "CM_InvoiceContract" then // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			if not calc.isCargoCalcType then // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
				continue; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			endif; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
		endif;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(calc.code) then
			selectionValue := 1;
			array.add(calc);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; calc.code &amp; " (" &amp; calc.description &amp; ")");
		_tbl.accessRow(idx).itemObject := calc;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="32ed35aa-c949-4f59-8d42-fd1478f1bbdd">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	calcType 	: CM_CalculationType;
	str 		: String;
	numRows,
	idx			: Integer;
	sa 			: StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			calcType := _tbl.accessRow(idx).itemObject.CM_CalculationType;
			sa.add(calcType.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="353ad405-d13b-44c3-9493-419b1f78f3bf">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars

begin
	if _value.isKindOf(CM_CalculationType) then
		if _value &lt;&gt; null then
			return _value.CM_CalculationType.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b7fc1b04-fa1b-4e11-98f6-603f5c6d4a22">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	invalidObj : Boolean;
	object : CM_CalculationType;
	returnVal : String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_CalculationType) then
			object := _value.CM_CalculationType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
