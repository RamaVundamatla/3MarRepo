    <JadeMethod name="addTI" id="1038f422-f142-4024-96ee-4731bd4178ef">
        <updating/>
        <source>addTI(_ti : CM_TrackedItem ) updating;
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myTrackedItem :=_ti;
	self.sortCargo := self.code;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
