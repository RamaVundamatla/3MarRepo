    <JadeMethod name="cmbVessel_displayEntry" id="50223d25-3276-4901-bfc8-39998cf66257">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVessel_displayEntry(combobox: ComboBox input; pVessel: CM_Vessel; lstIndex: Integer):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	failedDAC : CM_DataAccessController; 

begin
	if pVessel = null then
		return null;
	endif;
	
	if (not pVessel.canCreateVoyages) then
		return null;
	endif;
	if (not pVessel.isBarge) then
		return null;
	endif;
	
	if not pVessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;
	
	if self.myTerminal.getConfig(VesselComboByName).Boolean then
		return pVessel.name &amp;  " - (" &amp; pVessel.code &amp; ")" ;
	else
		return pVessel.code &amp; Tab &amp; pVessel.name;		
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="910273dd-e011-43af-b567-924f9a07aaad">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge cargo Creation
//
vars

begin
	if self.doSave() then
		inheritMethod();
	else
		self.modalResult := IDCANCEL;
		self.unloadForm;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="49aac2a9-cad3-493e-a885-6f9fcb926509">
        <source>doSave() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	idx : Integer;
	vessel : CM_Vessel;
	cargoId : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	weight, density : Decimal [14,4];
	specialStow : CM_SpecialStow;
	combo : ComboBox;
	pxyTI : CM_TrackedItem;

begin
	// get the data from the cloned controls
	idx := 1;
	self.allTrackedItems.clear;
	self.allVessels.clear;
	while true do
		combo := self.cmbCargoType.getControl(idx);
		if combo = null then
			break;
		endif;
		vessel := self.cmbVessel.getControl(idx).listObject.CM_Vessel;
		cargoType := combo.listObject.CM_CargoType;
		cargoId := self.txtCargoId.getControl(idx).text;
		cargoSubType := self.cmbCargoSubtype.getControl(idx).listObject.CM_Product;
		specialStow := self.cmbSpecialStow.getControl(idx).listObject.CM_SpecialStow;
		if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
			if cargoSubType = null then
				cargoSubType := cargoType.mySystemProductType;
			endif;
			density := cargoSubType.myDensityDec.value;			// ### TFS 52193 22Nov2021 NAVPW1
			weight := self.txtTotalWeight.getControl(idx).CMUI_MeasurementTable.getConvertedValue * density;
		else
			weight := self.txtTotalWeight.getControl(idx).CMUI_MeasurementTable.getConvertedValue;
		endif;
		
		if vessel &lt;&gt; null then
			self.allVessels.add(vessel);
		endif;
		create pxyTI as cargoType.myClassToCreate transient;
		pxyTI.zSetPxyId(cargoId);
		if cargoType &lt;&gt; null then
			pxyTI.setCargoType(cargoType.id);
		endif;
		pxyTI.setMyProduct(cargoSubType);
		pxyTI.setTotalWeight(weight, null, app.myPassport);
		if specialStow &lt;&gt; null then
			pxyTI.zSetPxySpecialStow(specialStow.code);
		endif;
		self.allTrackedItems.add(pxyTI);
		
		idx := idx + 1;
	endwhile;
	
	// copy TIs and vessels to parent form
	self.myBulkCreateForm.setBulkCargoAndVessels(self.allTrackedItems, self.allVessels);
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadExistingData" id="9a8ddca1-4926-4f81-b65d-d0eb3c2f8668">
        <updating/>
        <source>loadExistingData() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	idx : Integer;
	ti : CM_TrackedItem;
	vesselCombo : CMUI_ComboBox;
	cargoIdBox : CMUI_TextBox;
	cargoTypeCombo : CMUI_ComboBoxCargoTypeForTerm;
	cargoSubTypeCombo : CMUI_ComboProduct;
	weightBox : CMUI_MeasurementTable;
	specialStowCombo : CMUI_ComboSpecialStow;
	density : Decimal [14,4];

begin
	foreach ti in self.allTrackedItems do
		idx := idx + 1;
		
		vesselCombo := self.cmbVessel.getControl(idx).CMUI_ComboBox;
		cargoIdBox := self.txtCargoId.getControl(idx).CMUI_TextBox;
		cargoTypeCombo := self.cmbCargoType.getControl(idx).CMUI_ComboBoxCargoTypeForTerm;
		cargoSubTypeCombo := self.cmbCargoSubtype.getControl(idx).CMUI_ComboProduct;
		weightBox := self.txtTotalWeight.getControl(idx).CMUI_MeasurementTable;
		specialStowCombo := self.cmbSpecialStow.getControl(idx).CMUI_ComboSpecialStow;
		
		if vesselCombo &lt;&gt; null then
			vesselCombo.listIndex := vesselCombo.findObject(self.allVessels[idx]);
		endif;
		if cargoIdBox &lt;&gt; null then
			cargoIdBox.text := ti.id;
		endif;
		if cargoTypeCombo &lt;&gt; null then
			cargoTypeCombo.listIndex := cargoTypeCombo.findObject(ti.myCargoType);
			self.onCargoTypeChange(idx, ti.myCargoType);
		endif;
		if cargoSubTypeCombo &lt;&gt; null and ti.myProduct &lt;&gt; null then
			cargoSubTypeCombo.listIndex := cargoSubTypeCombo.findObject(ti.myProduct);
			self.onCargoSubTypeChange(idx, ti.myProduct);
		endif;
		if weightBox &lt;&gt; null then
			if ti.myCargoType.isTrackByVolume then
				if ti.myProduct &lt;&gt; null and ti.myProduct.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
					density := ti.myProduct.myDensityDec.value;							// ### TFS 52193 22Nov2021 NAVPW1
				else
					density := ti.myCargoType.mySystemProductType.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
				endif;
				weightBox.setValues(app.convertMeasurementForDisplay(weightBox.getUnit, ti.totalWeight / density) &amp; Space &amp; weightBox.getUnit);
			else
				weightBox.setValues(app.convertMeasurementForDisplay(weightBox.getUnit, ti.totalWeight) &amp; Space &amp; weightBox.getUnit);
			endif;
		endif;
		if specialStowCombo &lt;&gt; null then
			specialStowCombo.listIndex := specialStowCombo.findObject(app.myRoot.allSpecialStows[ti.specialStow]);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="onCargoSubTypeChange" id="45defdeb-e18c-4f6d-a9f0-17863f544a0f">
        <updating/>
        <source>onCargoSubTypeChange(_index : Integer; _cargoSubType : CM_Product) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	measureType : CM_MeasurementType;
	textWeight : CMUI_MeasurementTable;

begin
	if _cargoSubType = null then
		return;
	endif;
	
	if _index &lt;&gt; null then
		textWeight := self.txtTotalWeight.getControl(_index);
		if textWeight = null then
			return;
		endif;
		
		if _cargoSubType.myCargoType.isTrackByVolume then
			if _cargoSubType.getMyVolume &lt;&gt; null and _cargoSubType.getMyVolume.myMeasurementType &lt;&gt; null then
				measureType := _cargoSubType.getMyVolume.myMeasurementType;
				if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
					textWeight.setup(Type_Volume, self.backColor);
					textWeight.setValues(Space &amp; measureType.shortName);
				endif;
			endif;
		else
			if _cargoSubType.getMyWeight &lt;&gt; null and _cargoSubType.getMyWeight.myMeasurementType &lt;&gt; null then
				measureType := _cargoSubType.getMyWeight.myMeasurementType;
				if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
					textWeight.setup(Type_Weight, self.backColor);
					textWeight.setValues(Space &amp; measureType.shortName);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="onCargoTypeChange" id="bd3ad345-d1e4-4958-8361-74fd4ed75614">
        <updating/>
        <source>onCargoTypeChange(_index : Integer; _cargoType : CM_CargoType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	comboSubType : CMUI_ComboProduct;
	textWeight : CMUI_MeasurementTable;

begin
	if _index &lt;&gt; null then
		comboSubType := self.cmbCargoSubtype.getControl(_index).CMUI_ComboProduct;
		if comboSubType &lt;&gt; null then
			comboSubType.setCargoType(_cargoType);
			comboSubType.initialise(true);
		endif;
		
		textWeight := self.txtTotalWeight.getControl(_index);
		if textWeight &lt;&gt; null then
			textWeight.setup(Type_Weight, self.backColor);
			if _cargoType &lt;&gt; null then
				if _cargoType.isTrackByWeight then
					textWeight.setup(Type_Weight, self.backColor);
					textWeight.setValues(Space &amp; _cargoType.myWeightMeasurementType.shortName);
				elseif _cargoType.isTrackByVolume then
					textWeight.setup(Type_Volume, self.backColor);
					textWeight.setValues(Space &amp; _cargoType.myVolumeMeasurementType.shortName);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="onVesselChange" id="a04fc95a-8b66-4e43-aebd-1f28b99e3934">
        <updating/>
        <source>onVesselChange(_idx : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	vesselCombo : CMUI_ComboBox;
	vessel: CM_Vessel;
	prefix, vesselName, vesselChar, cargoID : String;
	number, padLength : Integer;

begin
	vesselCombo := self.cmbVessel.getControl(_idx);
	if vesselCombo = null then
		return;
	endif;
	
	vessel := vesselCombo.listObject.CM_Vessel;
	if vessel = null then
		return;
	endif;
	
	// generate the cargo ID - made from Voyage Code Prefix + Barge ID, where Barge ID is the 3-digit
	// number at the end of the vessel name, or the entire vessel name if it doesn't end in 3 digits
	cargoID := self.myAssistant.generateCargoIdForBargeCargo(self.myBulkCreateForm.txtVoyageCode.text.trimBlanks.toUpper, self.myBulkCreateForm.txtTotal.text.Integer, vessel);
	/*prefix := self.myBulkCreateForm.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.myBulkCreateForm.txtTotal.text.Integer;
	if number &lt; 10 then
		padLength := 1;
	else
		padLength := 2;
	endif;
	
	vesselName := vessel.code;
	vesselChar := vesselName[vesselName.length-2:end];
	if vesselChar.isInteger then
		cargoID := (prefix &amp; vesselChar);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	else
		cargoID := (prefix &amp; vesselName);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	endif;*/
	self.txtCargoId.getControl(_idx).CMUI_TextBox.text := cargoID;
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBulkCargoAndVessels" id="d1aa84ce-226c-4160-b1e4-c18707e5d8b2">
        <updating/>
        <source>setBulkCargoAndVessels(_allTIs : CM_TIArray; _allVessels : CM_ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars

begin
	_allTIs.copy(self.allTrackedItems);
	_allVessels.copy(self.allVessels);
epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <Parameter name="_allVessels" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7542874e-f3f4-45bb-9bc5-b5294e31db89">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	prefix : String;
	number, padLength, idx, top : Integer;
	newLblBargeCode : CMUI_Label;
	newCmbVessel : CMUI_ComboBox;
	newTxtCargoId : CMUI_TextBox;
	newCmbCargoType : CMUI_ComboBoxCargoTypeForTerm;
	newCmbCargoSubtype : CMUI_ComboProduct;
	newTxtWeight : CMUI_MeasurementTable;
	newCmbSpecialStow : CMUI_ComboSpecialStow;
	vessel : CM_Vessel;
	vesselName, vesselChar, cargoID : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	specialStow : CM_SpecialStow;
	weight : String;
	vesselByName : Boolean;

begin
	inheritMethod();
	
	// generate cargo ids
	vessel := self.myBulkCreateForm.cmbVessel.listObject.CM_Vessel;
	prefix := self.myBulkCreateForm.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.myBulkCreateForm.txtTotal.text.Integer;
	cargoID := self.myAssistant.generateCargoIdForBargeCargo(prefix, number, vessel);
	/*prefix := self.myBulkCreateForm.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.myBulkCreateForm.txtTotal.text.Integer;
	if number &lt; 10 then
		padLength := 1;
	else
		padLength := 2;
	endif;
	
	vessel := self.myBulkCreateForm.cmbVessel.listObject.CM_Vessel;
	vesselName := vessel.code;
	vesselChar := vesselName[vesselName.length-2:end];
	if vesselChar.isInteger then
		cargoID := (prefix &amp; vesselChar);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	else
		cargoID := (prefix &amp; vesselName);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	endif;*/
	
	// get the default values from the parent form
	vesselByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	if self.myBulkCreateForm.cmbCargoType.listIndex &gt; 0 then
		cargoType := self.myBulkCreateForm.cmbCargoType.listObject.CM_CargoType;
	endif;
	if self.myBulkCreateForm.cmbCargoSubtype.listIndex &gt; 0 then
		cargoSubType := self.myBulkCreateForm.cmbCargoSubtype.listObject.CM_Product;
	endif;
	if self.myBulkCreateForm.cmbSpecialStow.listIndex &gt; 0 then
		specialStow := self.myBulkCreateForm.cmbSpecialStow.listObject.CM_SpecialStow;
	endif;
	if self.myBulkCreateForm.txtTotalWeight.getRawValue &lt;&gt; null then
		weight := self.myBulkCreateForm.txtTotalWeight.getRawValue &amp; Space &amp; self.myBulkCreateForm.txtTotalWeight.getUnit;
	endif;
	
	top := self.lblBargeCode.top.Integer;
	idx := 1;
	while idx &lt;= number do
		newLblBargeCode := self.lblBargeCode.loadControl(idx).CMUI_Label;
		newLblBargeCode.visible := true;
		newLblBargeCode.move(self.lblBargeCode.left, top, self.lblBargeCode.width, self.lblBargeCode.height);
		newLblBargeCode.caption := prefix &amp; idx.padLeadingWith('0', padLength);
		
		newCmbVessel := self.cmbVessel.loadControl(idx).CMUI_ComboBox;
		newCmbVessel.visible := true;
		newCmbVessel.move(self.cmbVessel.left, top, self.cmbVessel.width, self.cmbVessel.height);
		newCmbVessel.tabIndex := self.cmbVessel.tabIndex + (100 * idx);
		newCmbVessel.listCollection(app.myRoot.allVessels, true, 0);
		newCmbVessel.listIndex := newCmbVessel.findObject(vessel);
		
		newTxtCargoId := self.txtCargoId.loadControl(idx).CMUI_TextBox;
		newTxtCargoId.visible := true;
		newTxtCargoId.move(self.txtCargoId.left, top, self.txtCargoId.width, self.txtCargoId.height);
		newTxtCargoId.tabIndex := self.txtCargoId.tabIndex + (100 * idx);
		newTxtCargoId.text := cargoID;
		
		newCmbCargoType := self.cmbCargoType.loadControl(idx).CMUI_ComboBoxCargoTypeForTerm;
		newCmbCargoType.visible := true;
		newCmbCargoType.move(self.cmbCargoType.left, top, self.cmbCargoType.width, self.cmbCargoType.height);
		newCmbCargoType.tabIndex := self.cmbCargoType.tabIndex + (100 * idx);
		newCmbCargoType.setEventMapping("click", "cmbCargoType_click");
		newCmbCargoType.myTerminal := self.myTerminal;
		newCmbCargoType.initialise(true);
		if cargoType &lt;&gt; null then
			newCmbCargoType.listIndex := newCmbCargoType.findObject(cargoType);
			self.onCargoTypeChange(idx, cargoType);
		endif;
		
		newCmbCargoSubtype := self.cmbCargoSubtype.loadControl(idx).CMUI_ComboProduct;
		newCmbCargoSubtype.visible := true;
		newCmbCargoSubtype.move(self.cmbCargoSubtype.left, top, self.cmbCargoSubtype.width, self.cmbCargoSubtype.height);
		newCmbCargoSubtype.tabIndex := self.cmbCargoSubtype.tabIndex + (100 * idx);
		newCmbCargoSubtype.setEventMapping("click", "cmbCargoSubtype_click");
		newCmbCargoSubtype.initialise(true);
		if cargoType &lt;&gt; null and cargoSubType &lt;&gt; null then
			newCmbCargoSubtype.setCargoType(cargoType);
			newCmbCargoSubtype.initialise(true);
			newCmbCargoSubtype.listIndex := newCmbCargoSubtype.findObject(cargoSubType);
			self.onCargoSubTypeChange(idx, cargoSubType);
		endif;
		
		newTxtWeight := self.txtTotalWeight.loadControl(idx).CMUI_MeasurementTable;
		newTxtWeight.visible := true;
		newTxtWeight.move(self.txtTotalWeight.left, top, self.txtTotalWeight.width, self.txtTotalWeight.height);
		newTxtWeight.tabIndex := self.txtTotalWeight.tabIndex + (100 * idx);
		if cargoType = null and cargoSubType = null then
			newTxtWeight.setup(Type_Weight, self.backColor);
		elseif cargoSubType &lt;&gt; null then
			self.onCargoSubTypeChange(idx, cargoSubType);
		elseif cargoType &lt;&gt; null then
			self.onCargoTypeChange(idx, cargoType);
		endif;
		if weight &lt;&gt; null then
			newTxtWeight.setValues(weight);
		endif;
		
		newCmbSpecialStow := self.cmbSpecialStow.loadControl(idx).CMUI_ComboSpecialStow;
		newCmbSpecialStow.visible := true;
		newCmbSpecialStow.move(self.cmbSpecialStow.left, top, self.cmbSpecialStow.width, self.cmbSpecialStow.height);
		newCmbSpecialStow.tabIndex := self.cmbSpecialStow.tabIndex + (100 * idx);
		newCmbSpecialStow.initialise(true);
		if specialStow &lt;&gt; null then
			newCmbSpecialStow.listIndex := newCmbSpecialStow.findObject(specialStow);
		endif;
		
		top := top + 25;
		idx := idx + 1;
	endwhile;
	
	self.height := top + self.btnCancel.height + 50;
	
	if self.allTrackedItems.isNotEmpty then
		self.loadExistingData();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2da2c531-9d05-4072-a71b-2644576b9d1b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2021 10:12:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024335, locale);
	lblBargeCode.translateCaption(Xlat_0024336, locale);
	lblCargoId.translateCaption(Xlat_0024337, locale);
	lblCargoSubtype.translateCaption(Xlat_0024338, locale);
	lblCargoType.translateCaption(Xlat_0024339, locale);
	lblSpecialStow.translateCaption(Xlat_0024340, locale);
	lblVessel.translateCaption(Xlat_0024341, locale);
	lblWeight.translateCaption(Xlat_0024342, locale);
end;</source>
    </JadeMethod>
</GUIClass>
