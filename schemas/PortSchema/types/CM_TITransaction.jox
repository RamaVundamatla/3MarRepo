    <JadeMethod name="getVoyage" id="f1774ebd-cde3-4acb-8ae0-6b6be6673262">
        <source>getVoyage(): CM_Voyage;

// rs April 2005 if a voyage is removed eg garbage collection the self.voyage
// is not updated so we check that it is valid.
// cnwrs1 Aug 2008 change to use handleDeletedObject exception
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	isInvalid : Boolean;
	str : String;
	voy	: CM_Voyage;
begin
	voy := self.voyage;
	if voy = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, voy, isInvalid);
	str := voy.code;
	if not isInvalid then
		return voy;
	else
		return null;
	endif;
end;</source>
        <text>&lt;Documentation&gt;
&lt;Description&gt;
The voyage (refer CM_Voyage) that was copied from the tracked item when the transaciton was created.  
As this is a reference to the voyage, this can be null if the voyage has been deleted.
&lt;/Description&gt;
&lt;/Documentation&gt;</text>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="10446c1d-efb9-486c-843b-b50c9201d45b">
        <source>getVoyageCode() : String;
/* ---------------------------------------------------------------------------
Created:     01 October 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpVoyage	: CM_Voyage;
begin
	// PAR 24432 - return voyageCode if this has been set
	// voyageCode attribute added in 7.8.2, so need to cater for prior data
	if self.voyageCode &lt;&gt; null then
		return self.voyageCode;
	else
		tmpVoyage := self.getVoyage();
		if tmpVoyage &lt;&gt; null then
			return tmpVoyage.code;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
