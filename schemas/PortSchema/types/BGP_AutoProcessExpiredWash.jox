<Class name="BGP_AutoProcessExpiredWash" id="0439a973-30de-4435-ab9a-9705ac17a867">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Process Expired Wash&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myToDoTaskDesc" id="7a99fdc5-886c-4ef3-bdc8-382a8c4bd91b">
        <embedded/>
        <type name="CM_ToDoTaskDesc"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="08b233ef-f182-46b8-b359-750b960577f9">
        <updating/>
        <source>action(): Boolean updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.processExpiredWash();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString2(Successfully_Processed_ExpWash, self.myToDoTaskDesc.shortDescription, self.myTerminal.code), false, false);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="052cc5c5-4a12-4062-a20c-10c6556780b7">
        <source>getDisplay(): String;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return inheritMethod &amp; Tab &amp; 'Check Wash Expired';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="c3dbf2f2-cf6f-4923-9cd5-f60e8152c67d">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskExpiredWash) updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myToDoTaskDesc	:= _task.myToDoTaskDesc;		
	inheritMethod(_task);
end;</source>
        <Parameter name="_task" type="CM_AutoTaskExpiredWash"/>
    </JadeMethod>
    <JadeMethod name="processExpiredWash" id="2ff9988f-c946-47cb-8d87-9fc5935c3343">
        <source>processExpiredWash()protected;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  Expired Wash Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate terminal', null, null);
		return;
	endif;
	
	if self.myToDoTaskDesc = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate To Do Task for Wash', null, null);
		return;
	endif;
		
	app.myPassport.setMyTerminal(self.myTerminal);

	app.myTrxUA.trxAutoProcessExpiredToDoTask(self.myTerminal, self.myToDoTaskDesc, app.myPassport);
			
	if (not app.myPassport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process Expired Wash',null, app.myPassport.allErrors, null, true, true);
	endif;
	msg := "=====================  Expired Wash Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
