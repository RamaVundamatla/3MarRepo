    <JadeMethod name="utlDeleteXlations" id="2adccaea-69ca-4c0f-954d-90d5dacbf58c">
        <updating/>
        <source>utlDeleteXlations(_coll : ObjectArray; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/04/2022	navdap1		Initial creation TFS 53181
//
vars
	xlation			:Object;
	gotException	:Boolean;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	// we don't expect this trx to be widely used
	on Exception do app.handleDeletedObject (exception, xlation, gotException);
	
	foreach xlation in _coll do
		self.reserveLock(xlation);
		
		if gotException then
			gotException := false;
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteXlation(xlation.CM_Xlation, _passport);
	endforeach;

epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
