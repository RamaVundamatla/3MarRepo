	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixMachTypesThatDontSuppRT" id="3563c40b-62ce-4dae-adcd-872e9ea4767f">
        <source>fixMachTypesThatDontSuppRT(_controller: CnEcReleaseController);
/*

Purpose:			Portainer Cranes are not currently allowed VMTs, and should not have been allowed to be setup as one

Parameters:			

Return Value:		


Date			Who		Reason
14 May 2018		jlgmd1	Initial creation TFS #38555 MSL PORTAINER CRANE IN RT

*/

vars
	root : CM_Root;
	machine : CM_Machine;
	machineType : CM_MachineType;
	iter : Iterator;
	auditAgent : CM_UpdateTransactionAuditAgent;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fix Machines being incorrectly allowed to support RT when they shouldn't", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fix Machines being incorrectly allowed to support RT when they shouldn't") ;	
	endif;
	
	create auditAgent transient;
	
	root := CM_Root.firstInstance;
	iter := root.allMachines.createIterator;
	
	beginTransaction;
	
	while iter.next(machine) do
		if not app.isValidObject(machine) then
			continue;
		endif;
		
		machineType := null;
		machineType := app.myRoot.allMachineTypes[machine.machineType];
		
		if machineType &lt;&gt; null and not machineType.supportsRT then
			auditAgent.audUpdateGeneric(machine, true);
			machine.setPropertyValue('hasRadioTelemetry', false);
			machine.setPropertyValue('myRTDevice', null);
			machine.setPropertyValue('canWeighCargo', false);
			machine.setPropertyValue('canCertifyWeight', false);
			auditAgent.audUpdateGeneric(machine, false);
		endif;
	endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing Machines being incorrectly allowed to support RT when they shouldn't",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished fixing Machines being incorrectly allowed to support RT when they shouldn't");
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete iter;
	delete auditAgent;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixReportTemplatePrinters" id="6ad8efd5-4134-465f-b9d5-7464c57f7829">
        <source>fixReportTemplatePrinters(_controller: CnEcReleaseController);

/*

Purpose:			Check to see if the wrong (logical) printer name has been associated to any report templates
					and if it has, swap it with the physical printer name by just updating/re-saving the report template
	
Parameters:			

Return Value:		


Date				Who		Reason
12 October 2017		jlgmd1	TFS 7140 DPH - message box in bgp process
27 October 2017		jlgmd1	Added check for users who no longer have access to a report
09 November 2017 	jlgmd1	Rewrote method to use its own updating trx/utl method to update printer names
							without affecting other data. (eg, users who no longer have access to the report)
15 May 2018			jlgmd1	Moved 'finished' log out of the epilog so it doesn't say it finishes running every release (oops!)

*/

vars
	isOk 				: Boolean;
	request				: BGP_ReportRequest;
	requestsToFix,
	reqArray			: ObjectArray;
	obj					: Object;
	correctPrinters 	: HugeStringArray;	// Just in case we have a long printer name
	printerName 		: String;
	printer 			: CM_PrinterDef;
	reqNum 				: Integer;
	msg 			: String;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fixing BGP Report Requests printers", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fixing BGP Report Requests printers");
	endif;
	
	create reqArray transient;
	create requestsToFix transient;
	create correctPrinters transient;
	
	// Get all our BGP requests
	BGP_ReportRequest.allInstances(reqArray, 0, true);
	
	foreach obj in reqArray discreteLock do
		
		request := obj.BGP_ReportRequest;
		if request = null then
			continue;
		endif;
		
		printerName := request.printerName;
		printer := app.myRoot.getPrinter(printerName);
	
		// If printer is not null then we've found a printer based on its logical name. This is not what we want.
		// Only change to the physical name if its actually different from the logical one!
		if printer &lt;&gt; null and printerName &lt;&gt; printer.physicalPrinterName then
			// Change from logical to physical printer name (even if the physical printer name is blank)
			printerName := printer.physicalPrinterName;
		else
			// We (hopefully) already have the correct printer name, so lets go to the next one
			continue;
		endif;
		
		requestsToFix.add(request);
		correctPrinters.add(printerName);
	
	endforeach;
	
	isOk := requestsToFix.size = correctPrinters.size;
	reqNum := 1;
	
	if not isOk then
		msg := "Request object array size [" &amp; requestsToFix.size.String &amp; "] does not match printer array size [" &amp; correctPrinters.size.String &amp; "]";
	endif;
	
	while reqNum &lt;= requestsToFix.size and isOk do
		
		// Grab our request
		request := requestsToFix[reqNum].BGP_ReportRequest;
		// Log what we are changing
		msg := "Changing printer [" &amp; request.printerName &amp; "] to [" &amp; correctPrinters[reqNum] &amp; "] for " &amp; request.getOidAsString;
		app.writeLog(method.qualifiedName &amp; " " &amp; msg, LogINFO);
		
		// Update the printer name
		app.myTrxUA.trxUpdateBGPReqPrinterName(request, correctPrinters[reqNum], app.myPassport);
		
		if app.myPassport.hasErrorsOrWarnings then
			isOk := false;
			msg := app.myPassport.getAllErrorsWarningsAsString();
		endif;
			
		reqNum := reqNum + 1;	// next
	endwhile;
	
	if isOk then
		self.addScriptRun(method.name);
	else
		app.writeLog(method.qualifiedName &amp; " " &amp; msg, LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg);
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing BGP Report Requests printers", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished fixing BGP Report Requests printers");
	endif;
	
epilog
	delete requestsToFix;
	delete correctPrinters;
	delete reqArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupInvStatusEmailTemplate" id="1f66131b-3600-4ce8-9b58-6f2fc924ff45">
        <source>fixupInvStatusEmailTemplate(_controller: CnEcReleaseController);
/*
Purpose:			// TFS 43188 (TFS 39618 PATCH 2)
						The release script to create the email templates on the new invoice statuses was wrong, it generated the wrong subject text.
						This script updates the email template to the data on the actual invoice status
Date				Who			Reason
JULY 2017		CNWAB1		Initial creation
*/

/*
Please DON'T call app.initialize in this method - the app is already initialized and already has SUPERUSER set as its user. 
Please DO use the self.hasScriptBeenRunAtAll and self.addScriptRun pair to ensure your script only gets run once.
Please DO use app.writeLog or updateController.logEntry to log the start and end of each method

*/
vars							
	defEmail : CM_InvStatusDefaultEmail;
	invProcess : CM_InvoiceProcess;
	invStatus : CM_InvoiceStatus;
	root : CM_Root;
begin
	root := CM_Root.firstInstance;

	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Invoice Status Email Template FIXUP", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Invoice Status Email Template FIXUP") ;	
	endif;

	
	// ALL DEFAULT EMAILS HAD WRONG NAME
	foreach invProcess in root.allInvoiceProcesses	discreteLock do
		foreach invStatus in invProcess.allStatuses	discreteLock do
			defEmail := root.allInvStatusDefaultEmails[invProcess.pinEmailOffset + invStatus.id];
			if defEmail &lt;&gt; null then
				
				if invStatus.description &lt;&gt; defEmail.name then
					beginTransaction;
					defEmail.setPropertyValue(CM_InvStatusDefaultEmail::name.name, invStatus.description);
					defEmail.setPropertyValue(CM_InvStatusDefaultEmail::subjectLine.name,invStatus.description);
					commitTransaction;
				endif;
			endif;
	
		endforeach;
	
	endforeach;
	
	
	
	
	
	app.writeLog(method.qualifiedName &amp; " Invoice Status Email Template FIXUP  complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Invoice Status Email Template FIXUP complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupReserveTIs" id="56defb25-bf5d-4925-bd68-bcf87e8d013b">
        <source>fixupReserveTIs(_controller: CnEcReleaseController);
/*

Purpose:		remove reserve TIs where getTIs returns null i.e no cargo assigned or been released	

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlger1	Initial creation 43404

*/

vars

	terminal : CM_Terminal;
	iter : Iterator;
	br 	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	invalidReserveTIs  : ObjectSet;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fixing invalid Release Request reserved cargo ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing invalid Release Request reserved cargo") ;	
	endif;
	
	create invalidReserveTIs transient;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		delete iter;
		iter := terminal.allBulkReleaseByTypeByStByCd.createIterator;
		terminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE,null,null,iter);
		
		while iter.next(br) do
			foreach reserveDetail in br.allReserveDetails do
				if not reserveDetail.isKindOf(CM_ReserveTI) then
					continue;
				endif;
				if reserveDetail.allTrackedItems.size = 0 and 
					reserveDetail.allTrackedItemsReleased.size = 0 then
				//	write terminal.code &amp; " " &amp; br.code &amp; " " &amp; reserveDetail.String;
					invalidReserveTIs.add(reserveDetail);
				endif;
			endforeach;
		endwhile;
	endforeach;
	
	beginTransaction;
	invalidReserveTIs.purge;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing invalid Release Request reserved cargo",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("  Finished fixing invalid Release Request reserved cargo complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete iter;
	delete invalidReserveTIs;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupVoyageProcess" id="b76556b4-a088-4ccd-a127-85094ec4f232">
        <source>fixupVoyageProcess();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	iter01 : Iterator;
	workorder : CM_Voyage;
	oArray : ObjectArray; 
	voyProcess : CM_VoyageProcess;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Setting default voyage process. ", LogINFO);
	
	create oArray transient;
	CM_Voyage.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;

	voyProcess := CM_Root.firstInstance.allVoyageProcesses["JMT"];
	
	while iter01.next(workorder) do
		if workorder.myVoyageProcess = null then
			beginTransaction;
			workorder.setPropertyValue("myVoyageProcess",voyProcess);
			commitTransaction;
		endif;
		
		
	endwhile;
	
	app.writeLog(method.qualifiedName &amp; ": Setting default voyage process complete. ", LogINFO);
	
	
	self.addScriptRun(method.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupWorkOrderTransactions" id="5e0d6e37-97a1-45e8-a508-a96f74d5b82a">
        <source>fixupWorkOrderTransactions();
// TFS 39237
vars
	iter01 : Iterator;
	workorder : CM_WorkOrder;
	oArray : ObjectArray; 
	tran : CM_WOTransaction;
	newType : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting terminal reference on WORK ORDER transactions", LogINFO);
	
	create oArray transient;
	CM_WorkOrder.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;

	while iter01.next(workorder) do
		beginTransaction;
			foreach tran in workorder.allTransactions	discreteLock do
				
				
				if tran.type = WO_TRANS_ACTION then
					newType :=  TRANS_TYPE_WO_ACTION;
				elseif tran.type = WO_TRANS_COMPLETE then
					newType :=  TRANS_TYPE_WO_COMPLETE;
				endif;		
	
				if tran.type &lt;&gt; newType then
					tran.setPropertyValue("type",newType);
				endif;
			
				if tran.myTerminal = null then
					tran.setPropertyValue("myTerminal",workorder.myTerminal);
				endif;
			endforeach;
		commitTransaction;
	
	endwhile;

	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Setting terminal reference on WORK ORDER transactions complete", LogINFO);	
epilog
	delete oArray;
	delete iter01;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTeklogixAuditConfig" id="34b75faf-7ac8-4c94-8af6-70656d85448a">
        <source>removeTeklogixAuditConfig(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2019	jlgndl1	Initial creation	TFS 44152

*/

vars

	tmpAC : CM_AuditConfig;
	toDelete : CM_AuditConfig;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Removing Teklogix Audit Config ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Removing Teklogix Audit Config") ;	
	endif;
	
	foreach tmpAC in app.myRoot.allAuditConfigs discreteLock do
		if tmpAC.className = "CM_RadioTelemetryInterface" then
			toDelete := tmpAC;
			break;
		endif;
	endforeach;
	
	if toDelete &lt;&gt; null then
		beginTransaction;
		delete tmpAC;
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Remove of Teklogix Audit Config - complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Remove of Teklogix Audit Config - complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
