    <JadeMethod name="validateMe" id="62141a5c-47ef-42bb-8906-c361dd60948c">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014   cnwdb2	    PAR 35364
// ---------------------------------------------------------------------------
vars
	maxLength	: Integer;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, self.getCodeHeading() &amp; 'Code', null, null);
		app.raiseCMException1(Input_required_field_cdeHeadn, self.getCodeHeading(), null, null); // cnwdb2	PAR 35364
	else
		maxLength := self.maxCodeLength();
		if self.code.length &gt; maxLength then
			app.raiseCMException2(ERR_STRING_TO_LONG, self.getCodeHeading() &amp; 'Code', maxLength.String, null, null);
		endif;
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, self.getCodeHeading() &amp; 'Description', null, null);
		app.raiseCMException1(Input_required_field_cdheadDes, self.getCodeHeading() , null, null); // cnwdb2	PAR 35364


	endif;
	if self.myCodeGroup &lt;&gt; null then
		self.myCodeGroup.myCodeGroupType.validateCode(self.code);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
