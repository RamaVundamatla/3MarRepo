<CollClass name="CM_ObjectByOidEditionDict" id="c8955267-6111-43c8-a0a1-5c1a26711ab1">
    <memberType name="Object"/>
    <superclass name="CM_ExtKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExternalKey name="oid">
        <length>101</length>
        <type name="String"/>
    </ExternalKey>
    <ExternalKey name="edition">
        <type name="Integer"/>
    </ExternalKey>
    <ImplicitInverseRef name="myIterator" id="e3a2b5d2-8b00-4303-8fbf-6f08fcfdca81">
        <embedded/>
        <type name="Iterator"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="add" id="63d1802a-0e28-4245-9dfc-0130fd8b5cb6">
        <lockReceiver/>
        <updating/>
        <source>add(_obj: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpEdition,
	keyEdition	: Integer;
	iter	: Iterator;
	tmpOidStr,
	keyOidStr	: String;
	tmpObj		: Object;

begin

	if _obj = null then
		return;
	endif;
	
	iter := self.myIterator;

	tmpOidStr := _obj.getOidString;
	tmpEdition := _obj.edition;
	self.startKeyGeq(tmpOidStr, 1, iter);
	iter.next(tmpObj);		// need to check there is an object and we have not run off end of collection
	self.getIteratorKeys(keyOidStr, keyEdition, iter);
	
	if tmpObj &lt;&gt; null and tmpOidStr = keyOidStr then
		if tmpEdition = keyEdition then
			// object is in dict with same edtion
			return;
		endif;
		// object in dict with different edition so
		// remove and re-add below
		self.removeKey(keyOidStr, keyEdition);
	endif;
			
	self.putAtKey(tmpOidStr, tmpEdition, _obj);

end;</source>
        <Parameter name="_obj" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="create" id="286c4182-c3fe-460c-b387-c38209659f07">
        <lockReceiver/>
        <updating/>
        <source>create() lockReceiver, updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (not self.isTransient) then
		// if need to change this then would need to change how iterator is handled
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'You cannot cerate persistent instances of this class');
	endif;

	// create iterator for performance so don't have to
	// create/delete repeatadly
	self.myIterator := self.createIterator();

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="2ef1f6ca-51e3-4ad0-bfc3-8bcd6bce8e26">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	delete self.myIterator;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getEditionForObject" id="e1a5a15a-5e12-47cf-89e8-889602bcb248">
        <source>getEditionForObject(_obj : Object) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     Returns -1 if object not found
// ---------------------------------------------------------------------------
vars
	keyEdition	: Integer;
	iter	: Iterator;
	tmpOidStr,
	keyOidStr	: String;
	me			: SelfType;
	
begin

	if _obj = null then
		return -1;
	endif;
	
	if self.myIterator = null then
		// do this so method does not have to be updating
		me := self;
		me.myIterator := self.createIterator();
	endif;
	iter := self.myIterator;
	
	tmpOidStr := _obj.getOidString;
	
	self.startKeyGeq(tmpOidStr, 1, iter);
	self.getIteratorKeys(keyOidStr, keyEdition, iter);
	
	if tmpOidStr &lt;&gt; keyOidStr then
		return -1;
	endif;
	
	return keyEdition;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includes" id="6d959213-8a3b-477d-96bc-3244d7cfde93">
        <source>includes(_obj: MemberType): Boolean;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyEdition	: Integer;
	iter	: Iterator;
	tmpOidStr,
	keyOidStr	: String;
	tmpObj		: Object;

begin

	if _obj = null then
		return false;
	endif;
	
	iter := self.myIterator;

	tmpOidStr := _obj.getOidString;
	
	self.startKeyGeq(tmpOidStr, 1, iter);
	iter.next(tmpObj);		// need to check there is an object and we have not run off end of collection
	self.getIteratorKeys(keyOidStr, keyEdition, iter);
	
	if tmpObj &lt;&gt; null and tmpOidStr = keyOidStr then
		return true;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="remove" id="9d9a82dc-1867-45fd-9ad8-64848ccec5db">
        <lockReceiver/>
        <updating/>
        <source>remove(value: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	keyStr	: String;
begin

	self.removeKeyEntry(value.Object.getOidString(), value.Object.edition, value);
end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="validateEditionForObject" id="c78aea78-1334-4068-85db-54425cbccf12">
        <source>validateEditionForObject(_obj : Object; _errStr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     04 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	expectedEdition	: Integer;
begin

	expectedEdition := self.getEditionForObject(_obj);
	
	if expectedEdition &lt; 0 then
		app.raiseExNoEditionForUpdateObj(_obj);
	else
		exclusiveLock(_obj);
		if _obj.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, _errStr, null, null);
		endif;
	endif;
	
	return expectedEdition;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_errStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
