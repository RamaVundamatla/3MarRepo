<CollClass name="CM_MTPoolingEnquiryLineDict" id="9017b370-d0e9-43a0-bca7-364469298d9c">
    <loadFactor>66</loadFactor>
    <memberType name="CM_MTPoolingEnquiryLine"/>
    <superclass name="MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="threshold"/>
    <MemberKey>
        <property name="CM_MTPoolingEnquiryLine::priority"/>
    </MemberKey>
    <JadeMethod name="includesThreshold" id="fb4ad5ed-8333-434e-b1a4-5d645da2b9a0">
        <source>includesThreshold( _thresh : CM_MTThreshold ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	iter : Iterator;
	enqLine : CM_MTPoolingEnquiryLine;

begin

	if _thresh = null then
		return false;
	endif;

	iter := self.createIterator;
	while iter.next( enqLine ) do
		if _thresh = enqLine.myMTThreshold then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_thresh" type="CM_MTThreshold"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
