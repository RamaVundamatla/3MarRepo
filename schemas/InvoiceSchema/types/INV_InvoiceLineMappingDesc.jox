    <JadeMethod name="fileSilentExceptionHandler" id="d2a3f40e-0818-428b-b48a-1a71e01b4a4e">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDebtorName" id="9db4dcf2-f9dd-4560-a4fb-b77355cf8592">
        <source>getDebtorName(_debtor : CM_Debtor) : String protected;
/*

Purpose:			Gets the debtor name for the debtor passed in

Parameters:			_debtor	CM_Debtor	The debtor to get the name for

Return Value:		String	The debtors name

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	return _debtor.name;
	
end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="90c8c9a8-452f-48e9-980c-01897ee9a942">
        <source>getExportFileName(_startDT :TimeStamp; _extension : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	
begin
	return "InvLineMappingDesc_" &amp; _startDT.date.userFormat($CM_YearFormat) &amp;_startDT.time.formatAsHHMMSS() &amp; _extension ;
epilog

end;</source>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileNameBase" id="6364c8b3-577b-49ac-9d12-2bc8f2d47d9a">
        <source>getExportFileNameBase(_exportPath : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if _exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
	else
		target := _exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_exportPath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvLineTypeDescription" id="6faf82d6-f24d-4763-b513-11478d73b053">
        <source>getInvLineTypeDescription(_invoiceLineDesc : CM_InvoiceLineDesc) : String;
/*

Purpose:			Gets the narration for the invoice line type

Parameters:			_invoiceLineDesc	CM_InvoiceLineDesc	The invoice line type to get the narration for

Return Value:		String	The narration for the invoice line type passed in

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	return _invoiceLineDesc.narration;
	
end;</source>
        <Parameter name="_invoiceLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="a82c7179-dfab-482e-9d15-1941d2c8160c">
        <source>haltProgress(pe : CM_ProgressException; ls : Boolean io) : Integer protected;
/*

Purpose:			halts the progress on the form

Parameters:			pe	CM_ProgressException	The progress exception we got
					ls	Boolean					Holds the current load state

Return Value:		Integer	How we should handle the exception in our code. Whether we continue or abort etc.

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	wasSet : Boolean;
	
begin
	wasSet := ls;
	app.cmsEndLoad(ls);		// from 35872 testing, to avoid an error with msg box in load state
	
	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		
		self.tblData.columns := 1;
		return Ex_Abort_Action;
	else
		if wasSet then
			app.cmsBeginLoad(ls);
		endif;
		return Ex_Continue;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pe" type="CM_ProgressException"/>
        <Parameter name="ls" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="dda42f96-9eb1-4b15-a336-c79ec816fd6c">
        <source>includeObject(_invLineDescMapping : CM_InvoiceLineDescMapping; _invLineTypes : CM_InvLineDescByNarrDupsADict; _debtors : CM_DebtorByNameDict) : Boolean protected;
/*

Purpose:			Whether we should or should not include the item

Parameters:			_invLineDescMapping	CM_InvoiceLineDescMapping		The Invoice Line Mapping to use
					_invLineTypes		CM_InvLineDescByNarrDupsADict	The Invoice Line Types to use
					_debtors			CM_DebtorByNameDict				The debtors to use

Return Value:		Boolean	Representing whether we should or should not include an object in the data table

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	if _invLineTypes.includes(_invLineDescMapping.myInvoiceLineDesc) and _debtors.includes(_invLineDescMapping.myDebtor) then
		return true;
		
	endif;
	
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="_invLineDescMapping" type="CM_InvoiceLineDescMapping"/>
        <Parameter name="_invLineTypes" type="CM_InvLineDescByNarrDupsADict"/>
        <Parameter name="_debtors" type="CM_DebtorByNameDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCreateEditFrame" id="307000ad-0f88-4770-bb55-d03195ef62fd">
        <updating/>
        <source>initCreateEditFrame(_invoiceLineTypeMapping : CM_InvoiceLineDescMapping) updating, protected;
/*

Purpose:			Initialises the Edit frame on the form

Parameters:			_invoiceLineTypeMapping	CM_InvoiceLineDescMapping	The mapping we should use on the frame (Can be null)

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.positionPropertiesFrame();
	self.setQueryControl(self.cmbBankProp);
	self.setQueryControl(self.lblBankProp);
	
	self.doCmbBankPropBuild();
	self.cmbBankProp.enabled	:= false;
	self.cmbBankProp.listIndex	:= self.cmbBankProp.findObject(self.myCurrentBank);
	
	self.setQueryControl(self.cmbDebtor);
	self.setQueryControl(self.lblDebtor);
	self.doCmbDebtorBuild();
	self.cmbDebtor.setFocus();
	
	self.setQueryControl(self.cmbInvoiceLineType);
	self.setQueryControl(self.lblInvoiceLineType);
	self.cmbInvoiceLineType.enabled := true;
	self.doCmbInvLineTypeBuild();
	
	self.setQueryControl(self.cmbInvoiceType);
	self.setQueryControl(self.lblInvoiceType);
	self.cmbInvoiceType.enabled := true;
	self.doCmbInvoiceTypeBuild();

	
	if _invoiceLineTypeMapping &lt;&gt; null then
		self.cmbDebtor.listIndex			:= self.cmbDebtor.findObject(_invoiceLineTypeMapping.myDebtor);
		self.cmbInvoiceLineType.listIndex	:= self.cmbInvoiceLineType.findObject(_invoiceLineTypeMapping.myInvoiceLineDesc);
		self.cmbInvoiceType.listIndex		:= self.cmbInvoiceType.findObject(_invoiceLineTypeMapping.myInvoiceType);
		self.cmbInvoiceLineType.enabled		:= false;
		self.cmbInvoiceLineType.enabled		:= false;
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLineTypeMapping" type="CM_InvoiceLineDescMapping"/>
    </JadeMethod>
    <JadeMethod name="initModalDialog" id="6fc688fe-67e7-4192-a4e6-2937d14e6bb5">
        <source>initModalDialog() protected;
/*

Purpose:			Initializes the modal dialog for the form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.frmModalDialog.centreWindow;
	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.frmModalDialog.backColor 	:= self.backColor;
	self.btnModalDefault.visible 	:= false;
	self.pbProgressBar.top 			:= 38;
	self.lblModalInfo.top 			:= self.pbProgressBar.top + self.pbProgressBar.height + 2;
	self.pbProgressBar.zOrder(0);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="a0d7e127-8973-433e-bde6-c8fd95984359">
        <updating/>
        <source>initQueryFrame() updating, protected;
/*

Purpose:			Initialises the Query Frame

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
10 Apr 2025		navlw1	JIRA-34468: MTN | Filtering on Thin Client Controls Phase 2

*/

vars
	sht					: CMUI_Sheet;
	bank				: CM_Bank;
	invoiceLineDesc		: CM_InvoiceLineDesc;
	invLineTypeArray	: CM_InvLineDescByNarrDupsADict;
	rdg					: CM_RootDebtorGroup;
	debtor				: CM_Debtor;
	rootDebtors			: CM_DebtorNodeByNameDict;
	debtors				: CM_DebtorByNameDict;
	
begin
	sht := self.shtQuery1;
	sht.caption	:= "Debtor Mappings";
	
	if self.cmbBank.listCount &gt; 1 then
		self.setQueryControl(self.cmbBank);
		self.setQueryControl(self.lblBank);
		self.cmbBank.setFocus();
	else
		self.cmbBank.visible	:= false;
		self.lblBank.visible	:= false;
	endif;
	
	self.mulInvLineTypes.top := self.cmbBank.top;
	self.setQueryControl(self.mulInvLineTypes);
	self.setQueryControl(self.mulDebtors);
	
	bank := self.cmbBank.listObject.CM_Bank;
	
	create invLineTypeArray transient;
	
	foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock where not invoiceLineDesc.isNotAvailableForEntry do
		invLineTypeArray.add(invoiceLineDesc);
	endforeach;
	
	self.mulInvLineTypes.top						:= self.cmbBank.top + 25;
	self.mulInvLineTypes.left						:= self.cmbBank.left; 	
	self.mulInvLineTypes.width						:= self.cmbBank.width + 25; // navlw1 #JIRA-34468 10/04/2025
	self.mulInvLineTypes.height						:= 180; 					// navlw1 #JIRA-34468 10/04/2025
	self.mulInvLineTypes.myAvailableListBox.sorted	:= true;
	self.mulInvLineTypes.mySelectedListBox.sorted	:= true;
	self.mulInvLineTypes.setupControl(null, invLineTypeArray, INV_InvoiceLineMappingDesc::getInvLineTypeDescription.name);
	self.mulInvLineTypes.availableHeading			:= app.getErrorString(Availab_invoice_line_types);
	self.mulInvLineTypes.selectedHeading			:= app.getErrorString(Selecte_invoice_line_types);
	self.mulInvLineTypes.myBaseForm					:= self;
	// Start 20.3.2023 navmk20	TFS 56954
	//self.mulInvLineTypes.setSelected(null);
	if self.allInvoiceLineTypes &lt;&gt; null then
		self.mulInvLineTypes.setSelected(self.allInvoiceLineTypes);
	else
		self.mulInvLineTypes.setSelected(null);
	endif;
	// End 20.3.2023 navmk20	TFS 56954
	rdg := bank.getRootDebtorGroup();
	
	create rootDebtors transient;
	
	rdg.getDebtors(rootDebtors);
	
	create debtors transient;
	
	foreach debtor in rootDebtors as CM_Debtor discreteLock do
		debtors.add(debtor);
	endforeach;
	
	self.mulDebtors.top							:= self.mulInvLineTypes.top + self.mulInvLineTypes.height + 5;
	self.mulDebtors.left						:= self.mulInvLineTypes.left;
	self.mulDebtors.width						:= self.mulInvLineTypes.width;
	self.mulDebtors.height						:= 180;  						// navlw1 #JIRA-34468 10/04/2025
	self.mulDebtors.myAvailableListBox.sorted	:= true;
	self.mulDebtors.mySelectedListBox.sorted	:= true;
	self.mulDebtors.setupControl(null, debtors, INV_InvoiceLineMappingDesc::getDebtorName.name);
	self.mulDebtors.availableHeading			:= app.getErrorString(Available_debtors);
	self.mulDebtors.selectedHeading				:= app.getErrorString(Selected_debtors);
	self.mulDebtors.myBaseForm					:= self;
	// Start 20.3.2023 navmk20 TFS 56954
	//self.mulDebtors.setSelected(null);
	if self.allDebtors &lt;&gt; null then
		self.mulDebtors.setSelected(self.allDebtors);
	else
		self.mulDebtors.setSelected(null);
	endif;
	// End 20.3.2023 navmk20 TFS 56954
	sht.visible := true;
	
epilog
	delete invLineTypeArray;
	delete rootDebtors;
	delete debtors;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionPropertiesFrame" id="153caafe-8199-425c-a1e7-f3b8b408e4f8">
        <source>positionPropertiesFrame() protected;
/*

Purpose:			Positions the Properties Frame on the current form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.frmProperties.left		:=	(self.width / 2) - (self.frmProperties.width / 2);
	self.frmProperties.top		:=	50;			// position higher
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="6b4d885a-881b-4cbd-b290-2d92204880ae">
        <source>positionQueryFrame() protected;
/*

Purpose:			Positions the Query Frame on the current form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566
10 Apr 2025		navlw1	JIRA-34468: MTN | Filtering on Thin Client Controls Phase 2

*/

begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	65;			// position higher
	self.frmQuery.height	:=	500 ;		// stretch to fit the debtor and service multi-select group boxes
	self.frmQuery.width		:=	500;		// stretch to fit the debtor and service multi-select group boxes
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="4aa66f01-5fca-44ca-97a3-463fc8fdaa58">
        <source>searcherShowHideControls(_hide: Boolean) protected;
/*

Purpose:			What to do when we show/hide the searcher

Parameters:			_hide	Boolean	Whether or not we are showing or hiding the searcher

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.btnAddItem.enabled := _hide;
	
	if self.tblData.selectedCount &gt; 0 then
		self.btnEditItem.enabled := true;
		self.btnDelete.enabled := true;
		
	elseif self.tblData.rows &gt; 1 then
		self.btnImportCSVMap.enabled := true;
		self.btnExportCSVMap.enabled := true;
		
	else
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
		self.btnImportCSVMap.enabled := false;
		self.btnExportCSVMap.enabled := false;
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
