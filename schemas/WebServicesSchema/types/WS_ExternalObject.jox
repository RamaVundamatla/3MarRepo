<Class name="WS_ExternalObject" id="bf54b9af-6d75-4bd5-b91d-15ad27d0970a">
    <superclass name="WS_Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="setCMIF_ExternalWSProxy" id="e0e3ce65-89f6-4a4a-b80f-fb73afacfb06">
        <source>setCMIF_ExternalWSProxy(_cmif : CMIF_ExternalWSProxyObject input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2018	jlger1	Initial creation

*/

vars
	prop : Property;
	value : Any;
begin
	foreach prop in self.class.allProperties do
		if _cmif.class.getProperty(prop.name) = null then
			//write prop.name;
		else
			
			value:=self.getPropertyValue(prop.name);
			
			_cmif.setPropertyValue(prop.name,value);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ExternalWSProxyObject" usage="input"/>
    </JadeMethod>
</Class>
