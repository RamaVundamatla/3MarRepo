    <JadeMethod name="vCreateIterator" id="fb5f63d7-a9bd-4038-8ef0-fbdfbe4806dd">
        <updating/>
        <source>vCreateIterator(_collection : Collection; _clearControl : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		12 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myIterator;
	self.myIterator 		:= _collection.createIterator();
	self.clearControl 	:= _clearControl;
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_clearControl" type="Boolean"/>
    </JadeMethod>
