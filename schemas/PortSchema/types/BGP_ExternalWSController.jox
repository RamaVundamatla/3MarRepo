    <JadeMethod name="initApp" id="3f0304a8-a4c4-410d-8298-574ca638ab5c">
        <updating/>
        <source>initApp() updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	inheritMethod();
	self.beginTimer(BGP_Object.BGP_HandShakeInterval, Timer_Continuous, RetryTimerEvent);
	
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerStarting, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerStopped, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerRunning, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerSnapshot, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	
	app.writeLog(method.qualifiedName &amp; " beginNotification for Navis Smart Producer",LogINFO); // ### TFS 50669 19AUG2021 NAVAB1

	// Set this BGP controller status to RUNNING
	app.myTrxUA.trxUpdateEWSBGPStatus(self,EWS_STATUS_RUNNING, app.myPassport);
	
epilog

end;</source>
    </JadeMethod>
