    <JadeMethod name="setProxy" id="62d160dc-b8f9-4bc3-b8b2-c00d36f18b64">
        <updating/>
        <source>setProxy(_name : String; _bank : CM_Bank; _remarks : String; _gl : CM_GLCode; _group : CM_ServiceGroup; _rateType : Integer; _ct : CM_CalculationType; _tax : CM_TaxCode;
			_notAvailableForEntry : Boolean;
			_externalRef1 : String;
			_externalRef2 : String;
			_serviceTypes : CM_ServiceTypeSet	// 23/08/22	navkc1	#54569
			) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars

begin
	self.name := _name[1:60];
	self.bank := _bank;
	self.remarks := _remarks;
	self.genLCode := _gl;
	self.group := _group;
	self.myTaxCode := _tax;
	self.isNotAvailableForEntry := _notAvailableForEntry;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_gl" type="CM_GLCode"/>
        <Parameter name="_group" type="CM_ServiceGroup"/>
        <Parameter name="_rateType" type="Integer"/>
        <Parameter name="_ct" type="CM_CalculationType"/>
        <Parameter name="_tax" type="CM_TaxCode"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalRef2" type="String"/>
        <Parameter name="_serviceTypes" type="CM_ServiceTypeSet"/>
    </JadeMethod>
