    <JadeMethod name="displayString" id="0f5dce4a-af5f-4e85-80cb-a505be8e5c98">
        <source>displayString(): String;
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
begin

	if self.num20Gen &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20Gen.String &amp; "          20' GEN" &amp; "          " &amp; odimHazDetail &amp; CrLf;		// 22/09/2008 cnwar2 #17980/CCMS1619
	endif;																																// odim/hax details added

	if self.num20GenHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20GenHC.String &amp; "          20' GEN HC" &amp; "       " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num20Int &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20Int.String &amp; "          20' INT" &amp; "          " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num20IntHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20IntHC.String &amp; "          20' INT HC" &amp; "       " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num20Flat &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20Flat.String &amp; "          20' FLAT" &amp; "         " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num20FlatHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num20FlatHC.String &amp; "          20' FLAT HC" &amp; "      " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40Gen &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40Gen.String &amp; "          40' GEN" &amp; "          " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40GenHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40GenHC.String &amp; "          40' GEN HC" &amp; "       " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40Int &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40Int.String &amp; "          40' INT" &amp; "          " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40IntHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40IntHC.String &amp; "          40' INT HC" &amp; "       " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40Flat &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40Flat.String &amp; "          40' FLAT" &amp; "         " &amp; odimHazDetail &amp; CrLf;
	endif;
	
	if self.num40FlatHC &gt; 0 then
		str := str &amp; self.ssCode &amp; "          " &amp; self.num40FlatHC.String &amp; "          40' FLAT HC" &amp; "      " &amp; odimHazDetail &amp; CrLf;
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="6688d08b-1bf6-481b-9c78-fa3367d6a92f">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isForty,
	isHC,
	isFlat,
	isInt		: Boolean;
	isoType		: CM_ISOType; 
begin
	//-----------------------
	isForty := _ti.isAttributeTrue(TI_Attrib_IsForty);
	isoType := _ti.getISOTypeObject();
	if isoType &lt;&gt; null then
		isFlat := isoType.isFlat;
	endif;
	isInt := _ti.isAttributeTrue(TI_Attrib_RequiresPower);
	isHC := _ti.isAttributeTrue(TI_Attrib_IsHiCubed);
	//-----------------------
	
	if isForty then
		if isFlat then
			if isHC then
				self.num40FlatHC := self.num40FlatHC + 1;
			else
				self.num40Flat := self.num40Flat + 1;
			endif;
		elseif isInt then
			if isHC then
				self.num40IntHC := self.num40IntHC + 1;
			else
				self.num40Int := self.num40Int + 1;
			endif;
		else //isGen then
			if isHC then
				self.num40GenHC := self.num40GenHC + 1;
			else
				self.num40Gen := self.num40Gen + 1;
			endif;
		endif;
	else //is20
		if isFlat then
			if isHC then
				self.num20FlatHC := self.num20FlatHC + 1;
			else
				self.num20Flat := self.num20Flat + 1;
			endif;
		elseif isInt then
			if isHC then
				self.num20IntHC := self.num20IntHC + 1;
			else
				self.num20Int := self.num20Int + 1;
			endif;
		else //isGen then
			if isHC then
				self.num20GenHC := self.num20GenHC + 1;
			else
				self.num20Gen := self.num20Gen + 1;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
