    <JadeMethod name="addToolbarControls" id="7041e5be-2537-4e26-8785-ad23cdd50ac2">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnSelectAll_click" id="caec5096-00cb-429c-a73e-e7d74b81c4c9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectAll_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.lstVoyages.allSelectedObjects.isEmpty then
		self.lstVoyages.selectAll();
	else
		self.lstVoyages.clearSelected();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="65f01308-7ca8-4980-aff1-92b2424da051">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		22 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.permissionView		:= PmAdmShipProfile;
	self.permissionMaint	:= PmAdmShipProfile;

	self.helpFileName := HelpFile_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="c857b6d2-2acf-41d2-a87a-9268919021ff">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="2087cb01-96d2-489b-86e4-53bc478d2c24">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	self.myController.allVoyages.clear;
	self.lstVoyages.allSelectedObjects.copy(self.myController.allVoyages);

	self.myController.myCallingForm.sendMsg("doQueryVessel");
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="af821508-dfd0-4fc6-a51a-ee40cdef076e">
        <source>doQuery();
// ---------------------------------------------------------------------------
// Created:		23 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 02/08/2011	cnwcs5	Tidy up when removing old KPI classes

vars
	iter	: Iterator;
	kpi 	: CM_KPI;
	aVoy 	: CM_Voyage;
	vkpi	: CM_KPIVoyageEntity;
	list	: CMUI_ListTable;
begin
	if self.myController = null then
		return;
	endif;
	
	if self.myController.myVessel = null then
		return;
	endif;
	
	// find all voyages for the vessel forwhich there are KPI details
	iter := self.myController.myVessel.allVoyageKPIEntities.createIterator;
	
	self.myController.myVessel.allVoyageKPIEntities.startKeyGeq (KPI_Type_Voyage, null, null, iter);
	
	while iter.next (kpi) do
		if kpi.type &lt;&gt; KPI_Type_Voyage then
			break;
		endif;
		
		vkpi := kpi.CM_KPIVoyageEntity;
		
		if vkpi.myVoyage = null or vkpi.myVoyage = self.myController.myVoyage then
			continue;
		endif;
		
		self.allVoyages.addNoDuplicates(vkpi.myVoyage, false);
	endwhile;
	
	list 		:= self.lstVoyages;
	list.rows 	:= 0;
	
	foreach aVoy in self.allVoyages reversed do
		list.addItemObject(aVoy.code &amp; " - " &amp; aVoy.arrivedDT.Date.String, aVoy);
	endforeach;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="00df55a8-166e-4c53-b897-9396f9070f23">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;	
	self.showToolbar	:=	true;	
	inheritMethod();
	
	self.doQuery();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="04c881bb-92dd-4dd2-8c64-e6bc25d2e146">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006846, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0006847, locale);
	btnSelectAll.translateCaption(Xlat_0006848, locale);
end;</source>
    </JadeMethod>
</GUIClass>
