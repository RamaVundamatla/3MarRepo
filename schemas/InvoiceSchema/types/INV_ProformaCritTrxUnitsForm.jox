    <JadeMethod name="setUpCombo" id="32d14314-60bd-4869-ad1c-1e912edfb8ae">
        <source>setUpCombo( _row : Integer; _comboValue : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	combo : CMUI_ComboBox;

begin

	combo := self.cmbUnits.getControl(_row).CMUI_ComboBox;
	if combo = null then
		combo := self.cmbUnits.loadControl(_row).CMUI_ComboBox;
		combo.itemData[ combo.addItem( CM_ProformaTransactionCriteria.UserUnit) ] := CM_ProformaTransactionCriteria.UnitType_UserUnit;
		combo.itemData[ combo.addItem( CM_ProformaTransactionCriteria.PerDay) ] := CM_ProformaTransactionCriteria.UnitType_PerDay;
	endif;
	self.tblUnits.accessCell(_row,2).cellControl := combo;
	combo.listIndex := combo.findStringExact(1, _comboValue);

epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_comboValue" type="String"/>
    </JadeMethod>
