end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextNullObject" id="2025ba2e-b993-45b0-a0b2-4c0ab58d7736">
        <source>doMnuContextNullObject();
//-----------------------------------------
// Created: December 2003 By: cnwgd1
//-----------------------------------------
vars
begin
	self.mnuContextJobCargoList.visible := false;
	self.mnuContextRenumber.visible := false;
	self.mnuContextSep01.visible := false;
	self.mnuContextRemarks.visible := false;
	self.mnuContextRemarks.userObject := null;
	self.mnuContextJobDelete.visible := false;
	self.mnuContextJobDelete.userObject := null;
	self.mnuContextJobPos.visible := false;
	self.mnuContextJobEdit.visible := false;
	self.mnuContextJobEdit.userObject := null;
	self.mnuContextJobNew.visible := false;

	self.mnuContextJobUnload.visible := false;
	self.mnuContextJobLoad.visible := false;
	self.mnuContextJobLoad.userObject := null;
	
	self.mnuContextJobDown.visible := false;
	self.mnuContextJobUp.visible := false;
	self.mnuContextJobDown.userObject := null;
	self.mnuContextJobUp.userObject := null;
	self.mnuContextJobTimes.visible := true;
	self.mnuContextLashInfo.visible := true;
