    <JadeMethod name="setupThumbnailDetails" id="12ab47ee-2e26-424c-84b5-5733a2289da2">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theForm		: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	inheritMethod();
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_StatusThumb);
	theForm.setTblDataEntRows(ETDef_StatusThumb);

	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Abbreviation, false);
	//theForm.zAddSortColumn(ETRow_Description, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_StatusThumb);
	theForm.shtTblInput1.visible := true;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4ed13b56-90b0-4d4f-b68c-a52107d2ac78">
        <updating/>
        <source>showThumbnail(_status : CM_CargoStatus) updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	jCell		: JadeTableCell;
begin
	if _status = null then
		return;
	endif;
	
	tbl := self.myForm.tblInput1;
	
	tbl.setValueByName(ETRow_Abbreviation, _status.abbreviation);
	tbl.setValueByName(ETRow_Description, _status.description);
	jCell := tbl.accessCell(tbl.getRowByName(ETRow_Colour), CM_EntryTable.ColumnValue);
	jCell.backColor := _status.colour;
	
	tbl.hideRowByName(ETRow_InterModal, false);	// TFS 53084 jlizm1 02/05/2022
	
end;</source>
        <Parameter name="_status" type="CM_CargoStatus"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="dfa68790-40d5-4192-a96e-ac7dc32c447e">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	status	: CM_CargoStatus;
	jCell 	: JadeTableCell;
begin
	status := _obj.CM_CargoStatus;

	if (_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			jCell := myForm.tblData.accessCell(_idxRow, colourColumn);
			jCell.text := null;			
			jCell.backColor := status.colour;	
		endif;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
