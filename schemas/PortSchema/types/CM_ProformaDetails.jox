<Class name="CM_ProformaDetails" id="2598d724-eff4-4a87-9fe8-09971f246f61">
    <superclass name="CM_FinancialObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Saved pro forma invoice line details, used to reprint cash receipt and for cash reporting.</text>
    <DbClassMap file="proForma"/>
    <ExplicitInverseRef name="allCashPayments" id="9e71af3c-6ee6-4f82-b567-6af036f559e2">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_CashPaymentSet"/>
