    <JadeMethod name="loadDB" id="17bfa4ba-7537-4525-b869-2f83eaf9b05d">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*
Date		Who		Reason
07 September 2016	cnwer1	Initial creation TFS 2602
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
*/
vars
	proxy,
	realRelease : CM_BulkRelease;
	cmif 	: CMIF_EDIReleaseRequest;
	releaseItem : CM_ReserveDetail;
	resetCompleted,
	email,
	found : Boolean;
	ediTrackedItem : CM_EDITrackedItem;
	releasesToAdd,
	releasesToUpdate,
	releasesToDelete	: ObjectSet;
	doPartial : Boolean;
	coparnRules 		: CM_EDIPartyCoparnRules;
	newStatus			: Integer;
begin
	//inheritMethod(_validateOnly, _passport);
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if self.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS  or
		self.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X or
		self.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
		return;
	endif;
	
	realRelease:= self.getBulkRelease();
	create cmif transient;
	
	cmif.allEDITIs.add (self);
	
	doPartial	:= self.getMyTerminal.getConfig(EdiReleaseAllowPartial).Boolean;	
	coparnRules:= self.getCoparnRules();
	if self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if self.sequence &lt;&gt; null then
			found := false;
			foreach releaseItem in realRelease.allReserveDetails do
				if releaseItem.sequence = self.sequence then
					cmif.myReserveDetailDel := releaseItem;
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				ediTrackedItem := self;
				app.myTrxUA.trxUpdateEDITIStatus(ediTrackedItem, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, _passport);
				
				return ;
			endif;
		endif;
		cmif.myBulkRelease:=realRelease;
		create releasesToDelete transient;
		releasesToDelete.add(cmif);
		if coparnRules &lt;&gt; null then
			email := coparnRules.sendEmailForDeletes;
		
		endif;
		self.myEDIData.CM_EDIDataReleaseRequest.loadDB_Deletes (releasesToDelete,  doPartial, email,  _passport);	
			
		//do the delete
	elseif self.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or self.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE  then
		create releasesToAdd transient;
		create releasesToUpdate transient;
		if realRelease = null then
			create proxy transient;
			cmif.myBulkRelease:=proxy;
			releasesToAdd.add(cmif);
			
		else
			beginLoad;
			proxy	:=	realRelease.pxyCreateUpdateProxy();
			endLoad;
			cmif.myBulkRelease:=proxy;
			releasesToUpdate.add(cmif);
			
			if coparnRules &lt;&gt; null then
				email := coparnRules.sendEmailForUpdates;
				resetCompleted:= coparnRules.resetCompletedOnQtyIncrease;
			endif;
		endif;
		
		//need to set proxy br fro ediTI
		self.setProxyBulkRelease(proxy,null,null);
		
		if realRelease = null then		
			self.myEDIData.CM_EDIDataReleaseRequest.loadDB_Adds (releasesToAdd,  doPartial,  _passport);
		else
			self.myEDIData.CM_EDIDataReleaseRequest.loadDB_Updates(releasesToUpdate,doPartial,resetCompleted,email, _passport);
		endif;
	endif;
	
	
	newStatus := self.myEDIData.getStatusFromEDITrackedItems(false); 
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self.myEDIData, newStatus);	// par 27392 cnwrs1 14 Apr 2011
epilog
	delete cmif;
	delete releasesToDelete;
	delete releasesToAdd;
	delete releasesToUpdate;
	
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadPort" id="39a0a993-0937-4d92-b814-ee37dbc957a2">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort( set : Boolean; _value : String io ) mapping;

/*
Purpose:	protected the old 3 digit codes

Date				Who		Reason
31 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	port	: CM_Port;
	
begin
	if set then
		return;
	endif;
	
	if self.loadPort.length = 3 then
		port	:= app.myRoot.allLocodesByShortCode.getAtKeyGeq( self.loadPort, null );
		if port &lt;&gt; null and port.portCode = self.loadPort then
			_value	:= port.code;
		else
			_value	:= self.loadPort;
		endif;
	else
		_value		:= self.loadPort;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processAttributeDependencies" id="c9bf18b3-0b15-41a7-aefc-3a2c106d57b1">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
/*
// Date			Who		Reason
// 11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
*/
vars
	
begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then
	else
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setConsignorVoyage( self.getConsignorVoyage() );	// cnwrl1 11/06/2010 PAR 24299
	endif;
epilog
	
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setConsignorVoyage" id="62b77d3f-740e-4928-8f86-f62d61bf3110">
        <updating/>
        <source>setConsignorVoyage( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
	
vars
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.consignorVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.consignorVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.consignorVoyage.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.consignorVoyage	:= _value[ 1 : self.consignorVoyage.maxLength ];
	
	if not self.isTransient and
	   self.consignorVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.consignorVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.consignorVoyage.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="56e0dc32-6578-44e4-ab5f-31bf71676554">
        <updating/>
        <source>setForUpdate(_proxyEDITI : SelfType) updating;

/*
Purpose:	Set all of the properties when the edit functionality is selected and saved.

Date				Who		Reason
08 September 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	prop		: Property;
	propDict	: PropertyNDict;
	
begin
	inheritMethod(_proxyEDITI);
	
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setConsignorVoyage(_proxyEDITI.getConsignorVoyage());	// cnwrl1 15/06/2010 PAR 24299
	
	propDict	:= self.class.getProperties();
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
	// make sure the following fields are always upper case
	self.releaseRequestNumber	:=	self.releaseRequestNumber.toUpper();		// cnwrl1 06/05/2010 PAR 23847
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromEDIBookingTI" id="44e0ef43-88af-4290-9dbd-c4628de43632">
        <updating/>
        <source>setFromEDIBookingTI(_bookingItem : CM_EDIBookingItemTI input) updating;
/*

Date		Who		Reason
23 June 2015	cnwer1	Initial creation PAR
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/

vars

begin
	self.setId(_bookingItem.id.toUpper);
	self.cargoType		:= _bookingItem.cargoType;
	self.fullOrMT		:= _bookingItem.fullOrMT;
	self.cargoTypeDescr	:= _bookingItem.cargoTypeDescr;
	self.description	:= _bookingItem.description;
	self.messageMode		:= _bookingItem.messageMode.toUpper;
	self.subTerminalCode	:= _bookingItem.subTerminalCode;
	self.setVoyageCode(_bookingItem.getVoyageCode);
	
	self.isoType:=_bookingItem.isoType;
	self.isoTypeGroup:=_bookingItem.isoTypeGroup;
	self.remarks:=_bookingItem.remarks;
	self.sequence:=_bookingItem.sequence;
	self.operatorCode:=_bookingItem.getOperatorCode;
	
epilog

end;</source>
        <Parameter name="_bookingItem" type="CM_EDIBookingItemTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyBulkRelease" id="8297a211-50b6-403b-bd1c-4c0f7152a9b0">
        <source>setProxyBulkRelease(_proxy:CM_BulkRelease input;
					_reservesToDelete,
					_reservesToKeep	: CM_ReserveDetailSet input);
/* Changes

Date		Name	TFS#	Description
============================================================================
13/09/2016	cnwer1	2606	Initial creation 
09/03/2017	cnwrs1	3116 	only match on a release item once
10/07/2018	jlgrs1	38808 	JMT - Full and Partial loading not working correctly
24/01/2019	jlgka1	41708	As a result of the changes in the CM_BulkRelease.setProxy
							we also need to add myBOLIn here.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
============================================================================*/
vars
	root 					: CM_Root;
	mtGradeArray			: IntegerArray;
	realBulkRelease 		: CM_BulkRelease;
	terminal				: CM_Terminal;
	carrierId 				: String;
	dateRequested			: TimeStamp;
	deliveryReasonCode 		: Integer;
	freightPayerCode		: String;	//22 Nov 2013	NDL	Par 32057
	booking					: CM_BookingRef;
	operator				: CM_Operator;
	voyage 					: CM_Voyage;			
	ediReleaseData 			: CM_EDIDataReleaseRequest;
	voyageCode 				: String;
	transferToTerminal		: CM_Terminal;	//22 Nov 2013	NDL	Par 32057
	allPackLocations		: StringArray;
	subTerminal 			: CM_SubTerminal;
	stopEDIUpdates			: Boolean;	// par 29480 April 2012
	allEDIFiles 			: CM_EDIFileArray;	// CCMS POL 2122 / PAR 28696 cnwrs1
	statusBulkRelease		: Integer;
	pxyReserve,
	matchedReserve			: CM_ReserveDetail;
	ti,pxyTI				: CM_TrackedItem;
	releaseType 			: Integer;
	estimatedRequiredDate	: TimeStamp;	//22 Nov 2013	NDL	Par 32057
	deliveryReleaseNumber	: String;	//22 Nov 2013	NDL	Par 32057
	isInLoadState,doPartial	: Boolean;
	bookingConfirmation 	: String;	//22 Nov 2013	NDL	Par 32057
	expTimeStamp 			: TimeStamp;
	canHiLoCube 			: Boolean;
	bolIn					: CM_BOLIn; //jlgka1 TFS 41708
begin
	root :=app.myRoot;
	realBulkRelease 	:= _proxy.pxyGetRealObject();
	terminal			:= self.getMyTerminal();
	doPartial 			:= terminal.getConfig(EdiReleaseAllowPartial).Boolean;
	ediReleaseData := self.myEDIData.CM_EDIDataReleaseRequest;
	
	if self.releaseRequestNumber = null then
		app.raiseCMException1(Input_required_field_Required, ETRow_ReleaseRequestNumber, ETRow_ReleaseRequestNumber, self); // cnwdb2	PAR 35364
		return;
	endif;
	
	// use default values means its a coparn file
	if self.usesDefaultValues() and realBulkRelease &lt;&gt; null then
		statusBulkRelease 	:= _proxy.status;
		releaseType 		:= _proxy.type;
		carrierId 			:= _proxy.carrierId;
		deliveryReasonCode 	:= _proxy.deliveryReasonCode;
		subTerminal 		:= _proxy.mySubTerminal;
		if self.requestDateDoUpdate then	
			// there must have been a relevant DTM segemnt in the file
			dateRequested	:=	self.requestDate;
		else
			// leave requested date as it was - there was nothing in the file :-(
			dateRequested	:= _proxy.dateRequested;
		endif;
		canHiLoCube:=_proxy.canBeHiLoCube; //epr TFS 2606 10/3/17 decided to default coparn from release 
	else
		statusBulkRelease 	:= app.releaseStatusStringToEnum(self.statusBulkRelease.properCase);
		releaseType			:= app.releaseRequestTypeStringToEnum(self.releaseTypeStr);
		carrierId 			:= self.carrierCode;
		if self.requestDate.isValid then
			dateRequested		:= self.requestDate;
			dateRequested 		:= dateRequested.cnZeroSeconds();
		else
			dateRequested := null;
		endif;
		deliveryReasonCode 	:= self.deliveryReason;
		subTerminal 		:= terminal.allSubTerminals[self.subTerminalCode];
		if self.availabilityGrades.trimBlanks() &lt;&gt; null then
			create mtGradeArray transient;
			self.getAllAvailabilityGrades(mtGradeArray);
		endif;
		canHiLoCube :=self.canBeHiLoCube;
	endif;
	
	expTimeStamp := null;
	estimatedRequiredDate := null;	//22 Nov 2013	NDL	Par 32057
	if realBulkRelease &lt;&gt; null then
		freightPayerCode := realBulkRelease.freightPayerCode;	//22 Nov 2013	NDL	Par 32057
		transferToTerminal := realBulkRelease.myTransferToTerminal;	//22 Nov 2013	NDL	Par 32057
		allPackLocations := realBulkRelease.allPackLocations;	//cnwmc5 - 19 Nov 2013 - PAR 32086
		stopEDIUpdates	:= realBulkRelease.blockEDIUpdates;		// par 29481 May 2012
		estimatedRequiredDate := realBulkRelease.dateEstimatedRequired;	//22 Nov 2013	NDL	Par 32057
		expTimeStamp := realBulkRelease.expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
		deliveryReleaseNumber := realBulkRelease.deliveryReleaseNumber;	//22 Nov 2013	NDL	Par 32057
		bookingConfirmation := realBulkRelease.bookingConfirmation;	//22 Nov 2013	NDL	Par 32057
	endif;
	
	//13 Feb 2017	NDL	TFS 3368
	if self.expiryTimeStamp.Date.isValid then
		expTimeStamp := self.expiryTimeStamp;
	endif;
	
	//22 Nov 2013	NDL	Par 32057
	if self.estimatedRequiredDate.Date.isValid then
		// they passed one in use that
		estimatedRequiredDate := self.estimatedRequiredDate;
	endif;
	
	if self.bookingConfirmation &lt;&gt; null then
		bookingConfirmation := self.bookingConfirmation;
	endif;
	
	if self.getFreightPayerCode &lt;&gt; null then
		freightPayerCode := self.getFreightPayerCode;
	endif;
	
	if self.deliveryReleaseNumber &lt;&gt; null then
		deliveryReleaseNumber := self.deliveryReleaseNumber;
	endif;
	
	if self.operatorCode &lt;&gt; null then
		operator	:=	root.allOperators[self.operatorCode];
		if operator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, ETRow_Operator, self);
		endif;
	endif;
	
	if self.carrierCode &lt;&gt; null and root.allCarriers[self.carrierCode] = null then
		app.raiseCMException1(ERR_Carrier_Unknown, self.carrierCode, ETRow_Carrier, self);
	endif;
	
	if self.freightForwarder &lt;&gt; null and root.allConsigneeConsignors[self.freightForwarder] = null then
		app.raiseCMException1(ERR_INVALID_FreightForwarder, self.freightForwarder, ETRow_FreightForwarder, self);
	endif;
	
	self.getVoyageForRelease (  realBulkRelease,  voyage, voyageCode);	
	
	if self.bookingRef &lt;&gt; null then
		if operator = null or voyage = null then
			app.raiseCMException3(	Booking_Requires_Oper_Voyage,
									self.bookingRef,
									self.operatorCode,
									voyageCode, 	// par 29402 May 2012
									ETRow_BookingRef,
									self);
		else
			booking	:= terminal.getBookingReference(operator.code, self.bookingRef, voyage);
			if booking = null then
				app.raiseCMException3(	Booking_DoesNotExist4_OpVoyage,
										self.bookingRef,
										self.operatorCode,
										voyageCode, 	// par 29402 May 2012
										ETRow_BookingRef,
										self);
			endif;
		endif;
	endif;

	if self.destTerminal &lt;&gt; null then	//22 Nov 2013	NDL	Par 32057	
		// they passed one in use that
		transferToTerminal := root.allTerminals[self.destTerminal];
		if transferToTerminal = null then
			app.raiseCMException1(Err_InvalidTerminal, self.destTerminal, ETRow_DestTerminal, self);
		endif;
	endif;
	
	// Check that EDI Date statusBulkRelease is valid option
	if statusBulkRelease = BR_NOTSET then
		app.raiseCMException1(ERR_INVALID_StatusBulkRelease, self.statusBulkRelease.properCase(), ETRow_StatusBulkRelease, self);
	endif;
	
	if not self.releaseByType then
		if self.id = null or self.cargoType = null then
			app.raiseCMException2(ReleaseByID_RequiresMoreInform, self.releaseRequestNumber, self.releaseRequestNumber, ETRow_Id, self);
			return;
		else
			ti :=self.findTrackedItem(realBulkRelease);
			if ti = null then
				app.raiseCMException3(Specfied_Cargo_DoesNotExist, self.id, self.cargoTypeDescr, terminal.code, ETRow_Id, self);
				return;
			endif;
			
			pxyTI	:=	app.myProxyManager.getProxyObject(ti).CM_TrackedItem;
				
			if pxyTI &lt;&gt; null and not self.allowCargoMultiReleases  then	//PAR25759 - cnwsh3 27/09/2010 Need to allow for releases that allow multi cargo items.
				app.raiseCMException1(Attempt_Release_Cargo_Twice, self.id, ETRow_Id, self);
				return;
			endif;
			
			// Make a proxy of this TrackedItem.
			if pxyTI = null then  //PAR25759 - cnwsh3 27/09/2010 Need to allow for releases that allow multi cargo items.
				app.cmsBeginLoad(isInLoadState);
				pxyTI	:=	ti.pxyCreateUpdateProxy().CM_TrackedItem;
				app.cmsEndLoad(isInLoadState);
			endif;
			// this next bitt seems to be just to stop the same ti being used in &gt;1 release but it only checks releases within this file
				// so wont pick up releases that have already beend loaded - not sure if this is WAI or not (cnwcs5 - feb 2013)
				//if pxyTI.allBulkReleasesAssigned[_proxy.type, _proxy.status, _proxy.code, _proxy.dateRequested] = null then
			if not _proxy.allTrackedItemsAssigned.includes (ti) and not _proxy.allTrackedItemsReleased.includes (ti) then	// par 31185
				// now the proxy release has the proxy TI in its assigned collection - maybe it should be release ****
				pxyTI.allBulkReleasesAssigned.add(_proxy);
			else
				delete pxyTI;
			endif;
		endif;
		bolIn := _proxy.myBOLIn;
	endif;
	
	if releaseType = BR_TYPE_INVALID then
		app.raiseCMException1(Invalid_Release_Request_Type, self.releaseTypeStr.display, ETRow_ReleaseType, self);
	endif;
	
	// Any port code supplied must be a valid port code
	if self.loadPort &lt;&gt; null and root.allPorts[self.loadPort] = null then
		app.raiseCMException1(ERR_INVALID_LOAD_PORT, self.loadPort, ETRow_LoadPort, self);
	endif;
	
	if self.dischargePort &lt;&gt; null and root.allPorts[self.dischargePort] = null then
		app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, ETRow_DischargePort, self);
	endif;
	
	if self.destinationPort &lt;&gt; null and root.allPorts[self.destinationPort] = null then
		if doPartial then
			app.raiseCMWarning1(ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, self, null);
		else
			app.raiseCMException1(ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, self);
		endif;
	endif;
	
	if self.businessUnit &lt;&gt; null and terminal.companies[self.businessUnit] = null then
		app.raiseCMException(ERR_INVALID_BUSINESS_UNIT, ETRow_BusinessUnit, self);
	endif;
	
	if self.customsAgent &lt;&gt; null then		
		if root.allCustomsAgents[self.customsAgent] = null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, self.customsAgent, ETRow_CustomsAgent, ETRow_CustomsAgent, self);
		endif;
	endif;
	
	create allEDIFiles transient;
	ediReleaseData.ediFileArray.copy(allEDIFiles);	//07/11/2011	cnwrs1	CCMS POL 2122 / PAR 28696 - new property allEDIFiles
	
	_proxy.setProxy(	self.releaseRequestNumber,
						releaseType,
						self.releaseByType,
						statusBulkRelease,
						mtGradeArray,
						bookingConfirmation,	//22 Nov 2013	NDL	Par 30886
						carrierId,
						self.remarks,
						self.consignee[1:5],
						null,	//consigneeDesc	
						self.consignor[1:5],
						null,	//consignorDesc
						self.getConsignorVoyage(),
						dateRequested,
						estimatedRequiredDate,	//22 Nov 2013	NDL	Par 32057
						deliveryReasonCode,	//deliveryReasonCode
						app.deliveryReasonEnumToString(deliveryReasonCode),
						deliveryReleaseNumber,	//22 Nov 2013	NDL	Par 32057
						_proxy.doorsDirection,	//26 Mar 2012 cnwrs1	Par 29321

						freightPayerCode,	//22 Nov 2013	NDL	Par 30886
						booking,
						root.allPorts[self.loadPort],
						root.allPorts[self.destinationPort],
						root.allPorts[self.dischargePort],
						self.freightForwarder[1:5],	// 24/09/2014 cnwar2 #34942
						transferToTerminal,	//22 Nov 2013	NDL	Par 32057
						terminal,
						app.myRoot.allOperators[self.operatorCode],
						app.myRoot.allOperatorGroups[self.operatorGroup],
						voyage,
						terminal.companies[self.businessUnit],
// TFS 2686						self.removeStops,
						(not self.mtRelease),
						//_proxy.allPackLocations,	//26 Mar 2012 cnwrs1	Par 29321		//cnwmc5 - 19 Nov 2013 - PAR 32086	
						allPackLocations,		//cnwmc5 - 19 Nov 2013 - PAR 32086
						_proxy.myPoolPartner,	//26 Mar 2012 cnwrs1	Par 29321
						_proxy.dispatchLocation,	//26 Mar 2012 cnwrs1	Par 29321
						subTerminal,
						_proxy.mySubTerminalTarget,	//26 Mar 2012 cnwrs1	Par 29321
						_proxy.myAssignedTrain,	//26 Mar 2012 cnwrs1	Par 29321
						self.allowCargoMultiReleases,
						self.customsAgent,
						self.customsAssistance,
						canHiLoCube,	//26 Mar 2012 cnwrs1	Par 29321  //epr TFS 2606 10/3/17
						_proxy.needsReview,	// par 29480 needsReview	// needs to be set later for CCMS POL 2122
						stopEDIUpdates,	// par 29480 April 2012
						allEDIFiles,	// CCMS POL 2122 / PAR 28696 cnwrs1
						expTimeStamp,
						bolIn,			//jlgka1 TFS 41708
						_proxy.context	// ### TFS 53953 27June2022 NAVPW1
						);
								
	_proxy.setPxyTotalRequested(self.quantity);
	_proxy.setRemarksAdditionals(	self.remarksAdditional1,	//_remAdd1 : String;
									self.remarksAdditional2	//_remAdd2 : String
									);
	
	
	matchedReserve	:=	null;

	if self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then	
		if _reservesToDelete &lt;&gt; null then
			foreach pxyReserve in _proxy.allReserveDetails do
				if self.sequence = pxyReserve.sequence then
					if not _reservesToDelete.includes(pxyReserve) then
						_reservesToDelete.add(pxyReserve);
					endif;
				endif;
			endforeach;
		endif;
		
		foreach pxyReserve in _proxy.allReserveDetails do
			if _reservesToKeep &lt;&gt; null and
			   _reservesToKeep.includes(pxyReserve) then
				continue;
			endif;
			if pxyReserve.isAllocationById() then
				if ti &lt;&gt; null then
					//if pxyReserve.allTrackedItems.includes(ti) or
					if pxyReserve.includeTrackedItem(ti, false) or //23/06/2023	navkc1	CR 58406 Task 58408
						pxyReserve.allTrackedItemsReleased.includes (ti) then	// par 31185 feb 2013
						matchedReserve	:=	pxyReserve;
						break;
					endif;
				endif;
			else
				if pxyReserve.isEDIMatch(self, true) then
					matchedReserve	:=	pxyReserve;
					break;
				elseif pxyReserve.isEDIMatch(self, false) and matchedReserve &lt;&gt; null then
					matchedReserve	:=	pxyReserve;
					// Don't break here, as there may be a better matching Reserve later in the collection.
				endif;
			endif;
		endforeach;
		
		// If the matchedReserve parameter is null, then a new Reserve Detail will be created.
		self.setProxyReserve (_proxy, matchedReserve);
		
		if _reservesToKeep &lt;&gt; null then
			if matchedReserve &lt;&gt; null then
				if not _reservesToKeep.includes(matchedReserve) then	// cnwdad1 23/11/2010 - PAR #26392.
					_reservesToKeep.add(matchedReserve);
				endif;
			endif;
		endif;
	endif;
	
	
epilog
	delete mtGradeArray;
	delete allEDIFiles;
	app.cmsEndLoad(isInLoadState);
end;</source>
        <Parameter name="_proxy" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_reservesToDelete" type="CM_ReserveDetailSet" usage="input"/>
        <Parameter name="_reservesToKeep" type="CM_ReserveDetailSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyReserve" id="ae16ff78-e3e8-49af-baff-29b0027fb83a">
        <source>setProxyReserve(_bulkRelease:CM_BulkRelease input; _pxyReserve:CM_ReserveDetail io) protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
13/09/2016	cnwer1	TFS 2606	Initial creation 
19/04/2017  cnwma1	TFS #4153	Code :89407. An input is required for the weight field 
								When Trying Load an EDI Release Request
24/01/2019	jlgka1	41708		As a result of the changes in the CM_ReserveTI.setProxy	
								we also need to add two totalRequestedAmount and BOLItems here.
21/06/2021	navdap1	TFS 51386 	MTN Release request by type using EDI - don't set weightSelection, do set weightRequested
24/01/2021	jlika1	TFS 52472	MSL - Best Pick field for EDI Release Request
14 Jun 2022 jlier1		TFS 53678
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
08/08/2022	jlizm1	TFS 54067	Additional Fields on Release Line Level EDI
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
15 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
13 Jan 2025	navhl20 CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
============================================================================*/
vars
	root					: CM_Root;
	terminal				: CM_Terminal;
	cargoType				: CM_CargoType;
	product					: CM_Product;
	maskArray				: StringArray;
	maskString,voyageCode	: String;
	mtGradeArray			: IntegerArray;
	operator				: CM_Operator;
	voyage					: CM_Voyage;
	bol						: CM_BOLIn;
	isNew 					: Boolean;
	isoType 				: CM_ISOType;
	quantity				: Integer;
	ti 						: CM_TrackedItem;
	markSelection 			: String;	//29 Aug 2019	NDL	TFS 46118
	bestPick				: Boolean;
begin
	root			:= app.myRoot;
	terminal		:= self.getMyTerminal();
	isNew 			:= _pxyReserve = null;
		
	if isNew then
		if self.releaseByType then
			create _pxyReserve as CM_ReserveSelection transient;
		else
			create _pxyReserve as CM_ReserveTI transient;
		endif;
		
	endif;
	
	create maskArray transient;
	cargoType	:= root.getCargoTypeForID(self.cargoType);
	if self.releaseByType then
		if cargoType = null then
			app.raiseCMException(ERR_INVALID_TI_TYPE, ETRow_CargoTypeDesc, self);
		endif;
		if self.cargoType = TI_CargoType_BreakBulk or cargoType.isUserDefinedAndHandledAs(ProductType_BreakBulk) or cargoType.isUserDefinedAndHandledAs(ProductType_PieceBreakBulk) then
			if cargoType.isSubCargoTypeRequired then
				product	:= cargoType.allProducts[self.operatorCode, self.cargoSubType];
				if product = null then	//26 Mar	NDL	TFS 37539
					product	:=	cargoType.allProducts[null, self.cargoSubType];
				endif;
				if product = null then
					app.raiseCMException2(Cargo_SubType_Not_Found_CType, self.cargoSubType, self.cargoTypeDescr, ETRow_CargoSubType, self);
					return;
				elseif product.myOperator &lt;&gt; null and product.myOperator.code &lt;&gt; self.operatorCode then		//26 Mar	NDL	TFS 37539
					app.raiseCMException2(	Cargo_subtyp_not_valid_operat,
											self.cargoSubType,
											self.operatorCode,
											ETRow_CargoSubType,
											self);	
				endif;
			endif;
		endif;
		if self.usesDefaultValues() and not isNew then
			isoType :=_pxyReserve.CM_ReserveSelection.myISOType;
		else 
			isoType := root.allISOTypes[self.isoType];
		endif;
		bestPick := self.bestPick;
	else
		maskString	:=	self.ids.trimBlanks();
		maskString	:=	maskString.replaceString(SingleQuote, null);
		maskString	:=	maskString.replaceString(DoubleQuote, null);
		
		maskString.convertToDelimitedArray(",", maskArray);
	endif;
	
	if self.isoType &lt;&gt; null and root.allISOTypes[self.isoType] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, app.getString(ISO_Type), ETRow_IsoType, self);
	endif;
	
	if self.isoTypeGroup &lt;&gt; null and root.allISOTypeGroups[self.isoTypeGroup] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoTypeGroup, app.getString(ISO_Group), ETRow_IsoTypeGroup, self);
	endif;
	
	create mtGradeArray transient;
	self.getAllAvailabilityGrades(mtGradeArray);
	
	operator	:=	root.allOperators[self.operatorCode];
	
	if self.billOfLading &lt;&gt; null then
		voyageCode	:=	self.getVoyageCode();
		voyage		:=	terminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
		if voyage = null then
			app.raiseCMException2(Voyage_DoesNotExist_4_Terminal, self.getVoyageCode().trimBlanks(), terminal.code, ETRow_VoyageCode, self);
		else
			bol	:=	voyage.doesBOLAlreadyExist(self.billOfLading);
			if bol = null then
				app.raiseCMException2(BOL_not_found_voyage, self.billOfLading, self.getVoyageCode(), ETRow_BillOfLading, self);
				return ;
			endif;
		endif;
	endif;
	
	//29 Aug 2019	NDL	TFS 46118
	markSelection := self.mark;
	
	
	if self.releaseByType then
		_pxyReserve.CM_ReserveSelection.setProxy(CM_ReserveDetail.PackType_Parent,
												cargoType,
												null,
												isoType,
												root.allISOTypeGroups[self.isoTypeGroup],
												product,
												null,
												self.remarks,
												self.quantity,
												mtGradeArray,
												self.clean,
												null,
												self.heavyDuty,
												maskArray,
												self.quantity,
												null,
												self.description,
												0,
												0,
												null,
												0,
												null,
												0,
												//self.weight,	// 19/04/2017 cnwma1 TFS #4153	// TFS 51386
												0, 				// 19/04/2017 cnwma1 TFS #4153	// TFS 51386
												0,
												markSelection,
												0,
												null,
												null,
												bol,
												bestPick,
												self.sequence,null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
												null,	// ### TFS 53953 11July2022 NAVPW1
												self.lineNumber,		// TFS 54067
												self.customerReference,	// TFS 54067
												null, //28/06/2023 navmv20 CR 58410 Task 58411
												false,	// 6/12/2023 navcs2 ChangeRequest 57537
												false, //19/02/2023	navkc1 CR 60078 Task 62450
												null,  //24/04/2025	navrv30	MTN 34319
												null);
		
		// TFS 51386 tidy up for bulk
		if cargoType &lt;&gt; null and (cargoType.isBulkByWeight or cargoType.isBulkByVolume) then
			_pxyReserve.setWeightRequested(self.weight);
		endif;
		// TFS 51386 end
	else
		// 36821 allow EDI 'Release Request' quantity, if set and also weight
		quantity := self.quantity.max(1);
	
		_pxyReserve.CM_ReserveTI.setProxy(CM_ReserveDetail.PackType_Parent,
												null,
												self.removeStops,
												self.remarks,
												quantity,		// 36821
												quantity,		// 36821
												bol, 
												self.weight,	// 36821
												self.sequence,	// PAR #34058
												0,				// jlgka1 TFS 41708
												null,			// jlgka1 TFS 41708
												null,null,null,null,null					//13.01.2025 navhl20 #33695
												); 					
	endif;
	
	if isNew then
		_pxyReserve.setMyHeader(_bulkRelease);
	endif;
	
		
	if not self.releaseByType then
	
			ti	:=	terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_UNDEFINED, null, false);
			
			/*if ti = null then
				app.raiseCMException3(Specfied_Cargo_DoesNotExist, self.id, self.cargoTypeDescr, terminal.code, ETRow_Id, self);
				return;
			endif;*/
			// if the ti has already been released then it will not be found - that's OK in this case
			if ti &lt;&gt; null then
				if not _pxyReserve.allTrackedItems.includes(ti) then
					_pxyReserve.allTrackedItems.add(ti);
				endif;
			endif;
	
	endif;
	
epilog
	delete mtGradeArray;
	delete maskArray;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_pxyReserve" type="CM_ReserveDetail" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="67edfca8-5cd7-4d87-9527-dfd6923fb473">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;

</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupFromRelReqMultiLine" id="9c5ce4f0-8161-4884-938d-c576d2739561">
        <updating/>
        <source>setupFromRelReqMultiLine(_ediRequestHeaderTI : CM_EDIRequestHeaderTI; _ediRequestItemTI : CM_EDIRequestDetailTI) updating;
//
// 19 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// this is for the isMatch function 
// 12 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
// 10 Jul 2018	jlgrs1	TFS 38808 - JMT - Full and Partial loading not working correctly
// 24 Jan 2022	jlika1	TFS 52472 - MSL - Best Pick field for EDI Release Request
vars

begin
	self.allowCargoMultiReleases := _ediRequestHeaderTI.allowCargoMultiReleases;
	self.availabilityGrades := _ediRequestItemTI.availabilityGrades;
	self.billOfLading := _ediRequestItemTI.billOfLading;
	self.bookingConfirmation := _ediRequestHeaderTI.bookingConfirmation;
	self.bookingRef := _ediRequestHeaderTI.getBookingId();
	self.businessUnit := _ediRequestHeaderTI.businessUnit;
	if _ediRequestHeaderTI.getCanBeHiLoCubeSet then
		self.canBeHiLoCube := _ediRequestHeaderTI.canBeHiLoCube;
	endif;
	self.cargoSubType := _ediRequestHeaderTI.cargoSubType;
	self.carrierCode := _ediRequestHeaderTI.carrierCode;
	self.checkISOGroup := _ediRequestItemTI.checkISOGroup;
	self.clean := _ediRequestItemTI.clean;
	self.consignee := _ediRequestHeaderTI.consignee;
	self.consignor := _ediRequestHeaderTI.consignor;
	self.setConsignorVoyage(_ediRequestHeaderTI.consignorVoyage);
	self.customsAgent := _ediRequestHeaderTI.customsAgent;
	self.customsAssistance := _ediRequestHeaderTI.customsAssistance;
	self.deliveryReason := _ediRequestHeaderTI.deliveryReason;
	self.deliveryReleaseNumber := _ediRequestHeaderTI.deliveryReleaseNumber;
	self.destTerminal := _ediRequestHeaderTI.destTerminal;
	self.destinationPort := _ediRequestHeaderTI.destinationPort;
	self.dischargePort := _ediRequestHeaderTI.dischargePort;
	self.estimatedRequiredDate := _ediRequestHeaderTI.estimatedRequiredDate;
	self.expiryTimeStamp := _ediRequestHeaderTI.expiryTimeStamp;
	self.freightForwarder := _ediRequestHeaderTI.freightForwarder;
	self.generatorType := _ediRequestHeaderTI.generatorType;
	self.heavyDuty := _ediRequestItemTI.heavyDuty;
	self.ids := _ediRequestItemTI.ids;
	self.isGeneratorAttachment := _ediRequestItemTI.isGeneratorAttachment;
	self.isoType := _ediRequestItemTI.isoType;
	self.isoTypeGroup := _ediRequestItemTI.isoTypeGroup;
	self.loadPort := _ediRequestHeaderTI.loadPort;
	self.mtRelease := _ediRequestHeaderTI.mtRelease;
	self.operatorCode := _ediRequestHeaderTI.operatorCode;
	self.operatorGroup := _ediRequestHeaderTI.operatorGroup;
	self.quantity := _ediRequestItemTI.quantity;
	self.releaseByType := _ediRequestHeaderTI.releaseByType;
	self.releaseRequestNumber := _ediRequestHeaderTI.releaseRequestNumber;
	self.releaseType := _ediRequestHeaderTI.releaseType.Integer;
	self.releaseTypeStr := _ediRequestHeaderTI.releaseTypeStr;
	self.remarks := _ediRequestHeaderTI.remarks;
	self.removeStops := _ediRequestHeaderTI.removeStops;
	if _ediRequestHeaderTI.requestDate.isValid then
		self.requestDate := _ediRequestHeaderTI.requestDate;
	else
		self.requestDate := null;
	endif;
	self.requestDateDoUpdate := _ediRequestHeaderTI.requestDateDoUpdate;
	self.senderCode := _ediRequestHeaderTI.senderCode;
	self.sequence := _ediRequestItemTI.sequence;
	self.statusBulkRelease := _ediRequestHeaderTI.statusBulkRelease;
	self.trailerType := _ediRequestHeaderTI.trailerType;
	self.vesselName := _ediRequestHeaderTI.vesselName;
	self.setVoyageCode(_ediRequestHeaderTI.getVoyageCode());
	self.weight := _ediRequestItemTI.weight;
	
	self.messageMode := _ediRequestHeaderTI.messageMode;
//	self.myCargoType := self.myCargoType;
	self.cargoType := _ediRequestHeaderTI.cargoType;
	self.specialStowage := _ediRequestHeaderTI.specialStowage;
	self.status := _ediRequestHeaderTI.status;
	self.subTerminalCode := _ediRequestHeaderTI.subTerminalCode;
	self.temperatureAbsolute := _ediRequestItemTI.temperatureAbsolute;
	self.temperatureSign := _ediRequestItemTI.temperatureSign;
	self.mark := _ediRequestItemTI.mark;	//29 Aug 2019	NDL	TFS 46118
	self.bestPick := _ediRequestItemTI.bestPick;
epilog

end;</source>
        <Parameter name="_ediRequestHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediRequestItemTI" type="CM_EDIRequestDetailTI"/>
    </JadeMethod>
    <JadeMethod name="usesDefaultValues" id="dcdb60e8-1dce-4741-8a95-898eae931b7d">
        <source>usesDefaultValues() : Boolean;
//
// 15 Mar 2012	cnwrs1	Par 29264 defaults update
// 18 Feb 2013	cnwcs5	Minor changes to use local variables instead of getProertyValue calls
// 11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	file	: CM_EDIFile;
	result 	: Boolean;
begin
	file := self.myEDIData.myEDIFile;
	
	if file &lt;&gt; null and
	   file.myEDIFileType &lt;&gt; null then
		result := file.myEDIFileType.type = EDIFileType_Coparn;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyAndSetCMIF_BulkRelease" id="d1334aa2-4374-43d3-8c76-0240e00b3cd7">
        <source>verifyAndSetCMIF_BulkRelease(	_intFaceObject	: CMIF_BulkRelease input;
								_skipProcessing : Boolean io;
								_passport : CM_Passport input) protected;
/* Changes

Date		Name	TFS#			Description
============================================================================
06/09/2016	cnwer1	TFS 2606		Initial creation 
08/06/2018	jlgrh7 	TFS #39093		STWO - Voyage Planning Codes do not show in terminal Admin
10/07/2018	jlgrs1	TFS 38808 		JMT - Full and Partial loading not working correctly
24/01/2019	jlgka1	TFS 41708		STWO - CCRO Management. Add myBOLIn.
29/01/2019	jlgrs1	TFS 43112		Changes for TFS 41708 were incorrect
04/03/2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
============================================================================*/

vars

	releaseType 		: Integer;
	doPartial 			: Boolean;
	operator 			: CM_Operator;
	terminal 			: CM_Terminal;
	defaultVoyage		: CM_Voyage;
	voyage 				: CM_Voyage;
	voyageCode 			: String;
	ediReleaseData 		: CM_EDIDataReleaseRequest;
	bookingRef			: CM_BookingRef;
	cargoTypeObj		: CM_CargoType;
	productObj 			: CM_Product;
	trackedItem			: CM_TrackedItem; 
	action				: String;
	availabilityGrades	: IntegerArray;
	bolIn				: CM_BOLIn;						// cnwrl1 14/06/2010 PAR 24150
	tempString			: String;
	release 			: CM_BulkRelease; 
	subTerminal 		: CM_SubTerminal;		//+TFS39067
	consign : CM_ConsigneeConsignor;
begin
	
	terminal := self.getMyTerminal();
	release	:= self.getBulkRelease();
	
	doPartial := terminal.getConfig(EdiReleaseAllowPartial).Boolean;
	releaseType	:= app.releaseRequestTypeStringToEnum(self.releaseTypeStr);
	
	ediReleaseData := self.myEDIData.CM_EDIDataReleaseRequest;
	
	action	:= self.messageMode;
	if action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_MessageMode, self);
		return;						// not much point continuing
	endif;
	
	if self.releaseRequestNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, ETRow_ReleaseRequestNumber, ETRow_ReleaseRequestNumber, _ediTI);
		_skipProcessing := true;
		app.raiseCMException1(Input_required_field_Required, ETRow_ReleaseRequestNumber, ETRow_ReleaseRequestNumber, self); // cnwdb2	PAR 35364
		return;						// not much point continuing
	endif;
	
	if not self.releaseByType then
		if self.id = null or self.cargoType = null then
			app.raiseCMException2(ReleaseByID_RequiresMoreInform, self.releaseRequestNumber, self.releaseRequestNumber, ETRow_Id, self);
		endif;
		
		if self.createWarningForReleaseByID() then
			_skipProcessing := true;
			app.raiseCMException(Operat_coparn_party_rule_relea,null,self);			//cnwmc5 - 26 May 2014 - PAR 34164
			return;
		endif;
		
		trackedItem := self.findTrackedItem(release);
		if trackedItem = null then
			app.raiseCMException3(Specfied_Cargo_DoesNotExist, self.id, self.cargoTypeDescr, terminal.code, ETRow_Id, self);
		endif;	
		// 3.8.2017 cnwma1 TFS #5209
		if trackedItem &lt;&gt; null and trackedItem.myConsignee &lt;&gt; null  then
			if trackedItem.myConsignee.isRestricted then
				_skipProcessing := true;
				app.raiseCMException1(ERR_TI_CONSIGNEE_RESTRICTED,trackedItem.id ,null ,null);
				return;
			endif;
		endif;
	endif;	
	
	if releaseType = BR_TYPE_INVALID then
		app.raiseCMException1(Invalid_Release_Request_Type, self.releaseTypeStr.display, ETRow_ReleaseType, self);
	endif;
	// cnwrl1 25/05/2010 PAR 24131 - end of coding
	
	// Any port code supplied must be a valid port code
	if self.loadPort &lt;&gt; null and app.myRoot.allPorts[self.loadPort] = null then
		app.raiseCMException1(ERR_INVALID_LOAD_PORT, self.loadPort, ETRow_LoadPort, self);
	endif;
	
	if self.dischargePort &lt;&gt; null and app.myRoot.allPorts[self.dischargePort] = null then
		app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, ETRow_DischargePort, self);
	endif;
	
	if self.destinationPort &lt;&gt; null and app.myRoot.allPorts[self.destinationPort] = null then
		if doPartial then
			app.raiseCMWarning1(ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, self, null);
		else
			app.raiseCMException1(ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, self);
		endif;
	endif;
	
	if app.myRoot.allCargoTypesById[self.cargoType] = null then
		app.raiseCMException(ERR_INVALID_TI_TYPE, ETRow_CargoTypeDesc, self);
	endif;
	
	if self.isoType &lt;&gt; null and app.myRoot.allISOTypes[self.isoType] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, app.getString(ISO_Type), ETRow_IsoType, self);
	endif;
	
	if self.isoTypeGroup &lt;&gt; null and app.myRoot.allISOTypeGroups[self.isoTypeGroup] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoTypeGroup, app.getString(ISO_Group), ETRow_IsoTypeGroup, self);
	endif;
	
	if self.businessUnit &lt;&gt; null and terminal.companies[self.businessUnit] = null then
		app.raiseCMException(ERR_INVALID_BUSINESS_UNIT, ETRow_BusinessUnit, self);
	endif;
	
	if self.destTerminal &lt;&gt; null and app.myRoot.allTerminals[self.destTerminal] = null then
		app.raiseCMException1(Err_InvalidTerminal, self.destTerminal, ETRow_DestTerminal, self);
	endif;
	
	if self.operatorCode &lt;&gt; null then
		operator	:= app.myRoot.allOperators[self.operatorCode];
		if operator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, ETRow_Operator, self);
		endif;
	endif;
	
	if self.operatorGroup &lt;&gt; null and app.myRoot.allOperatorGroups[self.operatorGroup] = null then
		app.raiseCMException1(ERR_INVALID_OPERATOR_GROUP, self.operatorGroup, ETRow_OperatorGroup, self);
	endif;
	
	if self.carrierCode &lt;&gt; null and app.myRoot.allCarriers[self.carrierCode] = null then
		app.raiseCMException1(ERR_Carrier_Unknown, self.carrierCode, ETRow_Carrier, self);
	endif;
	
	// par 29402 May 2012 - validation of delivery reason code - should not have errors as this is defaulted for coparn
	if self.deliveryReason &lt;&gt; null then 
		if app.deliveryReasonEnumToString(self.deliveryReason) = DELSTR_NULL then 
			app.raiseCMException2(ERR_INVALID_VALUE, 'Delivery Reason', self.deliveryReason.String, ETRow_DeliveryReason, self);
		endif;
	endif;

	if self.freightForwarder &lt;&gt; null and app.myRoot.allConsigneeConsignors[self.freightForwarder] = null then
		app.raiseCMException1(ERR_INVALID_FreightForwarder, self.freightForwarder, ETRow_FreightForwarder, self);
	endif;
	
	if self.customsAgent &lt;&gt; null then
		if app.myRoot.allCustomsAgents[self.customsAgent] = null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, self.customsAgent, ETRow_CustomsAgent, ETRow_CustomsAgent, self);
		endif;
	endif;
	
		// Check that EDI Date statusBulkRelease is valid option
	if app.releaseStatusStringToEnum(self.statusBulkRelease.properCase()) = BR_NOTSET then
		app.raiseCMException1(ERR_INVALID_StatusBulkRelease, self.statusBulkRelease.properCase(), ETRow_StatusBulkRelease, self);
	endif;
	
	defaultVoyage:=ediReleaseData.getDefaultVoyage(self.senderCode);
	self.getVoyageForRelease ( release, voyage, voyageCode);
	
	//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
	if voyage &lt;&gt; null and voyage.hasDeparted  and  terminal.getConfig(EdiAddVoyageDepartError).Boolean then 
		_skipProcessing := true;
		app.raiseCMException1(Voyage_departed,voyage.code,"Voyage Code", self);
		return;
	endif;
	
	// check voyage cutoffs if we have a valid voyage in the file.
	if voyage &lt;&gt; null and voyage &lt;&gt; defaultVoyage then											// par 30096 Aug 2012
		// par 29402 check voyage cutoffs - only do this if the voyage in the file is valid
		ediReleaseData.checkEDICutoff (voyageCode, self.operatorCode, self);							// par 29158 - March 2012
	endif;
	
	if self.bookingRef &lt;&gt; null and not _passport.hasErrors() then
		// if the bookingRef is entered then the operator and voyage must also be entered (and valid).
		if operator = null or voyage = null then
			app.raiseCMException3(	Booking_Requires_Oper_Voyage,
									self.bookingRef,
									self.operatorCode,
									voyageCode,		// par 29402 May 2012
									ETRow_BookingRef,
									self);
		else
			bookingRef	:= terminal.getBookingReference(operator.code, self.bookingRef, voyage);
			if bookingRef = null then
				app.raiseCMException3(	Booking_DoesNotExist4_OpVoyage,
										self.bookingRef,
										self.operatorCode,
										voyageCode,	// par 29402 May 2012
										ETRow_BookingRef,
										self);
			endif;
		endif;
	endif;
	create availabilityGrades transient;
	self.getAllAvailabilityGrades(availabilityGrades);
	
	if self.billOfLading &lt;&gt; null then
		if voyage = null then
			app.raiseCMException2(Voyage_DoesNotExist_4_Terminal, voyageCode, terminal.code, ETRow_VoyageCode, self);	// par 29402 May 2012
		else
			bolIn := voyage.doesBOLAlreadyExist(self.billOfLading);
			if bolIn = null then
				app.raiseCMException2(BOL_not_found_voyage, self.billOfLading, voyageCode, ETRow_BillOfLading, self);	// par 29402 May 2012
				
			endif;
		endif;
	endif;
	
	cargoTypeObj :=	app.myRoot.allCargoTypesById[self.cargoType];
	if self.releaseByType  and cargoTypeObj &lt;&gt; null then
		if cargoTypeObj.isBreakBulk	and cargoTypeObj.isSubCargoTypeRequired then
				productObj	:=	cargoTypeObj.allProducts[self.operatorCode, self.cargoSubType];
				if productObj = null then	//26 Mar	NDL	TFS 37539
					productObj	:=	cargoTypeObj.allProducts[null, self.cargoSubType];
				endif;
				if productObj = null then
					app.raiseCMException2(	Cargo_SubType_Not_Found_CType,
											self.cargoSubType,
											self.cargoTypeDescr,
											ETRow_CargoSubType,
											self);				
				elseif productObj.myOperator &lt;&gt; null and productObj.myOperator.code &lt;&gt; self.operatorCode then		//26 Mar	NDL	TFS 37539
					app.raiseCMException2(	Cargo_subtyp_not_valid_operat,
											self.cargoSubType,
											self.operatorCode,
											ETRow_CargoSubType,
											self);	
				endif;
			
		endif;
		
	endif;
	
	//07 Sep 2021	NDL	TFS 51928
	if self.consignee[1:5].trimBlanks &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors.getAtKey( self.consignee[1:5].trimBlanks );
		if consign &lt;&gt; null then
			self.verifyObjectAvailableForEntry( consign );
		endif;
	endif;
	//07 Sep 2021	NDL	TFS 51928
	if self.consignor[1:5].trimBlanks &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors.getAtKey( self.consignor[1:5].trimBlanks );
		if consign &lt;&gt; null then
			self.verifyObjectAvailableForEntry( consign );
		endif;
	endif;
	
	
	if app.isSubTerminalsOn(terminal) then																													//+TFS39093
		if self.subTerminalCode = null then
			app.raiseCMException(Input_required_field_subTerm, ETRow_MySubTerminal, null); 
		else
			subTerminal:= terminal.allSubTerminals[self.subTerminalCode];
			if subTerminal = null then
				app.raiseCMException(Subterminal_invalid, ETRow_MySubTerminal, null); 
			endif;
		endif;
	endif;
	
	// Set the intFaceObject properties as best we can figure from the EDITI supplied.

	_intFaceObject.setUserDetails( app.getMyUser() );
	_intFaceObject.myUser					:= app.getMyUser();
	_intFaceObject.action					:= action;
	_intFaceObject.releaseNo				:= self.releaseRequestNumber;		// eventually ends up in code
	_intFaceObject.type						:= releaseType;
	_intFaceObject.status					:= app.releaseStatusStringToEnum(self.statusBulkRelease.properCase);
	if self.requestDate.isValid then
		_intFaceObject.dateRequested := self.requestDate;
	else
		_intFaceObject.dateRequested := null;
	endif;
	_intFaceObject.dateRequested			:= _intFaceObject.dateRequested.cnZeroSeconds();
	_intFaceObject.dateEstimatedRequired	:= self.estimatedRequiredDate;
	_intFaceObject.dateEstimatedRequired	:= _intFaceObject.dateEstimatedRequired.cnZeroSeconds();
	_intFaceObject.carrierCode				:= self.carrierCode;
	_intFaceObject.myCarrier				:= app.myRoot.allCarriers[self.carrierCode];
	_intFaceObject.voyageCode				:= voyageCode;
	_intFaceObject.myVoyage					:= voyage;	// par 30096 Aug 2012 
	_intFaceObject.myDischargePort			:= app.myRoot.allPorts[self.dischargePort];
	_intFaceObject.myLoadPort				:= app.myRoot.allPorts[self.loadPort];
	_intFaceObject.operatorCode				:= self.operatorCode;
	_intFaceObject.operatorGroupCode		:= self.operatorGroup;
	_intFaceObject.myOperatorGroup			:= app.myRoot.allOperatorGroups[self.operatorGroup];
	_intFaceObject.consigneeCode			:= self.consignee[1:5];
	_intFaceObject.consignorCode			:= self.consignor[1:5];
	_intFaceObject.consignorVoyageCode		:= self.getConsignorVoyage;

	_intFaceObject.freightForwarderCode		:= self.freightForwarder[1:5];	//20 Feb 2014	NDL	Par 33306
	_intFaceObject.myBusinessUnit			:= terminal.companies[self.businessUnit];
	// Attempt to get the matching delivery reason description, if not found will default to null,
	// this will then ends up as CM_BulkRelease.deliveryReasonDescr.
	_intFaceObject.deliveryReason			:= app.deliveryReasonEnumToString(self.deliveryReason);
	_intFaceObject.deliveryReleaseNumber	:= self.deliveryReleaseNumber;
	_intFaceObject.expiryTimeStamp			:= self.expiryTimeStamp;	//14 Feb 2017	NDL	TFS 3368
// TFS 2686	_intFaceObject.removeStops				:= self.removeStops;
	_intFaceObject.fullRelease				:= not self.mtRelease;						// Empties Only
	_intFaceObject.myTransferToTerminal		:= app.myRoot.allTerminals[self.destTerminal];	// destination terminal
	_intFaceObject.releaseByType			:= self.releaseByType;
	_intFaceObject.myCargoType				:= cargoTypeObj;
	_intFaceObject.allowCargoOnMultipleReleases := self.allowCargoMultiReleases; //PAR25759 cnwsh3 23/09/2010
	
	if self.releaseByType then			// ie release by type
		_intFaceObject.CMIF_BulkReleaseByType.isoType			:= self.isoType;
		_intFaceObject.CMIF_BulkReleaseByType.isoTypeGroup		:= self.isoTypeGroup;
		_intFaceObject.CMIF_BulkReleaseByType.myISOType			:= app.myRoot.allISOTypes[self.isoType];
		_intFaceObject.CMIF_BulkReleaseByType.doISOGroupCheck	:= self.checkISOGroup;
		
		_intFaceObject.CMIF_BulkReleaseByType.allAvailabilityGrades.clear;	// par 28696
		availabilityGrades.copy(_intFaceObject.CMIF_BulkReleaseByType.allAvailabilityGrades);
		_intFaceObject.CMIF_BulkReleaseByType.clean				:= self.clean;
		_intFaceObject.CMIF_BulkReleaseByType.heavyRated		:= self.heavyDuty;
		_intFaceObject.CMIF_BulkReleaseByType.totalRequested	:= self.quantity;
		_intFaceObject.CMIF_BulkReleaseByType.myBOLIn			:= bolIn;		// cnwrl1 14/06/2010 PAR 24150
		_intFaceObject.CMIF_BulkReleaseByType.myProduct			:= productObj;	// cnwdad1 05/10/2010 - PAR #25748.
		
		tempString	:= self.ids.trimBlanks();
		tempString	:= tempString.replaceString(SingleQuote, null);
		tempString	:= tempString.replaceString(DoubleQuote, null);
		_intFaceObject.CMIF_BulkReleaseByType.idMask	:= tempString;	// eventually ends up in CM_ReserveSelection maskIds
		_intFaceObject.canBeHiLoCube := self.canBeHiLoCube; //epr TFS 2606 9/3/17
		_intFaceObject.CMIF_BulkReleaseByType.doISOGroupCheck	:= self.checkISOGroup;
	elseif _intFaceObject.isKindOf(CMIF_BulkReleaseTIs) and //jlgrs1 TFS 43112 fixup to make TFS41708 work	
	
	   _intFaceObject &lt;&gt; null then
		_intFaceObject.CMIF_BulkReleaseTIs.myBOLIn	:= bolIn; //jlgka1 TFS 41708
	endif;
	
	_intFaceObject.remarks				:= self.remarks;	// cargoRemarks
	_intFaceObject.remarksAdditional1	:= self.remarksAdditional1;	//02 May 2018	NDL	TFS 37795
	_intFaceObject.remarksAdditional2	:= self.remarksAdditional2;	//02 May 2018	NDL	TFS 37795
	_intFaceObject.weightRequested		:= self.weight;		// 36821 for by-weight cargo
	_intFaceObject.totalRequested		:= self.quantity;		// 36821 for release by type or by id
	
	// cnwrl1 17/02/2010 PAR 22393 - start of coding
	_intFaceObject.customsAgent			:= self.customsAgent;
	_intFaceObject.customsAssistance	:= self.customsAssistance;
	
	_intFaceObject.myBookingRefStock	:= bookingRef;
		
	if app.isSubTerminalsOn(terminal) then
		_intFaceObject.subTerminalCode	:= self.subTerminalCode;
		_intFaceObject.mySubTerminal	:= terminal.allSubTerminals[_intFaceObject.subTerminalCode];
	endif;
	
	_intFaceObject.allEDITrackedItems.addNoDuplicates (self, false);		// par 32094
	
	_intFaceObject.myTerminal			:= terminal;
epilog
	delete availabilityGrades;

end;</source>
        <access>protected</access>
        <Parameter name="_intFaceObject" type="CMIF_BulkRelease" usage="input"/>
        <Parameter name="_skipProcessing" type="Boolean" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyAndUpdateStatus" id="7c2e2c92-051a-4ca4-8f0e-e574b13f50e9">
        <source>verifyAndUpdateStatus(  _coll :CMIF_TIObjectArray input;
						 newRelease : Boolean;
						_errorSet 	:CM_ErrorSet input;
						_passport : CM_Passport input) : Boolean;
/*

Date		Who		Reason
07 September 2016	cnwer1	Initial creation TFS 2606
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	skipProcessing : Boolean;	
	newStatus					:Integer;
	continueWithoutVerify : Boolean;
	release :CM_BulkRelease;
	coparnRules					:CM_EDIPartyCoparnRules;
	releaseByTypeOnly			: Boolean;
	cmif						:CMIF_BulkRelease;
	ediTI : CM_EDITrackedItem;
begin
	
	_passport.moveErrorsToSet (_errorSet);
	continueWithoutVerify :=false;
	
	
	release	:= self.getBulkRelease();
								// par 29402 may 2012
	coparnRules := self.getCoparnRules();
	if coparnRules &lt;&gt; null then
		releaseByTypeOnly := coparnRules.getRelByTypeOnly; //cnwrd1 par 34035
	endif;
	
	if release &lt;&gt; null and coparnRules &lt;&gt; null then
		if not self.myEDIData.CM_EDIDataReleaseRequest.canDoEDIUpdateDelete (release, self, coparnRules, _passport) then
			continueWithoutVerify := true;
		endif;
	endif;
	
	if not continueWithoutVerify and release = null and self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		continueWithoutVerify := true;
		app.raiseCMException1(ReleaseRequest_DoesNotExist, self.releaseRequestNumber, ETRow_ReleaseRequestNumber, self);
	endif;
	
	if continueWithoutVerify then
		newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;
	else		
		if newRelease or releaseByTypeOnly then //cnwrd1 par 34035
			if self.releaseByType then
				create cmif as CMIF_BulkReleaseByType transient;
			else
				create cmif as CMIF_BulkReleaseTIs transient;
			endif;
			cmif.myTerminal:=self.getMyTerminal(); //epr par 34078 15/9/14
			_coll.add(cmif);
		else
			cmif := _coll.last.CMIF_BulkRelease;
		endif;
		
		
		skipProcessing := false;
		
		//epr TFS 2606 refactored into method on ediTI we need to just verfiy and load one ediTI
		self.verifyAndSetCMIF_BulkRelease(cmif,skipProcessing, _passport);
		
		// par 29402 May 2012 - move voyage cutoff checking to setreleaseRequestInterfaceObject
				
		if _passport.hasErrors then	// par 29480
			if skipProcessing then
				newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;		
			else
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
			endif;
		elseif _passport.hasWarnings then
			newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS;
		else	
			// can't say for sure that it is verified so just set it to unprocessed - so far so good
			newStatus := CM_EDITrackedItem.EDI_STATUS_UNPROCESSED; 
		endif;				
	endif;
	// save off current values for next iteration - at this stage 
	_passport.moveErrorsToSet (_errorSet);

	// update status
	ediTI:=self;
	app.myTrxUA.trxUpdateEDITIStatus (ediTI, newStatus, _passport);

	return not continueWithoutVerify;
epilog

end;</source>
        <Parameter name="_coll" type="CMIF_TIObjectArray" usage="input"/>
        <Parameter name="newRelease" type="Boolean"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="fee6ee31-ccd6-4418-b5e4-5980174870a9">
        <source>verifySelf();
/*

Date		Who		Reason
07 September 2016	cnwer1	Initial creation TFS 2606
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks

*/

vars
	coll :CMIF_TIObjectArray;
	errorSet 					:CM_ErrorSet;
	cmif_BulkRelease	: CMIF_BulkRelease;
	passport : CM_Passport;
begin
//	on Exception do  self.myEDIData.validationExceptionHandler(exception, app.myPassport);
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	passport := app.myPassport;
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	passport.clearErrorsWarnings();
	create coll transient;
	create errorSet transient;
	//epr TFS 2606 refactored into method on ediTI we need to just verfiy and load one ediTI
	if not self.verifyAndUpdateStatus(coll, true, errorSet, passport) then	
		return;
	endif;
	
	if self.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
		return;
	endif;	
	
	cmif_BulkRelease := coll.first.CMIF_BulkRelease;
	
	if cmif_BulkRelease = null then
		return;
	endif;
	
	cmif_BulkRelease.verifyEDIDataTIs(passport);
	
	if not errorSet.isEmpty then
		passport.addErrorsFromSet(errorSet);
	endif;
epilog
	if coll &lt;&gt; null then		
		coll.purge();			// takes care of all the transients cmif_BulkRelease(s)	
	endif;
	delete coll;
	delete errorSet;
end;</source>
    </JadeMethod>
</Class>
