    <DbClassMap file="JtdCntrl"/>
    <PrimAttribute name="isUpdating" id="b438c391-93a8-42bc-a186-e8326be3f381">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="mySummary" id="76d1ec7f-3e7d-435d-8d36-9e14764233d4">
        <embedded/>
        <type name="JtdTransactionSummary"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="name" id="541a72ae-a448-4d8b-9672-8b6ea1480498">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="651b54d4-0a94-487b-a1bc-7c83eed80101">
        <updating/>
        <source>create() updating;

begin
	create self.mySummary transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="aa2d5d48-bb4e-4327-bf1a-cf3963df7596">
        <updating/>
        <source>delete() updating;

begin
	if self.mySummary &lt;&gt; null and global.isValidObject(self.mySummary) then
		delete self.mySummary;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTableString" id="f9fcbc34-1b44-41fe-acbb-39c85b84aeb6">
        <source>getTableString() : String;

vars
	jts : JtdTransactionSummary;
	pctType, pctTotal : Real;
	jds : JtdDriverSummary;
	n, i : Integer;
	
begin
	jts := self.mySummary;
	jds := app.mySession.mySummary;
	
	n := jts.jtdTotalTransactions;

	pctType := 0;
	pctTotal := 0;
	
	if self.isUpdating then
		if jds.jtdTotalUpds &gt; 0 then
			pctType := ((n / jds.jtdTotalUpds) * 100).roundedTo(1);
		endif;
	else
		if jds.jtdTotalReads &gt; 0 then
			pctType := ((n / jds.jtdTotalReads) * 100).roundedTo(1);
		endif;
	endif;
	if pctType &gt; 100 then
		pctType := 100;
	endif;

	i := jds.jtdGetTotalTransactions;
	if i &gt; 0 then
		pctTotal := ((n / i) * 100).roundedTo(1);
		if pctTotal &gt; 100 then
			pctTotal := 100;
		endif;
	endif;
	
	return self.name                              &amp; Tab &amp;
		   n.String                               &amp; Tab &amp;
		   pctType.String &amp; '%'                   &amp; Tab &amp;
		   pctTotal.String &amp; '%'                  &amp; Tab &amp;
		   jts.jtdTotalErrs.String                &amp; Tab &amp;
		   jts.jtdTotalUnhandledExceptions.String &amp; Tab &amp;
		   jts.jtdTotalLocks.String               &amp; Tab &amp;
		   jts.jtdTotalDeadlocks.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateFromString" id="7c0c31ed-b2b7-4dbd-aec0-0ba6ee9d4bd6">
        <source>updateFromString(s : String);

begin
	self.mySummary.jtdSetFromString(s);
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
</Class>
