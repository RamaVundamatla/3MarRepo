    <JadeMethod name="createDrawingController" id="e02d23ae-9453-468c-baa3-bd4713bd396f">
        <updating/>
        <source>createDrawingController(designMode : Boolean) updating, protected;
begin
	delete self.myDrawingController;
	
	if designMode then
		create self.myDrawingController as CMUI_BlockAreaDesignDrawer transient;
	else
		create self.myDrawingController as CMUI_BlockAreaEnquireDrawer transient;
	endif;
	self.myDrawingFrame.setBlockAreaDrawer(self.myDrawingController);
	self.myYardAllocationDrawingFrame.setBlockAreaDrawer(self.myDrawingController);
	self.myDrawingController.setTopFrame(self);
end;</source>
        <access>protected</access>
        <Parameter name="designMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDrawingFrame" id="0aad6aec-9688-4c6c-88ae-5687ff67611f">
        <updating/>
        <source>createDrawingFrame() updating, protected;
begin
	create self.myDrawingFrame transient;
	self.myDrawingFrame.name := "Drawing Frame";
	self.myDrawingFrame.bevelInner := Frame.Bevel_None;
	self.myDrawingFrame.bevelOuter := Frame.Bevel_None;
	self.myDrawingFrame.borderStyle := Frame.BorderStyle_None;
	self.myDrawingFrame.boundaryWidth := 0;
	self.myDrawingFrame.parent := self.myScrollingFrame;
	self.myDrawingFrame.alignContainer := Frame.AlignContainer_All;
	self.myDrawingFrame.caption := null;
	self.form.addControl(self.myDrawingFrame);

	// Create a frame for drawing Yard Allocations
	create self.myYardAllocationDrawingFrame transient;
	self.myYardAllocationDrawingFrame.name := "Yard Allocation Drawing Frame";
	self.myYardAllocationDrawingFrame.bevelInner := Frame.Bevel_None;
	self.myYardAllocationDrawingFrame.bevelOuter := Frame.Bevel_None;
	self.myYardAllocationDrawingFrame.borderStyle := Frame.BorderStyle_None;
	self.myYardAllocationDrawingFrame.boundaryWidth := 0;
	self.myYardAllocationDrawingFrame.parent := self.myDrawingFrame;
	self.myYardAllocationDrawingFrame.alignContainer := Frame.AlignContainer_All;
	self.myYardAllocationDrawingFrame.caption := null;
	self.myYardAllocationDrawingFrame.visible := false;
	self.myYardAllocationDrawingFrame.transparent := true;
	self.form.addControl(self.myYardAllocationDrawingFrame);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createScrollableFrame" id="6a8848ae-0c4b-472c-ad16-ebc518911d21">
        <updating/>
        <source>createScrollableFrame() updating, protected;
begin
	create self.myScrollableFrame transient;
	self.myScrollableFrame.name := "Scrollable Frame";
	self.myScrollableFrame.bevelInner := Frame.Bevel_None;
	self.myScrollableFrame.bevelOuter := Frame.Bevel_None;
	self.myScrollableFrame.borderStyle := Frame.BorderStyle_None;
	self.myScrollableFrame.boundaryWidth := 0;
	self.myScrollableFrame.ignoreSkin := true;
	self.myScrollableFrame.parent := self;
	self.myScrollableFrame.alignContainer := Frame.AlignContainer_All;

	self.form.addControl(self.myScrollableFrame);

	//self.setScrolledCallbackMethod('handleGridAreaScrolledEvent');
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createScrollingFrame" id="7c696c45-9b31-4b64-a808-a0b3c6f34198">
        <updating/>
        <source>createScrollingFrame() updating, protected;
begin
	create self.myScrollingFrame transient;
	self.myScrollingFrame.name := "Scrolling Frame";
	self.myScrollingFrame.bevelInner := Frame.Bevel_None;
	self.myScrollingFrame.bevelOuter := Frame.Bevel_None;
	self.myScrollingFrame.borderStyle := Frame.BorderStyle_None;
	self.myScrollingFrame.boundaryWidth := 0;
	self.myScrollingFrame.parent := self;
	self.form.addControl(self.myScrollingFrame);
end;</source>
        <access>protected</access>
    </JadeMethod>
