    <JadeMethod name="exportCSV" id="ef7068ab-8b91-4b12-9f64-8f9047b4ea57">
        <source>exportCSV() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	line : String;
	teusStr : String;
begin
	
	//05/09/2025	navkc1 JIRA 35622
	if self.isRoRo() then
		teusStr := self.length.String;
	else
		teusStr := self.teus.String;
	endif;
	
	line := 	inheritMethod()  &amp; "," &amp;
				self.taCode &amp; "," &amp;
				self.imexCode &amp; "," &amp;
				self.cargoTypeCode &amp; "," &amp; //05/09/2025	navkc1 JIRA 35622
				self.isoGroupCode &amp; "," &amp;
				self.contentsCode &amp; "," &amp;
				self.amount.String &amp; "," &amp;
				//self.teus.String &amp; CrLf;
				teusStr &amp; CrLf;
	return line;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayLine" id="def9638c-0467-4e9d-a900-ca293e831d57">
        <source>getDisplayLine() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	teusStr : String;
begin
	//05/09/2025	navkc1 JIRA 35622
	if self.isRoRo() then
		teusStr := self.length.String;
	else
		teusStr := self.teus.String;
	endif;

	return self.imexCode &amp; Tab &amp; 
			self.cargoTypeCode &amp; Tab &amp; //05/09/2025	navkc1 JIRA 35622
			self.isoGroupCode &amp; Tab &amp; 
			self.contentsCode &amp; Tab &amp; 
			self.amount.String &amp; Tab &amp; 
			//self.teus.String;
			teusStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCONT" id="ad743a66-5916-4d42-a97e-c8d96a17b5d2">
        <source>isCONT() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//05/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars
	cargoType		: CM_CargoType;
begin
	cargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);
	
	return cargoType &lt;&gt; null and self.cargoTypeCode = cargoType.abbreviation;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRoRo" id="e6c20491-b4db-49b2-b025-7e4ffc47e8a1">
        <source>isRoRo() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars
	kpiTA : CM_KPITerminalArea;
	
begin
	
	kpiTA := self.myKPITerminaArea;
	
	return kpiTA &lt;&gt; null and kpiTA.isRoRoLane();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3975848e-b693-4579-bc1c-d35703b428c8">
        <updating/>
        <source>setForCreate(_pxyMe : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_pxyMe);
	
	self.amount := _pxyMe.amount;
	self.contentsCode := _pxyMe.contentsCode;
	self.imexCode := _pxyMe.imexCode;
	self.isoGroupCode := _pxyMe.isoGroupCode;
	self.taCode := _pxyMe.taCode;
	self.teus := _pxyMe.teus;
	self.length := _pxyMe.length; //08/09/2025	navkc1 JIRA 35622 
	self.cargoTypeCode := _pxyMe.cargoTypeCode; //08/09/2025	navkc1 JIRA 35622 

end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setParent" id="43387d20-5e6e-4881-93af-e7b598ea5075">
        <updating/>
        <source>setParent(_ta : CM_KPITerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myKPITerminaArea := _ta;
end;</source>
        <Parameter name="_ta" type="CM_KPITerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="735fb9fc-7a73-4fa6-835a-a8b10664779a">
        <updating/>
        <source>setProxy(_tmpTi : CM_TrackedItem ;_term : CM_Terminal; _ts : TimeStamp; _user : String; _type : Integer; _ta : String; _imex : String; _iso : String; _cnts : String; _is40 : Boolean; _length : Decimal; _cargoTypeCode : String) updating; 
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars
begin
	self.setProxyKPI(_term, _ta, _ts, _type, _user);
	
	self.taCode := _ta;
	self.imexCode := _imex;
	self.isoGroupCode := _iso;
	self.contentsCode := _cnts;
	self.length := _length; //05/09/2025	navkc1 JIRA 35622
	self.cargoTypeCode := _cargoTypeCode; //05/09/2025	navkc1 JIRA 35622
	//self.updateTotals(_is40);  //26/02/2015  cnwma1 PAR #33352
	self.updateTotals(_tmpTi);   //26/02/2015  cnwma1 PAR #33352
	
end;</source>
        <Parameter name="_tmpTi" type="CM_TrackedItem"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ta" type="String"/>
        <Parameter name="_imex" type="String"/>
        <Parameter name="_iso" type="String"/>
        <Parameter name="_cnts" type="String"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_cargoTypeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTotals" id="4f46e1f8-4cae-4c3c-b764-1a9b99c58539">
        <updating/>
        <source>updateTotals(_tmpti : CM_TrackedItem) updating;
//updateTotals(_is40 : Boolean) updating; //26/02/2015  cnwma1 PAR #33352
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars
	lc		: CM_LocationsController;
begin
	self.amount := self.amount + 1;
	
	/*if _is40 then					//26/02/2015  cnwma1 PAR #33352
		self.teus := self.teus + 2;
	else
		self.teus := self.teus + 1;
	endif;*/
	
	self.teus := self.teus + _tmpti.getNumTEU().Integer;  //26/02/2015  cnwma1 PAR #33352
	
	//05/09/2025	navkc1 JIRA 35622
	if self.isRoRo() then
		lc := _tmpti.myPrimaryActualLocation;
		
		if lc &lt;&gt; null and lc.isRoRoController() then
			self.length += lc.CM_RoRoController.getTILengthInMetres(_tmpti);
		endif;
	endif;
	
end;</source>
        <Parameter name="_tmpti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
