    <JadeMethod name="doBtnSave" id="0bbcecfe-4886-49d8-bb90-a7e89a77c7b1">
        <updating/>
        <source>doBtnSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
08 May 2024		navhn30	Bug 63871: EUP | FR - 59098 - Departed Transport Correction - Driver Details Not Required
16 May 2024		navhn30	Bug 63874: EUP | FR 59098 - Corrected Details on Transport - Sub Area Selection Not Possible
20/09/2025		navcs2	MTN-35847 	Dev - Returning of Lot Based Cargo | UI Changes
*/

vars
	flexiGateCntrl		: CMIF_FlexiGateController;
	removedTisObjSet	: ObjectArray;
	removedTis			: CM_TISet;
	addedTisSet			: ObjectArray;
	gteRelease			: CMGTE_Release;
	addedTis			: CMGTE_EntitySet;
	terminalArea		: CM_TerminalArea;
	subTerminalArea		: CM_LocationsController;
	carrier,			
	subCarrier			: CM_Carrier;
	objectTi			: Object;
	ti					: CM_TrackedItem;
	cmifTI				: CMIF_MoveQuantityTI;
	pxyVVR				: CM_VehicleVisitRecord;
	vehicleReg,
	driverCode			: String;
	locationController	: CM_LocationsController;
	size				: Integer;
	driverDetails		: CM_DriverDetails;
	vehicle 			: CM_Vehicle;
	result				: Integer;
	terminal			: CM_Terminal;
begin
	// Get all data from form
	carrier 			:= self.cmbCarrier.getCurrentItemObject.CM_Carrier;
	subCarrier 			:= self.cmbSubHaulier.getCurrentItemObject.CM_Carrier;	
	terminalArea 		:= self.cmbTerminalArea.getCurrentItemObject.CM_TerminalArea;
	subTerminalArea		:= self.cmbTerminalSubArea.getCurrentItemObject.CM_LocationsController;	//	15.05.24	navhn30		TFS #63871
	terminal 			:= app.myPassport.myTerminal;					

	if carrier = null then
		app.raiseCMException1(Err_Is_Null, app.getErrorString(Carrier), null, carrier);
	endif;
	
	if subTerminalArea &lt;&gt; null then
		locationController := subTerminalArea;		//	15.05.24	navhn30		TFS #63871
	elseif terminalArea &lt;&gt; null then
		locationController 	:= terminalArea.getMyLocationsController();
	endif;
	
	vehicleReg			:= self.txtRegistration.text;
	driverCode			:= self.txtDriver.text;
	if self.myTerminal.vehicles[vehicleReg, null] = null and (app.msgBox(app.getErrorString1(VB_NEW_VEHICLE, vehicleReg), 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK) then
		return;
	endif;
	if self.myTerminal.allDriversByCode[driverCode] = null and driverCode &lt;&gt; null and (app.msgBox(app.getErrorString1(WARN_Driver_Unknown, driverCode), 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK) then	//08.05.24		navhn30		TFS #63871
		return;
	endif;
	
	create addedTisSet transient;
	create removedTisObjSet transient;
	create addedTis transient;
	
	self.tblReleasedTrackedItems.getAllRowObjects(addedTisSet);
	
	// Create gte entities
	
	foreach objectTi in addedTisSet do							// 20/09/2025	navcs2	MTN-35847 
		create flexiGateCntrl transient;
		create gteRelease transient;
		ti := objectTi.CMIF_MoveQuantityTI.myTI;				// 20/09/2025	navcs2	MTN-35847 
		flexiGateCntrl.setFromExistingPrenote(ti);
		gteRelease.setPXYFromController(flexiGateCntrl);
		gteRelease.setMyTrackedItem(ti);
		addedTis.add(gteRelease);
	endforeach;
	
	// Do the things
	self.myPxyVehicleVisitRecord.setProxyCorrectedInfo(driverCode, carrier, subCarrier, vehicleReg);
	while true do
		app.myTrxUA.trxUpdateVVDepartedTransport(self.myPxyVehicleVisitRecord, addedTis, locationController, self.myMoveControllers, app.myPassport);
			
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			return;
		else
			result := app.showErrorWarningDialog("Vehicle Visit Warnings", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				//self.unloadForm();
				//return;
			endif;
			return;
		endif;
	endwhile;
	
epilog
	delete addedTisSet;
	delete removedTisObjSet;
	delete addedTis;
	delete flexiGateCntrl;
	delete gteRelease;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveTi" id="12eca3ae-b98d-4375-8c42-dfb1e9cb67f0">
        <source>doMnuRemoveTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars
	allSelectedItems : ObjectArray;
	cmifTI : CMIF_MoveQuantityTI;
	obj,
	objIn	: Object;
	iter : Iterator;
	idx : Integer;
	objectSet : ObjectArray;
begin
	/*
	13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form
	This entire method was changed to use the CMIFs now and combine objects.
	*/
	
	create allSelectedItems transient;
	create objectSet transient;
	
	self.tblOnsiteTrackedItems.allSelectedObjects.copy(allSelectedItems);
	self.tblReleasedTrackedItems.getAllRowObjects(objectSet);
	
	foreach obj in allSelectedItems do
		self.tblOnsiteTrackedItems.removeItemObject(obj);
		cmifTI := obj.CMIF_MoveQuantityTI;

		if obj.CMIF_MoveQuantityTI.myTI.canSplitTotalQuantity then
			foreach objIn in objectSet do
				if objIn.CMIF_MoveQuantityTI.myTI = cmifTI.myTI then
					cmifTI.moveQuantity := cmifTI.moveQuantity + objIn.CMIF_MoveQuantityTI.moveQuantity;
					self.tblReleasedTrackedItems.removeItemObject(objIn);
				endif;
			endforeach;
		endif;
		self.tblReleasedTrackedItems.addObject(cmifTI);

	endforeach;
	
epilog
	delete allSelectedItems;
	delete objectSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblCargoContextMenu" id="6dfb5abf-df3f-4fa0-bfb7-6210f503a7a4">
        <updating/>
        <source>doTblCargoContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
10 October 2025	navcs2	MTN-36215 The removed quantity for the cargo item is not displayed in the Details section of the Vehicle Visit Enquiry form.
 */

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	self.tblSelectedReleased := false;		// 10 October 2025	navcs2	MTN-36215
	
	xLeft := x;
	yTop := y;
	
	self.mnuTblRemoveTi.visible := true;					
	self.mnuTblColumnOrganiser.userObject := cntrl;	
	
	if self.tblOnsiteTrackedItems.allSelectedObjects.size = 0 then	
		self.mnuTblRemoveTi.enabled := false;
	else	
		self.mnuTblRemoveTi.enabled := true;
	endif;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTblContext, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblReleasedContextMenu" id="7cbaf2b7-5fd4-4ab7-b184-43d795c36a6f">
        <updating/>
        <source>doTblReleasedContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2025	navcs2	MTN-36215: The removed quantity for the cargo item is not displayed in the Details section of the Vehicle Visit Enquiry form.

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	self.tblSelectedReleased := true;		// MTN-36215
	
	xLeft := x;
	yTop := y;
	
	self.mnuTblRemoveTi.visible := false;					
	self.mnuTblColumnOrganiser.userObject := cntrl;	
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTblContext, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="20b61d7d-1a60-4f48-aca4-9818ac227db6">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars
	rtnString	:	String;
begin
	rtnString := inheritMethod();
	rtnString := rtnString &amp; self.enquiryTypeDef_Cargo;
	
	return rtnString;
epilog

