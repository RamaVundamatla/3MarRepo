    <JadeMethod name="getXMLSettingsForSave" id="1455ac7a-9bc1-4579-9573-08f4cf35bbed">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theXML, theTypes		: String;
	theDate, toDay : Date;
	theDays, idx : Integer;
begin

	theDate := self.mskDate.getDate();
	theDays := (theDate - toDay);
	
	if theDays &lt; 1 then
		theDays := 1;
	endif;
	
	theXML := inheritMethod();
	
	theXML := theXML &amp; global.formatAsXML(XML_DAYS_OUT, theDays.String);
	theXML := theXML &amp; global.formatAsXML(XML_CONT_QUERY, self.cmbContQuery.text);
	theXML := theXML &amp; global.formatAsXML(XML_CONT_SUM, self.cmbContSummary.text);
	theXML := theXML &amp; global.formatAsXML(XML_REL_SUMM, self.cmbRelSummary.text);
	
	foreach idx in 1 to self.lstRelTypes.rows do
		if self.lstRelTypes.accessCell(idx,1).text = "1" then
			if theTypes = null then
				theTypes := self.lstRelTypes.accessCell(idx,2).text;
			else
				theTypes := theTypes &amp; ":" &amp; self.lstRelTypes.accessCell(idx,2).text;
			endif;
		endif;
	endforeach;
	theXML := theXML &amp; global.formatAsXML(XML_REL_TYPES, theTypes);
	
	
	foreach idx in 1 to self.lstRelStatus.rows do
		if self.lstRelStatus.accessCell(idx,1).text = "1" then
			if theTypes = null then
				theTypes := self.lstRelStatus.accessCell(idx,2).text;
			else
				theTypes := theTypes &amp; ":" &amp; self.lstRelStatus.accessCell(idx,2).text;
			endif;
		endif;
	endforeach;
	theXML := theXML &amp; global.formatAsXML(XML_REL_STATUS, theTypes);

	
	return theXML;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="fb988550-d7be-4d9c-9954-d59736524550">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	theDate, toDay : Date;
	theDays, idx : Integer;
	tmpString : StringArray;
	tmpStr : String;
begin

	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;

 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_CONT_QUERY);
 	if theXMLValue &lt;&gt; null then
		self.cmbContQuery.text := theXMLValue;
 	endif;

 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_CONT_SUM);
 	if theXMLValue &lt;&gt; null then
		self.cmbContSummary.text := theXMLValue;
 	endif;

 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_REL_SUMM);
 	if theXMLValue &lt;&gt; null then
		self.cmbRelSummary.text := theXMLValue;
 	endif;

	theXMLValue := theXML.cnEcGetTagValueOfName(XML_DAYS_OUT);
 	if theXMLValue &lt;&gt; null then
		theDays := theXMLValue.Integer;
		theDate := toDay + theDays;
 	endif;
	
	create tmpString transient;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_REL_TYPES);
 	if theXMLValue &lt;&gt; null then
		tmpString := theXMLValue.getTokens();
		foreach tmpStr in tmpString do

			foreach idx in 1 to self.lstRelTypes.rows do
				if tmpStr = self.lstRelTypes.accessCell(idx,2).text then
					self.lstRelTypes.accessCell(idx,1).text := "1";
				endif;
			endforeach;
		endforeach;
 	endif;
	
	tmpString.clear;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_REL_STATUS);
 	if theXMLValue &lt;&gt; null then
		tmpString := theXMLValue.getTokens();
		foreach tmpStr in tmpString do

			foreach idx in 1 to self.lstRelStatus.rows do
				if tmpStr = self.lstRelStatus.accessCell(idx,2).text then
					self.lstRelStatus.accessCell(idx,1).text := "1";
				endif;
			endforeach;
		endforeach;
 	endif;
	
	self.mskDate.setDate(theDate);
	
epilog
	delete tmpString;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5eb7948e-3745-4ca4-91c0-39db411e81d6">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.displayRelReqStatus();
	self.displayRelReqTypes();
	self.displaySelectorQueries();
	self.displaySummaryDefs();	
	
	self.getXMLSettingsForSetup();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0b882fe5-4f07-4939-9936-718ba6523e1b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013905, locale);
	btnCancel.translateCaption(Xlat_0013906, locale);
	btnSearch.translateCaption(Xlat_0013907, locale);
	btnSumDefnCont.translateBubbleHelp(Xlat_0013908, locale);
	btnSumDefnCont.translateCaption(Xlat_0013909, locale);
	btnSumDefnRel.translateBubbleHelp(Xlat_0013910, locale);
	btnSumDefnRel.translateCaption(Xlat_0013911, locale);
	grpContainers.translateCaption(Xlat_0013912, locale);
	grpRelease.translateCaption(Xlat_0013913, locale);
	lblConSummary.translateCaption(Xlat_0013914, locale);
	lblContQuery.translateCaption(Xlat_0013915, locale);
	lblRelDate.translateCaption(Xlat_0013916, locale);
	lblRelStatus.translateCaption(Xlat_0013917, locale);
	lblRelSummary.translateCaption(Xlat_0013918, locale);
	lblRelTypes.translateCaption(Xlat_0013919, locale);
end;</source>
    </JadeMethod>
</GUIClass>
