// -----------------------------------------------------------------------------
// Created:		08 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.myTicketSequenceRules.calculateRequired();
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkForDuplicateId" id="6e9c231b-61f3-4270-8dfc-4bc933a57349">
        <source>checkForDuplicateId(_ticketSeq : CM_TicketSequence)protected;
//--------------------------------------------------------------
//Created: 29 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	self.myTerminal.validateTicketSequence(self.myTicketSequenceRules.allTicketSequences, _ticketSeq);
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_ticketSeq" type="CM_TicketSequence"/>
    </JadeMethod>
