    <JadeMethod name="initialiseTransaction" id="6a3d550b-dc02-42b7-9532-b79187649d96">
        <updating/>
        <source>initialiseTransaction() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
// 12 Dec 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// 07 Mar 2023 navmp20 Bug 56603: FR 53330/54104 | EUP - Unexpected warnings when changing Barges or Vessels
// 18 Oct 2024 navnk30 JIRA 19927: EUP - Error 1081 When using Rail Lander
// 17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
// ---------------------------------------------------------------------------
vars

begin

	self.status 					  := TRXStatus_InComplete;
	self.clearErrorsWarnings();
	self.numWarningsAtValidationStage := 0;
	self.returnCode					  := 0;
	self.allTransMessages.clear;
	
	self.clearDeferUpdatesCollections();

	self.useTITransactionDeferUpdate   := false;
	self.useTIDictDeferUpdate 		   := false;
	self.useEventDeferUpdate 		   := false;  		// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	self.useWOTransactionDeferUpdate   := false;		//18.10.2024 navnk30 JIRA #19927
	self.useOfflineFutureActorDeferUpd := false;		//17.03.2025 navma1 #MTN-34120
	self.useOfflineFutureActorDeferDel := false;		//17.03.2025 navma1 #MTN-34120
	
	self.setPassportEdiMode(CM_Passport.EDI_MODE_NONE);				//12.12.2022 navma1 #52499
	
	// PAR 24822 - ensure any sub-audit controller is deleted at start of transaction (RJS 29 Jun 2010) 
	if self.myTIAuditController &lt;&gt; null then
		self.myTIAuditController.initialiseTransaction();
	endif;
	self.setIgnoreVesselChanges(false);       //07.03.2023 navmp20 TFS 56603

end;</source>
    </JadeMethod>
    <JadeMethod name="isInEdiDBLoadMode" id="4afbc30f-daab-4f21-b814-73c1b084e8b8">
