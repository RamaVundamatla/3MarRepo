    <JadeMethod name="setForCreate" id="79219b26-3a17-4c13-8f58-df0045ffc32a">
        <updating/>
        <source>setForCreate(_pxyMe : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.code := _pxyMe.code;
	self.dateTime := _pxyMe.dateTime;
	self.type :=  _pxyMe.type;
	self.userCode := _pxyMe.userCode;
	
	self.myTerminal := _pxyMe.myTerminal;
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyKPI" id="d5a0e071-255f-4f62-b8c4-b3c35ad8ae10">
        <updating/>
        <source>setProxyKPI(_term : CM_Terminal;_code : String; _ts : TimeStamp; _type : Integer; _user : String) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.code := _code;
	self.dateTime := _ts;
	self.type := _type;
	self.userCode := _user;
	self.myTerminal := _term;
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
</Class>
