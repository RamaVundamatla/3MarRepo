    <JadeMethod name="translateForm" id="c74f0c8c-3d2d-489e-9290-596784333286">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:44:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023303, locale);
	btnClear.translateCaption(Xlat_0023306, locale);
	btnClose.translateCaption(Xlat_0023307, locale);
	btnTestAP.translateCaption(Xlat_0023305, locale);
	lblTestAutoPlan.translateCaption(Xlat_0023304, locale);
	mnuAddYA.translateCaption(Xlat_0023321, locale);
	mnuColOrg.translateCaption(Xlat_0023322, locale);
	mnuContexts.translateCaption(Xlat_0023311, locale);
	mnuEditYA.translateCaption(Xlat_0023320, locale);
	mnuInspect.translateCaption(Xlat_0023323, locale);
	mnuPlanItems.translateCaption(Xlat_0023314, locale);
	mnuRemoveItems.translateCaption(Xlat_0023312, locale);
	mnuRemovePlanned.translateCaption(Xlat_0023313, locale);
	mnuSendToEnquiry.translateCaption(Xlat_0023315, locale);
	mnuSendToMove.translateCaption(Xlat_0023316, locale);
	mnuSendToReport.translateCaption(Xlat_0023317, locale);
	mnuShowAPLog.translateCaption(Xlat_0023319, locale);
	mnuSummarise.translateCaption(Xlat_0023318, locale);
	shtFail.translateCaption(Xlat_0023310, locale);
	shtResults.translateCaption(Xlat_0023309, locale);
	shtSelected.translateCaption(Xlat_0023308, locale);
end;</source>
    </JadeMethod>
