    <JadeMethod name="setComboValues" id="b49dd870-3b1d-4d98-959e-133f20ec22bf">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_MenuItemByTypeMenuIdDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	state,
	cnt					: Integer;	
begin
	_combo.clear();
	
	//_combo.addItem(app.stateEnumToString(TI_STATE_ARCHIVED));
	_combo.addItem(app.stateEnumToString(TI_STATE_DELETED));
	_combo.addItem(app.stateEnumToString(TI_STATE_EDI));
	_combo.addItem(app.stateEnumToString(TI_STATE_NORMAL));
	_combo.addItem(app.stateEnumToString(TI_STATE_NOTIFIED));
	_combo.addItem(app.stateEnumToString(TI_STATE_OFFLOADED));
	_combo.addItem(app.stateEnumToString(TI_STATE_OFFSITE));
	_combo.addItem(app.stateEnumToString(TI_STATE_ONSHIP));
	_combo.addItem(app.stateEnumToString(TI_STATE_TBA));
	_combo.addItem(app.stateEnumToString(TI_STATE_PLACEHOLDER));	//13 Mar 2020	NDL	TFS 47004
	_combo.addItem(app.stateEnumToString(TI_STATE_UNDEFINED));
	//epr TFS 47132 19/12/18
	if  app.isInterTerminalTransferEnabled() and  _params  &lt;&gt; null and _params.context = "CM_ContainerEnqForm" then
		_combo.addItem(app.stateEnumToString(TI_STATE_TRANSFER_FROM));
		_combo.addItem(app.stateEnumToString(TI_STATE_TRANSFER_TO));
	endif;
	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		if _params  &lt;&gt; null and _params.context = "CM_ContainerEnqForm" and _queryOperator.CM_QIntegerLookupEqual.searchValue = 0 then
			return;
		endif;	
		_combo.text := app.stateEnumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.stateEnumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="53160147-9d6e-4f14-81cf-7ebb7d9411b1">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------

vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	//intArray.add(TI_STATE_ARCHIVED);
	intArray.add(TI_STATE_DELETED);
	intArray.add(TI_STATE_EDI);
	intArray.add(TI_STATE_NORMAL);
	intArray.add(TI_STATE_NOTIFIED);
	intArray.add(TI_STATE_OFFLOADED);
	intArray.add(TI_STATE_OFFSITE);
	intArray.add(TI_STATE_ONSHIP);
	intArray.add(TI_STATE_TBA);
	intArray.add(TI_STATE_PLACEHOLDER);	//13 Mar 2020	NDL	TFS 47004
	intArray.add(TI_STATE_UNDEFINED);
	
	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_STATE_Constant);	

epilog
	delete intArray;
end;
/*
vars
	dict				: CM_MenuItemByTypeMenuIdDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	selectionValue,
	state,
	cnt					: Integer;	
begin
	_tbl.clear();
	_tbl.rows := _tbl.fixedRows;
	
	_tbl.addItem(self.doesIncludeState(TI_STATE_ARCHIVED, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_ARCHIVED));
	_tbl.addItem(self.doesIncludeState(TI_STATE_DELETED, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_DELETED));
	_tbl.addItem(self.doesIncludeState(TI_STATE_EDI, _operator) 		&amp; Tab &amp; app.stateEnumToString(TI_STATE_EDI));
	_tbl.addItem(self.doesIncludeState(TI_STATE_NORMAL, _operator) 		&amp; Tab &amp; app.stateEnumToString(TI_STATE_NORMAL));
	_tbl.addItem(self.doesIncludeState(TI_STATE_NOTIFIED, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_NOTIFIED));
	_tbl.addItem(self.doesIncludeState(TI_STATE_OFFLOADED, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_OFFLOADED));
	_tbl.addItem(self.doesIncludeState(TI_STATE_OFFSITE, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_OFFSITE));
	_tbl.addItem(self.doesIncludeState(TI_STATE_ONSHIP, _operator) 		&amp; Tab &amp; app.stateEnumToString(TI_STATE_ONSHIP));
	_tbl.addItem(self.doesIncludeState(TI_STATE_TBA, _operator) 		&amp; Tab &amp; app.stateEnumToString(TI_STATE_TBA));
	_tbl.addItem(self.doesIncludeState(TI_STATE_UNDEFINED, _operator) 	&amp; Tab &amp; app.stateEnumToString(TI_STATE_UNDEFINED));
	
	
end;

*/</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
