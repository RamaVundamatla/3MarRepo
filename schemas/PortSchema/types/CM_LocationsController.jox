        <source>numAllTIs():Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwer1	Initial creation

*/

vars

begin
	return self.numTIs + self.numPlannedTIs + self.numQueuedTIs;

epilog

end;</source>
