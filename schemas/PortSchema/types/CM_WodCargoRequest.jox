    <JadeMethod name="myBerth" id="8f7515fb-4056-4bc4-9374-3d9c7ae57e98">
        <methodInvocation>mapping</methodInvocation>
        <source>myBerth(set : Boolean; _value : HMS_Berth io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2018	jlgab1	Initial creation

*/

vars
	movement : HMS_VoyageMovement;
	voyage : CM_Voyage;
begin
	if not set then
		voyage :=  self.getMyVoyageObject();
		
		if voyage &lt;&gt; null then
			if voyage.myHMSVoyageData&lt;&gt; null then
				_value := voyage.myHMSVoyageData.getBerthForDateTime(self.getMyParent.requiredByDT);
			endif;
		endif;
	endif;
epilog

end;</source>
