    <JadeMethod name="assignValueSpecial" id="b01d3839-4a09-4f30-a117-3ffd46f40a5e">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
27 Aug 2024 navsaa30 Bug 65356: MTN - UNDG Code cannot be edited in EDI Operations (Transport Manifest)
*/

vars

begin

	if _propName = ETRow_CargoID then				//epr TFS 4139 27/4/17 changed from parent Cargo id			
		self.setId(_processedValue.toUpper);		
		return true;													
		
	elseif _propName = ETRow_AllUNDGCodes then							
		self.undgCodes := _processedValue.toUpper;		
		return true;
		
	elseif _propName = ETRow_UndgCodes then				//27/8/24   navsaa30 #65356			
		self.undgCodes := _processedValue.toUpper;		
		return true;
	
	elseif _propName = ETRow_CargoType then
		return inheritMethod(ETRow_CargoTypeDescr, _processedValue, _xlationOperator);
	
	elseif _propName = ETRow_FlashpointTemperature then	//07 Mar 2017	NDL	TFS 3486
		if _processedValue = null then
			self.flashpointTemperature := NULL_TEMPERATURE;
			return true;
		endif;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
