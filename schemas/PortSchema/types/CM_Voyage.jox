    <JadeMethod name="setExtraMoveDtls" id="02e53c3a-a599-449e-b38b-45e8837698b0">
        <updating/>
        <source>setExtraMoveDtls(_extraMoveDtl : CMIF_VoyageExtraMoveDtl; _passport : CM_Passport) updating;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpUserCode	: String;
	totKPI : CM_KPIVoyageTotals;
begin

	tmpUserCode := _passport.userCode;

	self.setNumCageMoves(_extraMoveDtl.numCageMoves, tmpUserCode);
	self.setNumExtraMoves(_extraMoveDtl.numExtraMoves, tmpUserCode);
	self.setNumLashingBinMoves(_extraMoveDtl.numLashingBinMoves, tmpUserCode);
	self.setNumLashings(_extraMoveDtl.numLashings, tmpUserCode);
	self.setNumUnlashings(_extraMoveDtl.numUnlashings, tmpUserCode);

	 // PAR 25719 NEW KPI 2010 CCMS SFW 1134
	totKPI := self.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	if totKPI = null then
		create totKPI;
		totKPI.setKPIForCreate(self, self.arrivedDT );
	endif;
	
	totKPI.setFromCMIF_VoyageExtraMoveDtl(_extraMoveDtl);

	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Voyage_Update_Event), self);  

epilog

end;</source>
        <Parameter name="_extraMoveDtl" type="CMIF_VoyageExtraMoveDtl"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e97d7b22-7485-4e21-842e-cb91e55de44c">
        <updating/>
        <source>setForCreate(_proxyVoyage : CM_Voyage; _realVoyGlobal : CM_VoyageGlobal; _createShipPlanningStructure : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/05/2006	cnwdad1		CCMS #1396 - added the dateFirstAvailable property.
// 29/04/2009	cnwer1		CCMS 1058 - refactored common code from setForCreate and setForUpdate into
//										into setForUpdateDetails - kept old code in setForCreateOLD for quick 
//										history
// 21 May 2010	cnwkpd1		PAR #23525 - Set up stable collections if required
// 13 mar 2013	PJS			PAR #31232	
// 11 Apr 2017	cnwdap1		TFS 4050 LNX Job ID Enhancements
// 12 Jun 2018	jlgrh7 		TFS #39015  LNX - RE: Ticket 38780 - Voyage Definition 'External Code' Value
// 07 Aug 2018	jlggb1		TFS 40692	Dev Error for Log Voyages 
// 03 Jun 2020  cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 06 Oct 2021	jlizm1		TFS 51963 SAL Voyage Request Changes
// 16 Jul 2024	navlw1		ChangedRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
// 26 Nov 2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
// ---------------------------------------------------------------------------
vars
	tmpGlobalVoyage		: CM_VoyageGlobal;
	tmpVessel			: CM_Vessel;
	agent				: CM_ObjectVolatilityConverter;
	externalCode,
	voyageGrpCode		: String;
	tmpCode				: String;
	voyageNumber		: Integer;
	progress 			: CM_VoyageProgress;
begin
	tmpCode := _proxyVoyage.code.trimBlanks();
	if tmpCode = null and app.myPassport.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then				// TFS 51963
		tmpCode := _proxyVoyage.myTerminal.getNextVoyageCode(self.vessel, voyageNumber, app.myPassport);	// TFS 51963
	endif;
	
	self.code := tmpCode;
	self.archived := false; //you cant create a voyage as archived you can only archive an existing voyage
	self.archivedDT := null;
	
	// Start navlw1 #63839
	//if _proxyVoyage.isAutomaticProcess() then										// MTN-33516
	if _proxyVoyage.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
		self.inwardCodeAuto := _proxyVoyage.inwardCodeAuto.trimBlanks();
		self.voyageCodeExternalAuto := _proxyVoyage.voyageCodeExternalAuto.trimBlanks();
		if self.voyageCodeExternalAuto &lt;&gt; null then
			if _proxyVoyage.myTerminal.allVoyagesByExtCodeAuto[self.voyageCodeExternalAuto, self.vesselCode] &lt;&gt; null then
				app.raiseCMException2(Voyage_Duplicate_External, self.code, self.voyageCodeExternalAuto, null, null);
				return;
			endif;
			self.myTerminalForExternalCodeAuto := _proxyVoyage.myTerminal;
		endif;
	else
		self.inwardCode := _proxyVoyage.inwardCode.trimBlanks();
		//self.voyageCodeExternal := _proxyVoyage.voyageCodeExternal;														// TFS 4050//-TFS39105
		if _proxyVoyage.voyageCodeExternal &lt;&gt; null then																		//+TFS39105 If nothing set in the text box then we hookcode
			self.voyageCodeExternal := _proxyVoyage.voyageCodeExternal;														// TFS 4050
		else
			if self.vessel &lt;&gt; null then //jlggb1 40692 07/09/2018 Log voyages don't have vessels
				//jlier1 TFS 51963 5/10/21 - they want to set this when voyage request is approved
				if _proxyVoyage.myVoyageProcess = null or _proxyVoyage.myVoyageProcess.isDefaultProcessJMT then
					externalCode := _proxyVoyage.myTerminal.getNextVoyageExternalCode(self.vessel);			// +TFS39105
					self.voyageCodeExternal := externalCode;
				endif;
			endif;
		endif;
		if self.voyageCodeExternal &lt;&gt; null then									// TFS 4050
			if _proxyVoyage.myTerminal.allVoyagesByExternalCode[self.voyageCodeExternal] &lt;&gt; null then // JLGAB1 TFS 47485
				app.raiseCMException2(Voyage_Duplicate_External, self.code, self.voyageCodeExternal, null, null);	 // JLGAB1 TFS 47485
			
				return; // JLGAB1 TFS 47485
			endif;
			self.myTerminalForExternalCode := _proxyVoyage.myTerminal;			// TFS 4050
		endif;																	// TFS 4050
	endif;
	// End navlw1 #63839
	
	self.voyageNumber		:=  _proxyVoyage.voyageNumber;
	
	//03/06/2020 cnwma1 Tfs #49400
	if _proxyVoyage.voyageGroupCode &lt;&gt; null then																		
		self.voyageGroupCode := _proxyVoyage.voyageGroupCode;										
	else
		voyageGrpCode := _proxyVoyage.myTerminal.getNextVoyageGroupCode(_proxyVoyage);
		self.voyageGroupCode := voyageGrpCode;
	endif;
	if self.voyageGroupCode &lt;&gt; null then
		self.myTerminalForGroupCode := _proxyVoyage.myTerminal;
	endif;
	//03/06/2020 cnwma1 Tfs #49400
	
	if self.myLayoutGraphic = null then
		self.myLayoutGraphic := _proxyVoyage.myLayoutGraphic;
	endif;
	// This must be done before we set the global voyage
	self.setMyTerminal(_proxyVoyage.myTerminal);
	if _realVoyGlobal = null then // not a log voyage?
		// See if there is already a global Voyage - Needed for Unit Tests which do not pass in a global voyage
		tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[code];
		if tmpGlobalVoyage = null then
			create tmpGlobalVoyage persistent;
			tmpGlobalVoyage.setForCreateBasics(_proxyVoyage.myVoyageGlobalArrival, app.myPassport);
		endif;
	else	// log voyage?
		tmpGlobalVoyage := _realVoyGlobal;
	endif;

	// lorcan 14/7/2007 We were setting the voyagegloabl to _realVoyGlobal which was not correct when we creating one above
	// we should have been (and are now) using tmpGlobalVoyage
	if _proxyVoyage.myVoyageGlobalDeparture &lt;&gt; null then
		self.setMyVoyageGlobalDeparture(tmpGlobalVoyage);
	endif;
	
	if _proxyVoyage.myVoyageGlobalArrival &lt;&gt; null then
		self.setMyVoyageGlobalArrival(tmpGlobalVoyage);
	endif;

	
	// 31232
	// create the ship block controller by default as part of the voyage creation
	self.createShipBlockController(app.myPassport);
	
	
	// Finally add into terminal dict
	self.myTerminal.addVoyageToDict(null, null, self);
	
	
	tmpVessel := self.getMyVessel();
	if tmpVessel &lt;&gt; null then
		tmpVessel.setVoyageNumberForTerminal(self.myTerminal, self.voyageNumber + 1);
	endif;
	
	self.setForUpdateDetails(_proxyVoyage, _createShipPlanningStructure, app.myPassport);	
	
	// PAR #23525 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if app.myRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;

	//epr TFS 39166 13/6/18
	if self.myVoyageProcess &lt;&gt; null then
	//	if self.myVoyageProcess.isPelindo1Process or self.myVoyageProcess.isInaPortNetProcess then
		 // ### TFS CR 64614 TASK 65082 17JUL2024 NAVAB1if not self.myVoyageProcess.isDefaultProcessJMT then	//23 July 2018	NDL	TFS 39882
		if self.myVoyageProcess.doesCreateVoyageWorkOrder() then // ### TFS CR 64614 TASK 65082 17JUL2024 NAVAB1
			//lets create a work order and the voyage work order request 
			app.myUtilityCA.utlCreateWorkOrderVoyage(self,app.myPassport);
		endif;
	endif;
	
epilog
	delete agent;
	
end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_realVoyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_createShipPlanningStructure" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="e1e24a3d-5ca6-478b-a6c9-63e0a0e84769">
        <updating/>
        <source>setForCreateInternal(_vessel : CM_Vessel; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			16 January 2003 by cnwdwq1
Purpose:			This is the NEW version of the create method, called exclusively
							from CM_Vessel::createVoyage
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

	if _vessel = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Vessel reference', null, null);
	endif;

	//---------------------
	//Copy vessel attributes applicable at CM_Vessel level
	//---------------------

	self.craneClearance := _vessel.craneClearance;
		
	self.lloydsNumber := _vessel.lloydsNumber;
	if _vessel.myLayoutGraphic &lt;&gt; null then
		self.myLayoutGraphic := _vessel.myLayoutGraphic.copyToVoyage();
	endif;
	
	self.remarks := _vessel.remarks;
	self.vesselName := _vessel.name;
	self.vesselCode := _vessel.code;
	self.setMyVessel(_vessel); // PAR 30558
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		self.myCellularVoyageStructure.setForCreateInternal(_vessel.myCellularVesselStructure, _passport);
	endif;	
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForShippingLineOperators" id="a147bc10-dc25-4318-a6ea-67b22c1e7740">
        <updating/>
        <source>setForShippingLineOperators(_shippingLine : CM_ShippingLine) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	self.myShippingLine := _shippingLine;
	
	/*epr CCMS 1058 users can now define ports of call and operators on the voyage defintion 
		these default from trade. It nolonger defaults from shipping line
	*/
	
	/*
	if self.myShippingLine &lt;&gt; null then
		self.myShippingLine.getAllDischargePorts(self.allPorts);
		self.myShippingLine.getAllDischargePorts(portSet);
		self.allOperators.clear();
		self.myShippingLine.getAllOperators(self.allOperators);
	endif;*/
epilog

end;</source>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="971044e3-ada7-4345-a8cc-208b83ca26cf">
        <updating/>
        <source>setForUpdate(	_hasStructure     : Boolean;
				_proxyVoyage 	  : CM_Voyage;  
				_realVoyGlobalArr, 
				_realVoyGlobalDep : CM_VoyageGlobal; 
				_passport 	      : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/05/2006	// cnwdad1	CCMS #1396 - added the dateFirstAvailable property.
   29/04/2009	cnwer1		CCMS 1058 - changes to ports of call and operators
									  - refactored out common code in setForCreate and
										setForUpdate into one method setForUpdateDetails
										-kept old method for reference setForUpdateOLD
   11/04/2017	cnwdap1		TFS 4050 LNX Job ID Enhancements
   02/05/2017	cnwdap1		TFS 4293 Avoid 1278 exceptios when clearing voyageCodeExternal
   03/06/2020   cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
   16/07/2024	navlw1		ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 
   26/11/2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
// ---------------------------------------------------------------------------*/
vars
	origCode					: String;
	
	js : CM_JobSheet;
begin
	
	// Save the original values to use for updating the dicts later
	origCode					:=	self.code;
	self.archived				:=	_proxyVoyage.archived; //you cant create a voyage as archived you can only archive an existing voyage
	self.archivedDT				:=	_proxyVoyage.archivedDT;
	
	self.setForUpdateDetails(_proxyVoyage,_hasStructure,_passport);
	
	// Any change to code and inwardCode must update all CM_TrackedItem.voyageCode as well
	self.updateCode(_proxyVoyage.code.trimBlanks, _passport);
	
	// start navlw1 #63839
	//if _proxyVoyage.isAutomaticProcess() then								// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
		self.updateInwardCodeAuto(_proxyVoyage.inwardCodeAuto.trimBlanks(), _passport);
		if _proxyVoyage.voyageCodeExternalAuto &lt;&gt; null then
			self.voyageCodeExternalAuto := _proxyVoyage.voyageCodeExternalAuto;
			self.myTerminalForExternalCodeAuto := _proxyVoyage.myTerminal;
		else
			self.myTerminalForExternalCodeAuto := null;
			self.voyageCodeExternalAuto := null;
		endif;
	else
		//self.inwardCode := _proxyVoyage.inwardCode;
		self.updateInwardCode(_proxyVoyage.inwardCode.trimBlanks, _passport);
		//if self.voyageCodeExternal &lt;&gt; null then								// TFS 4050		// TFS 4293
		if _proxyVoyage.voyageCodeExternal &lt;&gt; null then							// TFS 4050		// TFS 4293
			self.voyageCodeExternal := _proxyVoyage.voyageCodeExternal;			// TFS 4050		// TFS 4293
			self.myTerminalForExternalCode := _proxyVoyage.myTerminal;			// TFS 4050		// TFS 4293
		else																	// TFS 4050		// TFS 4293
			self.myTerminalForExternalCode := null;								// TFS 4050		// TFS 4293
			self.voyageCodeExternal := null;									// TFS 4050		// TFS 4293
		endif;		
	endif;
	// end navlw1 #63839
	
	//03/06/2020 cnwma1 Tfs #49400
	self.updateVoyageGroupCode(_proxyVoyage);																
	//03/06/2020 cnwma1 Tfs #49400
	
	// Backstop for PAR 10708
	self.validateArrivalDepartedDates();
	
/*
	6/11/18 MAP TFS41143	changed voyage code now handled in updateCode
	if self.myVoyageGlobalArrival &lt;&gt; _realVoyGlobalArr then
		self.setMyVoyageGlobalArrival (_realVoyGlobalArr);
	endif;
	
	if self.myVoyageGlobalDeparture &lt;&gt; _realVoyGlobalDep then
		self.setMyVoyageGlobalDeparture (_realVoyGlobalDep);
	endif;
*/
	
	self.updateVoyageInlandTerminals(_passport);
	
	if origCode &lt;&gt; self.code then
		self.causeEvent(self.myTerminal.getTerminalEvent(Voyage_UpdateCode_Event), false, self);
		
	endif;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	self.sealCheckReceival := _proxyVoyage.sealCheckReceival;
	self.sealCheckRelease := _proxyVoyage.sealCheckRelease;

	self.paymentType := _proxyVoyage.paymentType;		// 25/6/18 MAP TFS39250
	
	 // ### TFS 53105 30JUN2022 NAVAB1 - in case certain dates have been changed re set the ETC on each job sheet
	foreach js in self.allJobSheets discreteLock do
		js.setETC();
	
	endforeach;
	
end;</source>
        <Parameter name="_hasStructure" type="Boolean"/>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_realVoyGlobalArr" type="CM_VoyageGlobal"/>
        <Parameter name="_realVoyGlobalDep" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateBulk" id="a8b7e57c-65e6-4f5f-9fa5-f7505985c338">
        <updating/>
        <source>setForUpdateBulk(_cmifUpdate : CMIF_VoyageBulkUpdate) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
// 12/04/2023	navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
//
vars

begin
	if self.isTransient then
		self.status := _cmifUpdate.voyageStatus.id;
	else
		self.setStatusFromObject(_cmifUpdate.voyageStatus);
	endif;
	
	// ### TFS 55215 22Nov2022 NAVPW1
	if self.status = Voyage_Status_Arrived then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageArrival, app.myPassport);		// TFS 57362
	elseif self.status = Voyage_Status_Departed then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageDeparture, app.myPassport);		// TFS 57362
	endif;
	// ### TFS 55215 22Nov2022 NAVPW1
	
	if _cmifUpdate.voyageGroupCode &lt;&gt; null then
		self.voyageGroupCode := _cmifUpdate.voyageGroupCode;
	endif;
	
	if _cmifUpdate.estimatedArrivalDT.isValid then
		self.estimatedArrivalDT := _cmifUpdate.estimatedArrivalDT;
	endif;
	if _cmifUpdate.estimatedDepartureDT.isValid then
		self.estimatedDepartureDT := _cmifUpdate.estimatedDepartureDT;
	endif;
	if _cmifUpdate.arrivalDT.isValid then
		self.arrivedDT := _cmifUpdate.arrivalDT;
	endif;
	if _cmifUpdate.departureDT.isValid then
		self.departedDT := _cmifUpdate.departureDT;
	endif;
	if _cmifUpdate.nonEffectiveDT.isValid then
		self.nonPlannedEffectiveDT := _cmifUpdate.nonEffectiveDT;
	endif;
	if _cmifUpdate.generalLandingDate.isValid then
		self.generalLandingDate := _cmifUpdate.generalLandingDate;
	endif;
	
	if _cmifUpdate.exchangeStartedDT.isValid then
		self.shipExchangeDate := _cmifUpdate.exchangeStartedDT;
	endif;
	if _cmifUpdate.exchangeCompletedDT.isValid then
		self.shipExchangeCompleteDT := _cmifUpdate.exchangeCompletedDT;
	endif;
	if _cmifUpdate.departureTargetDT.isValid then
		self.departTargetDT := _cmifUpdate.departureTargetDT;
	endif;
	if _cmifUpdate.availabilityDate.isValid then
		self.dateFirstAvailable := _cmifUpdate.availabilityDate;
	endif;
	
	if _cmifUpdate.anchorDownDT.isValid then
		self.shipAnchorDownDT := _cmifUpdate.anchorDownDT;
	endif;
	if _cmifUpdate.totalTimeInPort &lt;&gt; null then
		self.totalTimeInPort := _cmifUpdate.totalTimeInPort;
	endif;
	if _cmifUpdate.labourOnBoardDT.isValid then
		self.labourOnBoard := _cmifUpdate.labourOnBoardDT;
	endif;
	if _cmifUpdate.labourOnShoreDT.isValid then
		self.labourOnShore := _cmifUpdate.labourOnShoreDT;
	endif;
	if _cmifUpdate.pilotOnBoardDT.isValid then
		self.pilotOnBoardDT := _cmifUpdate.pilotOnBoardDT;
	endif;
	if _cmifUpdate.pilotReturnDT.isValid then
		self.shipPilotReturnDT := _cmifUpdate.pilotReturnDT;
	endif;
	
epilog

end;</source>
        <Parameter name="_cmifUpdate" type="CMIF_VoyageBulkUpdate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCellularStructure" id="c9d2a22f-09d2-4dde-8047-cff9e9cdf70d">
        <updating/>
        <source>setForUpdateCellularStructure(_proxyVoyage : CM_Voyage; 
								_createShipPlanningStructure : Boolean) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Apr 2009	cnwer1	Initial creation
13 Mar 2013	PJS		PAR #31232


*/

vars
	tmpCellStructure,
	realCellStructure		: CM_CellularVoyageStructure;
	tmpVessel				: CM_Vessel;
begin
	// Cellular Structure
	tmpVessel := self.getMyVessel();

	// Cellular Structure
	tmpCellStructure := _proxyVoyage.myCellularVoyageStructure;

	if tmpCellStructure &lt;&gt; null then
		realCellStructure := tmpCellStructure.pxyGetRealObject();
		
		if realCellStructure &lt;&gt; null then 
			realCellStructure.setForUpdateCellular(_createShipPlanningStructure, false, tmpCellStructure, app.myPassport);
		elseif tmpCellStructure.isTransient then
			create self.myCellularVoyageStructure persistent;
			self.myCellularVoyageStructure.setForCreate(tmpCellStructure, app.myPassport);
			
			// do planning structures need to be created as well
			if _createShipPlanningStructure and tmpVessel &lt;&gt; null and tmpVessel.myCellularVesselStructure &lt;&gt; null then
				// set and create the cellular planning structures
				self.myCellularVoyageStructure.createPlanningStructures(tmpVessel.myCellularVesselStructure);
			endif;
		endif;
	
	//31232
	else
	
		if self.myCellularVoyageStructure &lt;&gt; null then
			delete self.myCellularVoyageStructure;
		endif;
			
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_createShipPlanningStructure" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateChargeResources" id="3350e003-b6ed-421f-ba01-09f0b4ea0840">
        <updating/>
        <source>setForUpdateChargeResources(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//30/08/2019 	JLGNS1	ChangeRequest 45926: ASPA - JMT Interface to AR Oracle Stevedores
// 21 Jan 2025	navhl20 Bug MTN-33827: NSW | Unable to Generate Harbour Invoices for Voyages Created with AUTO voyage process

vars
	aVM : HMS_VoyageMovement;
	pxyResUsed,aResUsed, tmpResUsed : HMS_ResourceUsed;
	pxyResourcesUsed : HMS_ResourceUsedSet;
	aTug	: HMS_Tug;
	numTugs,idx, qty : Integer;
	poc,contractTugCharged, berthageCharged, fullCharge, partCharge : Boolean;
	//isDefaultJMTProcess : Boolean;	//17 Oct 2018	NDL	TFS 41411	//21.01.2025 navhl20 #33827
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin
/* CCMS 1350
	// ### only if closed
	if self.status &lt;&gt; Voyage_Status_Closed then
		return;
	endif;
*/
	// ## NOT LICENSED
	if not app.myRoot.canDo(Mod_Harbour)  then // VTMIS License
		return;
	endif;
	
	// ## NO MOVEMENTS
	if self.myHMSVoyageData = null then
		return;
	endif;
	
	// ### GET Any used resources that have not got a transaction.
	create pxyResourcesUsed transient;

//	berthageCharged := self.doBerthageArrivalToDeparture(true);
	berthageCharged := app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;
	
	//isDefaultJMTProcess := self.myVoyageProcess = null or self.myVoyageProcess.isDefaultProcessJMT;	//17 Oct 2018	NDL	TFS 41411	//21.01.2025 navhl20 #33827

	foreach aVM in self.myHMSVoyageData.allVoyageMovements do	
		if aVM.moveStatusNEW &lt;&gt; MovementStatus_Actual then // PAR 10975
			if aVM.occursOnDTNEW &gt; app.actualTimeServer then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				partCharge := true;
				continue;
			endif;
			if aVM.moveStatusNEW = MovementStatus_Planned then  // PAR NSN VISIT 2006MAY
				continue;
			endif;
		endif;
		fullCharge := true;
		// ## charge for PILOTS, LAUNCHES, LINE COs and TUGS used
		
		//31 Oct 2018	NDL	TFS 41662
		if aVM.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then	//allow for non converted data // TFS 44438
			if aVM.getUnConvertedMyPilotRef &lt;&gt; null then
				aVM.getUnConvertedMyPilotRef.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM);
			endif;
		else
			foreach movementPilotDetails in aVM.allMovementPilotDetails do //pilot in aVM.allPilots do // TFS 44438
				movementPilotDetails.myPilot/*pilot*/.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM); // TFS 44438
			endforeach;
		endif;
		
		if aVM.myLineCompany &lt;&gt; null then
			aVM.myLineCompany.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM);
		endif;
		if aVM.getFirstPilotLaunch()/*myPilotLaunch*/ &lt;&gt; null then // TFS 44438 after 040 cut/release
			aVM.getFirstPilotLaunch()/*myPilotLaunch*/.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM); // TFS 44438 after 040 cut/release
		endif;

		//if isDefaultJMTProcess then		//17 Oct 2018	NDL	TFS 41411		//21.01.2025 navhl20 #33827
		if not self.myVoyageProcess.isMTNWOProcess() then						//21.01.2025 navhl20 #33827
			if not berthageCharged then
				if aVM.getMyBerth &lt;&gt; null then
					aVM.getMyBerth.createAutoCharge(aVM);
				endif;
	//		elseif aVM.moveType = HMSMovementTypeArrival then
			elseif (aVM.moveType = HMSMovementTypeDeparture or aVM.moveType = HMSMovementTypeArrival) then
				if aVM.getMyBerth &lt;&gt; null then
					aVM.getMyBerth.createAutoCharge(aVM);
				endif;
			endif;
		endif;

		numTugs := self.getVesselDefaultTugsForMovemnt(aVM);

		contractTugCharged := false;
		idx := 0;
		foreach aTug in aVM.allTugsUsed do
			idx := idx + 1;
			poc := (numTugs &gt;= idx);
			
			if poc and contractTugCharged then
				continue;
			endif;
			
			if poc then
				qty := numTugs;
			else
				qty := aVM.allTugsUsed.size - numTugs;
			endif;
			tmpResUsed := aTug.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM,poc,qty);
			
			if poc then
				contractTugCharged := true;
			else 
				break;
			endif;
		endforeach;

		// ### PAR 10693 if no tugs have been used, but there are some on contract then we must charge for them.
		if aVM.allTugsUsed.size = 0 and numTugs &gt; 0 then
			// ### need a resource so use first tug on harbour with a resource
			if self.myHMSVoyageData.myHarbour &lt;&gt; null then	//ChangeRequest 45926
				foreach aTug in self.myHMSVoyageData.myHarbour.allTugs do : tugLoop
					if aTug.getResourceForHarbourMovement(self.myHMSVoyageData.myHarbour,aVM.moveType) &lt;&gt; null then
						tmpResUsed := aTug.createAutoCharge(self.myHMSVoyageData.myHarbour,aVM,true,numTugs);
						break tugLoop;
					endif;
				endforeach;
			endif;
		endif;



		// ## ACTUAL RESOURCES USED
		foreach aResUsed in aVM.allResourceUsed do
			if aResUsed.myVTMISTransaction = null then
				pxyResUsed := aResUsed.pxyGetProxyObject;
				if pxyResUsed = null then
					pxyResUsed := app.createUpdateProxy(aResUsed).HMS_ResourceUsed;
				endif;
				pxyResourcesUsed.add(pxyResUsed);
			endif;
		endforeach;
	endforeach;
	

	// ### feed the used resources to the transaction map
	foreach pxyResUsed in pxyResourcesUsed do
		// Perform the operation
		app.myUtilityCA.utlCreateInvoiceResourceCharge(pxyResUsed,   _passport, true);
	endforeach;
epilog
	if not app.myPassport.hasErrorsOrWarnings
	or (app.myPassport.hasErrorsOrWarnings and app.myPassport.warningsAcknowledged) then

		
		if partCharge then
			if not fullCharge then
				self.statusInvoice := Voyage_Invoice_Status_NotGen;
			else
				self.statusInvoice := Voyage_Invoice_Status_PartGen;
				self.invoiceChargesProduced := true;
			endif;
		elseif fullCharge then
			self.statusInvoice := Voyage_Invoice_Status_FullGen;
			self.invoiceChargesProduced := true;
		endif;

	endif;
	// ### rid all the proxies
	if pxyResourcesUsed &lt;&gt; null then
		pxyResourcesUsed.purge;
		delete pxyResourcesUsed;
	endif;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCranesWPByHolds" id="58271a86-3bf7-4257-96d9-57de80c847a9">
        <updating/>
        <source>setForUpdateCranesWPByHolds(_cranesWPByHolds : CM_ObjectByObject) updating;
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars

begin
	self.allCranesWPByHolds.clear();
	
	_cranesWPByHolds.copy(self.allCranesWPByHolds);
	
epilog

end;</source>
        <Parameter name="_cranesWPByHolds" type="CM_ObjectByObject"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateDetails" id="752f491a-af15-48a3-8ff0-46236fb5a925">
        <updating/>
        <source>setForUpdateDetails(proxyVoyage 				: CM_Voyage;
					createShipPlanningStructure : Boolean;
					passport 					: CM_Passport input) protected, updating;
/*
Purpose:			
Parameters:			
Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
17/04/2009	cnwer1					Initial creation
01/12/2009 	cnwer1	Par 21806 
					CCMS 1900 		Update allStateData for voyage configs 
15/03/2012	cnwkpd1	PAR #29274 		Only set key values if they have changed
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival and deparure date/times
25/01/2017 	cnwns1 	TFS3214 		LNX - Voyage Operations Enhancements 
09/03/2018	jlgdap1	TFS 37427 		PEL1 Voyage Status Enhancements
19/03/2018	jlgdap1	TFS 37540 		PEL1 Voyage Statuses Pelindo 1
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
12 Feb 2020	jlgdi1	48477			PEL1 - Transfer the code that updates myDischargeCompany (value from the Proxy) 
									to the line after calling hook code to give way / prioritize the hook code return value when a hook code is link to the terminal
16.06.2022 navsrk20 Bug 52514		MTN - Voyage Process Issue Bulk Create Of Barge
============================================================================*/
vars
	pxyRecCutoff			: CM_ReceivalCutoffVoyage;
	realRecCutoff			: CM_ReceivalCutoffVoyage;
	recCutoffDef			: CM_ReceivalCutoffTermDef;
	oldExchangeCompleteDate	: Date;
	newExchangeCompleteDate	: Date;
	cutoffsChanged			: Boolean;
	stateData				: CM_StateData;
	useVAChanged			: Boolean; 
	useWhatsInDB 			: Boolean;
	glDate 					: Date;
	arriveTS 				: TimeStamp;
	departTS 				: TimeStamp;
	voyStatus 				: CM_VoyageStatus;		// TFS 37427
	statusChanged 			: Boolean;				// TFS 37540
	hookBank 				: CM_Bank;
	oldExchangeCompleteTS	: TimeStamp;
	event : CMEVT_VoyageEvent;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin 
	//same as create
	self.statusInvoice			:=	proxyVoyage.statusInvoice;
	
	statusChanged := self.status &lt;&gt; proxyVoyage.status;			// TFS 37540
	
	//14 Jun 2016	NDL	TFS 2140 - 
	//	self.setArrivalDepartureDT(_proxyVoyage.arrivedDT, _proxyVoyage.departedDT, true);
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(EtaEtdMandatory).Boolean then
		arriveTS := proxyVoyage.arrivedDT;
		departTS := proxyVoyage.departedDT;
		
		if proxyVoyage.estimatedArrivalDT.isValid and not arriveTS.isValid then
			arriveTS := proxyVoyage.estimatedArrivalDT;
		endif;
		
		if proxyVoyage.estimatedDepartureDT.isValid and not departTS.isValid then
			departTS := proxyVoyage.estimatedDepartureDT;
		endif;
		
		self.setArrivalDepartureDT(arriveTS, departTS, true);		
	else
		self.setArrivalDepartureDT(proxyVoyage.arrivedDT, proxyVoyage.departedDT, true);		
	endif;
	

	self.bitmap 		:= proxyVoyage.bitmap;
	self.callSign 		:= proxyVoyage.callSign;
	self.colour 		:= proxyVoyage.colour;
	self.cutOffDT 		:= proxyVoyage.cutOffDT;	//CCMS1569 Cargo Cut Off
	self.displayOption 	:= proxyVoyage.displayOption; // CCMS 1423
	self.departTargetDT	:=	proxyVoyage.departTargetDT;
	// PAR 33644	self.isNonPlannedVoyage := _proxyVoyage.isNonPlannedVoyage;
	// PAR 33644	self.isNonWorkedVoyage := _proxyVoyage.isNonWorkedVoyage;
	self.isTransferable := proxyVoyage.isTransferable;
	self.loadEndDT 		:= proxyVoyage.loadEndDT;
	self.loadStartDT 	:= proxyVoyage.loadStartDT;
	self.externalRef 	:= proxyVoyage.externalRef; //CCMS 1952 PAR24400 cnwsh3 20/10/2010 Customs Registration Number for SCT 
	//cnwjo3 CCMS 1028
	useVAChanged := (self.useVoyageAllocations &lt;&gt; proxyVoyage.useVoyageAllocations);
	
	self.useVoyageAllocations := proxyVoyage.useVoyageAllocations;// PAR 23216
	self.setForUpdateVoyageAllocations(proxyVoyage, useVAChanged);// PAR 23216
	
	// CCMS 1115 AKB2004JAN
	if proxyVoyage.labourOnBoard.isValid then
		self.labourOnBoard := proxyVoyage.labourOnBoard;
	else
		self.labourOnBoard := null;
	endif;
	if proxyVoyage.labourOnShore.isValid then
		self.labourOnShore := proxyVoyage.labourOnShore;
	else
		self.labourOnShore := null;
	endif;
	// cnwdad1 01/05/2006 - CCMS #1396.
	if proxyVoyage.dateFirstAvailable.isValid() then
		self.dateFirstAvailable	:=	proxyVoyage.dateFirstAvailable;
	else
		self.dateFirstAvailable	:=	null;
	endif;
	
	// KPI MODULE CCMS 1002. AKB2007SEP
	self.shipPilotReturnDT := proxyVoyage.shipPilotReturnDT;
	if (not self.shipPilotReturnDT.isValid) then
		self.shipPilotReturnDT := null;
	endif;
	self.shipAnchorDownDT := proxyVoyage.shipAnchorDownDT;
	if (not self.shipAnchorDownDT.isValid) then
		self.shipAnchorDownDT := null;
	endif;
	
	self.shipExchangeDate := proxyVoyage.shipExchangeDate;
	if (not self.shipExchangeDate.isValid) then
		self.shipExchangeDate := null;
	endif;

	self.pilotOnBoardDT := proxyVoyage.pilotOnBoardDT;
	if (not self.pilotOnBoardDT.isValid) then
		self.pilotOnBoardDT := null;
	endif;

	// 36459 save old and new values for hook code later
	oldExchangeCompleteDate := self.shipExchangeCompleteDT.date;
	oldExchangeCompleteTS := self.shipExchangeCompleteDT;
	self.shipExchangeCompleteDT := proxyVoyage.shipExchangeCompleteDT;
	if (not self.shipExchangeCompleteDT.isValid) then
		self.shipExchangeCompleteDT := null;
	endif;
	newExchangeCompleteDate := self.shipExchangeCompleteDT.date;
	
	//14 May 2021	NDL	TFS 51199
	event := self.allEventTransactionsByType.getFirstOfType(EVT_VoyExchangeCompleted).CMEVT_VoyageEvent;
	if event = null and self.shipExchangeCompleteDT &lt;&gt; null then
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		event := app.createEvent( EVT_VoyExchangeCompleted, self.shipExchangeCompleteDT, self.myTerminal, passport.userCode, false, false, 0 ).CMEVT_VoyageEvent;
		event.setMyVoyage(self);
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_VoyExchangeCompleted;
		cmifEventCtrl.dateTime := self.shipExchangeCompleteDT;
		cmifEventCtrl.myTerminal := self.myTerminal;
		cmifEventCtrl.userCode := passport.userCode;
		cmifEventCtrl.myVoyage := self;
		
		event := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		
	elseif event &lt;&gt; null and oldExchangeCompleteTS &lt;&gt; self.shipExchangeCompleteDT then
		if self.shipExchangeCompleteDT &lt;&gt; null then
			event.updateDateTimeUser( self.shipExchangeCompleteDT, passport.userCode );
		endif;
	endif;
	
	/* PAR 33644 removed, always create the SBS
	//JC PAR 8727 - might've deleted all bays and set nw, np
	if self.isNonPlannedVoyage or self.isNonWorkedVoyage then
	*/
		if self.myShipBlockStack = null then
			//better create one - can't do much with this voyage otherwise
			self.createShipBlockController(passport);
		endif;
	// endif;
	
	//09 Sep 2011 NDL Par 28173
	if self.myNotNotifiedStack = null then
		self.createNotNotifiedController(passport);
	endif;
	
	self.setNonPlannedEffectiveDT(proxyVoyage.nonPlannedEffectiveDT);
	self.totalTimeInPort	:=	proxyVoyage.totalTimeInPort;
	self.nonChargeTime		:=	proxyVoyage.nonChargeTime;
	self.stopChargingAt		:=	proxyVoyage.stopChargingAt;
	self.loadRate			:=	proxyVoyage.loadRate;
	self.dischargeRate		:=	proxyVoyage.dischargeRate;
	self.status 			:= proxyVoyage.status;
	
	/* TFS 39932 moved all this to bottom as changes made in voyStatus.processStatus uses the voyage data that has not yet been updated by the PXY
						so the changes in voyStatus.processStatus were being over written by the code after this
	//self.createEvent();								// TFS 37427
	voyStatus := self.getVoyageStatusObject;			// TFS 37427
	if voyStatus &lt;&gt; null and statusChanged then						// TFS 37540
		voyStatus.processStatus(self.status, self);		// TFS 37427
	endif;												// TFS 37427
	*/
	
	if proxyVoyage.myVoyageProcess &lt;&gt; null then		// 16.06.2022 navsrk20 52514
		self.myVoyageProcess 		  := proxyVoyage.myVoyageProcess;			// TFS 37540	
	else											// 16.06.2022 navsrk20 52514
		self.myVoyageProcess := passport.myTerminal.getDefaultVoyageProcess();	// 16.06.2022 navsrk20 52514
	endif;
	self.starboardBerthed 		  := proxyVoyage.starboardBerthed;
	self.myDefaultLineGroupDebtor := proxyVoyage.myDefaultLineGroupDebtor;
	self.myMMReceival 			  := proxyVoyage.myMMReceival;
	self.myMMRelease 			  := proxyVoyage.myMMRelease;
	self.myVoyagePlanningCode 	  := proxyVoyage.myVoyagePlanningCode;
	self.myOperator 			  := proxyVoyage.myOperator;
	self.myTrade 				  := proxyVoyage.myTrade;
	self.myCusresAltVoyage 		  := proxyVoyage.myCusresAltVoyage;
	self.myShippingLine 		  := proxyVoyage.myShippingLine;
	self.setMyTerminal(proxyVoyage.myTerminal);
	self.vesselType 			  := proxyVoyage.vesselType;
	self.lloydsNumber 			  := proxyVoyage.lloydsNumber;
	self.craneClearance 		  := proxyVoyage.craneClearance;
	self.remarks				  := proxyVoyage.remarks;
	
	if self.vesselCode &lt;&gt; proxyVoyage.vesselCode then		// PAR #29274
		self.vesselCode	:= proxyVoyage.vesselCode;
		self.myVessel 	:= self.getMyVesselFromCollection(); // PAR 30558
	endif;
	
	self.vesselName 	:= proxyVoyage.vesselName;
	
	//epr CCMS 1116 16/6/2011
	self.yearOfBuild		:= proxyVoyage.yearOfBuild;
	self.airDraft			:= proxyVoyage.airDraft;
	self.maxVesselBeam		:= proxyVoyage.maxVesselBeam;
	self.loaWithRampsDown	:= proxyVoyage.loaWithRampsDown;
	self.draftBow			:= proxyVoyage.draftBow;
	self.draftMid			:= proxyVoyage.draftMid;
	self.draftStern			:= proxyVoyage.draftStern;
	self.buildingLine		:= proxyVoyage.buildingLine;
	
	//epr par 21806 1/12/09
	foreach stateData in proxyVoyage.allStateData discreteLock do
		global.setExtraData(self.allStateData,self,stateData.key,stateData.getValue);
	endforeach;
	//Update HMS Voyage data
	self.setForUpdateHMSVoyageData(proxyVoyage);

	// General Cargo Structure
	self.setForUpdateGerneralCargo(proxyVoyage);

	// Log Structure
	self.setForUpdateLogVoyageStructure(proxyVoyage);

	// Cellular Structure
	self.setForUpdateCellularStructure(proxyVoyage,createShipPlanningStructure);

	//epr ccms 116 1/5/2011
	self.setForUpdateROROStructure(proxyVoyage);
	
	
	self.setForUpdateStructElements(proxyVoyage); //cnwrd1 par 31874
	//new for ccms 1058 
	//epr par 20673 extracted to method for reuse
	self.setForUpdatePortsOfCall(proxyVoyage.allPortRotations);
	
	self.allOperators.clear;
	proxyVoyage.allOperators.copy(self.allOperators);
	if self.myOperator &lt;&gt; null then
		if (not self.allOperators.includesKey(self.myOperator.code)) then
			self.allOperators.add(self.myOperator);
		endif;
	endif;
	
	self.setAllocatedEvents(proxyVoyage.allAllocatedEvents);	//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	
	
	self.overrideDefaults := proxyVoyage.overrideDefaults;		// 27/05/2009 cnwar2 CCMS1040/#19796
	
	// 12/06/2009 cnwar2 CCMS1040/#19796
	if proxyVoyage.allReceivalCutoffs.size &lt;&gt; self.allReceivalCutoffs.size then
		cutoffsChanged := true;
	endif;
	foreach pxyRecCutoff in proxyVoyage.allReceivalCutoffs discreteLock do
		realRecCutoff := self.allReceivalCutoffs[pxyRecCutoff.code, pxyRecCutoff.myOperator];
		
		if realRecCutoff = null
		or realRecCutoff.cutoffDateTime &lt;&gt; pxyRecCutoff.cutoffDateTime
		or realRecCutoff.earliestDateTime &lt;&gt; pxyRecCutoff.earliestDateTime 
		or realRecCutoff.cutoffDateTimePN &lt;&gt; pxyRecCutoff.cutoffDateTimePN		//04/03/2025	navkc1 JIRA Story MTN-34227
		or realRecCutoff.earliestDateTimePN &lt;&gt; pxyRecCutoff.earliestDateTimePN 	//04/03/2025	navkc1 JIRA Story MTN-34227
		 // ### JIRA 34234 24MAR2025 NAVAB1
		or realRecCutoff.hoursEarly &lt;&gt; pxyRecCutoff.hoursEarly 
		or realRecCutoff.hoursEarlyPN &lt;&gt; pxyRecCutoff.hoursEarlyPN 
		then
			cutoffsChanged := true;
			break;
		endif;
	endforeach;
		
	if cutoffsChanged then
		self.allReceivalCutoffs.purge;
		foreach pxyRecCutoff in proxyVoyage.allReceivalCutoffs discreteLock do
		
			create realRecCutoff persistent;
			realRecCutoff.setForCreateVoyage(self, pxyRecCutoff);
			
			recCutoffDef := self.myTerminal.allReceivalCutoffDefs[realRecCutoff.code];
			realRecCutoff.setRecCutoffDef(recCutoffDef);
			
		endforeach;
		
		self.causeEvent(self.myTerminal.getTerminalEvent(EVENT_STOP_CARGO_RECEIVAL), false, self); // PAR 35996
	endif;

	self.allowOutOfOrderJobs 	:= proxyVoyage.allowOutOfOrderJobs; //cnwrd1 par 30626 ccms 2209 23.10.12	
	self.estimatedArrivalDT		:= proxyVoyage.estimatedArrivalDT;			// PAR #35826
	self.estimatedDepartureDT	:= proxyVoyage.estimatedDepartureDT;		// PAR #35826	
	self.isBarge				:= proxyVoyage.isBarge; //jlgka1 TFS 37102
	
	// 36459 run ship exchange hook code on change
	if oldExchangeCompleteDate &lt;&gt; newExchangeCompleteDate then
		app.myHookAgent.runHookLinkPublic(HookType_ShipExchangeCompleted, self.myTerminal, self, oldExchangeCompleteDate);
	endif;
		
	// TFS 48477 - making sure the hook code is link to the chosen terminal
	if app.myRoot.allHookLinks[HookType_VoyageBusUnit, self.myTerminal] = null then 
		self.myDischargeCompany := proxyVoyage.myDischargeCompany;
	endif;
	if self.myDischargeCompany = null then
		// TFS 37562
		hookBank := app.myRoot.getVoyageBusUnit( self.myTerminal, self ).CM_Bank;
		if self.myDischargeCompany &lt;&gt; hookBank then
			self.myDischargeCompany := hookBank;
		else		
			self.myDischargeCompany := proxyVoyage.myDischargeCompany;
		endif;
	endif;
	
	useWhatsInDB := app.myCurrentUserCan(self.myTerminal, PmShpGLDateVoyageMaint); // TFS 4272
	if useWhatsInDB then // TFS 4272
		self.setGeneralLandingDate( proxyVoyage.generalLandingDate ); // TFS 4272
	else // TFS 4272
	
		 // 14 Mar 2016	NDL	TFS 1407
		glDate := proxyVoyage.getGeneralLandingDate(useWhatsInDB);	// Initially, only want the value we actually entered.
		if glDate = null and not useWhatsInDB then // TFS 4272
			if self.arrivedDT.date.isValid and self.departedDT.date.isValid then
				//Ok so nothing has been entered AND we have the dates we need, calaculate and populate the date.
				glDate := proxyVoyage.getGeneralLandingDate(false);
			endif;
		endif;
		self.setGeneralLandingDate( glDate );
	endif;
	
	// TFS 39932 moved all this to bottom as changes made in this call  uses the voyage data that has not yet been updated by the PXY
	//						so the changes in this call were being over written
	//self.createEvent();								// TFS 37427
	voyStatus := self.getVoyageStatusObject;			// TFS 37427
	if voyStatus &lt;&gt; null and statusChanged then						// TFS 37540
		voyStatus.processStatus(self.status, self);		// TFS 37427
	endif;												// TFS 37427
	
	self.ignoreCutoffs	:= proxyVoyage.ignoreCutoffs;	//31.Aug.2023 navsp1 TFS 57809
	
	self.shipCutoffsForPrenotes := proxyVoyage.shipCutoffsForPrenotes; //04/03/2025	navkc1 JIRA Story MTN-34227
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <access>protected</access>
        <Parameter name="proxyVoyage" type="CM_Voyage"/>
        <Parameter name="createShipPlanningStructure" type="Boolean"/>
        <Parameter name="passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGerneralCargo" id="c076cb29-96cc-4988-b952-b52ed3c82204">
        <updating/>
        <source>setForUpdateGerneralCargo(_proxyVoyage : CM_Voyage) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Apr 2009	cnwer1	Initial creation
13 Mar 2013	PJS		PAR #31232

*/

vars
	theGCVoyage,
	realGCVoyage : CM_GeneralCargoVoyageStructure;
begin
	// General Cargo Structure
	theGCVoyage := _proxyVoyage.myGeneralCargoVoyage;
	if theGCVoyage &lt;&gt; null then
		realGCVoyage := theGCVoyage.pxyGetRealObject();
		
		if realGCVoyage &lt;&gt; null then
			realGCVoyage.setForUpdate(theGCVoyage, app.myPassport);
		elseif theGCVoyage.isTransient then
			create self.myGeneralCargoVoyage persistent;
			self.myGeneralCargoVoyage.setDefaultLocationsFrom( theGCVoyage, false );	//10 July 2013	NDL	Par 31965
			self.myGeneralCargoVoyage.setForCreate(theGCVoyage, app.myPassport);
		endif;
		
	// 31232
	else
		if self.myGeneralCargoVoyage &lt;&gt; null then
			delete self.myGeneralCargoVoyage;
		endif;
			
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateHMSVoyageData" id="fe4fd715-431e-449e-89d4-fbba71af8b7f">
        <updating/>
        <source>setForUpdateHMSVoyageData(_proxyVoyage : CM_Voyage) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2009	cnwer1	Initial creation

*/

vars

begin
	//create HMS voyage
	if _proxyVoyage.myHMSVoyageData &lt;&gt; null then
		if self.myHMSVoyageData = null then
			create self.myHMSVoyageData persistent;
			self.myHMSVoyageData.setForCreate(_proxyVoyage.myHMSVoyageData, app.myPassport);
		else
			self.myHMSVoyageData.setForUpdate(_proxyVoyage.myHMSVoyageData, app.myPassport);
		endif;
	else
		if self.myHMSVoyageData &lt;&gt; null then
			delete self.myHMSVoyageData;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateLinkPayments2Lines" id="59291111-0b8c-4d87-a56c-4fb7d221f8fb">
        <updating/>
        <source>setForUpdateLinkPayments2Lines() updating;
/*

Purpose:	TFS 37963		
				Link the invoice lines created by Voyage Events and HMS Resource to the proforma cash payment for the same.

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgab1	Initial creation

*/

vars
	v : CM_Voyage;
	il : CM_InvoiceLine;
	i : CM_Invoice;
	p : CM_CashPayment;
	ps : CM_CashPaymentSet;
	pf : CM_ProformaDetails;
	t : CM_Terminal;
	ils : CM_InvoiceLineSet;
	lineTot : Decimal[16,6];
begin

	v := self;

	t := v.myTerminal;
	
	create ps transient;
	create ils transient;
	
	// ### Get all 'cash' invoice lines
	foreach i in v.allInvoices	discreteLock where i.debtor.isCashOnlyDebtor(t)  do
		if i.isPosted then
			continue;
		endif;
		foreach il in i.invoiceLines	discreteLock do
		
			if il.voided 
			or il.trackedItem &lt;&gt; null then		
				continue;
			endif;
		
			ils.add(il);
			
		endforeach;
	endforeach;

	// ### Link all the cash payments that exactly match an invoice line
	foreach p in v.allCashPayments discreteLock do : outerloop
		if p.myInvoiceLine &lt;&gt; null then // Already linked to an invoice line
			continue;
		endif;
		
		pf := p.myProformaDetail;
		if pf = null then
			continue;
		endif;
		
		foreach il in ils discreteLock do
		
			if pf.myInvoiceLineType = il.invoiceLineDesc 
			and pf.quantity = il.quantity 
			and pf.rate = il.getRate() then
				p.setInvoiceLine(il); // LINK Cash Payment to the Invoice Line
				ils.remove(il);
				continue outerloop;
			endif;
		endforeach;
		
		// Put the cash payments that do not exactly match into a set for later
		ps.add(p);
	endforeach;
		
	
	// left overs, possible that invoice line has multiple payments
	lineTot := 0;
	foreach p in ps discreteLock do
		if p.myInvoiceLine &lt;&gt; null then
			continue;
		endif;
		
		pf := p.myProformaDetail;
		if pf = null then
			continue;
		endif;
		
		// ## go through what is left of the invoice lines, link purely by invoice line type
		foreach il in ils discreteLock do
		
			if pf.myInvoiceLineType = il.invoiceLineDesc then
				p.setInvoiceLine(il); // LINK Cash Payment to the Invoice Line
				ps.remove(p);
				
				lineTot := lineTot + p.cashValue;
				
				if lineTot &gt;= il.lineTotal then
					lineTot := 0;
					ils.remove(il); // Fully paid
				endif;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete ps;
	delete ils;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdateLogVoyageStructure" id="753535e8-0327-413d-8823-1fea015fc1b9">
        <updating/>
        <source>setForUpdateLogVoyageStructure(_proxyVoyage : CM_Voyage) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars
	theLogStructure,
	realLogStructure		: CM_LogVoyageStructure;
begin
	// Log Structure
	theLogStructure := _proxyVoyage.myLogVoyageStructure;
	if theLogStructure &lt;&gt; null then
		realLogStructure := theLogStructure.pxyGetRealObject();
		
		if realLogStructure &lt;&gt; null then
			realLogStructure.setForUpdate(theLogStructure, app.myPassport);
		elseif theLogStructure.isTransient then
			create self.myLogVoyageStructure persistent;
			self.myLogVoyageStructure.setForCreate(theLogStructure, app.myPassport);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdatePortsOfCall" id="f419903f-0f2a-4570-b693-1e8852ce8fb3">
        <source>setForUpdatePortsOfCall( _allPortRotations : CM_PortRotationArray );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2009	cnwer1	Initial creation
4/9/17		MAP		TFS5551 don't delete/recreate ports of call unnecessarily

*/

vars
	pxyPOC,
	realPOC : CM_PortRotation;
	dict : DynaDictionary;
	iter : Iterator;
begin
	//new for ccms 1058 
//	self.allPortRotations.purge;
	self.allPorts.clear;

	create dict transient;
	dict.setMembership(CM_PortRotation);
	dict.addMemberKey(CM_PortRotation::myPort.name, false, false);
	dict.endKeys(true);
	
	self.allPortRotations.copy(dict);
	
	iter := dict.createIterator();
	while iter.next(realPOC) do
		realPOC.setMyVoyage(null);
	endwhile;

	foreach pxyPOC in _allPortRotations discreteLock do
		self.allPorts.add(pxyPOC.myPort);

		realPOC := dict[pxyPOC.myPort].CM_PortRotation;
		if realPOC = null then
			create realPOC persistent;
			realPOC.setForCreate(pxyPOC, self);
		else
			dict.remove(realPOC);
			realPOC.setMyVoyage(self);
			realPOC.setForUpdate(pxyPOC);
		endif;
	endforeach;
	
	dict.purge();

epilog
	delete dict;
	delete iter;
end;</source>
        <Parameter name="_allPortRotations" type="CM_PortRotationArray"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateROROStructure" id="4687cfef-6a6a-4aa7-a6a2-7da8bb0ea656">
