    <JadeMethod name="isInAnyLOBExcluding" id="cca87316-e698-4f8c-9b8e-ebd381d9b6b6">
        <source>isInAnyLOBExcluding( _labourWorkArea : CM_LabourWorkArea ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
22/04/2014	cnwndl1	Par 33995		Initial creation	
15/11/2018	jlgka1	41661			Fixed area issues where unallocated areas 
									are being greyed out.
============================================================================*/

vars
	labourWorkArea : CM_LabourWorkArea;
begin

	labourWorkArea := self.getMyLabourWorkArea();
	
	//jlgka1 --&gt; not found anywhere
	if labourWorkArea = null then 
		return false;
	endif;
	//jlgka1 &lt;--
	return labourWorkArea &lt;&gt; _labourWorkArea; 

end;</source>
        <Parameter name="_labourWorkArea" type="CM_LabourWorkArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
