    <JadeMethod name="deleteAllLabourRestriction" id="3ce79711-ff30-4a3a-a440-3ec44784d217">
        <updating/>
        <source>deleteAllLabourRestriction(_ta : CM_TerminalArea)updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowNum : Integer;
	str	: String;
	theTA : CM_TerminalArea;
	labourRestriction : CM_LabourRestriction;
	theLocations	: CM_LCArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	theTA := _ta;
	
	if theTA = null then
		return;
	endif;

	if theTA.allRestrictionsLabour.isEmpty then 
		app.msgBox('There are no Labour Resrtictions associated with this Terminal Area', 
						'No Labour Restrictions to Delete', MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, 'ALL ' &amp; app.getErrorString(CM_Labour_Restriction) &amp; 's',' for Teminal Area ' &amp; theTA.id), 'DELETE ALL Labour Restrictions',
						MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
										
	foreach labourRestriction in theTA.allRestrictionsLabour discreteLock do 
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteRestrictionLabour(labourRestriction, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(CM_Labour_Restriction), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;
	
	app.checkLabourRestrictionHook(theTA, theLocations); // PAR 21639 cnwgb1 28.4.2010
	
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="deleteLabourRestriction" id="24f4f6c2-3227-4b48-9357-cc9b4432d36f">
        <updating/>
        <source>deleteLabourRestriction(_labourRestriction : CM_LabourRestriction)updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str	: String;
	theLocations	: CM_LCArray;
	theTA 			: CM_TerminalArea;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	theTA	:= _labourRestriction.myTerminalArea;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(CM_Labour_Restriction), _labourRestriction.id), 'Confirm Delete',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRestrictionLabour(_labourRestriction, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(CM_Labour_Restriction), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	app.checkLabourRestrictionHook(theTA, theLocations); // PAR 21639 cnwgb1 28.4.2010
	
end;</source>
        <Parameter name="_labourRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="deselectProcessedLocation" id="29a8c139-5eff-4b40-ac8a-d045e1a23494">
        <updating/>
        <source>deselectProcessedLocation(	_ti : CM_TrackedItem; _moveMode : Integer ):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	lc : CM_LocationsController;
	yard : CM_YardController;
	tmpController : YRD_ContainerDrawingController;
	yardCell : CM_YALocationCell;
	doCheck : Boolean;
	removeYard : Boolean;

begin

	if _moveMode = PLANNING_MODE then
		lc := _ti.myPrimaryPlannedLocation;
	elseif _moveMode = QUEUE_MODE then
		lc := _ti.myPrimaryQueuedLocation;
	endif;
	
	if lc = null or not lc.isKindOf( CM_YardController ) then
		return false;
	endif;
	
	yard := lc.CM_YardController;
	
	tmpController := self.myCurrentDrawingController;
		
	if yard.allYAYardLocationCells.isEmpty then
		if tmpController.allSelectedObjects.includes(yard) then
			tmpController.allSelectedObjects.remove(yard);
		endif;
		if tmpController.allSelectedObjectsAlt.includes(yard) then
			tmpController.allSelectedObjectsAlt.remove(yard);
		endif;
		return true;
		
	else
		// locations are reprsented by cells.
		if tmpController.allSelectedObjects.includes(yard) or tmpController.allSelectedObjectsAlt.includes(yardCell) then
			doCheck := false;
			foreach yardCell in yard.allYAYardLocationCells do
				if not yardCell.isAvailForMultiMove then
					// it must have had something queued or planned to it or have existing cargo.
					if tmpController.allSelectedObjects.includes(yardCell) then
						tmpController.allSelectedObjects.remove(yardCell);
						doCheck := true;
					endif;
					if tmpController.allSelectedObjectsAlt.includes(yardCell) then
						tmpController.allSelectedObjectsAlt.remove(yardCell);
						doCheck := true;
					endif;
				endif;
			endforeach;
			if doCheck then
				// have removed one or more cells, do we still need the CM_YardController;
				removeYard := true;
				foreach yardCell in yard.allYAYardLocationCells do
					if tmpController.allSelectedObjects.includes(yardCell) then
						// still has a selected cell that is available.
						removeYard := false;
						break;
					endif;
					if tmpController.allSelectedObjectsAlt.includes(yardCell) then
						// still has a selected cell that is available.
						removeYard := false;
						break;
					endif;
				endforeach;
				if removeYard then
					if tmpController.allSelectedObjects.includes(yard) then
						tmpController.allSelectedObjects.remove(yard);
					endif;
					if tmpController.allSelectedObjectsAlt.includes(yard) then
						tmpController.allSelectedObjectsAlt.remove(yard);
					endif;
				endif;
			endif;
		endif;
		return doCheck;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySelectAreas" id="5f79ae09-dd96-44e0-9ca2-66848050267c">
        <source>displaySelectAreas(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aTerminalArea : CM_TerminalArea;
	theString : String;
begin
	
	if _theObject &lt;&gt; null 
	and global.isValidObject(_theObject) then
		aTerminalArea := _theObject.CM_TerminalArea;
		theString := aTerminalArea.id.trimBlanks &amp; " - " &amp;
		        	aTerminalArea.myType.description.trimBlanks; 
	endif;
	return theString;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="1846fb4c-bd4b-4336-aeda-f58d10a0b8c9">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     CALL BACK DO NOT DELETE
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	obj : Object;
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The grid area screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
/* WAS PAR 10555
	self.myCurrentDrawingController.allSelectorTIs.clear;
	self.useSelector := true;
	_resultCollection.copy(self.myCurrentDrawingController.allSelectorTIs);
	self.myCurrentDrawingController.drawSelf(true);	
	self.mnuGridSelectorClear.visible := not self.myCurrentDrawingController.allSelectorTIs.isEmpty;

NOW PAR 10555 */
	self.mySelectorEnquiryController := self.mySelectorForm.myEnqController;
	
	self.useSelector := true;
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		ydc.mySelectorEnquiryController := self.mySelectorEnquiryController;
		ydc.allSelectorTIs.clear;
		_resultCollection.copy(ydc.allSelectorTIs);
		ydc.drawSelf(true);	
		
	endforeach;
	self.mnuGridSelectorClear.visible := not self.myCurrentDrawingController.allSelectorTIs.isEmpty;
	

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResultsSpecial" id="c5793039-6f9d-48fb-80c7-81e145d303ae">
        <updating/>
        <source>displaySelectorResultsSpecial(_resultCollection : Collection; _mode : Integer; _selector : CMUI_Selector) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2006	cnwhjg1
//
// Purpose:     added for when Yard Grid area opened after selector so no mySelector set. 
// ----------   ----------  --------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	obj : Object;
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The grid area screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.myCurrentDrawingController = null then // has no yard areas displayed 
		app.msgBox('A grid area must be selected to display the items' ,'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.mySelectorEnquiryController := _selector.myEnqController;
	
	self.useSelector := true;
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		ydc.mySelectorEnquiryController := self.mySelectorEnquiryController;
		ydc.allSelectorTIs.clear;
		_resultCollection.copy(ydc.allSelectorTIs);
		ydc.drawSelf(true);	
		
	endforeach;
	self.mnuGridSelectorClear.visible := not self.myCurrentDrawingController.allSelectorTIs.isEmpty;
	

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_selector" type="CMUI_Selector"/>
    </JadeMethod>
