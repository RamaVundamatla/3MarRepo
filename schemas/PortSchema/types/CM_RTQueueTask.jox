    <JadeMethod name="setDetails" id="18cf7be5-99c9-4b48-a66a-67d2f34d26d0">
        <updating/>
        <source>setDetails(	_sourceLocation,
			_targetLocation : CM_LocationsController;
			_status ,
			_type : Integer;
			_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwer1	Initial creation

*/

vars

begin
	self.setSourceLocation(_sourceLocation);
	self.setTargetLocation(_targetLocation);
	self.status:=_status;
	self.taskType:=_type;
	self.ti:=_ti;
epilog

end;</source>
