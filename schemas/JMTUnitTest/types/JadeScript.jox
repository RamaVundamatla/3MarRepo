    <JadeMethod name="tswTest" id="449ea7f1-e31e-4687-900d-5237efda1e95">
        <source>tswTest();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16 August 2016	cnwdap1		Initial creation PAR #
//
vars
	tswClient		: CMIF_TSWHelper;
	xml				: JadeXMLDocument;
	result			: String;
	element			: JadeXMLElement;
	
begin
	create tswClient transient;
	
	// Test with JSC submitter code
