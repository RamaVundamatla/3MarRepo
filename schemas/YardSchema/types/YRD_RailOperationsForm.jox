    <JadeMethod name="doRefreshGraphicView" id="0e6b5799-da86-495e-ba03-67204494da89">
        <updating/>
        <source>doRefreshGraphicView() updating;

/*

Purpose:

Parameters:

Return Value:


Date        Who         Reason
11 Jun 2009     consw1  Initial creation
 07/06/24		jlier1 		TFS 64530 - performance improvements
*/

vars

begin
	if not self.xmlShowGraphic then
		return;
	endif;

    self.mousePointer := Window.MousePointer_HourGlass;



    self.removeDynamicGridAreaFrames;
    self.mySDF.clearAll();

    if self.myCurrentTrain &lt;&gt; null then
        //self.shtTransportView.caption := "Train - " &amp; self.myCurrentTrain.getName();//- cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.caption := app.getErrorString1(Train_Name, self.myCurrentTrain.getName());//+ cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.userObject := self.myCurrentTrain;
        self.showTrain(self.myCurrentTrain);
    elseif self.myCurrentRailLine &lt;&gt; null then
        //self.shtTransportView.caption := "Rail Line - " &amp; self.myCurrentRailLine.getIdString(); //- cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.caption := app.getErrorString1(Rail_line_id, self.myCurrentRailLine.getIdString());//+ cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.userObject := self.myCurrentRailLine;
        self.showRakeRailLine(self.myCurrentRailLine);
    elseif self.myCurrentJSIORake &lt;&gt; null then
        //self.shtTransportView.caption := "Rake Area - " &amp; self.myCurrentRailArea.id;//- cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.caption := app.getErrorString1(Rake_area_id, self.myCurrentRailArea.id);//+ cnwmd1, CCMS 1067, Par 19710
        self.shtTransportView.userObject := self.myCurrentRailArea;
        self.showRakeRailArea(self.myCurrentRailArea, null);
    endif;

    self.mySDF.drawSelf();

epilog
    self.mousePointer := Window.MousePointer_Default;
end;
</source>
    </JadeMethod>
