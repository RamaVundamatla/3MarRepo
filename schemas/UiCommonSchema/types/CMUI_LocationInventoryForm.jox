    <JadeMethod name="doResync" id="d6c135f8-aaab-4fdb-bf0f-9fbcfb9d815c">
        <source>doResync();
/*
Purpose:			

Date		Who		Reason
02JUN2021	NAVAB1	TFS 51219
*/


vars
	shipTrans	: CM_TITransaction;
	tiTrans		: CM_TITransaction;
	ti		: CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	completedDate	: TimeStamp;
	theReturn : Integer;
	table : Table;
	anObject : Object;
	invoice	: CM_Invoice;
	event : CMEVT_LocationActivity;
	bank : CM_Bank;
begin
	app.mousePointer := MousePointer_HourGlass; 
  	

	create controller transient;

	table := self.tblLocActivity;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CMEVT_LocationActivity) then
			event := anObject.CMEVT_LocationActivity;
			controller.allTransactions.add(event);
		endif;
	endif;	
	
	
	if controller.allTransactions.size &gt; 0 then
		while true do
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Inventory Event Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete controller;

	app.mousePointer := MousePointer_Default;  
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="4df3fb53-f2b5-48d6-9a3a-589ae7ccb219">
        <updating/>
        <source>doSystemNotification(_eventType: Integer; _object:Object; _eventTag: Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	invalidObject : Boolean;
	locActivity : CMEVT_LocationActivity;
	edition : Integer;
	rowIndex : Integer;
	
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	rowString : String;

begin

	on Exception do app.handleDeletedObject (exception, _object, invalidObject);
	
	if _object &lt;&gt; null and _object.isKindOf( CMEVT_LocationActivity ) and _eventType = Object_Update_Event then
		edition := _object.edition;
		if invalidObject then
			return;
		endif;
		locActivity := _object.CMEVT_LocationActivity;
	else
		return;
	endif;
	
	if locActivity &lt;&gt; null then 
		if self.allLocationActivitySet.includes( locActivity ) then
			self.tblLocActivity.findObjectInRow( locActivity, rowIndex );
			if rowIndex &gt; 2 then
			
				// ### TFS 51515 13JUL2021 NAVAB1
				ta := locActivity.mySourceTA.CM_TerminalArea;
				lc := locActivity.mySourceLocation;
				if ta = null then
					ta := locActivity.myTargetTA.CM_TerminalArea;
					lc := locActivity.myTargetLocation;
				endif;
				
				rowString := locActivity.inventoryRowData( ta, lc, self.filterWeightMeasType ); // ### TFS 51515 13JUL2021 NAVAB1
				self.tblLocActivity.setCellText( rowIndex, 1, rowString );
				
				/* // ### TFS 51515 13JUL2021 NAVAB1
				if locActivity.getHasBeenEdited then
					self.tblLocActivity.accessRow( rowIndex ).backColor := LightYellow;
					self.tblLocActivity.accessCell( rowIndex, 1 ).foreColor := Red;
				endif;
				if locActivity.isLocationBalance and locActivity.needsRecalculation then
					self.tblLocActivity.accessCell( rowIndex, 10 ).foreColor := Red;
				endif;	
				*/
				
				self.tblLocActivity.accessRow(rowIndex).backColor := locActivity.getDisplayColour( null );
		
				if locActivity.isLocationBalance
				and locActivity.needsRecalculation then  // ### TFS 51515 13JUL2021 NAVAB1
					self.tblLocActivity.accessRow(rowIndex).foreColor := Red;// ### TFS 51515 13JUL2021 NAVAB1
				endif;

			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="b0907a9f-721b-4c86-a83c-56cfab42a68d">
        <source>enableButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	obj : Object;
	locActivity : CMEVT_LocationActivity;
	edition : Integer;
	invalid : Boolean;
	rowIndex : Integer;
	ta : CM_TerminalArea;

begin

	//print
	self.btnPrint.enabled := self.tblLocActivity.rows &gt; self.tblLocActivity.fixedRows; 
	
	//extract
	self.btnCSV.enabled := self.tblLocActivity.rows &gt; self.tblLocActivity.fixedRows;
	
	//recalc
	if self.cmbTerminalArea.listIndex &gt; 0 then
		ta := self.cmbTerminalArea.itemObject[  self.cmbTerminalArea.listIndex ].CM_TerminalArea;
	endif;
	self.btnReCalc.enabled := ta &lt;&gt; null and app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	
	//refresh
	self.btnRefresh.enabled := ta &lt;&gt; null;
	
	//edit
	self.btnEdit.enabled := false;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );

	rowIndex := self.tblLocActivity.row;
	if rowIndex &lt;= self.tblLocActivity.rows then
		if not self.tblLocActivity.accessRow( rowIndex ).selected then
			return;
		endif;
		obj := self.tblLocActivity.accessRow( rowIndex ).itemObject;
		if obj &lt;&gt; null then
			edition := obj.edition;
			if invalid then
				return;
			endif;
			locActivity := obj.CMEVT_LocationActivity;
			if not locActivity.isAbleToBeEdited then
				return;
			endif;
			self.btnEdit.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuAudits_click" id="d202ee9a-05ab-4b52-bbf4-0f107cea8c16">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navab1	Initial creation

*/

vars

	locAct : CMEVT_LocationActivity;
	allAuditObjects : CM_AuditObjectDictByTimestamp;
	stateData : Any;
	form : CM_AuditViewForm;

begin

	locAct := menuItem.userObject.CMEVT_LocationActivity;
	if locAct = null then
		return;
	endif;
	
	//when new audits is in production this needs to use the new audit stuff.
	process.isNDLAudits;
	stateData := locAct.getExtraData("allAuditObjects");
	if stateData &lt;&gt; null then
		allAuditObjects := stateData.CM_AuditObjectDictByTimestamp;
	else
		return;
	endif;
	
	if not allAuditObjects.isEmpty then
		form := app.loadForm(CM_AuditViewForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_AuditViewForm;
	endif;
	form.show;
	form.displaySelectorResults( allAuditObjects, 0);

end;</source>
