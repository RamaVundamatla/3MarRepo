    <JadeMethod name="getDeliveryRequestForTI" id="aea4bea7-99b8-43a4-ae6d-e3e8d615383f">
        <source>getDeliveryRequestForTI(_ti : CM_TrackedItem) : CM_DeliveryRequest;
/*

Date		Who		Reason
20 June 2014	cnwer1	Initial creation PAR 34406

*/

vars
	request : CM_Request;
begin
	foreach request in self.allDeliveryRequests discreteLock do
		if request.isKindOf(CM_DeliveryRequest) then
			if request.CM_DeliveryRequest.allTrackedItemsAllocated.includes(_ti) then
				return request.CM_DeliveryRequest;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
