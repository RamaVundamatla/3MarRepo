<Class name="CM_UtilityAgent" id="8f763479-d69f-43d5-bd4a-1a6c87aac73a">
    <superclass name="CM_TransactionAgent"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>These classes bracket untransactioned calls to the database.
This means that these methods do NOT begin or END transaction themselves
and also do NOT do any special validation as the Control methods should</text>
    <DbClassMap file="cmtrans"/>
