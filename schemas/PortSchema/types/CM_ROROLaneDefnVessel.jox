    <JadeMethod name="cloneMySelf" id="5c1e1788-7e32-4dd2-89d7-4b38240ea802">
        <source>cloneMySelf(_newLayer : CM_DeckLayerLayout; _copy : Boolean; _nextOrd : Boolean) : CM_ROROLaneDefn; // PAR 27528 
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : CM_ROROLaneDefn;
begin
	newMe := inheritMethod(_newLayer, _copy, _nextOrd);

	if newMe.isKindOf(CM_ROROLaneDefnVessel) then
		newMe.CM_ROROLaneDefnVessel.myROROStructure := _newLayer.myDeckLayout.myDeck.CM_DeckVessel.myROROStructure;
	elseif newMe.isKindOf(CM_ROROLaneDefnVoyage) then
		newMe.CM_ROROLaneDefnVoyage.setMyVoyageStructure( _newLayer.myDeckLayout.myDeck.CM_DeckVoyage.myVoyageStructure);
		newMe.CM_ROROLaneDefnVoyage.createLaneController();
	endif;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_nextOrd" type="Boolean"/>
        <ReturnType type="CM_ROROLaneDefn"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7f4bfbf3-c884-4b5d-9006-a39ad43a4845">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			
Date			Who		Reason
21 April 2011	cnwab1	Initial creation
27/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyMe : SelfType;
	pxyVess : CM_ROROVesselStructure;
	completedOK	: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyVess := self.myROROStructure.pxyGetProxyObject();
	
	pxyMe.myROROStructure := pxyVess;
	
	completedOK := true;			// 27/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 27/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0ee34cf9-3c34-4a82-818d-1c4d5e775a26">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
19 April 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_proxyDeckItem, _passport);

	
	
	self.myROROStructure := _proxyDeckItem.myROROStructure;
	
	

epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="d469bc5e-1be1-4cba-b0b5-e42f273b6307">
        <updating/>
        <source>setForCreateImport(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_proxyDeckItem, _passport);
	self.myROROStructure:=self.myDeckLayerLayout.myDeckLayout.myDeck.CM_DeckVessel.getROROStructure;
	
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyROROStructure" id="361568f8-2e10-4301-be24-9ba2a2f6d11e">
        <updating/>
        <source>setMyROROStructure(_value : CM_ROROVesselStructure) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.myROROStructure:=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_ROROVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="aa4ba9d7-26a4-4ab8-8c1e-17dd65c87bb7">
        <updating/>
        <source>setProxy(_structure : CM_ROROVesselStructure; 
			_code, _desc, _remarks : String;
			_deckItemLayout :  CM_DeckItemLayout; 
			_deck : CM_Deck; 
			_width : Decimal;
			_len : Decimal;
			_gap : Decimal;
			_ordinal : Integer;
			_deckLayerLayout : CM_DeckLayerLayout) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars

begin
	
	inheritMethod(_structure, 
					_code, _desc, _remarks,
					_deckItemLayout, 
					_deck,
					_width,
					_len,
					_gap,
					_ordinal,
					_deckLayerLayout);
	self.myROROStructure := _structure;
epilog

end;</source>
        <Parameter name="_structure" type="CM_ROROVesselStructure"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_len" type="Decimal"/>
        <Parameter name="_gap" type="Decimal"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateDefaults" id="21926c64-bd9d-402a-a335-a9ee3a994067">
        <updating/>
        <source>setProxyForCreateDefaults( _deckItemLayout :  CM_DeckItemLayout; _gapInMetre : Decimal) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
	
begin
					
	inheritMethod(	_deckItemLayout , _gapInMetre	);		
	self.myROROStructure := self.myDeck.CM_DeckVessel.myROROStructure;
epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_gapInMetre" type="Decimal"/>
    </JadeMethod>
</Class>
