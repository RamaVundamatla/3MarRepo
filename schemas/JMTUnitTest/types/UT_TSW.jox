		self.deleteEDIAction(CUSTOMS_ACTION_NAME_3, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction3, "realCustomsAction3");
	endif;
	
	realCustomsAction3 := null;
	
	//Delete Customs Action 6
	realCustomsAction6 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_6];
	if realCustomsAction6 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_6, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction6, "realCustomsAction6");
	endif;
	
	realCustomsAction6 := null;
	
	//Create Customs Action TT
	create pxyCustomsActionTt transient;
	pxyCustomsActionTt.setProxy(CUSTOMS_ACTION_NAME_TT, CUSTOMS_ACTION_KEYWORD_TT, EDIKeyField_Clearance, EDIAction_Add, realStopsTableDtrHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_TT);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionTt, realCustomsActionTt, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionTt, "realCustomsActionTt");
	
	//Create Customs Action GC
	create pxyCustomsActionGc transient;
	pxyCustomsActionGc.setProxy(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableDtrHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionGc, realCustomsActionGc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionGc, "realCustomsActionGc");
	
	//Create Customs Action 2
	create pxyCustomsAction2 transient;
	pxyCustomsAction2.setProxy(CUSTOMS_ACTION_NAME_2, CUSTOMS_ACTION_KEYWORD_2, EDIKeySegment_MOT, EDIAction_Add, realStopsTableSeaHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction2, realCustomsAction2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction2, "realCustomsAction2");
	
	//Create Customs Action 3
	create pxyCustomsAction3 transient;
	pxyCustomsAction3.setProxy(CUSTOMS_ACTION_NAME_3, CUSTOMS_ACTION_KEYWORD_3, EDIKeySegment_MOT, EDIAction_Add, realStopsTableSeaHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction3, realCustomsAction3, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction3, "realCustomsAction3");
	
	//Create Customs Action 6
	create pxyCustomsAction6 transient;
	pxyCustomsAction6.setProxy(CUSTOMS_ACTION_NAME_6, CUSTOMS_ACTION_KEYWORD_6, EDIKeySegment_MOT, EDIAction_Add, realStopsTableSeaHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
