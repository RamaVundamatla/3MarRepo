    <JadeMethod name="roundToXXMinutes" id="b906c1f1-4f31-46aa-a0a6-4b9ca09e6939">
        <updating/>
        <source>roundToXXMinutes(roundTo: Integer):TimeStamp updating;

vars
 	validIntegers:	String;
 	timeComponent:	Time;
 	cnt:			Integer;
 	portionOfHour:	Real;
 	nearestLow:		Integer;
 	nearestHigh:	Integer;
 	nearestMins:	Integer;
 	nearestTime:	TimeStamp;

begin
	// NB: RoundTo is an integer that is the nearest number of minutes to
	// round the time to. This number must be a whole number division of 
	// 1hr. (Valid options are: 1,2,3,4,5,6,10,12,15,20,25,30,60).

	// Check to see if roundTo is one of the valid integers
	validIntegers := "1,2,3,4,5,6,10,12,15,20,25,30,60";
	if validIntegers.pos(roundTo.String,1) &lt; 1 then
		// Not a valid divisor of 1hr
		return self;	
	endif;
	timeComponent := self.time;
	portionOfHour := (timeComponent.minute) + (timeComponent.second/60);
	cnt := 0;
	while cnt*roundTo &lt;= 60 and cnt*roundTo &lt;= portionOfHour do
		nearestLow:=cnt*roundTo;
		nearestHigh:=(cnt+1)*roundTo;
		if nearestHigh&gt;60 then
			// Closest is low
			nearestMins:=nearestLow;
			break;
		else
			// Stop when nearestLow &lt; portionOfHour &lt; nearestHigh
			if nearestLow&lt;=portionOfHour and nearestHigh&gt;=portionOfHour then
				// portionOfHour is between low and high limits
				// determine which is closer.
				if portionOfHour-nearestLow&lt;=nearestHigh-portionOfHour then
					// Low is closest
					nearestMins:=nearestLow;
					break;
				else
					// High is closest
					nearestMins:=nearestHigh;
					break;
				endif;
			endif;
		endif;

		cnt:=cnt+1;
	endwhile;

	//PAR9906 &lt;--- from here
	nearestTime.setDate(self.date);
	// Adjust time that is being rounded
	if timeComponent.hour = 23 and nearestMins = 60 then
		// JADE 6 now recognises 24:00 hours as invalid
		timeComponent.setTime(0, 0, 0, 0);
		nearestTime.setTime(timeComponent);
		nearestTime.setDate(nearestTime.date+1);
	else
		timeComponent.setTime(timeComponent.hour, nearestMins, 0, 0);
		nearestTime.setTime(timeComponent);
	endif;
	
	return nearestTime;
	//PAR9906 &lt;--- to here

	// Modified by Glenys Drury 03/06/03 - Kludge no longer required after upgrade to JADE 5.2.08
	// Modified by Russell 29/11/99
	// ----------------------------------------------------------
/*
	if self.time.hour = 23 and nearestMins = 60 then
		// Time as been rounded to midnight of next day
		self.setDate((self.date+1));
	endif;
	// ----------------------------------------------------------
	return (self.date.String &amp; ", " &amp; nearestTime.String).TimeStamp;
*/

end;</source>
        <Parameter name="roundTo" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setDateTime" id="190b5a26-bff7-4e79-a310-e011ad99dc8d">
        <updating/>
        <source>setDateTime(_year, _month, _day, _hour, _minute, _second, _millisec: Integer) : TimeStamp updating;

vars
	date: Date;
	time:  Time;
begin

	date.setDate(_day, _month, _year);
	time.setTime(_hour, _minute, _second, _millisec);
	self.setDate(date);
	self.setTime(time);
	
	return self;
epilog

end;</source>
        <Parameter name="_year" type="Integer"/>
        <Parameter name="_month" type="Integer"/>
        <Parameter name="_day" type="Integer"/>
        <Parameter name="_hour" type="Integer"/>
        <Parameter name="_minute" type="Integer"/>
