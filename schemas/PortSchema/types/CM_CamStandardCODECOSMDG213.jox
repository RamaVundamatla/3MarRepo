    <JadeMethod name="checkEditTransactionForUnpack" id="13b64fe0-03af-419f-8470-02115c7fd947">
        <source>checkEditTransactionForUnpack(_transaction: CM_TITransaction; _fieldName : String) : String  protected;
		
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/


vars
	field : String;
	oldValue : String;
	newValue : String;
	fieldValue : String;
	i : Integer;
	theTI : CM_TrackedItem;
begin
	if _transaction.class.findProperty(_fieldName) &lt;&gt; null then
		fieldValue := _transaction.getPropertyValue(_fieldName).String;
	endif;
	theTI := _transaction.CM_Edit.myTrackedItem;
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		//see if it includes a voyage change
		if field = _fieldName then
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue &lt;&gt; null then
				fieldValue := oldValue;
				break;
			endif;
		endif;
	endforeach;
	return fieldValue;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_fieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
