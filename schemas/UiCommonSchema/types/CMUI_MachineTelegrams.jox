    <JadeMethod name="setupForm" id="e2eda5c4-3bee-4452-988f-fac8ce921274">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	//self.myMachine:="2296.272".asOid.CM_Machine;
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	
	self.caption:=self.myMachine.id &amp; " twistlock telegrams";
	
	self.beginClassNotification(CM_RTGTelegram, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_RTGTelegram, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_RTGTelegram, false, Object_Update_Event, Response_Continuous, 0);
	

end;</source>
