        <source>setForPre(_timeStamp : TimeStamp; _request : BGP_Request) updating;

// cnwdvb1 29 October 2002 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	if not app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' _request='&amp;_request.String&amp;' myCurrentRequest='&amp;self.myCurrentRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.myCurrentRequest := _request;
		self.myCurrentRequest.setStartTime(_timeStamp);
		app.isDoWindowEventInterrupted := false;
		self.abortProcessing := false;
		self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
	endif;
end;</source>
