    <JadeMethod name="getCurrentMachine" id="e1798bc6-d9aa-489a-8993-272239f127e1">
        <source>getCurrentMachine(pMachine : CM_Machine output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	selected	: Boolean;
	
begin

	if tblMachines.row &gt; 0 then
		pMachine := self.tblMachines.accessRow(tblMachines.row).itemObject.CM_Machine;
		selected := self.tblMachines.accessCell(self.tblMachines.row, 1).selected;
	endif;

	if pMachine = null or not selected then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="pMachine" type="CM_Machine" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getData" id="1a1a0b90-da73-43a9-9698-3ebe73943d98">
        <updating/>
        <source>getData(pAny: Any input; pType : Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		called from CMUI_GetData
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController : CM_LocationsController;
	idx 		: Integer;
begin
	self.mousePointer := MousePointer_Default;
	self.lstQueues.mousePointer := MousePointer_Default;
	
	// ##########
	// Find Container
	if pType = self.GetData_FindContainer then
		self.getDataFindContainer(pAny.String);
	// ################
	elseif pType = self.GetData_TestTi then
		self.getDataTestTi(pAny.CM_TrackedItem);
	endif;

end;</source>
        <Parameter name="pAny" type="Any" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataFindContainer" id="f8cf4f9b-2e5d-4625-82a5-2f91ab911d77">
        <updating/>
        <source>getDataFindContainer(pText: String input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	01/06/2018	JLGNS1	Bug 38922: RTQ form not working correctly
// ---------------------------------------------------------------------------

vars
	idx 	: Integer;
	lText, lTextIn : String;
	lController : CM_LocationsController;
	rtTask			: CM_RTQueueTask;
	foundCargo 	: Boolean;
begin

	foundCargo:=false;
	if pText &lt;&gt; null then
		lTextIn := pText.toUpper;
		foreach idx in 2 to self.tblQEntries.rows do
			rtTask:=self.tblQEntries.accessRow(idx).itemObject.CM_RTQueueTask;
			if rtTask &lt;&gt; null then
				lText:=rtTask.getTaskId;
			else																			//Bug 38922
				continue;																	//Bug 38922
			endif;																			//Bug 38922
			if lText = lTextIn 	or lText.pos(lTextIn,1) &gt; 0 then							//Bug 38922
		//	if lText = lTextIn.toUpper														//Bug 38922
		//	or lText[1:pText.length] = lTextIn then											//Bug 38922
		//	or lText.pos(pText,1) &gt; 0 then	//08 Oct 2014	NDL	Test '01-160' minor fault	//Bug 38922
				//epr 18/3/10 par 20518
				if not foundCargo then
					self.tblQEntries.clearAllSelected();
					foundCargo:=true;
				endif;
			
				self.tblQEntries.selectRow(idx,false);
				
		endif;
		endforeach;
	endif;	
	
	if foundCargo then											//Bug 38922
		if self.tblQEntries.allSelectedObjects.size = 1 then	//Bug 38922
			self.doQueueTblRowColChange(self.tblQEntries);		//Bug 38922
		else													//Bug 38922
			self.myCurrentEntry := null;						//Bug 38922
			self.myCurrentTask  := null;						//Bug 38922
		endif;													//Bug 38922
	endif;														//Bug 38922
		

end;</source>
        <Parameter name="pText" type="String" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataTestTi" id="3d450151-77b4-45f5-8edb-57474d4dc65e">
        <updating/>
        <source>getDataTestTi(_ti : CM_TrackedItem) protected, updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars

	machine : CM_Machine;

begin

	machine := self.myTaskWhenSubFormOpened.machine;
	if machine = null then
		return;
	endif;	
	
	app.myTrxUA.trxUpdateMachineAllocateTi(machine, _ti, app.myPassport);
	if app.myPassport.trxCompletedOK then
		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();
		self.loadQueues(true);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="26cf23ae-0c6b-43bc-a9a9-22691a3a0028">
        <source>getExtraPermissions(permArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     04 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(permArray);
	
	permArray.add(PmRTPeekAtScreen);

end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQueueIndex" id="e95ce316-6fa8-440e-a982-cb187da0e9a5">
        <source>getQueueIndex(_queue : CM_RadioTelemetryQueue) : Integer;
// -------------------------------------------
// Created 03 June 2004 by cnwdvb1
// -------------------------------------------
vars


begin

	return self.allDisplayQueues.indexOf(_queue);
	

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedInListQueues" id="79a5cc9c-d4b9-442b-9e9a-995e5f0a235f">
        <source>getSelectedInListQueues(_queueEntry : CM_RTQueueEntry);
/*

Date		Who		Reason
17 September 2014	cnwer1	Initial creation PAR

*/

vars
	qIdx,
	idx : Integer;
	obj 		: Object;
	queue 		: CM_RadioTelemetryQueue;
begin
	if _queueEntry = null then
		return;
	endif;
	
	queue:=_queueEntry.myQueue;
	qIdx:= self.lstQueues.findObject(queue);
	
	idx:=qIdx;
	
	while idx &lt;= self.lstQueues.listCount do
		obj := self.lstQueues.itemObject[idx];
		if obj &lt;&gt; null and obj.isKindOf(CM_RTQueueEntry) then
			if self.lstQueues.itemSelected[idx] then
				self.allSelectedRTQEntries.addExclusive(obj.CM_RTQueueEntry);
			endif;
			if obj.CM_RTQueueEntry.myQueue &lt;&gt; queue then
				break;
			endif;
		endif;		
		idx:=idx + 1;
	endwhile;
	
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="getSelectedMachines" id="dead947e-be8a-4232-a22d-09e50d2dfdd2">
        <source>getSelectedMachines(_machs : Collection input) ;
// ---------------------------------------------------------------------------
// Created:     14 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 20474
// ---------------------------------------------------------------------------

vars
	obj : Object;
	mach : CM_Machine;
	idx : Integer;
	selected : Boolean;
begin
	if _machs = null then
		return;
	endif;

	foreach idx in 1 to self.tblMachines.rows do
		selected := self.tblMachines.accessCell(idx, 1).selected;

		if selected then
			obj := self.tblMachines.accessRow(idx).itemObject;
			if obj.isKindOf(CM_Machine) then
				mach := obj.CM_Machine;
				_machs.add(mach);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_machs" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStatusPicture" id="d4a0b947-b249-4f58-97f6-2a8bd80bd76b">
        <source>getStatusPicture(_task : CM_RTQueueTask) : Binary;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2009	cnwer1	Initial creation
21 Nov 2012	cnwdap1	PAR #30762 CCMS QNS 2233 Include TASK_SYSTEM_HELD status
*/

vars

begin
	if _task.status = TASK_ACCEPTED then
		return self.picTaskAccepted.picture;
	elseif _task.status = TASK_ALLOCATED then
		return self.picTaskAllocated.picture;
	elseif _task.status = TASK_COMPLETE then
		return self.picTaskCompleted.picture;
	elseif _task.status = TASK_ERROR then
		return self.picTaskError.picture;
	//elseif _task.status = TASK_HELD then										// PAR #30762
	elseif (_task.status = TASK_USER_HELD or _task.status = TASK_SYS_HELD) then	// PAR #30762
		return self.picTaskHeld.picture;
	elseif _task.status = TASK_OFFERED then
		return self.picTaskOffered.picture;
	elseif _task.status = TASK_UNACTIONED then
		return self.picTaskUnaction.picture;
	elseif _task.status = TASK_WORKING then
		return self.picTaskWorking.picture;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getTblMachineDisplayString" id="f573eb00-7b1c-4ee9-aff9-0e1ecad6ff9f">
        <source>getTblMachineDisplayString(	_machine : CM_Machine; 
							_selectedQueue : CM_RadioTelemetryQueue; 
							_queueDisplayStr : String output;
							_bubbleHelpStr : String output	) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 03/10/2022   navds21     TFS 50083 MTN - Machine Delay Idle Time
vars
	invalidTask, invalidPrim : Boolean;
	primaryQ : CM_RadioTelemetryQueue;
	queueString : String;
	currentTask : CM_RTQueueTask;
	isInPrimary : Boolean;
	idleMins,delayMins : Integer; //03.10.2022 navds21 TFS 50083
	idleHist,delayHist : CM_MachineHistory;	//03.10.2022 navds21 TFS 50083
	backColorInt : Integer;

begin
	on Exception do app.handleDeletedObject(exception, primaryQ, invalidPrim);
	on Exception do app.handleDeletedObject(exception, currentTask, invalidTask);
	
	primaryQ := _machine.myPrimaryQueue;
	if _machine.myPrimaryQueue &lt;&gt; null then
		queueString := '/' &amp; primaryQ.id;
	endif;
	_queueDisplayStr := _machine.id;
	_bubbleHelpStr := _queueDisplayStr &amp; '  ' &amp; _machine.machineTypeString &amp; queueString;

	currentTask := _machine.currentQueueTask;			// PAR #26919
	isInPrimary := false;
	isInPrimary := currentTask &lt;&gt; null and currentTask.queue = primaryQ;
	
	if _machine.loggedOn and _machine.user &lt;&gt; null then
		_bubbleHelpStr := _bubbleHelpStr &amp; '/' &amp; _machine.user.userName;
	endif;
	// For queues other than the master, if the selected queue is a secondary queue for the machine 
	// then the id will be prefixed with "~"
	if _selectedQueue &lt;&gt; self.myMasterQueue then
		if _machine.allQueues.includes(_selectedQueue) and _selectedQueue &lt;&gt; _machine.myPrimaryQueue then
			_queueDisplayStr := '~' &amp; _queueDisplayStr;
		endif;
	endif;
		
	if primaryQ = self.myMasterQueue then
		_queueDisplayStr := _queueDisplayStr &amp; ' (M)';
	endif;
		
	if _machine.myNextPrimaryQueue &lt;&gt; null then	
		if _machine.myPrimaryQueue &lt;&gt; null then
			_bubbleHelpStr := _bubbleHelpStr &amp; CrLf &amp; "Queued to move from " &amp; _machine.myPrimaryQueue.id &amp; " to " &amp; _machine.myNextPrimaryQueue.id;
		else
			_bubbleHelpStr := _bubbleHelpStr &amp; CrLf &amp; "Queued to move to " &amp; _machine.myNextPrimaryQueue.id;
		endif;
	
		if _selectedQueue = _machine.myNextPrimaryQueue then
			_queueDisplayStr := _queueDisplayStr &amp; ' (+Q)';
		elseif _selectedQueue = self.myMasterQueue and _machine.myPrimaryQueue &lt;&gt; self.myMasterQueue then
			_queueDisplayStr := _queueDisplayStr &amp; ' (Q)';
		else
			_queueDisplayStr := _queueDisplayStr &amp; ' (-Q)';
		endif;
	endif;
		
	if currentTask &lt;&gt; null and currentTask.queue &lt;&gt; primaryQ then
		_queueDisplayStr := _queueDisplayStr &amp; ' (S)';
	endif;
	if _machine.isIdle(idleMins, idleHist) then
		//if idleHist &lt;&gt; null then
		//	idleMins := idleMins + _machine.myRTVehicleConfig.idleTimeAllowable;
		//endif;
		_queueDisplayStr := _queueDisplayStr &amp; ' (IDLE: ' &amp; idleMins.String &amp; ')';
		elseif _machine.isSetdownDelayed(delayMins, delayHist) then //03.10.2022 navds21 TFS 50083
		_queueDisplayStr := _queueDisplayStr &amp; ' (DELAY: ' &amp; delayMins.String &amp; ')'; //03.10.2022 navds21 TFS 50083
		
	endif;
	
	if idleMins &lt;&gt; null then
		backColorInt := self.myTerminal.getConfig(IdleTimeColour).Integer;
	elseif delayMins &lt;&gt; null then										//03.10.2022 navds21 TFS 50083
		backColorInt := self.myTerminal.getConfig(DelayTimeColour).Integer; //03.10.2022 navds21 TFS 50083
	else
		backColorInt := self.tblMachines.backColor;
	endif;
	return backColorInt;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_selectedQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_queueDisplayStr" type="String" usage="output"/>
        <Parameter name="_bubbleHelpStr" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="daa90d32-71b8-4239-b9c6-e6790eb97f5e">
        <source>getWeighFormObjects( _obj: CM_Object; _objArray: ObjectArray input ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

	errMsg : String;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive( _obj );
		_obj.isWeighBridgeWeighable(_objArray,errMsg);
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="2b8a09d5-93ab-434f-9c36-eb5a4dbdb045">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2009	cnwer1	Initial creation

*/

vars

	theXML : String;
	
begin

	theXML := inheritMethod();

	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="508e53bc-70ab-464b-bd98-eb52f7d53662">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 February 2009	cnwer1	Initial creation
24 August 2020		jlgmd1	TFS 49961 PRP - Hide Sub Queue Tasks

*/

vars
	
	theXML,
	tmpStr : String;
begin
	theXML := inheritMethod();
	
		
	tmpStr := self.tblQEntries.getXMLStrForColItems();

		
		theXML := theXML &amp; 
		global.formatAsXMLPrefix(CM_DataTable.XMLTag_Table &amp;  self.tblQEntries.name) &amp;
		global.formatAsXMLPrefix(CM_DataTable.XMLTag_EntTblDef &amp; self.tblQEntries.myEntTableDef.name) &amp;			
		tmpStr &amp;
		global.formatAsXMLSuffix(CM_DataTable.XMLTag_EntTblDef &amp; self.tblQEntries.myEntTableDef.name) &amp;									
		global.formatAsXMLSuffix(CM_DataTable.XMLTag_Table &amp; self.tblQEntries.name) &amp;
		global.formatAsXML(XMLTag_HideSubTasks, self.chkHideSubQTasks.value.String);

	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleUE14022" id="2327fac4-b49b-4538-893c-5131d8f8a7a7">
        <source>handleUE14022(_exc : Exception; hadException : Boolean io ) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwer1	Initial creation 31337

*/
constants
	 InvalidItemLevel = 14022;
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	
	if _exc.errorCode = InvalidItemLevel then
		hadException:=true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="hadException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="b4164ca3-fc8b-445d-94ef-eaa055f76676">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 August 2020	jlgmd1	Initial creation TFS 49961 PRP - Hide Sub Queue Tasks

*/

vars
	hideTasks : String;
begin
	inheritMethod(_userWindow);
	
	hideTasks := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_HideSubTasks);
	// Defaults to true if not set (see openWithSavedSettings)
	if hideTasks &lt;&gt; "" then
		self.chkHideSubQTasks.value := hideTasks.Boolean;
	endif;
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblQEntries" id="f3bb2f2a-2a4b-4557-bbdb-b19f55e2a851">
        <source>initTblQEntries();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lGray		: Integer;
	user		: CM_User;
	showExtra	: Boolean;
	entDef		: EntTableDef;
begin


	lGray := tblQEntries.accessCell(1,1).backColor;
	
		
	entDef:=app.myController.getEntTableDef(ETDef_YardQueues);	
	self.tblQEntries.setForm(self);
	self.tblQEntries.fixedRows:=2;
	self.tblQEntries.setTblDataEntRowsFromDef(entDef);
	self.tblDataSetupMergeHeading();
			
	self.tblQEntries.selectMode := Table.SelectMode_Row;
	self.tblQEntries.accessMode := Table.AccessMode_Row;
	self.tblQEntries.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblQEntries.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblQEntries.disallowColumnSorter:=true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isQueueExpanded" id="20720db4-18da-47f9-a2b5-76c08e04d33d">
        <source>isQueueExpanded(_queue : CM_RadioTelemetryQueue) : Boolean protected;

vars

begin

	if CM_MasterQueue.hasInstance(_queue) then
		return true;
	endif;
	return self.allQueuesExpandedState.includes(_queue);

end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="be510eb9-9d41-4e44-b94c-c35d03f6e049">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ==========	========	==================================================
// 16/09/2016	cnwdap1		TFS 2629 - Messina ITS / RTQ notification issues
// 16/09/2020	jlgdap1		TFS 49316 MTN Machine Idle Time
// 03/10/2022   navds21     TFS 50083 MTN - Machine Delay Idle Time
begin

	self.beginClassNotification(CM_RTQueueEntry, false, self.myTerminal.getTerminalEvent(RTQueueEntry_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RTQueueEntry, false, self.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RTQueueEntry, false, self.myTerminal.getTerminalEvent(RTQueueEntry_Alert_Event), Response_Continuous, null);		// TFS 2629

	self.beginClassNotification(CM_RadioTelemetryQueue, false, self.myTerminal.getTerminalEvent(RTQueue_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RadioTelemetryQueue, false, self.myTerminal.getTerminalEvent(RTQueue_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RadioTelemetryQueue, false, self.myTerminal.getTerminalEvent(RTQueue_Create_Event), Response_Continuous, null);
	
	self.beginClassNotification(CM_Machine, false, self.myTerminal.getTerminalEvent(RTMachine_Update_Event), Response_Continuous, null);
	
	self.beginClassNotification(CM_Machine, false, self.myTerminal.getTerminalEvent(Event_MachineIdle), Response_Continuous, null);		// TFS 49316
	self.beginClassNotification(CM_Machine, false, self.myTerminal.getTerminalEvent(Event_MachineIdleStop), Response_Continuous, null);	// TFS 49316
	
	self.beginClassNotification(CM_Machine, false, self.myTerminal.getTerminalEvent(Event_MachineDelay), Response_Continuous, null);		// 03.10.2022 navds21 TFS 50083
	self.beginClassNotification(CM_Machine, false, self.myTerminal.getTerminalEvent(Event_MachineDelayStop), Response_Continuous, null);	// 03.10.2022 navds21 TFS 50083
	
	self.loadQueues(false);
	
	//Not required as handled by the above
	//self.beginClassNotification(CM_WorkListEntry, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMachineSubMenu" id="3d352ab2-cffa-40c8-8c28-8ae8cf58c95a">
        <source>loadMachineSubMenu(pQueue : CM_RadioTelemetryQueue);
// ---------------------------------------------------------------------------
// Created:     12 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subMenu	: MenuItem;
	machine	: CM_Machine;
	idx		: Integer;
	
begin

	// Clear all machine sub-menu items
	
	idx := 1;
	while true do
		subMenu := mnuQueueFindMachine.getMenuItem(idx);
		if subMenu = null then
			break;
		endif;
		delete subMenu;
		idx := idx + 1;
	endwhile;

	// Create the new menu for all machines that can access this queue

	idx := 0;
	// DVB changed 06/09/04
	foreach machine in self.myTerminal.machines discreteLock where not machine.isNotAvailableForEntry do 
//		if machine.isInQueue(pQueue) then
		if machine.hasRadioTelemetry  or (machine.machineType = MACHINETYPE_PORTAINER_CRANE and machine.myPrimaryQueue &lt;&gt; null) then
			idx := idx + 1;

			subMenu := mnuQueueFindMachine.loadSubMenu(idx);			
			subMenu.caption	:= machine.id;
		endif;
//		endif;
	endforeach;

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="loadQueueEntries" id="fe4a193d-c21d-4131-a838-5a2b18b02d59">
        <updating/>
        <source>loadQueueEntries() updating;
//
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
//
vars
	note : CM_EventList;
	startTime : Decimal[20];		// PAR #38163
	msg : String;
	count : Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp;' ';
	startTime := app.relativeMachineTime();		// PAR #38163
	foreach note in self.allEventLists do
		self.loadQueueEntry(note.object, note.userInfo);
	endforeach;
	count := allEventLists.size;
	self.allEventLists.purge;
	self.lastEntityRefreshTimeElapsed := (app.relativeMachineTime() - startTime).Integer;					// PAR #38163
	msg := class.name&amp;'::'&amp;method.name&amp;" Number of Entries in "&amp;self.lastEntityRefreshTimeElapsed.String&amp;" millisecs was "&amp;count.String;
	app.writeLog(msg, 0);
//	write msg;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadQueueEntry" id="10a71550-7e8e-4477-a231-191665cb8c52">
        <updating/>
        <source>loadQueueEntry(_theObject: Object; _userInfo: Any) updating;
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Sep 2016	cnwrs1		TFS 2629 PAR #38163 JMT going slow
// 24 Aug 2020	jlgmd1		TFS 49961 PRP - Hide Sub Queue Tasks
// 18 Sep 2020	jlgdap1		TFS 49316 MTN Machine Idle Time
// 03/10/2022   navds21     TFS 50083 MTN - Machine Delay Idle Time
// ---------------------------------------------------------------------------
vars
	myListObj : Object;
	selectedQueue : CM_RadioTelemetryQueue;
	origQueue : CM_RadioTelemetryQueue;
	queue : CM_RadioTelemetryQueue;
	invalidQueueObj : Boolean;
	invalidListObj : Boolean;
	invalidObject : Boolean;
	isExpanded : Boolean;
	had14022ex : Boolean;
	orgParent : Integer;
	me : Integer;
	state : Integer;
	previousIdx : Integer;
	lParentPos : Integer;
	lEntries : Integer;
	lLevel : Integer;
	idx : Integer;
	str : String;
	colour : Integer;				// TFS 49316
begin
//write class.name&amp;'::'&amp;method.name&amp;' ';
	on Exception do app.handleDeletedObject(exception, _theObject, invalidObject);			
	on Exception do app.handleDeletedObject(exception, myListObj, invalidListObj);
	on Exception do app.handleDeletedObject(exception, origQueue, invalidQueueObj);
	// Get list object for later reset.
	myListObj := self.lstQueues.listObject;
	// Get where this entry is going.
	queue := _theObject.CM_RTQueueEntry.myQueue;
	if invalidObject then
		return;
	endif;
	// Where is this entry in list box.
	// Find entry in listbox.
	me := self.lstQueues.findObject(_theObject);
	// If entry was found remove me.
	if me &gt; 0 then
		// Remove from the listbox.
		self.lstQueues.removeItem(me);
//write class.name&amp;'::'&amp;method.name&amp;' remove me '&amp;me.String;
		// The following section is for dragging and dropping entries.
		// User info only sent when dragging and dropping from queue window.
		if  _userInfo &lt;&gt; null then
			// Where did the drag start from?
			origQueue := _userInfo.CM_RadioTelemetryQueue;
			// Where is this queue in the list box?
			orgParent := self.lstQueues.findObject(origQueue);
			// Reset parents text.
			if orgParent &gt; 0 then
				//str := origQueue.getQueueDisplay();										// TFS 49316
				str := origQueue.getQueueDisplay(colour);									// TFS 49316
//write class.name&amp;'::'&amp;method.name&amp;' getQueueDisplay='&amp;str;
				// 26339 Apr 2011 invalid origQueue object
				if invalidQueueObj then
					return;
				endif;
				self.lstQueues.itemText[orgParent] := str;
				if colour = self.myTerminal.getConfig(IdleTimeColour).Integer then			// TFS 49316
					self.lstQueues.itemBackColor[orgParent] := colour;						// TFS 49316
				elseif colour = self.myTerminal.getConfig(DelayTimeColour).Integer then		//03.10.2022 navds21 TFS 50083
					self.lstQueues.itemBackColor[orgParent] := colour;						//03.10.2022 navds21 TFS 50083
				else																		// TFS 49316
					self.lstQueues.itemBackColor[orgParent] := self.lstQueues.backColor;	// TFS 49316
				endif;																		// TFS 49316
			endif;
			// Do we need to remove altogether or replace?
			if origQueue &lt;&gt; null and origQueue &lt;&gt; queue then
				if myListObj = _theObject or myListObj = origQueue then
					state := State_Delete;	
				else
					state := State_Edit;
				endif;
			else
				state := State_Edit;
			endif;
		else
			state := State_Edit;
		endif;
	else
		// Just an add.
		state := State_Add;
	endif;
	
	// Where is my parent queue.
	lParentPos := self.lstQueues.findObject(queue);
	if not lParentPos &gt; 0 then
		return;
	endif;

	// 01/12/2009 cnwmh5 PAR21315 - Start
	if queue = null then
		return;
	endif;
	// 01/12/2009 cnwmh5 PAR21315 - End
	
	// Where in the queue is the entry.

	lEntries := queue.allEntries.indexOf(_theObject.CM_RTQueueEntry);
	// Where do we put the new entry in the list box?
	me :=  lParentPos + lEntries;
//write class.name&amp;'::'&amp;method.name&amp;' other2 me='&amp;me.String;
	
	//epr ccms 1395 there was a problem multi select and dragging to a position in a queue this should be better because the other
	// way would find a index of an item that has also been moved
	if lEntries &lt; queue.allEntries.size and 
	   lEntries &gt; 1  then
		previousIdx := self.lstQueues.findObject(queue.allEntries[lEntries - 1]);
		if previousIdx &gt; 0 then	
			lEntries := previousIdx + 1 ;
			me := lEntries;
//write class.name&amp;'::'&amp;method.name&amp;' other3 me='&amp;me.String;
		endif;
	endif;
	
	isExpanded := self.lstQueues.itemExpanded[lParentPos];
	// What will my new level be.
	lLevel := self.lstQueues.itemLevel[lParentPos] + 1;	
	
	on Exception do self.handleUE14022(exception,had14022ex);
	// Add entry.
	idx := lstQueues.addEntry(_theObject, me, lLevel, isExpanded);
//write class.name&amp;'::'&amp;method.name&amp;' idx='&amp;idx.String;
	if had14022ex then
		//got listbox exception adding 
//				self.loadQueues(true);
//write class.name&amp;'::'&amp;method.name&amp;' doStartRefreshTimer';
		self.doStartRefreshTimer();
		return;
	endif;
	
	// Update queue display.
	//str := queue.getQueueDisplay();											// TFS 49316
	str := queue.getQueueDisplay(colour);										// TFS 49316

	self.lstQueues.itemText[lParentPos] := str;
	if colour = self.myTerminal.getConfig(IdleTimeColour).Integer then			// TFS 49316
		self.lstQueues.itemBackColor[lParentPos] := colour;						// TFS 49316
	elseif colour = self.myTerminal.getConfig(DelayTimeColour).Integer then		//03.10.2022 navds21 TFS 50083
		self.lstQueues.itemBackColor[lParentPos] := colour;						//03.10.2022 navds21 TFS 50083
	else																		// TFS 49316
		self.lstQueues.itemBackColor[lParentPos] := self.lstQueues.backColor;	// TFS 49316
	endif;																		// TFS 49316
	// If listObject is now invalid set to queue.
	if invalidListObj then
		self.lstQueues.listObject := queue;
		myListObj := queue;
	else
		// Otherwise reset.
		self.lstQueues.listObject := myListObj;
	endif;

// This is the entry if we get a match.
	if myListObj = _theObject then
		// Have found it so no matter what we want to replace it in table.
		state := State_Edit;
		// Just in case we have strange between window dragging behaviour
		// we reset the table.
		if origQueue &lt;&gt; null then
			self.tblQEntries.rows := self.tblQEntries.fixedRows;
		endif;
		// Replace entry.
//write class.name&amp;'::'&amp;method.name&amp;' 1 showRefreshTask';
		self.showRefreshTask(_theObject.CM_RTQueueEntry, state,true);
		// Show machines.
		self.showMachinesForQueue(queue, false);
	elseif myListObj.isKindOf(CM_RadioTelemetryQueue) then
		selectedQueue := myListObj.CM_RadioTelemetryQueue;
		// Just a normal update from move code so refresh appropriate entry tasks
		// in the tasks table.
		
		if origQueue = null then
			// Only add/update the tasks if:
			// 1. The Hide Sub Queue Tasks box is false and the entries queue is the same as the one we have selected, or a sub-queue
			// 2. Or; The Hide Sub Queue Tasks box is true, and the selected queue matches the entries queue
			if (self.chkHideSubQTasks.value = false and selectedQueue.includesQueue(queue)) or
				(self.chkHideSubQTasks.value = true and selectedQueue = queue) then 
//write class.name&amp;'::'&amp;method.name&amp;' 2 showRefreshTask';
				self.showRefreshTask(_theObject.CM_RTQueueEntry, state,true);
				self.showMachinesForQueue(selectedQueue, false);
			endif;
		else
			// Drag and drop. Are we interested in the change? Does the table need to 
			// change to reflect move?
			if selectedQueue.includesQueue(origQueue) or selectedQueue.includesQueue(queue) then
				// Reset table and rebuild selected queue.
				self.tblQEntries.rows := self.tblQEntries.fixedRows;
//write class.name&amp;'::'&amp;method.name&amp;' 1 showQueueDetails';
				self.showQueueDetails(selectedQueue);
				self.showMachinesForQueue(selectedQueue, false);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="loadQueueObject" id="c743beb0-5c0b-404d-a905-0b10a2d06721">
        <source>loadQueueObject(pObj : Object; pPos : Integer io; pLevel : Integer; _isExpanded : Boolean);
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 May 2009	cnwkpd1		PAR #18769 - Prevent 1308 exceptions when another
//							process updates the Queued Entries array
// ---------------------------------------------------------------------------

vars
	theQ,
	subQ			: CM_RadioTelemetryQueue;
	theEntry		: CM_RTQueueEntry;
	headerIdx,
	idx				: Integer;
	iter1,
	iter2			: Iterator;
	localQueues,
	localSub: CM_RTQueueArray;
	localEntries	: CM_RTQueueEntryArray;
	
begin
	if pObj = null then
		return;
	endif;

	headerIdx := self.lstQueues.addEntry(pObj, pPos, pLevel, _isExpanded);

	if pObj.isKindOf(CM_RTQueueEntry) then
		return;
	elseif (not pObj.isKindOf(CM_RadioTelemetryQueue)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid call using (' &amp; pObj.String &amp; ')');
		return;
	endif;
	
	theQ := pObj.CM_RadioTelemetryQueue;
	self.allDisplayQueues.add(theQ);
	
	localEntries := theQ.allEntries.cloneSelf(true);			// PAR #18769
	foreach theEntry in localEntries do
		self.lstQueues.addEntry(theEntry, idx, pLevel + 1, _isExpanded);
		self.deselectRTQueueEntry( theEntry );	//17 July 2014	NDL	Par 25646
	endforeach;
	
	localQueues := theQ.allSubQueuesByOrder.cloneSelf(true);	// PAR #18769
	foreach subQ in localQueues do
		self.loadQueueObject(subQ, idx, pLevel + 1, self.isQueueExpanded(subQ));
	endforeach;
	
	if headerIdx &gt; 0 then
		self.lstQueues.itemExpanded[headerIdx] := _isExpanded;
	endif;

	
epilog
	if pPos &lt;&gt; 0 then
		pPos := idx;
	endif;
	delete iter1;
	delete iter2;
	delete localQueues;
	delete localEntries;
	
end;</source>
        <Parameter name="pObj" type="Object"/>
        <Parameter name="pPos" type="Integer" usage="io"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="_isExpanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadQueues" id="4893080d-b26e-49bf-b81e-14fc6a3fa9bb">
        <updating/>
        <source>loadQueues(pSavePosition : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
// ---------------------------------------------------------------------------
vars
	saveObj	: Object;
	idx,
	lvl		: Integer;
	loadStateSet : Boolean;

	deletedQueue : Boolean;	//10 Jun 2011	NDL	Par 27488
	startTime : Decimal[20];		// PAR #38163
begin
	startTime := app.relativeMachineTime();		// PAR #38163
	self.allSelectedRTQEntries.clear();	//17 July 2014	NDL	Par 25646
	
	self.saveQueueExpandedState();
	if pSavePosition then
		saveObj := lstQueues.listObject;
	endif;

	lstQueues.clear;

	self.allDisplayQueues.clear();
	//-----------------
	//Ask the master queue for all its queues
	//-----------------
	if self.mySelectedQueue &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, self.mySelectedQueue, deletedQueue );		//10 Jun 2011	NDL	Par 27488
		
		self.loadQueueObject(self.mySelectedQueue, idx, 1, self.isQueueExpanded(self.mySelectedQueue));
		
		//10 Jun 2011	NDL	Par 27488
		if deletedQueue then
			self.mySelectedQueue := null;
			self.btnPin.value := false;
			self.setCaption(app.getErrorString(Radio_Telemetry_Queue));
			self.loadQueueObject(self.myMasterQueue, idx, 1, self.isQueueExpanded(self.myMasterQueue));
		endif;
		
	else
		self.loadQueueObject(self.myMasterQueue, idx, 1, self.isQueueExpanded(self.myMasterQueue));
	endif;

	if pSavePosition and saveObj &lt;&gt; self.myMasterQueue then
		idx := lstQueues.findObject(saveObj);
		if idx &gt; 0 then
			lstQueues.listIndex := idx;
			lstQueues.listObject := saveObj;
			self.showQueueThumbnail(lstQueues.listObject);
	//		lstQueues.itemExpanded[idx] := true;
			return;
		endif;
	endif;

	if lstQueues.listCount &gt; 0 then
		lstQueues.listIndex := 1;
		lstQueues.listObject := lstQueues.itemObject[1];
		self.showQueueThumbnail(lstQueues.listObject);
	endif;
	self.lastRefreshTimeElapsed := (app.relativeMachineTime() - startTime).Integer;					// PAR #38163
end;</source>
        <Parameter name="pSavePosition" type="Boolean"/>
    </JadeMethod>
