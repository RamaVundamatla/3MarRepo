    <JadeMethod name="isVoyageCancelled" id="5d346cc2-6885-4f6e-8ae8-7eb4fffb3354">
        <source>isVoyageCancelled() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwrd1	Initial creation
// cnwrd1 par 23993 25.5.2010 ++
*/

vars
	voy : CM_Voyage;
begin

	voy := self.myVoyage;
	
	if voy = null then
		return true;  // deleted!?!?
	else
		if voy.isCancelled then  //jlier1 TFS51963 5/10/21
			return true;
		else
			return false;
		endif;
	endif;
	
	return false;
epilog

end;</source>
