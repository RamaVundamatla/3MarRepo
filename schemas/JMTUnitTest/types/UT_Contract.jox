    <JadeMethod name="deleteUTInvoiceLineTypes" id="c065263b-de31-41ca-be11-6b43e23445f3">
        <source>deleteUTInvoiceLineTypes();
/*
Purpose:			

Date		Who		Reason
22 February 2023	navab1	TFS CR 55646 TASK 56413
*/
constants
	Service1 = "UT_ServiceContractVB-1";
	Service2 = "UT_ServiceContractVB-2";
	InvType = "UT_InvTypeContractVB";
	InvLineType = "UT_LineTypeContractVB";
vars

begin
	self.deleteInvoiceService(Service1,FORCED_ERASE);
	self.deleteInvoiceService(Service2,FORCED_ERASE);
	self.deleteInvoiceType(InvType);
	self.deleteInvoiceLineType(InvLineType,FORCED_ERASE);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCloneInvoiceContract" id="24ddf479-7b17-4949-a962-e8d778d07982">
        <updating/>
        <source>tCloneInvoiceContract() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2023	navkc1	Initial creation CR #55652 Task 55682: Jade - Jade - Contracts Copy Unit Tests

*/

constants
	ContID				= "UT_ForCloningID";
	ClonedContIDAll		= "UT_ClonedIDAll2";
	ClonedContIDValid	= "UT_ClonedIDValid2";
	ContDesc 			= "UT_ForCloningDesc";
vars
	pxyContract,
	realContract,
	clonedContract	: CM_InvoiceContract;
	
	realContractDetails,
	clonedContractDetails,
	realContractDetails2,
	realContractDetails3	: CM_InvoiceContractDetails;
	
	realRate,
	clonedRate	: CM_InvoiceContractRate;
	
	realRateEntry1,
	realRateEntry2,
	realRateEntry3,
	realRateEntry4,
	clonedRateEntry	: CM_InvoiceContractRateEntry;
	
	today,
	fromTime,
	toTime			: TimeStamp;
	
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor,
	debtor2			: CM_Debtor;
	operator		: CM_Operator;
	cargoType		: CM_CargoType;
	invLineType		: CM_InvoiceLineDesc;
	calculationType	: CM_CalculationType;
	service1		: CM_Service;
	
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	today := app.actualTimeServer();
	
	fromTime := today.addDays(-365);
	toTime	:= today.addDays(365);
	
	realContract := self.createContract(debtor, ContID, false, false, fromTime, toTime, true);
	
	cargoType 				:= app.myRoot.getCargoTypeFromAbbrev("CONT");
	realContractDetails		:= self.createContractDetail(realContract, operator, cargoType);
	realContractDetails2	:= self.createContractDetail(realContract, operator, cargoType);
	//realContractDetails3	:= self.createContractDetail(realContract, operator, cargoType);
	
	beginTransaction;
	realContractDetails.setMyInvoiceLineType(realContractDetails2.myInvoiceLineType);
	//realContractDetails2.setMyInvoiceLineType(realContractDetails3.myInvoiceLineType);
	
	toTime := today.addDays(-30);
	realContractDetails2.setToTS(toTime);
	
	fromTime := realContractDetails2.toTS.addDays(1);
	toTime := today.addDays(60);
	realContractDetails.setFromTS(fromTime);
	realContractDetails.setToTS(toTime);
	
	fromTime := realContractDetails.toTS.addDays(1);
	//realContractDetails3.setFromTS(fromTime);
	commitTransaction;
	
	invLineType := realContractDetails.myInvoiceLineType;
	calculationType := invLineType.myCalculationType;
	
	service1 := invLineType.services.first();
	
	realRate := self.createContractRate(realContractDetails, service1);
	
	fromTime := realContractDetails.fromTS;
	toTime := realContractDetails.fromTS.addDays(10);
	/*realRateEntry1 := self.createContractRateEntry(realRate, 10.00, 1, 100, fromTime, toTime);
	
	fromTime := toTime.addDays(1);
	toTime := fromTime.addDays(10);
	realRateEntry2 := self.createContractRateEntry(realRate, 15.00, 101, 200, fromTime, toTime);
	
	fromTime := toTime.addDays(1);
	toTime := fromTime.addDays(10);*/
	realRateEntry3 := self.createContractRateEntry(realRate, 20.00, 201, 300, fromTime, toTime);
	
	fromTime := toTime.addDays(1);
	toTime := realContractDetails.toTS;
	realRateEntry4 := self.createContractRateEntry(realRate, 25.00, 301, 400, fromTime, toTime);
	
	debtor2 := self.getDebtor("UT_Debtor1");
	
	/*
	=============================
	TEST #1 - Copy EVERYTHING
	=============================
	*/
	pxyContract := realContract.cloneForCopy(true, false, null, true); // ### BUG 56908 21MAR2023 NAVAB1
	
	pxyContract.setProxy(	pxyContract.active,
							ClonedContIDAll,
							pxyContract.fromTS,
							pxyContract.toTS,
							pxyContract.primary,
							pxyContract.myBusinessUnit,
							pxyContract.myTerminal,
							debtor2,
							pxyContract.description
							);
							
	app.myTrxCA.trxCopyInvoiceContract(pxyContract, clonedContract, app.myPassport);
	
	self.assertEqual(clonedContract.myDebtor, debtor2);
	self.assertEqual(clonedContract.contractId, ClonedContIDAll);
	self.assertEqual(clonedContract.fromTS, realContract.fromTS);
	self.assertEqual(clonedContract.toTS, realContract.toTS);
	self.assertEqual(clonedContract.primary, false);

	self.assertEqual(clonedContract.allInvoiceContractDetails.size(), realContract.allInvoiceContractDetails.size());
	//clonedContractDetails := clonedContract.allInvoiceContractDetailByFrom.getAtKey(clonedContract.fromTS);
	clonedContractDetails := clonedContract.allInvoiceContractDetails.first();
	self.assertEqual(clonedContractDetails.contractType, realContractDetails.contractType);
	self.assertEqual(clonedContractDetails.criteriaPriority, realContractDetails.criteriaPriority);
	self.assertEqual(clonedContractDetails.fromTS, clonedContract.fromTS);
	self.assertEqual(clonedContractDetails.myBusinessUnit, realContractDetails.myBusinessUnit);
	self.assertEqual(clonedContractDetails.toTS, clonedContract.toTS);	
	self.assertEqual(clonedContractDetails.allInvoiceContractRates.size(), realContractDetails.allInvoiceContractRates.size());
	
	clonedRate := clonedContractDetails.allInvoiceContractRates.first();
	self.assertEqual(clonedRate.myService, realRate.myService);
	
	self.assertEqual(clonedRate.allInvoiceContractRateEntries.size(), realRate.allInvoiceContractRateEntries.size());
	
	//clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.getAtKey(clonedContract.fromTS);
	clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.last();
	self.assertEqual(clonedRateEntry.costPerUnit, realRateEntry4.costPerUnit);
	self.assertEqual(clonedRateEntry.fromAmount, realRateEntry4.fromAmount);
	self.assertEqual(clonedRateEntry.fromTS, clonedContract.fromTS);
	self.assertEqual(clonedRateEntry.myBusinessUnit, realRateEntry4.myBusinessUnit);
	self.assertEqual(clonedRateEntry.toAmount, realRateEntry4.toAmount);
	self.assertEqual(clonedRateEntry.toTS, clonedContract.toTS);
	
	// Delete proxy and cloned object, getting ready for next test
	pxyContract.deleteClonedProxy();
	delete pxyContract;
	app.myTrxDA.trxDeleteInvContract(clonedContract, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	=============================
	TEST #2 - Copy VALID only
	=============================
	*/
	pxyContract := realContract.cloneForCopy(true, true, today.date(), true); // ### BUG 56908 21MAR2023 NAVAB1
	
	pxyContract.setProxy(	pxyContract.active,
							ClonedContIDValid,
							pxyContract.fromTS,
							pxyContract.toTS,
							pxyContract.primary,
							pxyContract.myBusinessUnit,
							pxyContract.myTerminal,
							debtor2,
							pxyContract.description
							);
							
	app.myTrxCA.trxCopyInvoiceContract(pxyContract, clonedContract, app.myPassport);
	
	self.assertEqual(clonedContract.myDebtor, debtor2);
	self.assertEqual(clonedContract.contractId, ClonedContIDValid);
	self.assertEqual(clonedContract.fromTS, realContract.fromTS);
	self.assertEqual(clonedContract.toTS, realContract.toTS);
	self.assertEqual(clonedContract.primary, false);
	
	self.assertEqual(clonedContract.allInvoiceContractDetails.size(), 1);
	//clonedContractDetails := clonedContract.allInvoiceContractDetailByFrom.getAtKey(clonedContract.fromTS);
	clonedContractDetails := clonedContract.allInvoiceContractDetails.first();
	self.assertEqual(clonedContractDetails.contractType, realContractDetails.contractType);
	self.assertEqual(clonedContractDetails.criteriaPriority, realContractDetails.criteriaPriority);
	self.assertEqual(clonedContractDetails.fromTS, clonedContract.fromTS);
	self.assertEqual(clonedContractDetails.myBusinessUnit, realContractDetails.myBusinessUnit);
	self.assertEqual(clonedContractDetails.toTS, clonedContract.toTS);	
	self.assertEqual(clonedContractDetails.allInvoiceContractRates.size(), realContractDetails.allInvoiceContractRates.size());
	
	clonedRate := clonedContractDetails.allInvoiceContractRates.first();
	self.assertEqual(clonedRate.myService, realRate.myService);

	self.assertEqual(clonedRate.allInvoiceContractRateEntries.size(), 1);
	//clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.getAtKey(clonedContract.fromTS);
	/*clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.last();
	self.assertEqual(clonedRateEntry.costPerUnit, realRateEntry3.costPerUnit);
	self.assertEqual(clonedRateEntry.fromAmount, realRateEntry3.fromAmount);
	self.assertEqual(clonedRateEntry.fromTS, clonedContract.fromTS);
	self.assertEqual(clonedRateEntry.myBusinessUnit, realRateEntry3.myBusinessUnit);
	self.assertEqual(clonedRateEntry.toAmount, realRateEntry3.toAmount);
	self.assertEqual(clonedRateEntry.toTS, clonedContract.toTS);*/
	
	//clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.getAtKey(clonedContract.fromTS);
	clonedRateEntry := clonedRate.allInvoiceContractRteEntByFrom.first();
	self.assertEqual(clonedRateEntry.costPerUnit, realRateEntry4.costPerUnit);
	self.assertEqual(clonedRateEntry.fromAmount, realRateEntry4.fromAmount);
	self.assertEqual(clonedRateEntry.fromTS, clonedContract.fromTS);
	self.assertEqual(clonedRateEntry.myBusinessUnit, realRateEntry4.myBusinessUnit);
	self.assertEqual(clonedRateEntry.toAmount, realRateEntry4.toAmount);
	self.assertEqual(clonedRateEntry.toTS, clonedContract.toTS);
	
epilog

	// Delete any objects created
	if realContract &lt;&gt; null then
		app.myTrxDA.trxDeleteInvContract(realContract, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	if clonedContract &lt;&gt; null then
		app.myTrxDA.trxDeleteInvContract(clonedContract, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	if pxyContract &lt;&gt; null then
		pxyContract.deleteClonedProxy();
		delete pxyContract;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate01" id="8fabda15-dbab-42e0-8d1e-1c8bbab3e4d5">
        <updating/>
        <source>tContractDebtorRate01() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

Debtor with 3 different active contracts, no primary; each contract is for the same details but each detail has its own date range; 
	one of which covers 'now'. Create an invoice line for 'now' and check it chooses the correct active contract by date range.
*/
constants		
	CargoTypeStr = "CANNONBALL";
	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	
	iter						: Iterator;
	
	trxFound					: Boolean;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	tiContractid : String;
	charge : CM_Charge;
begin
	app.myPassport.setMyTerminal(self.myBank.terminal);
	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	self.assertTrueMsg(cargoType &lt;&gt; null, "cargoType is null");
	self.assertTrueMsg(cargoType.abbreviation = CargoTypeStr, "Cargo Type is not " &amp; CargoTypeStr);
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One - NOW
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// NOTE - last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor, fromTS, toTS, true, false, operator, cargoType, ild1, service01, true,10, null);
	tiContractid := realCon.contractId; // This is the one to use
	
	// Contract Two - In the past
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "02", debtor, fromTS, toTS, true, false,  operator, cargoType, ild1, service02, false,11, null);
	
	// Contract Three - In the future
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "03", debtor, fromTS, toTS,  true, false, operator, cargoType, ild1, service02, false,12, null);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(tiContractid);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	
	
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service01 then
			if charge.getRate() = 1000 then
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 1000");

epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate02" id="a9db1d6a-6f45-4ac6-b8f4-550f0222602b">
        <updating/>
        <source>tContractDebtorRate02() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

Debtor with 3 different active contracts, one is the primary; each contract is for the same details but each detail has its own date range, 
			none of which covers 'now'. Create an invoice line for 'now' and check it chooses the PRIMARY contract; becasue no contract by date 
			range could be found. Primary contract does not need to match on contractId.

*/
constants		
	CargoTypeStr = "CANNONBALL";

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	
	iter						: Iterator;
	
	trxFound					: Boolean;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-100);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor, fromTS, toTS, true, true, operator, cargoType, ild1, service01, true,10, null);
	
	// Contract Two
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-75);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "02", debtor, fromTS, toTS, true, false,  operator, cargoType, ild1, service02, false, 20, null);
	
	// Contract Three
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-50);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "03", debtor, fromTS, toTS,  true, false, operator, cargoType, ild1, service02, false, 30, null);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, 	CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(realCon.contractId);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
//	invLine.inspectModal;
epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate03" id="d4bd27e6-57df-4ba3-8166-07a9885eeaa4">
        <updating/>
        <source>tContractDebtorRate03() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

Debtor with 3 different non active contracts, no primary; each contract is for the same details but each detail has its own date range; one of which covers 'now'. 
	Create an invoice line for 'now' and check it does not use the contract at all, but uses the rate from the rate table.
*/
constants		
	CargoTypeStr = "CANNONBALL";

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	iter						: Iterator;
	
	trxFound					: Boolean;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	charge : CM_Charge;
	rateEntry 							: CM_RateEntry;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);

	// set up rate entry for service
	rateEntry := service01.debtorNodeRates.first.rateEntries.first;
	
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;
	
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	// set up rate entry for service

	// set up rate entry for service
	rateEntry := service02.debtorNodeRates.first.rateEntries.first;
	
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;
	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor, fromTS, toTS, false, false, operator, cargoType, ild1, service01, true, 2, null);
	
	// Contract Two
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "02", debtor, fromTS, toTS, false, false,  operator, cargoType, ild1, service02, false, 4, null);
	
	// Contract Three
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "03", debtor, fromTS, toTS,  false, false, operator, cargoType, ild1, service02, false, 6, null);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(realCon.contractId);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service02 then
			if charge.getRate() = 0.001 then
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 0.001");
epilog

	delete services;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate04" id="cf7899ef-8b04-4b2c-809c-826efb001581">
        <updating/>
        <source>tContractDebtorRate04() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

Debtor with 3 different active contracts, no primary; each contract has 3 details each detail with its own date range and rates, one of which covers 'now'.
Create an invoice line for 'now' and check it chooses the correct active contract by date range and the correct detail by date range.
*/
constants		
	CargoTypeStr = "CANNONBALL";
	
	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars
	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	
	iter						: Iterator;
	
	trxFound					: Boolean;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	tiContractid : String;
	charge : CM_Charge;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One - NOW
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// NOTE - last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte3Dtl(contractid &amp; "01", debtor, fromTS, toTS, true, false, operator, cargoType, ild1, service01, true,10);
	tiContractid := realCon.contractId; // This is the one to use
	
	// Contract Two - In the past
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte3Dtl(contractid &amp; "02", debtor, fromTS, toTS, true, false,  operator, cargoType, ild1, service02, false,11);
	
	// Contract Three - In the future
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte3Dtl(contractid &amp; "03", debtor, fromTS, toTS,  true, false, operator, cargoType, ild1, service02, false,12);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId,CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(tiContractid);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	
	
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service01 then
			if charge.getRate() = 20000 then
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 20000, should use the last detail on the second contract");

epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate05" id="f462316a-2d24-4a65-84cd-98149432386d">
        <updating/>
        <source>tContractDebtorRate05() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

Debtor with 3 different active contracts, no primary; each contract has 3 details each detail with its own date range and rates, one of which covers 'now', 
Each detail has 3 rates with their own date range, one of which cover 'now'.
Create an invoice line for 'now' and check it chooses the correct active contract/detail/rate by date range.

*/
constants		
	CargoTypeStr = "CANNONBALL";

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	iter						: Iterator;
	trxFound					: Boolean;
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	tiContractid : String;
	charge : CM_Charge;
	stTime, endTime : Time;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One - NOW
	stTime.setTime(0,0,0,0);
	endTime.setTime(23,59,59,999);
	fromTS := app.actualTimeAppServer();
	fromTS.setTime(stTime);
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);
	toTS.setTime(endTime);
	
	// NOTE - last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte3Dtl3Rte(contractid &amp; "01", debtor, fromTS, toTS, true, false, operator, cargoType, ild1, service01, true,10);
	tiContractid := realCon.contractId; // This is the one to use
	
	// Contract Two - In the past
	fromTS := app.actualTimeAppServer();
	fromTS.setTime(stTime);
	fromTS := fromTS.addDays(-20);
	toTS := fromTS.addDays(15);
	toTS.setTime(endTime);

	realCon := self.createContract4DebtRte3Dtl3Rte(contractid &amp; "02", debtor, fromTS, toTS, true, false,  operator, cargoType, ild1, service02, false,11);
	
	// Contract Three - In the future
	fromTS := app.actualTimeAppServer();
	fromTS.setTime(stTime);
	fromTS := fromTS.addDays(20);
	toTS := fromTS.addDays(15);
	toTS.setTime(endTime);

	realCon := self.createContract4DebtRte3Dtl3Rte(contractid &amp; "03", debtor, fromTS, toTS,  true, false, operator, cargoType, ild1, service02, false,12);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(tiContractid);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	
	
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service01 then
			if charge.getRate() = 11.118 then
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 11.118, should use the last rate entry on the first set of amount ranges, on the second rate detail. on the first contract");

epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate06" id="dc17a592-2960-44ae-b236-ce99f534ee51">
        <updating/>
        <source>tContractDebtorRate06() updating;
/*
Purpose:			

Date		Who		Reason
16JAN2023	NAVAB1	TFS CR 55644 TASK 55684

BU has a ship term with mappings for 3 invoice lines, each mapping pointing to a different debtor type. 2 Debtors each with 1 contract active and primary,  
contract has 3 details each with its own ship term. Create an invoice line to be charged to the debtor (debtor 1) on the operator, but the shipping term changes 
that to use debtor 2. Check that the rate comes from the contract for debtor 2.*/

constants		
	CargoTypeStr = "CANNONBALL";
	
	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceLineTypeId2			: String = "UT_ABCInvLineType2";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1, ild2						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	
	iter						: Iterator;
	bank : CM_Bank;
	trxFound					: Boolean;
	realInvoiceContractShipTerm,
	pxyInvoiceContractShipTerm : CM_InvoiceContractShipTerm;
	realInvoicShipMapping,
	pxyInvoiceShipMapping : CM_InvoiceShipTermMapping;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor1, debtor2 : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	tiContractid : String;
	charge : CM_Charge;
	carrier : CM_Carrier;
	debtorType : CM_DebtorType;
	invLines : CM_InvoiceLineDescSet;
begin
	bank := 	self.myBank;
	app.myPassport.setMyTerminal(self.myBank.terminal);
	
	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId2, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	create invLines transient;
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	invLines.add(ild1);
	
	ild2 := self.createInvoiceLineType(InvoiceLineTypeId2, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	invLines.add(ild2);
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor1 := operator.debtor;
	self.assertTrueMsg(debtor1 &lt;&gt; null, "Operator Debtor is null");

	self.deleteAllContractsForDebtor(debtor1); // need to delete the contracts here so we can delete the ship term, next
	
	carrier := app.myRoot.allCarriers[ self.getProfileSetting(UT_Profile.P_CARRIER).asString];
	self.assertTrueMsg(carrier &lt;&gt; null, "Carrier is null");

	// Debtor 2 will be for the carrier, a shipping term will tell the rate code to switch to use a contract of the same ID for the carrier's debtor
	debtor2 := carrier.myDebtor;
	self.assertTrueMsg(debtor2 &lt;&gt; null, "Carrier Debtor is null");

	self.deleteAllContractsForDebtor(debtor2); // need to delete the contracts here so we can delete the ship term, next
	
	
	// ### SHIP TERM
	self.deleteInvContractShipTerm("UT_ST1");
	
	debtorType := app.myRoot.allDebtorTypes["SDT9"]; // Carrier
	
    create pxyInvoiceContractShipTerm transient;
	pxyInvoiceContractShipTerm.setProxy("UT_ST1","Unit Test Ship Term One",self.myBank);
	self.createInvContractShipTerm(pxyInvoiceContractShipTerm,realInvoiceContractShipTerm);
	self.assertEqual(realInvoiceContractShipTerm.code,"UT_ST1");
	delete pxyInvoiceContractShipTerm;
	
	
	create pxyInvoiceShipMapping transient;
	pxyInvoiceShipMapping.setProxy(1,realInvoiceContractShipTerm,debtorType,invLines);
	self.createInvShipMapping(pxyInvoiceShipMapping,realInvoicShipMapping);
	self.assertEqual(realInvoicShipMapping.priority,1);
	self.assertEqual(realInvoicShipMapping.myDebtorType,debtorType);
	self.assertEqual(realInvoicShipMapping.allInvoiceLineTypes.size,2);
	
	delete pxyInvoiceShipMapping;
	
	// ### CONTRACT
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	self.assertTrueMsg(cargoType &lt;&gt; null, "cargoType is null");
	self.assertTrueMsg(cargoType.abbreviation = CargoTypeStr, "Cargo Type is not " &amp; CargoTypeStr);
	
	// ### DEBTOR ONE CONTRACT
	// Contracts - A debtor contract is unique
	contractid := debtor1.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One - NOW
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// NOTE - 2nd last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor1, fromTS, toTS, true, false, operator, cargoType, ild1, service01, true,10, realInvoiceContractShipTerm);
	tiContractid := realCon.contractId; // This is the one to use
	self.assertTrueMsg(realCon.allInvoiceContractDetails.first.myShippingTerm &lt;&gt; null, "Contract Ship Term is null");
	
	
	// ### DEBTOR TWO CONTRACT
	// Contracts - A debtor contract is unique
	// Second debtor needs to have same contractId for this to work.
	// Contract One - NOW
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// NOTE - 2nd last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor2, fromTS, toTS, true, false, operator, cargoType, ild1, service01, true,55, null);
	self.assertTrueMsg(realCon.allInvoiceContractDetails.first.myShippingTerm = null, "Contract Ship Term should be null");
	
	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", realCon.contractId);
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("ConsigneeCode", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(tiContractid);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transaction not found");
	
	
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service01 then
			if charge.getRate() = 5500 then // this is the rate set for the 2nd debtor, the first debtors rate is 1000
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 5500");

epilog
	delete pxyInvoiceContractShipTerm;
	delete pxyInvoiceShipMapping;

	delete services;
	delete allServices;
	delete iter;
	delete invLines;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	self.deleteAllContractsForDebtor(debtor1); // need to delete the contracts here so we can delete the ship term, next
	self.deleteAllContractsForDebtor(debtor2); // need to delete the contracts here so we can delete the ship term, next
	self.deleteInvContractShipTerm("UT_ST1"); // do not want anyone using this
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDebtorRate07" id="7361e4d7-85c4-4931-a87e-fbd30f860153">
        <updating/>
        <source>tContractDebtorRate07() updating;
/*
Purpose - 	debtor with 3 contracts all primary, all different date ranges, 1 in the past 1 in the future and one for now.
				the cargo does not have a contract so the primary will be used, and now it must find the correct primary using the invoice date
				
Who - NAVAB1
Date - 16NOV2023
ADO -  BUG 60627
*/

constants		
	CargoTypeStr = "CANNONBALL";
	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_ABCService1";
	InvoiceServiceId2			: String = "UT_ABCService2";
	InvoiceLineTypeId			: String = "UT_ABCInvLineType1";
	InvoiceTypeId				: String = "UT_ABCInvType";
	TransactionMapId			: String = "UT_MoveABC";
	TruckId						: String = "UTBCV";
	CalcType  = "UT_CALCABC";
	GLCode = "UT_GLABC";
	MeasType = "UT_MTABC";
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service01, service02		: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	contractid : String;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	
	iter						: Iterator;
	
	trxFound					: Boolean;
	
	invLine : CM_InvoiceLine;
	locn : CM_LocationsController;
	bs : CM_TerminalArea;
	debtor : CM_Debtor;
	operator : CM_Operator;
	fromTS, toTS : TimeStamp;
	realCon : CM_InvoiceContract;
	cargoType : CM_CargoType;
	tiContractid : String;
	charge : CM_Charge;
begin
	app.myPassport.setMyTerminal(self.myBank.terminal);
	self.resetDefaultTranMap();

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	
	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceService(InvoiceServiceId2, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCode);
	self.deleteCalculationType(CalcType, NORMAL_ERASE);
	self.deleteMeasurementType(MeasType);
	self.deleteTerminalArea("UT_BSAB");
	
	self.deleteVehicle(TruckId);
	
	bs := self.addBlockStack("UT_BSAB",999999,null);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType(InvoiceTypeId);
	if invType = null then
		self.createInvoiceType(InvoiceTypeId,InvoiceTypeGeneral);
	endif;
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type " &amp; InvoiceTypeId &amp; " not created. ");

	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MeasType, Type_Weight, MeasType);
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CalcType, CalcType, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CalcType &amp; " not created");

	glCode := self.createInvoiceGLCode(GLCode, "UnitTest CONTRACT DEBTOR RATE 1");
	service01 := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service01);
	
	service02 := self.createInvoiceService(InvoiceServiceId2, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service02);

	
	
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	
	// ### TRANSACTION MAP
	self.tranMapLoadMove();

	// ### CONTRACT
	
	operator := app.myRoot.allOperators[ self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");

	debtor := operator.debtor;
	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	cargoType :=  self.getCargoType(CargoTypeStr); // Cannon Balls
	self.assertTrueMsg(cargoType &lt;&gt; null, "cargoType is null");
	self.assertTrueMsg(cargoType.abbreviation = CargoTypeStr, "Cargo Type is not " &amp; CargoTypeStr);
	
	// Contracts - A debtor contract is unique
	contractid := debtor.name &amp; fromTS.formatAsYYYYMMDDHHmmSS();
	
	// Contract One - NOW
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// NOTE - last param for createContract4DebtorRate() is the CPU which then is used in 3 weight ranges with different rates. '10' will mean a rate of 1000 becasue of the weight of the TI, 
	//			we check for this rate later, if the contract rate is not used the rate on the CM_Charge will be ZERO since we have not set a default rate on our services above
	realCon := self.createContract4DebtRte(contractid &amp; "01", debtor, fromTS, toTS, true, true, operator, cargoType, ild1, service01, true,10, null);
	tiContractid := realCon.contractId; // This is the one to use
	
	// Contract Two - In the past
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "02", debtor, fromTS, toTS, true, true,  operator, cargoType, ild1, service02, false,11, null);
	
	// Contract Three - In the future
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(20);
	toTS := fromTS.addDays(15);

	realCon := self.createContract4DebtRte(contractid &amp; "03", debtor, fromTS, toTS,  true, true, operator, cargoType, ild1, service02, false,12, null);

	
	// ### VVR, TRUCK, CARGO ROAD JOB
	self.opts.purge();
	self.opts.addAssoc("ContractId", ""); // no contract Id on the TI
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, CargoTypeStr, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	self.deleteStops(ti);
	
	self.movePlanned(ti,bs.getMyLocationsController());
	self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null,"TI did not plan");
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
	
	self.workVehicle(vvr);
	locn := ti.getPrimaryLocation(REAL_MODE);
	
	self.assertNotNull(locn);
	self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
	self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	
	// ### ARE THERE INVOICE LINES
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			invLine := moveTrans.allInvoiceLines.first;
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	
	
	// ### did it use the contract rate? The contract rate should be 1000. 
	trxFound := false;
	foreach charge in invLine.charges discreteLock do
		// we used service01 for the contract that it should be using
		if charge.service = service01 then
			if charge.getRate() = 1000 then
				trxFound := true;
				break;
			endif;
		endif;
	endforeach;
//	invLine.inspectModal;	
	self.assertTrueMsg(trxFound, "Rate should be 1000");

epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDetailVerify" id="4fe45c95-a54b-42b8-8bdd-506f0f84a4b7">
        <updating/>
        <source>tContractDetailVerify() updating;
/*
Purpose:			

Date		Who		Reason
06 December 2022	navab1	TFS CR 55623 TASK 55674
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/
constants
	CONTRACTID = "UT_221206-01";
vars
	pxyCon, realCon : CM_InvoiceContract;
	pxyConDtl, realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	oArray : ObjectArray; 
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	yaPurge : CM_ObjectSet;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	
//	self.purgeAllContractData();
	

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl := self.createContractDetail(realCon, operator,cargoType);
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;
	
	// ### TRY TO UPDATE DETAIL with wrong contract type
	beginLoad;
	pxyConDtl := realConDtl.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyConDtl.myInvoiceContract &lt;&gt; null, "PROXY Rate Contract is null");
	assertTrueMsg(pxyConDtl.myInvoiceLineType &lt;&gt; null, "PROXY Invoice Line Type is null");
	assertTrueMsg(pxyConDtl.myCalculationType &lt;&gt; null, "PROXY Calculation Type is null");
	
	
	assertTrueMsg(pxyConDtl &lt;&gt; null,"AAA Pxy CONTRACT DETAIL not created");
	assertTrueMsg(pxyConDtl.contractType = INV_CONTRACT_TYPE_STANDARD, "AAA Proxy Contract type should be " &amp; INV_CONTRACT_TYPE_STANDARD.String &amp; ", it is &gt;&gt;&gt;" &amp; pxyConDtl.contractType.String &amp; "&lt;&lt;&lt;");
	//pxyConDtl.setProxy(99,123, fromTS, toTS,calcType,realCon,invLineType100, realCon.myBusinessUnit, null); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,99,123, fromTS, toTS,calcType,realCon,invLineType100, realCon.myBusinessUnit, null,null); //08/02/2023 navmv20 TFS 55650 TASK 55702
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Contra_detail_type_invali_shou); 
	
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected contract detail TYPE error");
	
	
	// ### TRY TO UPDATE DETAIL with null contract, calc type and invoice line type references
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Calcu_type_contr_detai_must_en); 
	self.expectedTrxErrors.add(Contra_must_given_contra_detai); 
	self.expectedTrxErrors.add(Invoi_line_type_contr_detai_mu); 

	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_STANDARD,123, fromTS, toTS,null,null,null, realCon.myBusinessUnit, null,null);
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail REFERENCES error");
	
	// ### TRY TO UPDATE DETAIL with wrong dates
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Contr_detai_from_datet_must_wi); 
	self.expectedTrxErrors.add(Contr_detai_datet_must_withi_c); 

	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_STANDARD,123, fromTS.addDays(-1), toTS.addDays(3),calcType,realCon,invLineType100, realCon.myBusinessUnit, null,null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_STANDARD,123, fromTS.addDays(-1), toTS.addDays(3),calcType,realCon,invLineType100, realCon.myBusinessUnit, null,null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail DATE TIME error");
	
	// ### UPDATE DETAIL with new priority
	self.clearExpectedTrxErrors();
	
	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_STANDARD,456, fromTS, toTS,calcType,realCon,pxyConDtl.myInvoiceLineType, realCon.myBusinessUnit, null, null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_STANDARD,456, fromTS, toTS,calcType,realCon,pxyConDtl.myInvoiceLineType, realCon.myBusinessUnit, null,null); //09/02/2023 navmv20 TFS 55650 TASK 55702 
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
	
	self.deleteInvoiceService("UT_ServiceContract-1",0);
	self.deleteInvoiceService("UT_ServiceContract-2",0);
	self.deleteInvoiceType("UT_InvTypeContract");
	self.deleteInvoiceLineType("UT_LineTypeContract",0);
epilog
	delete pxyCon;
	delete services;
	delete pxyConDtl;
	delete oArray;
	delete criteriaCargoTypes;
	if yaPurge &lt;&gt; null then
		yaPurge.purge;
		delete yaPurge;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractDtlUOMCode" id="5e12cc64-2378-44ba-99a9-0fb08b5d404e">
        <updating/>
        <source>tContractDtlUOMCode() updating;
/*

Purpose:			This UT tests the UOM code is stamped correctly on the Invoice Line.
					If Contract Details has UOM defined
						use it
					else
						use UOM defined in Invoice Line Type

Parameters:			

Return Value:		

Date		Who		Reason
03/11/2023	navkc1 Bug 61061: FR | 54089 - EUP - Contracts - Volume based Invoice line - UOM code is blank

*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	uomInvLineType,
	uomContractDtl	: CM_InvoiceUnitOfMeasure;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);
		
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient;
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType);
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	criteriaCargoTypes.add(contType);
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD, true,"CCT04");
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;
	
	uomInvLineType := app.myRoot.allInvoiceUnitOfMeasure["Quantity"];
	uomContractDtl := app.myRoot.allInvoiceUnitOfMeasure["TEU"];
	
	// Set Invoice Line Type UOM to Quantity
	// Set Contract Details UOM to TEU
	// We are expecting TEU to be stamped on the Invoice Line UOM code, let's see
	beginTransaction;
		invLineType100.setPropertyValue("myUOM", uomInvLineType);
		realConDtl.setPropertyValue("myUnitOfMeasure", uomContractDtl);
	commitTransaction;
	
	// ### CREATE RATE
	service100 := invLineType100.services.first;

		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 1 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 1 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2,aPort, 15000);
		tis2.add(ti);
	endforeach;
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	foreach ti in tis do
		invLine := ti.invoiceLines.first;
		self.assertTrueMsg(invLine.uomCode = uomContractDtl.code, "tis - Invoice Line has incorrect UOM code");
	endforeach;

	// different voyage but only one accumulation so 2nd voyage uses only top rate
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		self.assertTrueMsg(invLine.uomCode = uomContractDtl.code, "tis2 - Invoice Line has incorrect UOM code");
	endforeach;
	
	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);

epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractEndDateChangeVerify" id="edc41e61-89c4-4855-b3c2-cb8e44d4796e">
        <updating/>
        <source>tContractEndDateChangeVerify() updating;
/*
Purpose:			

Date		Who		Reason
20FEB2023	NAVAB1	CR 55646 TASK 56413 
*/


constants
	CONTRACTID = "UT_230220-01";
vars
	realCon, pxyCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl := self.createContractDetail(realCon,operator, cargoType);
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;
	assertTrueMsg(service100 &lt;&gt; service200, "service100 should be different from service200");

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,501,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	// ### CHECK All END DATE ARE THE SAME.
	assertTrueMsg(realCon.toTS = toTS, "Contract end date should be " &amp; toTS.String &amp; ", is " &amp; realCon.toTS.String);
	assertTrueMsg(realConDtl.toTS = toTS, "Contract detail end date should be " &amp; toTS.String &amp; ", is " &amp; realConDtl.toTS.String);
	assertTrueMsg(realRateEntry01.toTS = toTS, "Contract rate entry 01 end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry01.toTS.String);
	assertTrueMsg(realRateEntry02.toTS = toTS, "Contract rate entry 02 end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry02.toTS.String);
	assertTrueMsg(realRateEntry03.toTS = toTS, "Contract rate entry 03 end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry03.toTS.String);
	

	// ### CHANGE CONTRACT'S END DATE and AUTO Update matching Detail and Rate Entries.
	beginLoad;
	pxyCon := realCon.pxyCreateUpdateProxy();
	endLoad;
	toTS := toTS.addDays(6);
	
	pxyCon.setProxy(realCon.active,realCon.contractId, realCon.fromTS, toTS, realCon.primary, realCon.myBusinessUnit, realCon.myTerminal, realCon.myDebtor, "End Date Changed By Unit Test");
	
	self.clearExpectedTrxErrors();
	app.myTrxUA.trxUpdateInvContract(pxyCon,app.myPassport, true);
	
	// ### CHECK All END DATE ARE THE SAME.
	assertTrueMsg(realCon.toTS = toTS, "Contract new end date should be " &amp; toTS.String &amp; ", is " &amp; realCon.toTS.String);
	assertTrueMsg(realConDtl.toTS = toTS, "Contract detail new end date should be " &amp; toTS.String &amp; ", is " &amp; realConDtl.toTS.String);
	assertTrueMsg(realRateEntry01.toTS = toTS, "Contract rate entry 01 new end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry01.toTS.String);
	assertTrueMsg(realRateEntry02.toTS = toTS, "Contract rate entry 02 new end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry02.toTS.String);
	assertTrueMsg(realRateEntry03.toTS = toTS, "Contract rate entry 03 new end date should be " &amp; toTS.String &amp; ", is " &amp; realRateEntry03.toTS.String);
	
	
	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyRateEntry;
	delete pxyCon;

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractIdTiTransInvLine" id="8a7270ef-f720-4fd2-9a34-171c50ec87a4">
        <source>tContractIdTiTransInvLine();
/*
Purpose:	Test that contract Id, if set on a TI, is then stamped on all transactions and invoice lines		

Date		Who		Reason
23 January 2023	navab1	TFS CR 55625 TASK 55659
*/

constants		

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_MDHService1";
	InvoiceLineTypeId			: String = "UT_MDHInvLineType1";
	InvoiceTypeId				: String = "UT_MDHInvType";
	TransactionMapId			: String = "UT_MoveMDH";
	TruckId						: String = "UTMHMV";
	ContractId = "UT_CONTRACT";	
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service						: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	iter						: Iterator;
	invLine : CM_InvoiceLine;
begin
	app.myPassport.setMyTerminal(self.getTerminal());


	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode("5321-45665");
	self.deleteCalculationType("UT_MDHCONVW", NORMAL_ERASE);
	self.deleteMeasurementType("UTMWeight");
	
	self.deleteVehicle(TruckId);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType("UT_DPHINVTYPE");
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type UT_DPHINVTYPE not created. ");
	
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTMWeight", Type_Weight, "UT MDH Weight Units");
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, "UT_MDHCONVW", "UT_MDHCONVW", 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_MDHCONVW not created");

	glCode := self.createInvoiceGLCode("5321-45665", "UnitTest MDH 1");
	service := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadMove();

	self.opts.purge();
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, "CANNONBALL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	beginTransaction;
	ti.setContractId(ContractId);
	commitTransaction;
	
	self.deleteStops(ti);
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	
	self.workVehicle(vvr);
	self.assertNotNull(ti.getPrimaryLocation(REAL_MODE));
	self.assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	// check to see if contract id is on TI, Transaction and invoice line)
	self.assertTrueMsg(ti.contractId = ContractId, "TI contract Id is wrong");
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		
		invLine :=  moveTrans.allInvoiceLines.first;
		if invLine.invoiceLineDesc = ild1 then
			self.assertTrueMsg(trans.contractId = ContractId, "TRAN contract Id is wrong");
			self.assertTrueMsg(invLine.contractId = ContractId, "INVLINE contract Id is wrong");
			break;
		endif;
		
		
		
	endwhile;

//	invLine.inspectModal;
epilog

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractRateEntriesBulk" id="fb782c41-50d2-4090-9545-d354df8e2f2a">
        <updating/>
        <source>tContractRateEntriesBulk() updating;
/*
Purpose:			

Date		Who		Reason
// ### TFS CR 55651 TASK 55657 23MAR2023 NAVMV20
// ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1 re wrote to use new TRX. The rate entry UI was completely re written and a new TRX created
*/


constants
	CONTRACTID1 = "UT_221206-01";
	CONTRACTID2 = "UT_221206-02";
vars
	realCon1,
	realCon2              : CM_InvoiceContract;
	realConDtl1,
	realConDtl2			 : CM_InvoiceContractDetails;
	realRate1,
	realRate2				 : CM_InvoiceContractRate;
	pxyRateEntry1,
	pxyRateEntry2,
	pxyRateEntry3,
	pxyRateEntry4,
	entry,
	realRateEntry01,
	realRateEntry02,
	realRateEntry03,
	realRateEntry11,
	realRateEntry12,
	realRateEntry13          : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
	updateEntriesSet, newEntriesSet: ObjectSet;
	newCpu,
    cpuVal	   : Decimal[23,6];
	newFromTs,
	newToTs,
	fromTSVal,
	toTSVal		: TimeStamp;
	updateFromTS,
	updateToTS,
	updateCpu         : Boolean;
begin
	create newEntriesSet transient;
	create updateEntriesSet transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon1 := self.createContract(debtor, CONTRACTID1,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl1 := self.createContractDetail(realCon1,operator, cargoType);
	
	invLineType100 := realConDtl1.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;
	assertTrueMsg(service100 &lt;&gt; service200, "service100 should be different from service200");

	realRate1 := self.createContractRate(realConDtl1,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate1,12.34,0,100,realConDtl1.fromTS, realConDtl1.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate1,56.78,101,500,realConDtl1.fromTS, realConDtl1.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate1,910.12,501,40000,realConDtl1.fromTS, realConDtl1.toTS);
	
	// ### TRY to UPDATE 3rd ENTRY WITH NULL DATES
	beginLoad;
	pxyRateEntry1 := realRateEntry01.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyRateEntry1.myInvoiceContractRate &lt;&gt; null, "1 PROXY Rate Entry,Rate is null");
	
	newCpu := 10000;
	newFromTs := realConDtl1.fromTS.addDays(1);
	newToTs   := realConDtl1.toTS.addDays(-1);
	
	pxyRateEntry1.setProxy(pxyRateEntry1.id, newCpu, pxyRateEntry1.fromAmount, pxyRateEntry1.toAmount, newFromTs, newToTs, realRate1, realCon1.myBusinessUnit);
	
	updateEntriesSet.add(pxyRateEntry1);
	
	beginLoad;
	pxyRateEntry2 := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyRateEntry2.myInvoiceContractRate &lt;&gt; null, "2 PROXY Rate Entry,Rate is null");
	
	pxyRateEntry2.setProxy(pxyRateEntry2.id, newCpu, pxyRateEntry2.fromAmount, pxyRateEntry2.toAmount, newFromTs, newToTs, realRate1, realCon1.myBusinessUnit);
	
	updateEntriesSet.add(pxyRateEntry2);

	beginLoad;
	pxyRateEntry3 := realRateEntry03.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyRateEntry3.myInvoiceContractRate &lt;&gt; null, "3 PROXY Rate Entry,Rate is null");
	
	pxyRateEntry3.setProxy(pxyRateEntry3.id,newCpu,pxyRateEntry3.fromAmount,pxyRateEntry3.toAmount,newFromTs,newToTs, realRate1,realCon1.myBusinessUnit);
	updateEntriesSet.add(pxyRateEntry3);
	
	self.validateRateEntryUpdate(updateEntriesSet, newEntriesSet);
	
	self.assertTrueMsg(realRateEntry01.fromTS = newFromTs, "Rate entry 1 should have the same from date as others in group. Should be "&amp; newFromTs.String &amp; " Is " &amp; realRateEntry01.fromTS.String);
	self.assertTrueMsg(realRateEntry01.toTS = newToTs, "Rate entry 1 should have the same from date as others in group. Should be "&amp; newToTs.String &amp; " Is " &amp; realRateEntry01.toTS.String);
	
	self.assertTrueMsg(realRateEntry02.fromTS = newFromTs, "Rate entry 2 should have the same from date as others in group. Should be "&amp; newFromTs.String &amp; " Is " &amp; realRateEntry02.fromTS.String);
	self.assertTrueMsg(realRateEntry02.toTS = newToTs, "Rate entry 2 should have the same from date as others in group. Should be "&amp; newToTs.String &amp; " Is " &amp; realRateEntry02.toTS.String);
	
	self.assertTrueMsg(realRateEntry03.fromTS = newFromTs, "Rate entry 3 should have the same from date as others in group. Should be "&amp; newFromTs.String &amp; " Is " &amp; realRateEntry03.fromTS.String);
	self.assertTrueMsg(realRateEntry03.toTS = newToTs, "Rate entry 3 should have the same from date as others in group. Should be "&amp; newToTs.String &amp; " Is " &amp; realRateEntry03.toTS.String);


	updateEntriesSet.purge();

	create pxyRateEntry4 transient;
	pxyRateEntry4.setProxy(null, 8888.1234, 40001, 99999999, newFromTs, newToTs, realRate1, realCon1.myBusinessUnit);
	newEntriesSet.add(pxyRateEntry4);

	self.validateRateEntryUpdate(updateEntriesSet, newEntriesSet);
	
	assertTrueMsg(realRate1.allInvoiceContractRateEntries.size = 4, "Rate should have 4 rate entries");
	
	updateEntriesSet.purge();
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon1, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete updateEntriesSet;
	delete newEntriesSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractRateEntryDateVerify" id="811e0af2-c1c0-4972-9dcb-645533fe5403">
        <updating/>
        <source>tContractRateEntryDateVerify() updating;
/*
Purpose:	Check dazte ranges on the rate entries, paricu;larly those that overlap but start or end on the same date as overs.		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 28NOV2023
ADO -  BUG 61482
*/



constants
	CONTRACTID = "UT_231128-01";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03, realRateEntry04  : CM_InvoiceContractRateEntry;
	fromTS, toTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	
//	self.purgeAllContractData();

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(8);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl := self.createContractDetail(realCon,operator, cargoType);
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;
	assertTrueMsg(service100 &lt;&gt; service200, "service100 should be different from service200");

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES

	fromTS := realCon.fromTS;
	toTS := fromTS.addDays(3);
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,100,fromTS, toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,101,500,fromTS, toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,501,99999999,fromTS, toTS);
	
	// ### TRY to Create 2nd ENTRY WITH WRONG 'TO' DATE RANGE
	fromTS := realCon.fromTS;
	toTS := fromTS.addDays(2);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Date_range_confl_with_other_da); 

	create pxyRateEntry transient;
	pxyRateEntry.setProxy(null, 2.46, 0,10000, fromTS, toTS,realRate, realConDtl.myBusinessUnit); 

	app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry04, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG 'TO' DATE RANGE error");
	assertNoTrxErrorsOrWarnings();

	// ### TRY to Create 2nd ENTRY WITH WRONG 'FROM' DATE RANGE
	fromTS := realCon.fromTS;
	fromTS.addDays(1);
	toTS := realCon.toTS;
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Date_range_confl_with_other_da); 

	pxyRateEntry.setProxy(null, 2.46, 0,10000, fromTS, toTS,realRate, realConDtl.myBusinessUnit); 

	app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry04, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG 'FROM' DATE RANGE error");
	assertNoTrxErrorsOrWarnings();

	// ### Create 2nd ENTRY WITH CORRECT DATE RANGES
	fromTS := realCon.fromTS;
	fromTS := fromTS.addDays(5);
	toTS := realCon.toTS;
	self.clearExpectedTrxErrors();

	pxyRateEntry.setProxy(null, 2.46, 0,10000, fromTS, toTS, realRate,realConDtl.myBusinessUnit); 

	app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry04, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertTrueMsg(realRateEntry04 &lt;&gt; null, "realRateEntry04 is NULL!");
	
	
	assertTrueMsg(realRateEntry04.myInvoiceContractRate &lt;&gt; null, "Contract Rate is null");
	assertTrueMsg(realRateEntry04.fromAmount = 0, "Rate Entry 'from amount' is wrong");
	assertTrueMsg(realRateEntry04.toAmount = 10000, "Rate Entry 'to amount' is wrong");
	assertTrueMsg(realRateEntry04.costPerUnit = 2.46, "Rate Entry CostPerUnit is wrong");

	
	
	

	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyRateEntry;

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractRateEntryVerify" id="fe131711-978a-48c3-965c-a4dd98ac5ea9">
        <updating/>
        <source>tContractRateEntryVerify() updating;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55678
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/


constants
	CONTRACTID = "UT_221206-01";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	
//	self.purgeAllContractData();

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl := self.createContractDetail(realCon,operator, cargoType);
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;
	assertTrueMsg(service100 &lt;&gt; service200, "service100 should be different from service200");

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,501,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null, pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### TRY to UPDATE 3rd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry03.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry03.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,450,99999999,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate,realCon.myBusinessUnit); //10/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,450,99999999,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate,realCon.myBusinessUnit); //10/02/2023 navmv20 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 3 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### TRY to UPDATE 3rd ENTRY WITH WRONG DATES
	stTS := fromTS.addDays(-2);
	enTS := toTS.addDays(3);
	beginLoad;
	pxyRateEntry := realRateEntry03.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry03.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,501,99999999,stTS, enTS, realRate,realCon.myBusinessUnit); //10/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,501,99999999,stTS, enTS, realRate,realCon.myBusinessUnit); //10/02/2023 navmv20 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Rate_entry_from_datet_canno_be); 
	self.expectedTrxErrors.add(Rate_entry_datet_canno_after_c); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG DATES 3 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### TRY to UPDATE 3rd ENTRY WITH NULL DATES
	beginLoad;
	pxyRateEntry := realRateEntry03.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry03.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,501,99999999,null, null, realRate,realCon.myBusinessUnit); //10/02/203 navmv20 TFS 55650 TASK 55702
	//pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,501,99999999,null, null, realRate,realCon.myBusinessUnit); //10/02/203 navmv20 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Rate_entry_from_datet_must_ent); 
	self.expectedTrxErrors.add(Rate_entry_dateti_must_entere); 
	self.expectedTrxErrors.add(Rate_entry_from_datet_canno_be); 
	
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error NULL DATES 3 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	
	// ### UPDATE 3rd ENTRY WITH new range
	beginLoad;
	pxyRateEntry := realRateEntry03.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry03.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,501,888888888,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate,realCon.myBusinessUnit); //10/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,501,888888888,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate,realCon.myBusinessUnit);//10/02/2023 navmv20 TFS 55650 TASK 55702
	
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyRateEntry;

end;</source>
    </JadeMethod>
    <JadeMethod name="tContractRateVerify" id="34a698ff-4a0d-4931-b856-599dd922d76e">
        <updating/>
        <source>tContractRateVerify() updating;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55676
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/
constants
	CONTRACTID = "UT_221206-01";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200, service300 : CM_Service;
	proxyRate, realRate : CM_InvoiceContractRate;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	
	//self.purgeAllContractData();

	self.deleteInvoiceService("UT_ServiceContract-3",0);
	service300 := self.createInvoiceService("UT_ServiceContract-3","3- Unit test for TFS 55623", calcType, null);
	self.assertNotNullMsg(service300, "UT_ServiceContract-3 not created");
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	realConDtl := self.createContractDetail(realCon,operator, cargoType);
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;
	assertTrueMsg(service100 &lt;&gt; service200, "service100 should be different from service200");

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### UPDATE RATE
	beginLoad;
	proxyRate := realRate.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRate.myInvoiceContractDetail &lt;&gt; null, "PROXY Rate Contract Detail is null");
	assertTrueMsg(realRate.myService &lt;&gt; null, "PROXY Service is null, should be service200");
	
	//proxyRate.setProxy(service200,realConDtl); //08/02/2023 navmv20 TFS 55650 TASK 55702
	proxyRate.setProxy(null, service200,realConDtl, service200.myCalculationType); //08/02/2023 navmv20 TFS 55650 TASK 55702 // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
	
	app.myTrxUA.trxUpdateInvContractDtlRt(proxyRate, app.myPassport);
	
	delete proxyRate;
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realRate.myInvoiceContractDetail &lt;&gt; null, "Rate Contract Detail is null");
	assertTrueMsg(realRate.myInvoiceContractDetail = realConDtl, "Rate Contract Detail is wrong");
	assertTrueMsg(realRate.myService &lt;&gt; null, "Service is null, should be service200");
	assertTrueMsg(realRate.myService = service200, "Service is wrong, should be service200");
	
	
	// ### UPDATE RATE WITH WRONG SERVICE - service300 is not part of UT_LineTypeContract
	beginLoad;
	proxyRate := realRate.pxyCreateUpdateProxy();
	endLoad;
	//proxyRate.setProxy(service300,realConDtl); //10/02/2023 navmv20 TFS 55650 TASK 55702
	proxyRate.setProxy(null,service300,realConDtl, service300.myCalculationType); //10/02/2023 navmv20 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Servi_not_confi_contr_detai_in); 
	app.myTrxUA.trxUpdateInvContractDtlRt(proxyRate, app.myPassport);
	
	delete proxyRate;
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract rate WRONG SERVICE error");
	
	// ### UPDATE RATE WITH NO SERVICE
	beginLoad;
	proxyRate := realRate.pxyCreateUpdateProxy();
	endLoad;
	//proxyRate.setProxy(null,realConDtl); //10/02/2023 navmv20 TFS 55650 TASK 55702
	proxyRate.setProxy(null,null,realConDtl, null); //10/02/2023 navmv20 TFS 55650 TASK 55702 // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Contra_rate_must_have_servic); 
	app.myTrxUA.trxUpdateInvContractDtlRt(proxyRate, app.myPassport);
	
	delete proxyRate;
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract rate NO SERVICE error");
	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete proxyRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractSwitchPrimary" id="ad5fdc4c-ac20-4f4a-b052-0a5a60ea5991">
        <updating/>
        <source>tContractSwitchPrimary() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2024 navrv30 Initial creation - Bug 62682: FR - 54089 - Primary status - Invoice contracts

*/
constants
	CONTRACTID = "UT_CT-01";
	CONTRACTID2 = "UT_CT-02";
vars
	pxyCon1, pxyCon2,
	realCon1, realCon2 : CM_InvoiceContract;
	fromTS, toTS : TimeStamp;
	terminal : CM_Terminal;
	bank : CM_Bank;
	operator : CM_Operator;
	debtor : CM_Debtor;
	oArray : ObjectArray; 

begin
	app.myPassport.setMyTerminal(self.getTerminal());


	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	terminal := self.getTerminal();
	bank 		:= terminal.getDefaultCompanyBank();
	
	self.deleteAllContractsForDebtor(debtor);
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	
	// ### CREATE A CONTRACT Primary - True and Active - True
	realCon1 := self.createContract(debtor, CONTRACTID,true,true, fromTS, toTS, false);	
	// ### UPDATE CONTRACT TO MAKE NOT PRIMARY
	beginLoad;
	pxyCon1 := realCon1.pxyCreateUpdateProxy();
	endLoad;	
	pxyCon1.setProxy(false,CONTRACTID, fromTS, toTS, false, bank, terminal, debtor, "Generated By Unit Test");
	
	// ### CREATE A CONTRACT Primary - False and Active - False
	realCon2 := self.createContract(debtor, CONTRACTID2,false,false, fromTS, toTS, false);
	beginLoad;
	pxyCon2 := realCon2.pxyCreateUpdateProxy();
	endLoad;
	pxyCon2.setProxy(true,CONTRACTID2, fromTS, toTS, true, bank, terminal, debtor, "Generated By Unit Test");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoi_contr_debto_prima_canno_); 
	self.expectedTrxErrors.add(This_contr_last_activ_contr_de); 
	
	app.myTrxUA.trxSwitchInvContracts(pxyCon1, pxyCon2, app.myPassport);
	
	self.assertTrueMsg(realCon1.primary = false, "Contract Id Primary should be false but it is &gt;&gt;&gt;" &amp; realCon1.primary.String &amp;"&lt;&lt;&lt;");	

	self.assertTrueMsg(realCon2.primary = true, "Contract Id Primary should be true but it is &gt;&gt;&gt;" &amp; realCon2.primary.String &amp;"&lt;&lt;&lt;");

	self.clearExpectedTrxErrors();
	
	
	self.deleteAllContractsForDebtor(debtor);

epilog
	
	delete oArray;
	delete pxyCon1;
	delete pxyCon2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVerify" id="7849ed70-7e47-4cdc-8b7e-985bf076918d">
        <updating/>
        <source>tContractVerify() updating;
/*
Purpose:			

Date		Who		Reason
06 December 2022	navab1	TFS CR 55623 TASK 55672
*/
constants
	CONTRACTID = "UT_221206-01";
	CONTRACTID2 = "UT_221206-02";
vars
	pxyCon, realCon : CM_InvoiceContract;
	fromTS, toTS : TimeStamp;
	terminal : CM_Terminal;
	bank : CM_Bank;
	operator : CM_Operator;
	debtor : CM_Debtor;
	oArray : ObjectArray; 

begin
	app.myPassport.setMyTerminal(self.getTerminal());

	
//	self.purgeAllContractData();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	terminal := self.getTerminal();
	bank 		:= terminal.getDefaultCompanyBank();

	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	
	// ### CREATE A CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,true, fromTS, toTS, true);
	
	// ### TRY TO DELETE A CONTRACT, SHOULD SAY NO COS is PRIMARY
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoi_contr_debto_prima_canno_); 
	self.expectedTrxErrors.add(This_contr_last_activ_contr_de); 

	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Expected PRIMARY error");
	
	
	// ### UPDATE CONTRACT TO MAKE NOT PRIMARY
	beginLoad;
	pxyCon := realCon.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyCon.myBusinessUnit &lt;&gt; null, "PROXY Contract BANK is null");
	assertTrueMsg(pxyCon.myTerminal &lt;&gt; null, "PROXY Contract TERMINAL is null");
	assertTrueMsg(pxyCon.myDebtor &lt;&gt; null, "PROXY Contract DEBTOR is null");
	
	
	assertTrueMsg(pxyCon &lt;&gt; null,"AAA Pxy CONTRACT not created");
	assertTrueMsg(pxyCon.contractId = CONTRACTID, "AAA Proxy Contract Id should be " &amp; CONTRACTID &amp; ", it is &gt;&gt;&gt;" &amp; pxyCon.contractId &amp; "&lt;&lt;&lt;");
	
	pxyCon.setProxy(false,CONTRACTID, fromTS, toTS, false, bank, terminal, debtor, "Generated By Unit Test");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Debto_must_have_least_prima_co); // ### TFS BUG 60627 16NOV2023 NAVAB1
	
	
	app.myTrxUA.trxUpdateInvContract(pxyCon,app.myPassport, false);
	self.assertTrueMsg(realCon.contractId = CONTRACTID, "Contract Id should be " &amp; CONTRACTID &amp; ", it is &gt;&gt;&gt;" &amp; realCon.contractId &amp; "&lt;&lt;&lt;");
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Expected NO PRIMARY error");// ### TFS BUG 60627 16NOV2023 NAVAB1
	// ### TFS BUG 60627 16NOV2023 NAVAB1assertTrueMsg(realCon.primary = false, "Contract should not be PRIMARY");
	
	/*  // ### TFS BUG 60627 16NOV2023 NAVAB1 cannot delete primary, and now there must be at least one primary
	// ### SHOULD BE ABLE TO DELETE NOW
	self.clearExpectedTrxErrors();
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	*/
	delete pxyCon;

	// ### CREATE CONTRACT with WRONG DATES
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoi_contr_from_date_time_can); 
	self.expectedTrxErrors.add(Invoi_contr_date_time_canno_be); 

	create pxyCon transient;
	pxyCon.setProxy(true,CONTRACTID2, toTS, fromTS, true, bank, terminal, debtor, "Generated By Unit Test");
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	
	self.assertEqualMsg(realCon, null, "No errors! contract should not have been created");
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected From/To date order error");

	
	// ### Set dates so that they overlapp other primary contract - should get error
	// ### TFS BUG 60627 16NOV2023 NAVAB1
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-4);
	toTS := fromTS.addDays(6);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Debtor_already_primary_contrac); 
	pxyCon.setProxy(true,CONTRACTID2, fromTS, toTS, true, bank, terminal, debtor, "Generated By Unit Test");
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected From/To date order error");
	
	
	
	// ### TFS BUG 60627 16NOV2023 NAVAB1
	// ### Set dates correctly so contract is created
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-12);
	toTS := fromTS.addDays(6);

	self.clearExpectedTrxErrors();
	pxyCon.setProxy(true,CONTRACTID2, fromTS, toTS, true, bank, terminal, debtor, "Generated By Unit Test");
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	delete pxyCon;
	
	
	// ### UPDATE CONTRACT TO MAKE NULL DATES
	beginLoad;
	pxyCon := realCon.pxyCreateUpdateProxy();
	endLoad;
	assertTrueMsg(pxyCon&lt;&gt; null,"BBB Pxy CONTRACT not created");
	
	assertTrueMsg(pxyCon.contractId = CONTRACTID2, "BBB Proxy Contract Id should be " &amp; CONTRACTID2 &amp; ", it is &gt;&gt;&gt;" &amp; pxyCon.contractId &amp; "&lt;&lt;&lt;");
	
	pxyCon.setProxy(false,CONTRACTID2, null, null, false, bank, terminal, debtor, "Generated By Unit Test");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoi_contr_from_date_time_mus); 
	self.expectedTrxErrors.add(Invoi_contr_date_time_must_ent); 

	app.myTrxUA.trxUpdateInvContract(pxyCon,app.myPassport, false);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected From/To null date error");
	
	// ### Correct the dtes so that we can delete the contract next
	pxyCon.setProxy(false,CONTRACTID2, fromTS, toTS, false, bank, terminal, debtor, "Generated By Unit Test");
	
	self.clearExpectedTrxErrors();
	app.myTrxUA.trxUpdateInvContract(pxyCon,app.myPassport, false);

	// ### TIDY UP AFTERWARDS
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();

epilog
	delete oArray;
	delete pxyCon;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdDetailVerify" id="a1df8f45-4b7a-4e5f-a50c-bcca7cb33234">
        <updating/>
        <source>tContractVolBsdDetailVerify() updating;
/*
Purpose:			

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

constants
	CONTRACTID = "UT_221206-01";
vars
	pxyCon, realCon : CM_InvoiceContract;
	pxyConDtl, realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	oArray : ObjectArray; 
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	yaPurge : CM_ObjectSet;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;


	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	realConDtl := self.createContractDetailVolBased(realCon, operator,criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT04"); // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;
	
	// ### TRY TO UPDATE DETAIL with wrong contract type
	beginLoad;
	pxyConDtl := realConDtl.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(pxyConDtl.myInvoiceContract &lt;&gt; null, "PROXY Rate Contract is null");
	assertTrueMsg(pxyConDtl.myInvoiceLineType &lt;&gt; null, "PROXY Invoice Line Type is null");
	assertTrueMsg(pxyConDtl.myCalculationType &lt;&gt; null, "PROXY Calculation Type is null");
	
	
	assertTrueMsg(pxyConDtl &lt;&gt; null,"AAA Pxy CONTRACT DETAIL not created");
	assertTrueMsg(pxyConDtl.contractType = INV_CONTRACT_TYPE_VOLUME_BASED, "AAA Proxy Contract type should be " &amp; INV_CONTRACT_TYPE_VOLUME_BASED.String &amp; ", it is &gt;&gt;&gt;" &amp; pxyConDtl.contractType.String &amp; "&lt;&lt;&lt;");
	//pxyConDtl.setProxy(99,123, fromTS, toTS,calcType,realCon,invLineType100, realCon.myBusinessUnit, null); //08/02/2023 TFS 55650 TASK 55702 
	pxyConDtl.setProxy(null,99,123, fromTS, toTS,calcType,realCon,invLineType100, realCon.myBusinessUnit, null,null); //08/02/2023 TFS 55650 TASK 55702 

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Contra_detail_type_invali_shou); 
	
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected contract detail TYPE error");
	
	
	// ### TRY TO UPDATE DETAIL with null contract, calc type and invoice line type references
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Calcu_type_contr_detai_must_en); 
	self.expectedTrxErrors.add(Contra_must_given_contra_detai); 
	self.expectedTrxErrors.add(Invoi_line_type_contr_detai_mu); 

	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_VOLUME_BASED,123, fromTS, toTS,null,null,null, realCon.myBusinessUnit, null,null); //55702
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail REFERENCES error");
	
	// ### TRY TO UPDATE DETAIL with wrong dates
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Contr_detai_from_datet_must_wi); 
	self.expectedTrxErrors.add(Contr_detai_datet_must_withi_c); 

	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_VOLUME_BASED,123, fromTS.addDays(-1), toTS.addDays(3),calcType,realCon,invLineType100, realCon.myBusinessUnit, null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_VOLUME_BASED,123, fromTS.addDays(-1), toTS.addDays(3),calcType,realCon,invLineType100, realCon.myBusinessUnit, null,null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail DATE TIME error");
	
	// ### UPDATE DETAIL with new priority
	self.clearExpectedTrxErrors();
	
	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_VOLUME_BASED,456, fromTS, toTS,calcType,realCon,pxyConDtl.myInvoiceLineType, realCon.myBusinessUnit, null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_VOLUME_BASED,456, fromTS, toTS,calcType,realCon,pxyConDtl.myInvoiceLineType, realCon.myBusinessUnit, null,null); //09/02/2023 navmv20 TFS 55650 TASK 55702
	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
//	realCon.inspectModal();
	
	// ### TIDY UP - Delete the contract, parent&gt;child will delete the details, rates and rate entries
	app.myTrxDA.trxDeleteInvContract(realCon, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	
	self.deleteUTInvoiceLineTypes();
	self.deleteInvoiceService("UT_ServiceContract-1",0);
	self.deleteInvoiceService("UT_ServiceContract-2",0);
	self.deleteInvoiceType("UT_InvTypeContract");
	self.deleteInvoiceLineType("UT_LineTypeContract",0);
epilog
	delete pxyCon;
	delete services;
	delete pxyConDtl;
	delete oArray;
	delete criteriaCargoTypes;
	if yaPurge &lt;&gt; null then
		yaPurge.purge;
		delete yaPurge;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdPERRteEntCheck1" id="0811d73a-f7ab-49b1-9e8b-bd648da60e43">
        <updating/>
        <source>tContractVolBsdPERRteEntCheck1() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by period, so there should be only one set of accumulated total for weight, volume, quantity and TEU, no matter how many vessel visits.
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should only be 1 accumulation object.

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699 
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD, true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;

		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 1 is null");
	self.assertTrueMsg(accum.myVoyage = null, "Voyage on accumulation 1 should be null");
	self.assertTrueMsg(accum.myVessel = null, "Vessel on accumulation 1 should be null");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 1 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2,aPort, 15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = null, "Voyage on accumulation 2 should be null");
	self.assertTrueMsg(accum.myVessel = null, "Vessel on accumulation 2 should be null");
	self.assertTrueMsg(accum.accumulatedQuantity = 50010, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 50010, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 70000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 300000, "Accum WGT on accumulation 2 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();

//	self.writeInvLineCharges(tis, tis2,accum);

	idx := 1;
	foreach ti in tis do
			invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage but only one accumulation so 2nd voyage uses only top rate
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
		
		charge := invLine.charges.first;
		assertTrueMsg(charge.getRate() = 910.12, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		idx := idx + 1;
	endforeach;
	
	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);

epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdPERRteEntCheck2" id="08ea56b7-f04d-44f6-b027-3e55c3df214d">
        <updating/>
        <source>tContractVolBsdPERRteEntCheck2() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by period, so there should be only one set of accumulated total for weight, volume, quantity and TEU, no matter how many vessel visits.
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should only be 1 accumulation object.
			In addition, this test creates 2 contracts one is an invalid primary and other is a invalid active that does not match cargo, so the code should switch to the standard NON contract rate

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699 
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	CONTRACTIDPRIM = "UT_221206-88";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl, realConDtlPrim : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
	roundDecimalOpt : Integer;
begin

	self.deleteTranMapTI(MapName);

	roundDecimalOpt := self.getTerminalConfig(InvoiceRoundLineTotal).Integer;
	self.setTerminalConfig(InvoiceRoundLineTotal,CMIF_ConfigTerminal.InvLineRound_Value_NoRound);

	app.myPassport.setMyTerminal(self.getTerminal());

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-200);
	toTS := fromTS.addDays(10);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE first CONTRACT that  does not match
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD,true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;

		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	

	// ### CREATE second CONTRACT that  does not match
	realCon := self.createContract(debtor, CONTRACTIDPRIM,true,true, fromTS, toTS, false);
	
	realConDtlPrim := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD, false,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type

	realRate := self.createContractRate(realConDtlPrim,service100);
	
	// ### CREATE RATE ENTRIES - needs lots of different date ranges for rates, becasue if forced to switch to us eprimary we must use the last valid rates.
	realRateEntry01 := self.createContractRateEntry(realRate,4,0,20000,realConDtlPrim.fromTS, realConDtlPrim.fromTS.addDays(2));
	realRateEntry02 := self.createContractRateEntry(realRate,3,20001,50000,realConDtlPrim.fromTS, realConDtlPrim.fromTS.addDays(2));
	realRateEntry03 := self.createContractRateEntry(realRate,2,50001,99999999,realConDtlPrim.fromTS, realConDtlPrim.fromTS.addDays(2));
	
	realRateEntry01 := self.createContractRateEntry(realRate,14,0,20000,realConDtlPrim.fromTS.addDays(3), realConDtlPrim.fromTS.addDays(5));
	realRateEntry02 := self.createContractRateEntry(realRate,13,20001,50000,realConDtlPrim.fromTS.addDays(3), realConDtlPrim.fromTS.addDays(5));
	realRateEntry03 := self.createContractRateEntry(realRate,12,50001,99999999,realConDtlPrim.fromTS.addDays(3), realConDtlPrim.fromTS.addDays(5));
	
	realRateEntry01 := self.createContractRateEntry(realRate,50,0,20000,realConDtlPrim.toTS.addDays(-2), realConDtlPrim.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,40,20001,50000,realConDtlPrim.toTS.addDays(-2), realConDtlPrim.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,30,50001,99999999,realConDtlPrim.toTS.addDays(-2), realConDtlPrim.toTS);
	
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum = null, "Accumulation 1 should be null");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 0,"Should be no accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2,aPort, 15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum = null, "Accumulation 2 should be null");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 0,"Should be no accumulation on detail");
	
	accum := realConDtlPrim.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum = null, "Accumulation PRIMARY should  be null");
	self.assertTrueMsg(realConDtlPrim.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 0,"Should be no accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();

//	self.writeInvLineCharges(tis, tis2,accum);

	idx := 1;
	foreach ti in tis do
			invLine := ti.invoiceLines.first;
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
		
		charge := invLine.charges.first;
		assertTrueMsg(charge.getRate() = 0.001, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 0.001, is " &amp; charge.getRate().String);
		
		if idx &gt; 5 then
			assertTrueMsg(charge.total = 5, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 5, is " &amp; charge.total.String);
		else
			assertTrueMsg(charge.total = 0.001, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 0.001, is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage but only one accumulation so 2nd voyage uses only top rate
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
		
		charge := invLine.charges.first;
		assertTrueMsg(charge.getRate() = 0.001, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 0.001, is " &amp; charge.getRate().String);
		
		if idx &gt; 5 then
			assertTrueMsg(charge.total = 5, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 5, is " &amp; charge.total.String);
		else
			assertTrueMsg(charge.total = 0.001, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 0.001, is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);
	
epilog
	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdPERRteEntCheck3" id="4c6f738d-c49a-426f-9156-c95e92795a99">
        <updating/>
        <source>tContractVolBsdPERRteEntCheck3() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by period, so there should be only one set of accumulated total for weight, volume, quantity and TEU, no matter how many vessel visits.
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should only be 1 accumulation object.
			the contract has several ranges by weight. Weights in MTN are always stored as KGs, so even if the calc type is MT this will only produce the quantity, the rate for weight will used the accumulated weight in KGs to find a rate from ranges of weights in KGs.
Date		Who		Reason
 // ### TFS BUG 57505 13APR2023 NAVAB1
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	CONTRACTIDPRIM = "UT_221206-88";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-100);
	toTS := app.actualTimeAppServer();
	toTS := toTS.addDays(100);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE first CONTRACT that  does match
	realCon := self.createContract(debtor, CONTRACTID,true,true, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD,true,"CCT08"); // Weight MT -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;

		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 1 should not be null");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should be an accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2,aPort, 15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 1 should not be null");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should be  accumulation on detail");
	
//	voyage.inspectModal;
//	realCon.inspectModal();

//	self.writeInvLineCharges(tis, tis2,accum);

	idx := 1;
	foreach ti in tis do
			invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 185.1, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 185.1, is " &amp; charge.total.String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 61.7, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 61.7, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 567.8, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 567.8, is " &amp; charge.total.String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 851.7, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 851.7, is " &amp; charge.total.String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 283.9, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 283.9, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 9101.2 , "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 9101.2 , is " &amp; charge.total.String);
		elseif idx &gt;= 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 13651.8, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 13651.8, is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage but only one accumulation so 2nd voyage uses only top rate
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
		
		charge := invLine.charges.first;
		assertTrueMsg(charge.getRate() = 910.12, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be  910.12, is " &amp; charge.getRate().String);
		assertTrueMsg(charge.total = 13651.8, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 13651.8, is " &amp; charge.total.String);
		idx := idx + 1;
	endforeach;

	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);
	
epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdPERRteEntCheck4" id="cfcc9285-8806-4eb6-b72a-bb24746161e7">
        <updating/>
        <source>tContractVolBsdPERRteEntCheck4() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by period, so there should be only one set of accumulated total for weight, volume, quantity and TEU, no matter how many vessel visits.
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should only be 1 accumulation object.
			
			However for bug 61115 there is no upper range with a max value e.g. 99999999999.

Date		Who		Reason
06NOV2023	NAVAB1	BUG 61115
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
	ServiceRate = 0.001;
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_PERIOD, true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;

		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(ServiceRate);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,60000,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 1 is null");
	self.assertTrueMsg(accum.myVoyage = null, "Voyage on accumulation 1 should be null");
	self.assertTrueMsg(accum.myVessel = null, "Vessel on accumulation 1 should be null");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 1 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2,aPort, 15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = null, "Voyage on accumulation 2 should be null");
	self.assertTrueMsg(accum.myVessel = null, "Vessel on accumulation 2 should be null");
	self.assertTrueMsg(accum.accumulatedQuantity = 50010, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 50010, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 70000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 300000, "Accum WGT on accumulation 2 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();

//	self.writeInvLineCharges(tis, tis2,accum);

	idx := 1;
	foreach ti in tis do
			invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;

			// #### Because there is no upper range it will use the rate from the rate table
			assertTrueMsg(charge.getRate() = ServiceRate, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be " &amp; ServiceRate.String &amp; ", is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage but only one accumulation so 2nd voyage uses only top rate
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
		
		charge := invLine.charges.first;

		// #### Because there is no upper range it will use the rate from the rate table
		assertTrueMsg(charge.getRate() = ServiceRate, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be " &amp; ServiceRate.String &amp; ", is " &amp; charge.getRate().String);
		idx := idx + 1;
	endforeach;
	
	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);

epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdVOYRteEntCheck1" id="b289ec7d-5b18-4ca5-85b2-07d100463802">
        <updating/>
        <source>tContractVolBsdVOYRteEntCheck1() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by voyage, so each voyage has it own set of accumulated total for weight, volume, quantity and TEU
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should be 2 accumulations.

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-01";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation1 is null");
	self.assertTrueMsg(accum.myVoyage = voyage, "Voyage on accumulation 1 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 1 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = voyage2, "Voyage on accumulation 2 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 2 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 2,"Should only be 2 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();
//	self.writeInvLineCharges(tis, tis2,accum);

	
	idx := 1;
	foreach ti in tis do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx &gt;= 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 910.12, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage so the accumulations should be the same as voyage 1.
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "2. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx &gt;= 5 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 910.12, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);

	
epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdVOYRteEntCheck2" id="7c365cd6-2d93-488e-bc27-6fe9a2ecb2bc">
        <updating/>
        <source>tContractVolBsdVOYRteEntCheck2() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by voyage, so each voyage has it own set of accumulated total for weight, volume, quantity and TEU
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should be 2 accumulations.

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-01";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03, realRateEntry04, realRateEntry05 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,80,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,70,20001,25000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,60,25001,32000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,50,32001,35000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,40,35001,36500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,30,36501,38500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,20,38501,39500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,10,39501,45000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,9,45001,47800,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,8,47801,75000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,7,75001,120000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,6,120001,9999999,realConDtl.fromTS, realConDtl.toTS);
	
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,11000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,2500);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation1 is null");
	self.assertTrueMsg(accum.myVoyage = voyage, "Voyage on accumulation 1 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 67500.0000, "Accum WGT on accumulation 1 is wrong, should be 67500.0000, is " &amp; accum.accumulatedWeight.String);
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,12000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2, aPort,1500);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = voyage2, "Voyage on accumulation 2 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 67500.0000, "Accum WGT on accumulation 2 is wrong, should be 67500.0000, is " &amp; accum.accumulatedWeight.String);
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 2,"Should only be 2 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();
//	self.writeInvLineCharges(tis, tis2,accum);

	
	idx := 1;
	foreach ti in tis do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 880000, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 880,000 , is " &amp; charge.total.String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 720000, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 720,000 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 70.00, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 140000, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 140,000 , is " &amp; charge.total.String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 3, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 3, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 70.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 210000, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 210,000 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 50.00, "1. 3rd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 50000, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50,000 , is " &amp; charge.total.String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 5, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 50.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 100000, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 100,000 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 10.00, "1. 5th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 45000, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 45,000 , is " &amp; charge.total.String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 3, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 3, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 10.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 10000 , "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10,000 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 8.00, "1. 3rd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 57600, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 57,600  , is " &amp; charge.total.String);
		elseif idx &gt; 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 20000, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 20,000, is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage so the accumulations should be the same as voyage 1.
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "2. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 960000, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 960,000, is " &amp; charge.total.String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 640000, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 640,000, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 70.00, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 280000, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 280,000, is " &amp; charge.total.String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 4, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 4, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 70.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 70000, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70,000, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 40.00, "2. 4th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 40000, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40,000, is " &amp; charge.total.String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 6, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 6, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 40.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 20000, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 20,000, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 8.00, "2. 6th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 1600, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1600, is " &amp; charge.total.String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 96000, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 96,000 , is " &amp; charge.total.String);
		elseif idx &gt; 5 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 12000, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12,000 , is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);
	
	
epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdVOYRteEntCheck3" id="98336843-ce03-4661-869a-426c774e0086">
        <updating/>
        <source>tContractVolBsdVOYRteEntCheck3() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by voyage, so each voyage has it own set of accumulated total for weight, volume, quantity and TEU
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should be 2 accumulations.

Date		Who		Reason
 // ### TFS BUG 57505 13APR2023 NAVAB1
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-01";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03, realRateEntry04, realRateEntry05 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT08"); // Weight MT -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(0.001);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,80,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,70,20001,25000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,60,25001,32000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,50,32001,35000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,40,35001,36500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,30,36501,38500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,20,38501,39500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,10,39501,45000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,9,45001,47800,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,8,47801,75000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,7,75001,120000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,6,120001,9999999,realConDtl.fromTS, realConDtl.toTS);
	
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,11000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,2500);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation1 is null");
	self.assertTrueMsg(accum.myVoyage = voyage, "Voyage on accumulation 1 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 67500.0000, "Accum WGT on accumulation 1 is wrong, should be 67500.0000, is " &amp; accum.accumulatedWeight.String);
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,12000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2, aPort,1500);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = voyage2, "Voyage on accumulation 2 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 67500.0000, "Accum WGT on accumulation 2 is wrong, should be 67500.0000, is " &amp; accum.accumulatedWeight.String);
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 2,"Should only be 2 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();
//	self.writeInvLineCharges(tis, tis2,accum);

	
	idx := 1;
	foreach ti in tis do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 880, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 880 , is " &amp; charge.total.String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 720, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 720 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 70.00, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 140, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 140 , is " &amp; charge.total.String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 3, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 3, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 70.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 210, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 210 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 50.00, "1. 3rd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 50, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50 , is " &amp; charge.total.String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 5, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 50.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 50.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 100, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 100 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 10.00, "1. 5th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 45, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 45 , is " &amp; charge.total.String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 3, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 3, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 10.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 10 , "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 10 , is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 8.00, "1. 3rd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 57.6, "1. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 57  , is " &amp; charge.total.String);
		elseif idx &gt; 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 20, "1. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 20, is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage so the accumulations should be the same as voyage 1.
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "2. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 960, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 960, is " &amp; charge.total.String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 80.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 80.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 640, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 640, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 70.00, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 280, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 280, is " &amp; charge.total.String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 4, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 4, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 70.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 70, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 70, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 40.00, "2. 4th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 40, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40, is " &amp; charge.total.String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 6, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 6, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 40.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 40.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 20, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 20, is " &amp; charge.total.String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 8.00, "2. 6th Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 1.6, "2. Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1.6, is " &amp; charge.total.String);
		elseif idx = 5 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 96, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 96 , is " &amp; charge.total.String);
		elseif idx &gt; 5 then
			assertTrueMsg(invLine.charges.size = 1, "2. number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 8.00, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 8.00, is " &amp; charge.getRate().String);
			assertTrueMsg(charge.total = 12, "2. 1st Total for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12 , is " &amp; charge.total.String);
		endif;
		idx := idx + 1;
	endforeach;


	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);
	
	
epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tContractVolBsdVOYRteEntCheck4" id="662379ac-9a63-4018-aebf-c763e9782862">
        <updating/>
        <source>tContractVolBsdVOYRteEntCheck4() updating;
/*
Purpose:	Volume based contracts accumulate the cargo weight, quantity etc and use that accumulated amount to derive  a rate	
			This contract accumulates by voyage, so each voyage has it own set of accumulated total for weight, volume, quantity and TEU
			This test creates 2 voyages with cargo onboard, discharges all cargo and checks the accumulations and the rates used. There should be 2 accumulations.
			
			However for bug 61115 there is no upper range with a max value e.g. 99999999999.

Date		Who		Reason
06NOV2023	NAVAB1	BUG 61115
*/

constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-01";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";
	ServiceRate = 0.001;
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	product : CM_Product;
	terminal : CM_Terminal;
	vessel : CM_Vessel;
	voyage, voyage2 : CM_Voyage;
	aPort : CM_Port;
	lc : CM_LocationsController;
	idx : Integer;
	rateEntry : CM_RateEntry;
	ti : CM_TrackedItem;
	tis, tis2 : CM_TISet;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	charge : CM_Charge;
	accum : CM_InvoiceContractAccumulate;
begin
	app.myPassport.setMyTerminal(self.getTerminal());

	self.deleteTranMapTI(MapName);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);
	fromTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1
	toTS.cnZeroSeconds(); // ### TFS BUG 61096 21NOV2023 NAVAB1

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,true,false, fromTS, toTS, true);

	// ### CREATE A CONTRACT DETAIL VOLUME BASED
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	// ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1 cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	cargoType := self.addNewCargoType(); // ### TFS CR 61579 TASK 62473 14FEB2024 NAVAB1
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	criteriaCargoTypes.add(contType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	
	
	realConDtl := self.createContractDetailVolBased(realCon,operator, criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT04"); // Weight KG -  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	invLineType100 := realConDtl.myInvoiceLineType;
	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
		
	self.tranMapLoadReceived();

	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(ServiceRate);
	commitTransaction;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,12.34,0,20000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,56.78,20001,50000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,910.12,50001,60000,realConDtl.fromTS, realConDtl.toTS);
	
	// ### TRY to UPDATE 2nd ENTRY WITH WRONG RANGES
	beginLoad;
	pxyRateEntry := realRateEntry02.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(realRateEntry02.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry,Rate is null");
	//pxyRateEntry.setProxy(pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 TFS 55650 TASK 55702
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,99,510,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realCon.myBusinessUnit); //08/02/2023 TFS 55650 TASK 55702
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(QuantityRangeConflict); 
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected error WRONG RANGE 2 error");
	assertNoTrxErrorsOrWarnings();
	delete pxyRateEntry;
	
	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 9999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID1 &amp; idx.String, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID1 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.first;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation1 is null");
	self.assertTrueMsg(accum.myVoyage = voyage, "Voyage on accumulation 1 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 1 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 1 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 1,"Should only be 1 accumulation on detail");
		
	// ### CREATE CARGO ONSHIP FOR VOYAGE TWO READY FOR RECEIVAL
	voyage2	:= self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	create tis2 transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip(CONTRACTID, CONTID2 &amp; idx.String, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	foreach idx in 1 to 5 do
		ti := self.createGCOnShip(CONTRACTID, CARGOID2 &amp; idx.padPrefixZeros(3), cargoType, operator, voyage2, aPort,15000);
		tis2.add(ti);
	endforeach;
	
	
	self.moveAllCargo(voyage2,bs1.myLocationsController);
	
	accum := realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.last;
	self.assertTrueMsg(accum &lt;&gt; null, "Accumulation 2 is null");
	self.assertTrueMsg(accum.myVoyage = voyage2, "Voyage on accumulation 2 is wrong");
	self.assertTrueMsg(accum.myVessel = vessel, "Vessel on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedQuantity = 25005, "Accum QTY on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedTEU = 25005, "Accum TEU on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedVolume = 35000, "Accum VOL on accumulation 2 is wrong");
	self.assertTrueMsg(accum.accumulatedWeight = 150000, "Accum WGT on accumulation 2 is wrong");
	self.assertTrueMsg(realConDtl.CM_InvoiceContractDtlsVolBased.allAccumulationsByType.size = 2,"Should only be 2 accumulation on detail");
	
	
//	voyage.inspectModal;
//	realCon.inspectModal();
//	self.writeInvLineCharges(tis, tis2,accum);

	
	idx := 1;
	foreach ti in tis do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "1. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "1. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx &gt;= 5 then
			assertTrueMsg(invLine.charges.size = 1, "1.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			
			// #### Because there is no upper range it will use the rate from the rate table
			assertTrueMsg(charge.getRate() = ServiceRate, "1. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be " &amp; ServiceRate.String &amp; ", is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	// different voyage so the accumulations should be the same as voyage 1.
	idx := 1;
	foreach ti in tis2 do
		invLine := ti.invoiceLines.first;
		if idx = 1 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "2. Rate for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
		elseif idx = 2 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 12.34, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 12.34, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 56.78, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 3 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
		elseif idx = 4 then
			assertTrueMsg(invLine.charges.size = 2, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 2, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;
			assertTrueMsg(charge.getRate() = 56.78, "2. 1st Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 56.78, is " &amp; charge.getRate().String);
			charge := invLine.charges.last;
			assertTrueMsg(charge.getRate() = 910.12, "2. 2nd Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be 910.12, is " &amp; charge.getRate().String);
		elseif idx &gt;= 5 then
			assertTrueMsg(invLine.charges.size = 1, "2.number of charges for TI " &amp; idx.String &amp; " (" &amp; ti.id &amp; ") is wrong, should be 1, is " &amp; invLine.charges.size.String);
			charge := invLine.charges.first;

			// #### Because there is no upper range it will use the rate from the rate table
			assertTrueMsg(charge.getRate() = ServiceRate, "2. Rate for TI " &amp; idx.String  &amp; " (" &amp; ti.id &amp; ") is wrong, should be " &amp; ServiceRate.String &amp; ", is " &amp; charge.getRate().String);
		endif;
		idx := idx + 1;
	endforeach;

	self.deleteUTInvoiceLineTypes();
	self.deleteAllContractsForDebtor(debtor);

	
epilog
	self.resetDefaultTranMap();
	delete pxyRateEntry;
	delete tis;
	delete tis2;
	delete criteriaCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadMove" id="27a22b45-05da-42ac-b14a-5bbbf007f72c">
        <source>tranMapLoadMove();

/*  // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1

Purpose:		


*/
constants

	FileName					: String = "MoveMDH";
	MapName						: String = "UT_MoveMDH";

vars

	bank						: CM_Bank;
	cargoMap					: CM_TranMap;
		
	fileContent					: String;
	fileName					: String;


begin

	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
		'Cargo,'&amp;MapName&amp;',CANNONBALL| Cannon Balls,(Default),12POUNDER-12,Import,(Default),(Default),(Move),Road -&gt; Yard,(Default),(Default) ›,(Default),All,UT_ABCInvLineType1' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.getTerminal().getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[MapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadReceive" id="07c4914d-364a-4f17-84ec-f6bc41421413">
