<GUIClass name="CMUI_PickerButton" id="d093bc33-c908-4c09-aaa8-c273dd9bd6bb">
    <superclass name="CMUI_Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used for starters in CMUI_MonthPicker</text>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myMonthPicker" id="b3c80639-8493-4751-8b0b-a9666d2caf07">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CMUI_MonthPicker"/>
        <access>protected</access>
        <Inverse name="CMUI_MonthPicker::myPreviousYearBtn"/>
        <Inverse name="CMUI_MonthPicker::myPreviousMonthBtn"/>
        <Inverse name="CMUI_MonthPicker::myNextYearBtn"/>
        <Inverse name="CMUI_MonthPicker::myNextMonthBtn"/>
    </ExplicitInverseRef>
    <JadeMethod name="click" id="ffa5e475-3d68-43d6-aaa4-53a0bd580c01">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
/*

Date		    Who			Reason
28 October 2010	cnwas3	  Initial creation

*/

vars

begin
	if self.myMonthPicker &lt;&gt; null then
		self.myMonthPicker.handleButtonClick(btn.CMUI_PickerButton);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
