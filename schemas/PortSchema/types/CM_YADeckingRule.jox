    <JadeMethod name="getDeckingSequence" id="44b14582-1159-4249-bf6d-00a21f1f9f29">
        <source>getDeckingSequence(_gridController : CM_GridController ;
						_columns,
						_rows,
						_stackHeight,
						_rowOffset,
						_columnOffset : Integer) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwer1	Initial creation CCMS 1025

*/

vars
	sequencer : CMIF_DeckingSequenceService;
	deckingRule : CM_YADeckingRule;
	theRow,
	theColumn : Integer;
begin
	create sequencer transient;
	sequencer.onCreate(self.areaRule);
	
	sequencer.setExtent(_columns,_rows,_stackHeight);
	sequencer.setRules(self.stackRule, self.rowRule, self.patternRule);
	
	theRow:=_gridController.row - _rowOffset + 1;
	theColumn:=_gridController.column - _columnOffset + 1;
	
	return sequencer.getStackingSequence(theColumn,theRow,_stackHeight);
	
	
epilog	
	delete sequencer;


end;</source>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stackHeight" type="Integer"/>
        <Parameter name="_rowOffset" type="Integer"/>
        <Parameter name="_columnOffset" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDirection" id="bd6b309f-0be3-4ccd-a33f-da267b26aee1">
        <source>getDirection(_topHeightForRule: Boolean): Integer;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if  self.deckingRuleType = Height_Then_Next_Row_Pos then
		if _topHeightForRule then
			return Decking_Right;
		else
			return Decking_Up;
		endif;
	
	elseif  self.deckingRuleType = Height_Then_Prev_Row_Pos then
		if _topHeightForRule then
			return Decking_Left;
		else
			return Decking_Up;
		endif;
	
	elseif  self.deckingRuleType = Layer_Then_First_Row_Pos then
		return Decking_Right;

	elseif  self.deckingRuleType = Layer_Then_Last_Row_Pos then
		return Decking_Left;

	else
		return null;
	endif;

end;</source>
        <Parameter name="_topHeightForRule" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReverseRule" id="10f2f4df-d5e1-4926-950b-dfb4fcd0cfc3">
        <source>getReverseRule(): Integer;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule	: CM_YADeckingRule;
begin

	if self.deckingRuleType = DeckingRule_Default then
		rule := self.myYADeckingOptions.getNextLevelRule(self.heightFrom, self.isINRule);
		if rule = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'cannot find a specific rule for area');
			return DeckingRule_Null;
		else
			rule.getReverseRule();
		endif;
		
	elseif  self.deckingRuleType = Height_Then_Next_Row_Pos then
		return Height_Then_Prev_Row_Pos;

	elseif  self.deckingRuleType = Height_Then_Prev_Row_Pos then
		return Height_Then_Next_Row_Pos;

	elseif  self.deckingRuleType = Layer_Then_First_Row_Pos then
		return Layer_Then_Last_Row_Pos;

	elseif  self.deckingRuleType = Layer_Then_Last_Row_Pos then
		return Layer_Then_First_Row_Pos;

	elseif  self.deckingRuleType = Height_Then_Next_Col_Pos then
		return Height_Then_Prev_Col_Pos;

	elseif  self.deckingRuleType = Height_Then_Prev_Col_Pos then
		return Height_Then_Next_Col_Pos;

	elseif  self.deckingRuleType = Layer_Then_First_Col_Pos then
		return Layer_Then_Last_Col_Pos;

	elseif  self.deckingRuleType = Layer_Then_Last_Col_Pos then
		return Layer_Then_First_Col_Pos;

	elseif  self.deckingRuleType = DeckingRule_ReverseOfOther then
		return DeckingRule_ReverseOfOther;

	else
		//invalid for reversing
		app.raiseUnexpectedProgramError(class.name, method.name, 'this type of decking rule cannot be reversed');
		return self.deckingRuleType;
	endif;
	
	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSideAccess" id="d3257eae-1aef-4593-acfa-d39429363f60">
        <source>getSideAccess(_currentGridController: CM_GridController;		
				_allGridRows  :CM_GridRowDict;
				_allGridColumns : CM_GridColumnDict;
				_minHeight,
				_maxHeight : Integer) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwer1	Initial creation

*/

vars

	firstGCInColumn,
	lastGCInColumn : CM_GridController;
	firstColDeckingSeq,
	lastColDeckingSeq,
	column,
	middleRow,
	rows,
	columns,
	firstColumn,
	firstRow,
	tiers: Integer;
begin


	
	if _allGridRows.isEmpty then
		return CM_YABlock.SideAccess_NA;
	endif;
	
	if _currentGridController = null then
		return CM_YABlock.SideAccess_NA;
	endif;
	
	
	column := _currentGridController.column;
	
	firstGCInColumn:=_allGridRows.first.CM_GridRow.allControllersByColumn[column];
	lastGCInColumn:=_allGridRows.last.CM_GridRow.allControllersByColumn[column];
	
	
	
	if self.rowRule = DeckingRule_MiddleOut then
		//find the middle row check if 
		middleRow:=(_allGridRows.size/2).roundedTo(0).Integer;
		middleRow:=_allGridRows[_allGridRows.first.row + middleRow].row;
		if _currentGridController.row &gt; middleRow then
			return CM_YABlock.SideAccess_Front;  //epr par 33771 28/3/14 was Back
		elseif 	_currentGridController.row &lt; middleRow then
			return CM_YABlock.SideAccess_Back; //epr par 33771 28/3/14 was front
		elseif _currentGridController.row = middleRow then
			return CM_YABlock.SideAccess_Both;
		endif;
		

	else
	
		rows:=_allGridRows.size;
		columns:=_allGridColumns.size;
		firstColumn:=_allGridColumns.first.column;
		firstRow:=_allGridRows.first.row;
		//epr par 23403 25/3/10
		tiers:=(_maxHeight-_minHeight) +1;
		firstColDeckingSeq:= self.getDeckingSequence(firstGCInColumn,columns,rows,tiers,firstRow,firstColumn);
		lastColDeckingSeq:= self.getDeckingSequence(lastGCInColumn,columns,rows,tiers,firstRow,firstColumn);
		
		//ACCESS FRONT IS ACCESS FROM THE LAST ROW TO THE FIRST ROW
		if firstColDeckingSeq &lt; lastColDeckingSeq then
			return CM_YABlock.SideAccess_Front;
		else
			return CM_YABlock.SideAccess_Back ;
		endif;
	endif;	
	
	return CM_YABlock.SideAccess_NA;

epilog

end;</source>
        <Parameter name="_currentGridController" type="CM_GridController"/>
        <Parameter name="_allGridRows" type="CM_GridRowDict"/>
        <Parameter name="_allGridColumns" type="CM_GridColumnDict"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="797cec36-c0d0-478c-a099-7776764e1e34">
        <source>getTableDisplay(): String;
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.isINRule then
		return self.heightFrom.String &amp; " - " &amp; self.heightTo.String &amp; Tab &amp; app.getDeckingInCaption(DeckingMenuOffset_In + app.getDeckingMenuIndexFromOption(self.deckingRuleType));
	else
		return self.heightFrom.String &amp; " - " &amp; self.heightTo.String &amp; Tab &amp; app.getDeckingOutCaption(DeckingMenuOffset_Out + app.getDeckingMenuIndexFromOption(self.deckingRuleType));
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAdvancedRule" id="76dfd951-f85f-468e-9017-9b08dc074060">
        <source>isAdvancedRule(): Boolean;
//05 January 2009	cnwdw1	
//
vars

begin
	return self.deckingRuleType = DeckingRule_Advanced;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCustom" id="cba2c935-c8e3-4eea-ad96-33cbaa1e28da">
        <source>isCustom(): Boolean;
//05 January 2009	cnwdw1	
//
vars

begin
	return self.areaRule = DeckingRule_Custom;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOUTRule" id="92417085-d8c0-456f-b055-6e7f7602c1dd">
        <methodInvocation>mapping</methodInvocation>
        <source>isOUTRule(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		_value := (not self.isINRule);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7a2b0382-a4cb-42f2-b85c-c11dc1c68beb">
        <updating/>
        <source>setForCreate(_pxyDeckingRule: CM_YADeckingRule)updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.deckingRuleType	:= _pxyDeckingRule.deckingRuleType;
	self.heightFrom			:= _pxyDeckingRule.heightFrom;
	self.heightTo			:= _pxyDeckingRule.heightTo;
	self.isINRule			:= _pxyDeckingRule.isINRule;
	self.areaRule			:= _pxyDeckingRule.areaRule;
	self.stackRule			:= _pxyDeckingRule.stackRule;
	self.rowRule			:= _pxyDeckingRule.rowRule;
	self.patternRule		:= _pxyDeckingRule.patternRule;
	self.topupTier			:= _pxyDeckingRule.topupTier;

end;</source>
        <Parameter name="_pxyDeckingRule" type="CM_YADeckingRule"/>
    </JadeMethod>
    <JadeMethod name="setHeights" id="969d078e-9508-4201-95f4-bf9bcd051ff5">
        <updating/>
        <source>setHeights(_from, _to: Integer) updating;
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	terminalArea		: CM_TerminalArea;
	taStr				: String;
begin
	
	if _from &gt; _to then
		terminalArea := self.myYADeckingOptions.getTerminalArea();
		if terminalArea = null then
			taStr := self.myYADeckingOptions.getDisplayString;
		else
			taStr := terminalArea.id;
		endif;
		app.raiseCMException2(INVALID_HEIGHT_RANGE, self.deckingRuleType.String, taStr, null, null);
	endif;
	
	self.heightFrom := _from;
	self.heightTo	:= _to;

end;</source>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="13bbf704-3b13-416f-a16a-ffaf8cd03c07">
        <updating/>
        <source>setProxy(_isIn: Boolean; _areaRule, _stackRule, _rowRule, _patternRule: Integer; _topupTier: Integer) updating;
//31 December 2008	cnwdw1	
//
begin
	self.deckingRuleType := DeckingRule_Advanced;
	self.isINRule := _isIn;
	self.areaRule := _areaRule;
	self.stackRule := _stackRule;
	self.rowRule := _rowRule;
	self.patternRule := _patternRule;
	self.topupTier := _topupTier;
end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_areaRule" type="Integer"/>
        <Parameter name="_stackRule" type="Integer"/>
        <Parameter name="_rowRule" type="Integer"/>
        <Parameter name="_patternRule" type="Integer"/>
        <Parameter name="_topupTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyAndRuleType" id="42a4b9b0-971b-45c6-8267-1d7c8e2320d2">
        <updating/>
        <source>setProxyAndRuleType(_ruleType: Integer; _isIn: Boolean; _areaRule, _stackRule, _rowRule, _patternRule: Integer; _topupTier: Integer) updating;
//31 December 2008	cnwdw1	
//
begin
	self.deckingRuleType := _ruleType;
	self.areaRule := _areaRule;
	self.stackRule := _stackRule;
	self.rowRule := _rowRule;
	self.patternRule := _patternRule;
	self.topupTier := _topupTier;
	if self.heightFrom = 0 then
		self.heightFrom := 1;
	endif;
	if self.heightTo = 0 then
		self.heightTo := self.myYADeckingOptions.getStackHeight();	
	endif;
	self.isINRule := _isIn;
end;</source>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_areaRule" type="Integer"/>
        <Parameter name="_stackRule" type="Integer"/>
        <Parameter name="_rowRule" type="Integer"/>
        <Parameter name="_patternRule" type="Integer"/>
        <Parameter name="_topupTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyBasic" id="ef3240b8-54b3-412f-a90b-7020de426466">
        <updating/>
        <source>setProxyBasic(_ruleType, _heightFrom, _heightTo: Integer; _isIn: Boolean) updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// Convert the basic rule is to an advanced rule bfeore saving. 
vars

begin

	if _ruleType = Height_Then_Next_Row_Pos then   // 1
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	elseif _ruleType = Height_Then_Prev_Row_Pos then   // 2
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByRow, DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Columnwise, 0);
	elseif _ruleType = Layer_Then_First_Row_Pos then  // 3
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise, 0);
	elseif _ruleType = Layer_Then_Last_Row_Pos then  // 4
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByRow, DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Tierwise, 0);
	
	elseif _ruleType = Height_Then_Next_Col_Pos then   // 5
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	elseif _ruleType = Height_Then_Prev_Col_Pos then   // 6
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByStack, DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Columnwise, 0);
	elseif _ruleType = Layer_Then_First_Col_Pos then  // 7
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise, 0);
	elseif _ruleType = Layer_Then_Last_Col_Pos then  // 8
		self.setProxyAndRuleType(DeckingRule_Advanced, _isIn, DeckingRule_ByStack, DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Tierwise, 0);
	else
		self.deckingRuleType := _ruleType;
		self.isINRule := _isIn;
		if _heightFrom = null then
			self.heightFrom := 1;		
		else
			self.heightFrom := _heightFrom;
		endif;
		
		if _heightTo = null then
			self.heightTo := self.myYADeckingOptions.getStackHeight();		
		else
			self.heightTo := _heightTo;
		endif;
	endif;
end;</source>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_heightFrom" type="Integer"/>
        <Parameter name="_heightTo" type="Integer"/>
        <Parameter name="_isIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromOtherRule" id="8106abd4-a76b-4c4d-aa38-58baddcd9d03">
        <updating/>
        <source>setProxyFromOtherRule(_rule: SelfType) updating;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.deckingRuleType 	:= _rule.deckingRuleType;
	self.isINRule			:= _rule.isINRule;
	self.isOUTRule			:= _rule.isOUTRule;
	self.heightFrom			:= _rule.heightFrom;
	self.heightTo			:= _rule.heightTo;
	self.areaRule			:= _rule.areaRule;
	self.stackRule			:= _rule.stackRule;
	self.rowRule			:= _rule.rowRule;
	self.patternRule		:= _rule.patternRule;
end;</source>
        <Parameter name="_rule" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="validateForCustom" id="cd6cc124-c94c-4ec4-9aab-3dc740f7ba48">
        <source>validateForCustom();
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	termArea		: CM_TerminalArea;
	termAreaStr		: String;
	expectedFrom,
	expectedTo		: Integer;
begin

	if self.deckingRuleType &lt;&gt; DeckingRule_Custom then
		//not true custom but rather multi-rule custom
		return;
	endif;

	expectedFrom := 1;
	expectedTo := self.myYADeckingOptions.getStackHeight();
	

	if self.heightFrom &lt;&gt; expectedFrom
	or self.heightTo &lt;&gt; expectedTo then
		//error!
		termArea := self.myYADeckingOptions.getTerminalArea();
		if termArea = null then
			termAreaStr := self.myYADeckingOptions.getDisplayString;
		else
			termAreaStr := termArea.id;
		endif;
		app.raiseCMException4(INVALID_HEIGHTS_CUSTOM, termAreaStr, expectedFrom.String, expectedTo.String, self.heightFrom.String &amp;'-'&amp; self.heightTo.String, null, null);
		return;
	endif;

end;</source>
    </JadeMethod>
</Class>
