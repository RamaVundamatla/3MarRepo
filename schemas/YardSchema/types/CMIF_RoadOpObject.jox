    <JadeMethod name="getTableDisplayStrings" id="6da9e426-c327-48cf-a5ef-4cbd2ec0b87e">
        <source>getTableDisplayStrings(	_obj : CM_Object input; 
						_displayStrings : HugeStringArray input;
						_tableItems		: ObjectArray input) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	str : String;
begin
	str := _obj.getAttributeStringForDefArray(myDataTable.allTblDataEntRows);
	
	_displayStrings.add(str);
	_tableItems.add(_obj);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_displayStrings" type="HugeStringArray" usage="input"/>
        <Parameter name="_tableItems" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayStrings_TblObjs" id="d4eaea47-1eef-45d7-94c1-dc6ddff2cff8">
        <source>getTableDisplayStrings_TblObjs(_obj :CM_Object; _displayStrings : HugeStringArray input;
						_tableItems		: ObjectArray input) protected;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str				: String;
	tableObjects 	: ObjectArray;
	obj 			: Object;
	invalidObject	: Boolean;
begin	
	if _obj = null then
		return;
	endif;

	create tableObjects transient;
	
	self.getTableObjects(_obj, tableObjects);

	on Exception do app.handleDeletedObject (exception, obj, invalidObject);

	foreach obj in tableObjects do
		str := obj.CM_Object.getAttributeStringForDefArray(self.myDataTable.allTblDataEntRows);
		
		if invalidObject then
			// we got an exception in the previous line of code
			invalidObject := false;
			continue;
		endif;
		
		_displayStrings.add(str);
		_tableItems.add(obj);
	endforeach;
epilog
	delete tableObjects;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_displayStrings" type="HugeStringArray" usage="input"/>
        <Parameter name="_tableItems" type="ObjectArray" usage="input"/>
    </JadeMethod>
