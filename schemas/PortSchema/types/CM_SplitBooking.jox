<Class name="CM_SplitBooking" id="de50e427-2b4d-4587-8147-a934aa5d0806">
    <superclass name="CM_SplitRollBooking"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="getDisplayStringForAttribute" id="16fd6816-ed6d-43ae-8c8e-838e12d392da">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Mar 2012 from 27310, code recently added for RollBooking, do the same here
vars
	str : String;

begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 25/10/18 MAP TFS41191
		else
			if self.oldBookingReference &lt;&gt; self.newBookingReference then
				str := "Booking Reference " &amp; self.oldBookingReference &amp; " =&gt; " &amp; self.newBookingReference &amp; " ";
			endif;
			if self.oldDischargePort &lt;&gt; self.newDischargePort then
				str := str &amp; "Discharge Port " &amp; self.oldDischargePort &amp; " =&gt; " &amp; self.newDischargePort &amp; " ";
			endif;
			if self.oldVoyageCode &lt;&gt; self.newVoyageCode then
				str := str &amp; "Voyage " &amp; self.oldVoyageCode &amp; " = &gt; " &amp; self.newVoyageCode;
			endif;
			if self.remarks &lt;&gt; null then
				str := str &amp; " (" &amp; self.remarks &amp; ")";
			endif;
			return str;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
