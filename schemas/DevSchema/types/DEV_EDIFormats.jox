    <JadeMethod name="getElementUsingPath" id="72109c7c-21df-40d1-a12b-5f2b63c2b451">
        <source>getElementUsingPath(_xmlElemArray: JadeXMLElementArray): JadeXMLElement;
//----------------------------------------------------------------
//	Created:	03 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	prevElement,
	foundElement,
	xmlElement		: JadeXMLElement;
	tmpEDIField		: CM_EDIItemFieldXML;
	xmlElements		: JadeXMLElementArray;
	theTagName,
	attrName,
	attrValue		: String;
	attributes		: CM_FieldByNameDict;
	fieldAttr		: CM_Field;
	xmlAttr			: JadeXMLAttribute;
	allOK			: Boolean;
	
begin
	create tmpEDIField transient;
	create attributes transient;
	create xmlElements transient;

	prevElement := self.myXMLDoc.rootElement;
	
	foreach xmlElement in _xmlElemArray reversed do
		xmlElements.clear;
		attributes.clear;
		tmpEDIField.readTag(xmlElement.textData, theTagName, attributes);
		if prevElement.tagName = theTagName then
			//true for the first time through
			continue;
		endif;
app.writeStatement( attributes.size.String);		
		prevElement.getAllElementsByTagName(theTagName, xmlElements);
		//foundElement := prevElement.getElementByTagName(xmlElement.textData);
		
		foreach foundElement in xmlElements do	:	elementloop
app.writeStatement( "xmlElem " &amp;  foundElement.tagName);
			allOK := true;		
			foreach fieldAttr in attributes do	:	attrloop
				xmlAttr := foundElement.getAttributeByName(fieldAttr.name);
app.writeStatement( xmlAttr.value &amp; " = " &amp; fieldAttr.value);
				if xmlAttr = null
				or xmlAttr.value &lt;&gt; fieldAttr.value then
					allOK := false;
					break attrloop;
				endif;
app.writeStatement( "found " &amp;  fieldAttr.value);		
			endforeach;
			if allOK then

				break elementloop;
			endif;
		endforeach;	
		
		if foundElement = null then
			foundElement := prevElement;
			break;
		endif;
		prevElement := foundElement;
	endforeach;

	return foundElement;
epilog
	delete tmpEDIField;
	delete xmlElements;
	delete attributes;		
end;</source>
        <Parameter name="_xmlElemArray" type="JadeXMLElementArray"/>
        <ReturnType type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="getItemFieldClass" id="2b753dd9-6fe4-465b-89c3-39ce81403147">
        <source>getItemFieldClass(_class: Class output);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin


	if self.fileType = FileTypeCSV then
		_class := CM_EDIItemFieldCSV;
	elseif self.fileType = FileTypeXML then
		_class := CM_EDIItemFieldXML;
	else
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_class" type="Class" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initCmbFormatMethod" id="0b1d9139-6041-46c6-9648-d65a5b83baff">
        <source>initCmbFormatMethod();
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	type		: Class;
	typeMeths	: MethodNDict;
	meth		: Method;
begin
	self.cmbFormatMethod.clear;
	self.cmbFormatMethod.addItem("");
	
	create typeMeths transient;
	type := CMIF_EDIStringMethodHolder;
	
	type.getMethods(typeMeths);
	
	foreach meth in typeMeths do
		if meth.name[1:6] = 'format' then
			self.cmbFormatMethod.addItem(meth.name);
		endif;
	endforeach;
	
epilog
	delete typeMeths;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="cad5444b-e08a-4017-81f3-df4b30e0ea8d">
        <updating/>
        <source>initForm() updating;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//
	self.tblCSVDisplay.selectMode := Table.SelectMode_WholeRows;
	self.tblCSVDisplay.columns := 1;
	self.tblCSVDisplay.fixedColumns := 1;
	self.tblCSVDisplay.backColor := White;

	//ediDataTypeCombo
	self.cmbEDIDataType.addItemAt('Custom Stop', EDIDataType_CustomStop);
	self.cmbEDIDataType.addItemAt('Operator Stop', EDIDataType_OperatorStop);
	self.cmbEDIDataType.addItemAt('Bay Plan', EDIDataType_BayPlan);
	self.cmbEDIDataType.addItemAt('Booking Reference Single Line', EDIDataType_BookingSingleLine);
	self.cmbEDIDataType.addItemAt('Load List', EDIDataType_LoadList);
	self.cmbEDIDataType.addItemAt('PreNote', EDIDataType_Prenote);
	self.cmbEDIDataType.addItemAt('Pack', 7); //EDIDataType_Pack);	// ccms 1976 cnwrs1 10 dec 2010
//	self.cmbEDIDataType.addItemAt('St', EDIDataType_StowAdvice);

	
	//dataType combo
	self.cmbDataType.addItem('Integer');
	self.cmbDataType.addItem('Real');
	self.cmbDataType.addItem('String');
	self.cmbDataType.addItem('StringArray');
	self.cmbDataType.addItem('TimeStamp');
	self.cmbDataType.enabled := false;
	
	// format Method combo
	self.initCmbFormatMethod();
	
	self.fillFormats();
	
end;</source>
    </JadeMethod>
