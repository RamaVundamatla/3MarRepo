/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	wpq : CM_VoyageWorkPointQueue;
begin
	foreach wpq in self.allVoyageWorkPointQueues discreteLock do
