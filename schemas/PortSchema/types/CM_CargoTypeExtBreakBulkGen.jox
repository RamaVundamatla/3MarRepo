    <JadeMethod name="getAttributeValue" id="22bd8767-0244-4b27-b22e-bc9b4db10489">
        <source>getAttributeValue(_attribute: String): Any;
// -------------------------------------------
// Created 09 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _attribute = ETRow_MyWidthString or
	 _attribute = ETRow_MyHeightString or
	 _attribute = ETRow_MyLengthString or
	 _attribute = ETRow_MyWidth or
	 _attribute = ETRow_MyHeight or
	 _attribute = ETRow_MyLength or
	 _attribute = ETRow_MyQuantity or
	 _attribute = ETRow_MyVolume or
	 _attribute = ETRow_MyDensity or
	 _attribute = ETRow_MyWeight or
	 _attribute = ETRow_MyType then
		return self.allAttributesOnProduct.includes(_attribute);
	endif;
	
	if _attribute = CM_CargoTypeExtBreakBulkGen::defaultWidthString.name then
		return self.defaultWidthString;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultHeightString.name then
		return self.defaultHeightString;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultLengthString.name then
		return self.defaultLengthString;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultWidth.name then
		return self.defaultWidth;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultHeight.name then
		return self.defaultHeight;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultLength.name then
		return self.defaultLength;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultQuantity.name then
		return self.defaultQuantity;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultVolume.name then
		return self.defaultVolume;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultDensity.name then
		return self.defaultDensity;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultWeight.name then
		return self.defaultWeight;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::defaultType.name then
		return self.defaultType;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::myDefaultHandlingType.name then
		return self.myDefaultHandlingType;
	elseif _attribute = CM_CargoTypeExtBreakBulkGen::allAttributesOnProduct.name then
		return self.allAttributesOnProduct;
	elseif _attribute = ETRow_NumberOfProducts then
		return self.allProducts.size;
	endif;
	
	return inheritMethod(_attribute);

end;</source>
        <Parameter name="_attribute" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getExtraData" id="732441b8-6738-4fd3-a5aa-c5e80d14301a">
        <source>getExtraData(_allData: StringArray input);
// -------------------------------------------
// Created 09 November 2005 by cnwdvb1
// -------------------------------------------
vars

	str	: String;

begin

	if not self.allAttributesOnProduct.isEmpty() then
		_allData.add('');
//		_allData.add('Attribute Name' &amp; Tab &amp; 'Default Value');
//		_allData.add('');
	endif;
	
	_allData.add('Number of Products' &amp; Tab &amp; self.allProducts.size.String);
	
	if self.myDefaultHandlingType &lt;&gt; null then
		_allData.add('Default Handling Type' &amp; Tab &amp; self.myDefaultHandlingType.description);
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyWidthString) then
		_allData.add('Width Text' &amp; Tab &amp; self.defaultWidthString);
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyHeightString) then
		_allData.add('Width Text' &amp; Tab &amp; self.defaultHeightString);
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyLengthString) then
		_allData.add('Length Text' &amp; Tab &amp; self.defaultLengthString);
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyWidth) then
		_allData.add('Width' &amp; Tab &amp; self.defaultWidth.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyHeight) then
		_allData.add('Height' &amp; Tab &amp; self.defaultHeight.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyLength) then
		_allData.add('Length' &amp; Tab &amp; self.defaultLength.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyQuantity) then
		_allData.add('Quantity' &amp; Tab &amp; self.defaultQuantity.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyVolume) then
		_allData.add('Volume' &amp; Tab &amp; self.defaultVolume.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyDensity) then
		_allData.add('Density' &amp; Tab &amp; self.defaultDensity.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyWeight) then
		_allData.add('Weight' &amp; Tab &amp; self.defaultWeight.zeroNotAllowed());
	endif;
	
	if self.allAttributesOnProduct.includes(ETRow_MyType) then
		_allData.add('Type' &amp; Tab &amp; self.defaultType);
	endif;

	


end;</source>
        <Parameter name="_allData" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="80043daf-61a2-4a72-8aec-63656a60fb0d">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 14 November 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	extension 		: SelfType;
	completedOK		: Boolean;
begin

	extension := inheritMethod();
	
	extension.myDefaultHandlingType := self.myDefaultHandlingType;
	self.allAttributesOnProduct.copy(extension.allAttributesOnProduct);
	
	// Products take care of themselves from the product end.
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return extension;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete extension;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c3864580-e865-4164-a845-c9331e813800">
        <updating/>
        <source>setForUpdate(_pxyExtension : CM_CargoTypeExtBreakBulkGen) updating;
// -------------------------------------------
// Created 09 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allAttributesOnProduct.clear();
	_pxyExtension.allAttributesOnProduct.copy(self.allAttributesOnProduct);
	self.defaultDensity			:= _pxyExtension.defaultDensity;
	self.defaultHeight			:= _pxyExtension.defaultHeight;
	self.defaultHeightString	:= _pxyExtension.defaultHeightString;
	self.defaultLength			:= _pxyExtension.defaultLength;
	self.defaultLengthString	:= _pxyExtension.defaultLengthString;
	self.defaultQuantity		:= _pxyExtension.defaultQuantity;
	self.defaultType			:= _pxyExtension.defaultType;
	self.defaultVolume			:= _pxyExtension.defaultVolume;
	self.defaultWeight			:= _pxyExtension.defaultWeight;
	self.defaultWidth			:= _pxyExtension.defaultWidth;
	self.defaultWidthString		:= _pxyExtension.defaultWidthString;
	self.myDefaultHandlingType	:= _pxyExtension.myDefaultHandlingType;

	inheritMethod(_pxyExtension);


end;</source>
        <Parameter name="_pxyExtension" type="CM_CargoTypeExtBreakBulkGen"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromCMIF" id="29f91566-f44b-40ef-9d7f-bb5e17700eec">
        <updating/>
        <source>setProxyFromCMIF(_cmif: CMIF_CargoTypeExt) updating;
// -------------------------------------------
// Created 07 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod(_cmif);
	self.allAttributesOnProduct.clear();
	_cmif.allAttributesOnProduct.copy(self.allAttributesOnProduct);
	self.defaultDensity			:= _cmif.bbGenDefaultDensity;
	self.defaultHeight			:= _cmif.bbGenDefaultHeight;
	self.defaultHeightString	:= _cmif.bbGenDefaultHeightString;
	self.defaultLength			:= _cmif.bbGenDefaultLength;
	self.defaultLengthString	:= _cmif.bbGenDefaultLengthString;
	self.defaultQuantity		:= _cmif.bbGenDefaultQuantity;
	self.defaultType			:= _cmif.bbGenDefaultType;
	self.defaultVolume			:= _cmif.bbGenDefaultVolume;
	self.defaultWeight			:= _cmif.bbGenDefaultWeight;
	self.defaultWidth			:= _cmif.bbGenDefaultWidth;
	self.defaultWidthString		:= _cmif.bbGenDefaultWidthString;
	self.myDefaultHandlingType	:= _cmif.bbGenMyDefaultHandlingType;

end;</source>
        <Parameter name="_cmif" type="CMIF_CargoTypeExt"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ef61fcb3-6f32-48c4-8df3-97c1da86105f">
        <source>validateForDelete();
// -------------------------------------------
// Created 25 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod();
	if not self.allProducts.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.myCargoType.description, "products", null, null);
	endif;

end;</source>
    </JadeMethod>
