    <JadeMethod name="doResize" id="2bc21cca-26b3-4d44-981e-c94cae517d54">
        <source>doResize();
// 31448 add Address maintenance
vars
	table 	:	CM_DataTable;
begin
	inheritMethod();
	table := self.myForm.tblData4;
	table.accessColumn(1).width := 90;		// room for the row text
	table.accessColumn(2).width := table.width.Integer - table.accessColumn(1).width;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f0bf090d-8bb9-4b7f-8c61-b15d93998349">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
vars
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	proxyAddress			: CM_Address;
	lCode,lDescription		: String;
	lColour,lOrder			: Integer;
	lConsignGroup			: CM_ConsigneeConsignorGroup;
	lDebtor					: CM_Debtor;
	lDerogationNumber,
	lEmailAddress			: String;
	theForm					: SOP_TableMaintForm;
	notForEntry,showOOWRemarks,
	secureExporter			: Boolean;
	lEmailPINAddresses		: CM_EmailEntityByTypeNameDict;
	isConsignee,
	isConsignor,
	isFreightFwdr : Boolean; 
	address1	: String;
	address2	: String;
	address3	: String;
	postCode	: String;
	region		: String;
	countryCode	: String;
	country		: CM_Country;
	addressDetailsEntered	: Boolean;
	
	//cnwmc5 - 19/12/2012 - HAT 2198
	lLicense 	: String;
	lLicenseExpiryDate : Date;
	
	isUsedForPacking	: Boolean;						// PAR #35895
	isRestricted,
	isInternal 	: Boolean;  // 3.8.2017 cnwma1 TFS #5209
begin
	
	theForm := self.myForm; 
	
	//FD for consign derogation
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notForEntry := theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	lDerogationNumber := theForm.tblInput1.getValueByName(ETRow_DerogationNumber).String;
	lEmailAddress := theForm.tblInput1.getValueByName(ETRow_EmailAddress).String;
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer; 
	lConsignGroup := theForm.cmbConsignGroup.listObject.CM_ConsigneeConsignorGroup;
	lDebtor := theForm.cmbDebtor.myObject.CM_Debtor;
	secureExporter := theForm.tblInput1.getValueByName(ETRow_SecureExportPartner).Boolean;
	showOOWRemarks := theForm.tblInput1.getValueByName(ETRow_ShowOOWRemarks).Boolean;
	
		
	//par#12903 3/11/2006
	isConsignor := theForm.tblInput1.getValueByName(ETRow_IsConsignor).Boolean;
	isConsignee := theForm.tblInput1.getValueByName(ETRow_IsConsignee).Boolean;
	isFreightFwdr := theForm.tblInput1.getValueByName(ETRow_IsFreightFwdr).Boolean;
	
	//cnwmc5 - 19/12/2012 - HAT 2198
	lLicense 	:= theForm.tblInput1.getValueByName(ETRow_License).String;
	lLicenseExpiryDate := theForm.tblInput1.getValueByName(ETRow_LicenseExpiryDate).Date;
	
	isUsedForPacking := theForm.tblInput1.getValueByName(ETRow_IsUsedForPacking).Boolean;			// PAR #35895
	isRestricted := theForm.tblInput1.getValueByName(ETRow_IsRestricted).Boolean; // 2.8.2017 cnwma1 TFS #5209
	if isFreightFwdr then
		isInternal :=theForm.tblInput1.getValueByName(ETRow_IsInternal).Boolean; //jlier1 TFS 57087 27/6/23
	endif;
	
	// 31448 maintain address
	if theForm.myProxyObject &lt;&gt; null then
		if theForm.myProxyObject.CM_ConsigneeConsignor.myAddress &lt;&gt; null then
			proxyAddress := theForm.myProxyObject.CM_ConsigneeConsignor.myAddress.cloneSelf(true);
		endif;
	endif;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ConsigneeConsignor transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	// 31448 maintain address
	address1 := theForm.tblData4.accessCell(1,2).text.trimBlanks();
	address2 := theForm.tblData4.accessCell(2,2).text.trimBlanks();
	address3 := theForm.tblData4.accessCell(3,2).text.trimBlanks();
	postCode := theForm.tblData4.accessCell(4,2).text.trimBlanks();
	region := theForm.tblData4.accessCell(5,2).text.trimBlanks();
	country := theForm.cmbCountry.myObject.CM_Country;
	if country &lt;&gt; null then
		countryCode := country.code;
	endif;
	if address1 &lt;&gt; null or
	   address2 &lt;&gt; null or
	   address3 &lt;&gt; null or
	   postCode &lt;&gt; null or
	   region &lt;&gt; null or
	   countryCode &lt;&gt; null then
		addressDetailsEntered := true;
	endif;
	// don't create a CM_Address if not already one and no address details entered
	if proxyAddress = null and
	   addressDetailsEntered then
		create proxyAddress transient;
	endif;
	if proxyAddress &lt;&gt; null then
		proxyAddress.update(address1, address2, address3, postCode, region, countryCode);
	endif;

	create lEmailPINAddresses transient;
	theForm.mulSelect1.getSelected(lEmailPINAddresses);   
	
	proxyConsigneeConsignor := theForm.myProxyObject.CM_ConsigneeConsignor;
	proxyConsigneeConsignor.setMyAddress(proxyAddress);
	//proxyConsigneeConsignor.setProxy(lCode,lDescription, notForEntry, secureExporter, lDerogationNumber,lEmailAddress,lColour,lOrder,lConsignGroup,lDebtor,showOOWRemarks,isConsignee, isConsignor, isFreightFwdr,lEmailPINAddresses, lLicense, lLicenseExpiryDate);					//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895
	proxyConsigneeConsignor.setProxy(lCode,lDescription, notForEntry, secureExporter, lDerogationNumber,lEmailAddress,lColour,lOrder,lConsignGroup,lDebtor,showOOWRemarks,isConsignee, isConsignor, isFreightFwdr,lEmailPINAddresses, lLicense, lLicenseExpiryDate, isUsedForPacking,isRestricted,isInternal);	//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895 // 3.8.2017 cnwma1 TFS #5209

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateConsigneeConsignor(proxyConsigneeConsignor, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateConsigneeConsignor(proxyConsigneeConsignor, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	delete lEmailPINAddresses;
	delete proxyAddress;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
