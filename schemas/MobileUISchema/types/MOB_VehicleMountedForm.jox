    <JadeMethod name="tblMoveEntry_click" id="28a19172-2b16-45b4-a251-e81beb4e4f9f">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveEntry_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2010	cnwer1	Initial creation
10 March 2015   cnwma1  PAR # 35797 Mulitple Containers on IMV does not work for VMT configured for PENN
*/

vars
	entRow : EntTableRow;
	oSet	: ObjectSet;
begin
	create oSet transient;
	entRow:=myMoveTableDetails.myEntTableDef.getEntTableRow(ETRow_TwinTargetID);
	if entRow &lt;&gt; null then
		oSet.add(entRow);
	endif;
	entRow:=myMoveTableDetails.myEntTableDef.getEntTableRow(ETRow_TandemTargetID);
	if entRow &lt;&gt; null then
		oSet.add(entRow);
	endif;
	entRow:=myMoveTableDetails.myEntTableDef.getEntTableRow(ETRow_TargetID);
	if entRow &lt;&gt; null then
		oSet.add(entRow);
	endif;
	
	if  oSet.includes(table.accessRow(table.row).itemObject) and
			table.column = self.DataColumn  and
			 table.accessCell(table.row,table.column).text = "IMV" then
			 
		 table.accessCell(table.row,table.column).foreColor:=app.myVMAgent.getMyScreenMode().screenForeColour;//TextBox.Color_WindowText;
		// table.accessCell(table.row,table.column).text:=null;		// 10/03/2015  cnwma1 PAR #35797
		return;														// 10/03/2015  cnwma1 PAR #35797
	endif;
epilog
	delete oSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMoveEntry_gotFocus" id="e9edad7f-f909-424f-98b8-2e09b3f4e80a">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveEntry_gotFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwer1	Initial creation
10 March 2015   cnwma1  PAR # 35797 Mulitple Containers on IMV does not work for VMT configured for PENN
*/

vars
	entRow : EntTableRow;
begin

	if (	table.accessedCell.row = self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID) or
		table.accessedCell.row = self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinTargetID) or
			table.accessedCell.row = self.myMoveTableDetails.findRowWithEntRowName(ETRow_TandemTargetID )) and
			table.accessedCell.column = self.DataColumn  and
			 table.accessedCell.text = "IMV" then
			 
		table.accessedCell.foreColor:=app.myVMAgent.getMyScreenMode().screenForeColour;//TextBox.Color_WindowText;
		//table.accessedCell.text:=null;  	// 10/03/2015  cnwma1 PAR #35797
		return;								// 10/03/2015  cnwma1 PAR #35797
	endif;

	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMoveEntry_keyDown" id="8c4197dc-633c-400a-b4c6-a9275a0c230d">
        <controlMethod name="Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveEntry_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Date		Who		Reason
18 November 2015	cnwer1	Initial creation PAR

*/

vars
	tableCell : JadeTableCell;
begin
	//epr par 36977 18/11/15
	if keyCode = J_key_Tab then
		if self.isSettingDown then
		
			tableCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID),DataColumn);
			if tableCell = null then
				return;
			endif;
			if app.activeControl = tableCell.cellControl then
				if self.btnSwap.visible then
					self.tblMoveEntry.row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinTargetID);
				else
					self.btnTargetSearch.setFocus();
				endif;
			endif;
		endif;
		
		
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMoveEntry_scrolled" id="c586e79e-5c48-4650-ad4d-d40fa84e81d0">
        <controlMethod name="Table::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveEntry_scrolled(table: Table input; scrollBar: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2010	cnwer1	Initial creation

*/

vars
	rejectCell : JadeTableCell;
	searchTarget : JadeTableCell;
	isTwinSetdown,
	isTwin		: Boolean;
begin
	return;
	isTwinSetdown:=false;
	 
	
	isTwin:=false;
	rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinTargetID),DataColumn).cloneSelf(true);
	if  self.tblMoveEntry.accessRow(rejectCell.row).visible then
		isTwin:=true;
		if self.isNextTaskSetDown then
			isTwinSetdown:=true;
			if   self.tblMoveEntry.top + rejectCell.positionTop &gt; 0 then
				self.btnSwap.visible:=true;
				self.btnSwap.top:=self.tblMoveEntry.top +  rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ;
				self.btnIC.top:= self.btnSwap.top + self.btnSwap.clientHeight  + 5;
				self.btnIC.visible:=true;

			else
				self.btnSwap.visible:=false;
				self.btnIC.visible:=false;
			endif;
		endif;
	endif;
	delete rejectCell;
	
	rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID),DataColumn).cloneSelf(true);
	if  self.tblMoveEntry.accessRow(rejectCell.row).visible then
		if self.isNextTaskSetDown then
			self.btnIC.visible:=true;
			if  rejectCell.positionTop &gt; 0 then
				self.btnTargetSearch.visible:=self.btnGraphic.visible;
				self.btnTargetSearch.top:= self.tblMoveEntry.top + rejectCell.positionTop;// + self.tblMoveEntry.accessRow(rejectCell.row).height ; //self.tblMoveEntry.top + 
				if not isTwinSetdown then
					self.btnIC.top:=self.tblMoveEntry.top +  rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ;
				endif;
			else	
				if not isTwinSetdown then
					self.btnIC.visible:=false;
				endif;
				self.btnTargetSearch.visible:=false;
			endif;
			
			
		elseif self.isNextTaskPickup and isTwin then	
			if self.tblMoveEntry.top + rejectCell.positionTop &gt; 0 then
				self.btnRejectTask.visible:=true;
				
				self.btnRejectTask.top:=self.tblMoveEntry.top +  rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ; //;//
				self.btnRejectTask.left:=rejectCell.positionLeft;
			else
				self.btnRejectTask.visible:=false;
			endif;
		
			delete rejectCell;
			
			rejectCell:= self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinTargetID),DataColumn).cloneSelf(true);
			if rejectCell.positionTop &gt; 0 then
				self.btnRejectTwin.visible:=true;
				self.btnRejectTwin.top:=self.tblMoveEntry.top+ rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ;
				self.btnRejectTwin.left:=rejectCell.positionLeft;
			else
				self.btnRejectTwin.visible:=false;
			endif;
			delete rejectCell;
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblTasks_click" id="7b6b0f9d-5c6f-43d8-888f-e0255d2bc1f3">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTasks_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation

*/

vars

begin
	self.addInfoDisplay(null);
	
	if self.btnTandem.visible and self.btnTandem.value then
		self.displayVMTableRow(table,table.row,true);
	else
		self.displayVMTableRow(table,table.row,false);
	endif;
	
	self.addOStowInfo(table.row);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTasks_keyUp" id="49085a91-d6bb-4c63-b670-2a12b762de96">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTasks_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Jun 2010	cnwer1	Initial creation
03 Dec 2010 cnwer1	PAR 26487 - the Enter key - goes to next row the home to first row and end to last row
*/

vars

begin	
	if keyCode = J_key_UpArrow or
		keyCode = J_key_DownArrow  or 
		keyCode = J_key_Enter or 
		keyCode = J_key_Home or		
		keyCode = J_key_End	then		
		table.click(table);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWeight_lostFocus" id="f6d54e42-654d-4b96-a7a7-a7e9c7f021d6">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWeight_lostFocus(table: Table input) updating;
/*

Date		Who		Reason
24 March 2014	cnwer1	Initial creation PAR

*/

vars
	rowHeight : Real;
	measurement : CMUI_MeasurementTable;
	measureType	: CM_MeasurementType;
	str			: String;
	value		: Decimal [23,10];
	valueStr	: String;
	conValue	: String;
begin
	measurement:=table.CMUI_MeasurementTable;
	measureType := app.myRoot.allMeasurementTypesByShortName[measurement.accessCell(1,3).text];
	value := measurement.accessCell(1,1).text.Decimal;
	valueStr := measurement.accessCell(1,1).text;
	if measureType &lt;&gt; null then
		str := " " &amp; measurement.accessCell(1,3).text;
		if value &lt;&gt; null then
			conValue := measureType.formatValue(value);
			if conValue.length &gt; valueStr.length then
				conValue := conValue[1:valueStr.length];
			endif;
			str := conValue &amp; str;
		endif;
	endif;
	
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalQuantity,str);
		//self.measurementTableLostFocus(self.tblMoveEntry, rowHeight, table.CMUI_MeasurementTable);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="fe1c2fdf-abc0-4633-bc32-152c5b46eaab">
