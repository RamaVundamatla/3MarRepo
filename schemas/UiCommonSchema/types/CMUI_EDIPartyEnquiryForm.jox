    <JadeMethod name="doAddEDIParty" id="bad18938-79d8-42b8-8f50-529e78137937">
        <source>doAddEDIParty() protected;
/*
Date				Who		Reason
21 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
14 April 2021		navmd1	TFS 51071 ADP - EDI Party Enquiry screen cannot be accessed despite having licensce
*/
vars
	form		: CMUI_EDIPartyMaintForm;
	menuAction 	: CMUI_MenuAction;
begin
	form := app.loadForm(CMUI_EDIPartyMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDIPartyMaintForm;
	
	if form = null then
		return;
	endif;
	
	form.setParentForm(self);	// Make ourselves the parent of the Maint form
	form.show();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="8a1a77bc-4f07-4172-beee-95d29afe37fe">
        <updating/>
        <source>doDelete() updating;
/*
Date		Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	party	:CM_EDIParty;
	result	:Integer;
begin
	party := self.getSelectedEDIParty;
	
	if party = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, party.name, party.description),
				self.caption, 
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;	
	
	while true do
		app.myTrxDA.trxDeleteEDIParty (party, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="69ea15d0-6d5c-4831-96dd-87ce1ca44046">
        <updating/>
        <source>doEditItem() updating;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	form		: CMUI_EDIPartyMaintForm;
	menuAction 	: CMUI_MenuAction;
	table		: CM_DataTable;
begin
	table := self.tblData; // TFS 2198
	
	if table.allSelectedObjects.isEmpty then // TFS 2198
		return;
	endif;
	

	form := app.loadForm(CMUI_EDIPartyMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDIPartyMaintForm;
	
	if form = null then
		return;
	endif;
	
	form.myCurrentEDIParty	:= self.getSelectedEDIParty;
	form.setParentForm(self);
	
	form.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="5e198dc0-cbad-4fd0-8628-304c34b62d3a">
        <source>doNotableAdd(_party: CM_EDIParty);
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	// need to allow for notes already being registered for object
	self.allNotableObjects.addNoDuplicates(_party, false);
	
	// using class notifications for adds
	beginNotification(_party, Object_Update_Event, Response_Continuous, null);
	beginNotification(_party, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
        <Parameter name="_party" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="2621421e-2008-437b-a12f-d1d5b39c6dff">
        <source>doNotableClear();
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	// we don't want to call inheritMethod
	self.endNotificationForSubscriber (self);
	
	// don't forget the class notes
	self.beginClassNotification(CM_EDIParty, false, Object_Create_Event, Response_Continuous, 0);

	self.allNotableObjects.clear;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="302b58d4-4ffb-48ac-a6a8-9d3d7834e251">
        <source>doNotableRemove(_party: CM_EDIParty);
/*
Date		Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	if  self.allNotableObjects.includes(_party) then
		self.allNotableObjects.remove(_party);				// no exception even if invalid object
		
		self.endNotification(_party, Object_Update_Event);	// no exception even if invalid object
		self.endNotification(_party, Object_Delete_Event);	// no exception even if invalid object
	endif;
epilog

end;</source>
        <Parameter name="_party" type="CM_EDIParty"/>
    </JadeMethod>
