<Class name="YRD_WagonWheels" id="bf9d3de5-7626-4aa2-8787-8e1c8bb86ebe">
    <superclass name="CMUI_GridPoint"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is the row for interacting with the actual wagon. It actually is the wheel area on screen.</text>
    <DbClassMap file="Yard"/>
    <JadeMethod name="drawSelf" id="e8d7a23f-1682-4efd-847c-37899c09b75d">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	lWheelWidth, lWheelTop,leftWheelLeft, rightWheelLeft, lLabelLeft, myWidth: Real;
	wagon			: CM_Wagon;
	wheelCol,
	lFactor,
	lTotalCols 		: Integer;
	lPicture 		: Binary;
	aGridArea 		: YRD_WagonArea;
	drawWidth 		: Integer;
	scaleFactor 	: Real;
	drawLabel : String;
	saveDrawFillColor : Integer;
	flipHorizontal : Boolean;
	wellPos : Integer;
	well : CM_WellcarWellVisit;
	tmpWell : CM_WellcarWellVisit;
	midPoint : Real;
	
begin
	wagon := pFrame.myGridArea.YRD_WagonArea.myWagon;
	wheelCol := self.getColWheel(wagon);
	
	if self.x2 = 0 then
		return;
	endif;
	
	aGridArea := self.myGridArea.YRD_WagonArea;
	flipHorizontal := self.myGridArea.flipHorizontal;
	
	drawLabel := aGridArea.label;
	
	// AUG2009AKB - if inward unconfirmed, show wagon ID in brackets
	if not aGridArea.isOutward then
		if wagon &lt;&gt; null then
			if not wagon.confirmed then
				drawLabel := "(" &amp; aGridArea.label &amp; ")";
			endif;
		endif;
	endif;
	
	pFrame.drawFontName := "Arial";
	scaleFactor := aGridArea.scaleXFactor;
	if scaleFactor &gt;= 3 then
		drawWidth := 2;	
	else
		drawWidth := 1;
	endif;
	myWidth := self.x2 - self.x1;
	
	lTotalCols := self.myGridArea.allGridColumns.size;

	// draw wagon wheels
	pFrame.drawFillStyle := pFrame.DrawFillStyle_Solid; //DrawFillStyle_Solid;
	pFrame.drawFillColor := Gray;//14671839;//YRD_WagonArea.DisabledGrey_Light;
	pFrame.drawWidth := drawWidth;

	if aGridArea.isWagonSelected then
		pFrame.drawFillColor := wheelCol;
	endif;

	lWheelTop := self.y1;
	lWheelWidth := myWidth / 2.5;
	if self.column = 1 then//its the front set of wheels
		leftWheelLeft := self.x1 + (lWheelWidth div 2) - 1;
	elseif self.column =  lTotalCols then //it's the back set of wheels
		leftWheelLeft := self.x1;
	else
		return;
	endif;
	rightWheelLeft := leftWheelLeft + lWheelWidth + 1;
	// #####################################
	// LEFT WHEEL			
	if self.column = 1 and not flipHorizontal then//its the front set of wheels
		saveDrawFillColor := pFrame.drawFillColor;
		pFrame.drawFillColor := Yellow;
		pFrame.drawEllipse2(leftWheelLeft, lWheelTop, leftWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
		pFrame.drawFillColor := saveDrawFillColor;
	else
		pFrame.drawEllipse2(leftWheelLeft, lWheelTop, leftWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
	endif;
	
	
	// #####################################
	// RIGHT WHEEL	
	if self.column = lTotalCols and flipHorizontal then//its the front set of wheels
		saveDrawFillColor := pFrame.drawFillColor;
		pFrame.drawFillColor := Yellow;
		pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
		pFrame.drawFillColor := saveDrawFillColor;
	else
		pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
	endif;
	
	
	//draw bogie
	pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop, leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
	pFrame.drawLine( rightWheelLeft + (lWheelWidth / 2), lWheelTop, rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
	pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
	
	if self.column = 1 then
		// WAGON ID BETWEEN THE WHEELS
		pFrame.drawTextAlign := Window.DrawTextAlign_Center;
		if wagon.isWellcarVisit then
			if scaleFactor &gt; 2.0 then // lowest zoom is 1
				pFrame.drawFontSize := 8;
			elseif scaleFactor &gt; 1 then  // don't show the text if zoomed to 1
				pFrame.drawFontSize := 6;
			endif;
		else
			if scaleFactor &gt; 2.0 then // lowest zoom is 1
				pFrame.drawFontSize := 9;
			elseif scaleFactor &gt; 1 then  // don't show the text if zoomed to 1
				pFrame.drawFontSize := 7;
			endif;
		endif;
		if wagon.isWellcarVisit and wagon.CM_WellcarVisit.allWagonWellsArray.size.isEven then
			//lLabelLeft := self.x1 + ((self.x2 - self.x1) * wagon.CM_WellcarVisit.allWagonWellsArray.first.allLocationsControllersArray.size ) div 2;
			wellPos := (wagon.CM_WellcarVisit.allWagonWellsArray.size / 2).Integer;
			well := wagon.CM_WellcarVisit.allWagonWellsArray[wellPos];
			midPoint := self.x1 + ((self.x2 - self.x1) * well.allLocationsControllersArray.size ) div 2;
			foreach tmpWell in wagon.CM_WellcarVisit.allWagonWellsArray do
				if tmpWell = well then
					break;
				endif;
				midPoint := midPoint + ( tmpWell.allLocationsControllersArray.size * (self.x2 - self.x1) );
			endforeach;
			lLabelLeft := midPoint;
		else
			lLabelLeft := self.x1 + ((self.x2 - self.x1) * lTotalCols) div 2;
		endif;
		if scaleFactor &gt; 2.0 then // lowest zoom is 1
			pFrame.drawTextAt(drawLabel, lLabelLeft, self.y1 - 1,Black);
		elseif scaleFactor &gt; 1 then  // don't show the text if zoomed to 1
			pFrame.drawTextAt(drawLabel, lLabelLeft, self.y1 - 2,Black);
		endif;
	endif;
	
	if self.myGridArea.isBoxcar then	//19 Mar 2013	NDL	Par 31278
		//There is only one controller, don't get a second chance to draw the back set, do it now..
		leftWheelLeft := self.x1 + ( myWidth * ( lTotalCols - 1) );
		rightWheelLeft := leftWheelLeft + lWheelWidth + 1;
		pFrame.drawEllipse2(leftWheelLeft, lWheelTop, leftWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
		if flipHorizontal then
			saveDrawFillColor := pFrame.drawFillColor;
			pFrame.drawFillColor := Yellow;
			pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
			pFrame.drawFillColor := saveDrawFillColor;
		else
			pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
		endif;
		
		//draw bogie
		pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop, leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
		pFrame.drawLine( rightWheelLeft + (lWheelWidth / 2), lWheelTop, rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
		pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
	
	endif;


end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bd645137-8441-4837-9487-c4213a689697">
        <updating/>
        <source>setForCreate(pController : CM_WagonController; pWagonRow : YRD_WagonRow;
			 pWagonCol : YRD_WagonColumn; pGridArea : YRD_WagonArea) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myLocationsController := pController;
	self.myGridColumn 	:= pWagonCol;
	self.myGridRow		:= pWagonRow;
	self.myGridArea 	:= pGridArea;

end;</source>
        <Parameter name="pController" type="CM_WagonController"/>
        <Parameter name="pWagonRow" type="YRD_WagonRow"/>
        <Parameter name="pWagonCol" type="YRD_WagonColumn"/>
        <Parameter name="pGridArea" type="YRD_WagonArea"/>
    </JadeMethod>
</Class>
