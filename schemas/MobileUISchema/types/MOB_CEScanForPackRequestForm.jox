    <JadeMethod name="deleteObjectFromTable" id="68c1df49-3a0e-4277-ad77-4031535261e1">
        <updating/>
        <source>deleteObjectFromTable(obj: Object io) updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti: CM_TrackedItem;
begin
	inheritMethod(obj);
	if obj.isKindOf(CM_TrackedItem) then
		ti := obj.CM_TrackedItem;
		self.doCargoUnpack(ti);
		self.loadCargoIDsTbl(self.tbl_CargoIDs);
		self.loadPackingReqTbl(self.tbl_PackingRqst);//Par 17108
	endif;
end;</source>
        <Parameter name="obj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCargoSave" id="4b9f57f4-2268-48c1-9492-21f367b2936a">
        <updating/>
        <source>doCargoSave(_item :CM_TrackedItem input; _lc : CM_LocationsController input; _unpacking : Boolean ):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2008 by cnwaer1
//
// Purpose:   Update Container for Pack/Unpack  
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 02/04/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Update subterminal on pack to be marine subterminal
vars
	theMoveController 			: CMIF_MoveController;
	pxyContainer,
	pxyMaster,
	masterPack					: CM_TrackedItem;
	cmifTI	 					: CMIF_TIUpdateController;
	result						: Integer;
	isLoadStateSet				: Boolean;
	thePackTIs,	
	theUnpackTIs 				: CM_TIArray;
	subTerminal					: CM_SubTerminal;				// PAR #35895
	
begin
	// ##################
	// Make a proxy copy of our TI
	app.cmsBeginLoad(isLoadStateSet);
	
	if self.myCargoTI.isTransient() then
		pxyMaster := self.myCargoTI;
		pxyMaster.setPxyForMasterpack(_item, _lc);
		
		if self.allBulkReleases.size &lt;&gt; 0 and (not pxyMaster.allBulkReleasesAssigned.includes(self.allBulkReleases.first())) then
			pxyMaster.allBulkReleasesAssigned.add(self.allBulkReleases.first);
		endif;
	else
		pxyContainer := self.myCargoTI.pxyCreateUpdateProxy();
		// Anca 21/05/2008 
		// not sure why do the following - appears to be to "fix" situation where when first item is packed the 
		// container.allBulkReleases collection then looses its bulk release
		if self.allBulkReleases.size &lt;&gt; 0 and (not pxyContainer.allBulkReleasesAssigned.includes(self.allBulkReleases.first)) then
			pxyContainer.allBulkReleasesAssigned.add(self.allBulkReleases.first());
		endif;
	endif;

	// ##################
	// this is used to create pack and unpack transactions
	create thePackTIs transient;
	create theUnpackTIs transient;
	
	if _unpacking then
		theUnpackTIs.add(_item);
	else
		thePackTIs.add(_item);
	endif;
	
	//23 Jul 2013	NDL	Par 32023 - DPH automatically add any child hazards to the parent.
	pxyContainer.updateHazardsWhenPacking( thePackTIs );
	
	//epr TFS 2332 14/7/16 now done on pack complete
/*	// PAR #35895 update the sub-terminal on the container to the Marine sub-terminal			// PAR #35895
	if pxyContainer.myTerminal.isSubTerminalsOn() then											// PAR #35895
		subTerminal := self.myTerminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal;	// PAR #35895
		pxyContainer.setSubTerminal(subTerminal);												// PAR #35895
	endif;																						// PAR #35895
	*/
	//#######################
	//setup the move controller
	//if not unpacking then lc will be null, and the move controllers toLocation will be null. This is correct, as the move done
	//to the child items being packed is setting the locations to null, as it it is retrieved from the parent.
	if theUnpackTIs.size &lt;&gt; 0 and _lc = null then
		app.msgBox(	app.getErrorString(YouMustSelectARowYRD) &amp; CrLf &amp;
					app.getErrorString(ForTheItemsThatNeedUnpack),
					app.getErrorString(UnpackingLocationNotSelected),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	theMoveController := self.myMobileDataAgent.createMoveController(self.myCargoTI, _lc);
	
	if theMoveController.myOriginatingLocation = null then
		theMoveController.setMyOriginatingLocation(_item.getPrimaryLocation(REAL_MODE));
	endif;
	
	while true do
		if pxyContainer &lt;&gt; null then  // this is a container or an existing masterpack
			app.myTrxUA.trxUpdatePackUnpack(theMoveController, false, thePackTIs, theUnpackTIs, true, pxyContainer, app.myPassport);
		else
		// this must be a new masterpack
			app.myTrxUA.trxUpdatePackMasterPack(theMoveController, false, thePackTIs, theUnpackTIs, true, pxyMaster, masterPack, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			thePackTIs.clear();
			theUnpackTIs.clear();
			
			if masterPack &lt;&gt; null then
				self.myCargoTI := masterPack;
			endif;
			
			return true;
		else
			result := app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// Clear errors/warnings from form and err/warnings window
				continue;  
			endif;
			return false;
		endif;
	endwhile;
epilog
	delete cmifTI;
	delete pxyContainer;
	delete thePackTIs ;
	delete theUnpackTIs;
	delete theMoveController;
	app.cmsEndLoad(isLoadStateSet);
end;</source>
        <Parameter name="_item" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_unpacking" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoUnpack" id="7d9cc5f6-68cd-4b12-b522-a81a5d36bac0">
        <updating/>
        <source>doCargoUnpack(_ti : CM_TrackedItem io)updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
begin
	lc := self.newLocation; //22/06/2009 cnwdz2 par19972
	if lc = null then
		lc := app.myMobileGUIAgent.getLocation('Relocate Item');
		if lc = null then
				app.msgBox(app.getErrorString(YouMustSelectARowYRD) &amp; CrLf &amp;
							app.getErrorString(ForTheItemsThatNeedUnpack), app.getErrorString(UnpackingLocationNotSelected), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		self.newLocation := lc; //22/06/2009 cnwdz2 par19972
	endif;
	self.doCargoSave(_ti, lc, true);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getOnSiteCargoNo" id="80c42d71-0f1c-48a8-8d8f-11760dcb19da">
        <source>getOnSiteCargoNo(_reserve : CM_ReserveDetail; tiSet : CM_TIArray input ): Integer;
// ---------------------------------------------------------------------------
// Created:     07 May 2008 by cnwaer1
//
// Purpose:     return the number of onSite items.If is not applicable then return a negative number.
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
	result : Integer;
	ti : CM_TrackedItem;
	br : CM_BookingRef;
	brItem : CM_BookingRefItem;
	allTis	: CM_TISet;
begin
	create allTis transient;
	_reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in _reserve.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		tiSet.add(ti);
	endforeach;	
		
	br := _reserve.myReserveHeader.myBookingRefStock;
	
	if br &lt;&gt; null then
		foreach  brItem in br.allBookingRefItems do
			foreach ti in brItem.allTIs do
				if ti.site = TI_SITE_ONSITE and ti.myProduct &lt;&gt; null and ti.myProduct.code = _reserve.CM_ReserveSelection.myProduct.code and ti.myParent = null and (not tiSet.includes(ti))then //cwnrd1 par26512 27.5.2011 
					tiSet.add(ti);
				endif;
			endforeach;
		endforeach;
	elseif tiSet.size = 0 then
		return -1;
	endif;

	return tiSet.size;
epilog
	delete allTis;
end;</source>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="tiSet" type="CM_TIArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReserveDisplay" id="1146cdd9-0a12-498a-a06c-be1411f6a9e1">
        <source>getReserveDisplay(_res : CM_ReserveDetail): String;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	product,
	marks,
	onSiteString,
	str				: String;
	onSite, i,
	packed			: Integer;
	locations 		: String;
	loc 		    : CM_LocationsController;
	ti				: CM_TrackedItem;
	tiArray			: CM_TIArray;
	locationArray   : StringArray;
begin
	create tiArray transient;
	create locationArray transient;
	//-----------Product
	product := '';
	
	//epr 30546 15/10/12 
	if _res.getProductCode &lt;&gt; null then
		product := _res.getProductCode ;
	elseif _res.getISOType &lt;&gt; null then
		product := _res.getISOType.description;
	elseif _res.getCargoType &lt;&gt; null then
		product := _res.getCargoType.description;
	endif;
	
	if _res.isKindOf(CM_ReserveSelection) then
		//-----------Marks
		marks := _res.CM_ReserveSelection.getIdsAsString();
	endif;
	//-----------OnSite
	onSite := self.getOnSiteCargoNo(_res, tiArray);
	if onSite &lt; 0 then
		onSiteString := "n/a";
	else
		onSiteString := onSite.String;
	endif;
	//-----------Packed
	foreach ti in _res.allTrackedItemsReleased do
		if ti.myParent &lt;&gt; null then
			packed := packed + 1;
		endif;
	endforeach;
	//-----------Locations
	i := 0;
	foreach ti in tiArray do
		loc := ti.getPrimaryLocation(REAL_MODE);
		if loc &lt;&gt; null then
			if not locationArray.includes(loc.getFullId) then
				//locationArray.add(ti.myPrimaryActualLocation.getFullId);
				locationArray.add(loc.getFullId);
			endif;	
		else
			locationArray.add(ti.locationId);
		endif;
	endforeach;
	foreach str in locationArray do
		locations := locations &amp; str;
		if str &lt;&gt; locationArray.last then
			locations := locations &amp; CrLf;
		endif;
	endforeach;
	//-----------Display all
	return product&amp; Tab &amp; marks &amp; Tab &amp; _res.totalRequested.String &amp; Tab &amp; packed.String  &amp; Tab &amp; onSiteString &amp; Tab &amp; locations;
epilog
	delete tiArray;
	delete locationArray;
end;</source>
        <Parameter name="_res" type="CM_ReserveDetail"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTblCargoIDsSetting" id="f618cef0-4810-49d0-8a99-12882488ffdc">
