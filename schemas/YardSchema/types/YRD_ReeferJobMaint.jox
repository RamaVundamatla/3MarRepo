    <JadeMethod name="translateForm" id="02875804-b504-448f-a969-204b620fff8d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 July 2021 11:45:06.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023992, locale);
	btnDeleteJob.translateCaption(Xlat_0023993, locale);
	btnRefresh.translateCaption(Xlat_0024404, locale);
	btnUpdateTime.translateCaption(Xlat_0023994, locale);
	grpJobs.translateCaption(Xlat_0023995, locale);
	grpSelection.translateCaption(Xlat_0023996, locale);
	grpTypes.translateCaption(Xlat_0023997, locale);
	lblAction.translateCaption(Xlat_0023998, locale);
	lblSelect.translateCaption(Xlat_0023999, locale);
	mnuColOrg.translateCaption(Xlat_0024000, locale);
	mnuContext.translateCaption(Xlat_0024001, locale);
	mnuInspectObj.translateCaption(Xlat_0024002, locale);
	optAlarmType.translateCaption(Xlat_0024003, locale);
	optAllJobs.translateCaption(Xlat_0024004, locale);
	optAllTypes.translateCaption(Xlat_0024005, locale);
	optByGridArea.translateCaption(Xlat_0024006, locale);
	optByTerminal.translateCaption(Xlat_0024007, locale);
	optConnJob.translateCaption(Xlat_0024008, locale);
	optCurrentJobs.translateCaption(Xlat_0024009, locale);
	optDisconJob.translateCaption(Xlat_0024010, locale);
	optMonJob.translateCaption(Xlat_0024011, locale);
end;</source>
    </JadeMethod>
</GUIClass>
