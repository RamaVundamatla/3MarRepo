    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="602c83a3-e777-48c3-b5fd-d7edee1dd3fa">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_cmifCntrl: CMIF_BOLTransferController; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1901

*/

vars

	ti : CM_TrackedItem;

begin

	inheritMethod(_cmifCntrl, _passport);
	
	if _cmifCntrl.myFromBOL &lt;&gt; null then
		self.fromBolNumber := _cmifCntrl.myFromBOL.number;
	endif;
	
	if _cmifCntrl.myToBOL &lt;&gt; null then
		self.toBolNumber := _cmifCntrl.myToBOL.number;
	endif;
	
	ti := _cmifCntrl.myTrackedItem;
	if ti &lt;&gt; null then
		self.myTrackedItem := ti;
		self.commodity := ti.commodity;
		self.consignee := ti.consignee;
		self.locationId := ti.locationId;
		self.operator := ti.operatorCode;
		self.quantity := ti.totalQuantity;
		self.volume := ti.totalVolume;
		self.weight := ti.totalWeight;
		self.voyageCode := ti.voyageCode;
	endif;

epilog

end;</source>
        <Parameter name="_cmifCntrl" type="CMIF_BOLTransferController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setRelatedFromTransaction" id="4ad14d6e-8ed5-48c2-b06d-1946e76b15ce">
        <updating/>
        <source>setRelatedFromTransaction( _fromTransaction : CM_BOLTransferTransaction ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	self.myFromTfrTransaction := _fromTransaction;

epilog

end;</source>
        <Parameter name="_fromTransaction" type="CM_BOLTransferTransaction"/>
    </JadeMethod>
</Class>
