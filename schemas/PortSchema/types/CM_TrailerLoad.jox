    <JadeMethod name="qrySelectorCriteria" id="6a001045-ceb4-4168-bb3b-531fe0408491">
        <source>qrySelectorCriteria(_criteria: CM_SelectorCriteriaLine): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	propValue 	: Any; 
	retval 		: Boolean;
	oper 		: CM_QueryOperator;
	prop 		: String;
	valueToCheck : String;
begin
	if (_criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardCargoTypes.name or
		_criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardSubTypes.name or
		_criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardCosigneeCosignors.name or
		_criteria.myQueryProperty.propertyName =  CM_TITransaction::getParentTrailerTypeCode.name) then
		
		if _criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardCargoTypes.name then
			valueToCheck := self.getOnboardCargoTypes;
		elseif _criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardSubTypes.name then
			valueToCheck := self.getOnboardSubTypes;
		elseif _criteria.myQueryProperty.propertyName =  CM_TITransaction::getOnboardCosigneeCosignors.name then
			valueToCheck := self.getOnboardCosigneeCosignors;
		elseif _criteria.myQueryProperty.propertyName =  CM_TITransaction::getParentTrailerTypeCode.name then
			valueToCheck := self.getParentTrailerTypeCode;
		endif;		
			
		oper := _criteria.myQueryOperator;
		if oper &lt;&gt; null then 
			propValue := oper.getSearchValue;
			
			if propValue = null then
				return false;
			endif;
			if oper.description = CM_QueryOperator.Operator_IsOneOf or oper.description = CM_QueryOperator.Operator_Equal then
				if propValue.isKindOf(StringArray) then
					foreach prop in propValue.StringArray do
						if valueToCheck.pos(prop,1) &gt; 0 then
							return true;			
						endif;			
					endforeach;			
				elseif propValue.isKindOf(String) then
					if valueToCheck.pos(propValue.asStringJMT,1) &gt; 0 then
						return true;			
					endif;			
				endif;
			elseif oper.description = CM_QueryOperator.Operator_NotEqual then 
				if propValue.isKindOf(StringArray) then
					foreach prop in propValue.StringArray do
						if valueToCheck.pos(prop,1) = 0 then
							return true;			
						endif;			
					endforeach;			
				elseif propValue.isKindOf(String) then
					if valueToCheck.pos(propValue.asStringJMT,1) = 0 then
						return true;			
					endif;			
				endif;
			endif;
			
			return false;		
		endif;
		
		return false;		
	endif;

	return inheritMethod(_criteria);
epilog

end;</source>
        <Parameter name="_criteria" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="f9a8177f-bd45-4246-a781-6e96554310af">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2020	jlgndl1	Initial creation

*/

vars

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	if _tiTransCntrl.myVVR &lt;&gt; null then
		self.trailerTypeCode := _tiTransCntrl.myVVR.getTrailerTypeCode( self );
	endif; 

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
