<PrimType name="Date">
    <JadeMethod name="cnEcAddDays" id="a76060f1-7e84-4a60-80c0-be0b23c80380">
        <source>cnEcAddDays(pDays:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver date.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + pDays;
end;</source>
        <Parameter name="pDays" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddMonths" id="6fc043db-10ff-4f5e-b3f3-b82b04664793">
        <source>cnEcAddMonths(pMonths:Integer) : Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver date.
//
// Parameters:	pMonths (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dayNum		: Integer;
	monthNum	: Integer;
	yearNum		: Integer;
	daysInMonth : Integer;
	dateResult	: Date;
    
begin
	// Copy year, month and day attributes from self to local variables for computation.
	
	yearNum		:=	self.year;
	monthNum	:=	self.month;
	dayNum		:=	self.day;

	// Handle negative months parameters by going backwards in time.
	
	if monthNum + pMonths &lt; 1 then
		yearNum	:=	yearNum + (monthNum + pMonths - 12) div 12;
	else
		yearNum	:=	yearNum + (monthNum + pMonths - 1) div 12;
	endif;

	monthNum	:=	(monthNum + pMonths - 1) mod 12 + 1;
    
	if monthNum &lt; 1 then
		monthNum	:=	monthNum + 12;
	endif;

    // If end day exceeds last day of month, set day equal to the last day of the month.
    
	daysInMonth	:=	monthNum.cnEcDaysInMonth(yearNum.cnEcIsLeapYear());
    
	if dayNum &gt; daysInMonth then
		dayNum	:=	daysInMonth;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <Parameter name="pMonths" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddWeeks" id="d04d0419-5c8e-4e89-b833-e2ce6244aa71">
        <source>cnEcAddWeeks(pWeeks:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of weeks to the
//				receiver date.
//
// Parameters:	pWeeks (Integer) - The number of weeks to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	noDays	: Integer;
	
begin
	noDays	:=	pWeeks * 7;
	
	return self.cnEcAddDays(pWeeks);
end;</source>
        <Parameter name="pWeeks" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddYears" id="6885a281-ce45-4023-a7ee-97b416ff5ca0">
        <source>cnEcAddYears(pYears:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				receiver date.
//
// Parameters:	pYears (Integer) - The number of years to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
    dayNum		: Integer;
    monthNum	: Integer;
    yearNum		: Integer;
    dateResult	: Date;

begin
	// Copy year, month and day attributes from self to local variables for computation.

	yearNum		:=	year + pYears;
	monthNum	:=	month;
	dayNum		:=	day;

	// Handle special case where we end up with 29 Feb on non leap year, round down to 28th.
    
	if monthNum = 2 and dayNum = 29 and not yearNum.cnEcIsLeapYear() then
		dayNum	:=	28;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <Parameter name="pYears" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcCurrentAge" id="a16aa513-3bb8-43e1-8dae-c81e279b3ae8">
        <source>cnEcCurrentAge():String;
// If a valid date supplied, return current age in the format years:months:days 
// If invalid date format or a date in the future return null.
//
// Requires cnEcIsInFuture method to exist against Date.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	birthday	: String;			// Birth date
	today		: String;			// Today
	workArea	: String;			// Work area to carry this years birthday date
	age			: String;          	// Return Value  years:months:days
	ageYears	: Integer;			// Work area for years portion of the result
	ageMonths	: Integer;			// Work area for months portion of the result
	ageDays		: Integer;			// Work area for days portion of the result		

begin
	// Invalid date or date format, return null and stop.
	
	if self.Date = null or not self.Date.isValid then
		return null;
	endif;

	birthday	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer().Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	// If the date is in the future, return null and stop.
	
	if birthday.Date.cnEcIsInFuture() then
		return null;
	endif;

	// We have a valid date to work with.

   	workArea		:= birthday;
   	workArea[7:4]	:= today[7:4];						// Modify the year to become the actual date of this year's Birthday.

	if workArea.Date.cnEcIsInFuture() then
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer - 1;	
	else
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer;
	endif;

	age[1:3]	:= ageYears.String;						// Set the years value.
	age[4:1]	:= ":";

	if birthday[1:2] &lt;= today[1:2] then      			// Birthday 'day of the month' has occurred 
		if birthday[4:2] &gt; today[4:2] then   			// Birthday 'month' hasn't occurred yet.      
			ageMonths	:= 12 + today[4:2].Integer - birthday[4:2].Integer;
		else											// Birthday 'month' has occurred.
			ageMonths	:= today[4:2].Integer - birthday[4:2].Integer;
		endif;

		ageDays	:= today[1:2].Integer - birthday[1:2].Integer;       	
	endif;

	if birthday[1:2] &gt; today[1:2] then     				// Birthday 'day of the month' hasn't occurred yet.
		if birthday[4:2] &gt;= today[4:2] then   			// Birthday 'month' or before.
			ageMonths := 12  + today[4:2].Integer - birthday[4:2].Integer -1 ;
		else  	
			ageMonths := today[4:2].Integer - birthday[4:2].Integer - 1;
		endif;

		ageDays	:= 31;									// How many days between the relevant day last month and this month. Initially assume 31.

		// If last month was Apr, Jun, Sep or Nov change it to 30.
		
		if today[4:2].Integer - 1 = 4 or today[4:2].Integer - 1 = 6 or today[4:2].Integer - 1 = 9 or today[4:2].Integer - 1 = 11 then
			ageDays	:= 30;
		endif;

		if today[4:2].Integer - 1 = 2 then				// Last month was February.
			ageDays	:= 28;

			if today.Date.isLeapYear then
				ageDays	:= 29;
			endif;
		endif;

		ageDays	:= ageDays - birthday[1:2].Integer + today[1:2].Integer;
	endif;

	age[5:2]	:= ageMonths.String;					// Set the months value.
	age[7:1]	:= ":";
	age[8:2]	:= ageDays.String;						// Set the days value.

	// Correct any alignment problems caused by going from Integer to String during calculations.
	
	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[6:1] = " " then
		age[6:1]	:= age[5:1];
		age[5:1]	:= " ";
	endif;

	if age[9:1] = " " then
		age[9:1]	:= age[8:1];
		age[8:1]	:= " ";
	endif;

	return age;									//  Return value and stop.
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDaysInMonth" id="deefbeb1-7cc8-4acc-bc4d-da89d8f5cad7">
        <source>cnEcDaysInMonth():Integer;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days in the month of the receiver.
//
// Parameters:	None
//
// Returns:		The number of the days.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.month.cnEcDaysInMonth(self.year.cnEcIsLeapYear());
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcDaysInYear" id="32cb5167-383b-4a29-83f4-84b30ef44959">
        <source>cnEcDaysInYear():Integer;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		Returns the number of days in the receiver's current year.
//
// Parameters:	None
//
// Returns:		The number of days in the year.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMonth	: Integer;
	daysInYear	: Integer;

begin
	foreach theMonth in 1 to 12 do
		daysInYear	:=	daysInYear + theMonth.cnEcDaysInMonth(self.year.cnEcIsLeapYear());
	endforeach;

	return daysInYear;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAnsiFormat" id="4af6ce8c-d0c0-4ffc-9bf7-c79bfa5dd04b">
        <source>cnEcGetAnsiFormat():String;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Convert a Date type to an ANSI type string "2000-12-31".
//
//				Refer to the String::cnEcGetAnsiDateFormat method to retrieve an
//				ANSI date from a string.
//
// Parameters:	None
//
// Returns:		A string of the resulting date format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.userFormat($CNEC_ANSI_DATE_FORMAT);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCentury" id="c647f544-c9e2-4038-9197-05a8f0818d8f">
        <source>cnEcGetCentury():Integer;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's century.  If the receiver is not valid, then
//				a value of zero will be returned.
//
// Parameters:	None
//
// Returns:		The two-digit century as an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt;&gt; null and self.isValid then
		return (self.year - self.format("yy").Integer) div 100;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetFirstDayOfMonth" id="025db994-64a9-49d9-96e4-b4c079e9ff53">
        <source>cnEcGetFirstDayOfMonth() : Date;
/*

Date		    Who			Reason
03 November 2010	cnwas3	  Initial creation

*/

vars
	date : Date;
begin
	date.setDate(1,self.month(),self.year());
	return date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetLastDayOfMonth" id="1b1af1ae-5608-48af-a772-2493acc13c1a">
        <source>cnEcGetLastDayOfMonth() : Date;
/*

Date		    Who			Reason
15 December 2010	cnwas3	  Get the last day of the current month, for the current year.

*/

vars

	date : Date;
	pos : Integer;	
	
begin	

	date.setDate( pos, self.month, self.year );
	
	foreach pos in 1 to 31 reversed do
		date.setDate( pos, self.month, self.year );
		if not date.isValid then
			continue;
		endif;		
		return date;
	endforeach;
	
	return null;	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetLastMonday" id="409a8aec-ae02-4151-a3b9-6ccc4c4b398d">
        <source>cnEcGetLastMonday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the last Monday prior to the date of the
//				receiver.  If the receiver is already a Monday, then the previous
//				Monday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek = 1 then
		return self - 7;
	else
		return self - self.dayOfWeek + 1;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetLastSunday" id="baa25db2-001c-4c49-9029-7b6a4eb2feea">
        <source>cnEcGetLastSunday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the last Sunday prior to the date of the
//				receiver.  If the receiver is already a Sunday, then the previous
//				Sunday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self - self.dayOfWeek;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextMonday" id="24d3de51-2bf3-4386-8630-057f55d49db9">
        <source>cnEcGetNextMonday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the next Monday following the date of the
//				receiver.  If the receiver is already a Monday, then the following
//				Monday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self - self.dayOfWeek + 8;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextSunday" id="423370a0-33b8-4962-8e5a-403cbc063038">
        <source>cnEcGetNextSunday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the next Sunday following the date of the
//				receiver.  If the receiver is already a Sunday, then the following
//				Sunday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek = 7 then
		return self + 7;
	else
		return self - self.dayOfWeek + 7;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextWeekDay" id="13f23240-b97e-4335-9035-c73a420ac8a3">
        <source>cnEcGetNextWeekDay():Date;
// --------------------------------------------------------------------------------
// Created:		30 March 2005 by cnwdad1
//
// Purpose:		Returns the next week day following the receiver.
//
// Parameters:	None
//
// Returns:		The date of the next week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nextDay	: Date;
	
begin
	nextDay	:=	(self + 1);
	
	if nextDay.dayOfWeek &gt; 5 then
		return nextDay + (7 - self.dayOfWeek);
	else
		return nextDay;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetPreviousWeekDay" id="0ad6bce7-747c-4f39-aeb5-b977c732c094">
        <source>cnEcGetPreviousWeekDay():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the previous week day to the receiver.
//
// Parameters:	None
//
// Returns:		The date of the previous week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	previousDay	: Date;
	
begin
	previousDay	:=	(self - 1);
	
	if previousDay.dayOfWeek &gt; 5 then
		return previousDay - (previousDay.dayOfWeek - 5);
	else
		return previousDay;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWeek" id="5530ea21-8ddd-440a-9dfd-dc9d120ba894">
        <source>cnEcGetWeek():Integer;
// --------------------------------------------------------------------------------
// Created:		19 December 2000 by cnwdad2
//
// Purpose:		Returns the Year's week number for the receiver.
//
// Parameters:	None
//
// Returns:		Integer - The week number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek = 7 then
		return (self.dayOfYear div 7);
	else
		return ((self.dayOfYear div 7) + 1);
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsBetween" id="388e9361-849e-45be-971b-faa1ef55ba2b">
        <source>cnEcIsBetween(pStartDate:Date; pEndDate:Date):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Check to see whether the receiver is within the range of the dates
//				passed in.
//
// Parameters:	pStartDate (Date) - The starting (lower range) date.
//				pEndDate (Date) - The ending (upper range) date.
//
// Returns:		True if the receiver is between the specified dates, otherwise false.
//				NOTE: False is returned if the receiver is null or not a valid date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = null then
		return false;
	elseif not self.isValid then
		return false;
	endif;

	if pStartDate &lt;&gt; null then
		if pStartDate &gt; self then
			return false;
		endif;
	endif;

	if pEndDate &lt;&gt; null then
		if pEndDate &lt; self then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="pStartDate" type="Date"/>
        <Parameter name="pEndDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsInFuture" id="856048da-bd04-473a-ac6f-36b91896435a">
        <source>cnEcIsInFuture():Boolean;
// If given a valid date that is in the future will return true.
// If invalid date format, or date has passed, returns false.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	testDate	: String;					// Date given
	today		: String;					// Today

begin
	// If Invalid Date or Date format, return false and break.
	
	if self.Date = null
	or not self.Date.isValid
	then
		return null;
	endif;

	testDate	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer().Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	if testDate[7:4] &gt; today[7:4] then		// Year is in the future, return true and break.
		return true;
	endif;

	// Current Year and Month is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] &gt; today[4:2]
	then
		return true;
	endif;

	// If Current Year and Current Month and day is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] = today[4:2]
	and testDate[1:2] &gt; today[1:2]
	then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLeapYear" id="c70d3cd5-dcaa-4485-9957-145bc94b1cb8">
        <source>cnEcIsLeapYear():Boolean;
// --------------------------------------------------------------------------------
// Created:		06 January 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is in a
//				leap year.
//
// Parameters:	None
//
// Returns:		True if the receiver is in a leap year, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.year.cnEcIsLeapYear();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsNotValid" id="8ef06c8c-a888-4ee9-ab92-e8be8c0e86dd">
        <source>cnEcIsNotValid():Boolean;
// --------------------------------------------------------------------------------
// Created:		05 May 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is NOT a
//				valid date.
//
// Parameters:	None
//
// Returns:		True if the receiver is NOT valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isValid());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsWeekDay" id="67bc37c2-2f63-47b0-ac84-743c18054878">
        <source>cnEcIsWeekDay():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a week
//				day.
//
// Parameters:	None
//
// Returns:		True if the receiver is a week day, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/12/2002	cnwdad1		The method was returning true only if the date WAS NOT
//							a week day.
// --------------------------------------------------------------------------------
begin
//	return (self.dayOfWeek &gt; 5);
	return (self.dayOfWeek &lt;= 5);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMax" id="b2374279-b431-4926-9063-83d653481991">
        <source>cnEcMax(pDate:Date):Date;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the latest date between the receiver and the
//				parameter.
//
// Parameters:	pDate - The date to compare the receiver to.
//
// Returns:		The latest date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt; pDate then
		return self;
	else
		return pDate;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcMin" id="871b4571-838e-436f-86d8-0703a2b51900">
        <source>cnEcMin(pDate:Date):Date;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the earliest date between the receiver and the
//				parameter.
//
// Parameters:	pDate - The date to compare the receiver to.
//
// Returns:		The earliest date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt; pDate then
		return self;
	else
		return pDate;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetBeginningOfMonth" id="f405a6f9-cfb1-4206-a266-666537d3b16d">
        <updating/>
        <source>cnEcSetBeginningOfMonth() updating;
/*

Date		    Who			Reason
03 November 2010	cnwas3	  ccms 1108

*/

vars

begin
	self.setDate(1,self.month(),self.year());
epilog

end;</source>
