    </JadeMethod>
    <JadeMethod name="doButtonSaveClick" id="91173bf3-316b-43a3-b25c-b5c56339eec8">
        <updating/>
        <source>doButtonSaveClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgab1	Initial creation
25 Sep 2019 cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
09 Jan 2020 cnwma1  Bug 48211: JMT - 4 x Issues relating to cash credit totals.
*/

vars

	cashPaymentAmount,
	secondPaymentAmount	: Decimal[23,6];
	debtorLabel         : String;
begin
	if self.isInvoiceProforma then
		self.doProformaPrint();
		return;
	endif;
	
	if self.myDebtor = null then
		debtorLabel := self.lblAgent.caption;
		
		if debtorLabel.trimBlanks() &lt;&gt; null then
			app.msgBox(app.getErrorString1(Please_Select_A, debtorLabel), app.getErrorString(Problem), MsgBox_OK_Only);
		endif;
		
		return;
	endif;
	
	// ### UPDATE TFS 46032
	if self.myQueryCashReceipt &lt;&gt; null then
		self.doSaveUpdate(); // update comments and debtor only
		self.unloadForm();
	// ### CREATE TFS 46032
	else
		if self.myProxyCashReceipt = null then   //25.09.2019 cnwma1 #46582
			return;
		endif;
		
		//cashPaymentAmount := self.txtCashPayment.text.asDecimalJMT;   //09.01.2020 cnwma1 #48211
		cashPaymentAmount   := self.cashRequiredToClearCharges;         //09.01.2020 cnwma1 #48211
		
		if self.convertMultiplyRate &lt;&gt; 0 then 
			//secondPaymentAmount := (self.txtCashPayment2nd.text.asDecimalJMT * self.convertMultiplyRate).roundedTo(2);
			secondPaymentAmount := self.txtCashPayment2nd.text.asDecimalJMT * self.convertMultiplyRate;
		endif;
		
		cashPaymentAmount := cashPaymentAmount + secondPaymentAmount;
		
		self.myProxyCashReceipt.setCashValue(cashPaymentAmount);
		
		if self.doValidate( cashPaymentAmount ) then
			if self.doSave() then
				self.setDefaultCargoDebtorDetails();
			endif;
		endif;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCalculate" id="c78111b5-07a5-4311-b4e5-6c6eb50da99e">
        <updating/>
        <source>doCalculate() protected, updating;

/*

Purpose:			Do the pro forma processing for the selected cargo and show the results.

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2012	cnwndl1	Initial creation

*/

vars
	allTIs	: ObjectArray;
	row		: Integer;
	ti		: CM_TrackedItem;
	child	: CM_TrackedItem;
	obj		: Object;
	logger	: CMIF_Logger;
	tild	: CM_InvoiceLineDesc;
	debtorLabel : String;
	includeTI : Boolean;
begin
	create allTIs transient;
	
	if tblCharges.rows &lt;= 1 then
		return;
	endif;

	
	if self.myDebtor = null then
		debtorLabel := self.lblAgent.caption;
		
		if debtorLabel.trimBlanks() &lt;&gt; null then
			app.msgBox(app.getErrorString1(Please_Select_A, debtorLabel), app.getErrorString(Problem), MsgBox_OK_Only);
		endif;
		
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	if self.mnuTrace.checked then
		create logger transient;
		app.setLogger(logger);
	endif;
	
	if self.cashDebtorType &lt;&gt; null then
		self.applyAgentToCargo();
	endif;
	
	self.includeVoyageProforma := false;
	
	row := 2;
	while row &lt;= self.tblCharges.rows do
		obj := self.tblCharges.accessRow(row).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_TrackedItem ) then
				ti := obj.CM_TrackedItem;
				
				/* TFS 47864 WAS
				if self.tblCharges.accessCell(row, 1).text = self.selectedString then
					allTIs.addExclusive(ti); // TFS 45953
					// add the children here
					foreach child in ti.allChildren do
						if not allTIs.includes(child) then
							allTIs.add(child);
						endif;
					endforeach;
				endif;
				NOW */
				// TFS 47864 need to include ti if doing find or clicking calculate again
				includeTI := (self.tblCharges.helpKeyword = "CHARGES") 
									or (self.tblCharges.accessCell(row, 1).text = self.selectedString);
				if includeTI then // TFS 47864 calculate again
					allTIs.addExclusive(ti);
					// add the children here
					foreach child in ti.allChildren do
						if not allTIs.includes(child) then
							allTIs.add(child);
						endif;
					endforeach;
				endif;
				
			elseif obj.isKindOf(CM_Voyage) then
				self.includeVoyageProforma := (self.tblCharges.accessCell(row, 1).text = self.selectedString);
			endif;
		endif;
		
		row := row +1;
		
	endwhile;

	self.proformaGetAndDisplay(allTIs);

	if logger &lt;&gt; null then
		self.doShowLogging(logger);
	endif;
	
epilog
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
	app.mousePointer := MP_DEFAULT;
	delete allTIs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeMOP" id="9089956a-dbd9-432a-8fdc-11e6ba47cd0a">
        <source>doChangeMOP() protected;
/*

Purpose:			Show/hide cheque or POS fields from payment method setting.

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	mop : CM_PaymentMethod;

begin

	self.frmChqDetails.visible := false;
	self.frmPOSDetails.visible := false;
	mop := self.cmbMOP.listObject.CM_PaymentMethod;
	if mop = null then
		return;
	endif;
	if mop.isCheque then
		self.frmChqDetails.visible := true;
	elseif mop.isPOS then
		self.frmPOSDetails.visible := true;
	endif;

	if self.myProxyCashReceipt &lt;&gt; null then
		self.myProxyCashReceipt.setPxyForPaymentMethod(mop);		// 9/9/19 MAP TFS44266
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCompareProformaAndExisting" id="7e480643-32f8-455f-a9ce-48f49d93cf3b">
        <updating/>
        <source>doCompareProformaAndExisting(_pxyCashReceiptFromAgent : CM_CashReceipt input; _allReceiptFound : CM_CashReceiptSet) updating;
/*

Purpose:			This method compares the cash payments calculated from the Agent with the existing cash receipts.
					If the cash payments from Agent are in the existing cash receipt that is on Hold/Draft, we discard them as they should get paid in the existing one.
					If it's not, it will proceed to create a new draft receipt for the cash payment that is not already in the existing cash receipts.
					
					For example
						Existing hold/draft cash receipt has
							Cargo 1
								Storage cash payment
								Release road cash payment
						
						Agent comes back with
							Cargo 1
								Storage cash payment				- This will be discarded
								Release road cash payment			- This will be discarded
								Additional charnges cash payment 	- This will remains
					
					_pxyCashReceiptFromAgent will gets updated
						If all cash payments from the agent are discarded, nothing to be paid.
						If there is cash payment remains, they will be created in new draft cash receipt

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2025	navkc1 JIRA Bug MTN-34734: QTS | UAT - Hard stop for Cancelled Additional charges cash receipt.

*/

vars
	existingCashReceipt 	: CM_CashReceipt;
	cashPaymentAgent,
	cashPaymentExisting 	: CM_CashPayment; 
	allCashPaymentsAgent 	: CM_CashPaymentSet;
	invoiceLineAgent,
	invoiceLineExisting		: CM_InvoiceLine;
	proformaDetailsAgent,
	proformaDetailsExisting	: CM_ProformaDetails;
	allPxyCashPaymentToDelete : CM_CashPaymentSet;
	taxAmountToDeduct,
	cargoAmountToDeduct		: Decimal[23,6];
begin
	
	//CMIF_CashInvoiceProformaCtrl::doCompareProformaAndExisting;
	// Should do something similar
	
	// Nothing to compare
	if _allReceiptFound.isEmpty() then
		return;
	endif;
	
	create allPxyCashPaymentToDelete transient;
	create allCashPaymentsAgent transient;
	_pxyCashReceiptFromAgent.allCashPayments.copy(allCashPaymentsAgent);
	
	// Go through cash payments from Agent
	foreach cashPaymentAgent in allCashPaymentsAgent do : agent
		// On the UI, if it's a real object, always display it
		if cashPaymentAgent.pxyGetRealObject() &lt;&gt; null then
			continue;
		endif;
		
		invoiceLineAgent := cashPaymentAgent.myInvoiceLine;
		proformaDetailsAgent := cashPaymentAgent.getMyProformaDetails();
		
		// Compare with the existing cash payment
		foreach existingCashReceipt in _allReceiptFound do
			if not global.isValidObject(existingCashReceipt) then
				continue;
			endif;
			
			// If existing cash receipt is in Draft or Hold, we want to discard the cash payment from Agent if it matches
			if existingCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_HOLD and existingCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_DRAFT then
				continue;
			endif;
			
			foreach cashPaymentExisting in existingCashReceipt.allCashPayments discreteLock do
				invoiceLineExisting := cashPaymentExisting.myInvoiceLine;
				proformaDetailsExisting := cashPaymentExisting.getMyProformaDetails();
				
				// Check Invoice Line and amount
				if invoiceLineAgent &lt;&gt; null and invoiceLineExisting &lt;&gt; null and invoiceLineAgent.invoiceLineDesc = invoiceLineExisting.invoiceLineDesc then
					// It's the same invoice line type and cash amount, discard this from agent. This should be paid in the existing draft/hold receipt
					if cashPaymentAgent.cashValue &lt;= cashPaymentExisting.cashValue then
						allPxyCashPaymentToDelete.tryAdd(cashPaymentAgent);
						continue agent;
					endif;
				endif;
				
				
				// Check Profoma details and amount
				if proformaDetailsAgent &lt;&gt; null and proformaDetailsExisting &lt;&gt; null and proformaDetailsAgent.myInvoiceLineType = proformaDetailsExisting.myInvoiceLineType then
					// It's the proforma type and cash amount, discard this from agent. This should be paid in the existing draft/hold receipt
					if cashPaymentAgent.cashValue &lt;= cashPaymentExisting.cashValue then
						allPxyCashPaymentToDelete.tryAdd(cashPaymentAgent);
						continue agent;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	// Discard the cash payment from agent
	allPxyCashPaymentToDelete.purge();
	// Recalculate the balances
	self.setBalances();
epilog
	delete allCashPaymentsAgent;
	delete allPxyCashPaymentToDelete;
end;</source>
        <Parameter name="_pxyCashReceiptFromAgent" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_allReceiptFound" type="CM_CashReceiptSet"/>
    </JadeMethod>
    <JadeMethod name="doCreateProformaPrint" id="f1f4670c-b0ab-4f37-8c52-cf5fe7ec492f">
        <updating/>
        <source>doCreateProformaPrint() : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Changes

/* Changes

Date		Name	TFS#		Description
============================================================================
10/08/2017	jlgdap1	TFS 5740 	Initial creation  AAT Changes to Pro Forma Invoices
20/10/2017	jlgdap1	TFS 7510 	AAT Comments on Cash Receipt not appearing on proforma invoice
14/02/2019	cnwma1	42918		GUQ - Proforma Invoice.
10/04/2019	jlgka1	44252		AAT - Test Issue - Printing Proforma Invoice.
============================================================================*/

vars
	row					: Integer;
	now 				: TimeStamp;
	obj 				: Object;
	debtorTerm 			: CM_DebtorTerminal;
	proformaReceipt 	: CM_CashReceiptProformaPrint;
	realReceipt 		: CM_CashReceiptProformaPrint;
	proformaPayment 	: CM_CashPaymentProformaPrint;
	proformaAgent 		: CM_CashInvoiceProformaAgent;
	invLine 			: CM_InvoiceLine;
	theReturn 			: Integer;
	index 				: Integer;
	allAgents 			: ObjectArray;
	showProformaDebtor	: Boolean;				
	clearComments 		: Boolean;		
	payment : CM_CashPayment;
begin

	//19 Oct 2017	NDL	FS 7481
	if self.myDebtor = null then
		app.msgBox( app.getErrorString(Debtor_not_found), app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
	endif;
	
	//"Record Proforma Invoice Print Debtor" from Cash Module Config
	showProformaDebtor := self.myTerminal.getConfig(ShowDebtorForProforma).Boolean;
	
	// Only do this TRX IF we want to record who printed what.
	if showProformaDebtor then
	
		proformaReceipt := self.myProxyCashReceipt.CM_CashReceiptProformaPrint;
		
		// TFS 47985 do not try to re save this already saved proforma.
		// SHOULD REALLY CHANGE PROFORM SAVE TOP USE THE ORDINARY TRX
		foreach payment in proformaReceipt.allCashPayments	discreteLock do
			if payment.pxyGetRealObject &lt;&gt; null then
				return true;
			endif;
		endforeach;
	
			
		proformaReceipt.allInvoiceLines.clear(); // TFS 47847 clear out transient manual invoice lines

		// we have a proforma cash receipt, with payments for actual, estimated and extra charges
		// pass this to the trx to persist
		while true do
			app.myTrxCA.trxCreateCashPrintProforma(proformaReceipt, self.myCashReceiptProformaPrint, app.myPassport);
			if app.myPassport.trxCompletedOK then
				clearComments := true;						// TFS 7510
				break;
			else
				theReturn := app.showErrorWarningDialog("Cash Receipt", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			
				return false;
			endif;
			break;
		endwhile;
		
	endif;
	return true;
	
epilog
	if clearComments then								// TFS 7510
		self.cashComments := null;						// TFS 7510
	endif;												// TFS 7510

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="706c7227-c8e5-4dc6-a59c-9e9950c4341d">
        <updating/>
        <source>doEdit() updating;
/*
Purpose:	TFS 46032		
Date				Who			Reason
AUGUST 2019		JLGAB1 initial creation
*/


vars

	index	: Integer;
begin
	self.btnEdit.enabled := false;

	self.cashDebtorType := self.myTerminal.getConfig(CashDebtorType).CM_DebtorType;
	if self.cashDebtorType &lt;&gt; null then
		self.populateAgentCombo(null); 
		index := self.cmbAgent.findObject(self.myQueryCashReceipt.myAgent);
		if index &gt; 0 then
			self.cmbAgent.listIndex := index;
		endif;

	endif;
	
	self.lblAgent.visible := true;
	self.lblAgent.width := (self.cmbAgent.left -self.lblAgent.left); 
	self.cmbAgent.visible := true;
	self.chkPrintRec.caption := "Print Receipt";
	self.chkPrintRec.visible := true;
	self.btnSave.visible := true;
	self.btnSave.enabled := app.myCurrentUserCan( self.myTerminal, PmGteCashCollectionMaint );	//10 Dec 2019	NDL	TFS 47963 
	self.btnComments.enabled := true; 
	self.cmbAgent.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableEdit" id="7a2e815c-5a55-4e8b-8cd3-8bb224592f53">
        <source>doEnableEdit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars
	isWorkOrderCashRec : Boolean;
begin
	
	if self.myQueryCashReceipt &lt;&gt; null then
