    <JadeMethod name="setMyOriginatingBulkRelease" id="f490bcdf-8489-4b89-ad6d-2cfb7423f263">
        <updating/>
        <source>setMyOriginatingBulkRelease(_value : CM_BulkRelease) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.isTransient) then
   		// Do this to trigger an Update Event for any forms registered
	   	// for an update on the bulk release which has an inverse.
		if _value = null and
		   self.myOriginatingBulkRelease &lt;&gt; null then
		   	self.myOriginatingBulkRelease.causeUpdateEvent();
		elseif _value &lt;&gt; null and
	       self.myOriginatingBulkRelease = null then
		   	_value.causeUpdateEvent();
		elseif _value &lt;&gt; null and
	       self.myOriginatingBulkRelease &lt;&gt; null and 
		   _value &lt;&gt; self.myOriginatingBulkRelease then
		   self.myOriginatingBulkRelease.causeUpdateEvent();
		   _value.causeUpdateEvent();
		endif;
	endif;

	self.myOriginatingBulkRelease := _value;

end;</source>
        <Parameter name="_value" type="CM_BulkRelease"/>
    </JadeMethod>
