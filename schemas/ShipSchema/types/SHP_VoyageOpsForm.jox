    <JadeMethod name="cmbVoyage_displayEntry" id="4dc00909-cb5d-4e6f-85a1-1ce040e38966">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
// 02/10/2015 cnwma1 PAR #36962 Voyage Operations search
//--------------------------------------------------
vars
	voyage : CM_Voyage;

begin
	voyage := obj.CM_Voyage;
	if self.chkLOLOBays.value and voyage.myCellularVoyageStructure &lt;&gt; null then
		// include LOLO voyages and voyage is LOLO
		return self.myAssistant.displayEntryVoyageObject(voyage);
	elseif self.chkRORODecks.value and voyage.myROROStructure &lt;&gt; null then
		// include RORO voyages and voyage is RORO
		return self.myAssistant.displayEntryVoyageObject(voyage);
	elseif self.chkHolds.value and voyage.myGeneralCargoVoyage &lt;&gt; null then
		// include HOLDS voyages and voyage has HOLDS
		return self.myAssistant.displayEntryVoyageObject(voyage);
	elseif self.chkBlockStack.value and ( voyage.myShipBlockStack &lt;&gt; null or voyage.isNullVoyage) then //02/10/2015 cnwma1 PAR #36962
		return self.myAssistant.displayEntryVoyageObject(voyage);
	else
		return null;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
