    <JadeMethod name="armNotesForObject" id="52b1dc48-7354-49dd-9de5-7aecf4b3122c">
        <source>armNotesForObject(_object: CM_SnapShot);
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiSnapShot	: CM_TISnapShot;
begin

