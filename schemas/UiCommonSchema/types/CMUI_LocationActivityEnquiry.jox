    <JadeMethod name="translateForm" id="a6d91d3d-3078-4719-b969-1ab961d9b621">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 July 2021 11:40:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024230, locale);
	btnCSV.translateBubbleHelp(Xlat_0024164, locale);
	btnCSV.translateCaption(Xlat_0024165, locale);
	btnEdit.translateBubbleHelp(Xlat_0024166, locale);
	btnEdit.translateCaption(Xlat_0024167, locale);
	btnPrint.translateBubbleHelp(Xlat_0024170, locale);
	btnPrint.translateCaption(Xlat_0024171, locale);
	btnQuery.translateCaption(Xlat_0024172, locale);
	btnRefresh.translateCaption(Xlat_0024173, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0024174, locale);
	btnResetSearch.translateCaption(Xlat_0024175, locale);
	frmSearchCrit.translateCaption(Xlat_0024177, locale);
	grpCriteria.translateCaption(Xlat_0024393, locale);
	lblCargoTYpe.translateCaption(Xlat_0024178, locale);
	lblCloseDate.translateCaption(Xlat_0024179, locale);
	lblLocation.translateCaption(Xlat_0024180, locale);
	lblLocationType.translateCaption(Xlat_0024181, locale);
	lblOpenDate.translateCaption(Xlat_0024182, locale);
	lblOperator.translateCaption(Xlat_0024183, locale);
	lblTerminalArea.translateCaption(Xlat_0024184, locale);
	mnuAudits.translateCaption(Xlat_0024185, locale);
	mnuColOrg.translateCaption(Xlat_0024186, locale);
	mnuColourLegend.translateCaption(Xlat_0024394, locale);
	mnuContext.translateCaption(Xlat_0024187, locale);
	mnuEditLocAct.translateCaption(Xlat_0024188, locale);
	mnuInspect.translateCaption(Xlat_0024189, locale);
	mnuInvoiceLineShow.translateCaption(Xlat_0024273, locale);
	mnuInvoiceShow.translateCaption(Xlat_0024274, locale);
	mnuResync.translateCaption(Xlat_0024275, locale);
	staLine.translateCaption(Xlat_0024190, locale);
end;</source>
