    <JadeMethod name="getAuditText" id="a6003a59-228d-4e77-8e1f-077be7dd4deb">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61331: Jade - Terms Audits

*/

vars
	audTxt, 
	tmpStr			: String;	
	term			: CM_InvoiceTermsOfTrade;
begin

	audTxt[10000] 	:= '*';
	audTxt			:= null;
	
	audTxt := inheritMethod();
	
	return audTxt;

epilog

end;</source>
