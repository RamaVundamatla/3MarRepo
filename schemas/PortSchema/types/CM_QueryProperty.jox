    <JadeMethod name="setListTableFromIntConstants" id="813195ef-c758-45e2-80c8-8e5628e0eeec">
        <source>setListTableFromIntConstants(_tbl: Table input; _operator: CM_QIntegerIsOneOf; _intConsts: IntegerArray; _categoryName: String);
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intConst	: Integer;
	strObj		: CM_String;
	idx			: Integer;
begin

	foreach intConst in _intConsts do
		if _categoryName = TI_SITE_Constant then
			strObj := app.siteEnumToStringObject(intConst);
		elseif _categoryName = TI_STATE_Constant then
			strObj := app.stateEnumToStringObject(intConst);
		elseif _categoryName = TI_TRANSMODE_Constant then
			strObj := app.transModeToStringObject(intConst);
		elseif _categoryName = TI_PLANNINGSTATE_Constant then
			strObj := app.planningStateEnumToStringObj(intConst);
		elseif _categoryName = TI_COU_TYPE_Constant then
			strObj := app.couTypeEnumToStringObject(intConst);
		elseif _categoryName = Container_CoolingType_Constant then
			strObj := app.coolingTypeENumToStringObj(intConst);			
		elseif _categoryName = Container_VoltageType_Constant then
			strObj := app.voltageTypeENumToStringObj(intConst);	
		elseif _categoryName = TI_INTENDRELEASEMODE_Constant then //+ cnwmd1, CCMS 1067, Par 19710
			strObj := app.intendedReleaseModeToObject(intConst);
		elseif _categoryName = Audit_Type_Constant then			// 7/6/18 MAP TFS37718
			strObj := app.auditTypeEnumToStringObject(intConst);
		else
			continue;
		endif;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(intConst) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; strObj.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; strObj.string);	
		endif;
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;


end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_intConsts" type="IntegerArray"/>
        <Parameter name="_categoryName" type="String"/>
    </JadeMethod>
