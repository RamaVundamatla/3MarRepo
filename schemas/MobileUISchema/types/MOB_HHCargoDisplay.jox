<GUIClass name="MOB_HHCargoDisplay" id="4bf1c50f-d599-4d52-862c-6fdb24038ed5">
    <superclass name="MOB_HHTruckCargo"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="checkIfLockedDown" id="588321c7-e784-4483-a894-0f22bfd016ae">
        <source>checkIfLockedDown();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	row : Integer;
	entTableRow : EntTableRowTransient;
begin

	if self.lockedDown then
		row := tblCargo.row;
		if row &gt; 0 and row &lt;= self.tblCargo.rows then
			entTableRow := self.tblCargo.allEntRowTransients[row].EntTableRowTransient;
			if entTableRow &lt;&gt; null and self.class.getPropertyInHTree(entTableRow.controlName) = null then
				self.msgBox( app.getErrorString1(No_Handheld_Chg_allowed, tblCargo.getCellText(row,1)) ,app.getErrorString(Warning) ,MsgBox_OK_Only, true );
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationForTablePopulation" id="9be68f7c-d718-444d-a474-458e6b4cfaea">
        <source>getLocationForTablePopulation(entTableRow: EntTableRowEntity; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars

	dataValue : String;
	
begin

	dataValue := self.myTrackedItem.getDisplayStringForAttribute(entTableRow.name,false);
	
	return dataValue;
				
epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
