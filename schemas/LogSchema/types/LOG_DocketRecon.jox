    <JadeMethod name="bolOutHdrAdd" id="a5961f0b-6d64-4b72-a58c-61942bbf811e">
        <source>bolOutHdrAdd();
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	self.myAssistant.LOG_Assistant.inputLogReleaseData(null);
	//self.showScaleData();				
end;</source>
    </JadeMethod>
    <JadeMethod name="bolOutHdrDelete" id="c35def5b-1421-47bf-b454-b989d5f9edd9">
        <updating/>
        <source>bolOutHdrDelete() updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	msgStr 			: String;
	tmpBOLOutHdr 	: CM_BOLOutHeader;
	edition		: Integer;
	invalidObj : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentBOLOutHdr, invalidObj);
	
	if self.myCurrentBOLOutHdr = null then
		app.msgBox('Please select from table the unmatched data to be deleted.','Select Unmatched Data', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;		
	endif;
	
	msgStr := 'Are you sure you want to delete' &amp; CrLf &amp;
		      'Docket Header ' &amp; self.myCurrentBOLOutHdr.bolNumber.String &amp; ' ?';

	if app.msgBox(msgStr, 'Docket Header Delete', MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	// par 16848 -AER 13/10/2008
	// self.myCurrentBOLOutHdr can be set to null by notification processing while msgBox is shown
	if self.myCurrentBOLOutHdr = null then
		return;		
	endif;
	exclusiveLock(self.myCurrentBOLOutHdr);
	
	tmpBOLOutHdr := self.myCurrentBOLOutHdr;	
		
	// delete it here!!!
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteBOLOutHeader(tmpBOLOutHdr, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Docket Reconciliation', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.setCurrentHeaderEdition(null);
	self.clearHeaderEntry();		
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="bolOutHdrEdit" id="e8c4a884-fe5c-4b9c-8d31-3d8fc1a927e0">
        <updating/>
        <source>bolOutHdrEdit() updating;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.myCurrentBOLOutHdr = null then
		app.msgBox('Please select unmatched header to be edited.','Select Unmatched Header', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	self.myAssistant.LOG_Assistant.inputLogReleaseData(self.myCurrentBOLOutHdr);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="bolOutHdrSave" id="ed6ae01f-e5ee-48e4-b450-56e09a2f6f25">
        <updating/>
        <source>bolOutHdrSave() updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	ls 				: Boolean;
	pxyBOLOutHdr 	: CM_BOLOutHeader;
	number, supplier : String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if self.myCurrentBOLOutHdr = null then
		return;
	endif;

	if self.myCurrentBOLOutHdr.edition &lt;&gt; self.headerEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Docket Header', null, null);
		return;
	endif;
		
	number		:=	tblTicketEntry.getValueByName(ETRow_DocketNumber).String.toUpper();
	supplier	:=	tblTicketEntry.getValueByName(ETRow_Supplier).String;
	
	//Check for any change, return if no change.
	if number = self.myCurrentBOLOutHdr.bolNumber and
	   supplier = self.myCurrentBOLOutHdr.operatorCode then
	   	return;
	endif;
	
	app.cmsBeginLoad(ls);
	sharedLock(self.myCurrentBOLOutHdr);
	pxyBOLOutHdr := app.createUpdateProxy(self.myCurrentBOLOutHdr).CM_BOLOutHeader;
	
	pxyBOLOutHdr.setProxy(BOLType_Log, number, supplier,
						 pxyBOLOutHdr.userCode,
						 pxyBOLOutHdr.inputDateTime,
						 pxyBOLOutHdr.myTerminal);
						 
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateBOLOutHeader(pxyBOLOutHdr, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.setCurrentHeaderEdition(self.myCurrentBOLOutHdr);
			break;
		else
			theResult := app.showErrorWarningDialog('Docket Reconciliation', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	delete pxyBOLOutHdr;
	app.cmsEndLoad(ls);	
end;</source>
    </JadeMethod>
