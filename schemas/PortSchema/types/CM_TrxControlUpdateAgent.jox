    <JadeMethod name="trxUpdateWorkOrder" id="b1212e86-cab9-40ba-944e-fd31f87cd492">
        <updating/>
        <source>trxUpdateWorkOrder(_pxyWorkOrder : CM_WorkOrder input;
					_updateTasks : Boolean;
				_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Aug 2009	cnwmd1	Initial creation
14 Jun 2018 jlger1	tfs 39166
09 Mar 2024	navsck1	ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
26 Mar 2024	navpw1	TFS: 62849 (62927) - Reverted Code by removing _allDocuments parameter and reverting method to previous version
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks

*/

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Set to use deffered updates
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateWorkOrder(_pxyWorkOrder,_updateTasks, _passport);
	
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_updateTasks" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
