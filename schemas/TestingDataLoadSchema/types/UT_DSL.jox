    <JadeMethod name="deleteUserHookCode" id="66422cfc-c523-4dc1-96e4-9cbe39931b3e">
        <source>deleteUserHookCode(_userHookCode : String);

/*

Purpose:		Delete a User Hook Code	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation

*/

vars
	userHookCode			: CM_HookCode;
	hookLink				: CM_HookLink;
	
	notAvailable			: Boolean;
begin

	while true do
		userHookCode := app.myRoot.allHookCodes[_userHookCode, notAvailable];
		if userHookCode &lt;&gt; null then
			beginTransaction;
			delete userHookCode;
			commitTransaction;
		endif;
		if notAvailable then
			break;
		endif;
		notAvailable := true;
	endwhile;

epilog

end;</source>
        <Parameter name="_userHookCode" type="String"/>
