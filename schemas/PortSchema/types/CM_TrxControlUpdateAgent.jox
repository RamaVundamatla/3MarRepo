    <JadeMethod name="trxCompleteToDoTasks" id="606d7301-8c91-48f0-82e6-1296fe38d601">
        <updating/>
        <source>trxCompleteToDoTasks(_ti : CM_TrackedItem input; _allTasks : CMIF_TiToDoTasksArray; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);


	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObject(_ti); //jlier1 TFS 61676 14/12/23 
	endif;
	beginTransaction;
	app.myUtilityUA.utlCompleteToDoTasks(_ti,_allTasks, _passport);
	
	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allTasks" type="CMIF_TiToDoTasksArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxConfirmWagonTrainDepart" id="c12369d7-25aa-44cf-8b33-13432cdfc3ae">
        <updating/>
        <source>trxConfirmWagonTrainDepart(_train : CM_Train input;
				   _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2016	cnwmp6	Initial creation
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars
	cmifToDepartTrain : CMIF_RakeRegion;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_train.validateDepartureProcess(); //22/08/2023	navkc1	CR 59610 Task 59611
	
	//22/08/2023	navkc1	CR 59610 Task 59611
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	beginTransaction;
	
	_passport.useTIDictDeferUpdate		  	:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useEventDeferUpdate		  	:= true;			//25.10.2024 navma1 #MTN-33231
	_passport.useOfflineFutureActorDeferDel := true;			//17.03.2025 navma1 #MTN-34120
	
	_train.confirmWagons(null, false, false, app.myPassport);

	// clear the entire train.
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := _train;
	cmifToDepartTrain.validate(_passport);

	app.myUtilityUA.utlUpdateRailClearRake(cmifToDepartTrain, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	delete cmifToDepartTrain;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_train" type="CM_Train" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
