    <JadeMethod name="buildEventFile" id="2eb1c4f6-c0fc-4e57-862d-98564df0f95b">
        <updating/>
        <source>buildEventFile(_camProtocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _seqNumber :Integer; _unhSeqNumber : Integer io; _terminal : CM_Terminal) updating;
/*

Purpose:			
    buildFile but for Event Transactions rather than TITransactions CCMS 2346 DPH PAR 34561 
Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwgb1	Initial creation
23.04.2015	cnwgb1	PAR 35989 
24 Aug 2015	cnwrs1	Par 36680/36801 Single transation not working for event files
03 Sep 2015	cnwrs1	Par 36857 Single Transaction per file still not working for suzano events
14 Sep 2015	cnwrs1	Par 36896 fix for Par36857 made non Single transaction file create multiple (based on number of transactions in allEventTrans) emails instead of 1
16 Sep 2015	cnwrs1	Par 36860 using the event.datTime when should be using event.camsTimeStamp
20 Apr 2016	cnwrs1	Par 37788 TFS Came 1875 Events does not check cam group operators nor cargotype list
06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
21 Mar 2023 navmd1	TFS 57092 Fix being unable to re-send a file if 'Single File per Transaction' was enabled
*/
vars
	allEventTrans	: CM_EventTransByDateTime;
	lastTS   		: TimeStamp;
	seqNo			: Integer;
	transaction		: CM_EventTransaction;
    camFile         : CM_CamFile;
	camTaskHistory	: CM_CamTaskHistory;
	iterStartTS , 
	startTS, endTS	: TimeStamp;
	transCount		: Integer;
	iter			: Iterator;
	daysToLookBack	: Integer;
	trProcessDateTime	: TimeStamp;
	logExcludedTransaction	: Boolean;
	isFirstTime : Boolean;

begin
	seqNo			:= _seqNumber;
	iter 			:= _terminal.allEventTransactionsByCamsTS.createIterator;
	startTS					:= _camAgent.startDateTime;	
	endTS					:= _camAgent.endDateTime;	
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;
	iterStartTS 	:= startTS;
	create allEventTrans transient;
	create camFile transient;	
	_terminal.allEventTransactionsByCamsTS.startKeyGeq(iterStartTS, iter);

	while iter.next(transaction) do
		if transaction.camsTimeStamp &gt; endTS then
			break;
		endif;
		// makes sense to exclude transaction of the incorrect type 1st
		if not self.includeEvent(transaction, _camProtocol,  _camAgent) then
			continue;
		endif;
		if not transaction.isValidForCamsProcess(startTS, daysToLookBack, trProcessDateTime) then 	// par 15375
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction was created prior to CAMS start date/time');
			endif;
			continue;
		endif;
		
		transCount := transCount + 1;
		
		if transCount mod 100 = 0 then
			app.writeLog(_camProtocol.code &amp; " Event " &amp; transaction.camsTimeStamp.String &amp; ".",LogWARN);
		endif;
		
		// makes sense to exclude events of the incorrect type 1st
		if not self.isEventTypeToBeProcessed(_camProtocol, transaction) then
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction type does not match CAM proctocol event types');
			endif;
			continue;
		endif;
		
		// we want it
		allEventTrans.add(transaction);
//		endif;
	endwhile;

	if allEventTrans.size = 0 then	// Nothing found 
		app.writeLog(_camProtocol.code &amp; " no events found", LogWARN);
		return;
	endif;
	
	// Process the transactions
	if _camProtocol.isSingleTransPerFile and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then 
		// Create one file for EACH transaction
		lastTS := null;
		isFirstTime := true;
		foreach transaction in allEventTrans do			// These are now in date seq
			
			camFile.clear();	// TFS 57092 moved up
			self.processEvent(transaction, _camProtocol, _camAgent, camFile);

			if camFile.camVoyages.size &gt; 0 then
				if not isFirstTime then
					seqNo := seqNo + 1;						// TFS 57092 moved up
					_camAgent.setProcessSeqNumber(seqNo);	// TFS 57092 moved up
					self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
				endif;
				isFirstTime	:= false;
				if lastTS &lt;&gt; null and lastTS &lt;&gt; transaction.camsTimeStamp then
					// Its okay to update the timestamp now	### incomplete how can we do this???? done in task history but need to know that a trans is the last one for the time stamp####
					lastTS := transaction.camsTimeStamp;
				endif;
				//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null);			// TFS 48016
				app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, null);		// TFS 48016
				//camFile.clear();							// TFS 57092
				//seqNo := seqNo + 1;						// TFS 57092
				//_camAgent.setProcessSeqNumber(seqNo);		// TFS 57092
			endif;
		endforeach;
	else
		// There is only one Adhoc Proctol History Item (seq=0) Since we don't automatically send ADhoc messages anywhere, we just append them all  cnwgb1 PAR 35989 15.04.2015
		foreach transaction in allEventTrans do	//cnwgb1
			
//			self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
			
			self.processEvent(transaction, _camProtocol, _camAgent, camFile);
		endforeach; 
	endif;

	if _camProtocol.isSingleTransPerFile and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then 
	else
		//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null);			// TFS 48016
		app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null, null);		// TFS 48016
		if (not app.myPassport.trxCompletedOK) then
			_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
		endif;
    endif;
epilog
	delete allEventTrans;
    delete camFile;
	delete iter;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="buildFile" id="67f7fb45-eb4d-4f78-a863-27d81e9ea0d6">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _seqNumber :Integer; _unhSeqNumber : Integer io; _terminal : CM_Terminal) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 30/05/2012	cnwcs5		par 29601 - log reason for transactions being excluded
// 01 June 2012	cnwrs1		Par 26914 - make cams restart after lock error
// 26/06/0212	cnwcs5		par 29601 - log excluded transactions
// 18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 26/07/2012	cnwcs5		par 29601/3 - minor changes after test run
// 30 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 11/12/2012	cnwcs5		CCMS SFW 1294 / par 30855 - use CAMS timestamp instead of transaction timestamp
// 25 Mar 2013	cnwrs1		CCMS SFW 1294 Testing - not failing after exception in cam task history
// 25 Jun 2013	cnwrs1		Par 31047 - add Enviroment Terminal and Protocol to Cams Alerts
// 19 Nov 2014	cnwrs1		CCMS 2405 - Alabama Steel Cams
// 06 Mar 2015	cnwrs1		Par35784 - increased exclusion reason logging to include non excluded
// 06 Jul 2016	cnwrs1		Par 38021 - Review Cam logging
// 09 Jan 2020	jlgdap1		TFS 48016 SNO Deletion CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
// 12 Mar 2020	jlgdap1		TFS 487858 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
// ---------------------------------------------------------------------------
vars
	camFile 				: CM_CamFile;
	camGroup				: CM_CamGroup;
	transaction 			: CM_TITransaction;
	camTaskHistory 			: CM_CamTaskHistory;
	startTS, endTS			: TimeStamp;
	//coll					: CM_TITransactionByDateTypeDict;
	coll					: CM_TITransactionByDtOrdTiDict;	//13 Aug 2020	NDL	TFS 49876
	typeColl				: IntegerArray;
	iter 					: Iterator;
	logExcludedTransaction	: Boolean;		// par 29601
	str						: String;
	type					: Integer;
begin
   
   if self.isEventType() then //cnwgb1 PAR 34561, 34883 CCMS 2346 Suzano confirmations
        self.buildEventFile(_camProtocol, _camAgent, _seqNumber, _unhSeqNumber, _terminal);
		if not _camProtocol.protocolDesc.isAlsoTransactionType then
			return;
		endif;
    endif;
    
	create camFile transient;
	create coll transient;
	
	camGroup				:= _camProtocol.camGroup;				// par 29601 Jane 2012
	startTS					:= _camAgent.startDateTime;				// par 29601 June 2012
	endTS					:= _camAgent.endDateTime;				// par 29601 June 2012
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;	// par 29601 June 2012
	
	iter 	:= _terminal.allTITransactionsByCamsTS.createIterator();

	create typeColl transient;
	
	self.getTransactionTypesToProcess (_camProtocol, typeColl);
	
	// build up colection with all transactions os required type/dates in a collection
	foreach type in typeColl do
		// str in the transaction type (integer)
		iter.reset;
		
		_terminal.allTITransactionsByCamsTS.startKeyGeq(type, startTS, iter);
		
		while iter.next (transaction) do
			if transaction.type &lt;&gt; type or
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			coll.add (transaction);
		endwhile;
	endforeach;
	
	delete iter;
	
	iter := coll.createIterator;
	
	// remove load state to prevent contention (refer also PAR-15593)
	while iter.next(transaction) do		
		// makes sense to exclude transaction of the incorrect type 1st
		if self.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
									_camProtocol, camGroup, _camAgent, logExcludedTransaction, null) then	// par 29601 June 2012	// TFS 48785
									
			// reasons for excluding have been logged in self.includeTransaction
			if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 												
				if _camAgent.logIncludedTransactions then
					_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
				endif;
				if _camAgent.logIncludedTransactions then
					_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
				endif;
				self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' tr='&amp;transaction.String&amp;' ti='&amp;transaction.myTrackedItem.String&amp;' '&amp;transaction.myTrackedItem.id, LogDEBUG);
			endif;
			
			// some protocols do extra processing so this is implemented in the buildFileExtra method 
			self.buildFileExtra (transaction, _camProtocol, _camAgent, camFile);

		endif;
	endwhile;
	
	// this next bt creates the CAMS file and updates the CAM protocol history
	//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null);		// TFS 48016
	app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null, null);	// TFS 48016
	if (not app.myPassport.trxCompletedOK) then
		_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
	endif;
epilog
	delete camFile;
	delete iter;
	delete coll;
	delete typeColl;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="buildFileExtra" id="33357245-e72f-439f-a428-e15b7d29e96c">
        <updating/>
        <source>buildFileExtra(_transaction :CM_TITransaction; _camProtocol :CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile :CM_CamFile input)updating, protected;
/*
Date		Who		Reason
27/06/2012	cnwcs5	Initial creation - par 29601
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//25 Sep 2023	navdap1	TFS 60365 EUP | FR 53853 - Goods Receipt Message Grouping
vars

begin
	//if not _transaction.isCamsEditType() then							// TFS 60365
	if _transaction = null or not _transaction.isCamsEditType() then	// TFS 60365
		return;
	endif;
	
	// if we get an edit transaction then we may need to re-process all CAMS transaction
	// that were included using this protocol
	// "Reprocess all Cam transactions after an ID change"
	if _camProtocol.reprocessOnIdChange then						
		self.checkEditTransactionForId(_transaction, _camProtocol, _camAgent, _camFile);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
