    <JadeMethod name="setComboValues" id="a4714f59-99bf-4bc5-9b6a-a58b2eb997db">
        <source>setComboValues(comboBox				: ComboBox input; 
			   criteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator		: CM_QueryOperator; 
			   passport				: CM_Passport);
/******************************************************************
// TFS 8390

*** Changes ***
Date			Name	TFS#	Description
==================================================================
25/09/2018		jlgka1	40200	Allow SUPERUSER to be in the list
								Add Username to the dropdown list.

*****************************************************************/

vars
	user 	: CM_User;
	iter	: Iterator;
	int		: Integer; 
	index	: Integer;

begin
	comboBox.sorted := false;
	comboBox.clear();
	iter := app.myRoot.allUsers.createIterator;
	while iter.next(user) do
		index := comboBox.addItem(user.code &amp; Tab &amp; ' (' &amp; user.userName &amp; ')');		
		comboBox.itemObject[index] := user;
	endwhile;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		comboBox.listObject := app.myRoot.allUsers[queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		comboBox.listObject := app.myRoot.allUsers[queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
epilog
	delete iter;	
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="9e5153dc-6c29-4ffc-a6b2-b48ff79f1db8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// TFS 8390

vars
	user 		: CM_User;
	userDict 	: CM_UserByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	userDict := app.myRoot.allUsers;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach user in userDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(user.code) then
			selectionValue := 1;
			array.add(user);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; user.code &amp; ' (' &amp; user.userName &amp; ')');
		_tbl.accessRow(idx).itemObject := user;
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6db81fd9-3d8f-4cf9-a17f-0dbfb0b7007d">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// TFS 8390
vars
	user : CM_User;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			user := _tbl.accessRow(idx).itemObject.CM_User;
			sa.add(user.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="3a367fa6-297f-47ce-9161-5cd02702514e">
        <source>translateToDisplayValue(_value: Any): String;
// TFS 8390

vars

begin
	if _value.isKindOf(CM_User) then
		if _value &lt;&gt; null then
			return _value.CM_User.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="1d849038-e966-4fa1-8764-e71c5e03af8e">
        <source>translateToSearchValue(_value: Any): Any;
// TFS 8390
vars
	invalidObj 		: Boolean;
	object			: CM_User;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;

		if _value.isKindOf(CM_User) then
			object := _value.CM_User;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.code;
	endif;
	
	return returnVal;
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="8fed8e89-b086-4560-9a29-6c65c52eb942">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(String) then
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
