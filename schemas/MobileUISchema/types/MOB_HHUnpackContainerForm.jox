    <JadeMethod name="txtCargoId_gotFocus" id="834e9c78-dad2-486b-920b-a3bc274a187b">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtCargoId.text = lblCargoId.caption.toUpper then
		txtCargoId.selStart := 0;
		txtCargoId.selLength := lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="2390ffe6-d559-4252-97ca-1861d4eaac60">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if txtCargoId.text.trimBlanks = null then
		txtCargoId.text := lblCargoId.caption.toUpper;
	endif;
	
	txtCargoId.selStart := 0;
	txtCargoId.selLength := 0;

epilog

end;</source>
