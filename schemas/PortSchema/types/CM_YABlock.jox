    <JadeMethod name="pxyCreateUpdateProxy" id="0a341192-1d5e-41be-8ceb-41d4f16b57f6">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		26 April 2005 by cnwdad1
//
// Purpose:		Creates a proxy version of the receiver, and returns a reference to it.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();		// Clone the receiver.
	
	// Now copy the references - DO NOT set the Yard Allocation reference - this
	// must be set automatically by adding the receiver to the Yard Allocation's
	// array of blocks, at a specific position.

	self.allYardControllers.copy(proxyObj.allYardControllers);
	
	if self.myDeckingOptions = null then
		proxyObj.setProxyDeckingOptions();
	else	
		self.myDeckingOptions.pxyCreateUpdateProxy().setMyBlock(proxyObj);
	endif;
	
	proxyObj.myTerminalArea		:=	self.myTerminalArea;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="searchClosestOverstowLCIn" id="7cdeb615-ef9d-4ebd-95e1-a3548e005eb8">
        <source>searchClosestOverstowLCIn(_yaAgent : CM_YAAutoplanAgent input;
							_deckingOptions : CM_YADeckingOptions input;
							_mode : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwer1	Initial creation
25 June 2013	cnwer1	Initial creation par 31576
*/

vars
	dynaDict 	: DynaDictionary;
	locationCell 	: CM_YALocationCell;
	theLC, currentLC 			: CM_LocationsController;
	sequence,
	i				: Integer;
	ti 					: CM_TrackedItem;
	iter			: Iterator;
	numFailedInRow		: IntegerArray;
	checkBackEnd	 : Boolean;
begin
	if not self.initSearchForLC(_yaAgent) then
		return false;
	endif;
	
	ti:= _yaAgent.myCurrentCMIFYAAutoPlan.getMyTrackedItem;
	theLC := ti.getPrimaryLocation(_mode);
	if not theLC.isKindOf(CM_GridController) then
		return true;
	endif;
	currentLC:=ti.myPrimaryActualLocation;
	checkBackEnd:=ti.getLengthInUnits &gt; 2;

	create dynaDict transient;
	dynaDict.setMembership(CM_YALocationCell);
	dynaDict.addExternalKey(Integer,4,false,false); //external key is the decking sequence order
	dynaDict.endKeys(true);
	dynaDict.clear;
		
	if _deckingOptions &lt;&gt; null then
		iter:=_deckingOptions.allYALocationCellsIn.createIterator;
	else
		iter:=self.myDeckingOptions.allYALocationCellsIn.createIterator;
	endif;	
	
	i:=i+1;
	while iter.next(locationCell) do
		if _yaAgent.allLCsToIgnore.includes(locationCell.myYardController) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Ignoring ' &amp; locationCell.myYardController.getFullId &amp; ' would restrict access to orignal overstowed cargo', false);
			continue;
		endif;
		//is 40 | 45 | 53 then check back end 
		if checkBackEnd and locationCell.myYardController.isKindOf(CM_GridController) then
			if locationCell.myYardController.CM_GridController.myNextController &lt;&gt; null and  _yaAgent.allLCsToIgnore.includes(locationCell.myYardController.CM_GridController.myNextController) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Ignoring ' &amp; locationCell.myYardController.getFullId &amp; ' would restrict access to orignal overstowed cargo', false);
				continue;
			endif;	
		endif;
		
		if not locationCell.testCellHeight(self,_yaAgent) then
			continue;
		endif;
		if not self.myTerminalArea.isKindOf(CM_GridArea) then
			sequence:=i;
			i:=i+1;
		else
			//epr par 23403
			if currentLC.myTerminalArea.isKindOf(CM_GridArea) then
				if currentLC.myTerminalArea.CM_GridArea.useSideAccessRules  then
					if currentLC.CM_GridController.column = locationCell.myYardController.CM_GridController.column then
						_yaAgent.addLogEntry(AP_Log_YA_Default,'Ignoring ' &amp; locationCell.myYardController.getFullId &amp; ' would restrict access to orignal overstowed cargo', false);
						continue;
					endif;
					
					if checkBackEnd and  currentLC.CM_GridController.myPreviousController &lt;&gt; null then
						if  currentLC.CM_GridController.myPreviousController.column = locationCell.myYardController.CM_GridController.column then
							_yaAgent.addLogEntry(AP_Log_YA_Default,'Ignoring ' &amp; locationCell.myYardController.getFullId &amp; ' would restrict access to orignal overstowed cargo', false);
							continue;
						endif;
					endif;
				endif;
			endif;
		
			sequence:=self.getOverstowDeckingSequence(	self.myTerminalArea.CM_GridArea.useSideAccessRules,
													theLC.CM_GridController,
													locationCell);						
		endif;	
		dynaDict.putAtKey(sequence,locationCell);

	endwhile;
		
	delete iter;
	create numFailedInRow transient;
	
	iter:=dynaDict.createIterator;
	//this is the collection I need to evaluate
	while iter.next(locationCell) do
		if self.searchLCIn(locationCell,_yaAgent ) then
			return true;
		endif;
		
		if not self.checkFreeSpaceRequired(_yaAgent,locationCell.myYardController,numFailedInRow) then
			return false;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;
	delete dynaDict;
	delete numFailedInRow;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptions" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForLocationIn" id="9fa4de31-91a2-4a17-b129-d1ad96ed60a6">
        <source>searchForLocationIn(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 18 March 2005 by cnwdvb1
// -------------------------------------------
vars

	locationCell			: CM_YALocationCell;
	yardController			: CM_YardController;
	rtnValue,
	doContinue,
	doReturn: Boolean;
	rtnValueInteger			: Integer;

begin

	///epr CCMS 1025 20/1/09
	if not self.initSearchForLC(_yaAgent) then
		return false;
	endif;
	
	// Run though all cells for this block.
	foreach locationCell in self.myDeckingOptions.allYALocationCellsIn discreteLock do
		//epr CCMS 1025 21/1/10 refactored into method
		if self.searchLCIn(locationCell,_yaAgent) and _yaAgent.hasFoundAvailableLoc() then //cnwrd1 par 29269 14.3.2012
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForLocationOut" id="54484960-15b2-4e48-b669-0c2fca9722e8">
        <source>searchForLocationOut(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
vars


	
	
	locationCell			: CM_YALocationCell;
	yardController			: CM_YardController;
	allocation				: CM_YardAllocation;
	rtnValue				: Boolean;

begin

	// cnwrd1 par 24524 30.6.2010
	// we now autoplan director tasks from gridded areas.
	/*
	if _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest.isDeliveryRequest then
		if self.myTerminalArea.isKindOf(CM_GridArea) then
			_yaAgent.addLogEntry('Ignoring ' &amp; self.myTerminalArea.getID &amp; ' as Yard Internal requests should come from block stacks', true);
			return false;
		endif;
	endif;
	*/
	
	// Clear working sets.
	_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocations.clear();
	_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.clear();
	_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.clear(); //cnwrd1 par 29269 14.3.2012
	_yaAgent.allLCsToIgnore.copy(_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations);
	// Run though all cells for this block.
	foreach locationCell in self.myDeckingOptions.allYALocationCellsOut discreteLock do
	
		// Get location from cell.
		yardController := locationCell.myYardController;
		
		// Have we tested this one and passed it?
		if _yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocations.includes(yardController) then
			// Shouldn't test same location twice. If successful then
			// ti should be returned.
		elseif _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(yardController) then
			continue;
		else
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing location ' &amp; yardController.getID(), true);
			// Test location and add it to appropriate set.
			self.sharedLock(yardController);
			if not yardController.testLocationYA(_yaAgent, false) then
				_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(yardController);
			else
				if yardController.testAutoPlanRequestYA(_yaAgent) then
					return true;
				endif;
				
				_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(yardController);
			endif;
			self.unlock(yardController);
		endif;
		
	endforeach;
	
	return false;
epilog

	if yardController &lt;&gt; null then
		self.unlock(yardController);
	endif;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForLocationsBestPick" id="05d37aa3-2b72-4485-b823-e83be00cf5d5">
        <source>searchForLocationsBestPick(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// 25/02/2010	cnwjre1	CCMS 1101 add best-pick to yard allocations
vars

	locationCell			: CM_YALocationCell;
	yardController			: CM_YardController;

begin

	// Run though all cells for this block.
	foreach locationCell in self.myDeckingOptions.allYALocationCellsOut discreteLock do
	
		// Get location from cell.
		yardController := locationCell.myYardController;
		
		// Have we tested this one and passed it?
		if _yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocations.includes(yardController) then
			// Shouldn't test same location twice. If successful then
			// ti should be returned.
		elseif _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(yardController) then
			continue;
		else
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing location ' &amp; yardController.getID(), true);
			// Test location and add it to appropriate set.
			self.sharedLock(yardController);
			if not yardController.testLocationYA(_yaAgent, false) then
				_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(yardController);
			else
				if yardController.testAutoPlanRequestYA(_yaAgent) then
					return true;
				endif;
				
				_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.add(yardController);
			endif;
			self.unlock(yardController);
		endif;
		
	endforeach;
	
	return false;
epilog

	if yardController &lt;&gt; null then
		self.unlock(yardController);
	endif;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchLCIn" id="88b562fe-9699-43f0-a9ff-f7e642a091ad">
        <source>searchLCIn(_locationCell : CM_YALocationCell;
		   _yaAgent 	 : CM_YAAutoplanAgent input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwer1	Initial creation
*/

vars
	rtnValue 		: Boolean;
	yardController 	: CM_YardController;
	gridController  : CM_GridController;
	rtnValueInteger : Integer;
	notSuitMsg 		: Boolean;
	lc 				: CM_LocationsController;
	ycFullId		: String;
	cmifAutoPlan	: CMIF_YAAutoPlan;
begin

	rtnValue 		:= false;
	yardController  := _locationCell.myYardController;
	ycFullId		:= yardController.getFullId();
	
	if yardController.isKindOf(CM_GridController) then
		gridController := yardController.CM_GridController;
	endif;
	
	// Have we tested this one and passed it?
	cmifAutoPlan := _yaAgent.myCurrentCMIFYAAutoPlan;
	
	if cmifAutoPlan.allPassedLocations.includes(yardController) then
		// Test cell.
		if _yaAgent.testCellSuitabilityForTI(_locationCell, self) then
			rtnValue:=true;
		else
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " &amp; 			    ycFullId, true);	// 14/02/2013 cnwmh5 #30999
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Location not suitable for TI in " &amp; ycFullId, true);	// 14/02/2013 cnwmh5 #30999
		endif; 
			
	// Have we tested this one and failed it?
	elseif cmifAutoPlan.allFailedLocations.includes(yardController) then
		notSuitMsg := true;
		//29 May 2014	NDL	Par 34246
		if cmifAutoPlan.allLocations &lt;&gt; null then
			foreach lc in cmifAutoPlan.allLocations do
				if cmifAutoPlan.allFailedLocations.includes(lc) then
					notSuitMsg := false;
					_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " &amp; ycFullId, true);
					_yaAgent.addLogEntry(AP_Log_YA_Default,'TI already in '    &amp; self.getDisplayDetails(false), true);
					return false;
				endif;
			endforeach;
		endif;
		///////
		if notSuitMsg then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " 						&amp; ycFullId, true);	// 14/02/2013 cnwmh5 #30999
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Location not suitable for TI in " 		&amp; ycFullId, true);	// 14/02/2013 cnwmh5 #30999
			return false;
		endif;
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing location ' &amp; ycFullId, true);
		// Test location and add it to appropriate set.
		if not _yaAgent.testYardLocation(_locationCell) then
			return false;
		endif;
		
		if _yaAgent.testCellSuitabilityForTI(_locationCell, self) then
			rtnValue:=true;
		endif;
		
	endif;
	
	// We passed a cell, time to check nested locations.
	if rtnValue then
		if self.getNestedLocationsYA(_yaAgent, yardController, rtnValueInteger) then
			// Yay no nested locations. Ok to proceed.
			if _yaAgent.isSingleProcessing() then
				if _yaAgent.isForTwinDeck then
					_yaAgent.useLinkedYAAutoPlan(true);    // PAR 26856
					if gridController &lt;&gt; null then
						// if we have got to this stage and is twin then it must have a next controller that is a grid controller
						_yaAgent.addLocationToAgent(gridController.myNextController, CM_YAAutoplanAgent.Locations_Found);
					elseif yardController.isKindOf(CM_BlockController) then
						//epr 20017 19/6/09
						// if we have got to this stage and is twin then it must have a next controller that is a grid controller
						_yaAgent.addLocationToAgent(yardController, CM_YAAutoplanAgent.Locations_Found);
					endif;
					_yaAgent.useLinkedYAAutoPlan(false);    // PAR 26856
				endif;
	
				return true;
			else
				_yaAgent.processSenarioCounter(_locationCell);
			endif;
		else
			// This one will be picked up later if nothing better is found.
			// Chuck it in the failed set.
			if rtnValueInteger = YAOverlap_LastResort then
				_yaAgent.addLogEntry(AP_Log_YA_Default,ycFullId &amp; ' height ' &amp; _locationCell.height.String &amp; ' is an appropriate last resort location', false);
				_yaAgent.numberOfLocationsFound := _yaAgent.numberOfLocationsFound + 1;
			endif;
			_yaAgent.removeFromPassedLocations(yardController);
			_yaAgent.addToFailedLocations(yardController);
			rtnValue := false;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locationCell" type="CM_YALocationCell"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="aa7c705c-97b7-4a5d-8692-29c6cf6aa4f0">
        <updating/>
        <source>setForCreate(pProxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
begin
	self.setForUpdate(pProxyObj);
end;</source>
