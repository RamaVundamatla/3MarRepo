    <JadeMethod name="create" id="c5d0b20e-5c37-4b76-b2a5-7541e707e367">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 23 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.permissionMaint := PmHMSDelayMaint;
	self.permissionView := PmHMSDelayView;	
	
	self.helpFileName := HelpFile_Harbour;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="cda7dce6-e911-4979-bea9-049624689b52">
        <updating/>
        <source>doOK() updating;

vars

begin
	if self.mySelectedWorkingVoyage &lt;&gt; null then
		if self.updateWorkingVoyageDelay() then
			inheritMethod();
		endif;
	elseif self.mySelectedVoyage &lt;&gt; null then
		if self.updateVoyageDelay() then
			inheritMethod();
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Voyage');
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDetails" id="3efd0bb8-606f-4ec7-8d07-b72288feb2c8">
        <updating/>
        <source>loadDetails()updating;

vars
	now : TimeStamp;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	if self.mySelectedDelay &lt;&gt; null then
		self.cmbDelay.listIndex := self.cmbDelay.findObject(self.mySelectedDelay.myDelay);
		self.txtDateFrom.setDate(self.mySelectedDelay.startTime.date);
		self.txtTimeStart.setTime(self.mySelectedDelay.startTime.Time);		
		self.txtDateTo.setDate(self.mySelectedDelay.stopTime.date);
 		self.txtTimeEnd.setTime(self.mySelectedDelay.stopTime.Time);	
		self.chkChargeable.value := self.mySelectedDelay.isChargeable;
	
	elseif self.mySelectedWorkingDelay &lt;&gt; null then
		self.cmbDelay.listIndex := self.cmbDelay.findObject(self.mySelectedWorkingDelay.myDelay);
		self.txtDateFrom.setDate(self.mySelectedWorkingDelay.startTime.date);
		self.txtTimeStart.setTime(self.mySelectedWorkingDelay.startTime.Time);		
		self.txtDateTo.setDate(self.mySelectedWorkingDelay.stopTime.date);
 		self.txtTimeEnd.setTime(self.mySelectedWorkingDelay.stopTime.Time);	
		self.chkChargeable.value := self.mySelectedWorkingDelay.isChargeable;
	else
		self.txtDateFrom.setDate(now.date);
		self.txtTimeStart.setTime(now.Time);		
		self.txtDateTo.setDate(now.date);
 		self.txtTimeEnd.setTime(now.Time);

		if self.cmbDelay.listCount &gt; 0 then
			self.cmbDelay.listIndex := 1;
		endif;	
	 			
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1bfbb258-2464-4d7e-a70e-03f3eeaed602">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 21 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.myTerminal.myHarbour &lt;&gt; null then
		self.cmbDelay.listCollection(app.myRoot.allHMSDelays,true,0);
	endif;
	
	self.loadDetails();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="41df99b4-01ca-420f-8e69-80a7bca81f64">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005973, locale);
	blbStart.translateCaption(Xlat_0001716, locale);
	chkChargeable.translateCaption(Xlat_0001715, locale);
	lblDelay.translateCaption(Xlat_0001717, locale);
	lblFinish.translateCaption(Xlat_0001718, locale);
	lblInfo.translateCaption(Xlat_0001719, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateVoyageDelay" id="d327520e-334b-4bde-ac94-a04ec3804722">
        <updating/>
        <source>updateVoyageDelay():Boolean updating;
//-----------------------------------------
// Created: 21 June 2005 By: cnwgd1
//-----------------------------------------
vars
	result			: Integer;
	pxyVoyageDelay	: HMS_VoyageDelay;
	tsFrom			: TimeStamp;
	tsTo			: TimeStamp;
	
begin
	if self.mySelectedDelay = null then
		create pxyVoyageDelay transient;
	elseif self.mySelectedDelay.isTransient then
		pxyVoyageDelay := self.mySelectedDelay;
	else
		pxyVoyageDelay := app.createUpdateProxy(self.mySelectedDelay).HMS_VoyageDelay;	
	endif;
	
	// params: _archived, _isChargeable, _archivedDT, _startTime, _stopTime, _myDelay
// cnwdad1 17/06/2009 - PAR #19942.
//	pxyVoyageDelay.setProxy(self.chkChargeable.value,
//						(self.txtDateFrom.text &amp; "," &amp; self.txtTimeStart.text).TimeStamp,
//						(self.txtDateTo.text &amp; "," &amp; self.txtTimeEnd.text).TimeStamp,
//						self.cmbDelay.listObject.HMS_Delay,
//						self.mySelectedVoyage);	
	tsFrom.setDate(self.txtDateFrom.text.asDateJMT());
	tsFrom.setTime(self.txtTimeStart.text.asTimeJMT());
	tsTo.setDate(self.txtDateTo.text.asDateJMT());
	tsTo.setTime(self.txtTimeEnd.text.asTimeJMT());
	
	pxyVoyageDelay.setProxy(self.chkChargeable.value,
							tsFrom,
							tsTo,
							self.cmbDelay.listObject.HMS_Delay,
							self.mySelectedVoyage);	

	while true do
		app.myTrxUA.trxUpdateHMSObject(pxyVoyageDelay, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Voyage Delay', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		return false;
	endwhile;						

	return true;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWorkingVoyageDelay" id="ccb21113-b251-4335-8afe-a95d7c65ce66">
        <source>updateWorkingVoyageDelay():Boolean;
//-----------------------------------------
// Created: 21 June 2005 By: cnwgd1
//-----------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars

	voyageDelay : CMIF_HMS_VoyageDelay;
begin

	if self.mySelectedWorkingDelay = null then
		create voyageDelay;
	else
		voyageDelay := mySelectedWorkingDelay;
	endif;	
		
	voyageDelay.myDelay			:= self.cmbDelay.listObject.HMS_Delay;
// cnwdad1 17/06/2009 - PAR #19942.
//	voyageDelay.startTime		:= (self.txtDateFrom.text &amp; "," &amp; self.txtTimeStart.text).TimeStamp;		
//	voyageDelay.stopTime		:= (self.txtDateTo.text &amp; "," &amp; self.txtTimeEnd.text).TimeStamp;
	voyageDelay.startTime.setDate(self.txtDateFrom.text.asDateJMT());
	voyageDelay.startTime.setTime(self.txtTimeStart.text.asTimeJMT());		
	voyageDelay.stopTime.setDate(self.txtDateTo.text.asDateJMT());
	voyageDelay.stopTime.setTime(self.txtTimeEnd.text.asTimeJMT());
	
	voyageDelay.isChargeable	:= self.chkChargeable.value;
	voyageDelay.myWorkingVoyage := self.mySelectedWorkingVoyage;

	if voyageDelay.myWorkingVoyage = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Voyage'), "Voyage Delay", MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Input_required_field_voyage), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon); // cnwdb2	PAR 35364

		if self.mySelectedWorkingDelay = null then
			// In add mode
			voyageDelay.myWorkingVoyage := null;
			delete voyageDelay;
		endif;
		return false;		
	endif;
	
	if voyageDelay.myDelay = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Delay'), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Input_required_field_delay), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon); // cnwdb2	PAR 35364

		if self.mySelectedWorkingDelay = null then
			// In add mode
			voyageDelay.myWorkingVoyage := null;
			delete voyageDelay;
		endif;
		return false;		
	endif;
	
 	if (not voyageDelay.startTime.isValid) then
//		app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Delay Start'), "Voyage Delay", MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Input_required_field_delayStrt), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon); //  cnwdb2	PAR 35364

		if self.mySelectedWorkingDelay = null then
			// In add mode
			voyageDelay.myWorkingVoyage := null;
			delete voyageDelay;
		endif;
		return false;		
 	endif;
 	
 	if (not voyageDelay.stopTime.isValid) then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Delay Finish'), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Input_required_field_delayFin), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon); // cnwdb2	PAR 35364
		
		if self.mySelectedWorkingDelay = null then
			// In add mode
			voyageDelay.myWorkingVoyage := null;
			delete voyageDelay;
		endif;
		return false;		
 	endif; 	
 	
	if voyageDelay.startTime &gt;= voyageDelay.stopTime then
	//	app.msgBox(app.getErrorString1(AutoScheduleDateError, 'Start date/time must be before finish date/time'), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Input_required_field_strtDate), app.getErrorString(Voyage_delay), MsgBox_OK_Only+MsgBox_Stop_Icon); // cnwdb2	PAR 35364

		if self.mySelectedWorkingDelay = null then
			// In add mode
			voyageDelay.myWorkingVoyage := null;
			delete voyageDelay;
		endif;
		return false;		
	endif; 	 	
		
	return true;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
