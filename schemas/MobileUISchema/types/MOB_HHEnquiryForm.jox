    <JadeMethod name="txtCargoId_keyPress" id="52271c87-cae6-48aa-a131-076f22c8edbe">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2013	cnwmc5	Initial creation	PAR 32517

*/

vars

begin
	if keyCharCode = J_key_Enter then
		app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
		self.doClickPartCargoIdSearch();
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="c89bea74-9820-44a8-abbe-b71e26602e1a">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation		Par 51506

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
