    <JadeMethod name="isNextTaskACrane" id="d1693ab9-383c-4ab5-aa84-cc0bcda2cd4c">
        <source>isNextTaskACrane() : Boolean;

vars

begin
	if self.myNextTask = null then
		return false;
	endif;
	
	return self.myNextTask.isCraneTask;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNextTaskReadyForPickup" id="f6859d4e-bf72-4de1-9053-2985bfabc62d">
        <source>isNextTaskReadyForPickup() : Boolean;

vars

begin
	if self.myNextTask = null then
		return true;
	endif;
	
	if not self.myNextTask.isAccepted then
		return false;
	endif;
	
	return not self.myNextTask.getMachine.isMoving;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
