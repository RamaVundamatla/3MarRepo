    <JadeMethod name="setGateInEntity" id="69a04d47-072b-4a23-848f-735ea5d98cc3">
        <updating/>
        <source>setGateInEntity( _pxyGateEntity : CMGTE_Entity io; _itm : CM_InterTerminalMove) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwrd1	Initial creation

*/

vars	
	itm,
	primaryITM	: CM_InterTerminalMove;
	primaryCargo : CM_TrackedItem;
	controller : CMIF_FlexiGateController;
	pxyAttachment : CMGTE_Container;
	prenote : CM_TrackedItem;
begin
	
	
	if self.myInterTermVehicleJob = null then
		return;
	endif;

	primaryITM := _itm;
	
	if primaryITM = null then
		return; //havnt found any
	endif;
	
	//grab the first for now.
	
	primaryCargo := primaryITM.mySourceTI;
	
	if primaryCargo = null then
		//broken
		return;
	endif;
	
	//check and move prenote
	if primaryITM.myTargetTI &lt;&gt; null and primaryITM.myTargetTI.myTerminal &lt;&gt; self.myTerminal then  //if we have a prenote and its at another terminal
		prenote := primaryITM.myTargetTI;
		delete prenote;
		primaryITM.mySourceTI.interTerminalRelease(self.myTerminal);
		primaryITM.setMyTargetTI( primaryITM.mySourceTI.myMoveCloneToTI  );
	//	primaryITM.mySourceTI.setMyInTransitTerminalTo( self.myTerminal );
	endif;
	
	
	//primaryCargo.allBulkReleasesAssigned.first
	
	//gateName := self.myInterTermConfig.myGate.CM_Gate.name;  // get default ?
	// Create the GTE Entity and add to VVR later
	create controller transient;
	
	controller.myTerminal := self.myTerminal;
	
	
	if app.myRoot.isAnEmptyCommodity( primaryCargo.commodity, false) then  //should allways be dealing with MT's here realy
		controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
		//empty := true;
	else
		controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
	//	empty := false;
	endif;
	
		
	controller.numItems := 1;   //how many we are moving - should be max 2 normaly
	

	controller.id := primaryCargo.id;
	controller.isoTypeCode := primaryCargo.CM_Container.isoType;
	controller.operatorCode := primaryCargo.operatorCode;
	controller.commodity := primaryCargo.commodity;
	controller.weightTotal := primaryCargo.totalWeight;
	controller.cargoType := TI_CargoType_Container;
	controller.carriageTempC := NULL_TEMPERATURE;
	//controller.carriageTempF := NULL_TEMPERATURE;
	controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	controller.setOxygen( NULL_OXYGEN );
	controller.myVehicleVisitRecord := self.myVehicleVisit;
	controller.myTerminal := self.myTerminal;	
	
	if primaryITM.myTargetLC &lt;&gt; null then //if we have a target location
		controller.yardLocationTxt := primaryITM.myTargetLC.getFullId();
	endif;
	
	_pxyGateEntity.setPXYFromController(controller); 
	

	
epilog
	delete controller;
end;</source>
        <Parameter name="_pxyGateEntity" type="CMGTE_Entity" usage="io"/>
        <Parameter name="_itm" type="CM_InterTerminalMove"/>
    </JadeMethod>
    <JadeMethod name="setGateOutEntity" id="0adbe85c-4c6a-4ab5-a55c-182f513859ec">
        <updating/>
        <source>setGateOutEntity( _pxyGateEntity : CMGTE_Entity io; _itm : CM_InterTerminalMove) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwrd1	Initial creation

*/

vars
	primaryITM  : CM_InterTerminalMove;
	primaryCargo : CM_TrackedItem;
	controller : CMIF_FlexiGateController;
	//_pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	releaseType : Integer;
	subterm : CM_SubTerminal;
begin

	if self.myInterTermVehicleJob = null then
		return;
	endif;

	primaryITM := _itm;
	
	if primaryITM = null then
		return; //havnt found any
	endif;
	
	//grab the first for now.
	
	primaryCargo := primaryITM.mySourceTI;
	
	if primaryCargo = null then
		//broken
		return;
	endif;
	
	// Create the GTE Entity and add to VVR later
	create controller transient;
	
	controller.myTerminal := self.myTerminal;
	
	
	if app.myRoot.isAnEmptyCommodity( primaryCargo.commodity, false) then  //should allways be dealing with MT's here realy
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
		//empty := true;
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
	//	empty := false;
	endif;
	
		
	controller.numItems :=  1;   //how many we are moving - should be max 2 normaly
	

	controller.id := primaryCargo.id;
	controller.isoTypeCode := primaryCargo.CM_Container.isoType;
	controller.operatorCode := primaryCargo.operatorCode;
	controller.commodity := primaryCargo.commodity;
	controller.weightTotal := primaryCargo.totalWeight;  //cnwrd1 changed to totalWeight
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := self.myVehicleVisit;
	controller.myTerminal := self.myTerminal;
	controller.consigneeCode := primaryCargo.consignee;	//16 Jan 2015	NDL	Par 35297
	controller.deliveryRelease := primaryCargo.deliveryRelease;	//16 Jan 2015	NDL	Par 35297
	
	
	// set release?!?
	releaseType := null;
	release := primaryCargo.getMyInterTerminalRelease();
	if release &lt;&gt; null then
		controller.myBulkRelease := release;
		controller.myReserveDetail := null; //? need one?
		controller.deliveryReason :=  release.deliveryReasonDescr;
		if release.deliveryReleaseNumber &lt;&gt; null then		//16 Jan 2015	NDL	Par 35297
			controller.deliveryRelease := release.deliveryReleaseNumber; //cnwrd1 par 32284
		endif;
		releaseType := release.type;
		if controller.consigneeCode = null then
			controller.consigneeCode := release.consigneeCode;	//16 Jan 2015	NDL	Par 35297
		endif;
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		
		//par 22984 cnwrd1 8.3.2010
		subterm := self.myTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
																				releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
																				0,
																				null,
																				false);
		if subterm &lt;&gt; null then
			controller.subTerminalCode := subterm.code;
		endif;
	endif;
	_pxyGateEntity.setPXYFromController(controller); 

	_pxyGateEntity.CMGTE_Release.setIsReleaseById(true); //should always be this
	

epilog
	delete controller;
end;</source>
        <Parameter name="_pxyGateEntity" type="CMGTE_Entity" usage="io"/>
        <Parameter name="_itm" type="CM_InterTerminalMove"/>
    </JadeMethod>
    <JadeMethod name="setProxyVVR" id="ce9df52a-6b58-41a7-ae72-6eb0fd9f56a9">
        <updating/>
        <source>setProxyVVR( _pxyVVR : CM_VehicleVisitRecord io; loading : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwrd1	Initial creation
13/05/2022 			navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars
	itm : CM_InterTerminalMove;
	terminal : CM_Terminal;	
	gate: CM_Gate;
	adminGate: CM_GateArea;
	now: TimeStamp;
	vehicle : CM_Vehicle;
	laneController : CM_YardController;
	lc				: CM_LaneController;
	interTerminalBR : CM_InterTerminalBulkRelease;
	interTermConfig : CM_InterTerminalConfig;
	laneNumber	: Integer;
begin

	if self.myInterTermVehicleJob = null then
		return ;
	endif;
	
	if loading then
		itm := self.allMovesForLoading.first;
	else
		itm := self.allMovesForOffloading.first;
	endif;
	
	if itm = null then
		return ;
	endif;
	
	if driver = null then //set driver from user name
		driver := app.getMyUserName();
	endif;
		
	terminal := self.myTerminal;
	
	//sort gate stuff out
	if loading then
		interTerminalBR := itm.mySourceTI.getMyInterTerminalRelease();	
		if interTerminalBR &lt;&gt; null then
			interTermConfig := interTerminalBR.myInterTerminalConfig;
			if interTermConfig &lt;&gt; null then
				gate := interTermConfig.myGate;		
				if gate &lt;&gt; null then
					adminGate := gate.getFirstAGate_IN();
					laneController := interTermConfig.myLaneController;
					if adminGate &lt;&gt; null and laneController = null then
						laneController := adminGate.getDefaultLane_IN();
					endif;
				endif;
				//21 Nov 2014	NDL	Par 35097
				if gate = null then
					app.raiseCMException1(NO_Default_gate, interTermConfig.configName, null, null);
					return;
				endif;
			endif;
			
		endif;
		
	else
		gate := terminal.getDefaultGate_IN();
		if gate &lt;&gt; null then
		adminGate := gate.getFirstAGate_IN();		
			if adminGate &lt;&gt; null then
				laneController := adminGate.getDefaultLane_IN();
			endif;
		endif;
		
	endif;
	
	//21 Nov 2014	NDL	Par 35097
	if gate = null then
		app.raiseCMException1(NO_Default_gate, terminal.code, null, null);
		return;
	endif;
	
	// Create the Vehicle Visit Record
	
	// 1061 When creatibng a new visit record for a truck, the truck should NOT be onsite
	vehicle := self.myTerminal.vehicles[self.myInterTermVehicleJob.vehicleID, self.myInterTermVehicleJob.state];
	
	if vehicle = null then	
		app.raiseCMException(Err_Gate_VehicleId, ETRow_RegNumber, null);
		return;
	endif;
	
	if vehicle &lt;&gt; null and vehicle.isOnsite then
		app.raiseCMException2(VehicleIsOnSite, self.myInterTermVehicleJob.vehicleID, vehicle.getMyPrimaryActualLocation.getNiceName(), ETRow_RegNumber, null);
	endif;
	
	_pxyVVR.setProxyFlexiGate( 	driver, 
								driver, 
								vehicle.carrier.code,
								null,									//13/05/2022 navhl20 TFS 53430
								 self.myInterTermVehicleJob.vehicleID, 
								self.myInterTermVehicleJob.state, 
								gate.name, 
								self.myTerminal,
								gate,
								laneController,
								"");
	_pxyVVR.setAutoComplete( true );
	 _pxyVVR.setTimeIn(now.date, now.time);

	return;

epilog

end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="loading" type="Boolean"/>
    </JadeMethod>
