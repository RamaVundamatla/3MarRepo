    <JadeMethod name="showThumbnailData_TI" id="9ab20a91-6f09-4a23-82e4-eacd682ab4e8">
        <source>showThumbnailData_TI(_headings:StringArray input; _data:HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     07 September 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2006	cnwdad1		CCMS #1396.
// 19/05/2009	concms1		Par 19715 - show cargo pickup/dropoff
//                          Also removed commented out code and code to show
//							VVRD (see showThumbnail_VVRD)
//							Also removed unsed parameters
// 17/06/2013	cnwcs5		par 31670 - ignore merged TIs
// ---------------------------------------------------------------------------
constants
	SPACES = '     ';
vars
	ti		: CM_TrackedItem;
	unit,
	tiQuantityDisplay : String;
	tiQuantity : Decimal[14,4];
	tisProcessed : StringArray;		//06 Mar 2014	NDL	Par 33596
begin

	if (not self.allReceivedTrackedItems.isEmpty) then
		
		_headings.add(app.getErrorString(Items_received));   
		_data.add(null);
		
		create tisProcessed transient;	//06 Mar 2014	NDL	Par 33596
		
		foreach ti in self.allReceivedTrackedItems do	//epr par 32717
			
			//06 Mar 2014	NDL	Par 33596
			if tisProcessed.includes(ti.id) then
				continue;
			endif;
			tisProcessed.add(ti.id);
			
			_headings.add( SPACES &amp; app.getErrorString(CM_ID)); 	
			tiQuantityDisplay:=null;
			//epr CCMS 1366 bulk 29/9/14
			if ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti then
				tiQuantityDisplay:=self.getMoveTotalForTIIDDisplay(ti);
			endif;
			if tiQuantityDisplay &lt;&gt; null then
				_data.add(tiQuantityDisplay &amp; "x" &amp;  ti.id);
			else
				_data.add(ti.id);
			endif;
		endforeach;
		
	endif;
	
	if (not self.allReleasedTrackedItems.isEmpty) then		
		_headings.add(app.getErrorString(Items_released));   
		_data.add(null);
		
				
		foreach ti in self.allReleasedTrackedItems do	// par 31670
			if ti.state = TI_STATE_MERGED then
				continue;
			endif;
			_headings.add(SPACES &amp; app.getErrorString(CM_ID)); 
				//epr CCMS 1366 bulk 29/9/14
			tiQuantityDisplay:=ti.getTotalAmountDisplay();
			if tiQuantityDisplay &lt;&gt; null then
				_data.add(tiQuantityDisplay &amp; "x" &amp; ti.id);
			else
				_data.add(ti.id);
			endif;
			if ti.deliveryRelease &lt;&gt; null then
				_headings.add(SPACES &amp; app.getErrorString(Delivery_Release));    //epr par 34031 30/4/14
				_data.add(	ti.deliveryRelease);
			endif;
		endforeach;	
	endif;
	
epilog

	delete tisProcessed;		//06 Mar 2014	NDL	Par 33596
	
end;</source>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData_VVRD" id="ed7357b2-ab98-4398-af99-e01a2d508c88">
        <source>showThumbnailData_VVRD(_headings:HugeStringArray input; _data:HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     07 September 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2006	cnwdad1		CCMS #1396.
// 19/05/2009	concms1		Par 19715 - show cargo pickup/dropoff
//                          Also removed commented out code and removed code for
//							receivals/releases (see showThumbnailData_TI)
//							Also changed to show just the VVRD that we have
//							Also removed unused parameters
// 21/09/2009	cnwcs5		ccms 1061 - Show cancelled reason
// 21/12/2009	cnwmh5		PAR 21864 - Truncate the cancel details at 50 characters
// 17/06/2013	cnwcs5		par 31670 - show id/qty for break bulk
// ---------------------------------------------------------------------------
vars
	ti						: CM_TrackedItem;
	detail					: CM_VehicleVisitRecordDetail;
	recordDetailDescription: String;
begin
	if self.myTerminal = null then
		return;
	endif;
		
	foreach detail in self.allVehicleVisitRecordDetails do	
		recordDetailDescription:=detail.getRecordDetailDescription();
			
		/*if recordDetailDescription.length &gt; 62 then 
			recordDetailDescription := recordDetailDescription [1:62];
		endif;*/
			
		_headings.add (recordDetailDescription);
	
		_data.add (self.systemToLocalTime(detail.timeStart).asStringJMT);	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
			
	endforeach;
		
end;</source>
        <Parameter name="_headings" type="HugeStringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateAddRemoveCargo" id="7843af71-7b55-4bc9-bd01-6124beb28041">
        <updating/>
        <source>updateAddRemoveCargo(_pxyVVR : CM_VehicleVisitRecord; _addedCargo : CMGTE_EntitySet; _location : CM_LocationsController; _moveController : CMIF_Array;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
15/05/2024		navcs2	Bug 64144: Correct Release Data - Few issues found
02/07/2024		navcs2	Bug 64134: EUP | FR 57088 - Release Request is not updated with the corrected data on the vehicle visit
19/09/2025		navcs2	Bug 65450 Dev - Returning of Lot Based Cargo | PortSchema Changes
10/10/2025		navcs2	MTN-36214 Unable to Add Cargo to the Cargo Released section which is received onsite
// 16/10/2025	navcs2	MTN-36214 Unable to Add Cargo to the Cargo Released section which is received onsite
21/10/2025		navcs2	MTN-36398 Cargo item is still visible on the Cargo Released table with quantity 0 
*/

vars
	gteEntity 		: CMGTE_Entity;
	trackedItem		: CM_TrackedItem;
	transaction		: CM_TITransaction;
	transactionSet	: CM_TITransactionSet;
	reserveDetail	: CM_ReserveDetail;
	locController	: CM_LocationsController;
	foundHeight		: Integer;
	vehicleLocation	: String;
	transTimeStamp,
	vvrDetailTime	: TimeStamp;
	moveController	: CMIF_MoveController;
	vvrCargoPlaced,
	vvrDetail,
	vvrRoadExit,
	newVVr			: CM_VehicleVisitRecordDetail;
	timeDifference	: Integer;
	information 	: StringArray512;						// 15/05/2024		navcs2	Bug 64144
	bulkRelease		: CM_BulkRelease;
	obj				: CMIF_Object;
	transControl	: CMIF_TITransactionController;
	removedTIs		: CM_TISet;
	tiLoop			: CM_TrackedItem;
	tiSet			: CM_TISet;
	monitor			: CMIF_Monitor;
	terminal		: CM_Terminal;
begin	
	// Update basic details
	self.myDriverDetails 	:= _pxyVVR.myDriverDetails;
	self.driverCode		 	:= _pxyVVR.driverCode;
	self.driversName	 	:= _pxyVVR.driversName;
	self.carrierCode		:= _pxyVVR.carrierCode;
	self.subCarrierCode		:= _pxyVVR.subCarrierCode;
	
	create removedTIs transient;
	create tiSet transient;
	create monitor transient;
	
	terminal := self.myTerminal;
	
	// Move the cargo to the location specified 20/09/2025	navcs2	MTN-35846
	if _moveController &lt;&gt; null then
		foreach obj in _moveController do																	// 20/09/2025	navcs2	MTN-35846
			moveController := obj.CMIF_MoveController;														// 20/09/2025	navcs2	MTN-35846
			tiLoop := moveController.myTrackedItem;															// 20/09/2025	navcs2	MTN-35846
			moveController.setMoveContext(CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT);				// 20/09/2025	navcs2	MTN-35846
			if moveController.quantity = tiLoop.totalQuantity then											// 21/10/2025	navcs2	MTN-36398
				self.allReleasedTrackedItems.tryRemove(tiLoop);												// 21/10/2025	navcs2	MTN-36398
			endif;																							// 21/10/2025	navcs2	MTN-36398
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);							// 20/09/2025	navcs2	MTN-35846
			terminal.lookupAllOnsiteTrackedItems(tiLoop.cargoType, tiLoop.id, tiSet, false, monitor);		// 20/09/2025	navcs2	MTN-35846
			
			tiSet.copyNoDuplicates(removedTIs, false);														// 20/09/2025	navcs2	MTN-35846
		endforeach;
	endif;
	// Try to find the reserve detail if we can
	if not self.allGateEntities.isEmpty and self.allGateEntities.first.isKindOf(CMGTE_Release) then
		reserveDetail := self.allGateEntities.first.CMGTE_Release.myReserveDetail;
		if reserveDetail &lt;&gt; null then							// 02/07/2024 navcs2 Bug 64134 start
			bulkRelease := reserveDetail.myReserveHeader;		// 02/07/2024 navcs2 Bug 64134 start
		endif;													// 02/07/2024 navcs2 Bug 64134 start
	endif;
	
	// Find the right timestamp for the new VVR detail
	foreach vvrDetail in self.allVehicleVisitRecordDetails reversed do
		if vvrDetail.recordType = VisitRecord_CargoPlaced then
			vvrCargoPlaced := vvrDetail;
		elseif vvrDetail.recordType = VisitRecord_Arrive_PGate_Out or  vvrDetail.recordType = VisitRecord_Complete_OutGate then
			vvrRoadExit := vvrDetail;
		endif;
		
		if vvrCargoPlaced &lt;&gt; null and vvrRoadExit &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	// Do some time things
	if vvrCargoPlaced &lt;&gt; null and vvrRoadExit &lt;&gt; null then
		timeDifference := vvrCargoPlaced.createdTime.time.asMilliseconds - vvrRoadExit.createdTime.time.asMilliseconds;
		vvrDetailTime.setTime(self.timeOut.time);																		// 28/05/2024		navcs2	Bug 64144
		vvrDetailTime.setDate(self.timeOut.date);																		// 28/05/2024		navcs2	Bug 64144
	endif;
	
	// Handle Added cargo
	if _addedCargo &lt;&gt; null then
		foreach gteEntity in _addedCargo do
			trackedItem := gteEntity.getTI();
			if trackedItem &lt;&gt; null and trackedItem.site &lt;&gt; TI_SITE_OFFSITE then					// 20/09/2025	navcs2	MTN-35846
				if gteEntity.isKindOf(CMGTE_Release) then
					if reserveDetail &lt;&gt; null then
						if trackedItem.totalQuantity &gt; reserveDetail.getQuantityRemaining then											// 10/10/2025		navcs2	MTN-36214
							app.raiseCMException1(Quant_weigh_relea_will_excee_r, reserveDetail.getReleaseNumberDescr, null, null); 	// 10/10/2025		navcs2	MTN-36214
							return;																										// 10/10/2025		navcs2	MTN-36214
						endif;																											// 10/10/2025		navcs2	MTN-36214
						if  reserveDetail.isReserveSelection then								// 19/08/2024		navcs2	Bug 65450
							reserveDetail.addTIReleased(trackedItem);
						elseif bulkRelease &lt;&gt; null then											// 19/08/2024		navcs2	Bug 65450
							bulkRelease.addReserveTiReleased(trackedItem, null);				// 19/08/2024		navcs2	Bug 65450
						endif;																	// 19/08/2024		navcs2	Bug 65450
					endif;
				endif;
				
				create moveController transient;
				moveController.setMoveContext(CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT);				// 16/10/2025	navcs2	MTN-36214
				moveController.setMyTrackedItem(trackedItem);
				locController := self.vehicle.locationsController;
				moveController.setMyToPrimaryLocation(locController);
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);							// 20/09/2025	navcs2	MTN-35846
				app.myPassport.myTerminal.findLocationFromString(app.getErrorString(Nowhere), true ,locController, foundHeight);
				delete moveController;
				create moveController transient;
				moveController.setMoveContext(CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT);				// 20/09/2025	navcs2	MTN-35846
				moveController.setMyTrackedItem(trackedItem);
				moveController.setMyToPrimaryLocation(locController);
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);							// 20/09/2025	navcs2	MTN-35846
				self.allReleasedTrackedItems.add(trackedItem);
				
				create information transient;																								// 15/05/2024		navcs2	Bug 64144
				information.add(app.getErrorString2(Track_item_from_vehic_visit_co, "Added", self.visitNumber .asStringJMT));				// 15/05/2024		navcs2	Bug 64144
				trackedItem.createInfomationTransaction( "Corrected Info", information, null, _passport );									// 15/05/2024		navcs2	Bug 64144
				delete information;																											// 15/05/2024		navcs2	Bug 64144
				delete moveController;
			endif;
		endforeach;
	endif;

	// Handle removed cargo
	if tiSet &lt;&gt; null then		// 20/09/2025	navcs2	MTN-35846
		if self.vehicle &lt;&gt; null and self.vehicle.locationsController &lt;&gt; null then 
			vehicleLocation := self.vehicle.locationsController.CM_VehicleController.getFullSourceId;
		endif;
		foreach trackedItem in tiSet do		// 20/09/2025	navcs2	MTN-35846
			if trackedItem &lt;&gt; null then
				foreach vvrDetail in self.allVehicleVisitRecordDetails do
					if vvrDetail.getExtraInfo_TrackedItem = trackedItem then
						foreach transaction in trackedItem.allTransactions reversed do
							if (transaction.getType = TRANS_TYPE_MOVE and transaction.CM_Move.targetLocn = app.getErrorString(Nowhere) and transaction.CM_Move.sourceLocn = vehicleLocation) then
								transTimeStamp 	:= transaction.dateTime;
								transaction.setForDelete("Corrected Info");
								break;
							endif;
						endforeach;
						foreach transaction in trackedItem.allTransactions reversed do
							if (transaction.getType = TRANS_TYPE_MOVE and transaction.CM_Move.targetLocn = vehicleLocation and transaction.dateTime = transTimeStamp)
							or (transaction.getType = TRANS_TYPE_EDIT and transaction.dateTime = transTimeStamp)
							or (transaction.getType = TRANS_TYPE_REL_ROAD and transaction.dateTime = transTimeStamp)
							or (transaction.getType = TRANS_TYPE_STORAGE and transaction.dateTime = transTimeStamp) then
								transaction.setForDelete("Corrected Info for Departed transport");
							endif;
						endforeach;
						if reserveDetail &lt;&gt; null then 
							reserveDetail.removeTIReleased(trackedItem);	
						endif;
						vvrDetail.erase(NORMAL_ERASE);
					endif;
				endforeach;
				
				self.allReleasedTrackedItems.tryRemove(trackedItem);
				vvrDetail := self.createVisitRecordDetail(VisitRecord_CargoRemoved, trackedItem, null);									// 28/05/2024		navcs2	Bug 64144	
				create information transient;																							// 15/05/2024		navcs2	Bug 64144
				information.add(app.getErrorString2(Track_item_from_vehic_visit_co, "Removed", self.visitNumber.asStringJMT));			// 15/05/2024		navcs2	Bug 64144
				trackedItem.createInfomationTransaction( "Corrected Info", information, null, _passport );								// 15/05/2024		navcs2	Bug 64144
				delete information;																										// 15/05/2024		navcs2	Bug 64144
			endif;
		endforeach;
	endif;
	
	// 02/07/2024 navcs2 Bug 64134 start
	if bulkRelease &lt;&gt; null and not bulkRelease.releaseByType then
		foreach trackedItem in tiSet do
			bulkRelease.removeReserveTi(trackedItem);
		endforeach;
	endif;
	// 02/07/2024 navcs2 Bug 64134 end
epilog
	delete information;	// 15/05/2024		navcs2	Bug 64144
	delete transControl;
	delete tiSet;
	delete removedTIs;
	delete monitor;
	
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_addedCargo" type="CMGTE_EntitySet"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_moveController" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateGateCheckDetails" id="d5713544-88a8-439d-9523-8f1f28503a26">
        <updating/>
        <source>updateGateCheckDetails(_gateInCheck : Boolean;_gateCheckStatus : String; _gateCheckTS : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2022	navsp1	Initial creation TFS - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
08 Sep 2023	navdap1	TFS 59894 FR | 53667 - Inspection App - No Message Send When Both Inspections Are Set To "NO"
26 Jul 2024 navsp1  TFS Bug 65247: EUP - Gate Out Check Status not getting updated
*/

vars
	gateCheckStatus : String;

begin
	/*Regardless of the vehicle booking slot gate in check value, the Inspection Status should be able to be changed to any value.			//TFS 65247
	// TFS 59894 start
	gateCheckStatus := _gateCheckStatus;
	if self.myVehicleBookingTimeslot &lt;&gt; null and _gateInCheck and not self.myVehicleBookingTimeslot.preGateInCheck then
		gateCheckStatus := self.InspectionNA;
	elseif self.myVehicleBookingTimeslot &lt;&gt; null and not _gateInCheck and not self.myVehicleBookingTimeslot.preGateOutCheck then
		gateCheckStatus := self.InspectionNA;
	endif;
	// TFS 59894 end
	*/
	
	if _gateInCheck then
		self.gateInCheckStatus 	:= _gateCheckStatus;	//TFS 65247
		self.gateInCheckTS 		:= _gateCheckTS;
	else
		self.gateOutCheckStatus	:= _gateCheckStatus;	//TFS 65247
		self.gateOutCheckTS		:= _gateCheckTS;
	endif;
epilog

end;</source>
        <Parameter name="_gateInCheck" type="Boolean"/>
        <Parameter name="_gateCheckStatus" type="String"/>
        <Parameter name="_gateCheckTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateJobQueueOrder" id="9a7d2048-ad8d-47f1-8794-309bdb1bc7bc">
        <source>updateJobQueueOrder(
						_allReceivalGTEs : CMGTE_EntityArray;
						_allReleaseGTEs :   CMGTE_EntityArray);
/*

Date		Who		Reason
15 July 2014	cnwer1	Initial creation PAR  CCMS 1386 ROB gate cargo

*/

vars
	obj : Object;
	childGte,
	gte : CMGTE_Entity;
	idx : Integer;
	allGTEs : CMGTE_EntityArray;
begin
	
	
	create allGTEs transient;
	foreach gte in self.allGateEntities do
		//will add children straigt after parent
		if gte.myParent = null then
			allGTEs.add(gte);
		endif;
	endforeach;
	// re-hash the gate entities, so that we don't get key clashes
	foreach gte in self.allGateEntities do
		gte.setJobQueueNum(-gte.jobQueueNum);
	endforeach;
	
	//all in chasssis first
	idx:=1;
	if self.myInCMGTE_Chassis &lt;&gt; null then
		self.myInCMGTE_Chassis.setJobQueueNum(1);	//chassis in always 1
		allGTEs.remove(self.myInCMGTE_Chassis);
	endif;
	idx:=3;
	//all receival containers
	if _allReceivalGTEs &lt;&gt; null then
		foreach obj in _allReceivalGTEs do
			if self.allGateEntities.includes(obj.CMGTE_Entity) then
				obj.CMGTE_Entity.setJobQueueNum(idx);
				idx:=idx +1;
				allGTEs.remove(obj.CMGTE_Entity);
				foreach childGte in obj.CMGTE_Entity.allChildren do			
					if self.allGateEntities.includes(childGte) then	
						childGte.setJobQueueNum(idx);
						idx:=idx +1;
						allGTEs.remove(childGte);
					endif;
				endforeach;
			endif;
		endforeach;
	endif;	
	
	foreach gte in allGTEs do
		if gte.isReceipt then
			gte.setJobQueueNum(idx);
			idx:=idx +1;
			foreach childGte in gte.allChildren do			
				if self.allGateEntities.includes(childGte) then
					childGte.setJobQueueNum(idx);
					idx:=idx +1;
				endif;
			endforeach;
		endif;
	endforeach;	
	
	
	//all out chassis
	if self.myOutCMGTE_Chassis &lt;&gt; null then
		self.myOutCMGTE_Chassis.setJobQueueNum(2); //chassis out always 2
		allGTEs.remove(self.myOutCMGTE_Chassis);
	endif;
	
	//must be release 
	//do containers then children
	if _allReleaseGTEs &lt;&gt; null then
		foreach obj in _allReleaseGTEs do
			if self.allGateEntities.includes(obj.CMGTE_Entity) then
				obj.CMGTE_Entity.setJobQueueNum(idx);
				idx:=idx +1;
				allGTEs.remove(obj.CMGTE_Entity);
				foreach childGte in obj.CMGTE_Entity.allChildren do			
					if self.allGateEntities.includes(childGte) then		
						childGte.setJobQueueNum(idx);
						idx:=idx +1;
						//allGTEs.remove(childGte);
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
	//the remaining
	foreach gte in allGTEs do
		if not gte.isReceipt then
			gte.setJobQueueNum(idx);
			idx:=idx +1;
			foreach childGte in gte.allChildren do		
				if self.allGateEntities.includes(childGte) then
					childGte.setJobQueueNum(idx);
					idx:=idx +1;
				endif;
			endforeach;
		endif;
	endforeach;	
epilog
	delete allGTEs;
end;</source>
        <Parameter name="_allReceivalGTEs" type="CMGTE_EntityArray"/>
        <Parameter name="_allReleaseGTEs" type="CMGTE_EntityArray"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="8f826bb5-fe79-45ce-b549-b2206c9aa2cb">
        <updating/>
        <source>updateStatus(_status : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/11/2011		cnwdap1			PAR #28494 If I'm cancelling the CMGTE_Entities, and I'm not Cancelled
//									but I have no road job any more, cancel me as well
// 18 Jun 2013		cnwcs5			par 31670 - new _context parameter for createVehicleVisitDetail method
// ---------------------------------------------------------------------------

vars
	gateItem : CMGTE_Entity;
begin
	foreach gateItem in self.allGateEntities discreteLock do 
		gateItem.changeStatus(_status);
	endforeach;
	
	// PAR #28494 start
	if _status = CMGTE_Entity.Status_Cancelled and self.status &lt;&gt; self.Status_Cancelled and self.myRoadJob = null then
		self.status := self.Status_Cancelled;
		// and create the detail records to record the cancel
		self.createVisitRecordDetail(VisitRecord_Cancel, null, null);			// par 31670
		self.setTimeOutCancelled(app.serverTimestampAtTrxStart );
		self.createVisitRecordDetail(VisitRecord_Complete_OutGate, null, null);	// par 31670
	endif;
	// PAR #28494 end

epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateChangeStatus" id="67d13238-84e0-43fd-9b80-1c02ed3b9d85">
        <source>validateChangeStatus(_newStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     09 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	currentStatus : Integer;
begin
	currentStatus := self.status;
	
	if _newStatus =  currentStatus then
		return;
	endif;

	if _newStatus = self.Status_Cancelled then
		if currentStatus = self.Status_Complete
		or  currentStatus = self.Status_Unactioned
		or  currentStatus = self.Status_Yard then
			app.raiseCMException3(ERR_Cannot_Change_Status, self.visitNumber, "'Cancelled'", " As it is currently '" &amp; self.getStatusString() &amp; "'." , null, self);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1b119f4f-97d6-4012-8616-508b73d7c75d">
        <source>validateForCreate(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09 Feb 2024      navbs1          Bug 62310: STWO - Trucks being banned
//
// ---------------------------------------------------------------------------
vars
	vehicle : CM_Vehicle;
begin

	
	vehicle := self.myTerminal.vehicles[self.regNumber, self.state];
	if vehicle &lt;&gt; null and vehicle.isNotAvailableForEntry then		//09.02.2024 navbs1 #62310
		app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Vehicle) &amp; ' (' &amp; self.regNumber &amp; '  ' &amp; self.state &amp;') ', null, null);
	// 1061 When creatibng a new visit record for a truck, the truck should NOT be onsite
	elseif vehicle &lt;&gt; null and vehicle.isOnsite and not vehicle.isInGateLocation(self.myGateIn) then
		app.raiseCMException2(VehicleIsOnSite, self.regNumber, vehicle.getMyPrimaryActualLocation.getNiceName, ETRow_RegNumber, null);
	endif;

	return self.validateForUpdate(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateJobFlexi" id="8c579941-7554-458f-9da8-354526e35625">
        <source>validateForCreateJobFlexi(_passport : CM_Passport input;  _pxyTIs : CM_ObjectByStringDict io; _fromEasyGate : Boolean);
// ---------------------------------------------------------------------------
// Created:     26 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxySub, 
	pxyGate 	: CMGTE_Entity;
	hasTrouble 	: Boolean;
	pxyTI		: CM_TrackedItem;
	vehicle		: CM_Vehicle;
	reg			: String;
	driver		: CM_DriverDetails;
begin
	if self.allGateEntities.isEmpty() and self.myInCMGTE_Chassis = null and self.myOutCMGTE_Chassis = null  and 
	   self.myOutCMGTE_Chassis = null then	
		app.raiseCMException1(ERR_No_Items_Entered, null, null, self);
		return;
	endif;
	
	if self.myRoadJob &lt;&gt; null or self.status = self.Status_Complete then
//		app.raiseCMException2(ERR_RoadJob_Exists, self.visitNumber &amp; " for " &amp; self.vehicle.code, null, null, self);
		app.raiseCMException2(ERR_RoadJob_Exists, self.visitNumber &amp; " for " &amp; self.regNumber, null, null, self);	//23 Nov 2020	NDL	TFS 50398
		return;
	endif;
	

	vehicle := self.myTerminal.vehicles[self.regNumber, self.state];
	if vehicle = null then 
		if self.state &lt;&gt; null then
			reg := regNumber &amp; " (" &amp; self.state &amp; ")";
		else
			reg := regNumber;
		endif;
		app.raiseCMWarning1(VB_NEW_VEHICLE, reg, null, null, self);
	endif;
	
	// cnwjk3	09/10/09 PAR 21026 
	// we can only create a driver on the fly if we have both code and name
	driver := self.myTerminal.allDriversByCode[self.driverCode];
	if driver = null and self.driverCode &lt;&gt; null and self.driversName &lt;&gt; null then
		app.raiseCMWarning1(WARN_Driver_Unknown, self.driverCode, null, null, self);
	endif;
	
	self.validateForUpdate(_passport);

	if _fromEasyGate then
		return;
	endif;
	
	// ### This creates the 'trouble' if any
	foreach pxyGate in self.allGateEntities discreteLock do
		
		// cnwjk3 PAR 21925 12/02/10 
		pxyTI := null;
		//19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx 
		pxyGate.validateMe(_passport,_pxyTIs);
	/*	 
		pxyGate.validateForCreate(_passport, pxyTI);
				
		if pxyTI &lt;&gt; null then
			if not _pxyTIs.includes(pxyTI) then
				//_pxyTIs[pxyGate.id] := pxyTI;
				_pxyTIs[pxyGate.getStringDictKey] := pxyTI;	//30 Nov 2016	TFS 2999
			endif;
		endif;

		pxyGate.setForUpdateErrorsFromPassport(self, _passport);

		if pxyGate.isReceipt then
		
			foreach pxySub in pxyGate.allChildren discreteLock do
				pxySub.validateForCreate(_passport, pxyTI);
				if pxyTI &lt;&gt; null then
					//_pxyTIs[pxySub.id] := pxyTI;
					_pxyTIs[pxySub.getStringDictKey] := pxyTI;	//30 Nov 2016	TFS 2999
				endif;
				pxySub.setForUpdateErrorsFromPassport(self, _passport);
			endforeach;
		endif;*/
	endforeach;

epilog

	if _passport.hasErrors and pxyTI &lt;&gt; null and pxyGate &lt;&gt; null and not _pxyTIs.includes(pxyTI) then
		//if the line "pxyGate.validateForCreate(_passport, pxyTI);" fails we get left with a proxy
		// that is not in the collection, so isn't deleted.
		_pxyTIs[pxyGate.getStringDictKey] := pxyTI;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTIs" type="CM_ObjectByStringDict" usage="io"/>
        <Parameter name="_fromEasyGate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateSecurityGate" id="dfa74ccb-f6cc-4d6d-ac4d-a0c7d0ef14b3">
        <source>validateForCreateSecurityGate(_batNumber : String; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 25/02/2014	cnwdap1		PAR #33582 Registration Number configurable as required
// 19/06/2014	cnwmh5		#34270 - Check that BAT/RFID number is currently available
// 10 Mar 2017	cnwrs1	TFS3591 handle null rfidTag
// 01 Aug 2018	jlgrh7 TFS39735 STWR - Security Gate Visit / Road Gate Visit
//
vars
	vehicle : CM_Vehicle;
	reg		: String;
	driver	: CM_DriverDetails;
	rfidTag	: CM_RFIDTag;
	vvr 			: CM_VehicleVisitRecord;															//+TFS39735
begin
	if self.myTerminal.getConfig(KnownTruckRequired).Boolean then			// PAR #33582
		vehicle := self.myTerminal.vehicles[self.regNumber, self.state];
		if vehicle = null then 
			if self.state &lt;&gt; null then
				reg := regNumber &amp; " (" &amp; self.state &amp; ")";
			else
				reg := regNumber;
			endif;
			app.raiseCMException1(No_Record_Of_Vehicle, reg, null, self);
		endif;
	endif;																	// PAR #33582
	
	// we can only create a driver on the fly if we have both code and name
	driver := self.myTerminal.allDriversByCode[self.driverCode];
	if driver = null and self.driverCode &lt;&gt; null and self.driversName &lt;&gt; null then
		app.raiseCMWarning1(WARN_Driver_Unknown, self.driverCode, null, null, self);
	endif;
	
	// if the terminal is configured for rfid tags / bat numbers, we have to have one at this stage
	if not self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean then
		if _batNumber = null then
			app.raiseCMException(ERR_Bat_Number_Blank, null, null);
		endif;
		// 19/06/2014 cnwmh5 #34270
		rfidTag := self.myTerminal.allRFIDTagsByCode[_batNumber];
		if rfidTag &lt;&gt; null and
		   not rfidTag.isAvailableForEntry then
			app.raiseCMException1(ERR_BAT_IN_USE, _batNumber, null, self);
		endif;	
	endif;
	
	vehicle := self.myTerminal.vehicles[self.regNumber, self.state];								//+TFS39735 STWR - Security Gate Visit / Road Gate Visit
	if vehicle &lt;&gt; null then
		vvr := vehicle.getCurrentVisit();
		if vvr &lt;&gt; null and vvr.isIncompleteForSecurityGate() then											// already an indentical vehicle at the security gate and not gate out yet
				app.raiseCMException1(ERR_VehiREG_IN_USE, self.regNumber, null, self);
		endif;
	endif;
	
	self.validateForUpdate(_passport);
epilog

end;</source>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForFlexiDuplicates" id="6694858d-c3dc-45a3-be63-ff1fa9eadbf7">
        <source>validateForFlexiDuplicates(_gtes : Collection input);
// ---------------------------------------------------------------------------
// Created:     05 November 2008 by cnwab1
//
// When a proxy gate entity (_pxyEntity) is supplied, the validation uses the updated
// proxy in place of the existing real entity for the validate.
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	02/05/2023		jlizm1			TFS 55453 Cargo uniqueness by subtype
// 15 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
// ---------------------------------------------------------------------------

vars
	gateColl : CMGTE_EntityArray;
	subTypeChecks : CMGTE_EntityArray;
	gate, subGate : CMGTE_Entity;
	tmpGate : CMGTE_Entity;
	ids, mess : StringArray;
	tmpID, tmpMess : String;
	errorCodes : IntegerArray;
	preventSubTypeDups : Boolean;
	iter : Iterator;
begin
	create gateColl transient;
	create subTypeChecks transient;
	create ids transient;
	create mess transient;
	create errorCodes transient;	//13 Sep 2012	NDL	Par 30366

	if _gtes &lt;&gt; null then
		iter:=_gtes.createIterator;
	else
		self.allGateEntities.copy(gateColl);
		iter:=gateColl.createIterator;
	endif;
	
	preventSubTypeDups := self.myTerminal.getConfig(DisallowDupIDForSubtype).Boolean;
	
	
	while iter.next(gate) do
		if gate.isKindOf(CMGTE_Release) then
			if not gate.CMGTE_Release.isReleaseById then
				continue;
			endif;
		endif;		

		
		tmpID := gate.getID();
		if tmpID = null then
			continue;
		endif;
		
		if gate.isKindOf(CMGTE_Release) then
			if gate.CMGTE_Release.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
				continue;
			endif;
		endif;
		
		if not ids.includes(tmpID) then
			if not gate.cargoTypeAllowsDuplicates then //cnwrd1 par 31731
				ids.add(tmpID);
			endif;
		else
			
				//tmpMess := "Duplicate ID for " &amp; gate.getCargoTypeDescription() &amp; " " &amp; tmpID &amp; "."; //- cnwmd1, Par 20524
				tmpMess := app.getErrorString2(Duplicate_ID_For,gate.getCargoTypeDescription(), tmpID);
				errorCodes.add(Duplicate_ID_For);	//13 Sep 2012	NDL	Par 30366
				mess.add(tmpMess);
		
		endif;
		
		if gate.isReceipt then
			if preventSubTypeDups and gate.cargoTypeAllowsDuplicates then
				subTypeChecks.add(gate);
			endif;
		
			foreach subGate in gate.allChildren discreteLock do
				tmpID := subGate.getID();
				
				if not ids.includes(tmpID) then
					ids.add(tmpID);
				else
					if subGate.cargoTypeAllowsDuplicates and self.myTerminal.getConfig(AllowDuplicatePreNotes).Boolean then	//30 Nov 2016	NDL	TFS 2999
						//that's OK
					else
						//tmpMess := "Duplicate ID for " &amp; subGate.getCargoTypeDescription() &amp; " " &amp; tmpID &amp; "."; //- cnwmd1, Par 20524
						tmpMess := app.getErrorString2(Duplicate_ID_For, subGate.getCargoTypeDescription(), tmpID);
						errorCodes.add(Duplicate_ID_For);	//13 Sep 2012	NDL	Par 30366
						mess.add(tmpMess);
					endif;
				endif;
				
				if preventSubTypeDups and gate.cargoTypeAllowsDuplicates and self.myTerminal.getConfig(AllowDuplicatePreNotes).Boolean then
					subTypeChecks.add(subGate);
				endif;
			
			endforeach;
		endif;
	endwhile;
	
	// Go through and check for duplicate ids where subtype requires uniqueness
	ids.clear();
	foreach gate in subTypeChecks do
		if ids.includes(gate.getID()) then
			continue;
		endif;
		foreach tmpGate in subTypeChecks do
			if tmpGate = gate then
				continue;
			endif;
			if tmpGate.getID() &lt;&gt; gate.getID() then
				continue;
			endif;
			if ids.includes(tmpGate.getID()) then
				continue;
			endif;
			if tmpGate.getCargoTypeDescription &lt;&gt; gate.getCargoTypeDescription then
				continue;
			endif;
			if tmpGate.getCargoSubTypeCode() = gate.getCargoSubTypeCode() then
				continue;
			endif;
			tmpMess := app.getErrorString2(Duplicate_ID_For, gate.getCargoTypeDescription(), tmpID);
			errorCodes.add(Duplicate_ID_For);
			mess.add(tmpMess);
			ids.add(gate.getID);
		endforeach;
	endforeach;
	
	foreach tmpMess in mess do
		//app.raiseCMException1(Flexi_Duplicates, tmpMess, null, self);
		app.raiseMultiReasonExcOrWarning( errorCodes, tmpMess, false, null,  null );	//13 Sep 2012	NDL	Par 30366
	endforeach;
	
epilog
	delete iter;
	delete gateColl;
	delete subTypeChecks;
	delete ids;
	delete mess;
	delete errorCodes;	//13 Sep 2012	NDL	Par 30366
end;</source>
        <Parameter name="_gtes" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForSecurityGateExit" id="7eada39d-0c47-4b51-b488-839613e17648">
        <source>validateForSecurityGateExit(_exitTime : TimeStamp);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	roadJob	: CM_RoadJob;
	detail	: CM_VehicleVisitRecordDetail;
	ts : TimeStamp;

begin
	// if we still have a road job, have to validate we can process the road exit for it
	if self.myRoadJob &lt;&gt; null then
		if self.myRoadJob.status &lt;&gt; JOB_COMPLETE then
			if self.myRoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
				app.raiseCMWarning(XLAT_RoadExit_Warning1, "myRoadJob", null, self);
			endif;
			if self.myRoadJob.autoComplete then
				app.raiseCMException(XLAT_Road_Exit_Error1, "myRoadJob", null);
			else
				app.raiseCMException(XLAT_Road_Exit_Error2, "myRoadJob", null);
			endif;
		endif;
		
		// can't road exit a truck through the security gate if it has released cargo on it
		if not self.myRoadJob.allReleaseTrackedItems.isEmpty then
			app.raiseCMException1(Vehicle_not_checked_road_gate, self.regNumber, "allReleasedTrackedItems", null);
		endif;
	endif;
	
	//02 Nov 2015	NDL	Par 36886
	if self.myTerminal.getConfig( MustExitMainGatePreSec ).Boolean then
		ts := self.getArrivalAtGateInTime();
		if ts &lt;&gt; null then	// they have been gated into the real terminal
			detail := self.getGateOutVVRDetail();
			if detail = null then
				app.raiseCMException(Truck_not_exite_from_secur_gat, "Exit Main Gate", self);
			endif;
		endif;
	endif;
	
	detail := self.allVehicleVisitRecordDetails.last;
	if _exitTime &lt; detail.timeStart then
		app.raiseCMException2(Departure_Date_Too_Early, detail.getRecordDetailDescription, detail.timeStart.asStringJMT, "Departure Time", self);
	endif;
epilog

end;</source>
        <Parameter name="_exitTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d7626b99-9670-42e5-b584-2e233ff894f1">
        <source>validateForUpdate(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26 Feb 2010		consw1			PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit
// 18 Dec 2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate
// 25 Feb 2014		cnwdap1			PAR #33582 Reg Number is no longer required at Security Gate
// 10 Oct 2014		cnwdap1			PAR #34937 Correct validation of whether vehicle already has a job
//									if last vehicle visit still has a road job, we can't create a new visit
// 28 Aug 2018		jlgrs1			TFS 39619 PEN - Approved Carriers For Operator 
// 19 Aug 2019		jlgdap1			TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 23 Feb 2022		navdap1			TFS 52268 AAT 1-Stop VBS Integration
// 14/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 11/05/2023		navpw1			TFS: 54049 (55840) - If the vbs process is slot type valdiation then for each vbs time slot, we are validating the vehicle against it
// 26/05/2023		navpw1			TFS: 57756 (57896) - Changed to call VBSProcess::validateVehicleAganistVBSSlot as it raises warnings and errors against the trx
// 21/03/2024		jlizm1			TFS 63084 Gate required driver
// ---------------------------------------------------------------------------

vars
	driver				: CM_DriverDetails;
	carrier,
	subCarrier			: CM_Carrier;
	vehicle				: CM_Vehicle;
	tmpStr				: String;
	reqTruck,
	reqCarrier,
	reqDriver			: Boolean;
	tmpTerm				: CM_Terminal;
	tmpVVREC			: CM_VehicleVisitRecord;
	realMe				: SelfType;
	reg					: String;
	obj					: Object;
	releaseContainers	: ObjectSet;
	ti					: CM_TrackedItem;
	dac					: CM_DataAccessController;
	operatorStr			: String;
	cargoSubType,
	isoType,
	trailerType			: String;
	entity				: CMGTE_Entity; 				// TFS 52268
	needsBooking		: Integer;						// TFS 52268
	vbsProcess			: CM_VBSProcess;				// ### TFS 54049 (55840) 04May2023 NAVPW1
	vbts				: CM_VehicleBookingTimeSlot;	// ### TFS 54049 (55840) 23May2023 NAVPW1
	gateEntitySet		: CM_ObjectSet;					// ### TFS 54049 (55840) 23May2023 NAVPW1
	invalidObject		: Boolean;						// ### TFS 62889 (63086) 21Mar2024 NAVPW1
	
begin
	tmpTerm := self.myTerminal;														// PAR #33582
	
	//reqTruck := false;															// PAR #33582
	reqTruck := tmpTerm.getConfig(KnownTruckRequired).Boolean;						// PAR #33582
	reqCarrier := false;
	reqDriver := tmpTerm.getConfig(KnownTruckDriverRequired).Boolean;				// TFS63084

	// Driver is optional, but can be configured to be mandatory 
	if reqDriver then
		// both will be required, but don't bother raising an error for both every time 
		if driverCode = null then
			app.raiseCMException1(ERR_Driver_Code_Blank, null, null, null);	
		elseif driversName = null then
			app.raiseCMException1(ERR_Driver_Name_Blank, null, null, null);	
		endif;
	endif;
	
	// use the code to lookup, as it is mantatory
	driver := tmpTerm.findDriver(self.driverCode);

	if driver &lt;&gt; null then
		tmpStr := driver.isDriverOK();
		if tmpStr &lt;&gt; null then
			app.raiseCMException2(ERR_Driver_Bad_Status,self.driversName, tmpStr, null,  null);
		endif;
	endif;

	carrier:= app.myRoot.allCarriers[self.carrierCode];
	if reqCarrier then
		if self.carrierCode = null then
			app.raiseCMException1(ERR_Carrier_Blank,  null, null, null);
		else
			if carrier = null then
				app.raiseCMException2(ERR_Carrier_Unknown,  "'" &amp; self.carrierCode &amp; "'", null , null, null);
			endif;
		endif;
	endif;
	
	//Start 14/05/2022 navhl20 TFS 53430 
	if self.subCarrierCode &lt;&gt; null then
		subCarrier:= app.myRoot.allSubCarriersRoad[self.subCarrierCode];
		if reqCarrier then
				if subCarrier = null then
					app.raiseCMException2(ERR_Carrier_Unknown,  "'" &amp; self.subCarrierCode &amp; "'", null , null, null);
				endif;
		endif;
	endif;
	//End 14/05/2022 navhl20 TFS 53430

	// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
	if carrier &lt;&gt; null then
		create releaseContainers transient;
		self.getAllReleaseContainerEntities(releaseContainers);
		foreach obj in releaseContainers do
			ti := obj.CMGTE_Release.myTrackedItem;
			
			// ### TFS 62889 (63086) 21Mar2024 NAVPW1
			if ti &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, ti, invalidObject);
				ti.edition;
				on Exception do null;
				if invalidObject then
					invalidObject := false;
					continue;
				endif;
			endif;
			// ### TFS 62889 (63086) 21Mar2024 NAVPW1
			
			// get cargo sub type and iso type									// TFS 45836
			if ti &lt;&gt; null then													// TFS 45836
				cargoSubType := ti.productCode;									// TFS 45836
				isoType := ti.getISOType();										// TFS 45836
			endif;																// TFS 45836
			// get trailer type													// TFS 45836
			if obj.CMGTE_Release.myTILCType &lt;&gt; null then						// TFS 45836
				trailerType := obj.CMGTE_Release.myTILCType.code;				// TFS 45836
			endif;																// TFS 45836
			if  ti &lt;&gt; null and
			   ti.myOperator &lt;&gt; null and
			   ti.cargoType &lt;&gt; null and
			   //not ti.myOperator.canOpAccessCarrierForCargoType(carrier, ti.cargoType) then									// TFS 45836
			   not ti.myOperator.canOpAccessCarrierForCargoType(carrier, ti.cargoType, cargoSubType, isoType, trailerType) then	// TFS 45836
				app.raiseCMException3(Opera_denie_carri_acces_cargo_, ti.myOperator.description, carrier.description, ti.cargoTypeDescr, null, null);
			endif;
			
			if  ti &lt;&gt; null and 
				not carrier.canCarrierAccessForOperator(ti.myOperator, dac, true) then
				if ti.myOperator &lt;&gt; null then
					operatorStr := ti.myOperator.description;
				endif;
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
				return false;
			endif;
		endforeach;
	endif;

	if self.regNumber = null then
		if reqTruck or self.visitType &lt;&gt; self.VisitType_SecurityGate  then	//epr par 36232 18/5/15													
			app.raiseCMException1(ERR_Truck_Blank,  null, null, null);
		endif;																		// PAR #33582
	else
		vehicle:= tmpTerm.vehicles[self.regNumber, self.state];
		if reqTruck then
			//cnwmc5 - 5 August 2014 - PAR 34672
		//epr par 35304 2/12/14 
			if vehicle = null then					
				// ccms1035 cnwjk3 - added state
				if self.state &lt;&gt; null then
					reg := self.regNumber &amp; " (" &amp; self.state &amp; ")";
				else
					reg := self.regNumber;
				endif;
				app.raiseCMException1(ERR_Truck_Unknown, "'" &amp; reg &amp; "'", null, null);
			endif;
		endif;
	endif;
	
	// PAR #32849 Don't validate lane controller if we're still at the security gate - we won't have one
	if self.visitType &lt;&gt; self.VisitType_SecurityGate then									// PAR #32849
		if self.myGateLaneController = null then
			app.raiseCMException1(ERR_GateLane_Unknown, null, null, null);
		endif;
	endif;																					// PAR #32849
	
	realMe := self.pxyGetRealObject().CM_VehicleVisitRecord;
	if realMe = null then
		realMe := self;
	endif;

	if vehicle &lt;&gt; null then
		tmpVVREC := vehicle.visitRecords.last;
		if tmpVVREC &lt;&gt; null and tmpVVREC &lt;&gt; realMe then
			if tmpVVREC.status &lt;&gt; self.Status_Complete and  tmpVVREC.status &lt;&gt; self.Status_Cancelled then // or cancelled?
				// ccms1035 cnwjk3 - added state
				//app.raiseCMException2(ERR_VehicleHasJob, vehicle.regNumber, "Job number (" &amp; tmpVVREC.jobNumber &amp; ").", null, null);
				if vehicle.state &lt;&gt; null then
					reg := vehicle.regNumber &amp; " (" &amp; vehicle.state &amp; ")";
				else
					reg := vehicle.regNumber;
				endif;
				
				if  not (tmpVVREC.status = self.Status_Unverified and self.allGateEntities.size = 0) 	// PAR #34937 then //epr 3/3/14 it was annoying me if I had an VVR that had nothing why can't you edit it				
				or tmpVVREC.myRoadJob &lt;&gt; null then														// PAR #34937
					app.raiseCMException2(ERR_VehicleHasJob, reg, tmpVVREC.visitNumber, null, null);
				endif;
			endif;
		endif;
	endif;
	

	if driver &lt;&gt; null and carrier &lt;&gt; null then																//cnwas3 par 23465 begin
		if not driver.allCarriers.isEmpty() and not driver.allCarriers.includes(carrier) then			
			app.raiseCMException1(Selected_carrier_not_driver,carrier.code, null,  null);
		endif;
	endif;
	
	if driver &lt;&gt; null and
	   vehicle &lt;&gt; null and
	   not driver.isVehicleOnDriversList(vehicle) then		//cnwas3 par 23865
	    if vehicle.carrier &lt;&gt; carrier then
			if not _passport.allErrors.includesErrorCode(Selected_vehicle_not_driver) then
				app.raiseCMException1(Selected_vehicle_not_driver,vehicle.regNumber, null,  null);
			endif;
		elseif vehicle.carrier = carrier then	
			if not _passport.allWarnings.includesErrorCode(Selected_vehicle_not_driver) and
				_passport.warningsAcknowledged then																//cnwas3 par 23865
				app.raiseCMWarning1(Selected_vehicle_not_driver,vehicle.regNumber, null,  null, null);
			endif;
		endif;
	endif;	
	
	if tmpTerm.roadProcessIsASPA then
		if not self.timeIn.isValid then
			app.raiseCMException(Date_Enter_Valid, null, null);
			return false;
		endif;
	endif;
	
	// TFS 52668 are there enough 1-Stop vehicle booking slots
	if tmpTerm.roadProcessIs1StopVBS and tmpTerm.is1STOPVBSConfigured then
		foreach entity in self.allGateEntities where entity.requires1StopVehicleBooking do
			needsBooking := needsBooking + 1;
		endforeach;
		if self.all1StopExtVehicleBookings.size &lt; needsBooking then
			if not app.myPassport.allErrors.includesErrorCode(Not_enough_vehicle_book_slots) then
				app.raiseCMException2(Not_enough_vehicle_book_slots, self.all1StopExtVehicleBookings.size.String, self.allGateEntities.size.String, null, null);
			endif;
			return false;
		endif;
	endif;
	// TFS 52268 end
	
	// ### TFS 54049 (55840) 04May2023 NAVPW1
	//vbsProcess := tmpTerm.getMyVBSProcess();
	//if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and self.allVehicleBookingSlots.isNotEmpty then
	if tmpTerm.isUsingVbsSlotValProcess and self.allVehicleBookingSlots.isNotEmpty then
		//self.validateVehicleAganistVBSSlot(self.allVehicleBookingSlots, tmpTerm);
		vbsProcess := tmpTerm.getMyVBSProcess();										// ### TFS 57756 (57896) 26May2023 NAVPW1
		create gateEntitySet transient;
		self.allGateEntities.copy(gateEntitySet);
		
		vbsProcess.validateVbsSlotCriteria(self.allVehicleBookingSlots, tmpTerm, self, gateEntitySet);	// ### TFS 57756 (57896) 26May2023 NAVPW1
		
	endif;
	// ### TFS 54049 (55840) 04May2023 NAVPW1
	
	return _passport.hasErrors();
	
epilog
	delete releaseContainers;
	delete gateEntitySet;		// ### TFS 54049 (55840) 23May2023 NAVPW1
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReleaseTrailerCargo" id="875b3517-bfd3-4652-92cd-52ddbdb596e8">
        <updating/>
        <source>validateReleaseTrailerCargo()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189 - Moved from CM_RoadJob.validateReleaseTrailerCargo

*/

vars

	ti		: CM_TrackedItem;
	trailer 	: CM_TILC;
	onboardTIs : CM_TISet;
	gteEntity 	: CMGTE_Entity;
	
begin
	
	if self.myOutCMGTE_Chassis = null then
		return;
	endif;
	
	trailer := self.myOutCMGTE_Chassis.getTI.CM_TILC;
	
	if trailer = null then
		return;
	endif;

	if trailer.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
		return;
	endif;
	
	create onboardTIs transient;
	trailer.getAllOnboardTIs(onboardTIs);
		
	foreach ti in onboardTIs discreteLock do 
		gteEntity := self.getGateEntityForTIID(ti.id);
		if gteEntity = null or not gteEntity.isKindOf(CMGTE_Release) then
			app.raiseCMException2(Trailer_release_onboard_cargo,trailer.id,ti.id,null,null);	
		endif;
	endforeach;
		
epilog

	delete onboardTIs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateReserveTI" id="a154f090-f0f1-47b3-9409-c7ae838f94f0">
        <updating/>
        <source>validateReserveTI(_gtes : Collection input) updating ;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
11/04/2019	jlgka1	44334	Use stops heading in the error messages rather than the code.
12/04/2019	jlgka1	44369	STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
17/04/2019	jlgka1	44427	STWO - Bug from Functional Review of 7058 - Cargo Sub Type not displayed
17/04/2019	jlgka1	44423	STWO - Bug from Functional Review of 7058 - Stop Error for Cargo on Ship
15 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
****************************************************/
vars	
	
	gateColl 			: CMGTE_EntityArray;
	gate 				: CMGTE_Entity;
	mess 			: String200Array;
	tmpMess 			: String;
	errorCodes 			: IntegerArray;
	tmpWarnMess			: String200Array;
	cmifGrouping		: CMIF_ReserveTIGrouping;
//	cmifDetails			: CMIF_ReserveTIDetail;
	object				: Object; 
	iter : Iterator;
begin

	create gateColl transient;
	create mess transient;
	create errorCodes transient;
	
	if _gtes &lt;&gt; null then
		iter :=_gtes.createIterator;
	else
		self.allGateEntities.copy(gateColl);
		iter:=gateColl.createIterator;
	endif;
	
	while iter.next(gate) do
	
		if not gate.isKindOf(CMGTE_Release) then
			continue;
		endif;		
		
		if not gate.CMGTE_Release.isReleaseById then
			continue;
		endif;
		
		if gate.CMGTE_Release.myBulkRelease &lt;&gt; null then
			create cmifGrouping transient;
			
			cmifGrouping.setCMIFFromBulkRelease(gate.CMGTE_Release.myBulkRelease, cmifGrouping);
			
			cmifGrouping.validateReserveTIs( errorCodes, mess, null ); // 18 Jun 2019	NDL	TFS 45162 - code from below migrated into this call.
			
			delete cmifGrouping; // 18 Jun 2019	NDL	TFS 45162 - transient leak.
			
		endif;	
	endwhile;
	
	foreach tmpMess in mess do		
		if tmpMess[2:5] = "Error" or tmpMess[1:5] = "Error" then			
			app.raiseMultiReasonExcOrWarning( errorCodes, tmpMess, false, null,  null );	
		else
			app.raiseMultiReasonExcOrWarning( errorCodes, tmpMess, true, null,  null );	
		endif;
	endforeach;
	
epilog
	delete iter;
	delete gateColl;
	delete mess;
	delete errorCodes;	
	
end;
</source>
        <Parameter name="_gtes" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdateVvrStevedore" id="c5125cef-5d44-4ec7-b572-b8cfb7b3378a">
        <source>validateUpdateVvrStevedore(_stevedore : CM_Stevedore);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars

begin
	if _stevedore = null  then
		app.raiseCMException1(ERR_FIELD_STEVEDORE,'' , 'Stevedore', null);
	endif;
epilog

end;</source>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
    </JadeMethod>
</Class>
