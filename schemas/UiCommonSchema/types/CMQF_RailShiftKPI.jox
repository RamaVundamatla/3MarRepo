<Class name="CMQF_RailShiftKPI">
    <JadeMethod name="setFromAgent" id="fccfe82e-95cd-4835-bdea-d80212befdd4">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Nov 2009	cnwndl1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	iter : Iterator;
	terminal : CM_Terminal;
begin
	if _agent.state = _agent.STATE_TEMPLATE_SAVE or _agent.state = _agent.STATE_TEMPLATE_EDIT then
		self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ProcessDate), self.baseDateTplType, self.baseDateTplFactor, ETRow_ProcessDate);
	else	
		self.processDate := _agent.getValueByNameForDateIfVisible(ETRow_ProcessDate);
	endif;
		
	if _agent.isKindOf(CMUI_ReportAgentStd) and _agent.CMUI_ReportAgentStd.myLstTblTerminals &lt;&gt; null then
		iter := _agent.CMUI_ReportAgentStd.myLstTblTerminals.allSelectedObjects.createIterator;
		while iter.next( terminal ) do
			if not self.allTerminals.includes(terminal) then
				self.allTerminals.add(terminal);
			endif;
		endwhile;
	endif; 
epilog
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
