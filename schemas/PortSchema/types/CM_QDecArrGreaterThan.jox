    <JadeMethod name="doMatch" id="d65ed425-7dd9-4e14-8262-e2bef0ef42b3">
        <source>doMatch(_value: DecimalArray): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	decimalVal : Decimal[23,4];
begin
	foreach decimalVal in _value do
		if decimalVal &gt; self.searchValue then
			return true;
		endif;
	endforeach;
	return false;

epilog

end;</source>
