    <JadeMethod name="txtCargoID_doAlignCtrls" id="2d7436a5-1a2c-434b-aac2-17a284b204b8">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoID_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
// -----------------------------------------------------------------------------
// Created:		01 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	tmpWidth : Integer;

begin
	tmpWidth := self.defaultControlWidth - self.txtCargoID.height.Integer - 3;

	self.txtCargoIDvalue.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, tmpWidth, self.txtCargoID.height);
	
	self.btnCargoIDsearch.move(self.txtCargoID.width - self.txtCargoID.height, 0, self.txtCargoID.height, self.txtCargoID.height);

	self.lstCargoIDvalues.visible := false;
	self.txtCargoIDvalue.visible := true;
	
	self.txtCargoIDvalue.case := TextBox.Case_Upper;
	
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoID_doTabOrder" id="295e61ec-094a-44e1-bea9-45af4628a1c6">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>txtCargoID_doTabOrder(_startTab: Integer):Integer protected;
// -----------------------------------------------------------------------------
// Created:		01 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	tabOrder	: Integer;
	
begin
	tabOrder 						:= _startTab + 1;
	self.txtCargoIDvalue.tabIndex 	:= tabOrder;
	tabOrder 						:= tabOrder + 1;
	self.lstCargoIDvalues.tabIndex 	:= tabOrder;
	tabOrder 						:= tabOrder + 1;
	self.btnCargoIDsearch.tabIndex 	:= tabOrder;
	
	return tabOrder;
	
epilog

end;</source>
