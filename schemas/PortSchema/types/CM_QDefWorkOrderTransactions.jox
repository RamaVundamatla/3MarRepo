	qProp.set('Receive Cargo Booking Reference', CM_WOTransaction::getRecieveBookingRef.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
