    <JadeMethod name="doPlaceOnHold" id="cc451053-4145-4cde-89cc-a3b171b739af">
        <updating/>
        <source>doPlaceOnHold() : Boolean protected, updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

	errorStr		: String;

begin

	if self.aIsAbleToPutOnHold then
		if not app.msgBox('Do you wish to place the current queue entry on hold?', 'Recover',  MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.placeOnHold(self.aState, errorStr, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else	
			self.updateFromState();
			return true;
		endif;
		break;
	endwhile;
		
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPreferences" id="6786ac06-6123-4d81-9f36-fd6760ba18cf">
        <updating/>
        <source>doPreferences() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Displays the preferences form, and updates the main application form
//				accordingly when the preferences form is closed.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	prefsFormObj	: RadioTelemetry_PrefsForm;
	
begin
	create prefsFormObj;
	
	if prefsFormObj.showModal() = self.MB_MODAL_UPDATE then
		self.doApplyScreenColors();
		self.tableOptionsDetailsPopulate();
	endif;
end;</source>
