        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="697fd1da-9a02-40a6-98f5-08489df8cd4c">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theReturn : Integer;
begin
	if self.myQueryAgent.allKPITerminalAreas.isEmpty then
		app.msgBox("Nothing to save!", "Update Issue", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
		app.myTrxCA.trxCreateKPITerminalArea(self.myQueryAgent, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			app.msgBox("All saved!", "Update Complete", MsgBox_Information_Icon);
			self.doComboTABuild();
			break;
		else
			theReturn := app.showErrorWarningDialog("Space Utilisation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnHazSetClick" id="f9e19869-4f50-400d-9728-5ca8449cac61">
        <updating/>
        <source>doBtnHazSetClick() updating;

vars
	theReturn : Integer;
	tis : CM_TISet;
begin
	create tis transient;
	self.tblHaz.allSelectedObjects.copy(tis);
	if tis.isEmpty() then
		app.msgBox("Please select some hazardous cargo to update.","Hazardous Segregation Set Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
			app.myTrxUA.trxUpdateHazSegTISet(tis,app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Haz Seg Cargo Set Location", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
epilog
	delete tis;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doComboTABuild" id="9add3f78-5f76-4174-938a-1cab64b815b1">
        <source>doComboTABuild();
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/09/2025	navkc1 JIRA 35623 MSL | Terminal Utilization RoRo - Form
// ---------------------------------------------------------------------------
vars
	tmpTAs : CM_TerminalAreaMasterSet;
	tmpTA : CM_TerminalAreaMaster;
	tmpKPI : CM_KPI;
	iter : Iterator;
	code : String;
begin
	create tmpTAs transient;
	
	iter := self.myTerminal.allKPIbyTypeCodeTS.createIterator();
	tmpKPI := self.myTerminal.allKPIbyTypeCodeTS.getAtKeyGeq(KPI_Type_TerminalArea,null,null);
	if tmpKPI &lt;&gt; null then
		iter.startAtObject(tmpKPI);
		code := tmpKPI.code; //08/09/2025	navkc1 JIRA 35623 
		
		//08/09/2025	navkc1 JIRA 35623 
		if tmpKPI.isKPITerminalArea() then
			if tmpKPI.CM_KPITerminalArea.isRoRoLane() then
				code := tmpKPI.CM_KPITerminalArea.terminalAreaCode;
			endif;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreaMastersById[code];
		if tmpTA &lt;&gt; null then
			tmpTAs.addNoDuplicates(tmpTA,false);
		endif;
	endif;
	
	while iter.next(tmpKPI) do 
		if tmpKPI.type &lt;&gt; KPI_Type_TerminalArea then
			break;
		endif;
		code := tmpKPI.code; //08/09/2025	navkc1 JIRA 35623 
		
		//08/09/2025	navkc1 JIRA 35623 
		if tmpKPI.isKPITerminalArea() then
			if tmpKPI.CM_KPITerminalArea.isRoRoLane() then
				code := tmpKPI.CM_KPITerminalArea.terminalAreaCode;
			endif;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreaMastersById[code];
		if tmpTA &lt;&gt; null then
			tmpTAs.addNoDuplicates(tmpTA,false);
		endif;

	endwhile;
	
	self.lstTermAreaExpt.rows := 0;
	
	self.cmbKPITA.clear;
	self.cmbTA.clear;
	self.cmbTA.sorted := true;
	foreach tmpTA in tmpTAs do
		self.cmbTA.addItemObject(tmpTA.getID &amp; " - " &amp; tmpTA.typeString,tmpTA);
		self.lstTermAreaExpt.addItemObject(tmpTA.getID &amp; " - " &amp; tmpTA.typeString,tmpTA);
	endforeach;
	
	self.lstTermAreaExpt.sortColumn[1] := 2;
epilog
	delete tmpTAs;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTAKPIBuild" id="10195040-4b0f-403f-881d-a3ea169039cb">
        <source>doComboTAKPIBuild(_tam : CM_TerminalAreaMaster);
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//	08/09/2025	navkc1 JIRA 35623 MSL | Terminal Utilization RoRo - Form
// ---------------------------------------------------------------------------
vars
	tmpKPITA : CM_KPITerminalArea;
	tmpKPI : CM_KPI;
	iter : Iterator;
	code,
	tmpCode : String;
begin
	self.cmbKPITA.clear;
	self.cmbKPITA.sorted := true;
	tmpCode := 	_tam.id;
	
	iter := self.myTerminal.allKPIbyTypeCodeTS.createIterator();
	tmpKPI := self.myTerminal.allKPIbyTypeCodeTS.getAtKeyGeq(KPI_Type_TerminalArea,tmpCode,null);
	iter.startAtObject(tmpKPI);
//	self.cmbKPITA.addItemObject(tmpKPI.code &amp; " - " &amp; tmpKPI.dateTime.String,tmpKPI);
	
	while iter.next(tmpKPI) do 
		
		if tmpKPI.type &lt;&gt; KPI_Type_TerminalArea then
		//or tmpKPI.code &lt;&gt; tmpCode then //08/09/2025	navkc1 JIRA 35623 
			break;
		endif;
		
		tmpKPITA := tmpKPI.CM_KPITerminalArea; //08/09/2025	navkc1 JIRA 35623 
		
		// RORO's code includes lane number. Use Terminal Area code instead //08/09/2025	navkc1 JIRA 35623 
		if tmpKPITA.isRoRoLane() then
			if tmpKPITA.terminalAreaCode &lt;&gt; tmpCode then
				break;
			endif;
		elseif tmpKPITA.code &lt;&gt; tmpCode then
			break;
		endif;
		
		// RORO to display lane number too //08/09/2025	navkc1 JIRA 35623 
		if tmpKPITA.isRoRoLane() then
			code := tmpKPITA.code;
		else
			code := tmpKPITA.terminalAreaCode;
		endif;
		
		self.cmbKPITA.addItemObject(code &amp; " - " &amp; tmpKPITA.dateTime.String
										&amp; " " &amp; tmpKPITA.getParamString(true),tmpKPITA);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="52121e59-5e20-4950-a49d-2b7c3b69e63d">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
	tmpKPI : CM_KPI;
	table : CM_DataTable;
begin
	self.myQueryAgent.init();
	
	tmpKPI := self.cmbKPITA.listObject.CM_KPI;
	if tmpKPI = null then
		app.msgBox("Nothing to delete","Delete Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if app.msgBox("Are you sure that you want to delete '" &amp; self.cmbKPITA.text &amp; "'?", "Delete Confirmation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
	app.myTrxDA.trxDeleteKPITerminalArea(tmpKPI.CM_KPITerminalArea, app.myPassport);
	if app.myPassport.trxCompletedOK then
		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();
		global.beep;

		self.doComboTABuild();
		self.tblData.rows := self.tblData.fixedRows;
		break;
	else
		theReturn := app.showErrorWarningDialog("Space Utilisation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
		   theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return;
	endif;
	break;
endwhile;


end;</source>
    </JadeMethod>
    <JadeMethod name="doExport" id="7c62f4ff-7507-4b81-a4bb-5594aaa308a7">
        <source>doExport();
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ts	: TimeStamp;
begin
//	self.showExportFrame();
	ts := app.actualTimeServer;

	if self.fldMain.topSheet = self.shtHaz then
		self.tblHaz.outputAsCSV("JMTHazardDtls" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	elseif self.fldMain.topSheet = self.shtYA then
		self.tblYA.outputAsCSV("JMTAlloc" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	elseif self.fldMain.topSheet = self.shtSpace then
		self.tblData.outputAsCSV("JMTSpaceUtil" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	elseif self.fldMain.topSheet = self.shtSpaceDtl then
		self.tblSpaceDtl.outputAsCSV("JMTSpaceDtl" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportExport" id="3db17e09-5588-4674-aba7-2e323a0feb51">
        <source>doExportExport();
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	fileXML : CMDFileOpen;
	theXMLFile : File;
	fileName : String;
	aKPI : CM_KPI;
	tam : CM_TerminalAreaMaster;
	anObj : Object;
	kpiFrom, kpiTo : TimeStamp;
	tmpTime : Time;
	iter : Iterator;
	tmpCode : String;
	fileEx:        FileException;
	ts,
	fromLocal,
	toLocal: TimeStamp;
begin
	on FileException do self.fileExceptionHandler(fileEx);

	app.mousePointer := Window.MousePointer_HourGlass;
		
	if self.lstTermAreaExpt.allSelectedObjects.isEmpty then
		app.msgBox("Nothing to export!", "Export Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// set up params
	fromLocal.setDate(self.dteFrom.getDate());
	fromLocal.setTime(null);
	toLocal.setDate(self.dteTo.getDate());
	tmpTime.setTime(23,59,59,999);
	toLocal.setTime(tmpTime);
	kpiFrom := self.localToSystemTime(fromLocal);	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
	kpiTo := self.localToSystemTime(toLocal);
	
	ts := app.actualTimeServer();	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	// setup file
	create fileXML;
	fileXML.filter := "Comma Seperated (*.csv)|*.csv";
	fileXML.fileName := "JMTSpaceUtil" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv";
	if fileXML.open = 0 then
		create theXMLFile;		
		theXMLFile.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;
//		theXMLFile.purge();
		fileName := fileXML.fileName;
		// use these if not compressed		
		theXMLFile.maxRecordSize := 40000;
		
		iter := self.myTerminal.allKPIbyTypeCodeTS.createIterator();
		
		// for each terminal area 
		foreach anObj in self.lstTermAreaExpt.allSelectedObjects discreteLock do
			tam := anObj.CM_TerminalAreaMaster;
			tmpCode := 	tam.id;
			
			// export the KPI stuff
			aKPI := self.myTerminal.allKPIbyTypeCodeTS.getAtKeyGeq(KPI_Type_TerminalArea,tmpCode,kpiFrom);
			iter.reset();
			iter.startAtObject(aKPI);
			while iter.next(aKPI) do 
				if aKPI.type &lt;&gt; KPI_Type_TerminalArea 
				or aKPI.code &lt;&gt; tmpCode 
				or aKPI.dateTime &gt; kpiTo then
					break;
				endif;
				theXMLFile.writeString(aKPI.exportCSV());
			endwhile;
			
		endforeach;
	
		app.msgBox("Export finished to file" &amp; Cr &amp; "'" &amp;  fileName &amp; "'","Export",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	
	delete iter;
	if theXMLFile &lt;&gt; null then
		theXMLFile.close;
	endif;

	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doGetInfoTableData" id="a5bf0b46-e316-4b1f-a80b-5de0ec0b0d2a">
        <updating/>
        <source>doGetInfoTableData(_dataTable: CM_DataTable input; _infoTable : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theVjob : CM_VoyageJob;
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	_infoTable.rows := 0;

	if _dataTable.row &lt;= _dataTable.fixedRows then
		return;
	endif;

	theObject := _dataTable.accessRow(_dataTable.row).itemObject;
	if (not global.isValidObject(theObject)) then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
		if self.myCurrentTrackedItem &lt;&gt; null then
			//self.btnLocate.enabled := self.myCurrentTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController);
		endif;
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theObject := theObject.CM_WorkListEntry.myTrackedItem;
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
	
	if useTableInfo then

		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else

			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, _infoTable, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_infoTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doListBoxCargoBuild" id="437dfbb6-a679-41c2-89a2-912417e16ef7">
        <updating/>
        <source>doListBoxCargoBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
// 02 MAR 2015  cnwma1 PAR #33532  Space Utilisation functionality for Block Stacks
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	bolType : CM_CargoBOLType;
	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	anArray : ObjectArray;
begin
	self.lstCargoTypes.rows := 0;
	self.lstCargoTypes.zOrder(1);
	self.lstCargoTypes.sortColumn[1] := 2; 					// 02 MAR 2015 cnwma1 PAR#33532   
	
//	foreach aCargoType in app.myRoot.allCargoTypesById do
	foreach bolType in self.myTerminal.allCargoBOLTypes do	//24 July 2014	NDL	Par 34335
		if not bolType.isCargoType then
			continue;
		endif;
		aCargoType := bolType.CM_CargoType;
		
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		self.lstCargoTypes.addItemObject(aCargoType.abbreviation &amp; " - " &amp; aCargoType.description,aCargoType);
		
		// #################
		// DEFAULT TO CONTAINER
		if aCargoType.id = TI_CargoType_Container then
			self.lstCargoTypes.rowChecked(lstCargoTypes.rows);

			if not self.lstCargoTypes.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
				self.lstCargoTypes.allSelectedObjects.add(aCargoType);
			endif;


		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxContentsBuild" id="efbf7f5f-ec53-4cc2-952c-aab74a297004">
        <updating/>
        <source>doListBoxContentsBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aOperator : CM_Operator;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	opDict : CM_OperatorByCodeDict;
	cs : CM_ContentsStatus;
begin
	passport := app.myPassport;
	self.lstContents.zOrder(1);
	self.lstContents.rows := 0;
	
	app.cmsBeginLoad(ls);
	foreach cs in app.myRoot.allContentsStatuses do
		if cs.code = TI_CONTENTS_STATUS_NULL
		or cs.code = TI_CONTENTS_STATUS_MASK then
			continue;
		endif;
		
		idx := self.lstContents.addItemObject(cs.description,cs);
	endforeach;
	app.cmsEndLoad(ls);
	
	self.lstContents.userInputEnabled := true;
epilog
	endLoad;

end;</source>
    </JadeMethod>
