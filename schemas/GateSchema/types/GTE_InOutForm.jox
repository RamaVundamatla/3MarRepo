    <JadeMethod name="getCargoBOLType" id="7f178d98-8258-4cfb-bd45-bcb8d25ae11d">
        <source>getCargoBOLType(pSheet : GTE_Sheet): CM_CargoBOLType;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	cargoBOLType	: CM_CargoBOLType;
begin

	if pSheet = null then
		return null;
	endif;
	
	cargoBOLType := pSheet.getCargoType();

	if cargoBOLType &lt;&gt; null then
		return cargoBOLType;
	else
		return pSheet.getDocketType();
	endif;

end;</source>
