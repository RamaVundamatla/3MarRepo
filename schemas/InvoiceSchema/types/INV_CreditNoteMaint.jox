    <JadeMethod name="tblInvoiceLink_dblClick" id="0fd4252a-3d5a-4d00-8c49-4d2be617bb26">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInvoiceLink_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
