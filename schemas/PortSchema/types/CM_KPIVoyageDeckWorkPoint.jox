    <JadeMethod name="getDeckId" id="d947ad51-0b73-42a1-b54a-f65c167125a2">
        <source>getDeckId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars

begin
	if self.myDeckVoyage &lt;&gt; null then
		return self.myDeckVoyage.code;
	endif;
epilog

end;</source>
