<Class name="CM_VesselUnavailability" id="2459c69b-4e83-42a9-b0be-0fdc2020e758">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="vessel"/>
    <PrimAttribute name="comments" id="c87b3e5f-0a4b-458d-b4ab-d60970f6f139">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateFrom" id="447c5f94-ffa1-4a74-b143-4b70a147a609">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateTo" id="03888e3f-c923-44f6-bfe6-22537f628083">
