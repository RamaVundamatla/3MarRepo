        <source>comboBoxStkOrdFulfilledStatus(_cmb : CMUI_ComboBox input; _orderStatus : Integer);

vars

begin
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.itemData[_cmb.addItem(OrderStatus_Unfulfilled_Descr)] := OrderStatus_Unfulfilled;
	_cmb.itemData[_cmb.addItem(OrderStatus_Partial_Descr)] := OrderStatus_Partial;
	_cmb.itemData[_cmb.addItem(OrderStatus_Fulfilled_Descr)] := OrderStatus_Fulfilled;
	
	if _orderStatus &lt;&gt; null then
		_cmb.text := app.orderStatusEnumToString(_orderStatus);//null will return unfulfilled
	endif;
	
end;</source>
