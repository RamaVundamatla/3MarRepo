    <JadeMethod name="getDisplayStringForAttribute" id="ca5d9056-ef24-4ab8-86e1-3b31a0e50bbf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Log) then	// 10/09/2009 cnwar2 CCMS-1107/#20627
				// Log inspection/fumigation for C3 not associated with Todo Task
				return null;
			else
				return self.getCompletedTaskString;
			endif;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="07555c60-d3c9-4c40-b0b4-08a0030c7255">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	31 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lDetail : String;

begin
	lDetail := inheritMethod();
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Log) then	// 10/09/2009 cnwar2 CCMS-1107/#20627
		// Log inspection/fumigation for C3 not associated with Todo Task
	else
		lDetail := lDetail &amp; self.getCompletedTaskString;
	endif;
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="14933dc9-c82d-4d0a-8510-4347a86f3e6c">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	trans : CM_TITransaction;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.setFumigationDetails();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
