<Class name="NR_CountTransients" id="4d3887c0-8acb-4e5d-acad-b0adda28e962">
    <superclass name="NR_NodeRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="nodereq"/>
    <CompAttribute name="allClassNamesFound" id="2021d2b6-f209-491f-84d5-17596a16cd7e">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <CompAttribute name="allClassNamesToCheck" id="5d03004a-818a-4f00-a1e9-52948c356813">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ImplicitInverseRef name="allClassesToCheck" id="5aa549dd-e669-4beb-9c39-850c3f688dac">
        <memberTypeInverse/>
        <type name="ClassColl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="includeSubSchemas" id="6df2e8c6-bc84-44d5-abe3-cb3e43f47740">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxNum" id="8e7dc3fd-0489-43da-a37d-000aff7d3acc">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="schemaName" id="c6d1f4d9-5882-4778-9e24-246ae9b23887">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="actionOnTargetNode" id="11903b0a-1441-4bdc-97dc-6d96d9f8292c">
        <updating/>
        <source>actionOnTargetNode() updating;

vars

begin

	self.beginNotification(self, NR_NodeRequestCancelEvent, Response_Cancel, 0);
	self.beginNotification(self, self.NR_NodeRequest_CntTransients, Response_Continuous, 0);

	on Exception do self.exHandler(exception);
	beginTransaction;
	self.logEntry('Transient Classes with &gt;= ' &amp; self.maxNum.String &amp; ' instances on ' &amp; node.name &amp; '/' &amp; app.name &amp; ' (' &amp; app.niceName &amp; ')');
	self.logEntry('as at ' &amp; app.actualTimeServer.String);
	commitTransaction;

	self.checkTransientsForClass(1);

/*
this is now done as part of a user notification as we need to
do it on the actual process as JADE 6 does not allow class.allNodeTransientInstances

	beginTransaction;
	self.isBeingActioned	:= false;
	self.isRequestComplete 	:= true;
	self.logEntry('**** Request processing complete. ****');
	commitTransaction;

epilog
	self.causeEvent(NR_NodeRequestCompleteEvent, true, self);
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="checkTransientsForClass" id="fc660823-1404-4f58-865f-2a0f7c77a739">
        <updating/>
        <source>checkTransientsForClass(_classIdx : Integer) updating, protected;

vars
	tmpClass	: Class;
	objs		: ObjectArray;
	idx,
	numObjs,
	tmpMaxNum	: Integer;
	onlySome	: Boolean;
	tmpClassName	: String;
	
begin


	idx := _classIdx;

	if idx &lt;= 0 or idx &gt; self.allClassesToCheck.size then
		self.completeOnTargetNode();
		return;
	endif;

	tmpClass := self.allClassesToCheck[idx];
	if tmpClass = null then
		self.completeOnTargetNode();
		return;
	endif;

	tmpMaxNum := self.maxNum;
	onlySome  := (self.allClassNamesToCheck.size &gt; 0);

	create objs transient;

	tmpClassName := tmpClass.name;

	tmpClass.allProcessTransientInstances(objs, tmpMaxNum, false);
	numObjs := objs.size;
	if ((not onlySome) and numObjs &gt;= tmpMaxNum) or
	   (onlySome and numObjs &gt; 0) then
		beginTransaction;
		if onlySome then
			self.logEntry('CLASS &gt;&gt; ' &amp; tmpClassName &amp; '    (' &amp; numObjs.String &amp; ')');
		else
			self.logEntry('CLASS &gt;&gt; ' &amp; tmpClassName);
		endif;
		self.allClassNamesFound.add(tmpClassName);
		commitTransaction;
	endif;

	idx := idx + 1;
	if (idx mod 10) = 0 then
		self.checkForCancelNote();
	endif;

	self.causeEvent(self.NR_NodeRequest_CntTransients, true, idx);

epilog
	delete objs;
end;</source>
        <access>protected</access>
        <Parameter name="_classIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkTransientsOLD" id="26cea715-6c97-4920-88e1-8bdea7718c0f">
        <updating/>
        <source>checkTransientsOLD() updating, protected;
// old JADE 5 version where we could access class.allNodeTransientInstances.
vars
	tmpClassColl	: ClassColl;
	tmpClass	: Class;
	objs		: ObjectArray;
	iter		: Iterator;
	cnt,
	numObjs,
	tmpMaxNum	: Integer;
	onlySome	: Boolean;
	tmpClassName	: String;
	
begin

	create tmpClassColl transient;
	self.getClasses(tmpClassColl);
	tmpMaxNum := self.maxNum;

	create objs transient;

	self.logEntry('Transient Classes with &gt;= ' &amp; tmpMaxNum.String &amp; ' instances on ' &amp; node.name);
	self.logEntry('as at ' &amp; app.actualTimeServer.String);
	
	onlySome := (self.allClassNamesToCheck.size &gt; 0);
	if onlySome then
		tmpMaxNum := 0;
	endif;
	
	iter := tmpClassColl.createIterator;	
	while iter.next(tmpClass) do
		tmpClassName := tmpClass.name;

		if onlySome and
		   (not self.allClassNamesToCheck.includes(tmpClassName)) then
			continue;
		endif;

		objs.clear;
		tmpClass.allNodeTransientInstances(objs, tmpMaxNum, false);
		numObjs := objs.size;
		if ((not onlySome) and numObjs &gt;= tmpMaxNum) or
		   (onlySome and numObjs &gt; 0) then
			beginTransaction;
			if onlySome then
				self.logEntry('CLASS &gt;&gt; ' &amp; tmpClassName &amp; '    (' &amp; numObjs.String &amp; ')');
			else
				self.logEntry('CLASS &gt;&gt; ' &amp; tmpClassName);
			endif;
			self.allClassNamesFound.add(tmpClassName);
			commitTransaction;
		endif;
		cnt := cnt + 1;
		if (cnt mod 10) = 0 then
			self.checkForCancelNote();
		endif;
	endwhile;

	self.logEntry('Transient Classes check for ' &amp; node.name &amp; ' complete');

epilog
	delete tmpClassColl;
	delete objs;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="completeOnTargetNode" id="673274b4-c9b3-498f-a385-e2fdec9743c7">
        <updating/>
        <source>completeOnTargetNode() updating, protected;

vars

begin

	beginTransaction;
	self.logEntry('Transient Classes check for ' &amp; node.name &amp; ' complete');
	self.isBeingActioned	:= false;
	self.isRequestComplete 	:= true;
	self.logEntry('**** Request processing complete. ****');
	commitTransaction;

epilog
	self.causeEvent(NR_NodeRequestCompleteEvent, true, self);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getClasses" id="deab9090-7977-47fd-bd78-f06bda82e49d">
        <updating/>
        <source>getClasses(_classColl : ClassColl input) updating, protected;

vars
	tmpClassColl	: ClassColl;
	tmpClass	: Class;
	theSchema,
	tmpSchema	: Schema;
	tmpSubSchemas	: SchemaColl;
	
begin

	_classColl.clear;
	create tmpClassColl transient;

	theSchema := rootSchema.getSchema(self.schemaName);
	self.logEntry('Getting classes for ' &amp; theSchema.name);
	theSchema.allClasses.copy(tmpClassColl);
	
	if self.includeSubSchemas then
		create tmpSubSchemas transient;
		theSchema.allSubschemas(tmpSubSchemas);
		foreach tmpSchema in tmpSubSchemas do
			self.logEntry('Getting classes for ' &amp; tmpSchema.name);
			foreach tmpClass in tmpSchema.allClasses do
				if (not tmpClassColl.includes(tmpClass)) then
					tmpClassColl.add(tmpClass);
				endif;
			endforeach;
		endforeach;
	else
		self.logEntry('Subschemas ignored');
	endif;
	
	if self.allClassNamesToCheck.size &gt; 0 then
		foreach tmpClass in tmpClassColl do
			if self.allClassNamesToCheck.includes(tmpClass.name) then
				_classColl.add(tmpClass);
			endif;
		endforeach;
	else
		tmpClassColl.copy(_classColl);
	endif;
epilog
	delete tmpSubSchemas;
	delete tmpClassColl;
end;</source>
        <access>protected</access>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runAsSeperateProcess" id="86f010bc-7ff7-4fa3-9a00-d1bb67cedacc">
        <source>runAsSeperateProcess(): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendRequest" id="e12f7ad1-9dcf-45cb-b4f8-ac66c02cc3bf">
        <updating/>
        <source>sendRequest(_schemaName : String; _includeSubSchemas : Boolean; 
			_maxNum : Integer; _classesToCheck : StringArray) updating;

vars

begin

	self.allLogEntries.clear();
	self.schemaName := _schemaName;
	self.includeSubSchemas := _includeSubSchemas;
	self.maxNum := _maxNum;
	
	if _classesToCheck = null then
		self.allClassNamesToCheck.clear;
	else
		_classesToCheck.copy(self.allClassNamesToCheck);
	endif;
	
	self.getClasses(self.allClassesToCheck);
	
	self.allClassNamesFound.clear;

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_includeSubSchemas" type="Boolean"/>
        <Parameter name="_maxNum" type="Integer"/>
        <Parameter name="_classesToCheck" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="5f4181b1-62a8-47cc-88f5-078cb50e266d">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if eventType = NR_NodeRequest_CntTransients then
		self.checkTransientsForClass(userInfo.Integer);
		return;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
