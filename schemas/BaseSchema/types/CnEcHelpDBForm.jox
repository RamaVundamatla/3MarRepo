    <JadeMethod name="outputBanner" id="474ec6c2-5301-485c-bde2-27afb637e6fd">
        <source>outputBanner() : String;

vars
	outputLine	: String;
	todaysDate	: Date;
begin
	outputLine := "Windows Help Information" &amp; CrLf;
	outputLine := outputLine &amp; CrLf &amp; "Forms information extracted " &amp; todaysDate.display;
	outputLine := outputLine &amp; CrLf &amp; "Copyright Aoraki Corporation " &amp; todaysDate.format("yyy").String &amp; CrLf;

	if optListOnly.value then
		outputLine := outputLine &amp; CrLf &amp; "! Help Keyword does not match form name";
		outputLine := outputLine &amp; CrLf &amp; "? Help Keyword is undefined";
		outputLine := outputLine &amp; CrLf &amp; "1 in New column is a new form";
		outputLine := outputLine &amp; CrLf &amp; "Form" &amp; Tab &amp; "Caption" &amp; Tab &amp; "Help Keyword" &amp; Tab &amp; "Attn" &amp; Tab &amp; "New" &amp; Tab &amp; "Last Modified" &amp; Tab &amp; "Created";
		
	elseif optStatsOnly.value then
		outputLine := outputLine &amp; CrLf &amp; "Forms with name followed by an asterisk (*) are NOT new, and will have adjusted values." &amp; CrLf;
		outputLine := outputLine &amp; CrLf &amp; "Form" &amp; Tab &amp; "Caption" &amp; Tab &amp; "Help Keyword" &amp; Tab &amp; "Controls" &amp; Tab &amp; "Buttons" &amp; Tab &amp; "Sheets" &amp; Tab &amp; "Rating" &amp; Tab &amp; "Adjusted";
		
	elseif optAllDetails.value then
		outputLine := outputLine &amp; CrLf &amp; "Online help skeletons for forms";
		
	endif;
	
	return outputLine;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputForms" id="1f763a93-46ed-47b3-ba40-80340108ce85">
        <source>outputForms(file : File io);

vars
	outputLine	: String;
	cnHelp		: CnEcHelpFormDetail;
	object		: Object;
	listPointer	: Integer;
	listbox		: ListBox;
	objectSet	: ObjectSet;
begin
	outputLine := self.outputBanner();

	if file = null then
		write(outputLine);
	else
		file.writeLine(outputLine);
	endif;

	if lstForms_change.listIndex &gt; 0 then
		listbox := lstForms_change;
		objectSet := aAllChangedForms;
	else
		listbox := lstForms_included;
		objectSet := aAllIncludedForms;
	endif;

	if optAllForms.value then
		foreach object in objectSet do
			outputLine := aMyHelp.getHelpForm(object.Form).getFormDetail(optListOnly.value, optStatsOnly.value, optAllDetails.value);
			
			if file = null then
				write(outputLine);
			else
				file.writeLine(outputLine);
			endif;
		endforeach;
	else
		foreach listPointer in 1 to listbox.listCount do
			if listbox.itemSelected[listPointer] then
				object		:= listbox.itemObject[listPointer];
				outputLine	:= self.aMyHelp.getHelpForm(object.Form).getFormDetail(optListOnly.value, optStatsOnly.value, optAllDetails.value);
				
				if file = null then
					write(outputLine);
				else
					file.writeLine(outputLine);
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateAllDetails" id="e7e9ad57-afd8-4fd6-8f6a-402932178af3">
        <source>populateAllDetails();

vars
	helpForm	: CnEcHelpFormDetail;
	object		: Object;
	form		: Form;
	cnHelpTime	: CnEcHelpTime;
	comboStr	: String;
	index		: Integer;
	f1, f2		: String;
begin
	// create list of projects

	comboStr := "";
	foreach object in aMyHelp.allTimes do
		cnHelpTime := object.CnEcHelpTime;
		comboStr := comboStr &amp; table.comboList &amp; cnHelpTime.project &amp; Tab;
	endforeach;
	if comboStr.length &gt; 0 then
		comboStr := comboStr[ 1 : comboStr.length - 1 ];	// remove last Tab
	endif;

	// set up table headings

	f1 := aMyHelp.flag1Text;
	if f1.length = 0 then
		f1 := "Flag 1";
	endif;
	f2 := aMyHelp.flag2Text;
	if f2.length = 0 then
		f2 := "Flag 2";
	endif;

	txtFlag1.text := f1;
	txtFlag1_1.text := f2;

	table.clear;
	table.rows := 1;
	table.text := "Form" &amp; Tab &amp; "Keyword" &amp; Tab &amp; "ContextID" &amp; Tab &amp; "Help File" &amp; Tab &amp; "Project" &amp; Tab &amp; "Time" &amp; Tab &amp; f1 &amp; Tab &amp; f2;

	// populate table

	foreach object in aAllIncludedForms do	// cnEcHelp.helpForms do
		form := object.Form;
		helpForm := aMyHelp.getHelpForm( form );

		if helpForm.flag1 then
			f1 := "1";
		else
			f1 := "";
		endif;
		if helpForm.flag2 then
			f2 := "1";
		else
			f2 := "";
		endif;
		table.addItem( helpForm.myForm.name &amp; Tab &amp; helpForm.helpTopic &amp; Tab &amp; helpForm.helpContextID.String &amp; Tab &amp; helpForm.helpFile &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; f1 &amp; Tab &amp; f2 );

		table.accessMode := Table.AccessMode_Cell;
		table.row := table.rows;
		table.column := 1;
		table.itemObject := helpForm;
		table.column := 2;
		table.inputType := Table.InputType_TextBox;
		table.column := 3;
		table.inputType := Table.InputType_TextBox;
		table.column := 4;
		table.inputType := Table.InputType_TextBox;
		table.column := 5;
		table.inputType := Table.InputType_ComboBox;
		table.comboList := comboStr;	// populates combo with list of projects
		table.column := 6;
		table.inputType := Table.InputType_TextBox;
		table.column := 7;
		table.inputType := Table.InputType_CheckBox;
		table.column := 8;
		table.inputType := Table.InputType_CheckBox;
/*
	if cnEcHelpFormDetail.helpTopic = "" then
		tbHelpKeyword.text := form.name;
	else
		tbHelpKeyword.text := cnEcHelpFormDetail.helpTopic;
	endif;

		tbContextID.text := cnEcHelpFormDetail.helpContextID.String;
		tbDateModified.text := cnEcHelp.getFormTimeStamp( form ).String;
		tbHelpFile.text := cnEcHelpFormDetail.helpFile;
*/
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCnEcHelp" id="ece4603c-4c92-42f9-8bc8-ed61b99652e8">
        <updating/>
        <source>populateCnEcHelp() updating;

vars
	cnHelp		: CnEcHelp;
	myIndex		: Integer;

begin
	if CnEcHelp.instances.size = 0 then
//		write("creating CnEcHelp");
		self.createCnEcHelp(cnHelp);
		app.msgBox( "As no lists exist, a new list will be created.", "Create List", MsgBox_OK_Only );
	endif;

	lblOptions_list.clear;

	foreach cnHelp in CnEcHelp.instances do
		myIndex := lblOptions_list.addItem(cnHelp.name);
//		write(cnHelp.name);
		lblOptions_list.itemObject[myIndex] := cnHelp;
	endforeach;

	if aMyHelp = null then
		lblOptions_list.listIndex := 1;
		aMyHelp := lblOptions_list.listObject.CnEcHelp;
	else
		myIndex := lblOptions_list.findObject(aMyHelp);
		lblOptions_list.listIndex := myIndex;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateHelpLists" id="ab0a3b52-efc4-4572-ba50-0e6fd8d8e1f3">
        <source>populateHelpLists();

begin
	lstForms_included.listCollection(aAllIncludedForms, false, 0);
	lstForms_excluded.listCollection(aAllExcludedForms, false, 0);
	lstForms_new.listCollection(aAllNewForms, false, 0);
	lstForms_change.listCollection(aAllChangedForms, false, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateProjects" id="926abd46-b2bc-47b2-a404-dfb06173e57c">
        <source>populateProjects();

vars
	string		: String;
	projName	: String;
	projTime	: Real;
	projEst		: Real;
	object			: Object;
	cnEcHelpTime	: CnEcHelpTime;
begin
	lstTimes_list.clear;

	txtProjectName.text := "";
	txtProjectEst.text := "";
	txtProjectUsed.text := "";	

	txtTime.text := "";

	if not chkTimeRecording.value then
		sheetProjects.visible := false;
		fraTimeRecord.visible := false;
		return;
	endif;

	fraTimeRecord.visible := true;
	txtTime.enabled := false;	// time entry field

	btnProjectsRemove.enabled := false;
	lstStored_list.enabled := true;

	sheetProjects.visible := true;
	lstStored_list.clear;

	foreach object in aMyHelp.allTimes do
		cnEcHelpTime := object.CnEcHelpTime;

		if cnEcHelpTime = null then
			string := "not defined";
			lstStored_list.addItem(string);
			lstTimes_list.addItem(string);
		else
			string := cnEcHelpTime.displayDetails();//project &amp; Tab &amp; cnEcHelpTime.timeEstimate.String &amp; Tab &amp; cnEcHelpTime.timeUsed.String;
			lstStored_list.itemObject[lstStored_list.addItem(string)]	:= cnEcHelpTime;
			lstTimes_list.itemObject[lstTimes_list.addItem(string)]		:= cnEcHelpTime;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSchemas" id="85cd0693-979f-44b7-adfb-944c7ce5566b">
        <source>populateSchemas();

begin
	lblOptions_schema.listCollection(Schema.instances, false, 0);
	lblOptions_schema.listIndex := lblOptions_schema.findObject(currentSchema);
end;</source>
