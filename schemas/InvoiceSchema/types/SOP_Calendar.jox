    <JadeMethod name="objLoadChildren" id="92b70ef5-bb68-4c5f-9c48-2dcb0c1ab2e6">
        <source>objLoadChildren(_object : Object;  _level: Integer; _at : Integer);
// ---------------------------------------------------------------------------
// Created:     02 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	calendar,
	tmpCalendar		: CM_Calendar;
	calendarYear,
	tmpCalendarYear	: CM_CalendarYear;
	calendarDate  : CM_CalendarDate;
	idx, theLevel : Integer;
	theListBox : ListBox;
	desc : String;
begin

	theListBox:= self.lstData;
	
	if _object.isKindOf(CM_CalendarDate) then
		return; // is date so has no children to load
	elseif _object.isKindOf(CM_CalendarYear) then
		tmpCalendarYear := _object.CM_CalendarYear;
	elseif _object.isKindOf(CM_Calendar) then
		tmpCalendar := _object.CM_Calendar;
	endif;

	if tmpCalendarYear &lt;&gt; null then 
		foreach calendarDate in tmpCalendarYear.allCalendarDates do
			theLevel := 3;
			desc := calendarDate.date.String &amp; ' - ' &amp; calendarDate.description;
			idx := theListBox.newIndex() + 1;
			theListBox.addItemAt(desc, idx);
			theListBox.itemObject[idx] := calendarDate;
			theListBox.itemLevel[idx] := theLevel;
//			theListBox.itemPicture[idx] := self.picDate.picture;  // no picture at mo.
			theListBox.itemExpanded[idx] := true;
		endforeach;	
	elseif tmpCalendar &lt;&gt; null then 
		foreach calendarYear in tmpCalendar.allCalendarYears do
			theLevel := 2;
			desc := calendarYear.year.String;
			idx := theListBox.newIndex() + 1;
			theListBox.addItemAt(desc, idx);
			theListBox.itemObject[idx] := calendarYear;
			theListBox.itemLevel[idx] := theLevel;
			theListBox.itemPicture[idx] := self.picYear.picture;
			
			foreach calendarDate in calendarYear.allCalendarDates do
				theLevel := 3;
				desc := calendarDate.date.String &amp; ' - ' &amp; calendarDate.description;
				idx := theListBox.newIndex() + 1;
				theListBox.addItemAt(desc, idx);
				theListBox.itemObject[idx] := calendarDate;
				theListBox.itemLevel[idx] := theLevel;
//				theListBox.itemPicture[idx] := self.picDate.picture;  // no picture at mo.
				theListBox.itemExpanded[idx] := true;
			endforeach;	
		endforeach;	
	endif;
	
	if theListBox.listIndex &lt; 1 then
		return;
	endif;
	
	theListBox.itemExpanded[1] := true;
//	theListBox.listIndex := 1;
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="objLoadListAt" id="779efa46-326f-4078-a9f8-dc14ca109bfb">
        <source>objLoadListAt(_object : Object;  _level: Integer; _at : Integer);
// ---------------------------------------------------------------------------
// Created:     01 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theCalendar : CM_Calendar;
	theCalendarDate : CM_CalendarDate;
	theCalendarYear : CM_CalendarYear;
	theListBox : CMUI_ListBox;
begin

	theListBox := self.lstData;
	

	if _object.isKindOf(CM_CalendarDate) then
		theCalendarDate := _object.CM_CalendarDate;
		if _at &gt; 0 then
			theListBox.addItemAt(theCalendarDate.date.String &amp; ' - ' &amp; theCalendarDate.description,_at);
		else
			theListBox.addItem(theCalendarDate.date.String &amp; ' - ' &amp; theCalendarDate.description);
		endif;
		theListBox.itemObject[theListBox.newIndex] := theCalendarDate;
//		theListBox.itemPicture[theListBox.newIndex] := self.picDebtor.picture; no picture for date
		theListBox.itemLevel[theListBox.newIndex] := _level;		
		theListBox.itemExpanded[theListBox.newIndex] := true;

		

	elseif _object.isKindOf(CM_CalendarYear) then
		theCalendarYear := _object.CM_CalendarYear;
		if _at &gt; 0 then
			theListBox.addItemAt(theCalendarYear.year.String,_at);
		else
			theListBox.addItem(theCalendarYear.year.String);
		endif;
		theListBox.itemObject[theListBox.newIndex] := theCalendarYear;
		theListBox.itemLevel[theListBox.newIndex] := _level;
		theListBox.itemPicture[theListBox.newIndex] := self.picYear.picture;

	elseif _object.isKindOf(CM_Calendar) then
			theCalendar := _object.CM_Calendar;
		if _at &gt; 0 then
			theListBox.addItemAt(theCalendar.code &amp; ' - ' &amp; theCalendar.description,_at);
		else
			theListBox.addItem(theCalendar.code &amp; ' - ' &amp; theCalendar.description);
		endif;
		theListBox.itemObject[theListBox.newIndex] := theCalendar;
		theListBox.itemLevel[theListBox.newIndex] := _level;
		theListBox.itemPicture[theListBox.newIndex] := self.picCalendar.picture;
	endif;
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="5d930df7-dad8-432b-b9d4-675af15613e3">
        <source>setDate();
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     to set datebox to open on the year that relates to myCurrentYear. 
// ----------   ----------  --------------------------------------------------
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	actualYear,
	calendarYear,
	yearDifference	: Integer;
	calendarDate,
	currentDate	: Date;
	actualDateTime : TimeStamp;
begin

	calendarYear := self.myCurrentYear.year; // get calendar year

	actualDateTime:= app.actualTimeServer();   // get actual date/time to find current year
	currentDate := actualDateTime.date(); // turn into a type date
	actualYear :=	currentDate.year();		// get the year 	
	yearDifference := calendarYear - actualYear; // find the difference so now how many to add on when seting date
	
	if yearDifference &lt;&gt; 0 then
		calendarDate  := currentDate.cnEcAddYears(yearDifference);  //add on difference to current date
	endif;	

	// set date text box so when calendar opens will open on current day but year specified by myCurrentYear
	self.tblCalendar.setValueByControlName(ETRow_Date, calendarDate);  
end;</source>
    </JadeMethod>
    <JadeMethod name="setUserAccess" id="2b87c296-b651-4a4c-ade3-ac517f50e247">
        <source>setUserAccess();
// ---------------------------------------------------------------------------
// Created:     17 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpViewOnly : Boolean; 
begin

	tmpViewOnly := self.viewOnly;
	
	self.btnNewCalendar.visible := not tmpViewOnly;
	self.btnCopy.visible := not tmpViewOnly;
	self.btnCalendarYear.visible := not tmpViewOnly;
	self.btnDelete.visible := not tmpViewOnly;
	self.btnEdit.visible := not tmpViewOnly;
	self.btnNewDate.visible := not tmpViewOnly;
	
	self.mnuCopy.visible := not tmpViewOnly;
	self.mnuDelete.visible := not tmpViewOnly;
	self.mnuEdit.visible := not tmpViewOnly;
	self.mnuNewDate.visible := not tmpViewOnly;
	self.mnuNewCalendar.visible := not tmpViewOnly;
	self.mnuNewYear.visible := not tmpViewOnly;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c87b9a00-9ab2-426c-90e8-23388f53f9e7">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if (not app.myCurrentUserCan(self.myTerminal, PmAdmHolidayMaint)) then
		self.viewOnly := true;
	else
		self.viewOnly := false;
	endif;

	self.frmProperties.height := PROPHEIGHT;
	self.frmProperties.width := PROPHEIGHT + 100;
	
	self.modalDialogResize();
	if self.isBaseFormModal then
		self.handleMenusForModalDisplay();
	endif;

	self.setCaption(self.caption);
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	self.lstData.multiSelect := ListBox.MultiSelect_Extended;
	self.lstData.stretchHeight := true;
	self.lstData.stretchWidth := true;
	self.lstData.cnEcResizeContents();
	self.doResize();
	
	self.fldProperties.useSheetBackColors := true;
	self.fldProperties.setDefaultSheetBackColors();
	self.fldProperties.initSheetBackColors();
	
	self.initCalendarTable(ETDef_CalendarDetails);

	self.setNavigatorHeading(self.caption);
	
	self.loadCalendars();

	self.beginClassNotification(CM_Calendar, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_Calendar, false, Object_Delete_Event, Response_Continuous, null);
	self.beginClassNotification(CM_Calendar, false, Object_Update_Event, Response_Continuous, null);
	
	self.beginClassNotification(CM_CalendarYear, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarYear, false, Object_Delete_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarYear, false, Object_Update_Event, Response_Continuous, null);
	
	self.beginClassNotification(CM_CalendarDate, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarDate, false, Object_Delete_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarDate, false, Object_Update_Event, Response_Continuous, null);

	self.setUserAccess();
	self.splMain.hideRightControl(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="ac367b77-cbf3-4322-915e-48949913bf8e">
        <updating/>
        <source>showPropertyFrame(_entTableView: String; _mode: Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theFolder : CMUI_Folder;
	theTable : CM_EntryTable;
	theFrame : Frame;
	theHeight : Integer;
	thelabel	: CMUI_Label;
	toolBarHeight : Real;
begin
	
//	self.currentView := _entTableView;
	theFolder := self.fldProperties;
	theFrame := self.frmProperties;
	theTable := self.tblCalendar;
	
//	theFrame.width := 200;
	
	if _entTableView &lt;&gt; null then
		theTable.showHideRowsByViewName(_entTableView, CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
	endif;

	if self.updateMode = self.UpdateMode_Copy then 
		self.displayPropDataCopy();
	else
		self.displayPropData();
	endif;
	
	if _actualHeight &lt;&gt; null then
		theHeight := _actualHeight;
	else
		theHeight := (theTable.rows * 16);
	endif;
	
	thelabel := self.lblHeading;
	toolBarHeight := self.frmPropToolbar.height;
	
	thelabel.top:= self.frmPropToolbar.height + 5;
	thelabel.width := theFrame.clientWidth - 10;
	thelabel.left := 5;	
	thelabel.height := 40;
	thelabel.visible := true;
	
	
	theTable.top	:= toolBarHeight + thelabel.height + 5 + VerticalSpacing + 10;
	theTable.height := theHeight - toolBarHeight + thelabel.height ;
	theTable.width := theFrame.clientWidth - 10;
	theTable.left := 5;	

	theTable.accessColumn(1).width := 90;
	theTable.accessColumn(2).width := (theTable.width - 125).Integer;
	theTable.resetSize();

//	theFrame.height := self.frmPropToolbar.height + theHeight + 30;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	
	theTable.setFocus();

	self.lstData.enabled := false;
	
	self.fldProperties.visible := false;  // just in case has been set as visible. - dont want to see as table is on frame. 
	
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
