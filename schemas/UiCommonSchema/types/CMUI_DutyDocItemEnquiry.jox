    <JadeMethod name="includeObject" id="f46c7e2f-5e1b-43f8-9255-64a82b2dc2cf">
        <updating/>
        <source>includeObject(_obj: CM_DutyDocItem; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.filterVoyage &lt;&gt; null and _obj.voyage &lt;&gt; self.filterVoyage then
		return false;
	endif;

	if self.filterConsignee &lt;&gt; null and _obj.consignee &lt;&gt; self.filterConsignee.code then
		return false;
	endif;
	
	if self.filterID &lt;&gt; null and not _obj.cargoId.startsWith(self.filterID) then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_obj" type="CM_DutyDocItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="049b4d62-e3ba-4a6e-8cdc-573de47d8ba1">
        <updating/>
        <source>initForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	theTable : CM_EntryTable;
	entTableDef		: EntTableDef;
begin

	self.showDataOnStartup := false; 
	self.allowMultiSelectDelete := self.allowUpdate; 
	
	self.setTblDataEntRows(ETDef_DutyDocItem);	

	//the following is needed to hide the thumbnail (not sure what useTblThumb does seemed to hide all tables
	self.isThumbnailVisible := true;//so as to make this false in the following call
	self.hideShowThumbnail();
	self.allowTblDataHide:=false;

	self.showFilterOnStartup:=true;
	
epilog

end;</source>
    </JadeMethod>
