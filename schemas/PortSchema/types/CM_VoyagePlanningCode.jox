    <JadeMethod name="setForCreate" id="9319d4c3-1f85-44dd-a1d4-51c36a53d98d">
        <updating/>
        <source>setForCreate(pProxyObj: CM_VoyagePlanningCode) updating;
// --------------------------------------------------------------------------------
// Created:		10 March 2005 by cnwdad1:2
//
// Purpose:		Sets the receiver's property values from the proxy object.
//
// Parameters:	pProxy - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(pProxyObj);
	
	self.myTerminal	:=	pProxyObj.myTerminal;
end;</source>
        <Parameter name="pProxyObj" type="CM_VoyagePlanningCode"/>
    </JadeMethod>
