    <JadeMethod name="mnuFileReload_click" id="6cbae878-f545-478b-9d03-e8450ab88d0e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileReload_click(menuItem: MenuItem input) updating;

begin
	if self.jtdUnsavedChanges then
		if app.msgBox("You have made changes that have not been saved." &amp; CrLf &amp; CrLf &amp;
			"This operation will discard all unsaved changes." &amp; CrLf &amp; CrLf &amp;
			"Are you sure you want to continue?", "Warning - Unsaved Changes", MsgBox_Yes_No +
			MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
		then
			return;
		endif;
	endif;
	
	self.jtdReload;
end;</source>
