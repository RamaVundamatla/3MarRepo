<Class name="HMS_VoyageDelayEdit" id="1fd81e49-a4d6-48aa-ba18-5635edc6ff68">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="myVoyageDelay" id="59275508-720d-4dba-b74f-4c8daad1d7bd">
        <embedded/>
        <type name="HMS_VoyageDelay"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createPropertyChanges" id="d79452cf-9df4-4aae-8f9d-822405de59de">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	workingDelay : CMIF_HMS_VoyageDelay;
 	tmpProxy : HMS_Object;
begin
	inheritMethod(_cmifTrans);
	workingDelay := _cmifTrans.myWorkingDelay;
	tmpProxy := _cmifTrans.myProxyHMSObject;
	if workingDelay &lt;&gt; null then
		self.myVoyageDelay.createPropertyChanges(self, workingDelay);
	elseif HMS_VoyageDelay.hasInstance(tmpProxy) then
		self.myVoyageDelay.createPropertyChangeFromProxy(self, tmpProxy.HMS_VoyageDelay);
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="6a2071d1-87a1-4342-9b9b-4a4213aea15a">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_transController, _passport);
	self.myVoyageDelay := _transController.myPersistentVoyageDelay;
end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="ef226ea8-cc6e-429a-a19d-05728d520d22">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
  	// Set type and typeString
	type:=TRANS_TYPE_EditVoyageDelay;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="d16c30d5-ce41-4813-ad3c-dfd732740c4c">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myWorkingDelay = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Working Delay', 'Null', null, null);
		return false;
	endif;	

	if _transController.myPersistentVoyageDelay = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Voyage Delay', 'Null', null, null);
		return false;
	endif;		
	return rtnValue;	
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
