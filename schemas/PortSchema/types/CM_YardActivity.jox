    <JadeMethod name="validateForUpdate" id="0561c65e-9358-48c8-9774-6d89349503a3">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/07/2020	jlgndl1	Initial creation	TFS 49581
18/12/2020	jlgdap1	TFS 50522 MTN Reefer API Testing
19/01/2021	jlgdap1	TFS 50648 MTN Reefer App Issue (4)
*/

vars
	realActivity, otherActivity : CM_YardActivity;		// TFS 50522

begin

	if self.type = 0 then
		app.raiseCMException1(Err_InvalidType, app.getErrorString(Null), null, null);
	endif;
	
	if self.myTrackedItem = null then
		app.raiseCMException(No_Cargo_selected, null, null);
	endif;
	
	if not self.actionTime.Date.isValid then
		app.raiseCMException1(Action_date_time_require, self.getTypeString, null, null);
	endif;
	
	// TFS 50522 check there isn't another job of the same type at the same time
	if self.myTrackedItem &lt;&gt; null then
		if self.isTransient then
			realActivity := app.myProxyManager.getRealObject(self).CM_YardActivity;
		else
			realActivity := self;
		endif;
		otherActivity := self.myTrackedItem.allYardActivities[self.type, self.actionTime, self.myTrackedItem];
		//if otherActivity &lt;&gt; null and otherActivity &lt;&gt; realActivity then							// TFS 50648
		if otherActivity &lt;&gt; null and otherActivity &lt;&gt; realActivity and not app.isWebApp then		// TFS 50648
			app.raiseCMException3(Reefer_job_exists, otherActivity.getTypeString, self.myTrackedItem.id, otherActivity.getActionTimeDateLocalTZ.asStringJMT, null, null);
		endif;
	endif;
	// TFS 50522 end

epilog

end;</source>
    </JadeMethod>
