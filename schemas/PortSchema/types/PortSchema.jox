    <JadeMethod name="loadSystemReport" id="9dd1c21d-76c1-484e-8460-4407fb56e52b">
        <source>loadSystemReport(_cnstRep : String; _cnstHdr : String);
//----------------------------------------------------------------
//	Created:	13 July 2005	by Jason Chapman  (cnwjc2)
//	Changed:	28 May 2008		by Adam Richards  (cnwar2)
//				Changed to take constant parameters.
//				For report load as in #16751.
//----------------------------------------------------------------
vars
	menuAgent			: CM_MenuAgent;
	menuRoot			: CM_MenuRootReportForRoot;
	report, header		: GlobalConstant;
	tmpUser				: CM_User;
	id					: String;
	menuHdr, menuDtl	: CM_MenuEntity;
	
begin
	app.initialize();
	
	//create report objects
	create menuAgent transient;
		
	header 	 := currentSchema.getConstant(_cnstHdr);
	report 	 := currentSchema.getConstant(_cnstRep);
	menuRoot := app.myRoot.myReportMenuRoot;
	
	beginTransaction;
	menuAgent.loadJMTDefaultMenuHdrs(header, CM_MenuEntity.XMLTag_MenuReportHdr, menuRoot);
	menuAgent.loadJMTMenuReportDetails(report, menuRoot);
	menuAgent.loadJMTDefaultMenuChildren(header, CM_MenuEntity.XMLTag_MenuReportHdr, menuRoot);
	
	id		:= '_rptHdr' &amp; header.valueAsInteger.String;
	menuHdr	:= menuRoot.allMenuItems[MenuType_HeaderSystem, id];
	if menuHdr = null then
		id := '_hdr' &amp; header.valueAsInteger.String;
		menuHdr := menuRoot.allMenuItems[MenuType_HeaderSystem, id];
	endif;
	
	id	:= '_rpt' &amp; header.valueAsInteger.String;
	menuDtl	:= menuRoot.allMenuItems[MenuType_DetailSystem, id];
	
	// add the new report(s) to all users menus
	foreach tmpUser in app.myRoot.allUsers do
		
		//tmpUser.resetReportMenuFromJMTDefault(true);		// 15/10/2008 cnwar2 #18197 - replaced with below
		if menuHdr &lt;&gt; null then
			menuHdr.addToUserMenuFromMenu(menuRoot);
		endif;
		if menuDtl &lt;&gt; null then
			menuDtl.addToUserMenuFromMenu(menuRoot);
		endif;
		
		tmpUser.checkReportMenuAgainstSecurity();
	endforeach;
	commitTransaction;
	
epilog
	delete menuAgent;
end;</source>
        <Parameter name="_cnstRep" type="String"/>
        <Parameter name="_cnstHdr" type="String"/>
    </JadeMethod>
