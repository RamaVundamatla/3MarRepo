    <JadeMethod name="setProxyForInaPortnetPKK" id="81bc30be-f040-47bc-9e91-f42b073916d1">
        <updating/>
        <source>setProxyForInaPortnetPKK(_cmifPKK : CMIF_IPNPKKItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date			Name	TFS#		Description
============================================================================
17 April 2018	jlgndl1	TFS 38135	Initial creation	
27 Sept	 2019	jlgka1	TFS 46780	PEL1 - (TOP URGENT) Pindah| Caught exception: Error Fetching http headers.
============================================================================*/

vars
	shippingLine : CM_ShippingLine;
	movement   : HMS_VoyageMovement;
	pxyHMSVoyage : HMS_VoyageData;
	vesselType : HMS_VesselType;
begin

	pxyHMSVoyage := self.myHMSVoyageData;
	
	if pxyHMSVoyage = null then
		create pxyHMSVoyage transient;
		self.setHMSVoyageData(pxyHMSVoyage);
		if self.myVessel &lt;&gt; null and self.myVessel.myHMSVesselData &lt;&gt; null then
			self.myVessel.myHMSVesselData.setProxyVoyageHMSData( pxyHMSVoyage,false, self.myTerminal );
		endif;
	endif;

/*
	//5. Taxpayer Registration Number of Shipping Company, Mandatory
	if self.npwp = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::npwp.name, null, null);
		retValue := false;
	endif;
	
	//6. Vessel Registration Mark, Mandatory
	if self.tandaPendaftaranKapal = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::tandaPendaftaranKapal.name, null, null);
		retValue := false;
	endif;
	
	//8. Captain Of a Ship, Optional
	//self.nahkoda
*/	
	self.voyageCodeExternal:=_cmifPKK.nomorPKK;
	
	if pxyHMSVoyage &lt;&gt; null then
		pxyHMSVoyage.setProxyForInaPortnetPKK(	_cmifPKK);
	endif;
	
	//13. Production Year, Mandatory
	self.yearOfBuild := _cmifPKK.tahunPembuatan.Integer;
	
	self.myOperator:=_cmifPKK.getOperator();
	
	shippingLine:=_cmifPKK.getShippingLine;
	if shippingLine &lt;&gt; null and self.myShippingLine &lt;&gt; shippingLine then
		self.myShippingLine:=_cmifPKK.getShippingLine;
		if self.myHMSVoyageData &lt;&gt; null then
			foreach movement in self.myHMSVoyageData.allVoyageMovements do
				movement.setProxyDefaultsForVoyage(self.myHMSVoyageData,movement.moveType,app.myPassport);
			endforeach;
		endif;
	endif;
	
/*	
	//15. Maximum Draft, Mandatory
	if self.drMax = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::drMax.name, null, null);
		retValue := false;
	endif;

	//18. Middle Draft, Optional
	//self.drTengah
	
	//19. Type Of Route, Mandatory
	if self.jenisTrayek = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::jenisTrayek.name, null, null);
		retValue := false;
	endif;
*/	
	//21. Vessel Call Sign, Optional
	self.callSign := _cmifPKK.callSign[1:35]; //jlgka1	TFS 46780
	
	//22. IMO Number, Optional
	//epr TFS 42606 17/12/18 don't set this to 0
	if _cmifPKK.imoNumber &lt;&gt; null and _cmifPKK.imoNumber.trimBlanks.Integer &lt;&gt; 0 then
		self.lloydsNumber := _cmifPKK.imoNumber.Integer.String;
	endif;
	
	self.setProxyNextLastPortRotations(_cmifPKK.getOriginPort,_cmifPKK.getLastPortOfCall,_cmifPKK.getNextPortOfCall,_cmifPKK.getLastPort);	
	
	self.myVoyageProcess := CM_VoyageProcessIPN1.firstInstance;
	
/*	
		
	//29. Quay Name, Mandatory
	if self.dermagaNama = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::dermagaNama.name, null, null);
		retValue := false;
	endif;
	
	//65. Route Number, Mandatory
	if self.nomorTrayek = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::nomorTrayek.name, null, null);
		retValue := false;
	endif;
	
		*/

epilog

end;</source>
        <Parameter name="_cmifPKK" type="CMIF_IPNPKKItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyForVoyage" id="c523939f-684f-4440-b9d5-31443994cd43">
        <updating/>
        <source>setProxyForVoyage(	_code : String;
					_terminal : CM_Terminal;
					_loadStartDT : TimeStamp;
					_loadEndDT : TimeStamp;
					_arriveDT : TimeStamp;
					_departDT : TimeStamp;
					_sailDT : TimeStamp;
					_loadRate : Decimal;
					_status : Integer;
					_voyGlobal : CM_VoyageGlobal;
					_vesselCode : String;
					_vesselName : String;
					_expectedArrivalDT : TimeStamp;						// PAR #35826
					_expectedDepartureDT : TimeStamp) updating;			// PAR #35826
// ---------------------------------------------------------------------------
// Created:     10 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10 Apr 2008	cnwkpd1		PAR #16378 - Changed update to arrivedDT to use
//							set method to maintain manual collection on global 
//							voyage correctly
// extra parameters Aug 2011 cnwjre1 CCMS 1120 Par 28082 Log voyage operations changes, add sail date, load rate
// 05 Mar 2015	cnwdap1		PAR #35826 CCMS SFW 1410 - added expected arrival/departure date/time parameters
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.setArrivalDT(_arriveDT);				// PAR #16378
	self.code 			:= _code.trimBlanks;
	self.departedDT		:= _departDT;
	self.loadStartDT	:= _loadStartDT;
	self.loadEndDT 		:= _loadEndDT;
	self.departedDT 	:= _sailDT;
	self.loadRate 		:= _loadRate;
	self.status 		:= _status;	//jlgzm1 22/02/2019 tfs43334 archive date not being set
	self.vesselCode		:= _vesselCode;
	self.vesselName		:= _vesselName;
	
	if self.status = Voyage_Status_Archived then
		// This MUST be done before setMyTerminal call below
		self.archived := true;
		self.archivedDT := app.serverTimestampAtTrxStart;
	endif;	

	self.setMyTerminal(_terminal);
	self.setMyVoyageGlobalArrival (_voyGlobal);

	if self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.setDatesFromVoyageUpdate(_arriveDT, _departDT);
	endif;
	
	self.estimatedArrivalDT := _expectedArrivalDT;			// PAR #35826
	self.estimatedDepartureDT := _expectedDepartureDT;		// PAR #35826
	//self.status 		:= _status;			// MAP 5/9/18 TFS40672	this line moved down to here

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_loadStartDT" type="TimeStamp"/>
        <Parameter name="_loadEndDT" type="TimeStamp"/>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_sailDT" type="TimeStamp"/>
        <Parameter name="_loadRate" type="Decimal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_expectedArrivalDT" type="TimeStamp"/>
        <Parameter name="_expectedDepartureDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxyForVoyageType" id="14f09d62-367f-40ec-ae0f-38b458a0f862">
        <updating/>
        <source>setProxyForVoyageType(	_includesLOLO 	: Boolean;
						_includesRORO 	: Boolean;
						_includesHolds	: Boolean;
						_vessel : CM_Vessel) updating;
/*

Purpose:	Just pass in the vesselType and create the appropriate proxy structures 
				- essentially moved from doing this in the setProxy of the SHP_VoyageDefinitionForm

Parameters:		will be either 	GeneralCargoStructureStr
								CellularStructureROROStr
								CellularStructureStr

Return Value:		


Date		Who		Reason
08 Jun 2011	cnwer1	Initial creation CCMS MES 1116
12 Mar 2013	PJS		PAR #31232	- completely reworked to use the option from the form	

*/

vars
	vesselCellularStructure : CM_CellularVesselStructure;
	pxyCellStructure : CM_CellularVoyageStructure;
	pxyGCVoyage : CM_GeneralCargoVoyageStructure;
	pxyROROVoyage 		: CM_ROROVoyageStructure;
	pxyVoyageStruct 	: CM_VoyageStructuralElements;

	bridgeAfterBay : String;
	isoHalfHeights, 
	use40Id,
	useBayCellTierNumbering  : Boolean;
begin
	pxyCellStructure := self.myCellularVoyageStructure;
	
	// 31232 - fully reworked to move to new mode of individual components rather
	// than based upon a vessel type
	
	
	if _includesLOLO then
		if pxyCellStructure = null then
			create pxyCellStructure transient;
			self.setProxyVoyageCellullStructure(pxyCellStructure);
			vesselCellularStructure:=_vessel.myCellularVesselStructure;
			useBayCellTierNumbering:=true;
			if vesselCellularStructure &lt;&gt; null then
				bridgeAfterBay:=vesselCellularStructure.bridgeAfterBay;
				isoHalfHeights:= vesselCellularStructure.isoHalfHeights;
				use40Id:=vesselCellularStructure.use40Id;
				useBayCellTierNumbering:= vesselCellularStructure.useBayCellTierNumbering;
			endif;
			
			pxyCellStructure.setProxyCellularVoyage(bridgeAfterBay, isoHalfHeights,
										 use40Id, useBayCellTierNumbering);
			
		endif;
		
	else
		if pxyCellStructure &lt;&gt; null then 
			delete pxyCellStructure;
		endif;
		
	
	endif;
		
	pxyROROVoyage := self.myROROStructure;
	
	if  _includesRORO then
	
		// 31232 - type now  redundant
		//if self.myCellularVoyageStructure &lt;&gt; null then
		//	 self.myCellularVoyageStructure.setType(CellularStructureRORO);
		//endif;
		
		if pxyROROVoyage = null then 
			create pxyROROVoyage transient;
			self.setMyROROStructure(pxyROROVoyage);
		endif;
	else
		if pxyROROVoyage &lt;&gt; null then
			delete pxyROROVoyage;
		endif;	
	
	endif;

	
	pxyGCVoyage := 	self.myGeneralCargoVoyage;	
	if _includesHolds then
		if pxyGCVoyage = null then
			create pxyGCVoyage transient;
			self.setProxyVoyageGeneralCargo(pxyGCVoyage);
		endif;
	else
		if pxyGCVoyage &lt;&gt; null then
			delete pxyGCVoyage;
		endif;		
		
	endif;
	
	pxyVoyageStruct := self.myStructuralElements;
	if pxyVoyageStruct = null then
		create pxyVoyageStruct transient;
		self.setProxyStructuralElement(pxyVoyageStruct);
	endif;
epilog

end;</source>
        <Parameter name="_includesLOLO" type="Boolean"/>
        <Parameter name="_includesRORO" type="Boolean"/>
        <Parameter name="_includesHolds" type="Boolean"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromWodVoyageRequest" id="2937438f-1e6f-4d64-9447-8696870c9327">
        <updating/>
        <source>setProxyFromWodVoyageRequest(_wod : CM_WodVoyageRequest) updating;
/*

Purpose:			 // TFS 40029

Parameters:			

Return Value:		

Date				Who		Reason
21 August 2018		jlgab1	Initial creation
07 October 2021		jlizm1	TFS 51963 SAL Voyage Request Changes

*/

vars
	tmpOperator : CM_Operator;
	ops : CM_OperatorByCodeDict;
	originPort, lastPortOfCall, nextPortOfCall, lastPort : CM_Port;
	vessCat : HMS_VesselCategory;
	visitType : HMS_VisitType;
	move : HMS_Movement;
	workOrder : CM_WorkOrder;
begin
	if _wod = null then
		return;
	endif;
	
	workOrder:=_wod.myParent;

	self.handleGCForWorkOrder(_wod.hasCargo and workOrder.hasBeenApproved4VoyageApproval);
	
	self.externalRef := _wod.voyageCodeIn &amp; "|" &amp; _wod.voyageCodeOut;
	
	// ### HMS STUFF
	if self.myHMSVoyageData &lt;&gt; null then
		vessCat := app.myRoot.allVesselCategories[_wod.vesselCategoryCode];
		if vessCat &lt;&gt; null then
			self.myHMSVoyageData.setVesselCategoryIn(vessCat);
		endif;
		visitType := app.myRoot.allVisitTypes[_wod.visitTypeCode];
		if visitType &lt;&gt; null then
			self.myHMSVoyageData.setMyVisitType(visitType);
		endif;
		
		move := self.getMovementArrival();
		if move &lt;&gt; null then
			move.setOccursOnDT(_wod.estimatedArrivalTS);
		endif;
		move := self.getMovementDeparture();
		if move &lt;&gt; null then
			move.setOccursOnDT(_wod.estimatedDepartureTS);
		endif;
		
		self.myHMSVoyageData.setRemarksGeneral(_wod.generalRemarks); // TFS 51963
		
	endif;
	
	self.estimatedArrivalDT := _wod.estimatedArrivalTS;
	self.estimatedDepartureDT := _wod.estimatedDepartureTS;	
	
	// ### PORTS
	originPort := app.myRoot.allPorts[_wod.portCode1];
	lastPortOfCall := app.myRoot.allPorts[_wod.portCode2];
	nextPortOfCall := app.myRoot.allPorts[_wod.portCode4];
	lastPort := app.myRoot.allPorts[_wod.portCode5];
	
	self.setProxyNextLastPortRotations(originPort, lastPortOfCall, nextPortOfCall, lastPort);

	
	// ### OPERATORS
	create ops transient;
	tmpOperator := app.myRoot.allOperators[_wod.cargoOperatorCodeLoad];
	if tmpOperator &lt;&gt; null then
		if not ops.includes(tmpOperator) then
			ops.add(tmpOperator);
		endif;
	endif;
	tmpOperator := app.myRoot.allOperators[_wod.cargoOperatorCodeDischarge];
	if tmpOperator &lt;&gt; null then
		if not ops.includes(tmpOperator) then
			ops.add(tmpOperator);
		endif;
	endif;
	tmpOperator := app.myRoot.allOperators[_wod.voyageOperatorCode];
	if tmpOperator &lt;&gt; null then
		if not ops.includes(tmpOperator) then
			ops.add(tmpOperator);
		endif;
	endif;
	
	if self.myOperator &lt;&gt; tmpOperator then
		self.myOperator := tmpOperator;
	endif;
	
	self.allOperators.clear;
	ops.copyNoDuplicates(self.allOperators,false);
	if self.myOperator &lt;&gt; null then
		if (not self.allOperators.includesKey(self.myOperator.code)) then
			self.allOperators.add(self.myOperator);
		endif;
	endif;
	
	
epilog
	delete ops;
end;</source>
        <Parameter name="_wod" type="CM_WodVoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxyLogVoyage" id="ea1e942f-a47a-47fd-9237-786b8f00f318">
        <updating/>
        <source>setProxyLogVoyage(	_code : String;
					_terminal : CM_Terminal;
					_loadStartDT : TimeStamp;
					_loadEndDT : TimeStamp;
					_arriveDT : TimeStamp;
					_departDT : TimeStamp;
					_sailDT : TimeStamp;
					_loadRate : Decimal;
					_status : Integer;
					_voyGlobal : CM_VoyageGlobal;
					_vesselCode, _vesselName : String;
					_expectedArrivalDT, _expectedDepartureDT : TimeStamp) updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
// extra parameters Aug 2011 cnwjre1 CCMS 1120 Par 28082 Log voyage operations changes, add sail date, load rate
// 05/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expceted arrival/departure date/time parameters
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.setProxyForVoyage(	_code,
							_terminal,
							_loadStartDT,
							_loadEndDT,
							_arriveDT,
							_departDT,
							_sailDT,
							_loadRate,
							_status,
							_voyGlobal,
							_vesselCode,
							_vesselName,
							_expectedArrivalDT,				// PAR #35826
							_expectedDepartureDT);			// PAR #35826
	
	if self.myLogVoyageStructure &lt;&gt; null then
		self.myLogVoyageStructure.setProxyLogVoyage(_terminal, _voyGlobal.numHatches);
	endif;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_loadStartDT" type="TimeStamp"/>
        <Parameter name="_loadEndDT" type="TimeStamp"/>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_sailDT" type="TimeStamp"/>
        <Parameter name="_loadRate" type="Decimal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_expectedArrivalDT" type="TimeStamp"/>
        <Parameter name="_expectedDepartureDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxyNextLastPortRotations" id="d0c6300f-b19e-4959-929d-17db6cca70f5">
        <source>setProxyNextLastPortRotations(	_originPort,
								_lastPortOfCall,
								_nextPortOfCall,
								_lastPort : CM_Port);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlger1	Initial creation 39166

*/

vars
	port,
	terminalPort: CM_Port;
	terminalPortIdx : Integer;
	dict : DynaDictionary;
	iter : Iterator;
	pxyPOC,
	poc 			: CM_PortRotation;
begin
	if not self.isTransient then
		return;
	endif;
	
	
	terminalPort :=app.myPassport.myTerminal.getDefaultPort;

	if not self.allPorts.includes(terminalPort) then
		self.allPorts.add(terminalPort);
	endif;
	
	terminalPortIdx:=  self.allPorts.indexOf(terminalPort);
	if _lastPortOfCall &lt;&gt; null and _lastPortOfCall &lt;&gt; terminalPort then
		if  self.allPorts.includes(_lastPortOfCall) then
			 self.allPorts.remove(_lastPortOfCall);
		endif;
		terminalPortIdx:=  self.allPorts.indexOf(terminalPort);

		 self.allPorts.insert(terminalPortIdx,_lastPortOfCall);
	endif;
	
	if _originPort &lt;&gt; null and _originPort &lt;&gt; terminalPort then
		if  self.allPorts.includes(_originPort) then
			 self.allPorts.remove(_originPort);
		endif;	
		 self.allPorts.insert(1,_originPort);
	endif;
	
	
	if _nextPortOfCall &lt;&gt; null and _nextPortOfCall &lt;&gt; terminalPort then
		if  self.allPorts.includes(_nextPortOfCall) then
			 self.allPorts.remove(_nextPortOfCall);
		endif;	
		terminalPortIdx:=  self.allPorts.indexOf(terminalPort);
		if terminalPortIdx =  self.allPorts.size then
			 self.allPorts.add(_nextPortOfCall);
		else
			 self.allPorts.insert(terminalPortIdx+ 1,_nextPortOfCall);
		endif;
	endif;
	if _lastPort &lt;&gt; null  and _lastPort &lt;&gt; terminalPort then
		if  self.allPorts.includes(_lastPort) then
			 self.allPorts.remove(_lastPort);
		endif;	
		 self.allPorts.add(_lastPort);
	endif;
	
	create dict transient;
	dict.setMembership(CM_PortRotation);
	dict.addMemberKey(CM_PortRotation::myPort.name, false, false);
	dict.endKeys(true);
	self.allPortRotations.copy(dict);
	iter:= dict.createIterator;
	while iter.next(poc) do
		poc.setMyVoyage(null);
	endwhile;
	
	foreach port in self.allPorts discreteLock do
	
		pxyPOC := dict[port].CM_PortRotation;
		if pxyPOC = null then
			create pxyPOC transient;
			pxyPOC.setProxy(port, self);
		else
			dict.remove(pxyPOC);
			pxyPOC.setMyVoyage(self);		
		endif;
	endforeach;
	
epilog
	delete dict;
	delete iter;
end;</source>
        <Parameter name="_originPort" type="CM_Port"/>
        <Parameter name="_lastPortOfCall" type="CM_Port"/>
        <Parameter name="_nextPortOfCall" type="CM_Port"/>
        <Parameter name="_lastPort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="setProxyPrenoteCutoff" id="f86c4ad6-6874-4439-911c-a36370be08e4">
        <updating/>
        <source>setProxyPrenoteCutoff(_usePrenoteCutoffs : Boolean) updating;
/*
Purpose:	

Date		Who		Reason
13 March 2025	navab1	JIRA 34233
*/

vars

begin
	self.shipCutoffsForPrenotes := _usePrenoteCutoffs;
epilog

end;</source>
        <Parameter name="_usePrenoteCutoffs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyStructuralElement" id="d0873cce-7bdd-4a01-8e8a-1eb1f6d8887a">
        <updating/>
        <source>setProxyStructuralElement(_structElement : CM_VoyageStructuralElements) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2013	cnwrd1	Initial creation

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	if self.myStructuralElements &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myStructuralElements reference is already set');
		return;
	endif;
	self.myStructuralElements := _structElement;
epilog

end;</source>
        <Parameter name="_structElement" type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyage" id="999af1fd-0e14-4575-8cce-a78f9ff7864e">
        <updating/>
        <source>setProxyVoyage(	_bitmap 					 : Binary;
				_callSign					 : String;
				_code						 : String;
				_inwardCode					 : String;
				_remarks					 : String;
				_vesselCode					 : String;
				_vesselName					 : String;
				_lloydsNumber 				 : String;
				_archived					 : Boolean;
				_isTransferable				 : Boolean;
				_starboardBerthed 			 : Boolean;
				_craneClearance				 : Integer;
				_displayOption				 : Integer;
				_colour						 : Integer;
				_status						 : Integer;
				_vesselType 				 : Integer;
				_archivedDT					 : TimeStamp;
				_arrivedDT					 : TimeStamp;
				_departedDT					 : TimeStamp;
				_loadStartDT				 : TimeStamp;
				_loadEndDT					 : TimeStamp;
				_nonPlannedEffectiveDT		 : TimeStamp;
				_cutOffDT					 : TimeStamp;
				_defaultLineGroupDebtor 	 : CM_LineGroupDebtor;
				_dischargeCompany 			 : CM_Bank;
				_operator 					 : CM_Operator;
				_trade 						 : CM_Trade;
				_myShippingLine 			 : CM_ShippingLine;
				_myTerminal 				 : CM_Terminal;
				_voyGlobal 					 : CM_VoyageGlobal;
				_vpc 						 : CM_VoyagePlanningCode;
				_invStatus 					 : Integer;
				_moveMapReceivals			 : CM_MoveMap;
				_moveMapReleases 			 : CM_MoveMap;
				_cusresAltVoyage 			 : CM_Voyage;
				_voyageNumber 				 : Integer;
				_overrideDefaults 			 : Boolean;
				_allOperators 				 : CM_OperatorByCodeDict;
				_allRecRestrictions 		 : CM_RecCutoffVoyByCodeOp;
				_useVoyageAllocation 		 : Boolean; 	//CCMS 1028 cnwjo3
				_externalRef 				 : String;
				_yearOfBuild 				 : Integer;
				_airDraft    				 : Decimal;
				_maxVesselBeam 				 : Decimal;
				_draftBow 					 : Decimal;
				_draftMid 					 : Decimal;
				_draftStern 				 : Decimal;
				_buildingLine 				 : Decimal;
				_loaWithRampDown 			 : Decimal;
				_useOutOfSequenceLoadingJobs : Boolean;
				_expectedArrivalDT 			 : TimeStamp;	// PAR #35826
				_expectedDepartureDT 		 : TimeStamp;	// PAR #35826
				_generalLandingDate 		 : Date;		//14 Mar 2016	TFS 1407
				_externalCode 				 : String;		// TFS 4050
				_paymentType				 : Integer;
				_isBarge 					 : Boolean;		// jlgka1 TFS 37102
				_groupCode                   : String;
				_ignoreCutOffs				 : Boolean		// 31.Aug.2023 navsp1 TFS 57809
				) updating;  
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
/****Changes

Date		Name	TFS#			Description
============================================================================
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX job ID Enhancements
22/03/2018	jlgdap1	TFS 37445 		PEL1 Voyage Status Security
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
08/06/2020  cnwma1  ChangeRequest   49400: ASPA - Invoice Enhancements for Barges
16/07/2024	navlw1	ChangeRequest 	63839: NSW | OnePort - Uniqueness of Inward and External Code
============================================================================*/
begin
	self.raiseExceptionIfNotTransient(method);

	 //can't create a voyage as archived, can only archive an existing voyage

	self.setArrivalDT(_arrivedDT);				// PAR #16378
	if _departedDT.isValid then
		self.departedDT := _departedDT;	
	else
		self.departedDT := null;
	endif;
	
	self.archived 	:= _archived;	 
	self.archivedDT := _archivedDT;
	self.bitmap 	:= _bitmap;	
	self.callSign 	:= _callSign;
	//CCMS1569 Cargo Cut Off
	//self.cutOffDT := _cutOffDT;								// 27/05/2009 cnwar2 CCMS1040/#19796
	self.overrideDefaults := _overrideDefaults;					// 27/05/2009 cnwar2 CCMS1040/#19796

	self.code 			:= _code.trimBlanks;
	self.colour 		:= _colour;
	self.craneClearance := _craneClearance;
	self.displayOption 	:= _displayOption; // CCMS 1423	
	self.inwardCode 	:= _inwardCode.trimBlanks;
//	PAR 33644 self.isNonPlannedVoyage := _isNonPlannedVoyage;
// PAR 33644 	self.isNonWorkedVoyage := _isNonWorkedVoyage;
	self.isTransferable := _isTransferable;
	self.lloydsNumber 	:= _lloydsNumber;
	self.loadEndDT 		:= _loadEndDT;
	self.loadStartDT 	:= _loadStartDT;
	self.statusInvoice 	:= _invStatus;
	self.externalRef 	:= _externalRef; //CCMS 1952 PAR24400 cnwsh3 20/10/2010 Customs Registration Number for SCT 
	
	self.myDefaultLineGroupDebtor 	:= _defaultLineGroupDebtor;
	self.myDischargeCompany 		:= _dischargeCompany;
	self.myOperator 		  		:= _operator;
	self.myTrade 			  		:= _trade;
	self.setMyVoyageGlobalArrival (_voyGlobal);
	self.myCusresAltVoyage 	  		:= _cusresAltVoyage;
	self.myVoyagePlanningCode 		:= _vpc;
	self.myMMReceival		  		:= _moveMapReceivals;
	self.myMMRelease 		  		:= _moveMapReleases;		
	self.myShippingLine 	  		:= _myShippingLine;
	self.allOperators.clear;
	_allOperators.copy(self.allOperators);
					
	self.setNonPlannedEffectiveDT(_nonPlannedEffectiveDT);

	self.remarks 		  := _remarks.trimBlanks;
	self.starboardBerthed := _starboardBerthed;
	//self.status := _status;			// TFS 37445 moved after myTerminal is set, now depends on this
	//CCMS1369
	//	self.seedJobNum := _seedJobNumD;
	//	self.seedJobNumLoad := _seedJobNumL;

	self.vesselCode := _vesselCode.toUpper; // cnwrl1 14/05/2010 PAR 24216
	self.vesselName := _vesselName;	
	self.vesselType := _vesselType;	
	self.voyageNumber	:= _voyageNumber;
	
	//epr CCMC 1116 15/6/2011
	self.yearOfBuild	  := _yearOfBuild;
	self.airDraft		  := _airDraft;
	self.maxVesselBeam	  := _maxVesselBeam;
	self.draftBow		  := _draftBow;
	self.draftMid		  := _draftMid;
	self.draftStern		  := _draftStern;
	self.buildingLine	  := _buildingLine;
	self.loaWithRampsDown := _loaWithRampDown;
	
	self.setMyTerminal(_myTerminal);
	
	if self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.setDatesFromVoyageUpdate(_arrivedDT, _departedDT);
	endif;
	
	//cnwjo3 CCMS 1028
	self.useVoyageAllocations := _useVoyageAllocation;

	//cnwrd1 par 30626 ccms 2209 23.10.12
	self.allowOutOfOrderJobs 	:= _useOutOfSequenceLoadingJobs;	
	self.estimatedArrivalDT 	:= _expectedArrivalDT;				// PAR #35826
	self.estimatedDepartureDT 	:= _expectedDepartureDT;			// PAR #35826

	
	self.setGeneralLandingDate( _generalLandingDate );	//15 Mar 2016	NDL	TFS 1407
	
	self.voyageCodeExternal := _externalCode;	// TFS 4050
	self.voyageGroupCode    := _groupCode;      //03/06/2020 cnwma1 Tfs #49400
	self.status 			:= _status;			// TFS 37445 moved to after myTerminal is set, now depends on this
	self.paymentType 		:= _paymentType;	// 25/6/18 MAP TFS39250
	self.isBarge 			:= _isBarge;		// jlgka1 TFS 37102
	self.ignoreCutoffs	    := _ignoreCutOffs;	// 31.Aug.2023 navsp1 TFS 57809
	
	self.inwardCodeAuto 		:= _inwardCode.trimBlanks; 		// navlw1 #63839
	self.voyageCodeExternalAuto := _externalCode.trimBlanks;	// navlw1 #63839
	

end;</source>
