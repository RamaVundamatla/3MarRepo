    <JadeMethod name="th2RunTestShipSub" id="ac76645d-fd10-483f-bbba-77f77ee39002">
        <source>th2RunTestShipSub();
constants
	ExistingVoyageCode = 'PTN010002';
	UseExistingVoyage = true;
vars
	tran					: Ship;
	startPos,
	pos						: Integer;
	voyageJob				: CM_VoyageJob;
begin
	app.initialize;
	app.sequenceId:= 1;
	create tran transient;
	
	tran.startup;
	app.jtdMyTransactionGenerator.JmtTransactionGenerator.loopCount := 0;
	app.doWindowEvents(2000);
	
	if (not UseExistingVoyage) then//start right from the beginning
		tran.vp001_loadVoyageEnqForm();
		app.doWindowEvents(1000);
		tran.vp003_loadVoyageDefForm();
		app.doWindowEvents(1000);
		tran.vp004_saveVoyageDef();
		app.doWindowEvents(1000);
		tran.vp005_setVoyageData();
		app.doWindowEvents(1000);
		tran.vp015_loadEDIForm();

		tran.myGH.baplieFile.fileName := 's:\' &amp; tran.myGH.baplieFile.fileName[12:end];
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-'&amp; tran.myGH.baplieFile.fileName);
		tran.vp016_loadBaplieFile();
		tran.vp017_showData();
		tran.vp019_verifyEDIData();
		tran.vp020_dbLoadEDI();
		tran.vp021_makeBayPlanActual();
		
	else//provides shortcut for testing - this will work as long as the voyage is 'fresh'
		tran.myVoyage := app.getMyTerminal.allVoyagesByCode.getAtKeyGeq(ExistingVoyageCode, null);
	
		if tran.myVoyage = null or tran.myVoyage.code &lt;&gt; ExistingVoyageCode then//yikes
			tran.assert(false, tran.myVoyage);
			return;
		endif;
	endif;

	app.doWindowEvents(1000);
	//tran.th014CleanUp();
	
epilog
	
	delete tran;
end;</source>
    </JadeMethod>
</Class>
