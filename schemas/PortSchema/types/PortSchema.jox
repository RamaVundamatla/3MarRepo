    <JadeMethod name="hfCheckTSMain" id="11fb457e-51eb-475d-99d8-8f590c2e008b">
        <source>hfCheckTSMain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwmc5	Initial creation

*/
constants

	SAVE_DIR			: String = "\\cnwchcm24\cnwpod$\Releases\Temp\";
	HOTFIX_DRIVE		: String = "\\cnwchcm24\cnwpod$\";
	
vars
	fileFolder,
	fileFolderHotfix,
	fileFolderSave		: FileFolder;
	fileNode			: FileNode;
	file,
	saveFile			: File;
	
	meth				: Method;

	allFiles			: FileNodeArray;
	detailsArray		: HugeStringArray;
	args				: StringArray;
	
	allDevMethods,
	allProdMethods,
	allMethods			: MethodColl;
	
	index,
	result				: Integer;
	methodName,
	line,
	latestHotfix,
	commandResult,
	env,
	hotfixNumber,
	errorsFileName,
	envName				: String;
	
	commandBool			: Boolean;
	version				: String;
	
	commands			: StringArray;
	command				: String;
	key					: String;
	value				: String;
	pos					: Integer;
	
	appServerLocn		: String;
	appServerPort		: String;
	devIni				: String;
	devDir				: String;
begin
	app.initialize();

	envName := CM_Version.VERSION.replaceString('.', '');
	
	//Get the command line value
	commandResult := process.getCommandLine();
	
	create commands transient;
	commandResult := commandResult[commandResult.pos("endJade", 1)+"endJade".length+1 : end];
	commandResult.getTokensForDelimiter(" ", commands);
	
	foreach command in commands do
		pos := 1;
		key := command.scanUntil("=", pos);
		value := command[pos+1 : end];
		
		if key = "master" then
			commandBool := value.Boolean;
		elseif key = "devVersion" then
			version := value;
		elseif key = "devPort" then
			appServerPort := value;
		endif;
	endforeach;
	
	appServerLocn := "jade1." &amp; version &amp; ".cnw.co.nz";
	devIni := "C:\DevelopmentEnvs\" &amp; version &amp; "\" &amp; version &amp; ".ini";
	devDir := "C:\DevelopmentEnvs\" &amp; version &amp; "\c_bin";
	
	env := "Prod";
	if not commandBool then
		env := "Dev";
	endif;
	
	//Get latest hotfix
	create fileFolderHotfix transient;
	fileFolderHotfix.fileName := HOTFIX_DRIVE &amp; "Releases\" &amp; envName &amp; "\Hotfixes\";
	allFiles := fileFolderHotfix.files();
	
	foreach fileNode in allFiles reversed do
		if not fileNode.isKindOf(FileFolder) then
			continue;
		endif;
		
		latestHotfix := fileNode.FileFolder.fileName;
		hotfixNumber := latestHotfix[latestHotfix.length-2:end];
		app.writeLog("Checking under file path: " &amp; latestHotfix &amp; "...", LogINFO);
		break;
	endforeach;

	//Setup the directory to look for the UNLs
	create fileFolder transient;
	fileFolder.fileName := latestHotfix &amp; "\JadeMaster\Schemas";
	if not fileFolder.isValidPathName(fileFolder.fileName) or not fileFolder.isAvailable() then
		app.writeLog("Unable to find directory (" &amp; fileFolder.fileName &amp; ")", LogINFO);
		return;
	endif;
	
	//Setup the file mask, defines the files to look for
	fileFolder.mask := "*_" &amp; envName &amp; "_*.unl";
	
	//Get all the files in the directory
	allFiles.clear();
	allFiles := fileFolder.files();
	
	create allMethods transient;
	create detailsArray transient;
	
	//Get all the methods in the files
	foreach fileNode in allFiles do
		if not fileNode.isKindOf(File) then
			continue;
		endif;
		
		file := fileNode.File;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

		while not file.endOfFile() do
			line := file.readLine();
			if line = null then
				continue;
			endif;
			if line[1:6].toUpper() = "METHOD" then
				self.hfGetMethodsFromFile(line, file.fileName, detailsArray);
			elseif line[1:5].toUpper() = "CLASS" then
				self.hfGetClassMethodsFromFile(line, file.fileName, detailsArray);
			endif;
		endwhile;
	endforeach;
	
	//Get all the details for the Development environment
	foreach line in detailsArray do
		self.hfGetMethodsActual(allMethods, line);
	endforeach;
	
	//Write method details to file
	create saveFile transient;
	saveFile.mode := File.Mode_Output;
	saveFile.allowCreate := true;
	saveFile.openOutput(SAVE_DIR &amp; env &amp; "_" &amp; envName &amp; "_" &amp; hotfixNumber &amp; ".txt");
	if saveFile.isAvailable then
		saveFile.purge();
	endif;
	
	app.writeLog("Saving file...", LogINFO);
	
	foreach meth in allMethods do
		saveFile.writeLine(meth.getSchema().name &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; 
							Tab &amp; meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String);
	endforeach;
	
	//app.writeLog("Finished saving file...", LogAlways);
	
	/*
	***********************************************
	Comparring to be done from only one environment
	***********************************************
	*/
	if commandBool then
		app.writeLog("Opening development environment...", LogINFO);
		
		create args transient;
		args.add('appServer=' &amp; appServerLocn);
		args.add('appServerPort=' &amp; appServerPort);
		args.add('app=HotfixTimestampChecking');
		args.add('schema=PortSchema');
		args.add('ini="' &amp; devIni &amp; '"');
		args.add('endJade');
		args.add('master=false');
		
		node.createExternalProcess(devDir, '"' &amp; devDir &amp; '\jade.exe"', args, null, true, true, result);
		
		app.writeLog("Checking for differences in timestamps...", LogINFO);
		self.hfCompareTimestamps(SAVE_DIR, envName, hotfixNumber);
		app.writeLog("Finished compare...", LogINFO);
		
		create fileFolderSave transient;
		fileFolderSave.fileName := SAVE_DIR;
		allFiles := fileFolderSave.files();
		errorsFileName := "Errors_" &amp; envName &amp; "_" &amp; hotfixNumber &amp; ".txt";
		
		foreach fileNode in allFiles do
			if not fileNode.isKindOf(File) then
				continue;
			endif;
			
			if fileNode.File.fileName &lt;&gt; (SAVE_DIR &amp; errorsFileName) then
				continue;
			endif;
			
			args.clear();
			args.add(errorsFileName);
			node.createExternalProcess(SAVE_DIR, 'notepad.exe', args, null, true, false, result);
			break;
		endforeach;
	endif;
epilog
	delete fileFolderHotfix;
	delete fileFolder;
	delete fileFolderSave;
	delete allMethods;
	delete allDevMethods;
	delete allProdMethods;
	delete detailsArray;
	delete saveFile;
	delete args;
	
	delete commands;
	
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="hfCompareTimestamps" id="dce2cc9b-e5f5-496a-a47c-49a2fc5e78e5">
        <source>hfCompareTimestamps(_saveDir, _envName, _hotfixNumber : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2013	cnwmc5	Initial creation

*/
vars
	devFile,
	prodFile,
	saveFile			: File;

	detailsArray		: HugeStringArray;
	
	line				: String;
	haveWrittenError	: Boolean;
begin	
	create detailsArray transient;
	create devFile transient;
	create prodFile transient;
	
	devFile.kind  := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	prodFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

	
	devFile.fileName := (_saveDir &amp; "Dev_" &amp; _envName &amp; "_" &amp; _hotfixNumber &amp; ".txt");
	devFile.mode := File.Mode_Input;
	devFile.open;
	
	while not devFile.endOfFile() do
		line := devFile.readLine();
		if line = null then
			continue;
		endif;
		
		detailsArray.add(line);
	endwhile;
	
	prodFile.fileName := (_saveDir &amp; "Prod_" &amp; _envName &amp; "_" &amp; _hotfixNumber &amp; ".txt");
	prodFile.mode := File.Mode_Input;
	prodFile.open;
	
	haveWrittenError := false;	
	while not prodFile.endOfFile() do
		line := prodFile.readLine();
		if line = null then
			continue;
		endif;
		
		if detailsArray.includes(line) then
			continue;
		endif;
		
		//Write method details to file
		if not haveWrittenError then
			create saveFile transient;
			saveFile.mode := File.Mode_Output;
			saveFile.allowCreate := true;
			saveFile.openOutput(_saveDir &amp; "Errors_" &amp; _envName &amp; "_" &amp; _hotfixNumber &amp; ".txt");
			if saveFile.isAvailable then
				saveFile.purge();
			endif;
		endif;
		
		saveFile.writeLine("Incorrect TimeStamp: " &amp; line);
		app.writeLog("Incorrect TimeStamp: " &amp; line, LogINFO);
		haveWrittenError := true;
	endwhile;
	
	if haveWrittenError then
		saveFile.close();
	endif;
epilog
	delete saveFile;
end;</source>
        <Parameter name="_saveDir" type="String"/>
        <Parameter name="_envName" type="String"/>
        <Parameter name="_hotfixNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="hfGetClassMethodsFromFile" id="104d4779-428d-4d1a-a586-d2658690432c">
        <source>hfGetClassMethodsFromFile(_line, _fileName : String; _detailsArray : HugeStringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwmc5	Initial creation

*/

vars

	schema				: Schema;
	klass				: Class;
	meth				: Method;
	
	methodsDict			: MethodNDict;

	parNumber			: Integer;
	posParFile			: Integer;
	posSlash			: Integer;
	posUnderscore		: Integer;
	posParLine			: Integer;
	className 			: String;
	schemaName			: String;
	methodSource		: String;
	
begin	
	//Get the class name
	if posParLine = 0 then
		className := _line[7:end].trimBlanks();
	else
		className := _line[7:posParLine-7];
	endif;
	if className.toUpper() = "JADESCRIPT" then
		return;
	endif;
		
	//Get the schema name
	schema := rootSchema.getSchema("PortSchema");

	posSlash := _fileName.reversePos("\");
	posUnderscore := _fileName.pos("_", posSlash);
	schemaName := _fileName[posSlash+1:posUnderscore-1-posSlash];
	schema := schema.getSchema(schemaName);
	if schema = null then
		return;
	endif;
	
	//Get the class
	klass := schema.getClass(className);
	if klass = null then
		return;
	endif;
	
	//Get the methods
	create methodsDict transient;
	klass.getMethods(methodsDict);
	
	//Check the methods for the par number
	foreach meth in methodsDict do
		methodSource := meth.getSource();
		if methodSource.cnContains(parNumber.String) then
			if not _detailsArray.includes(klass.name &amp; " " &amp; meth.name) then
				_detailsArray.add(schema.name &amp; " " &amp; klass.name &amp; " " &amp; meth.name);
			endif;
		endif;
	endforeach;
	
epilog
	delete methodsDict;
end;</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_detailsArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hfGetMethodsActual" id="8ce514e5-5eb2-4340-9d0d-fc2d3b6edd34">
        <source>hfGetMethodsActual(_allMethods : MethodColl io; _line : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwmc5	Initial creation

*/

vars
	schema 			: Schema;
	klass			: Class;
	meth			: Method;
	prim			: PrimType;
	
	schemaName,
	className,
	methodName		: String;
	index			: Integer;
begin	
	//Get the schema
	index := 1;
	schemaName := _line.scanUntil(" ", index);
	schema := rootSchema.getSchema("PortSchema");
	schema := schema.getSchema(schemaName);
	if schema = null then
		app.writeLog("Unknown Schema: " &amp; schemaName &amp; "...", LogINFO);
		return;
	endif;
	
	//Get the class
	index := index + 1;
	className := _line.scanUntil(" ", index);
	klass := schema.getClass(className);
	if klass = null then
		prim := schema.getPrimitive(className);
		if prim = null then
			app.writeLog("Unknown Class: " &amp; className &amp; "...", LogINFO);
			return;
		endif;
		
		index := index + 1;
		methodName := _line.scanUntil(" ", index);
		meth := prim.getMethod(methodName);
		if meth = null then
			app.writeLog("Unknown Method: " &amp; methodName &amp; "...", LogINFO);
			return;
		endif;
		
		return;
	endif;
	
	//Get the method
	index := index + 1;
	methodName := _line.scanUntil(" ", index);
	meth := klass.getMethod(methodName);
	if meth = null then
		app.writeLog("Unknown Method: " &amp; methodName &amp; "...", LogINFO);
		return;
	endif;
	
	if _allMethods.includes(meth) then
		return;
	endif;
	
	_allMethods.add(meth);
epilog

end;</source>
        <Parameter name="_allMethods" type="MethodColl" usage="io"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="hfGetMethodsFromFile" id="73c972b8-1b8c-4f74-9f60-05263cf40561">
        <source>hfGetMethodsFromFile(_line, _fileName : String; _detailsArray : HugeStringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwmc5	Initial creation

*/

vars
	schema			: Schema;
	
 	posSlash,
	posUnderscore	: Integer;
	
	methodName,
	schemaName		: String;
begin
	//Get the schema name
	schema := rootSchema.getSchema("PortSchema");

	posSlash := _fileName.reversePos("\");
	posUnderscore := _fileName.pos("_", posSlash);
	schemaName := _fileName[posSlash+1:posUnderscore-1-posSlash];
	schema := schema.getSchema(schemaName);
	if schema = null then
		return;
	endif;
	
	//Get the method name
	methodName := _line[8:_line.pos(" ", 8) - 8].toUpper();
	if methodName &lt;&gt; "JADESCRIPT" and  methodName &lt;&gt; "DECIMAL" and 
			methodName &lt;&gt; "INTEGER"then 
		if not _detailsArray.includes(_line[8:end]) then
			_detailsArray.add(schema.name &amp; " " &amp; _line[8:end]);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_detailsArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hhGroundingEnumToString" id="29c95ef0-ef06-465d-8e7b-a5fd53b17594">
        <source>hhGroundingEnumToString( _enum : Integer ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

begin

	if _enum = BothOpts then
		return app.getErrorString(Both_options_allowed);
	elseif _enum = NoOpts then
		return app.getErrorString(No_options_allowed);
	elseif _enum = GroundComplete then
		return app.getErrorString(Grounding_completes);
	elseif _enum = GroundInTransit then
		return app.getErrorString(Grounding_in_transit);
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_enum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hhScanningEnumToString" id="70876071-c7d7-4bef-8cb4-3e7d232d38ba">
