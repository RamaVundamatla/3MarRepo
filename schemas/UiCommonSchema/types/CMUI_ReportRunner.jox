    <JadeMethod name="setTemplateControlsEnabled" id="c03b7880-7f58-4397-b2ae-48c997ef41ec">
        <source>setTemplateControlsEnabled(_enabled : Boolean) protected;
// -------------------------------------------
// Created 09 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin


	self.cmbUserRunAs.enabled := _enabled and self.isUserCmbEnabled;
	self.multiGrpEdit.readOnly:= not _enabled;
	self.multiGrpOutput.readOnly:= not _enabled;

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTemplateControlsForNew" id="c09e1e43-840e-4a5c-ba5e-5cdb3af3ac24">
        <updating/>
        <source>setTemplateControlsForNew() protected, updating;
// -------------------------------------------
// Created 14 December 2004 by cnwdvb1
// -------------------------------------------
vars

	editArray	: ObjectArray;
	outputArray	: ObjectArray;
	user		: CM_User;
	qryReport	: CM_QryReport;	

begin

	user := app.getMyUser();
	qryReport := self.myReportAgent.myQryReport;
	
	create editArray transient;
	create outputArray transient;
	editArray.add(user);
	outputArray.add(user);
	self.cmbUserRunAs.listObject := user;

	// 31266 May 2013 add system and terminal administrator users with template edit permission so they can also access this template (as they already can for reports)
	foreach user in app.myRoot.allUsers do
		if user.isNotAvailableForEntry or
		   user.code.trimBlanks.toUpper = 'SUPERUSER' then
			continue;
		endif;
		
		if user.isAdministrator() and
		   user.isTerminalAdminstrator(self.myTerminal) then
			if not user.canDo(self.myTerminal, PmRptTemplateMaint) then
				continue;
			endif;
			if not user.canUserViewReport(qryReport) then
				continue;
			endif;
			editArray.add(user);

		endif;
	endforeach;
	
	self.multiGrpEdit.setSelected(editArray);
	self.multiGrpOutput.setSelected(outputArray);
	self.isUserCmbEnabled := true;

epilog
	delete editArray;
	delete outputArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5236dc6d-0610-4721-8c0b-36b50adb72af">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
//Date			Who		Reason
//22 May 2025	navpw1	JIRA: MTN-34827 - Fixed combo box style when config option DoNotFilterCombos is turned on. These are now still editable.
//02 Sep 2025 	navcs2 	Bug MTN-35806: PENN - Run Date Value not editable when "Do not filter combo boxes" is checked
constants
	HorzGap = 5;
vars
	user : CM_User;
	root : CM_Root;
	
begin
	self.comboBoxIdx := 1;	// ### JIRA: MTN-36160 05Nov2025 NAVPW1
	root := app.myRoot;
	inheritMethod();
	self.addRegisteredKey(J_key_F);
	user := app.getMyUser();
	
	self.canAccessTemplates := user.canDo(self.myTerminal, PmRptTemplateMaint);
	self.canPrintBackground	:= user.canDo(self.myTerminal, PmRptRunBGPrint);
	
	self.initTemplateUsers(user);
		
	self.initForm();
	self.grpReports.top := 0;
	self.grpReports.left := 0;
	self.grpReports.height := self.grpReports.parent.height;
	
	self.grpRight.top := 0;
	self.grpRight.height := self.grpRight.parent.height - HorzGap;
	
	self.lbReportTree.left := self.lbReportTree.parent.left + HorzGap;
	self.lbReportTree.top := self.lbReportTree.parent.top + (HorzGap * 3);
	self.lbReportTree.width :=  self.lbReportTree.parent.width - (HorzGap * 2);
	self.lbReportTree.height := self.lbReportTree.parent.height - (HorzGap * 3);
	
	//self.centreWindow(); Do Not centre as user setting are used instead.
	
	self.tblParameter.repositionAfterResize();
	self.tblParameter.stretchWidth := true;
	self.tblParameter.setDistanceFromRight(13);
	self.lblRepName.top := 5;			// 35875 was 20, move up to compensate for height change
	self.lblRepName.left := self.tblParameter.left;
	self.lblRepName.height := 80;		// 35875 increase height to show description with name
	self.lblRepName.wordWrap := true;	// 35875 make it multi-line and set parentAspect
	self.lblRepName.parentAspect := 1;
	self.lblRepName.visible := false;

	self.tblBGPReports.top := self.tblParameter.top;
	self.tblBGPReports.repositionAfterResize();
	self.tblBGPReports.stretchWidth := true;
	self.tblBGPReports.stretchHeight:= true;
	//PAR18772 - 22/1/2009 cnwsh3 - Changed distance from the bottom to avoid intrusion into Output Options.
	self.tblBGPReports.setDistanceFromBottom(180);
	//self.tblBGPReports.setDistanceFromBottom(150);
	//self.tblBGPReports.height := self.height - self.btnSaveBGR.top;
	self.tblBGPReports.setDistanceFromRight(13);
	self.tblBGPReports.multiSelect := ListBox.MultiSelect_Extended;
	
	self.tblBGPEnt.top := self.tblParameter.top;
	self.tblBGPEnt.stretchWidth := true;
	self.tblBGPEnt.setDistanceFromRight(13);

	if root.getConfig(BackgroundReportsAvailable).Boolean then
	//CNWTH2 to decide what to do here
	endif;
	
	self.fldReport.useSheetBackColors := true;
	self.fldReport.setDefaultSheetBackColors();
 	self.fldReport.initSheetBackColors();
 	
 	self.cmbUserRunAs.listCollection(root.allUsers, true, 0);
 	
	self.multiGrpOutput.formDisplayEntryMethodName := CMUI_ReportRunner::displayDetail.name; 
//	self.multiGrpOutput.availableHeading := 'Available Users';	// cnwrl1 11/11/2009 PAR 19951 - what it was
//	self.multiGrpOutput.selectedHeading := 'Selected Users';	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.multiGrpOutput.availableHeading := app.getString( Available_Users );
	self.multiGrpOutput.selectedHeading := app.getString( Selected_Users );
	self.multiGrpOutput.myBaseForm	:= self;
	self.multiGrpOutput.mySelectedListBox.sorted := false;
	self.multiGrpOutput.multiSelect	:= ListBox.MultiSelect_Extended;
	
	self.multiGrpOutput.setAvailable(self.allTemplateUsersOutput, false);
	
	
	self.multiGrpEdit.formDisplayEntryMethodName := CMUI_ReportRunner::displayDetail.name; 
//	self.multiGrpEdit.availableHeading := 'Available Users';	// cnwrl1 11/11/2009 PAR 19951 - what it was
//	self.multiGrpEdit.selectedHeading := 'Selected Users';	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.multiGrpEdit.availableHeading := app.getString( Available_Users );
	self.multiGrpEdit.selectedHeading := app.getString( Selected_Users );
	self.multiGrpEdit.myBaseForm	:= self;
	self.multiGrpEdit.mySelectedListBox.sorted := false;
	self.multiGrpEdit.multiSelect	:= ListBox.MultiSelect_Extended;
	
	self.multiGrpEdit.setAvailable(self.allTemplateUsersEdit, false);
 	
//	self.setNavigatorHeading('Reports');	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.setNavigatorHeading( app.getString( Reports ) );
	self.sptMain.setLeftToRightRatioAndResize(35);
	self.lbReportTree.setFocus;
	self.doResize();

	self.cmbArriveDFrom.automaticCellControl := true;
	self.cmbArriveDTo.automaticCellControl := true;
	self.cmbDepartDFrom.automaticCellControl := true;
	self.cmbDepartDTo.automaticCellControl := true;
	self.cmbInPortDFrom.automaticCellControl := true;
	self.cmbInPortDTo.automaticCellControl := true;
	self.cmbBaseDate.automaticCellControl := true;
	self.cmbOnDate.automaticCellControl := true;
	self.cmbOpenDate.automaticCellControl := true;
	self.cmbCloseDate.automaticCellControl := true;
	self.cmbQueryParamDate.automaticCellControl := false;
	self.cmbPackByDate.automaticCellControl := true;
	self.cmbMatchEnd.automaticCellControl := true;
	self.cmbMatchStart.automaticCellControl := true;
	self.cmbProcDate.automaticCellControl := true;	//16 Nov 2009	NDL	Par 21519
	self.cmbProcEndDate.automaticCellControl := true;  //cnwjo3 par 25615
	
	self.cmbExpArrDFrom.automaticCellControl := true;			//+TFS39313
	self.cmbExpArrDTo.automaticCellControl := true;
	self.cmbExpDepDFrom.automaticCellControl := true;
	self.cmbExpDepDTo.automaticCellControl := true;
	self.cmbQueryParamDate.automaticCellControl := true; // ### JIRA: MTN-36160 05Nov2025 NAVPW1
	
	// ### JIRA: MTN-34827 22May2025 NAVPW1
	if root.getConfig(DoNotFilterCombos).Boolean then
		self.cmbOpenDate.style 				:= ComboBox.Style_DropDown;		//02.09.2025 navcs2 #35806			
		self.cmbCloseDate.style 			:= ComboBox.Style_DropDown;		//02.09.2025 navcs2 #35806
		self.cmbArriveDFrom.style			:= ComboBox.Style_DropDown;
		self.cmbArriveDTo.style				:= ComboBox.Style_DropDown;
		self.cmbDepartDFrom.style			:= ComboBox.Style_DropDown;
		self.cmbDepartDTo.style				:= ComboBox.Style_DropDown;
		self.cmbInPortDFrom.style			:= ComboBox.Style_DropDown;
		self.cmbInPortDTo.style				:= ComboBox.Style_DropDown;
		self.cmbExpArrDFrom.style			:= ComboBox.Style_DropDown;
		self.cmbExpArrDTo.style				:= ComboBox.Style_DropDown;
		self.cmbExpDepDFrom.style			:= ComboBox.Style_DropDown;
		self.cmbExpDepDTo.style				:= ComboBox.Style_DropDown;
		self.cmbContractFromStartDate.style	:= ComboBox.Style_DropDown;
		self.cmbContractToStartDate.style	:= ComboBox.Style_DropDown;
		self.cmbDetailFromStartDate.style	:= ComboBox.Style_DropDown;
		self.cmbDetailToStartDate.style		:= ComboBox.Style_DropDown;
		self.cmbRateFromStartDate.style		:= ComboBox.Style_DropDown;
		self.cmbRateToStartDate.style		:= ComboBox.Style_DropDown;
		self.cmbContractFromEndDate.style	:= ComboBox.Style_DropDown;
		self.cmbContractToEndDate.style		:= ComboBox.Style_DropDown;
		self.cmbDetailFromEndDate.style		:= ComboBox.Style_DropDown;
		self.cmbDetailToEndDate.style		:= ComboBox.Style_DropDown;
		self.cmbRateFromEndDate.style		:= ComboBox.Style_DropDown;
		self.cmbRateToEndDate.style			:= ComboBox.Style_DropDown;
		self.cmbQueryParamDate.style		:= ComboBox.Style_DropDown;	// ### JIRA: MTN-36160 05Nov2025 NAVPW1
		
	endif;
	// ### JIRA: MTN-34827 22May2025 NAVPW1
	
	
	
	// cnwrl1 09/02/2010 PAR 22291 - start of coding
	// If the user only has access to 1 terminal then do NOT show
	// the "Terminal Select" menu when Report runner is selected.
	self.mnuTerminalSelect.visible	:= user.allUserTerminals.size &gt; 1;
	// cnwrl1 09/02/2010 PAR 22291 - end of coding
//	if process.isSH then
//		self.staMain.visible := false;
//	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showBGPReportsOffHeader" id="bf2ff192-d08b-4523-8603-8edacfae79b5">
        <updating/>
        <source>showBGPReportsOffHeader(_menuHeader : CM_MenuUserHdr) updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002		cnwth2	
//
// Purpose:     Could potentially be menuRoot or a menu header (both with children) passed in here
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity				: CM_MenuEntity;
	entDef					: EntTableDef;
begin

	entDef := app.myController.getEntTableDef(ETDef_BGPReportInfo);
	if entDef = null then 
		return;
	endif;
	
	self.myReportAgent.setState(self.myReportAgent.STATE_BGR_RUN);
	
	self.tblBGPReports.rows := self.tblBGPReports.fixedRows;
	
	if _menuHeader &lt;&gt; null then
		foreach menuEntity in _menuHeader.allChildren do
			self.addBGPReportRow(menuEntity, entDef);
		endforeach;
	endif;
	self.tblBGPReports.leftColumn := 1;
	//self.tblBGPReports.adjustHeight(200);
	self.doResize();
	
end;</source>
        <Parameter name="_menuHeader" type="CM_MenuUserHdr"/>
    </JadeMethod>
    <JadeMethod name="showBGPReportsOffRoot" id="cbc95310-9185-451f-bf75-b9d25d2bfbe5">
        <updating/>
        <source>showBGPReportsOffRoot(_menuRoot : CM_MenuRootUserBackgroundReps) updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002		cnwth2	
//
// Purpose:     Could potentially be menuRoot or a menu header (both with children) passed in here
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity				: CM_MenuEntity;
	entDef					: EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_BGPReportInfo);
	if entDef = null then 
		return;
	endif;
	
	self.tblBGPReports.visible := true;
	self.lblRepName.visible := true;
	
	
	if _menuRoot = _menuRoot.CM_MenuRootUserBackgroundReps.myUser.myMenuRootBGRCurrent then
		self.myReportAgent.setState(self.myReportAgent.STATE_BGR_RUN);
	elseif _menuRoot = _menuRoot.CM_MenuRootUserBackgroundReps.myUser.myMenuRootBGRSaved then
		self.myReportAgent.setState(self.myReportAgent.STATE_BGR_RUN);
	endif;
	
	self.tblBGPReports.rows := self.tblBGPReports.fixedRows;
	
	foreach menuEntity in _menuRoot.allMenuUserItemsWithAMenuItem do
		self.addBGPReportRow(menuEntity, entDef);
	endforeach;
	
	self.tblBGPReports.leftColumn := 1;
	self.doResize();
end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRootUserBackgroundReps"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="034f83f2-025b-4185-9b1a-34c57fb8f5ba">
