    <JadeMethod name="translateForm" id="e891d7fe-e518-4865-ba7c-ad0093204a49">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 September 2025 10:37:05.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024410, locale);
	btnClose.translateCaption(Xlat_0024411, locale);
	btnCloseQuery.translateCaption(Xlat_0024412, locale);
	btnDetails.translateCaption(Xlat_0024605, locale);
	btnRefresh.translateCaption(Xlat_0024413, locale);
	btnSearchQuery.translateCaption(Xlat_0024414, locale);
	btnShowQuery.translateCaption(Xlat_0024415, locale);
