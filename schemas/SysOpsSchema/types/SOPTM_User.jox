    <JadeMethod name="initShtDataTable1" id="31300c58-c8ca-4abe-8d11-a21e863a12bf">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sht							: CMUI_Sheet;
	tbl							: CM_DataTable;
	cargoBOLTypeDescrs			: String;
begin
	inheritMethod;
	
	sht := self.myForm.shtDataTable1;
