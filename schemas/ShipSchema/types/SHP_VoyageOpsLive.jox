    <JadeMethod name="tableRowChange" id="dfd43e44-0df0-470d-a3cb-388aa1145cdb">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807
17JAN20 	navra1	CR 62045/Task 62049 - UI - Export Container Confirmation Location
27 Jun 2024	jlika1	TFS 64887 CUX - Adding columns to child/onboard cargo detail column organizer shows blanks in Voyage Ops Live/FLP
20 Aug 2024	jlizm1	TFS 65704 children of discharged mafi not automatically removed from table
*/

vars
	obj : CM_Object;
begin

	self.myCurrentContextTbl	:= _table;	
	
	obj := _table.accessRow(_newRow).itemObject.CM_Object;

	if not global.isValidObject(obj) then
		self.myCurrentTrackedItem := null;
		return;
	endif;
	
	if obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;
		self.buildComboConfirm();			//navra1 - CR 62045/Task 62049 - 17th Jan 2024
	else
		self.myCurrentTrackedItem	:= null;
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
