    <JadeMethod name="doBaseFormSave" id="c10013f1-dfc2-42a3-bff6-e60c049654b1">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.doSaveTemps() then
		endNotificationForSubscriber(self);	
		self.dataChanged := false;	//reset
		
		//have to try to preserve the comm status info when this is refreshed
		//re-display info
		self.resetTableReefers();
	endif;
	


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="f2abbfd4-62fd-4471-a786-ad9d9996cc34">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if not self.doSaveTemps() then
		return;
	endif;

	self.modalResult := IDOK;
	self.unloadForm;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="a605f9d5-1566-486f-b290-c023672b47d0">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
constants
	GAP : Real = 4;
vars
	topVal	: Real;
	leftVal	: Real;	
begin
	topVal 	:= GAP + self.frmToolbar.height;
	inheritMethod();
	
	self.lblReadingDate.top := topVal;
	self.lblReadingDate.left := GAP;
	
	leftVal := self.lblReadingDate.left + self.lblReadingDate.width + GAP;
	
	self.lblReadingTime.top := topVal;
	self.lblReadingTime.left := leftVal;
	
	topVal := lblReadingDate.top + lblReadingDate.height + GAP; 
	
	self.txtDate.top := topVal;
	self.txtDate.left := GAP;
	
	self.txtTime.top := topVal;
	self.txtTime.left := leftVal;
	
	leftVal := self.txtTime.left + self.txtTime.width + GAP;
	
	self.chkNoCharge.height := self.txtTime.height;
	self.chkNoCharge.top := topVal;
	self.chkNoCharge.left := leftVal;
	
	leftVal := self.chkNoCharge.left + self.chkNoCharge.width;
	
	self.lblRequests.left := leftVal;
	self.lblRequests.top := topVal;
	
	topVal := self.txtDate.top + self.txtDate.height + GAP;
	

	self.tblReefers.move(0, topVal, self.clientWidth, self.height - topVal - 27);
	
//	self.btnSave.move(self.btnCancel.left-self.btnCancel.width-GAP,self.btnCancel.top,self.btnCancel.width,self.btnCancel.height);
//	self.btnOk.move(self.btnSave.left-self.btnCancel.width-GAP,self.btnCancel.top,self.btnCancel.width,self.btnCancel.height);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="33aa7c06-9d13-4936-b0a1-726c0376efab">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

	if self.doSaveTemps() then
		endNotificationForSubscriber(self);	
		self.dataChanged := false;	//reset
		
		//have to try to preserve the comm status info when this is refreshed
		//re-display info
		self.resetTableReefers();
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTemps" id="78af3554-55ca-49e4-80aa-4fd76e63a98e">
        <updating/>
        <source>doSaveTemps():Boolean updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 18/03/2015	cnwdap1		PAR #35874 TFS 265 Added Humidity and Ventilation readings
// 18 July 2016	cnwns1 		TFS2333 Multi-timezone issues
// 02/10/2017	jlgdap1		TFS 7204 STWR Decimal temperatures not sawed in non-standard locale
// 27/09/2021	navdap1		TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
	idx					: Integer;
	reefer				: CM_TrackedItem;	// CCMS 1007
	strTemp				: String;
	timeStmpLocal		: TimeStamp;						//18 July 2016	cnwns1 	TFS2333 Multi-timezone issues
	timeStmpSystem		: TimeStamp;						//18 July 2016	cnwns1 	TFS2333 Multi-timezone issues
	tempReadingParams	: CMIF_TempReading;
	tempParams			: CMIF_TempReading;					// PAR #35874
	humidReadingParams	: CMIF_HumidReading;				// PAR #35874
	humidParams			: CMIF_HumidReading;				// PAR #35874
	ventReadingParams	: CMIF_VentReading;					// PAR #35874
	ventParams			: CMIF_VentReading;					// PAR #35874
	loadState			: Boolean;
	theProxyTI			: CM_TrackedItem;	// CCMS 1007
	isFah				: Boolean;
	result				: Integer;
	strHumid, strVent	: String;							// PAR #35874
	tempTemp : Real;	//01 Sep 2021	NDL	TFS 51874
	co2Params, co2ReadingParams : CMIF_CO2Reading;			// MTN-36569
	o2Params, o2ReadingParams : CMIF_O2Reading;				// MTN-36569
	strCO2, strO2		: String;					// MTN-36569
begin

	if not self.dataChanged then
		result := app.msgBox("Nothing has changed in the table.  Are you sure you want to save the current temperatures?","Add Readings?",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	timeStmpLocal.setDate(self.txtDate.getDate());
	timeStmpLocal.setTime(self.txtTime.getTime());

	timeStmpSystem := self.localToSystemTime(timeStmpLocal);	//18 July 2016	cnwns1 	TFS2333 Multi-timezone issues
	
	create tempReadingParams transient;
	
	create humidReadingParams transient;							// PAR #35874
	humidReadingParams.dateTime := timeStmpSystem;					// PAR #35874
	humidReadingParams.noCharge := self.chkNoCharge.value;			// PAR #35874
	humidReadingParams.userId := app.getMyUserCode();				// PAR #35874
	humidReadingParams.myTerminal := self.myTerminal;				// PAR #35874
	create ventReadingParams transient;								// PAR #35874
	ventReadingParams.dateTime := timeStmpSystem;					// PAR #35874
	ventReadingParams.noCharge := self.chkNoCharge.value;			// PAR #35874
	ventReadingParams.userId := app.getMyUserCode();				// PAR #35874
	ventReadingParams.myTerminal := self.myTerminal;				// PAR #35874
	
	// MTN-36569 CO2 and O2 readings
	create co2ReadingParams transient;
	co2ReadingParams.dateTime := timeStmpSystem;
	co2ReadingParams.noCharge := self.chkNoCharge.value;
	co2ReadingParams.userId := app.getMyUserCode();
	co2ReadingParams.myTerminal := self.myTerminal;
	create o2ReadingParams transient;
	o2ReadingParams.dateTime := timeStmpSystem;
	o2ReadingParams.noCharge := self.chkNoCharge.value;
	o2ReadingParams.userId := app.getMyUserCode();
	o2ReadingParams.myTerminal := self.myTerminal;
	// MTN-36569 end of this bit
	
	foreach idx in 2 to self.tblReefers.rows do
		reefer := self.tblReefers.accessRow(idx).itemObject.CM_TrackedItem;	// CCMS 1007
		strTemp:= self.tblReefers.accessCell(idx,INPUT_COLUMN).text;
		isFah  := self.tblReefers.accessCell(idx,FAH_COLUMN).text.Integer.Boolean;
		
		strHumid := self.tblReefers.accessCell(idx,INPUT_HUMID_COLUMN).text;				// PAR #35874
		strVent := self.tblReefers.accessCell(idx,INPUT_VENT_COLUMN).text;					// PAR #35874
		strCO2 := self.tblReefers.accessCell(idx,INPUT_CO2_COLUMN).text;		// MTN-36569
		strO2 := self.tblReefers.accessCell(idx,INPUT_O2_COLUMN).text;			// MTN-36569
		
		//if reefer &lt;&gt; null and strTemp.isReal then											// PAR #35874
		//if reefer &lt;&gt; null and (strTemp.isReal or strHumid.isReal or strVent.isReal) then	// PAR #35874	// TFS 7204
		if reefer &lt;&gt; null and (strTemp.isRealJMT or strHumid.isDecimalJMT or strVent.isRealJMT				// TFS 7204
								or strCO2.isRealJMT or strO2.isRealJMT) then						// MTN-36569
		
			tempParams := null;																// PAR #35874
			humidParams := null;															// PAR #35874
			ventParams := null;																// PAR #35874
			co2Params := null;			// MTN-36569
			o2Params := null;			// MTN-36569
			
			app.cmsBeginLoad(loadState);
			theProxyTI := reefer.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			
			//if strTemp.isReal then														// PAR #35874	// TFS 7204
			if strTemp.isRealJMT then																		// TFS 7204
				
				if isFah then
					tempTemp := app.temperatureConversion(false, strTemp.asRealJMT);
				else
					tempTemp := strTemp.asRealJMT;
				endif;
				
				//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
				tempReadingParams.initialise(	theProxyTI,	//_reefer : CM_TrackedItem;
												self.chkNoCharge.value,	//_defaultNoChargeValue : Boolean;
												timeStmpSystem,	//_dateTime : TimeStamp;			// TFS 52081
												tempTemp	//_temperature : Real
												);
												
				tempParams := tempReadingParams;											// PAR #35874
				
			endif;																			// PAR #35874
			//if strHumid.isReal then														// PAR #35874	// TFS 7204
			if strHumid.isDecimalJMT then																		// TFS 7204
				humidReadingParams.myTrackedItem := theProxyTI;								// PAR #35874
				humidReadingParams.setHumidity( strHumid.asDecimalJMT );							// PAR #35874
				humidParams := humidReadingParams;											// PAR #35874
			endif;																			// PAR #35874
			//if strVent.isReal then														// PAR #35874	// TFS 7204
			if strVent.isRealJMT then																		// TFS 7204
				ventReadingParams.myTrackedItem := theProxyTI;								// PAR #35874
				ventReadingParams.ventilation := strVent.Real;								// PAR #35874
				ventParams := ventReadingParams;											// PAR #35874
			endif;																			// PAR #35874
			
			// MTN-36569 CO2 and O2 readings
			if strCO2.isRealJMT then
				co2ReadingParams.myTrackedItem := theProxyTI;
				co2ReadingParams.co2 := strCO2.Real;
				co2Params := co2ReadingParams;
			endif;
			if strO2.isRealJMT then
				o2ReadingParams.myTrackedItem := theProxyTI;
				o2ReadingParams.o2 := strO2.Real;
				o2Params := o2ReadingParams;
			endif;
			// MTN-36569 end of this bit
			
			while true do
				app.myTrxCA.trxCreateReeferReadings(tempParams, humidParams, ventParams, co2Params, o2Params, null, app.myPassport);	// MTN-36569
	
				if (not app.myPassport.trxCompletedOK) then
					result := app.showErrorWarningDialog('Temp Reading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors()
					and result = IDOK
					then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
					//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					return false;
				else
					self.clearErrorWarnings();
					break;
				endif;
			endwhile;
			delete theProxyTI;
		endif;
	endforeach;
	
	return true;
	
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete tempReadingParams;
	delete humidReadingParams;		// PAR #35874
	delete ventReadingParams;		// PAR #35874
	delete tempReadingParams;		// PAR #35874
	delete co2ReadingParams;		// MTN-36569
	delete o2ReadingParams;			// MTN-36569
	delete theProxyTI;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColour" id="deaea8be-b8c3-47cc-923e-82e04f63ff97">
        <source>getColour(_status: String): Integer;
//----------------------------------------------------------------
//	Created:	02 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
/*
	White;
	self.ColorGreenLight;
	LightRed;
*/
	if _status = Comm_Discon then
		return self.ColorGreenLight;
	elseif _status = Comm_Yes then
		return self.tblReefers.backColor;
	else
		return White;
	endif;
	
end;</source>
        <Parameter name="_status" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNote" id="eb5c21c1-a694-489d-a072-a5f5ebb74973">
        <updating/>
        <source>handleNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	30 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	event			: Integer;
	communucating	: Boolean;
	savedMPointer	: Integer;
begin
    //app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " got note " &amp; eventType.String);
	savedMPointer := app.mousePointer;
	app.mousePointer := MousePointer_HourGlass;
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = EVENT_REFCON_RESPONSE then
		//if CM_Container.hasInstance(theObject) then	// CCMS 1007
		if CM_TrackedItem.hasInstance(theObject) then	// CCMS 1007
			if userInfo.isKindOf(Boolean) then
				communucating := userInfo.Boolean;			
			else
				communucating := false;
			endif;
			//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; theObject.CM_Container.id &amp; " is comm = " &amp; communucating.getYesNo());
			self.requestsReturned := self.requestsReturned + 1;
			//self.updateReeferTableComm(theObject.CM_Container, communucating);	// CCMS 1007
			self.updateReeferTableComm(theObject.CM_TrackedItem, communucating);	// CCMS 1007
			self.setRequestLabel();
		endif;
	endif;


epilog
	endLoad;
	app.mousePointer := savedMPointer;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="ead8ea54-b44e-4fbc-b655-b6eb7ebb0d55">
        <updating/>
        <source>initForm()updating;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		OAR #3584 TFS 265 Form now does more than just temperature readings
// 16/01/2026	navdap1		MTN-36569 CPL | Reeefer Runner Integration
vars
begin
	//self.btnSaveBase.bubbleHelp := "Save entered temperatures";		// PAR #35874
	self.btnSaveBase.bubbleHelp := "Save entered readings";				// PAR #35874
	self.dataChanged := false;
	self.width := 835;				// MTN-36569
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblReefers" id="502eae5c-68a1-4069-bc2b-91e73bbea45d">
        <source>initTblReefers();
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added ventilation and humidity readings to form
// 18/07/2016	cnwns1 		TFS2333 Multi-timezone issues
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars

	localTS		: TimeStamp;
	inputCol	: JadeTableColumn;	
	ventType	: CM_MeasurementType;				// PAR #35874
begin
	localTS := self.systemToLocalTime(app.actualTimeServer);	// 18 July 2016	cnwns1	TFS2333
	self.txtDate.setDate(localTS.date());						// 18 July 2016	cnwns1	TFS2333
	self.txtTime.setTime(localTS.time());						// 18 July 2016	cnwns1	TFS2333

	self.tblReefers.clear;
	self.tblReefers.columns := COMM_COLUMN;
	
	inputCol := self.tblReefers.accessColumn(INPUT_COLUMN);
	inputCol.inputType := CM_DataTable.InputType_TextBox;
	inputCol.backColor := LightBlue;
	
	self.tblReefers.accessColumn(SET_COLUMN).alignment := CM_DataTable.Alignment_Right;
	self.tblReefers.accessColumn(LOC_COLUMN).alignment := CM_DataTable.Alignment_Center;
	self.tblReefers.accessColumn(LASTTEMP_COLUMN).alignment := CM_DataTable.Alignment_Right;
	self.tblReefers.accessColumn(INPUT_COLUMN).alignment := CM_DataTable.Alignment_Right;
	self.tblReefers.accessColumn(FAH_COLUMN).inputType := CM_DataTable.InputType_CheckBox;	//
//	self.tblReefers.accessColumn(COMM_COLUMN).visible := app.myRoot.canDo(PmRefCon);
	self.tblReefers.accessColumn(COMM_COLUMN).visible := app.myRoot.canDo(Mod_BaseSystem);	//07 Oct 2019	NDL	TFS 46169
	
	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).alignment := CM_DataTable.Alignment_Right;			// PAR #35874
	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).inputType := CM_DataTable.InputType_TextNumeric;	// PAR #35874
//	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).maxLength := 2;									// PAR #35874
	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).backColor := LightBlue;							// PAR #35874
	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).maxLength := 6;	//27 May 2020	NDL	- JBL Benchmark testing
	self.tblReefers.accessColumn(INPUT_HUMID_COLUMN).decimals := 2;		//27 May 2020	NDL	- JBL Benchmark testing
	
	self.tblReefers.accessColumn(INPUT_VENT_COLUMN).alignment := CM_DataTable.Alignment_Right;			// PAR #35874
	self.tblReefers.accessColumn(INPUT_VENT_COLUMN).inputType := CM_DataTable.InputType_TextNumeric;	// PAR #35874
	ventType := app.getDefaultMeasurementForType(Type_Displacement);									// PAR #35874
	self.tblReefers.accessColumn(INPUT_VENT_COLUMN).decimals := ventType.getDecimalPrecision;			// PAR #35874
	self.tblReefers.accessColumn(INPUT_VENT_COLUMN).maxLength := ventType.getDecimalPrecision + 5;		// PAR #35874	// MTN-36569
	self.tblReefers.accessColumn(INPUT_VENT_COLUMN).backColor := LightBlue;								// PAR #35874
	
	// MTN-36569 add CO2 and O2 columns
	self.tblReefers.accessColumn(INPUT_CO2_COLUMN).alignment := CM_DataTable.Alignment_Right;
	self.tblReefers.accessColumn(INPUT_CO2_COLUMN).inputType := CM_DataTable.InputType_TextNumeric;
	self.tblReefers.accessColumn(INPUT_CO2_COLUMN).decimals := 2;
	self.tblReefers.accessColumn(INPUT_CO2_COLUMN).maxLength := 5;
	self.tblReefers.accessColumn(INPUT_CO2_COLUMN).backColor := LightBlue;
	
	self.tblReefers.accessColumn(INPUT_O2_COLUMN).alignment := CM_DataTable.Alignment_Right;
	self.tblReefers.accessColumn(INPUT_O2_COLUMN).inputType := CM_DataTable.InputType_TextNumeric;
	self.tblReefers.accessColumn(INPUT_O2_COLUMN).decimals := 2;
	self.tblReefers.accessColumn(INPUT_O2_COLUMN).maxLength := 5;
	self.tblReefers.accessColumn(INPUT_O2_COLUMN).backColor := LightBlue;
	// MTN-36569 end
	
	self.tblReefers.fixedColumns := 0;
	self.tblReefers.rows := 1;
	self.tblReefers.fixedRows := 1;
	self.tblReefers.visible := true;
	self.tblReefers.stretchToParent := true;
	self.tblReefers.accessCell(1, 1).text :='Reefer ID'&amp;Tab&amp;
											'Set Temp.'&amp;Tab&amp;
											'Location'&amp;Tab&amp;
											'Last Reading'&amp;Tab&amp;
											'Current Temp.'&amp;Tab&amp;
											'Fahrenheit'&amp;Tab&amp;
											'Humidity'&amp;Tab&amp;																		// PAR #35874
											'Ventilation ' &amp; app.getDefaultMeasurementForType(Type_Displacement).shortName&amp;Tab&amp;	// PAR #35874
											'CO2 (%)' &amp; Tab &amp; 			// MTN-36569
											'O2 (%)' &amp; Tab &amp;			// MTN-36569
											'Comm. Status';
	
	self.tblReefers.sortAsc[1] := true;
	self.tblReefers.sortColumn[1] := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="7bcb49c6-98f2-4f3c-9019-e4d0426871d7">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	
begin
	inheritMethod();
	
	self.initForm();
	self.initTblReefers();
	
	self.loadReeferTable();
	
	self.frmToolbar.positionToolbarControls();
	self.frmToolbar.visible := true;
	self.height := self.height - 1;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadReeferTable" id="00dbabb5-df8d-48ec-886a-7c3688da4a97">
        <updating/>
        <source>loadReeferTable() updating;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//							Replace 'reefer' with 'ti'
// 22/04/2015	cnwdap1		PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements. Remove restriction that reefer
//							had to have been connected before you could record a temperature reading for it
vars
	idx		: Integer;
	//reefer	: CM_Container;		// CCMS 1007
	ti		: CM_TrackedItem;
begin
	foreach ti in self.allReefers do
		//reefer := ti.CM_Container;
		//if ti.getFirstConnectDT.isValid and ti.isAttributeTrue(TI_Attrib_RequiresTemperature) then	// PAR #36094
		if ti.isAttributeTrue(TI_Attrib_RequiresTemperature) then										// PAR #36094
			idx := self.tblReefers.addItem(self.tblReefersDisplayRow(ti));
			self.tblReefers.accessRow(idx).itemObject := ti;
			if self.commCheckMode = Comm_Check_Readings and ti.isConnected then
				self.updateReeferTableComm(ti, ti.hasRecentlyCommunicated);
			endif;
			self.tblReefers.accessedRow.backColor := self.getColour(self.tblReefers.getCellText(idx, COMM_COLUMN));
		endif;
	endforeach;


	self.sortTable(LOC_COLUMN);
	

//	self.tblReefers.displayCollection(self.allReefers,false,,null);


end;</source>
    </JadeMethod>
    <JadeMethod name="resetTableReefers" id="472d8cc2-ee3e-4846-8726-6920b654c4d7">
        <source>resetTableReefers();
//----------------------------------------------------------------
//	Created:	02 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// 18/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements - if etmp was entered in F, show it in F
// 18 July 2016	cnwns1 		TFS2333 Multi-timezone issues

vars
//	inputCol	: JadeTableColumn;

	localTS		: TimeStamp;
	//reefer	: CM_Container;		// CCMS 1007
	reefer		: CM_TrackedItem;	// CCMS 1007
	intRow		: Integer;
	tempText	: String;	
	inF			: Boolean;
begin
	localTS := self.systemToLocalTime(app.actualTimeServer);	// 18 July 2016	cnwns1	TFS2333
	self.txtDate.setDate(localTS.date());						// 18 July 2016	cnwns1	TFS2333
	self.txtTime.setTime(localTS.time());						// 18 July 2016	cnwns1	TFS2333
	
//	inputCol := self.tblReefers.accessColumn(INPUT_COLUMN);
//	inputCol.backColor := LightBlue;
	
	foreach intRow in self.tblReefers.fixedRows+1 to self.tblReefers.rows do
		//reefer := self.tblReefers.accessRow(intRow).itemObject.CM_Container;	// CCMS 1007
		reefer := self.tblReefers.accessRow(intRow).itemObject.CM_TrackedItem;	// CCMS 1007
		inF := self.tblReefers.accessCell(intRow, self.FAH_COLUMN).text.asBooleanJMT;				// PAR #31155
		tempText := self.tblReefers.accessCell(intRow, INPUT_COLUMN).text;
		self.tblReefers.accessedCell.backColor := LightBlue;
		if tempText &lt;&gt; Str_EnterTemp then
			if inF then																			// PAR #31155
				self.tblReefers.accessedCell.text := app.temperatureConversion(true, reefer.getTemperature).String;	// PAR #31155
			else																				// PAR #31155
				self.tblReefers.accessedCell.text := reefer.getTemperature.String;
			endif;																				// PAR #31155
		endif;
		tempText := self.tblReefers.accessCell(intRow, COMM_COLUMN).text;
		if tempText = Comm_Yes or tempText = Comm_Discon then
			self.tblReefers.accessCell(intRow, INPUT_COLUMN).text := Str_EnterTemp;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="03f39a0e-f0e5-44f3-aeea-26e7ca9d3401">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpBackColor 	:	Integer;
	tmpControlBack	:	Integer;
	tmpHeadingColor	:	Integer;
	
begin
	inheritMethod(_colorControl);

	tmpBackColor 	:= self.backColor;
	tmpControlBack	:= self.colorControlBack;
	tmpHeadingColor	:= self.colorHeadingColumn;
	
	self.tblReefers.backColor 		:= tmpControlBack;
	
	self.tblReefers.accessRow(1).backColor 		:= tmpHeadingColor;
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setForSetup" id="313cf68e-7703-4a81-a2dc-27711d0db71c">
        <updating/>
        <source>setForSetup(_terminal: CM_Terminal) updating;
//----------------------------------------------------------------
//	Created:	25 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS 1007 Any tracked item can now be a reefer, not just containers
vars
	reefer : CM_TrackedItem;
begin
	self.setMyTerminal(_terminal);
	
	if self.commCheckMode = Comm_Check_Readings then
		self.lblRequests.visible := false;
		return;
	endif;
	
	self.lblRequests.visible := true;
	
	foreach reefer in self.allReefers do
		//if reefer.CM_Container.getFirstConnectDT.isValid and reefer.isAttributeTrue(TI_Attrib_RequiresTemperature) then	// CCMS 1007
		if reefer.CM_TrackedItem.getFirstConnectDT.isValid and reefer.isAttributeTrue(TI_Attrib_RequiresTemperature) then	// CCMS 1007
			beginNotification(reefer,self.myTerminal.getTerminalEvent(EVENT_REFCON_RESPONSE), Response_Cancel, 0);
			self.requestsSent := self.requestsSent + 1;
		endif;
	endforeach;

epilog
	self.setRequestLabel();
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setRequestLabel" id="1ad6a149-f772-4b3e-a7a2-ae9f8f172beb">
        <source>setRequestLabel();
//----------------------------------------------------------------
//	Created:	05 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.lblRequests.caption := app.getErrorString(Requests_Outstanding) &amp; (self.requestsSent - self.requestsReturned).String;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ebb80825-5c0c-45db-af40-5669bb2d98ee">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();

	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	self.btnSave.visible := false;
	if self.myTerminal.getConfig(ChargeFirstTemperatureOnly).Boolean then
		//setting this value will have no effect so disable it
		self.chkNoCharge.enabled := false;
	endif;
	
	/* epr 32714 3/12/13 - terminal config never used removing
	if self.myTerminal.getConfig(TempFahForFahOperator).Boolean then
		self.tempFahIfOperatorFah := true;
	endif;*/
	
	self.addToolbarControls();

end;</source>
    </JadeMethod>
    <JadeMethod name="sortTable" id="da3bc22a-6c9e-4467-8a14-82913729698b">
        <source>sortTable(_col: Integer);
//----------------------------------------------------------------
//	Created:	27 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _col &lt; 1 or _col &gt; self.tblReefers.columns then
		return;
	endif;
	
	self.tblReefers.sortColumn[1] := _col;    
	self.tblReefers.sortAsc[1]    := true;
	self.tblReefers.sortCased[1]  := false;
	self.tblReefers.resort;

epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblReefersDisplayRow" id="11065a45-aa6a-44fd-90b8-eb413697d56b">
        <source>tblReefersDisplayRow(_reefer : CM_TrackedItem /*_container: CM_Container*/): String;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	//cont		: CM_Container;		// CCMS 1007
	reef		: CM_TrackedItem;	// CCMS 1007
	defTemp		: String;
	dispTemp	: String;
	defComm		: String;
	fah			: Integer;
	displayF	: Boolean;	
begin
	//cont := _container;	// CCMS 1007
	reef := _reefer;		// CCMS 1007
	
	// epr 32714 3/12/13 terminal config never used always look from ti operator
	displayF :=  reef.displayTempFahrenheit;
	
	if displayF then
		dispTemp := reef.getDisplayTemperature(false, false);
	else
		dispTemp := reef.getDisplayTemperature(false, true);
	endif;
	
	if dispTemp = null or (not reef.isConnected) then
		defTemp := Str_EnterTemp;
		if reef.isConnected then
			defComm := Comm_Conn;
		else
			defComm := Comm_Discon;
		endif;
	else
		if displayF then
			defTemp := _reefer.temperatureInFahrenheit.String;
			fah := true.Integer;
		else
			defTemp := _reefer.getTemperature.String;
			fah := false.Integer;
		endif;
		defComm := Comm_Conn;
	endif;				

															
	return reef.id &amp; Tab &amp; 
			dispTemp &amp; Tab &amp;
			reef.locationId &amp; Tab &amp;
			reef.getLastTempReadingStr(not displayF) &amp; Tab &amp;
			defTemp &amp; Tab &amp;
			fah.String &amp; Tab &amp; 
			reef.getLastHumidityReadingStr &amp; Tab &amp; 					// PAR #35874
			reef.getLastVentilationReadingStr &amp; Tab &amp;				// PAR #35874
			reef.getLastCO2ReadingStr &amp; Tab &amp; 				// MTN-36569
			reef.getLastO2ReadingStr &amp; Tab &amp; 				// MTN-36569
			defComm;
end;</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblReefers_click" id="aa90098a-637a-4546-9b96-f11ce5392bf8">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added ventilation and humidity columns
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
	cell	: JadeTableCell;
	row		: JadeTableRow;
	txtBox	: TextBox;
begin
	if table.column.isOneOf(INPUT_COLUMN, INPUT_HUMID_COLUMN, INPUT_VENT_COLUMN, INPUT_CO2_COLUMN, INPUT_O2_COLUMN) then	// MTN-36569
		cell := table.accessCell(table.row, table.column);
		row := table.accessRow(table.row);
		if row.itemObject &lt;&gt; null then
			self.dataChanged := true;
			cell.backColor := LightYellow;
			if cell.cellControl &lt;&gt; null and cell.cellControl.isKindOf(TextBox) then
				txtBox := cell.cellControl.TextBox;
				txtBox.selStart := 0;
				txtBox.selLength := -1;
			endif;  
			
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblReefers_dblClick" id="04a52a91-4606-405c-aa2d-0127038a865c">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_dblClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	27 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	col : Integer;
begin
	col := table.column;
	if self.tblReefers.row = 1 then
		self.sortTable(col);
	else
		//
	endif;


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblReefers_keyUp" id="d7dad958-d139-4115-bafa-f42e02b1a326">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if keyCode = 40 or keyCode = 38 then
		self.tblReefers_click(self.tblReefers);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6c08d205-5cba-4f19-9117-def03296ed28">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008396, locale);
	btnSave.translateCaption(Xlat_0004196, locale);
	btnSaveAndClose.translateBubbleHelp(Xlat_0004192, locale);
	btnSaveAndClose.translateCaption(Xlat_0004193, locale);
	chkNoCharge.translateCaption(Xlat_0004197, locale);
	lblReadingDate.translateCaption(Xlat_0004194, locale);
	lblReadingTime.translateCaption(Xlat_0004195, locale);
	lblRequests.translateCaption(Xlat_0004198, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtDate_lostFocus" id="8f59399c-d314-45fd-b8cb-dce74d748359">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDate_lostFocus(editMask: JadeEditMask input) updating;
//----------------------------------------------------------------
//	Created:	23 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	date	: Date;
	today	: Date;
begin

	date := editMask.CMUI_DateMask.getDate();
	
	if date.isValid then
		if editMask.CMUI_DateMask.getDate() &lt;&gt; date then
			editMask.setTextFromDate(date);
		endif;	
	else 
		if not editMask.CMUI_DateMask.getDate().isValid then
			editMask.setTextFromDate(today);
		endif;
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateReeferTableComm" id="11bb08f8-efbd-4268-a9a0-6ab4f50314e0">
        <source>updateReeferTableComm(_reefer: CM_TrackedItem/*CM_Container*/; _communicating: Boolean);
//----------------------------------------------------------------
//	Created:	30 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	rowIdx		: Integer;
	commStatus	: String;
begin

	if self.tblReefers.findObjectInRow(_reefer, rowIdx) then
		if _communicating then
			commStatus := Comm_Yes;
			if self.tblReefers.accessCell(rowIdx, INPUT_COLUMN).backColor &lt;&gt; LightYellow then
				self.tblReefers.accessCell(rowIdx, INPUT_COLUMN).text := Str_EnterTemp;
			endif;
			self.tblReefers.accessCell(rowIdx, COMM_COLUMN).text := Comm_Yes;
		else
			commStatus := Comm_No;
			self.tblReefers.accessCell(rowIdx, COMM_COLUMN).text := Comm_No;
		endif;
		self.tblReefers.accessRow(rowIdx).backColor := self.getColour(commStatus);	
		//global.beep;
	endif;
end;</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <Parameter name="_communicating" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="b5e49bef-66f5-4279-9d36-9f74c724bdfc">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	30 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.handleNote(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
