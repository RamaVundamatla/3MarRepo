    <JadeMethod name="translateForm" id="8e91fd99-b05e-45c9-a264-15c4734b8c12">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 May 2023 13:45:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022923, locale);
	btnAdd.translateCaption(Xlat_0019135, locale);
	btnAddSub.translateBubbleHelp(Xlat_0026077, locale);
	btnAddSub.translateCaption(Xlat_0026078, locale);
	btnAudits.translateCaption(Xlat_0022176, locale);
	btnClose.translateCaption(Xlat_0019136, locale);
	btnDelete.translateCaption(Xlat_0019137, locale);
	btnEdit.translateCaption(Xlat_0019138, locale);
	lblCriteria.translateCaption(Xlat_0019139, locale);
	lblGroup.translateCaption(Xlat_0019140, locale);
//	lblInvLine.translateCaption(Xlat_0019141, locale);
	mnuContext.translateCaption(Xlat_0021142, locale);
	mnuInspect.translateCaption(Xlat_0021143, locale);
end;</source>
    </JadeMethod>
</GUIClass>
