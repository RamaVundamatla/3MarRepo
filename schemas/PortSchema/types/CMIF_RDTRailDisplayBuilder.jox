    <JadeMethod name="getDefaultDisplayMode" id="544ae753-b551-4372-9e39-3cff78f7f169">
        <source>getDefaultDisplayMode(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwjk3	Initial creation

*/

vars

	topDown : Boolean;
	faceView : Boolean;

begin

	//10 Feb 2012	NDL	Par 29108
	if self.myRTVehicleConfig &lt;&gt; null then
		faceView := self.myRTVehicleConfig.canDisplayFaceView;
		topDown := self.myRTVehicleConfig.canDisplayTopDownView;
	endif;

	if topDown then
		return CMIF_RDTDrawElement.MODE_TOPDOWN;
	elseif faceView then
		return CMIF_RDTDrawElement.MODE_FACE;
	else
		return CMIF_RDTDrawElement.MODE_TOPDOWN;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGridLocation" id="4547bd31-abf4-435c-89aa-b05566ca5e5b">
        <source>getGridLocation(_lc: CM_LocationsController): CMIF_RDTGridLocation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwndl1	Initial creation

*/

vars

	key : String;
	gridLocation : CMIF_RDTGridLocation;

begin

	if _lc.isBoxcarCont then
		key := _lc.getOidAsString();
		gridLocation := self.getObjectForKey(self.allBoxcarLoadPositions, key).CMIF_RDTGridLocation;
		if gridLocation &lt;&gt; null then
			return gridLocation;
		endif;
	endif;
	
	return inheritMethod(_lc);

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="CMIF_RDTGridLocation"/>
    </JadeMethod>
