    </JadeMethod>
    <JadeMethod name="cnEcAge" id="5358522a-c85f-4421-8d2d-bb3688a64115">
        <source>cnEcAge():Decimal;
// Determines the age - i.e. the time between the TimeStamp and now.
// Returns the age in milliseconds.
vars
	now	: TimeStamp;
	age	: Decimal[23,1];

begin
	if now &gt;= self then
		age := now.cnEcDiff(self);
	else
		age := self.cnEcDiff(now);
	endif;

	return age;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcAgeInDays" id="d4e8771e-c268-4290-b828-7cfd586f66a8">
        <source>cnEcAgeInDays():Integer;

begin
	return (self.cnEcAge() div Milliseconds_In_Day).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcDiff" id="09b4cd84-54a1-43c1-8d82-7de7e21424bb">
        <source>cnEcDiff(pTimeStamp:TimeStamp):Decimal;
// Calculates the difference between two timestamp values and returns "days" and
// time difference in milliseconds.  The value returned will be positive (always
// taking the smaller value from larger value).
vars
	dateFrom		: Date;
	dateTo			: Date;
	timeFrom		: Time;
	timeTo			: Time;
	daysDifference	: Integer;

begin
	// Make sure we take the smaller value from the larger.

    if self &gt; pTimeStamp then
 		dateFrom	:=	self.Date;
		dateTo		:=	pTimeStamp.Date;

	   	timeFrom	:=	self.Time;
		timeTo		:=	pTimeStamp.Time;
	else
		dateTo		:=	self.Date;
		dateFrom	:=	pTimeStamp.Date;

	   	timeTo		:=	self.Time;
		timeFrom	:=	pTimeStamp.Time;
	endif;

	daysDifference	:=	dateFrom - dateTo;         						// Get the difference in dates.

	// [DvA19990127] added .Decimal to be able to calculate with differences larger than 24 days.....
	// .... also changed the returned datatype from Integer to Decimal.
	// cnwdad1 03/12/2001 - Changed to cast the Milliseconds_In_Day to a decimal.
//	return  (Milliseconds_In_Day * daysDifference).Decimal + 			// days component
//			(timeFrom - timeTo).Decimal;								// and time
	return  (Milliseconds_In_Day.Decimal * daysDifference.Decimal) + 	// days component
			(timeFrom - timeTo).Decimal;								// and time
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcEncrypt" id="49019194-f5cc-43c7-8066-9084883339ef">
        <source>cnEcEncrypt():String;
// Encrypts the receiver and returns the value as a string.
//
// NOTE: If the date is less than EncryptBaseDate, then the decryption
// will not match the date supplied here - this is deliberate. The date
// time should be current in which case the decryption will be correct.
vars
	theDate				: Date;
	theTime				: Time;
	dateInteger			: Integer;
	timeInteger			: Integer;
	returnString		: String;
	positionOfRandom	: Integer;
	lengthOfRandom		: Integer;
	randomSubstring		: String;

begin
	// Split the current date and time.
	theDate	:=	self.date;
	theTime	:=	self.time;

	// Get the integer differnces from the base date and time.
	if theDate &lt; ENCRYPTBASEDATE then
		dateInteger	:=	0;
	else
		dateInteger	:=	theDate - ENCRYPTBASEDATE;
	endif;

	timeInteger	:=	theTime - ENCRYPTBASETIME;

	// Build the initial return string.
	returnString	:=	dateInteger.cnEcPad(6) &amp; timeInteger.String;

	// Generate the position of the random insert string (also random).
	if returnString.length &lt; 9 then
		positionOfRandom	:=	app.random(returnString.length);
	else
		positionOfRandom	:=	app.random(9);
	endif;

	// Generate the length of the random insert string (also random).
	lengthOfRandom	:=	app.random(6);

	// Generate the random string - if no length then null is also valid.
	if lengthOfRandom &gt; 0 then
		randomSubstring	:=	app.random('999999'[1:lengthOfRandom].Integer).cnEcPad(lengthOfRandom);
	endif;

	// Insert rand at the required position.
	if positionOfRandom &gt; 1 then
		if positionOfRandom &lt; returnString.length then
			returnString	:=	returnString[1:positionOfRandom - 1] &amp; randomSubstring &amp; returnString[positionOfRandom:end];
		else
			returnString	:=	returnString &amp; randomSubstring;
		endif;
	else
		returnString	:=	randomSubstring &amp; returnString;
	endif;

	// Put the posRand and lenRand at the start of the return string
	// and return the result.

	return positionOfRandom.cnEcPad(1) &amp; lengthOfRandom.cnEcPad(1) &amp; returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcEstimatedEndTime" id="5421cdda-10c6-4b3e-bc1e-3468e024868c">
        <source>cnEcEstimatedEndTime(pStartTime:TimeStamp; pTotalParts:Integer; pPartsDone:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		27 February 2003 by cnwdad1
//
// Purpose:		Estimates the completion time of a number of job parts, based upon
//				the total number of parts to do, and the number of parts that are
//				already done.
//
// Parameters:	pStartTime - The time that the processing began.
//				
//
// Returns:		The estimated timestamp for when the job will be completed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elapsedMilliSeconds	: Decimal[23,0];
	estTotalElapsed		: Decimal[23,0];
	returnTime			: Time;
	returnTimestamp		: TimeStamp;
	plusDays			: Integer;
	plusHours			: Integer;
	plusMins			: Integer;
	plusSecs			: Integer;
	
begin
	elapsedMilliSeconds	:=	self.cnEcMillisecondsSince(pStartTime);
	estTotalElapsed		:=	(elapsedMilliSeconds / pPartsDone) * pTotalParts;
	
	if estTotalElapsed &gt;= 86400000 then
		plusDays		:=	(estTotalElapsed / 86400000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 86400000;
	endif;
	
	if estTotalElapsed &gt;= 3600000 then
		plusHours		:=	(estTotalElapsed / 3600000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 3600000;
	endif;
	
	if estTotalElapsed &gt;= 60000 then
		plusMins		:=	(estTotalElapsed / 60000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 60000;
	endif;
	
	if estTotalElapsed &gt;= 1000 then
		plusSecs		:=	(estTotalElapsed / 1000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 1000;
	endif;
	
	returnTime.setTime(	pStartTime.Time.hour,
						pStartTime.Time.minute,
						pStartTime.Time.second,
						00);
	
	if plusSecs &gt; 0 then
		if plusSecs + returnTime.second &gt; 60 then
			plusMins	:=	plusMins + 1;
			plusSecs	:=	(plusSecs + returnTime.second) - 60;
		endif;
	endif;  
	
	if plusMins &gt; 0 then
		if plusMins + returnTime.minute &gt; 60 then
			plusHours	:=	plusHours + 1;
			plusMins	:=	(plusMins + returnTime.minute) - 60;
		endif;
	endif;
	
	returnTime.setTime(	returnTime.Time.hour,
						plusMins + returnTime.Time.minute,
						plusSecs + returnTime.Time.second,
						00);
	
	returnTimestamp.setTime(returnTime);
	returnTimestamp.setDate(pStartTime.Date); 
	
	if plusHours &gt; 0 then
		returnTimestamp	:=	returnTimestamp.cnEcAddHours(plusHours);
	endif;
	
	if plusDays &gt; 0 then
		returnTimestamp	:=	returnTimestamp.cnEcAddDays(plusDays);
	endif;
	
	return returnTimestamp;
end;</source>
        <Parameter name="pStartTime" type="TimeStamp"/>
        <Parameter name="pTotalParts" type="Integer"/>
        <Parameter name="pPartsDone" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetBeginningOfMonth" id="174319d0-c107-459e-8e06-c2edcb54f66e">
        <source>cnEcGetBeginningOfMonth() : TimeStamp;
/*

Date		    Who			Reason
05 October 2010	cnwas3	  Initial creation

*/

vars
	date : Date;
	time : Time;
	ts : TimeStamp;
begin
	ts := self;
	date.setDate(1,self.date.month(),self.date.year());
	time.setTime(0,0,0,0);
	ts.cnEcSetDateAndTime(date,time);
	return ts;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGreaterThan" id="5d0ed5f6-ede1-4408-b128-2e4850f280fe">
        <source>cnEcIsGreaterThan(pTimeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		06 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is greater
//				than the specified timestamp.
//
// Parameters:	pTimeStamp - The tmestamp to compare the receiver to.
//
// Returns:		True if the receiver is greater than the specified timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &gt; pTimeStamp.date then
		return true;
		
	elseif self.date = pTimeStamp.date and self.time &gt; pTimeStamp.time then
		return true;
		
	endif;

	return false;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGreaterThanOrEqual" id="18af2be4-33fb-41bb-abe4-1278dee1c5e1">
        <source>cnEcIsGreaterThanOrEqual(pTimeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		06 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is greater
//				than or equal the specified timestamp.
//
// Parameters:	pTimeStamp - The timestamp to compare the receiver to.
//
// Returns:		True if the receiver is greater than or equal to the specified
//				timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &gt; pTimeStamp.date then
		return true;
		
	elseif self.date = pTimeStamp.date and self.time &gt;= pTimeStamp.time then
		return true;
		
	endif;

	return false;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLessThan" id="00f6847c-718c-4145-af6a-580bef8cc212">
        <source>cnEcIsLessThan(pTimeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		06 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is less
//				than the specified timestamp.
//
// Parameters:	pTimeStamp - The timestamp to compare the receiver to.
//
// Returns:		True if the receiver is less than the specified timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt; pTimeStamp.date then
		return true;
		
	elseif self.date = pTimeStamp.date and self.time &lt; pTimeStamp.time then
