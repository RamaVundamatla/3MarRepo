    <JadeMethod name="getDisplayStringForAttribute" id="2f0c756b-876f-4420-a4ce-09d7e9292114">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
20 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

vars
	persist : CM_ResourceTypeUsage;
begin

	if _attrName = ETRow_Resource then
		if self.myResourceType = null then
			return null;
		else
			return self.myResourceType.description;
		endif;
		
	elseif _attrName = ETRow_Quantity then
		return self.quantity.asStringJMTWithPrecision(self.myResourceType.decimalPlaces,false);  //cnwrd1 par 23800 22.4.2010
		//return self.quantity.asStringJMT;
		
	elseif _attrName = ETRow_Units then
		if self.myResourceType = null then
			return null;
		else
			return self.myResourceType.unitDescription;
		endif;
		
	elseif _attrName = ETRow_NoCharge then
		return self.noCharge.asStringJMT;
		
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
		
	elseif _attrName = ETRow_Status then
		return self.getStatusString;
		
	elseif _attrName = ETRow_Identifier then
		if myTransaction = null or not myTransaction.hasAudits then	//14 Jan 2021	NDL	TFS 50152
			return null;
		else
			if self.isTransient then
				persist := self.pxyGetRealObject();
				if persist = null then
					return null;
				else
					return persist.identifier();
				endif;
			else
				return self.identifier();
			endif;
		endif;
		
	elseif _attrName = ETRow_IsStoreOnPallet then	//18 Apr 2017	NDL	TFS 3414
		return self.isStoreOnPallet.asStringJMT;
		
	elseif _attrName = ETRow_IsHeatTreated then	//18 Apr 2017	NDL	TFS 3414
		return self.isHeatTreated.asStringJMT;
		
	elseif _attrName = ETRow_PalletType then	//18 Apr 2017	NDL	TFS 3414
		return self.getPalletType;	//20 Apr 2017	NDL	TFS 3414
	
	elseif _attrName = ETRow_IsAutoApply then						//20.12.2023 navlc30 #60748
		return isAutoApplyResourceUsage.asStringJMT;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
