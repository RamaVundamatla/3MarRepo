    <JadeMethod name="isCMIFDataMatch" id="f92ab2c8-0026-4af1-8881-ba6cebc32bc7">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	return _yaData.value = null or _cmifAutoPlan.isVehicleYear_Match(_yaData);

epilog

end;</source>
