    <JadeMethod name="tablePopulate" id="99944fd9-34e0-4023-a0a9-da21c4674590">
        <source>tablePopulate() protected;
// --------------------------------------------------------------------------------
// Created:		15 March 2006 by cnwdad1
//
// Purpose:		Populates the table with the BaseSchema hex colors.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	HEX_COLOR_CAT	: String = "CnEcHex_Colors";
	
vars
	allConstants	: ConstantNDict;
	constantObj		: Constant;
	cellObj			: JadeTableCell;
	tableObj		: Table;
	rowPointer		: Integer;
	colPointer		: Integer;
	hexValue		: String;
	colorValue		: Integer;
	reverseColor	: Integer;
	colorRed		: Integer;
	colorGreen		: Integer;
	colorBlue		: Integer;
	stringObj		: CnEcString;
	
begin
	if not global.cnEcGetConstants(HEX_COLOR_CAT, allConstants) then
		write "Didn't find any constants!";
		return;
	endif;
	
	tableObj	:=	tblColors;
	tableObj.alignment	:=	Table.Alignment_Center;
	rowPointer	:=	1;
	colPointer	:=	1;
	
	if allConstants &lt;&gt; null and (allConstants.cnEcIsNotEmpty()) then
		foreach constantObj in allConstants do
			hexValue			:=	constantObj.getSource();
			
			create stringObj transient;
			stringObj.updateMe(hexValue);
			
			hexValue			:=	hexValue.cnEcRemoveSubstring("#");
			hexValue			:=	hexValue.cnEcRemoveSubstring('"');
			colorValue			:=	hexValue.cnEcHexValue();
			
			// I'm not sure why this is, but the hex color value has the red and blue
			// back-to-front, i.e. BGR instead of RGB, so we'll just swap them around
			// to render the correct color.
			
			colorValue.cnEcGetRGBValues(colorRed, colorGreen, colorBlue);
			colorValue.cnEcSetColorFromRGB(colorBlue, colorGreen, colorRed);
			reverseColor		:=	colorValue.cnEcGetReverseColor();
			
			cellObj				:=	tableObj.accessCell(rowPointer, colPointer);
			cellObj.text		:=	constantObj.name[10:end];
			cellObj.backColor	:=	colorValue;
			cellObj.foreColor	:=	reverseColor;
			cellObj.itemObject	:=	stringObj;

			colPointer	:=	colPointer + 1;
			
			if colPointer &gt; tableObj.columns then
				colPointer	:=	1;
				rowPointer	:=	rowPointer + 1;
				
				if rowPointer &gt; tableObj.rows then
					tableObj.rows	:=	tableObj.rows + 1;
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblColors_rowColumnChg" id="fb88423b-bbc4-460c-8a9d-a1944dd84636">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblColors_rowColumnChg(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		31 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	cellObj			: JadeTableCell;
	rgbDisplay		: String;
	rowPointer		: Integer;
	colPointer		: Integer;
	colorRed		: Integer;
	colorGreen		: Integer;
	colorBlue		: Integer;
	
begin
	tableObj	:=	tblColors;
	rowPointer	:=	tableObj.row;
	colPointer	:=	tableObj.column;
	
	if rowPointer &gt; tableObj.fixedRows and rowPointer &lt;= tableObj.rows then
		cellObj		:=	tableObj.accessCell(rowPointer, colPointer);
		lblColor.cnEcSet(cellObj.backColor.String);
		cellObj.backColor.cnEcGetRGBValues(colorRed, colorGreen, colorBlue);
		rgbDisplay	:=	colorRed.String &amp; " " &amp; colorGreen.String &amp; " " &amp; colorBlue.String;
		lblRGB.cnEcSet(rgbDisplay);
		lblHex.cnEcSet(cellObj.itemObject.CnEcString.stringValue);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="f03720cd-4bf6-49b7-a4bd-48c9a229b05c">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	tblColors.cnEcClearAllCellObjects(true);
end;</source>
    </JadeMethod>
</GUIClass>
