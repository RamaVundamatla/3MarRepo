    <JadeMethod name="zGetAllExtraDataXSD" id="b7be8f0b-90e4-4d17-8a95-7eced0e62517">
        <source>zGetAllExtraDataXSD( xsdString : String io; xmlSample : String io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2017	cnwndl1	Initial creation	TFS 4331
08 Aug 2023	jlirs1	TFS 59187 (59019) EUP
08 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
*/

vars
	type : Type;
	fieldName : String;
	exampleValue : String;
begin
	inheritMethod(xsdString,xmlSample);
	
	fieldName := ETRow_SalesOrderNbr;
	type := String;
	exampleValue := "12345";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";

	fieldName := ETRow_ContainerNumberText;		//08 Aug 2023	jlirs1	TFS 59187 (59019) EUP
	type := String;
	exampleValue := "Container Number Text";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";

	fieldName := ETRow_PortOfOrigin;		//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
	type := String;
	exampleValue := "NZAKL";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";
epilog

end;</source>
        <Parameter name="xsdString" type="String" usage="io"/>
        <Parameter name="xmlSample" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zGetExtraItemFields" id="599d6380-2fda-4c7a-9014-95024b402378">
        <source>zGetExtraItemFields( _fields: CM_FieldByTypeSysNameDict input; _fieldClass: Class );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2017	cnwndl1	Initial creation	TFS 4331
08 Jul 2023	jlirs1	TFS 59187 (59019) EUP
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
*/

vars

	field : CM_EDIItemField;
	type : Type;
	fieldName : String;

begin

	inheritMethod( _fields, _fieldClass );

	fieldName := ETRow_SalesOrderNbr;
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);
	
	fieldName := ETRow_ContainerNumberText;		//08 Aug 2023	jlirs1	TFS 59187 (59019) EUP
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);

	fieldName := ETRow_PortOfOrigin;		//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);

epilog

end;</source>
        <Parameter name="_fields" type="CM_FieldByTypeSysNameDict" usage="input"/>
        <Parameter name="_fieldClass" type="Class"/>
    </JadeMethod>
</Class>
