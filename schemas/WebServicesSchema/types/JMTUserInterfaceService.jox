    <JadeWebServicesMethod name="getVesselLOLODefinitions" id="b1c28202-87af-43c7-a9f8-833f4c460c13">
        <source>getVesselLOLODefinitions(request :WS_VesselLOLODefnsRequest) : WS_VesselLOLODefnsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2013	cnwer1	Initial creation 
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	response : WS_VesselLOLODefnsResponse;
	completedOK : Boolean;
	iter : Iterator;
	vessel : CM_CellularVesselStructure;
	wsVessel  : WS_VesselDefn;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmShipBayDefView);		// Replace with appropriate permission
	
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	iter:=app.myRoot.allVesselCellularStructures.createIterator;
	
	while iter.next(vessel) do
		if not vessel.allBaysByOrdinal.isEmpty then
			continue;
		endif;
		create wsVessel transient;
		wsVessel.code:=vessel.myVessel.code;
		wsVessel.name:=vessel.myVessel.name;
		wsVessel.numDefined := vessel.numSlotsDefined;
		wsVessel.numExpected := vessel.numSlotsExpected;
		wsVessel.use40BayIds := vessel.use40Id;
		wsVessel.useBayCellTier := vessel.useBayCellTierNumbering;
		response.allVessels.add(wsVessel);
	endwhile;
	// Perform validation, start populate response
	// ....	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete iter;		//08.01.2026 navma1 #MTN-36897
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_VesselLOLODefnsRequest"/>
        <ReturnType type="WS_VesselLOLODefnsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVesselSchedule" id="144d8b6d-96be-4667-9c88-5cf6ee073533">
        <source>getVesselSchedule(request : WS_VesselScheduleRequest) : WS_VesselScheduleResponse webService;
/*

Purpose:		Display vessel info to the guest or logged in user	

Parameters:			

Return Value:		

Date				Who		Reason
13 Sep 2017	jlgam15	To display shipping/vessel schedules to public
14 Dec 2018 jlger1	TFS 42346 - pelindo want some advanced search fields 
4/09/2019 	JLGNS1	Bug 46392: PEN - JMT TEST Web Apps
14 Sept 2022 navvt20 Bug 52711: MTN - Web Portal Voyages created after a future voyage not showing
21 Jul 2023	jlizm1	TFS 56327 dates not filtering correctly when searching by vessel
*/

vars
	response		: WS_VesselScheduleResponse;
	completedOK		: Boolean;
	iter			: Iterator;
	voyage			: CM_Voyage;
	proxyShipping	: WS_VesselSchedule;
	departedTS		: TimeStamp;
	scheduledTS		: TimeStamp;
	now				: TimeStamp;
	departedHours	: Integer;
	scheduledHours 	: Integer;
	failedDAC  		: CM_DataAccessController;
	arrivalDict		: CM_VoyageByArrivedDTCodeDict;
	vessel 			: CM_Vessel;
	fromDate,
	toDate 			: Date;
	time 			: Time;
	showArchived    : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//new permission for vessel schedule
	app.checkCurrentUserHasAccess(PmWebVesselSchedule);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	create arrivalDict transient;
	departedTS:=null;
	scheduledTS:=null;
	fromDate := request.filterDateFrom.asDateFromWebInterface();
	toDate := request.filterDateTo.asDateFromWebInterface();
	if fromDate &lt;&gt; null then
		departedTS.setDate(fromDate);
		time.setTime(0,0,0,0);
		departedTS.setTime(time);
		showArchived:=true;
	endif;
	if toDate &lt;&gt; null then
		scheduledTS.setDate(toDate);
		time.setTime(23,59,59,59);
		scheduledTS.setTime(time);
	endif;	
	
	if request.filterVessel &lt;&gt; null then
		vessel:=app.myPassport.getObjectOfTypeFromOid(request.filterVessel,CM_Vessel).CM_Vessel;
		
		if vessel = null then
			vessel:=app.myRoot.allVessels[request.filterVessel];
			
			if vessel = null then
				completedOK := true;
				return response;
			endif;
		endif;
			
		iter := vessel.allVoyagesByTermCodeArrival.createIterator();
		 vessel.allVoyagesByTermCodeArrival.startKeyGeq(app.myPassport.myTerminal,null,null,iter);
		while iter.next(voyage) do
			if voyage.myTerminal &lt;&gt; app.myPassport.myTerminal then
				break;
			endif;
			if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
				continue;
			endif;
			
			if departedTS &lt;&gt; null then
				if voyage.departedDT  &lt; departedTS then
					continue;
				endif;
			endif;
			if scheduledTS &lt;&gt; null then
				if voyage.arrivedDT &gt; scheduledTS then
					continue;
				endif;				
			endif;			
			
			arrivalDict.add(voyage);
		endwhile;
		delete iter;
	
		
	
	elseif request.filterVoyage &lt;&gt; null then

		voyage := app.myPassport.myTerminal.allVoyagesByCode.getAtKeyGeq(request.filterVoyage,null);
		
		//the above look-up always return anything that matches from and after '_voyageCode'
		//hence, ensure the code always matches the passed-in code
		if voyage &lt;&gt; null and voyage.code &lt;&gt; request.filterVoyage then
			voyage := null;
		endif;
		
		if voyage = null then //lets try all upper jlier1 TFS 64552
			voyage := app.myPassport.myTerminal.allVoyagesByCode.getAtKeyGeq(request.filterVoyage.toUpper(),null);
			if voyage &lt;&gt; null and voyage.code &lt;&gt; request.filterVoyage.toUpper() then
				voyage := null;
			endif;
		endif;
		//epr TFS 41310 13/10/18
		if voyage = null then
			voyage:=app.myPassport.getObjectOfTypeFromOid(request.filterVoyage,CM_Voyage).CM_Voyage;
		endif;
		
		if voyage = null then
			//app.raiseCMException1(Voyage_not_found,request.filterVoyage,null,null);
			completedOK := true;
			return response;
		endif;
		
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			completedOK := true;
			return response;
		endif;
		
		arrivalDict.add(voyage);
		
	else
		if departedTS = null then		
			now := app.actualTimeServer;
			departedHours:=app.myPassport.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
			if departedHours = 0 then
				departedHours := request.departedRangeInDays * 24;
			endif;
			if departedHours = 0 then
				departedHours:=48;
			endif;		
		
			departedTS := now.changeByXXHours(-departedHours);
		endif;
		if scheduledTS = null then
			scheduledHours := request.scheduledRangeInDays * 24;
			scheduledTS := now.changeByXXHours(scheduledHours);
		endif;
				
		iter := app.myPassport.myTerminal.allVoyagesByDepartDTCode.createIterator();
		app.myPassport.myTerminal.allVoyagesByDepartDTCode.startKeyGeq(departedTS,null,iter);
		while iter.next(voyage) do
			if voyage.isNullVoyage or voyage.isCancelled then //jlier1 TFS 5/10/21
				continue;
			endif;
			
			if not showArchived and voyage.archived then
				continue;
			endif;
		
			if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
				continue;
			endif;
			
			if voyage.arrivedDT &gt; scheduledTS  then
				// outside of timeframe
				//break;		// 14 Sept 2022 navvt20 TFS 52711
				continue; 		// ### TFS 52711 24Jan2022 NAVPW1		// 14 Sept 2022 navvt20 TFS 52711
			endif;
			
			arrivalDict.add(voyage);
		endwhile;
		delete iter;
		iter := app.myPassport.myTerminal.allVoyagesByArrivalDTCode.createIterator();			//Bug 46392
		app.myPassport.myTerminal.allVoyagesByArrivalDTCode.startKeyGeq( departedTS,null,iter);	//Bug 46392
		while iter.next(voyage) do																//Bug 46392
			if voyage.isNullVoyage  or voyage.isCancelled then //jlier1 TFS 5/10/21
				continue;																		//Bug 46392
			endif;																				//Bug 46392
																								//Bug 46392
			if not showArchived and voyage.archived then										//Bug 46392
				continue;																		//Bug 46392
			endif;																				//Bug 46392
																								//Bug 46392
			if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then				//Bug 46392
				continue;																		//Bug 46392
			endif;																				//Bug 46392
																								//Bug 46392
			if voyage.arrivedDT &gt; scheduledTS then												//Bug 46392
				// outside of timeframe															//Bug 46392
				break;																			//Bug 46392
			endif;																				//Bug 46392
																								//Bug 46392
			arrivalDict.addNoDuplicates(voyage,false);											//Bug 46392
		endwhile;																				//Bug 46392
		delete iter;																			//Bug 46392
		
	endif;
	
	

	iter:=arrivalDict.createIterator;
	while iter.next(voyage) do
		create proxyShipping transient;
		proxyShipping.setProxyFromObject(voyage);
		response.allVesselSchedules.add(proxyShipping);
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	delete iter;	
	delete arrivalDict;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_VesselScheduleRequest"/>
        <ReturnType type="WS_VesselScheduleResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVessels" id="ff25a34a-53c6-45b9-84c7-23687fbbb012">
        <source>getVessels() :WS_VesselResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Mar 2009	#cnwdz2	PAR #17554 - Development of new RIA Web Service application 
                   

*/

vars
	response		: WS_VesselResponse;
	completedOK		: Boolean;
	vessel			: CM_Vessel;
	vesselProxy	    : WS_Vessel;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	foreach vessel in app.myRoot.allVessels discreteLock do
		// Populate response
		create vesselProxy transient;
		vesselProxy.setProxyFromObject(vessel);
		response.allVessels.add(vesselProxy);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getVessels</wsdlName>
        <ReturnType type="WS_VesselResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVesselsForVoyageCreate" id="df870617-20c4-4b02-9425-53cc47a6e642">
        <source>getVesselsForVoyageCreate() :WS_VesselResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2018	jlger1	Initial creation  tfs 37661 pelindo voyage request need this
						vesssel must be able to create voyages and check user data access
19 Nov   2018   cnwma1  Bug 42058: PEL1 - Workorder Voyage Missing port
27 Jan   2020   cnwma1	Bug 48119: Web Portal - Issues
04 Oct 	 2021	jlier1	TFS 51963
*/

vars
	response		: WS_VesselResponse;
	completedOK		: Boolean;
	vessel			: CM_Vessel;
	vesselProxy	    : WS_Vessel;
	failedDAC	    : CM_DataAccessController;
	terminal 	    : CM_Terminal;
	voyageProcess   : CM_VoyageProcess;
	processTerminal : CM_ProcessTerminal;
	allVesselsTemp  : CM_VesselByCodeDict;
	allVessels      : CM_VesselByCodeDict;
	harbour         : HMS_Harbour;
	displayVesselByName : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//11 Jun 2018	NDL	TFS 39140 - Available vessels is limited by the CM_ProcessTerminal, if it has been set up with vessels
	terminal      := app.myPassport.myTerminal;
	voyageProcess := terminal.getDefaultVoyageProcess;
	harbour       := terminal.myHarbour;
	
	if voyageProcess &lt;&gt; null then
		processTerminal := voyageProcess.allProcessTerminals.getAtKey( voyageProcess, terminal );
	endif;
	
	if processTerminal &lt;&gt; null and not processTerminal.allVessels.isEmpty then
		create allVesselsTemp transient;
		processTerminal.allVessels.copy( allVesselsTemp );
		allVessels := allVesselsTemp;
	else
		allVessels := app.myRoot.allVessels;
	endif;
	displayVesselByName:=terminal.getConfig(VesselComboByName).Boolean;	
//	foreach vessel in app.myRoot.allVessels discreteLock do
	foreach vessel in allVessels discreteLock do	//11 Jun 2018	NDL	TFS 39140
		if not vessel.canCreateVoyages then
			continue;
		endif;
		if not vessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		//if app.isDevelopmentSystem then    19.11.2018  cnwma1  Bug #42058
			/*
			27.01.2020 cnwma1 #48119
			if vessel.myHMSVesselData = null or  
				vessel.myHMSVesselData.allVesselDataForHarbour[app.myPassport.myTerminal.myHarbour] = null then
				continue;
			endif;
			*/

			if vessel.hasHarbourDetails then			//27.01.2020 cnwma1 #48119
				if vessel.myHMSVesselData.allVesselDataForHarbour[harbour] = null then
					continue;
				endif;
			endif;

		//endif;
		
		// Populate response
		create vesselProxy transient;
		vesselProxy.setProxyFromObject(vessel);
		
		//jlier1 TFS 51963 4/10/21
		if displayVesselByName then
			vesselProxy.setComboboxDescription(vesselProxy.name &amp; Tab &amp; vesselProxy.code);
		endif;
		
		response.allVessels.add(vesselProxy);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	delete allVesselsTemp;	//11 Jun 2018	NDL	TFS 39140
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_VesselResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVisits" id="62fb7b5c-54f8-4731-98b7-7b9510e07f2b">
        <usesRPC>default</usesRPC>
        <source>getVisits(request: WS_VisitsRequest) : WS_VisitsResponse webService;
/*
Purpose:	Get all visits that start/finish between from (inclusive) and to (exclusive).

Date		Who		Reason
16 May 2012	cnwdw1	Initial creation
*/
vars
	response: WS_VisitsResponse;
	completedOK: Boolean;
	
	agent: CM_KEAAgent;
	now, from, too: TimeStamp;
	visits: CM_KPIVisitDtlArray;
	visit: CM_KPIVisitDtl;

	ws_visit: WS_KPIVisitDtl;
	
	diffTo : Integer;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	from := request.from.asTimeStampFromWebInterface;
	too :=  request.too.asTimeStampFromWebInterface;
	
	diffTo := now.cnSecondsDifference(too);
	
	if from.isValid and from.date.year &gt;= 2012 and from &lt; now and
	   too.isValid and too.date.year &gt;= 2012 and from &lt; too then
	    create agent transient;
		create visits transient;
		
		agent.getTruckVisits(from, too, app.myPassport.myTerminal, visits);
		agent.getShipVisits(from, too, app.myPassport.myTerminal, visits);
		agent.getTrainVisits(from, too, app.myPassport.myTerminal, visits);
		
		foreach visit in visits do
			if visit.isKindOf(CM_KPITruckVisitDtl) then
				create ws_visit as WS_KPITruckVisitDtl transient;
			elseif visit.isKindOf(CM_KPIShipVisitDtl) then
				create ws_visit as WS_KPIShipVisitDtl transient;
			elseif visit.isKindOf(CM_KPITrainVisitDtl) then
				create ws_visit as WS_KPITrainVisitDtl transient;
			endif;
			ws_visit.setFrom(visit);
			response.allVisits.add(ws_visit.WS_KPIVisitDtl);
		endforeach;
	else
		app.raiseCMException1(KEA_ERROR, "Invalid From (" &amp; request.from &amp; ") or To (" &amp; request.too &amp; ") timestamp. Format should be dd/MM/yyyy HH:mm:ss Current: " &amp; now.String, null, null);
	endif;
	
	completedOK := true;
	return response;

epilog
	delete agent;
	delete visits;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <text>Get all visits that start/finish between from (inclusive) and to (exclusive).</text>
        <Parameter name="request" type="WS_VisitsRequest"/>
        <ReturnType type="WS_VisitsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyage40ftBayIds" id="aeb0a43f-8a92-4e6d-97cd-de43fe5bdffd">
        <source>getVoyage40ftBayIds(_voyageCode : String) : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	wsCode : WS_Code;
	failedDAC : CM_DataAccessController;
	bay : CM_Bay;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	if _voyageCode.trimBlanks = "" then
		completedOK := true;
		return response;
	endif;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage := app.myPassport.getObjectOfTypeFromOid(_voyageCode, CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		completedOK := true;
		return response;
	endif;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(_voyageCode, null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; _voyageCode then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null or voyage.myCellularVoyageStructure = null then
		completedOK := true;
		return response;
	endif;
		
	if voyage &lt;&gt; null then
		foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
			if bay.idBay40 = null then
				continue;
			endif;
			create wsCode transient;
			wsCode.setProxyDetails(bay, bay.idBay40, bay.idBay40);
			response.allCodes.add(wsCode);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageBayIds" id="1908f0d2-d782-44c2-bdf9-c72b9e5c953b">
        <source>getVoyageBayIds(_voyageCode : String) : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	wsCode : WS_Code;
	failedDAC : CM_DataAccessController;
	bay : CM_Bay;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	if _voyageCode.trimBlanks = "" then
		completedOK := true;
		return response;
	endif;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage := app.myPassport.getObjectOfTypeFromOid(_voyageCode, CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		completedOK := true;
		return response;
	endif;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(_voyageCode, null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; _voyageCode then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null or voyage.myCellularVoyageStructure = null then
		completedOK := true;
		return response;
	endif;
		
	if voyage &lt;&gt; null then
		foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
			create wsCode transient;
			wsCode.setProxyDetails(bay, bay.id, bay.id);
			response.allCodes.add(wsCode);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageBays" id="7fecf565-d46b-472c-adc8-42740a6cd829">
        <source>getVoyageBays(request : WS_VoyageDefinitionRequest) : WS_VoyageDefinitionResponse webService;
/*
Purpose:			
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
*/


vars
	response		: WS_VoyageDefinitionResponse;
	completedOK, found		: Boolean;
	voyageId, holdcode : String;
	obj : Object;
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	bay : CM_BayVoyage;
	deck : CM_DeckVoyage;
	hold : CM_GeneralCargoController;
	wsbay : WS_BayDefn;
	wsdeck : WS_Deck;
	wshold : WS_HoldGC;
	failedDAC 	: CM_DataAccessController;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	
	voyageId := request.voyageCode;
	
	if voyageId.trimBlanks = "" then
		completedOK := true;
		return response;
	
	endif;
	
	// Create the response
	create response transient;
		
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
		
	if voyage &lt;&gt; null then
		if voyage.myCellularVoyageStructure &lt;&gt; null then
			foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
				create wsbay;
				wsbay.setProxyFromObjectBay(bay); // no cell, tier or slot objects.
				response.allBays.add(wsbay);
			endforeach;
		endif;
		if voyage.myROROStructure &lt;&gt; null then
			foreach deck in voyage.myROROStructure.allDecks discreteLock do
				create wsdeck;
				wsdeck.setProxyFromObject(deck);
				response.allDecks.add(wsdeck);
			endforeach;
		endif;
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
			foreach hold in voyage.myGeneralCargoVoyage.allLocationsByHatchPlace discreteLock do
			
				holdcode := hold.hatch.padLeadingWith('0',2);
				found := false;
				
				foreach wshold in response.allHoldsGC do
					if wshold.code = holdcode then
						found := true;
					endif;
				
				endforeach;
				
				if not found then
					create wshold;
					wshold.setProxyFromObject(hold);
					response.allHoldsGC.add(wshold);
				endif;
			endforeach;
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_VoyageDefinitionRequest"/>
        <ReturnType type="WS_VoyageDefinitionResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageDetailsByCode" id="0b7f56dc-2c31-441a-b4f5-31fea18ae457">
        <source>getVoyageDetailsByCode(_voyageCode : String) :  WS_VesselScheduleResponse webService;
/*

Purpose:	PEL1 needs to be able to retrieve a voyage based on the voyage code		

Parameters: voyage code

Return Value: Voyage Details for the given voyage code	

Date			Who		Reason
17 August 2018	jlgam15	TFS 40346 - Search &amp; Return voyage based on the voyage code

*/

vars
	response 	: WS_VesselScheduleResponse;
	completedOK : Boolean;
	terminal 	: CM_Terminal;
	voyage 		: CM_Voyage;
	proxyVessel	: WS_VesselSchedule;
	failedDAC 	: CM_DataAccessController;

begin
	
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	voyage := terminal.allVoyagesByCode.getAtKeyGeq(_voyageCode,null);
	
	//the above look-up always return anything that matches from and after '_voyageCode'
	//hence, ensure the code always matches the passed-in code
	if voyage &lt;&gt; null and voyage.code &lt;&gt; _voyageCode then
		voyage := null;
	endif;
	
	//epr TFS 41310 13/10/18
	if voyage = null then
		voyage:=app.myPassport.getObjectOfTypeFromOid(_voyageCode,CM_Voyage).CM_Voyage;
	endif;
	
	if voyage = null then
		app.raiseCMException1(Voyage_not_found,_voyageCode,null,null);
		completedOK := true;
		return response;
	endif;
	
	if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(Access_Denied,null,null);
		completedOK := true;
		return response;
	endif;
	
	create proxyVessel transient;	
	proxyVessel.setProxyFromObject(voyage);
	response.allVesselSchedules.add(proxyVessel);
	
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="WS_VesselScheduleResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageHMSResourcesUsed" id="3c5b752e-10c2-4959-be13-45480648f33e">
        <source>getVoyageHMSResourcesUsed(_voyage : String) : WS_HMSResourceUsedResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation 38561 Voyage Work Orders

*/

vars
	voyage : CM_Voyage;
	response : WS_HMSResourceUsedResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	failedDAC : CM_DataAccessController;
	voyageMovement : HMS_VoyageMovement;
	resourceUsed : HMS_ResourceUsed;
	wsResourceUsed : WS_HMSResourceUsed;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	
	if _voyage.trimBlanks = "" then
		completedOK := true;
		return response;
	
	endif;
	voyage :=app.myPassport.getObjectOfTypeFromOid(_voyage,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(_voyage,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; _voyage then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	if voyage.myHMSVoyageData = null then
		completedOK := true;
		return response;
	endif;
	
	foreach voyageMovement in  voyage.myHMSVoyageData.allVoyageMovements discreteLock do
		foreach resourceUsed in voyageMovement.allResourceUsed discreteLock do
			create wsResourceUsed transient;
			wsResourceUsed.setProxyFromObject(resourceUsed);
			response.allHMSResourcesUsed.add(wsResourceUsed);
		endforeach;
	endforeach;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
