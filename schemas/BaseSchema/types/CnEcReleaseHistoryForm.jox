    <JadeMethod name="doFormLoad" id="b4530fdb-73ca-4357-a875-40c47d5f8d1b">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/06/2003	cnwdad1		Changed from using a BaseSchema method to fetch the
//							server timestamp, to use the native method.
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	txtStartDate.setDate(app.actualTimeServer().date);
	txtStartTime.setTime(app.actualTimeServer().time);
	
	self.initializeTable();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="07f77111-fc10-49fa-bb0b-418f60545522">
        <updating/>
        <source>doSearch() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Search the release history master.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTimestamp		: TimeStamp;
	userName			: String;
	computerName		: String;
	allHistoryMasters	: CnEcRelHistoryMasterByTimeDict;
	
begin
	self.aAllSearchResults.clear();
	create allHistoryMasters transient;
	
	startTimestamp.cnEcSetDateAndTime(txtStartDate.date, txtStartTime.getTime());
	userName		:=	txtUserName.cnEcString();
	computerName	:=	txtComputerName.cnEcString();
	
	app.myBaseRoot.allReleaseHistoryMasters.searchForReleases(	startTimestamp,
																userName,
																computerName,
																allHistoryMasters);
	
	if allHistoryMasters.cnEcIsNotEmpty() then
		allHistoryMasters.copy(self.aAllSearchResults);
	endif;

	tblHistory.displayCollection(self.aAllSearchResults, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION, null);
	self.enableButtons();
epilog
	delete allHistoryMasters;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="22c7dc36-c467-4b8f-8a66-01f91797d140">
        <source>enableButtons() protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Set the currently enabled button controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isValidRow	: Boolean;
	
begin
	isValidRow	:=	(tblHistory.row &gt; tblHistory.fixedRows and tblHistory.row &lt;= tblHistory.rows);
	
	btnDetails.enabled	:=	isValidRow;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeTable" id="fb788622-800b-457b-8366-963534debd2e">
        <source>initializeTable() protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Initialize the data table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: CnEcTable;
	
begin
	tableObj			:=	tblHistory;
	tableObj.clear;
	tableObj.rows		:=	1;
	tableObj.fixedRows	:=	1;
	
	tableObj.addColumnHeading(	1,
								self.TABLE_RELEASE &amp; Tab &amp;
								self.TABLE_APPLICATION &amp; Tab &amp;
								self.TABLE_START &amp; Tab &amp;
								self.TABLE_FINISH &amp; Tab &amp;
								self.TABLE_IS_OKAY &amp; Tab &amp;
								self.TABLE_USER &amp; Tab &amp;
								self.TABLE_COMPUTER);
	
	tableObj.initialize();
	self.enableButtons();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="76a5f75c-aec3-4972-b2cc-dc0b2f2562bd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="8d7186d6-2cc4-4d46-9e57-dd58a7fb6616">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	tblHistory.move(tblHistory.left, tblHistory.top, (self.width - 27), (self.height - tblHistory.top - 67));
	btnClose.move((self.width - btnClose.width - 17), (self.height - btnClose.height - 36), btnClose.width, btnClose.height);
	btnDetails.move((btnClose.left - btnDetails.width - 6), btnClose.top, btnDetails.width, btnDetails.height);
	btnSearch.move((btnDetails.left - btnSearch.width - 6), btnClose.top, btnSearch.width, btnSearch.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="showDetails" id="81720c25-4039-474f-bed7-a9a309bd0efd">
        <source>showDetails() protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Display the release history details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	detailsFormObj		: CnEcReleaseHistoryDetailForm;
	historyMasterObj	: CnEcReleaseHistoryMaster;
	
begin
	historyMasterObj	:=	tblHistory.accessRow(tblHistory.row).itemObject.CnEcReleaseHistoryMaster;
	create detailsFormObj;
	detailsFormObj.setHistoryMaster(historyMasterObj);
	detailsFormObj.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblHistory_click" id="a864a58b-93c5-422b-92b6-2e95d0a775bf">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHistory_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.enableButtons();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblHistory_dblClick" id="cce773c6-5a19-4984-b180-5b4aee5adda3">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHistory_dblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnDetails.click(btnDetails);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblHistory_displayRow" id="26be7acc-71b1-430a-8849-ad575d67f27c">
        <controlMethod name="CnEcTable::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHistory_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	historyMasterObj	: CnEcReleaseHistoryMaster;
	
begin
	historyMasterObj	:=	obj.CnEcReleaseHistoryMaster;
	
	return	historyMasterObj.currentReleaseNumber &amp; ' ' &amp; historyMasterObj.currentPatchNumber &amp; Tab &amp;
			historyMasterObj.processAppName &amp; Tab &amp;
			historyMasterObj.processStartTime.String &amp; Tab &amp;
			historyMasterObj.processFinishTime.String &amp; Tab &amp;
			historyMasterObj.isCompletedOK.cnEcGetYesNo() &amp; Tab &amp;
			historyMasterObj.processUser &amp; Tab &amp;
			historyMasterObj.computerName;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblHistory_sysNotify" id="fb662f63-129c-481c-ad3b-f32ee806830d">
        <controlMethod name="Table::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHistory_sysNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.enableButtons();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
