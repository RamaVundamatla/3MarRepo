    <JadeMethod name="jtdAsString" id="803400fe-9fef-4315-86c8-19a9ea828411">
        <source>jtdAsString() : String;

begin
	return self.jtdFormTop.String                  &amp; ';' &amp;
		   self.jtdFormLeft.String                 &amp; ';' &amp;
		   self.jtdFormHeight.String               &amp; ';' &amp;
		   self.jtdFormWidth.String                &amp; ';' &amp;
		   self.jtdTrxDelay.String                 &amp; ';' &amp;
		   self.jtdAutoPingResponseInterval.String &amp; ';' &amp;
		   self.jtdProfileName                     &amp; ';' &amp;
		   self.jtdStatusDisplayEnabled.String     &amp; ';' &amp;
		   self.jtdStartupDelaySecs.String         &amp; ';' &amp;
		   self.jtdShutdownDelaySecs.String        &amp; ';';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdInitialize" id="69bbd215-4549-44be-bf58-462dd0c484b9">
        <updating/>
        <source>jtdInitialize() updating;

begin
	self.jtdAutoPingResponseInterval := 0;
	self.jtdFormHeight := 0;
	self.jtdFormLeft := 0;
	self.jtdFormTop := 0;
	self.jtdFormWidth := 0;
	self.jtdTrxDelay := 0;
	self.jtdProfileName := null;
	self.jtdStatusDisplayEnabled := true;
	self.jtdStartupDelaySecs := 0;
	self.jtdShutdownDelaySecs := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdSetFromString" id="1b5341bd-d215-403c-afa9-34af504eff52">
        <updating/>
        <source>jtdSetFromString(paramString : String) updating;

vars
	i, n, len : Integer;
	s : String;
	
begin
	self.jtdInitialize;
	
	if paramString = null then
		return;
	endif;

	i := 1;
	n := 1;
	len := paramString.length;
		
	while n &lt;= len do
		s := paramString.scanUntil(';', n).trimBlanks;
		
		if n &lt; 1 then
			return;
		endif;

		if i = 1 then		
			self.jtdFormTop := s.Real;
		elseif i = 2 then
			self.jtdFormLeft := s.Real;
		elseif i = 3 then
			self.jtdFormHeight := s.Real;
		elseif i = 4 then
			self.jtdFormWidth := s.Real;
		elseif i = 5 then
			self.jtdTrxDelay := s.Integer;
		elseif i = 6 then
			self.jtdAutoPingResponseInterval := s.Integer;
		elseif i = 7 then
			self.jtdProfileName := s;
		elseif i = 8 then
			self.jtdStatusDisplayEnabled := s.Boolean;
		elseif i = 9 then
			self.jtdStartupDelaySecs := s.Integer;
		elseif i = 10 then
			self.jtdShutdownDelaySecs := s.Integer;
			break;
		elseif i = 11 then
			self.jtdMachineId := s;
			break;	
		elseif i = 12 then
			self.jtdTerminalId := s;
			break;	
		endif;

		n := n + 1;
		i := i + 1;
	endwhile;		
end;</source>
        <Parameter name="paramString" type="String"/>
    </JadeMethod>
</Class>
