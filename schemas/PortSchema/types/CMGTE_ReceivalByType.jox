	return null;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="8357b639-79b9-48d2-891e-4b1a50777529">
        <source>getCommodity():CM_Commodity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

begin

	if self.myReceivalInfo &lt;&gt; null and self.myReceivalInfo.commodity.trimBlanks &lt;&gt; null then
		return app.myRoot.allCommodities[self.myReceivalInfo.commodity.trimBlanks];
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a1118696-cda3-4f01-b572-2fef028948dc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2017	cnwndl1	Initial creation	TFS 3758

*/

vars

	cargoType : CM_CargoType;
	bookingRef : CM_BookingRef;
	detail : String;

begin

	if _attrName = ETRow_PickerType then
		return self.jobTypeString;
		
	elseif _attrName = ETRow_BookingRelease then
		bookingRef   := self.myReceivalInfo.myBooking;
		if bookingRef &lt;&gt; null then
			return bookingRef.bookingReference;
		endif;
		return null;
		
	elseif _attrName = ETRow_Detail then
		cargoType 	 := self.myReceivalInfo.myCargoType;
		if cargoType &lt;&gt; null then
			detail := cargoType.description;
			if self.myProduct &lt;&gt; null then
				detail := detail &amp; "; " &amp; self.myProduct.description;
			endif;
		else
			detail := app.getErrorString(Miscellaneous_items);
		endif;
		
		if  self.myReceivalInfo.quantity &gt; 0 then
			detail := self.myReceivalInfo.quantity.String &amp; " x " &amp; detail;
		else
			detail := "??" &amp; " x " &amp; detail;
		endif;
		
		return detail;
		
	elseif _attrName = ETRow_Bol then	//17 Mar 2017	NDL	TFS 3758																//+cnwml2 PAR21090
		return null;
		
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="311f1a33-7e3d-4dca-a2f4-3b80465e3d9a">
        <source>getTableDisplayString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwjk3	ccms 1017

*/

vars
	type,
	detail,
	booking,
	display		: String;
	xtraCrit : String;	//10 Jan 2019	NDL	TFS 40479
begin
	
	//15 Mar 2017	NDL	TFS 3758
	type := self.getDisplayStringForAttribute( ETRow_PickerType, false );
	detail := self.getDisplayStringForAttribute( ETRow_Detail, false );
	booking := self.getDisplayStringForAttribute( ETRow_BookingRelease, false );
	
	display := type &amp; Tab &amp; detail &amp; Tab &amp; booking;
	//10 Jan 2019	NDL	TFS 40479
	if xtraCrit &lt;&gt; null then
		display := display &amp; Tab &amp; xtraCrit;
	endif;
	return display;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
