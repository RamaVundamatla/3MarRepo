    <JadeMethod name="setKPIVoyageDeckWPMovesTRAN" id="1a90a1df-345e-404e-b260-004bd15bd283">
        <source>setKPIVoyageDeckWPMovesTRAN(_tran :CM_TITransaction);
/*
Purpose:		Update KPI for deck/workpoint for single transaction	
Parameters:			
Return Value:		

Date			Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
06 March 2024	navpw1	 TFS: 62717 (62728) - Added a check to make sure the job is a voyage deck job before type casting it.
*/
vars
	kpi 		: CM_KPIVoyageDeckWorkPoint;
	tranJob		: CM_Job;
	job 		: CM_VoyageDeckJob;
	deck		: CM_DeckVoyage;
	vessel 		: CM_Vessel;
begin
	tranJob := _tran.getJob();
	
	if tranJob = null then 
		return;
	endif;
	
	if not tranJob.isVoyageDeckJob then
		return;
	endif;
	
	job := tranJob.CM_VoyageDeckJob;
	
	if job = null then
		return;
	endif;
	
	vessel := self.myVoyage.getMyVessel();
	
	deck	:= job.myDeck;

	if deck = null then
		return;
	endif;
	
	kpi := deck.getKPIVoyageDeckWorkPointForJS (self);
	
	if kpi = null then
		create kpi;

		kpi.setKPI(self.getMyWorkPoint, self, deck);
	endif;

	kpi.setFromTransaction(_tran);
	
	if kpi.allTrackedItems.isEmpty then
		// not sure why this would happen !
		delete kpi;
	endif;
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
