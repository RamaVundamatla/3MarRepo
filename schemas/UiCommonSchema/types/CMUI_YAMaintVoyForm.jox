    <JadeMethod name="formatCaption" id="502e5e5b-f12e-44a7-b4ca-3f1684886f6e">
        <updating/>
        <source>formatCaption() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	cnwas3	Initial creation

*/

vars

begin
	caption := self.caption;
	if self.isExport then
		if self.updateMode then
			self.setCaption(app.getErrorString2(Colour_coding_update,self.myVoyage.code, app.getErrorString(Load)));
		else
			self.setCaption(app.getErrorString2(Colour_coding_NEW,self.myVoyage.code, app.getErrorString(Load)));
		endif;
	else
		if self.updateMode then
			self.setCaption(app.getErrorString2(Colour_coding_update,self.myVoyage.code, app.getErrorString(Discharge)));
		else
			self.setCaption(app.getErrorString2(Colour_coding_NEW,self.myVoyage.code, app.getErrorString(Discharge)));
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="formatDescription" id="b07c059e-9e59-47cf-9fab-b8c1e2e4180a">
        <source>formatDescription();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation
21/09/2010	cnwmh5	#25631 - Change so that description displays correctly

*/
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue	: Any;
	i				: Integer;
	imexStatus		: CM_IMEXStatus;
	groupName		: String;
	yaTemplate		: CM_YATemplate;
	bValue 			: Any;
	// cnwjk3 SFW1030
	yaConfig: CM_YAConfig;
	yaIMEXConfig: CM_YAIMEXConfig;
	yaCriteriaType : CM_YACriteriaType;

	term : CM_Terminal;
begin
	term := self.getTerminal();
	
	if term &lt;&gt; null
	and term.getConfig(ReportGrpDescriptionType).Integer = RepGrpDscType_Attributes then // PAR 34184
		formatDescriptionVAAttributes(); // PAR 34184
		return; // PAR 34184
	endif;
	
	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	
	if imexStatus = null or imexStatus.code = TI_IMEX_STATUS_NULL then
		groupName := "N";
	else
		groupName := imexStatus.abbreviation[1];
	endif;

	yaIMEXConfig := self.myVoyage.allVoyageAllocationConfigs.first; // PAR 34184

	if yaIMEXConfig = null then
		yaConfig := self.myTerminal.myYAConfig;
		if imexStatus &lt;&gt; null and yaConfig &lt;&gt; null then
				yaIMEXConfig := yaConfig.allYAIMEXConfigs[imexStatus.code];
		endif;
	endif;
	
	// cnwjk3 SFW1030
	if yaIMEXConfig &lt;&gt; null and yaIMEXConfig.allGroupLabelCriteria &lt;&gt; null and yaIMEXConfig.allGroupLabelCriteria.size() &gt; 0 then
		
		// We have a group order specified, so form the names using only those group criteriam and in the configured order.
		foreach yaCriteriaType in yaIMEXConfig.allGroupLabelCriteria do
			// Locate the control associated with this criteria type
			criteriaCtrl := self.locateControlForCriteriaType(yaCriteriaType);
			if criteriaCtrl &lt;&gt; null then 
				if criteriaCtrl.visible then
					criteriaValue := criteriaCtrl.getDisplayForGroupName;
					if criteriaValue &lt;&gt; null then
						groupName := groupName &amp; " " &amp; criteriaValue.String;
					endif;
				endif;
			endif;
		endforeach;
	
	else	

		while true do
			i := i + 1;
			criteriaCtrl := self.frmCriteria.getControl(i);
			if criteriaCtrl = null then
				break;
			endif;
			if criteriaCtrl.visible then
				criteriaValue := criteriaCtrl.getDisplayForGroupNameNumbers();
				// 21/09/2010 cnwmh5 #25631 - Start
				if criteriaValue &lt;&gt; null then
					bValue := criteriaCtrl.getValue();
					if bValue &lt;&gt; null then
						if (bValue &lt;&gt; criteriaValue and bValue.Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE) or
								bValue = criteriaValue then
							groupName := groupName &amp; " " &amp; criteriaValue.String;
						endif;
					endif;
				endif;
				/*
				//criteriaValue := criteriaCtrl.getDisplayForGroupName();
				bValue := criteriaCtrl.getValue();
				if bValue &lt;&gt; null and bValue.Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE then //if the criteria option is "yes" or it's populated,in case of a textbox
					if criteriaValue &lt;&gt; null then
						//if bValue
						groupName := groupName &amp; " " &amp; criteriaValue.String;
					endif;
				endif;
				*/
				// 21/09/2010 cnwmh5 #25631 - End
			endif;
		endwhile;
	endif;
	
	txtGroupName.text := groupName;
	
	yaTemplate := cmbYATemplate.listObject.CM_YATemplate;

	//if not defaultYACodeChanged then
		if yaTemplate = null then
			txtDescription.text := groupName;
		else
			txtDescription.text := groupName &amp; " - " &amp; yaTemplate.code;
		endif;
	//endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="formatDescriptionVAAttributes" id="4d47ae0b-9851-4ad9-a79e-c6909e490117">
        <source>formatDescriptionVAAttributes();
/*
Purpose:	34184		
Date				Who			Reason
MAY 2014	CNWAB1		Initial creation
*/
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue	: String;
	i				: Integer;
	imexStatus		: CM_IMEXStatus;
	groupName		: String;
	yaTemplate		: CM_YATemplate;
	bValue 			: Any;
	commGrp : CM_CommodityGroup;
	comm : CM_Commodity;
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	yaConfig: CM_YAConfig;
	yaIMEXConfig: CM_YAIMEXConfig;
	yaCriteriaType : CM_YACriteriaType;
	sectionSet : Boolean;
	powerStr, typeStr, hiStr : String;
	isGen : Boolean;
	cargoType : CM_CargoType;
begin
	
	
	// ### IMEX STATUS
	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	
	if imexStatus = null or imexStatus.code = TI_IMEX_STATUS_NULL then
		groupName := "N";
	else
		groupName := imexStatus.abbreviation[1];
	endif;

	yaIMEXConfig := self.myVoyage.allVoyageAllocationConfigs.first;

	if yaIMEXConfig &lt;&gt; null then
		

		// ### CARGOTYPE
		yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_CargoType);
		criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
		if criteriaValue &lt;&gt; null then 
			cargoType := app.myRoot.getCargoTypeFromAbbrev(criteriaValue);
		endif;
			
		// ### DISCHARGE PORT
		yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_DischargePort);
		criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
		if criteriaValue &lt;&gt; null then 
			groupName := groupName &amp; " " &amp; criteriaValue.String; 
		endif;

		if cargoType= null
		or cargoType.id = TI_CargoType_Container then
		
			// ### LENGTH
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_ISOGroup);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null then
					isoGroup := app.myRoot.allISOTypeGroups[criteriaValue];
					if isoGroup &lt;&gt; null then
						sectionSet := true;
						if isoGroup.is20ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(TwentyFoot); 
						elseif isoGroup.is30ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(ThirtyFoot); 
						elseif isoGroup.is40ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FortyFoot); 
						elseif isoGroup.is45ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FortyFiveFoot); 
						elseif isoGroup.is53ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FiftyThreeFoot); 
						else					
							groupName := groupName &amp; " " &amp; app.getErrorString(TwentyFoot); 
						endif;
						
						if isoGroup.isHiCube then
							hiStr := app.getErrorString(SummaryDesc_HighCube);
						endif;
						
						if isoGroup.isPowered then
							powerStr := app.getErrorString(SummaryDesc_Integral);
						endif;
						
						if isoGroup.isCrib	then
							typeStr := app.getErrorString(SummaryDesc_Crib);
						elseif isoGroup.isFlat then
							typeStr := app.getErrorString(SummaryDesc_FlatRack);
						elseif isoGroup.isTank then
							typeStr := app.getErrorString(SummaryDesc_Tank);
						elseif isoGroup.isOpenTop then
							typeStr := app.getErrorString(SummaryDesc_OpenTop);
						elseif isoGroup.isFantainer then
							typeStr := app.getErrorString(SummaryDesc_Fantainer);
						else
							isGen := true;
						endif;
		
					endif;
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_ISO);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null then
					isoType := app.myRoot.allISOTypes[criteriaValue];
					if isoType &lt;&gt; null then
						sectionSet := true;
						if isoType.is20ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(TwentyFoot); 
						elseif isoType.is30ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(ThirtyFoot); 
						elseif isoType.is40ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FortyFoot); 
						elseif isoType.is45ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FortyFiveFoot); 
						elseif isoType.is53ftLong() then
							groupName := groupName &amp; " " &amp; app.getErrorString(FiftyThreeFoot); 
						else					
							groupName := groupName &amp; " " &amp; app.getErrorString(TwentyFoot); 
						endif;
						
						if isoType.isHiCube then
							hiStr := app.getErrorString(SummaryDesc_HighCube);
						endif;
						
						if isoType.isPowered then
							powerStr := app.getErrorString(SummaryDesc_Integral);
						endif;
						
						if isoType.isCrib	then
							typeStr := app.getErrorString(SummaryDesc_Crib);
						elseif isoType.isFlat then
							typeStr := app.getErrorString(SummaryDesc_FlatRack);
						elseif isoType.isTank then
							typeStr := app.getErrorString(SummaryDesc_Tank);
						elseif isoType.isOpenTop then
							typeStr := app.getErrorString(SummaryDesc_OpenTop);
						elseif isoType.isFantainer then
							typeStr := app.getErrorString(SummaryDesc_Fantainer);
						else
							isGen := true;
						endif;
		
					endif;
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsTwenty);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; " " &amp; app.getErrorString(TwentyFoot); 
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsThirty);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; " " &amp; app.getErrorString(ThirtyFoot); 
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsForty);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; " " &amp; app.getErrorString(FortyFoot); 
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsFortyFive);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; " " &amp; app.getErrorString(FortyFiveFoot); 
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsFiftyThree);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; " " &amp; app.getErrorString(FiftyThreeFoot); 
				endif;
			endif;
			
			if typeStr &lt;&gt; null then
				groupName := groupName &amp; " " &amp; typeStr; 
			endif;
			
			sectionSet := false;
			
			
			// ### POWER
			if not sectionSet then
				if powerStr = null	then
					yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_RequiresPower);
					criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
					if criteriaValue &lt;&gt; null 
					and criteriaValue.pos("Not",1) &lt;= 0 then 
						sectionSet := true;
						powerStr := app.getErrorString(SummaryDesc_Integral); 
					endif;
				endif;
				if powerStr&lt;&gt; null then
					sectionSet := true;
					groupName := groupName &amp; " " &amp; powerStr; 
				endif;
			endif;
			
			// ### EMPTY
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_CommodityGroup);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null then
					commGrp := app.myRoot	.allCommodityGroups[criteriaValue];
					if commGrp &lt;&gt; null then
						sectionSet := true;
						groupName := groupName &amp; " " &amp; app.getErrorString(SummaryDesc_Empty); 
					
					endif;
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_Commodity);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null then
					comm := app.myRoot.allCommodities[criteriaValue];
					if comm &lt;&gt; null then
						sectionSet := true;
						groupName := groupName &amp; " " &amp; app.getErrorString(SummaryDesc_Empty); 
					
					endif;
				endif;
			endif;
			if not sectionSet then
				yaCriteriaType := yaIMEXConfig.getCriteriaByType(YACriteriaType_IsEmpty);
				criteriaValue := getControlValueForCriteriaType(yaCriteriaType);
				if criteriaValue &lt;&gt; null 
				and criteriaValue.pos("Not",1) &lt;= 0 then 
					sectionSet := true;
					groupName := groupName &amp; " " &amp; app.getErrorString(SummaryDesc_Empty); 
				endif;
			endif;
			
			if not sectionSet
			and isGen then
				sectionSet := true;
				groupName := groupName &amp; " " &amp; app.getErrorString(SummaryDesc_General); 
			endif;
		else
			if cargoType = null then
				groupName := app.getErrorString(SummaryDesc_Unknown);
			else
				groupName := cargoType.description;
			endif;

		endif;
	endif;
	
	
	groupName := groupName &amp; " " &amp; hiStr;

	txtGroupName.text := groupName;
	
	yaTemplate := cmbYATemplate.listObject.CM_YATemplate;

	if yaTemplate = null then
		txtDescription.text := groupName;
	else
		txtDescription.text := groupName &amp; " - " &amp; yaTemplate.code;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="a77f0b55-b33c-49e3-8c7f-0ef515dae3dd">
        <source>getCriteriaAllCMIF( _cmifArray	: CMIF_Array input );

/*

Purpose:		Create transient objects for maintaining criteria

Parameters:			

Return Value:	Transients returned in collection _cmifArray


Date			Who		Reason
06 August 2008	consw1	Initial creation
12/07/2011		cnwmh5	#27772 - Change so handles Cargo SubType correctly
*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteria 		: CM_YACriteria;
	ctype : CM_YACriteriaType;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;
	imexStatus		: CM_IMEXStatus;
	objSet			: CM_ObjectSet;
	strArray		: CnStringArray;
	voyAlloc 		: CM_VoyageAllocation;
	bValue			: Any;
	isTS : Boolean;
begin
	//  Create transient maintenance objects for all existing criteria and mark for delete action

	voyAlloc := self.myProxyYA.CM_VoyageAllocation;
	if voyAlloc &lt;&gt; null then
		foreach criteria in voyAlloc.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For each criteria control - update/add transient maintenance object

	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible and criteriaCtrl.hasValue() then			
			ctype := criteriaCtrl.getCriteriaType();
			//epr TFS 1822 28/4/16
			bValue := criteriaCtrl.getValue();
		
			// PAR 25833 - if they are using the tranship criteria, check if it is set to YES, if so IMEX = TRANSHIP
			isTS := (ctype &lt;&gt; null and ctype.type = YACriteriaType_IsTransShip);
			if isTS then
				if bValue.Integer &lt;&gt; 1 then
					isTS := false;
				endif;
			endif;
			self.getCriteriaSingleCMIF( _cmifArray,ctype , bValue );
		endif;
	endwhile;
	
	// PAR 25833
	if isTS then
		imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	else
		imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	endif;
	
	create objSet transient;
	objSet.add( imexStatus );
	self.getCriteriaSingleCMIF( _cmifArray, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
epilog
	delete objSet;
	delete strArray;
end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
