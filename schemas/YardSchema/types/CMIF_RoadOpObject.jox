    <JadeMethod name="setupProceedOptions_GateLanes" id="a2499118-bc17-4b31-9e57-01f24ebaa67c">
        <updating/>
        <source>setupProceedOptions_GateLanes(_mnuProceed: MenuItem input; _in :Boolean) updating,protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	laneColl, 
	menuColl	:CM_ObjectArray;
	obj			:Object;
	glc 		:CM_GateAreaLaneController;
	menu,
	subMenu 	: MenuItem;
begin 	
	create laneColl transient;
	
	self.setupProceedOptions_GetLanes(_in, laneColl);
	
	if laneColl.isEmpty then 
		return;	// should not happen :-)
	endif;
		
	// add menu item for "Proceed"
	menu := self.getProceedMenuItem;
	
	if menu = null then
		self.myRoadOpController.setNumberOfMenuItems(self.myRoadOpController.numberOfMenuItems+1);

		menu			:= _mnuProceed.loadMenu(self.myRoadOpController.numberOfMenuItems);
		menu.visible	:= true;
		menu.caption	:= Proceed;
		menu.userObject	:= self;
		
		self.allMenuItems.add(menu);
	endif;

	create menuColl transient;
	
	self.getProceedSubMenuItems (menuColl);
	
	foreach obj in laneColl discreteLock do
		glc	:= obj.CM_GateAreaLaneController;
		
		if not menuColl.isEmpty then
			subMenu := menuColl.first.MenuItem;
			
			menuColl.removeAt (1);
		else
			self.myRoadOpController.setNumberOfMenuItems(self.myRoadOpController.numberOfMenuItems+1);
			
			subMenu	:= menu.loadSubMenu(self.myRoadOpController.numberOfMenuItems);
			
			subMenu.setEventMapping(MenuItem::click.name, YRD_RoadOperationsForm::mProceed_click.name);
			
			self.allMenuItems.add(subMenu);
		endif;
				
		subMenu.caption		:= self.getGateLaneMenuCaption (glc);
		subMenu.visible		:= true;
		subMenu.userObject	:= glc;
		
		if not glc.isUnavailable and  
			((_in and glc.laneDirection = CM_GateAreaLaneController.Is_In_Lane) or 
			(not _in and glc.laneDirection = CM_GateAreaLaneController.Is_Out_Lane)) and 
			not glc.hasVehicles then
			subMenu.enabled	:= true;	//only 1 vehicle per lane allowed
		else
			subMenu.enabled	:= false;
		endif;
	endforeach;
epilog
	delete laneColl;
	delete menuColl;
end;</source>
        <access>protected</access>
        <Parameter name="_mnuProceed" type="MenuItem" usage="input"/>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupProceedOptions_GetLanes" id="fa3c0710-4eff-4872-840c-9704ac4776ba">
        <source>setupProceedOptions_GetLanes(_in :Boolean; _coll :CM_ObjectArray input)protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				Get all lanes to be included in the proceed menu
// Parameters:  _in	- true = looking for entry lanes (otherwise looking for exit lanes)
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	gate	:CM_Gate;
	area	:Object;
begin
	create coll transient;
	
	foreach gate in self.myRoadOpController.allGates do
		if (_in and not gate.isInGate) or
			(not _in and not gate.isOutGate) then
			continue;
		endif;
		
		if _in then
			gate.CM_Gate.getPGateAreas_IN (coll); 
		else
			gate.CM_Gate.getPGateAreas_OUT (coll); 
		endif;
	endforeach;
	
	// coll contains our gate areas
	foreach area in coll do
		if area.CM_GateArea.laneCount = 0 then
			continue;
		endif;
		area.CM_GateArea.getAllLaneControllers (_coll);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_coll" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
