    <JadeMethod name="getCargoTypeFromAbbrevOrDescr" id="cda3dae0-e649-4cf7-8f3d-cdbe2ba0ed94">
        <updating/>
        <source>getCargoTypeFromAbbrevOrDescr( _cargoTypeString : String; _abbrev : Boolean; _desc : Boolean; _term : CM_Terminal ) : CM_CargoType updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgndl1	Initial creation	TFS 44194
20 Jun 2019		NDL		Cater for terminal to be checked too.

*/

vars

	cargoType 		 : CM_CargoType;
	iter 			 : Iterator;
	cargoTypeToCheck : CM_CargoType;
	cargoTypeUpper	 : String;

begin

	if _cargoTypeString = null then
		return null;
	endif;

	if self.cargoTypeDictNeedsRefresh or self.allCargoTypesByAbbrDict.isEmpty then
		self.populateCargoTypes();	
	endif;

	cargoTypeUpper := _cargoTypeString.toUpper; //30.10.2024 navma1 
	
	if _abbrev then
		cargoType := self.allCargoTypesByAbbrDict.getAtKey( _cargoTypeString ).CM_CargoType;
		if _term &lt;&gt; null and cargoType &lt;&gt; null and not cargoType.allTerminals.includes( _term ) then
			iter := self.allCargoTypesByAbbrDict.createIterator;
			iter.startAtObject( cargoType );
			cargoType := null;
			while iter.next( cargoTypeToCheck ) do
				if cargoTypeToCheck.abbreviation.toUpper &lt;&gt; cargoTypeUpper then
					break;
				endif;
				if cargoTypeToCheck.allTerminals.includes( _term ) then
					cargoType := cargoTypeToCheck;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	endif;
	if cargoType = null then
		if _desc then
			cargoType := self.allCargoTypesByDescription.getAtKey( _cargoTypeString ).CM_CargoType;
			if _term &lt;&gt; null and cargoType &lt;&gt; null and not cargoType.allTerminals.includes( _term ) then
				iter := self.allCargoTypesByDescription.createIterator;
				iter.startAtObject( cargoType );
				cargoType := null;
				while iter.next( cargoTypeToCheck ) do
					if cargoTypeToCheck.description.toUpper &lt;&gt; cargoTypeUpper then
						break;
					endif;
					if cargoTypeToCheck.allTerminals.includes( _term ) then
						cargoType := cargoTypeToCheck;
						break;
					endif;
				endwhile;
				delete iter;
			endif;
		endif;
	endif;
	
	return cargoType;

epilog
	delete iter;
end;</source>
        <Parameter name="_cargoTypeString" type="String"/>
        <Parameter name="_abbrev" type="Boolean"/>
        <Parameter name="_desc" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCarrierByDesc" id="8db56c15-103c-4c21-99e0-3e1828c55a5e">
