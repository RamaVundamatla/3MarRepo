    <JadeMethod name="initFromRailCargoForm" id="488dd798-2f25-4c11-aa68-20d1681c3012">
        <updating/>
        <source>initFromRailCargoForm(_cargoForm: CM_BaseForm; _trackedItem: CM_TrackedItem; _cargoType: CM_CargoType) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(_cargoForm, _trackedItem, _cargoType);
	
	if _cargoType &lt;&gt; null then
		self.existingCargoType	:= _cargoType;
	endif;
	
	self.btnCargoId.visible := false;  //cnwrd1 28325 10.10.2011		
epilog

end;</source>
