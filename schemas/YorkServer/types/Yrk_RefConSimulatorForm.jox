    <JadeMethod name="messageData" id="c19afeec-d066-44d5-afb2-41ad09d7c023">
        <source>messageData(_subOpCode:Integer;_ti:Yrk_Container):Binary protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	now	: TimeStamp;
	message:String;
begin
	message := "";
	if _subOpCode = Reefer_Data then
		message := message&amp;self.timeOfAct(now);
		message := message&amp;_ti.ident();
		message := message&amp;_ti.location();
		message := message&amp;_ti.attributes();
	elseif _subOpCode = Reefer_Delete then
		message := message&amp;self.timeOfAct(now);
		message := message&amp;_ti.ident();
	elseif _subOpCode = Reefer_Key_Change then
		message := message&amp;self.timeOfAct(now);
		message := message&amp;_ti.oldIdent();
		message := message&amp;_ti.newIdent();
	elseif _subOpCode = Reefer_Monitor then
		message := message&amp;self.timeOfAct(now);
		message := message&amp;_ti.ident();
		message := message&amp;_ti.attributes();
		message := message&amp;_ti.tempsCommTimes();
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;message;
	elseif _subOpCode = Recall_Reefer_Data then
		message := message&amp;self.timeOfAct(now);
	elseif _subOpCode = Handler_RFR10 then
		message := message&amp;self.recordType();
		message := message&amp;self.messageCode();
		message := message&amp;self.timeOfAct(now);
		message := message&amp;_ti.ident();
		message := message&amp;_ti.location();
		message := message&amp;_ti.attributes();
		message := message&amp;_ti.newIdent();
	endif;
	self.logReport('Message='&amp;message);
	return message.Binary;
end;</source>
        <access>protected</access>
        <Parameter name="_subOpCode" type="Integer"/>
        <Parameter name="_ti" type="Yrk_Container"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="messageHeader" id="f6655de2-c874-4f89-bc5b-9a4453c2c92d">
        <source>messageHeader(_subOpCode:Integer):Binary protected;

vars
	message:Binary[10];
begin
	message := null;
	message[1:1] := #00.Binary[1:1]; //MSB message length
	message[2:1] := #00.Binary[1:1]; //LSB message Length
	message[3:1] := #00.Binary[1:1]; //Task number
	message[4:1] := #03.Binary[1:1]; //OpCode
	message[5:1] := #00.Binary[1:1]; //message computer description
	message[6:1] := #00.Binary[1:1]; //message task destination
	message[7:1] := #00.Binary[1:1]; //message computer source
	message[8:1] := #00.Binary[1:1]; //message task source
	if _subOpCode = Reefer_Data then
		message[9:1] := #01.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Delete then
		message[9:1] := #02.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Key_Change then
		message[9:1] := #03.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Monitor then
		message[9:1] := #04.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Recall_Reefer_Data then
		message[9:1] := #05.Binary[1:1]; //SubOpCode
	endif;
	message[10:1] := #00.Binary[1:1]; //Dummy

	return message;
end;</source>
        <access>protected</access>
        <Parameter name="_subOpCode" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
