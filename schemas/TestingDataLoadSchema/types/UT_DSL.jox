    <JadeMethod name="moveCargoForVoyageJob" id="cddd7ed1-5a5a-473c-8175-f9b99e33e9a4">
        <source>moveCargoForVoyageJob(_job: CM_Job; _mode: Integer);
vars
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	wlesToMove, wlesWithWarnings : CM_WLEArray;
	completedDate : TimeStamp;
	sleep, idx: Integer;
	q : CM_VoyageQueue;
begin
	job := _job;
	create wlesToMove transient;
	create wlesWithWarnings transient;
	
	if job.CM_VoyageJob.isHatchLidJob() then
		return;
	endif;
	foreach wle in job.workListEntries discreteLock do
		wlesToMove.clear();
		wlesWithWarnings.clear();
		wlesToMove.add(wle);
		app.myPassport.warningsAcknowledged	:= true;	// stop 'No planned location, want to autoplan' warning and do the autoplan instead
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarnings, _mode, true,  null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();	// some invoicing wles may not complete, don't really care
		self.assertTrueMsg(wlesWithWarnings.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		idx := idx + 1;
		
		if self.getTerminal() &lt;&gt; null and self.getTerminal().code = "BISH" then
			if idx &gt; 30 then
				break;
			endif;
		endif;
	endforeach;
	
	if idx = job.workListEntries.size then
	beginTransaction;
	job.CM_VoyageJob.updateActualAndEndTs(completedDate);
	commitTransaction;
	endif;
	
epilog
	delete wlesToMove;
	delete wlesWithWarnings;
	app.myPassport.warningsAcknowledged	:= false;	// reset after setting above
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
