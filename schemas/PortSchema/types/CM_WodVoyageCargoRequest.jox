    <JadeMethod name="validate" id="426ea36b-a9a3-49d2-9734-359c6de54a02">
        <source>validate()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2018	jlgndl1	Initial creation	TFS 39930
11 Oct 2021	jlier1	TFS 51963
*/

vars

	cargoDetail 		: CM_WodCargoRequest;
	marineServiceDetail : CM_WodMarineServiceDetail;
	
begin
	inheritMethod();
	
	if self.myBerth = null then
		app.raiseCMException( Input_required_field_berth, null, null );
	endif;
	
	//21 Nov 2018	NDL	TFS 41907
	foreach cargoDetail in self.allCargoDetails do
		cargoDetail.validateForUpdate();
	endforeach;
	
	//27 Nov 2018	NDL	TFS 41980
	foreach marineServiceDetail in self.allMarineServiceDetails do
		marineServiceDetail.validateForUpdate();
	endforeach;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
