    <JadeMethod name="getLabel" id="e131ce71-5cc8-42e2-b032-e932ecfffe9a">
        <source>getLabel() : String;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.label = null then
		return null;
	endif;
	
	if self.label[1] = '_' then
		return null;
	endif;
	
	return self.label;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLeastOverstowedAvailableTI" id="90f50833-e2f8-46c3-87c7-03e71e8d09df">
        <source>getLeastOverstowedAvailableTI(_yaRequest: CMIF_YARequest; _task : CM_RTQueueTask): CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwrd1	Initial creation
11 Feb 2022 jlier1	TFS 52822
*/

vars
	foundOne		: Boolean;
	tiSet,
	tiSetNFM,
	tiSetFinal,
	allOverstowedTIs		: CM_TIArray;
	ti,
	resultTI		: CM_TrackedItem;
	iter 			: Iterator;
	rtqTask			: CM_RTQueueTask;
	aRequest		: CM_Request;
	agent  			: CM_YAAutoplanAgent;
	tmpRequest 		: CMIF_YARequest;
	rtEntry 		: CM_RTQueueEntry;
	invalidTI 		: Boolean; 
	removedStr		: String;
	lastOverstowLevel,
	thisOverstow,
	sideAccessDirection 	: Integer;
begin

	on Exception do app.handleDeletedObject(exception, ti, invalidTI);  // nuts but needed in dev.
	
	create tiSet transient;
	create tiSetNFM transient;
	create tiSetFinal transient;
	create allOverstowedTIs transient;
	
	agent := app.myYAAgent;
	if agent = null then
		app.initialiseForStartAutoPlan(app.myPassport);
		agent := app.myYAAgent;
	endif;
	//19 Jan 2011	NDL	Par 26779
	
	if agent.myCurrentCMIFYAAutoPlan = _yaRequest then
		agent.setCurrentYAAutoPlanToNull();	// so it doesn't get deleted when tmpRequest is set there
	endif;
	
	create tmpRequest transient;
	
	self.getTIs(tiSet, REAL_MODE);
	foreach ti in tiSet do
		//jlier TFS 51580 16/9/21
		if _yaRequest.allFoundTis.includes(ti) then
			continue;
		endif;
		if not ti.isQueued then
			if _yaRequest.operatorCode = null or _yaRequest.operatorCode = ti.operatorCode then // PAR 26671 if not queued and correct operator
				if ti.releaseRequest &lt;&gt; null and ti.releaseRequest &lt;&gt; _yaRequest.myDeliveryRequest then  //make sure we are not on another release request!
					continue;
				endif;
				tiSetNFM.add(ti); //add them to the collecton
				tiSetFinal.add(ti); //this is checked at the end
			endif;
		endif;
	endforeach;
	
	// ok have to remove some matching rt task cargo
	// but not if the rt task is us
	
	// then we have to see if we have any cargo left

	// if we have then we want to go through ALL of the ti's again finding the least overstowed one. - because we know we can fullfil the other requests with what we have left.
	iter := self.allRTQueueTasks.createIterator;	
	self.allRTQueueTasks.startKeyGeq( TASK_DIRECTOR, TASK_UNACTIONED ,iter);
	while iter.next(rtqTask) do
	
		if rtqTask = _task then
		//its the one we are looking at so we can ignore 
			continue;
		endif;
		
		if rtqTask.status &lt;&gt; TASK_UNACTIONED or rtqTask.taskType &lt;&gt; TASK_DIRECTOR then
			break;
		endif;
	
		//due to machine rules we may have more than one rtq task per move so we need to filter out some
		rtEntry := rtqTask.myEntry;
		//epr par 35702 CCMS 2457 17/2/15
		if rtEntry.getPreviousRelatedEntry() &lt;&gt; null then
			// we are not the first part of the move so we can skip
			continue;
		endif;
		
		// should be processing unactioned director tasks here.
		// for each one we try to find a matching cargo item in tiSetNFM and if so we remove it.	
		aRequest := rtqTask.myEntry.getMyRequest();
		
		//if aRequest = null or not aRequest.isKindOf(CM_DeliveryRequest) then  // do we care what kind of request it is here? for YArequest?
		if aRequest = null or (not aRequest.isKindOf(CM_DeliveryRequest) and not aRequest.isKindOf(CM_SlotRequest) and not aRequest.isKindOf(CM_ROROSlotRequest) ) then		// 03/08/2010 cnwmh5 #25169
		//if aRequest = null then
			// no request, or not delivery request so pass on
			continue;
		endif;
		
		// ok need to find and remove the first matching ti in tiSetNFM
		
		tmpRequest.clear();
		// 03/08/2010 cnwmh5 #25169 - Start
		if aRequest.isVoyageAllocDirector() then //cnwrd1 ccms 1303 14.11.2012
				//need to initialise from the voyage allocation. 
			tmpRequest.setMyAllocation(aRequest.myTerminal, aRequest.getFirstAllocation() );	
		elseif aRequest.isKindOf(CM_DeliveryRequest) then
			tmpRequest.initializeFromDeliveryRequest(aRequest.myTerminal, aRequest.CM_DeliveryRequest);		
		elseif aRequest.isKindOf(CM_SlotRequest) and aRequest.isBulkRelease then
			tmpRequest.initializeFromBulkRelease(aRequest.myTerminal, aRequest);		
		endif;
		
		agent.setCurrentYAAutoPlan(tmpRequest);  
		
		foreach ti in tiSetNFM do
							
			if ti.testAutoPlanRequestYA(agent) then
				//found a match
				tiSetNFM.remove(ti);
				removedStr := removedStr &amp; CrLf &amp; ti.id &amp; 
					" is not available as it has already been allocated to a Director Task (" &amp; rtqTask.tiId &amp; ") on queue - " &amp; rtqTask.queueId;  // 23/12/2010 cnwmh5 - logging
				break;
			endif;		
		endforeach;	
	endwhile;
	
	on Exception do app.handleDeletedObject(exception, tmpRequest, invalidTI); //+cnwas3 -&gt; follow up on "07 Jan 2011 NDL -unit test leak"
	// now we have all the ti's that are left available , need to find one that matches the CMIF
//	agent.initialise();
	agent.setCurrentYAAutoPlan(_yaRequest);   // this all I need to do?
	if not removedStr.isBlank then
		agent.addLogEntry(AP_Log_YA_Default,removedStr &amp; CrLf, false);			// 23/12/2010 cnwmh5 - logging
	endif;

	foreach ti in tiSetNFM do			
		if ti.testAutoPlanRequestYA(agent) then
			//found a match		
			foundOne := true;
			break;
		endif;		
	endforeach;
	
	if not foundOne then
		return null;
	endif;
	// ok we have looked at the other RTQ tasks and the remaining TI's and we have at least 1 box that matches
	//so now we will go back through all the cargo find matching ones then find the least overstowed box out of those.
		
	lastOverstowLevel := 999999;
	tiSetNFM.clear;
		
	foreach ti in tiSetFinal do	
		if ti.testAutoPlanRequestYA(agent) then		
			tiSetNFM.add(ti);
		endif;
	endforeach;		
		
	agent.setCurrentYAAutoPlanToNull();	
	agent.setYAAutoPlanToNull();		

	foreach ti in tiSetNFM do
		// this is a matching one.
		allOverstowedTIs.clear;
		sideAccessDirection:=null;
		ti.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null);
		thisOverstow := allOverstowedTIs.size;
	// if zero, drop into the code below, otherwise store in the agent and continue
		if thisOverstow &gt; 0 then
			if thisOverstow &lt; lastOverstowLevel then
				resultTI := ti;
				lastOverstowLevel := thisOverstow;
			endif;
			continue;
		else
		// not overstowed, ideal box,  lets get out here!
			//jlier1 tfs 52822 11/2/22
			//if we are accessing from front or back then check if access restricted by lignting tower or building
			if sideAccessDirection &lt;&gt; CM_YABlock.SideAccess_NA then
				if ti.myPrimaryActualLocation.CM_GridController.isSideAccessRestricted(sideAccessDirection,null) then
					continue;
				endif;
			endif;
			return ti;
		endif;
	endforeach;
	
	return resultTI;

epilog
	delete iter;
	delete tiSet;
	delete tiSetNFM;
	delete tmpRequest;
	delete allOverstowedTIs;
	delete tiSetFinal;
end;
</source>
        <Parameter name="_yaRequest" type="CMIF_YARequest"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getMySubTerminalAreaDef" id="2c9cf0de-7eb1-43cb-b3bf-ed9a15945f39">
        <source>getMySubTerminalAreaDef(): CM_SubTerminalAreaDef;
/*

Purpose:			

Parameters:		Needed until we can reorg a reference on Grid Object.		

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	subTermAreaDef : CM_SubTerminalAreaDef;
	terminalArea : CM_TerminalArea;

begin

	if self.mySubTerminalAreaDef &lt;&gt; null then
		return self.mySubTerminalAreaDef;
	endif;
	
	terminalArea := self.getGridArea;
	if terminalArea &lt;&gt; null then
		return terminalArea.mySubTerminalAreaDef;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_SubTerminalAreaDef"/>
    </JadeMethod>
