<Class name="UT_USCustoms" id="70b35878-adcb-4257-9090-80c1668bc853">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>cnwrl1 29 September 2009 PAR 20320 - New Messina Messages

This subclass will be used to provide unit tests of all of the Messina Line EDI data types.
</text>
    <DbClassMap file="unitTest"/>
    <Constant name="X12FileName" id="a45deb73-b709-4e46-b1f2-21f5f63cccac">
        <source>"Unit Test X12 Test"</source>
