    <JadeMethod name="displayTable" id="a9cedce1-a6c3-4ca2-9cb1-ee5cb85f15e8">
        <updating/>
        <source>displayTable() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theDataLine 	: String;
	loadStateSet 	: Boolean;
	tbl				: CM_DataTable;
	trans : CM_EventTransaction;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	

	app.cmsBeginLoad(loadStateSet);
	foreach trans in self.myCurrentWagon.allTransactions discreteLock do
		
		theDataLine := trans.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(theDataLine)).itemObject := trans;
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="750c6831-64e0-4c5c-9403-785da0e3ab45">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation

*/

vars
	anObject 	: Object;
	hasObject	: Boolean;
begin
	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	
	if cntrl = self.tblData then
		hasObject := CMEVT_WagonTransaction.hasInstance(anObject);
	elseif cntrl = self.tblCharges then
		hasObject := CM_InvoiceLine.hasInstance(anObject);
	endif;
	
	if hasObject then
		self.doMnuContextModifyCaptions();
		self.doMnuContextVisibility(true, cntrl);
		return true;
	else
		self.doMnuContextVisibility(false, cntrl);
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
