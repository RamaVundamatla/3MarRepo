    <JadeMethod name="tblHeaderData_dblClick" id="bc0fef75-0f86-4faf-956f-c4931616c361">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHeaderData_dblClick(table: Table input) updating;

vars

begin

	if table.row &lt;= table.fixedRows then
		self.tblHeaderData.resortTableByColumn(table.column);
		self.tblHeaderData.colourRows(self.colorRow1, self.colorRow2);
		return;
	endif;
	if self.myCurrentScalingHdr &lt;&gt; null then
		self.scaleDataEdit();
	elseif self.myCurrentBOLOutHdr &lt;&gt; null then
		self.bolOutHdrEdit();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblHeaderData_rowColumnChg" id="1273b5a2-a144-42bb-9cd7-7e1f8fe14ec0">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
