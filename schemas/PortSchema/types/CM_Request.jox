    <JadeMethod name="getSelectedRTQ" id="00f40bf8-66f9-4953-b07c-6f151d11dcb4">
        <source>getSelectedRTQ() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwrd1	Initial creation

*/

vars

	invalidQueue	: Boolean;
	id				: String;
begin
	// May 2011 from development, add handler for invalid mySelectedRTQueue
	on Exception do app.handleDeletedObject(exception, self.mySelectedRTQueue, invalidQueue);

	if self.mySelectedRTQueue &lt;&gt; null then
		id := self.mySelectedRTQueue.id;
		return id;
	else
		return null;
	endif;

epilog

end;</source>
