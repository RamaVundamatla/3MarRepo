    <JadeMethod name="loadDefinitionFromFile" id="40e05d82-4de1-47ce-a64e-4e5ecbfb5073">
        <updating/>
        <source>loadDefinitionFromFile() updating;
//02/06/2010 cnwdz2 24641
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	root                : CM_Root;
	terminal            : CM_Terminal;
	theUser             : CM_User;
	definition          : CM_DataDumpExtractDef;
	proxyDef			: CM_DataDumpExtractDef;
	sqlTable            : CM_DataDumpExtractClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	psqlColumn          : CM_DataDumpSQLColumn;
	sqlDataType         : CM_DataDumpSQLDataType;
	jadeFeature         : CM_DataDumpFeature;
	description         : String;
	line,
	line1				: String;
	token               : String;
	delimiterString     : String;
	file                : File;
	cmd                 : CMDFileOpen;
	startPos            : Integer;
	lineCount           : Integer;
	newDefName          : String;
	realDefinition      : CM_DataDumpExtractDef;
	nextSQLTableFound   : Boolean;
	defCreated,
	canceled			: Boolean;
	errorMsg   			: String;
	previousSelObj      : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	previousSelObj := self.myCurrentObject;
	
	create file transient;
	create cmd transient;	
	file.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
	cmd.allowMultiSelect := false;
	cmd.readOnly := true;
	cmd.filter     := 'Definitions | *' &amp; self.SQLNative_DefExportFileFormat;

	if cmd.open = 0 then
		file.fileName := cmd.fileName;
		if (not file.isAvailable) then
			canceled := true;
			app.msgBox(app.getErrorString1(FileUnavailable, file.fileName), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
			return;
		endif;
	else
	   canceled := true;
	   return;
	endif;

	file.mode     := File.Mode_Input;
	app.mousePointer := Busy;
    defCreated    := false;
	while not file.endOfFile do 
		line     := file.readLine;
		startPos := 1;
		lineCount := lineCount + 1;
		
		token := line.getDelimitedToken(startPos, Tab, delimiterString);
		if token.length &gt; 0 then
			if token[1 : 1] = "[" then
				if token = "[Definition]" then
					if lineCount &lt;&gt; 1 then				
						return;
					endif;
					definition := createDefinitionFromFile(file);
					if definition = null then
						return;
					endif;
					realDefinition := self.handleDupDefForLoad(definition);
					delete definition;
					if realDefinition = null then
						canceled := true;
						return;
					endif;
				else
					continue;
				endif;
				
				self.createProxiesForEdit();
				proxyDef := self.myProxyObject.CM_DataDumpExtractDef;
				
				while not file.endOfFile do 
					line1     := file.readLine;
					startPos := 1;
					token := line1.getDelimitedToken(startPos, Tab, delimiterString);
					if token.length &gt; 0 then
						if (token[1 : 1] = "[" and token = "[SQLTable]") then							
							//1/11/2010 cnwdz2 26191
							sqlTable := createSQLTableFromFile(file, proxyDef, nextSQLTableFound,errorMsg);
							if errorMsg &lt;&gt; null then						
								//app.msgBox(errorMsg, app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
								//21 Jan 2015	NDL	Par 35249
								if app.msgBox(errorMsg, app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
									continue;
								else
									return;
								endif;
							endif;
							
							if sqlTable = null then						
								return;
							endif;							
							proxyDef.allDataDumpExtractClasses.add(sqlTable);
							
							while nextSQLTableFound do 
								nextSQLTableFound := false;
								//1/11/2010 cnwdz2 26191
								sqlTable := createSQLTableFromFile(file, proxyDef, nextSQLTableFound, errorMsg);
								if errorMsg &lt;&gt; null then									
									//app.msgBox(errorMsg, app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
									//21 Jan 2015	NDL	Par 35249
									if app.msgBox(errorMsg, app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
										continue;
									else
										return;
									endif;
								endif;
								
								if sqlTable = null then
									return;
								endif;
								proxyDef.allDataDumpExtractClasses.add(sqlTable);								
							endwhile;
						endif;
					endif;
				endwhile;
				
				proxyDef.setDefinitionModified(true);
				
				//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
				while true do
				
					app.myTrxUA.trxUpdateDataDumpExtractDef(proxyDef, app.myPassport);
				
					if app.myPassport.trxCompletedOK then
						defCreated := true;
						break;
					else
						theResult := app.showErrorWarningDialog('Extract Definition', app.myPassport, ErrWarnMode_AddUpdate);
						if app.myPassport.noErrors and theResult = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					
					return;
					
				endwhile;
	
			endif;
		else
			return;
		endif;
	
	endwhile;
	
	
	self.mySelectedClass := null;
	
	if defCreated = false then //25/06/2010 cnwdz2 24489
		return;
	endif;
	
	self.zHandleObjectAdd();
	self.tblData.selectObject(self.myCurrentObject, true);
	self.zDoTblDataRefresh();
	self.mode := Mode_View;
	self.zShowThumbnailData(self.myCurrentObject);

epilog
	file.close;
	self.zClearProxyDetails();
	app.mousePointer := Idle;
	delete file;
	delete cmd;
	//1/11/2010 cnwdz2 26191
	if errorMsg &lt;&gt; null then
		if realDefinition &lt;&gt; null then
			self.doDelete();
		endif;		
		if previousSelObj &lt;&gt; null then
			self.myCurrentObject := previousSelObj;
		endif;
	else
		if defCreated = false and canceled = false then//25/06/2010 cnwdz2 24489
			app.msgBox(app.getErrorString(ERR_InvalidDefFileFormat), app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			if previousSelObj &lt;&gt; null then
				self.myCurrentObject := previousSelObj;
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
