<Class name="CMQF_VoyageRORODeckItemSummary" id="1129d69c-d637-4ec9-8ddd-0deebe26a10f">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterForActualPlan" id="5e270acc-7aa4-4bae-8e43-342651bda5f0">
        <source>filterForActualPlan(_collection: Collection input; _passport: CM_Passport);
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 18 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 18/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//----------------------------------------------------------------------
vars
	voyage 				: CM_Voyage;
	cmifDeckItemReporter: CMIF_DeckItemPointReporter;
	trackedItem			: CM_TrackedItem;
	location			: CM_LocationsController;
	deckItem			: CM_DeckItem;
	cmifReporterSet		: CMIF_DeckItemPointReportSet;
	cmifReportHeaderSet : CMIF_DeckItemReportHeaderSet;
	deckVoyage			: CM_DeckVoyage;
	generalArea			: CM_ROROGeneralArea;
	machineryArea		: CM_ROROEquipment;
	
begin
	voyage := self.getMyVoyage;
	
	if voyage = null then
		return;
	endif;
	
	create cmifReportHeaderSet transient;
	
	foreach trackedItem in voyage.allOnshipTIsByCargoTypeId do
			
		location := trackedItem.getPrimaryLocation(REAL_MODE);
		if location &lt;&gt; null then
			deckItem := location.getDefn();
			if deckItem &lt;&gt; null then
				deckItem.buildCMIFDeckReporters(cmifReportHeaderSet, trackedItem);
			endif;
		endif;
		//cmifReporterSet.copy(_collection);
	endforeach;
	
	foreach deckVoyage in voyage.myROROStructure.allDecks do
		//We don't have cargo items for general areas or equipment so tracked item in this case will be null.
		foreach generalArea in deckVoyage.allGeneralItems do
			//Build CMIF general Area items
			generalArea.buildCMIFDeckReporters(cmifReportHeaderSet, null);
		endforeach;
		
		foreach machineryArea in deckVoyage.allMachinery do
			//Build CMIF machinery/equipment items.
			machineryArea.buildCMIFDeckReporters(cmifReportHeaderSet, null);
		endforeach;
	endforeach;
	cmifReportHeaderSet.copy(_collection);
epilog


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="f65696dd-f806-4f25-8cab-e5a26a6be0f6">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 18 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 18/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//----------------------------------------------------------------------
vars

begin
	//inheritMethod(_collection, _passport);
	if self.modeDescr = MODE_OPT_ACTUAL then
		self.filterForActualPlan(_collection , _passport);
	endif;

epilog
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
