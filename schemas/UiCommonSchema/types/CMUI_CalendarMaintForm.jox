        <source>changeValue();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2010	cnwndl1	Initial creation

*/

vars

	maintAllowed : Boolean;
	
begin

	maintAllowed := ( app.getMyUser.canDo(null, PmAdmCalendarMaint) or app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint) );
	if self.myProxyCalendar &lt;&gt; null and maintAllowed then
		self.btnCalSave.enabled := true;
		self.btnCancel.enabled := true;
	else
		self.btnCalSave.enabled := false;
		self.btnCancel.enabled := false;
	endif;
epilog

end;</source>
