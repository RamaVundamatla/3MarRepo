	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkIfWorkbookExists" id="b634f596-3f38-464d-ac5e-47cd26c1e04a">
        <source>checkIfWorkbookExists() : Boolean;

/*****************************************************
	Written by	:	cnwpra1		27 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	root		: Root;
	wb			: WorkbookDefinition;
	iter		: Iterator;
	found		: Boolean;

begin
	root := Root.firstInstance;
	iter := root.allWBDefnsByAssocNameAndName.createIterator;
	root.allWBDefnsByAssocNameAndName.startKeyGeq(associatedObjectName, null, iter);
	
	iter.next(wb);
	
	if wb = null then
		return false;
	endif;
	
	if wb.associatedObjectName = associatedObjectName then
		return true;
	else
		return false;
	endif;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWizardNotRunning" id="84dedfc7-8789-46cb-8d37-9af8583294f1">
        <source>checkWizardNotRunning() : Boolean;

/*****************************************************
	Written by	:	cnwpra1		17 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if intCurrentWizardStep &gt; 0 and intCurrentWizardStep &lt; 7 then
		app.msgBox('The Wizard is already running. You must cancel out of the Wizard before you can carry out this action.',
						'Error Action', MsgBox_OK_Only);
		return false;
	else
		return true;
	endif;
		
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b6f2a80a-9817-4410-bda0-5b4259ecde99">
        <updating/>
        <source>delete() updating;

/*****************************************************
	Written by	:	cnwgrp1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myExcelDA &lt;&gt; null then
		myExcelDA.closeExcel;
		myExcelDA.doCleanupProcessing;
		myExcelDA := null;
	endif;
	
	if myExcelDataDA &lt;&gt; null then
		delete myExcelDataDA;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doActivateCall" id="3078f4d0-2420-475a-9b32-3d6b9d2813ce">
        <source>doActivateCall(form : Form);

/*****************************************************
	Written by	:	cnwpra1		20 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	
vars
	
begin
	myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, form, Option_Activate_Form);

epilog

end;</source>
        <Parameter name="form" type="Form"/>
    </JadeMethod>
    <JadeMethod name="doCancelled" id="6921daff-7192-4b07-b893-c4d1d10a9d1e">
        <updating/>
        <source>doCancelled() updating;

/*****************************************************
	Written by	:	cnwgrp1		11 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myWorkbookDefinition &lt;&gt; null then
		unlock(myWorkbookDefinition);
	endif;
	
	myWorkbookDefinition := null;
	
	setIntCurrentWizardStep(9);
	
	if myExcelDataDA &lt;&gt; null then
		delete myExcelDataDA;
		myApplicationExtractOptions := null;
	endif;
	
	if blnAllWorkbooks then
		setMyAssociatedObject(null);
		setAssociatedObjectName(null);
		setAssociatedObjectType(null);
	endif;
	
	if myControllingAppsCancelMethod &lt;&gt; null then
		cancelHostApp;
	endif;
	
	if myExcelDA &lt;&gt; null then
		myExcelDA.closeExcel;
		myExcelDA.doCleanupProcessing;
		myExcelDA := null;
	endif;
	
	//if myControllingAppsCancelMethod &lt;&gt; null then
		//cancelHostApp;
	//endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateWorkbookDirect" id="ddf7d940-c673-4437-bca8-fe86b072f948">
        <updating/>
        <source>doCreateWorkbookDirect(
	_workbookName : String;
	_workbookDescription : String;
	_dataWorksheetName : String;
	_shouldDataWorksheetBeHidden: Boolean;
	_topWorksheetName : String;
	_applicationExtractOptions : Object;
	_associatedObject : Object;
	_associatedObjectName : String;
	_associatedObjectType : String;
	_workbookBlob : Binary) : String updating;

vars
	errorMessage : String;
	workbookDefinition : WorkbookDefinition;
	
begin
	errorMessage := null;
	self.initialiseRoot();
	
	
// Validation ===================================================================

	create self.myExcelDataDA;
	
	self.myExcelDataDA.setValues(
		_workbookName,
		_workbookDescription,
		_dataWorksheetName,
		_shouldDataWorksheetBeHidden,
		_topWorksheetName);
	
	if not self.myExcelDataDA.validateAbstractData(
		self.myRoot, 
		null, 
		_associatedObject,
		_associatedObjectName,
		_associatedObjectType) then
		
		errorMessage := self.myExcelDataDA.errorMessage;
				
	endif;
	
	if errorMessage = null then
		create self.myExcelDA;
		self.myExcelDA.openBlobForValidation(_workbookBlob);
		errorMessage := self.myExcelDA.validateAbstractData(_topWorksheetName, _dataWorksheetName);
		self.myExcelDA.closeExcel();
	endif;
	
	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;
	
	
// Saving to database ==============================================================
	
	beginTransaction;
		create workbookDefinition;
		workbookDefinition.setValues(
			self.myRoot,
			_workbookName,
			_workbookDescription,
			_dataWorksheetName,
			_shouldDataWorksheetBeHidden,
			_topWorksheetName,
			_applicationExtractOptions,
			_associatedObject,
			_associatedObjectName,
			_associatedObjectType);
		workbookDefinition.setWorkbook(_workbookBlob);
	commitTransaction;
	
	return null;
	
epilog
	delete self.myExcelDA;
	delete self.myExcelDataDA;
	
end;</source>
        <Parameter name="_workbookName" type="String"/>
        <Parameter name="_workbookDescription" type="String"/>
        <Parameter name="_dataWorksheetName" type="String"/>
        <Parameter name="_shouldDataWorksheetBeHidden" type="Boolean"/>
        <Parameter name="_topWorksheetName" type="String"/>
        <Parameter name="_applicationExtractOptions" type="Object"/>
        <Parameter name="_associatedObject" type="Object"/>
        <Parameter name="_associatedObjectName" type="String"/>
        <Parameter name="_associatedObjectType" type="String"/>
        <Parameter name="_workbookBlob" type="Binary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doDeleteWBDefinition" id="c64d025b-c4a3-415b-88d2-2653167458bf">
        <updating/>
        <source>doDeleteWBDefinition(pWorkbookDefn:WorkbookDefinition io) updating;

/*****************************************************
	Written by	:	cnwgrp1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	deletedOk : Boolean;

begin
	beginTransaction;
		delete pWorkbookDefn.myApplicationExtractOptions;
		delete pWorkbookDefn;
	commitTransaction;
epilog

end;</source>
        <Parameter name="pWorkbookDefn" type="WorkbookDefinition" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doExtractWorkbook" id="2e873adf-f68f-470f-82f0-5136ca180170">
        <updating/>
        <source>doExtractWorkbook() updating;

/*****************************************************
	Written by	:	cnwpra1		28 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	fileDA			: FileManagementDA;
	cmd				: CMDFileSave;

begin
	if myWorkbookDefinition.workbook = null then
		app.msgBox('The selected Workbook Definition has not been set up with an Excel workbook', 'No Workbook', MsgBox_OK_Only);
		return;
	endif;
	
	create cmd;
	cmd.dialogTitle := 'Select the path and file name to save the workbook to';
	cmd.defaultExt := '.xls';
	cmd.fileMustExist := false;
	cmd.fileName := myWorkbookDefinition.workbookName;
	cmd.filter := 'Excel workbooks|*.xls';
	if cmd.open &lt;&gt; 0 then
		return;
	endif;
	
	create fileDA transient;
	fileDA.copyBlobToFile(myWorkbookDefinition.workbook, null, cmd.fileName);
	
epilog
	delete cmd;
	delete fileDA;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFinished" id="2109eb37-6f3f-4587-b88b-329429087049">
        <updating/>
        <source>doFinished(form : Form) updating;

/*****************************************************
	Written by	:	cnwgrp1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	Option_Delete_Form = 3;
	
vars
	frm : Object;
	int : Integer;
	doDelete	: Boolean;
begin
	doFormDeleteCall(form);
	
	if getAllOpenForms.isEmpty then
		myControllingAppsDA.invokeMethod(myControllingAppsContext,myControllingAppsTargMethod, null);
		doDelete := true;
		if myWorkbookDefinition &lt;&gt; null then
			unlock(myWorkbookDefinition);
		endif; 
		
		if myExcelDA &lt;&gt; null  then
			myExcelDA.closeExcel;
			myExcelDA.doCleanupProcessing;
			myExcelDA := null;
		endif;
		
	else
		if intCurrentWizardStep &gt; 7 then
			if myWorkbookDefinition &lt;&gt; null then
				unlock(myWorkbookDefinition);
				setMyWorkbookDefinition(null);
			endif;
			
			if myExcelDA &lt;&gt; null then
				myExcelDA.closeExcel;
				myExcelDA.doCleanupProcessing;
				myExcelDA := null;
			endif;
			
			if myExcelDataDA &lt;&gt; null then
				delete myExcelDataDA;
			endif;
			
			cancelHostApp;
			
		endif;
	endif;
	
	if doDelete then
		delete self;
	endif;
	
epilog

end;</source>
        <Parameter name="form" type="Form"/>
    </JadeMethod>
    <JadeMethod name="doFormDeleteCall" id="43264018-9c58-40e5-9a61-1c3229b493ba">
        <source>doFormDeleteCall(form : Form);

