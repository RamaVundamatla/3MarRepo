    <JadeMethod name="getAllGoodTrackedItems" id="1e7f0185-e25f-454c-879a-f51dbe8dc584">
        <source>getAllGoodTrackedItems( _localTiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2016	cnwndl1	Initial creation	TFS 1726

*/

vars

	ti : CM_TrackedItem;
	invalid : Boolean;
	edition : Integer;

begin

	on Exception do app.handleDeletedObject( exception, ti, invalid );

	foreach ti in self.allTrackedItems discreteLock do
		
		invalid := false;
		edition := ti.edition;
		if not invalid then
		
			// ### JIRA 36550 07NOV2025 NAVAB1
			if ti.isZombie() then
				continue;
			endif;
		
			_localTiArray.add( ti );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_localTiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
