	endif;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBTestInspect" id="b0ed93b7-ce5f-4c6a-bd26-7dc490966e9a">
        <source>dataDumpXDBTestInspect();
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwsb1
//
// Purpose:		Allows easy inspection of any External Dictionary.
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	obj : Object;
	extObj : ExternalObject;
	def : CM_DataDumpExtractDef;
	transExtractDef : CM_DataDumpTransExtractDef;
	classToInspect : Class;

begin
	app.initialize;
	
	create agent transient;
	on Exception do self.dataDumpXDBExHandler(exception, agent);

	classToInspect := CM_Country;	// Change to inspect new class
	
	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);
	
	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	
	agent.inspectExternalDict(classToInspect);
	
epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete transExtractDef;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBTestSpeed" id="b848717e-725d-4025-abca-b07ca614e4ef">
        <source>dataDumpXDBTestSpeed();
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Performance:	Make sure ODBCTraceOn=false before running !
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	extObj : ExternalObject;
	cnt : Integer;
	tsFrom : TimeStamp;
	str : String;
	def : CM_DataDumpExtractDef;
	transExtractDef : CM_DataDumpTransExtractDef;
	oba : ObjectArray;
	classToTest : Class;
	obj : Object;
	descr : String;

begin
	app.initialize;
	
	create agent transient;
	on Exception do self.dataDumpXDBExHandler(exception, agent);
	
	classToTest := CM_Country;

	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);

	create oba transient;
	classToTest.allInstances(oba, agent.MaxPerExternalTransaction, true);
	
	tsFrom := app.actualTimeServer;
	
	foreach obj in oba do
		cnt := cnt + 1;
		extObj := agent.getExternalObj(obj);
		if extObj = null then
			str := str &amp; CrLf &amp;
					"couldn't find country for " &amp; obj.CM_Country.code;
			continue;
		endif;
		descr := extObj.EDB_Country.getPropertyValue("edb_Description").String;
		if descr &lt;&gt; descr.trimRight then
			str := str &amp; CrLf &amp; "'" &amp; descr &amp; "'";
		endif;
	endforeach;

	str := str &amp; CrLf &amp;
			tsFrom.cnSecondsDifference(app.actualTimeServer).String &amp; " seconds";
			
	app.writeStatement( str);
	
epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete transExtractDef;
	delete agent;
	delete oba;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBTestUpdate" id="828f0003-1ede-4684-949e-efa1a3753e0d">
        <source>dataDumpXDBTestUpdate();
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	obj : Object;
	def : CM_DataDumpExtractDef;
	transExtractDef: CM_DataDumpTransExtractDef;
	created, updated : Boolean;
	sqlStatement: String;
	loadMode: Boolean;
begin
	app.initialize;
	
	create agent transient;
	on Exception do self.dataDumpXDBExHandler(exception, agent);

	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	
	obj := CM_Country.lastInstance;
	app.writeStatement( global.dataDumpFormatHex(obj));

	agent.beginTrans;
	agent.updateExternalObj(obj, created, updated, sqlStatement, loadMode);
	agent.commitTrans("EDB");
	if sqlStatement &lt;&gt; null then
		app.writeStatement( sqlStatement);
	endif;

	agent.getExternalObj(obj).inspectModal;
	
epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete agent;
	delete transExtractDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="datadumpConverHexListToOidList" id="21e1ad45-153e-458e-aceb-ea8ed12ec441">
        <source>datadumpConverHexListToOidList();

vars
	fileIn, fileOut : File;
	strHex, strOid : String;
	object : Object;
	count1, count2 : Integer;
	ti : CM_TrackedItem;
	tr : CM_Transaction;
begin
	create fileIn transient;
	fileIn.fileName := "c:\poe\hexoid.txt";
	fileIn.mode := File.Mode_Input;
	fileIn.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	fileIn.open;
	create fileOut transient;
	fileOut.fileName := "c:\poe\stroid.txt";
	fileOut.mode := File.Mode_Output;
	fileOut.open;
	while not fileIn.endOfFile do
		count1 := count1 + 1;
		strHex := fileIn.readLine;
		strOid := strHex.dataDumpHexToOidString();
		fileOut.writeLine(strOid);
		object := strOid.asOid.Object;
		ti := object.CM_TrackedItem;
		if global.isValidObject(ti) then
			beginTransaction;
			ti.updateObjectEdition (ti);	// par 30292
			count2 := count2 + 1;
			foreach tr in ti.allTransactions do
				tr.updateObjectEdition(ti);	// par 30292
			endforeach;
			commitTransaction;
		endif;
	endwhile;
	fileOut.writeLine("found="&amp;count1.String&amp;" updated="&amp;count2.String);
epilog
	fileIn.close;
	fileOut.close;
	delete fileIn;
	delete fileOut;
end;
</source>
    </JadeMethod>
    <JadeMethod name="deleteAllObjects" id="e06c3afc-18cd-4be1-8629-85a34f0cb926">
        <source>deleteAllObjects();

vars
	objArray : ObjectArray;
	object : Object;
	root : CM_Root;	
	terminal : CM_Terminal;
	aClass : Class;
begin
//	app.initialize;
	write "Start total deletion.";
	create objArray transient;
	CM_ShipPortGroup.allInstances(objArray,0,true);
	foreach object in objArray do
		if global.isValidObject(object) then
			beginTransaction;
			app.writeStatement(object.String);
			object.CM_Object.erase(NORMAL_ERASE);
			commitTransaction;
		endif;
	endforeach;
	root := CM_Root.firstInstance;
	if root &lt;&gt; null then
		foreach terminal in root.allTerminals do
			beginTransaction;
			terminal.erase(NORMAL_ERASE);
			commitTransaction;
		endforeach;
		beginTransaction;
		root.erase(NORMAL_ERASE);
		commitTransaction;
	endif;
	objArray.clear();
	CM_Object.allInstances(objArray,0,true);
	foreach object in objArray do
		if global.isValidObject(object) then
			if aClass = null or 
			   aClass &lt;&gt; object.class then
				write object.String;
				aClass := object.class;
			endif;
			beginTransaction;
			object.CM_Object.erase(NORMAL_ERASE);
			commitTransaction;
		endif;
	endforeach;
epilog
	delete objArray;
	write "Finished deletion.";
end;</source>
    </JadeMethod>
