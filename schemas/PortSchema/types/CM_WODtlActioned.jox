<Class name="CM_WODtlActioned" id="acd50f4e-5f3e-441c-88c4-f390bbacfcaf">
    <superclass name="CM_WOTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="myJob" id="5ffb1ff3-a963-4d8b-8b62-3bbf17d3eefc">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Job"/>
        <access>readonly</access>
        <text>
Note that once the job has been completed it is deleted so this will be null</text>
        <Inverse name="CM_Job::myWorkOrderTransaction"/>
