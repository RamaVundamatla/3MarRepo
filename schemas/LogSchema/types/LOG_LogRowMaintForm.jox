        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblSearch.clearValues;
	self.tblSearch.setValueByName(ETRow_FiltStatus, Status_OpenClosed);
