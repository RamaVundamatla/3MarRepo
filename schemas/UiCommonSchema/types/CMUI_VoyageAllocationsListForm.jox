    <JadeMethod name="deactivate" id="29aa3a82-60fc-498b-a619-367815cbca80">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
// --------------------------------------------------------------------------------
// Created:		27 July 2010 by cnwjo3
//
// Purpose:		par 25114
//
vars
	idx : Integer;
	f : Form;
begin
	f := app.activeForm;
	if f = null then
		return;
	endif;	
	
	if f &lt;&gt; self.myParentForm and not f.isKindOf(CMUI_YAMaintVoyForm) then
		self.myParentForm.deactivate();
	endif;			//cnwas3 par 27769


/*

	if f.isKindOf(CMUI_YAMaintVoyForm) or f.name = "SHP_VoyageAreaForm2"  then
	else
		foreach idx in 1 to app.formsCount do
			f := app.forms(idx);
			if f.name = "SHP_VoyageAreaForm2"  then
				f.deactivate();
			endif;
		endforeach;
	endif;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyAllocation" id="6bcc7810-ed52-4db4-8903-8102b792dd46">
        <updating/>
        <source>deleteVoyAllocation() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	
	realAlloc 				: CM_VoyageAllocation;
	voyCode 				: String;
	result 					: Integer;
begin	
	if self.myVoyage = null then		
		return false;
	endif;
	
	realAlloc := self.myCurrentVoyageAllocation;		
										
	
	if realAlloc = null then
		return false;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageAllocation(realAlloc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
epilog	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyAllocationALL" id="ee1e6cea-b95f-4aea-b809-2d7d6786d46d">
        <updating/>
        <source>deleteVoyAllocationALL() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	voyAllocations : CM_YardAllocationSet;
	realAlloc 				: CM_VoyageAllocation;
	voyCode, tmpStr 				: String;
	result , idx					: Integer;
	obj : Object;
begin	
	if self.myVoyage = null then		
		return false;
	endif;
	create voyAllocations transient;
	foreach idx in self.tblCCAllocation.fixedRows + 1 to self.tblCCAllocation.rows do //cnwas3 par26840
		obj := self.tblCCAllocation.accessRow(idx).itemObject;
		if obj = null then // PAR 23405
			continue;
		endif;
		voyAllocations.add(obj.CM_VoyageAllocation);
	endforeach;
	
	if voyAllocations.isEmpty() then
		return false;
	endif;
	
	if self.isExport then
		tmpStr := app.getErrorString(Export);
	else
		tmpStr := app.getErrorString(Import);
	endif;
	if app.msgBox(app.getErrorString2(CONFIRM_ALL_VOY_ALLOC_DELETE,tmpStr, self.myVoyage.code),app.getErrorString(Confirmed),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return true;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageAllocations(voyAllocations, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
epilog	
	delete voyAllocations;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayCCTable" id="03ac27a9-d63a-4491-bb61-c2d8e9391d10">
        <updating/>
        <source>displayCCTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jan 2010	cnwas3	Initial creation
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
					Added back beginLoad/endLoad, but made granular to prevent deadlock issues
					
*/

vars
	theDataLine 	: String;
	loadStateSet 	: Boolean;
	dict 			: CM_YardAllocationSet;
	voyageAllocation : CM_YardAllocation;
	idx,
	colourCol,
	col				: Integer;
	tbl				: CM_DataTable;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblCCAllocation;
	
//	tbl.gridColor := Black;
	tbl.rows := tbl.fixedRows;
	colourCol := tbl.getColumnByRowName(ETRow_AllocName);	
	
	create dict transient;
	self.myVoyage.allVoyageAllocations.copyNoDuplicates(dict, false);	
	
//	app.cmsBeginLoad(loadStateSet);	#26985. No need to lock and hold locks on all collections to be touched below until epilog. 14/02/2011
	foreach voyageAllocation in dict do	
		// PAR 25833 if not (self.isExport = voyageAllocation.isExportAllocation()) then
		if not (self.isExport = (voyageAllocation.isExportAllocation() or voyageAllocation.isTranshipAllocation())) then
		
			continue;
		endif;
		theDataLine := voyageAllocation.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(theDataLine);
		tbl.accessRow(idx).itemObject := voyageAllocation;			
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		tbl.accessCell(idx, colourCol).backColor := voyageAllocation.color;		
		tbl.accessCell(idx, colourCol).foreColor := voyageAllocation.color.getInverseColour();
		
	endforeach;	
	
		
	tbl.sortColumn[1] := 2;	
	tbl.sortAscending := true;	

	app.cmsBeginLoad(loadStateSet);					// PAR #27032
	self.displayCCTableExportNums();
	app.cmsEndLoad(loadStateSet);					// PAR #27032
	
	app.cmsBeginLoad(loadStateSet);					// PAR #27032
	self.displayCCTableRehandlesNums();  //cnwas3 par 26773
	app.cmsEndLoad(loadStateSet);					// PAR #27032
	
	app.cmsBeginLoad(loadStateSet);					// PAR #27032
	self.displayCCTableSOBsNums();
	app.cmsEndLoad(loadStateSet);					// PAR #27032
	
	self.displayCCTableTotalNums();
	self.displayCCTableTotals();

	
epilog
	delete dict;
	app.cmsEndLoad(loadStateSet);					// PAR #27032
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCCTableExportAddOne" id="4fb914d4-024c-4fd0-a324-a08202b9b35f">
        <source>displayCCTableExportAddOne(_alloc : CM_VoyageAllocation);
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	allocTotals : CM_VoyAllocationByPriority;
	tbl				: CM_DataTable;
	voyAlloc : CM_VoyageAllocation;
	exportCol,varCol, idx, totTIs, totRow, varience : Integer;
	iter : Iterator;
begin
	if _alloc = null then
		return;
	endif;
	
	tbl := self.tblCCAllocation;
	exportCol := tbl.getColumnByRowName(ETRow_MatchingTIsCollection);	
	if exportCol = 0 then
		return;
	endif;
	varCol := tbl.getColumnByRowName(ETRow_Variance);	
	totRow := tbl.rows - 1;
	
	foreach idx in tbl.fixedRows + 1 to tbl.rows do		//cnwas3 par 26840
		voyAlloc := tbl.accessRow(idx).itemObject.CM_VoyageAllocation;
		if voyAlloc = _alloc then
			// EXPORTS
			totTIs := tbl.accessCell(idx,exportCol).text.Integer;
			totTIs := totTIs + 1;
			tbl.accessCell(idx,exportCol).text := totTIs.zeroNotAllowed();
			
			totTIs := tbl.accessCell(totRow,exportCol).text.Integer;
			totTIs := totTIs + 1;
			tbl.accessCell(totRow,exportCol).text := totTIs.zeroNotAllowed();
			
			// VARIANCE
			totTIs := tbl.accessCell(idx,varCol).text.Integer;
			totTIs := totTIs + 1;
			tbl.accessCell(idx,varCol).text := totTIs.zeroNotAllowed();
			
			totTIs := tbl.accessCell(totRow,varCol).text.Integer;
			totTIs := totTIs + 1;
			tbl.accessCell(totRow,varCol).text := totTIs.zeroNotAllowed();
			
			break;
		endif;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_alloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="displayCCTableExportNums" id="bef48fef-0e06-4817-8cc7-058a710a6062">
        <source>displayCCTableExportNums();
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11 Jan 2011		cnwkpd1			PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	allocTotals : CM_VoyAllocationByPriority;
	tbl				: CM_DataTable;
	voyAlloc : CM_VoyageAllocation;
	exportCol,varCol, idx, totTIs, varience : Integer;
	iter : Iterator;
	allTIs : CM_TISet;//cnwas3 par 26840
	ti : CM_TrackedItem;
begin
	tbl := self.tblCCAllocation;
	exportCol := tbl.getColumnByRowName(ETRow_MatchingTIsCollection);	
	if exportCol = 0 then
		return;
	endif;
	varCol := tbl.getColumnByRowName(ETRow_Variance);	
	
	
	create allocTotals transient;
	create allTIs transient;
	iter := allocTotals.createIterator();
	self.myVoyage.getNumExportsForVoyAllocation(allocTotals,allTIs);
	
		
	self.doNotableClear();						//cnwas3 par 28640b	
	if not allTIs.isEmpty() then							
		foreach ti in allTIs do
			self.doNotableAdd(ti);
		endforeach;
	endif;
	
	foreach idx in tbl.fixedRows + 1 to tbl.rows do //cnwas3 par 26840
		voyAlloc := tbl.accessRow(idx).itemObject.CM_VoyageAllocation;
		totTIs := 0;
		
		if allocTotals.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			allocTotals.getIteratorKeys(totTIs,iter);
			
			tbl.accessCell(idx,exportCol).text := totTIs.zeroNotAllowed();
		endif;
		if varCol &gt; 0 and voyAlloc &lt;&gt; null then
			varience := (totTIs - voyAlloc.projected20);
			tbl.accessCell(idx,varCol).text := varience.zeroNotAllowed();
			
		endif;
		
	endforeach;
	
epilog
	delete allocTotals;
	delete allTIs;
	delete iter;		// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCCTableRehandlesNums" id="7d05b986-72e3-4dfe-934f-971302d84282">
        <source>displayCCTableRehandlesNums();
/*

Date		    Who			Reason
24 January 2011	cnwas3	  par26773

*/

vars
	allocTotals : CM_VoyAllocationByPriority;
