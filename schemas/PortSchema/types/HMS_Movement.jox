    <JadeMethod name="setMyBerth" id="8db8926c-9a61-4342-a858-aad14c49fd5a">
        <updating/>
        <source>setMyBerth(_berth : HMS_Berth ) updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2007 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Sep 2019 jlgka1 TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	self.myBerth := _berth;
	
	// always set berth on next movement
	self.setNextMovementBerthPrevious(_berth);
	
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setMyBerthPrevious" id="7bd17356-1b47-4727-9120-800075ed2020">
        <updating/>
        <source>setMyBerthPrevious() updating;
//-----------------------------------------------------------------------
//	Created:	08 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
18/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
23/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	prevMove	: HMS_Movement;
	prevBerth	: HMS_Berth;
	
begin
	prevMove := self.myPreviousMovement;
	if prevMove = null then
		self.myBerthPrevious := null;
		return;
	endif;
	
	prevBerth := prevMove.getMyBerth();
	
	self.myBerthPrevious := prevBerth;

end;</source>
    </JadeMethod>
