    <JadeMethod name="trxPropagateWorkPointRates" id="88eb69d6-01b9-46b5-94cf-f3bfabe5fddb">
        <updating/>
        <source>trxPropagateWorkPointRates(	_selectedDict : CM_WorkPointByCodeDict input; 
							_allTemplates : CM_WPRatesByCargoTypeProduct input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	wp : CM_WorkPoint;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	app.setContinueCMExceptions(true);

	foreach wp in _selectedDict do

		app.myUtilityUA.utlPropagateWorkPointRates( wp, _allTemplates, _passport);
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;
	
epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
