        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="imexCode" id="94d18c6b-aa11-4866-96de-bf5a218980aa">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
