    <JadeMethod name="loadDataForFirstTime" id="83862a39-e402-4140-bd60-a7e7cd1e7600">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	aVoyage : CM_Voyage;
begin
	inheritMethod();
	self.allCurrentVoyages.clear();
		
	self.myTerminal.getAllCurrentCellularVoyages(self.allCurrentVoyages, false, false);
	
	self.cmbVoyages.clear;
	self.cmbVoyages.listCollection(self.allCurrentVoyages,false,0);
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyageForTerminal(self.myTerminal);
	
	if aVoyage &lt;&gt; null then
		if self.allCurrentVoyages.includes(aVoyage) then
			self.cmbVoyages.listObject:=aVoyage;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
