    <JadeMethod name="trxDischargeCargoAutoPlan" id="0bcebb3a-9818-4069-afe6-33e0de460fba">
        <updating/>
        <source>trxDischargeCargoAutoPlan(	_machine : CM_Machine input;
							_ti : CM_TrackedItem input;
							_quantity : Integer;
							_weight : Decimal;
							_job : CM_VoyageJob output;
							_wle : CM_WorkListEntry output;						
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
18 March 2015	cnwer1	Initial creation PAR 35893
18 Sept  2017	jlgmd1	TFS 6813 - QNS - Jade application slow

*/

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813

	beginTransaction;
	
	app.myUtilityUA.utlDischargeCargoAutoPlan(_machine,_ti,_quantity,_weight,_job,_wle,_passport);
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
