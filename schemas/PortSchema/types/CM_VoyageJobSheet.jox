    <JadeMethod name="getOOWInfoLine" id="84f041f9-b06a-4628-8eb6-5f314824a1d2">
        <source>getOOWInfoLine(_totTI : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	SPACE = "      ";
vars
	totTI, ratePH, numHours, numMin, eachItem,allItems : Real;
	aCrane : CM_Crane;
	workPointObj	: CM_Object;
	etc, workStarted : TimeStamp;
	craneID : String;
	aJS : CM_VoyageJobSheet;
begin
	workPointObj := self.getMyWorkPointObject;
	
	if workPointObj = null then
		return null;
	endif;
	
	if _totTI = 0 then
		totTI := self.getTotalOOWItems();
	else
		totTI := _totTI;
	endif;
	
	if workPointObj.isKindOf(CM_WorkPoint) and workPointObj.CM_WorkPoint.hasDefinedCargoRates then	//08 Mar 2017	NDL	TFS 37437
		ratePH := workPointObj.CM_WorkPoint.getDefinedTargetRateWeight( self );
	else
		ratePH := workPointObj.IF_VoyageWorkPoint.getTargetRatePH;
	endif;
	if ratePH &gt; 0 then
		eachItem := (60 / ratePH); // in  minutes
	endif;
	allItems := (totTI * eachItem); // in minutes
	
	numHours := (allItems / 60).Integer.abs;
	numMin := (allItems - (numHours * 60)).Integer.abs;

	workStarted := self.getWorkStarted();
	etc := workStarted.cnEcAddMinutes(allItems.Integer);
	
	//11 Aug 2009	NDL	CCMS 1031 Par 20474
	craneID:=workPointObj.IF_VoyageWorkPoint.getTypeDescription &amp; " " &amp; workPointObj.IF_VoyageWorkPoint.getID;
	aCrane := self.getMyCrane();
	if aCrane &lt;&gt; null then
		craneID :=craneID &amp; " (";
		if aCrane.machineLiftType = TWIN_LIFT then
			craneID := craneID &amp; "T/L ";
		endif;
		if self.oowReversed then
			craneID := craneID &amp; "A&gt;F";
		else
			craneID := craneID &amp; "F&gt;A";
		endif;
		craneID := craneID &amp; ")";
	endif;
	
	return 	craneID &amp; "  " &amp; 
			totTI.String &amp; " Items @ " &amp; 
			ratePH.String &amp; " CPH = " &amp; 
			numHours.String &amp; " Hours " &amp; 
			numMin.String &amp; " Minutes" &amp; 
			SPACE &amp; "|" &amp; SPACE &amp; "ETC " &amp; etc.date.shortFormatJMT() &amp; SPACE &amp; etc.time.shortFormatJMT();
//			 &amp; " | ATC @ 40 CPH 12:11";

end;</source>
        <Parameter name="_totTI" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShiftDelayHoursLoLo" id="1c0c5aee-d508-46a3-9bb9-fb5b858751c3">
        <source>getShiftDelayHoursLoLo(_from, _to : TimeStamp; _delayCol : CM_DelayByStartDTDict input) : Real;
//getShiftDelayHours Renamed 11/04/2017 cnwma1 TFS #4027
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:
// 11/04/2017	cnwma1 TFS #4027:MSL - Voyage Side Profile - delay not showed
// ---------------------------------------------------------------------------
vars
	aDelay : CM_Delay;
	numHoursDelayed : Real;
	fromTS, toTS : TimeStamp;
	aCrane : CM_Crane;
	delayIsOnShift : Boolean;
	posNeg, numOfDays : Integer;
begin
	
	aCrane := self.getMyCrane();
	if aCrane = null then   
		return 0;
	endif;
	
	if _delayCol = null then
		return 0;
	endif;
	
	_delayCol.clear;
	
	foreach aDelay in self.myVoyage.allDelays discreteLock  do
		// we want all delays except delays for other cranes.
		if aDelay.myMachine &lt;&gt; null and aDelay.myMachine &lt;&gt; aCrane then
			continue;
		endif;
		
		delayIsOnShift := false;
		
		fromTS := aDelay.startDT;
		toTS := aDelay.endDT;
		if not toTS.isValid() then
			toTS := aDelay.estEndDT;
		endif;

		if fromTS &gt;= _from and fromTS &lt;= _to then // delay begins within shift
			delayIsOnShift := true;
			if toTS &gt; _to then // delay ends after shift
				toTS := _to;
			endif;
		elseif toTS &gt;= _from and toTS &lt;= _to then // delay ends within shift
			delayIsOnShift := true;
			fromTS := _from;
		elseif _from &gt;= fromTS and _to &lt;= toTS  then // delay if for the whole shift
			delayIsOnShift := true;
			fromTS := _from;
			toTS := _to;
		endif;
	
		if delayIsOnShift then
			_delayCol.addNoDuplicates(aDelay,false);
			// WAS numHoursDelayed := numHoursDelayed + fromTS.differenceAsTime(toTS,posNeg, numOfDays).getTotalMilliseconds/ 3600000;
			numHoursDelayed := numHoursDelayed + fromTS.differenceInHoursReal(toTS);
			
		endif;
	endforeach;
	return numHoursDelayed;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_delayCol" type="CM_DelayByStartDTDict" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getShiftDelayHoursRoRoHold" id="c617e932-a5c6-4f6c-8e21-4bb4ba8f121e">
        <source>getShiftDelayHoursRoRoHold(_from, _to : TimeStamp; _delayCol : CM_DelayByStartDTDict input) : Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2017	cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed

*/
vars
	aDelay : CM_Delay;
	numHoursDelayed : Real;
	fromTS, toTS : TimeStamp;
	aCrane : CM_Crane;
	delayIsOnShift : Boolean;
	posNeg, numOfDays : Integer;
	aWorkPoint :CM_WorkPoint;
begin
	
	aWorkPoint := self.getMyWorkPoint();

	if aWorkPoint = null then
		return 0;
	endif;
	
	if _delayCol = null then
		return 0;
	endif;
	
	_delayCol.clear;
	
	foreach aDelay in self.myVoyage.allDelays discreteLock  do
		// we want all delays for this work Point
		if aDelay.myWorkPoint &lt;&gt; null and aDelay.myWorkPoint.code &lt;&gt; aWorkPoint.code then
			continue;
		endif;

		delayIsOnShift := false;
		
		fromTS := aDelay.startDT;
		toTS := aDelay.endDT;
		if not toTS.isValid() then
			toTS := aDelay.estEndDT;
		endif;

		if fromTS &gt;= _from and fromTS &lt;= _to then // delay begins within shift
			delayIsOnShift := true;
			if toTS &gt; _to then // delay ends after shift
				toTS := _to;
			endif;
		elseif toTS &gt;= _from and toTS &lt;= _to then // delay ends within shift
			delayIsOnShift := true;
			fromTS := _from;
		elseif _from &gt;= fromTS and _to &lt;= toTS  then // delay if for the whole shift
			delayIsOnShift := true;
			fromTS := _from;
			toTS := _to;
		endif;
	
		if delayIsOnShift then
			_delayCol.addNoDuplicates(aDelay,false);
			numHoursDelayed := numHoursDelayed + fromTS.differenceInHoursReal(toTS);
			
		endif;
	endforeach;
	return numHoursDelayed;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_delayCol" type="CM_DelayByStartDTDict" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getShiftDelayMinutes" id="d954ba05-645b-424e-bfd9-292be37c73c8">
        <source>getShiftDelayMinutes(_from, _to : TimeStamp) : Real;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDelay : CM_Delay;
	numHoursDelaid : Real;
	fromTS, toTS : TimeStamp;
	aCrane : CM_Crane;
	delayIsOnShift : Boolean;
	posNeg, numOfDays : Integer;
begin
	aCrane := self.getMyCrane();
	if aCrane = null then
		return 0;
	endif;
	
	
//	foreach aDelay in self.myVoyage.allDelays discreteLock where aDelay.myMachine = aCrane do
	foreach aDelay in self.myVoyage.allDelays discreteLock  do
		// we want all delays except delays for other cranes.
		if aDelay.myMachine &lt;&gt; null and aDelay.myMachine &lt;&gt; aCrane then
			continue;
		endif;

		delayIsOnShift := false;
		
		fromTS := aDelay.startDT;
		toTS := aDelay.endDT;
		if not toTS.isValid() then
			toTS := aDelay.estEndDT;
		endif;

		if fromTS &gt;= _from and fromTS &lt;= _to then // delay begins within shift
			delayIsOnShift := true;
			if toTS &gt; _to then // delay ends after shift
				toTS := _to;
			endif;
		elseif toTS &gt;= _from and toTS &lt;= _to then // delay ends within shift
			delayIsOnShift := true;
			fromTS := _from;
		elseif _from &gt;= fromTS and _to &lt;= toTS  then // delay if for the whole shift
			delayIsOnShift := true;
			fromTS := _from;
			toTS := _to;
		endif;
	
		if delayIsOnShift then
				numHoursDelaid := numHoursDelaid + fromTS.differenceAsTime(toTS,posNeg, numOfDays).getTotalMilliseconds/ 60000;
		endif;
	endforeach;
	return numHoursDelaid;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getShiftLids" id="3797716e-bd1a-4f45-abe4-672dcdab7551">
        <source>getShiftLids(_shift : CM_Shift; _from, _to : TimeStamp) : Integer;
// ---------------------------------------------------------------------------

// 12 July 2017	jlgrh7 TFS #4796:QNS - Hatch Lids Moves in Voyage side profile
/*RULE for hatch lid jobs with no date/time for start or finish:

Get all the jobs in the same hold; in the OOW order.
If the cargo job after the hatch lid job (self) has 'started' e.g. at least 1 WLE is complete then use the start date/time of that cargo job.
If the hatch lid job (self) is the last job in the hold then use the previous cargo job and if it is complete then use the end date/time of that cargo job.
If the cargo jobs have not started or completed then the hatch lid jobs time stamp is null.
*/

//18 Feb 2018	NDl	TFS 37031 - Use 'Greater than or equal to' and 'Less than or equal to', so we don't miss exact time matches.  And make a permanent 
//								association between hatch lid jobs and shifts so that we don't count them twice
//								when shifts overlap or the start and end TS of shifts match.

// ---------------------------------------------------------------------------
vars
	pJob, tJob, vJob : CM_VoyageJob;
	numLids : Integer;
	tmpTs : TimeStamp;
	jobs : CM_VoyageJobArray;
	pJobHold : CM_Hold;
begin
		create jobs transient;
		foreach vJob in self.allJobsByJobNum discreteLock do
			if not vJob.isHatchLidJob() then																							//Only Need HatchLid Job
				continue;
			endif;
			//16 Feb 2018	NDL	TSF 37031 - If we've been passed a real shift use it to chevk if this job is ours.
			if _shift &lt;&gt; null and not _shift.isTransient and vJob.myShift &lt;&gt; null then
				if _shift &lt;&gt; vJob.myShift then
					//Skip this job, it's got a shift and its not ours.
					continue;
				endif;
			endif;
			
			if vJob.actualEndTs.isValid() then																							//Process Hatch job has end time
				if vJob.actualEndTs &gt;= _from and vJob.actualEndTs  &lt;= _to then								//Time Between the passing range then we add it up
					numLids := numLids + vJob.CM_VoyageHatchLidJob.allHatchLids.size;
					if _shift &lt;&gt; null and vJob.myShift = null then
						//Within this shifts timeframe... claim this job so it can't be double counted...
						vJob.setMyShift(_shift);
					endif;
					continue;
				else																																				//Outside of the range we skip to the next one
					continue;																																
				endif;
			else
				jobs.clear();
				tmpTs:= vJob.CM_VoyageHatchLidJob.getCompletedHatchJobTS( jobs);			//Process Hatch job does not have time stamp then use previous cargo job's time stamp (Refer to the the rule above)
				if tmpTs.isValid() then
					if tmpTs &gt;= _from and tmpTs &lt;= _to then
						 numLids := numLids + vJob.CM_VoyageHatchLidJob.allHatchLids.size;
						 if _shift &lt;&gt; null and vJob.myShift = null then
							//Within this shifts timeframe... claim this job so it can't be double counted...
							vJob.setMyShift(_shift);
						endif;
						continue;
					endif;
				endif;
			endif;
			if vJob = jobs.last() and vJob.isHatchLidJob then			 													//Process Last HatchJob to get previous Voyage Job TimeStamp
					pJob := self.getPreviousJobInOrder(vJob).CM_VoyageJob;
					if pJob &lt;&gt; null then
						pJobHold := pJob.getMyHold();												
						if pJobHold = vJob.getMyHold() then
							if pJob.isJobComplete() then
								tmpTs := pJob.actualEndTs;
								if tmpTs.isValid then
									if tmpTs &gt;= _from and tmpTs &lt;= _to then
										numLids := numLids + vJob.CM_VoyageHatchLidJob.allHatchLids.size;
										if _shift &lt;&gt; null and vJob.myShift = null then
											//Within this shifts timeframe... claim this job so it can't be double counted...
											vJob.setMyShift(_shift);
										endif;
									endif;
								endif;
							else
								continue;
							endif;
						endif;
					endif;
			endif;
		endforeach;
		return numLids;
		//pJob := self.getPreviousJobInOrder(tJob).CM_VoyageJob;
epilog
		delete jobs;
end;

</source>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getShiftMinMaxMoves" id="30ec2929-13e8-4664-8de2-fdef6d50c5f6">
        <source>getShiftMinMaxMoves(_from, _to : TimeStamp; _min, _max : Integer output);
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 12/08/2008 concms1	par 17592 Change so as not to retutn _min = 999999 which
///						causes decimal overflow errors in other methods
constants
	BIG_NUMBER = 99999999;
vars
	aDelay : CM_Delay;
	numHoursDelaid : Real;
	fromTS, toTS : TimeStamp;
	aCrane : CM_Crane;
	delayIsOnShift : Boolean;
	idx, numOfTIs, minTIs, maxTIs : Integer;
	trans : CM_TITransactionByDateDict;
	aTran : CM_TITransaction;
begin

	create trans transient;
	// ### for this jobsheet get all the loads and discharges from the transactions.
	trans.clear;
	self.allShipReceivals.copy(trans);
	self.allShipReleases.copy(trans);
	if trans.isEmpty then
		return;
	endif;

	aCrane := self.getMyCrane();
	if aCrane = null then
		return;
	endif;
	
	fromTS := _from;
	minTIs := BIG_NUMBER;	// PAR 17592
	while true do
		toTS := fromTS.addHours(1);
		
		// Just in case of an eternal loop
		idx := idx + 1;
		if idx &gt; 30 then
			break;
		endif;
		numOfTIs := 0;
		foreach aTran in trans discreteLock  
			where aTran.dateTime &gt;= fromTS and aTran.dateTime &lt;= toTS do
			
			numOfTIs := numOfTIs + 1;
		endforeach;

		if numOfTIs &gt; 0 then
			minTIs := minTIs.min(numOfTIs);
		endif;
		maxTIs :=maxTIs.max(numOfTIs);
		
		if toTS &gt;= _to then
			break;
		endif;
		fromTS := toTS;
	endwhile;
	
	if minTIs = BIG_NUMBER then	// par 17592
		minTIs := 0;			// par 17592
	endif;						// par 17592
	
	_min := minTIs;
	_max := maxTIs;
epilog
	delete trans; // AKB UNIT TEST
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_min" type="Integer" usage="output"/>
        <Parameter name="_max" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getShiftMinutesForADelay" id="99dbf43f-1bc1-46cb-99de-308644ebb84b">
        <source>getShiftMinutesForADelay(_delay : CM_Delay; _from, _to : TimeStamp) : Real;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDelay : CM_Delay;
	numHoursDelaid : Real;
	fromTS, toTS : TimeStamp;
	rfromTS, rtoTS : TimeStamp;
	delayIsOnShift : Boolean;
	posNeg, numOfDays : Integer;
begin
	
	aDelay := _delay;
	delayIsOnShift := false;
	
	fromTS := aDelay.startDT;
	toTS := aDelay.endDT;
	if not toTS.isValid() then
		toTS := aDelay.estEndDT;
	endif;
	rfromTS := fromTS;
	rtoTS := toTS;
	
	if fromTS &gt;= _from and fromTS &lt;= _to then // delay begins within shift
		delayIsOnShift := true;
		if toTS &gt; _to then // delay ends after shift
			toTS := _to;
		endif;
	elseif toTS &gt;= _from and toTS &lt;= _to then // delay ends within shift
		delayIsOnShift := true;
		fromTS := _from;
	elseif _from &gt;= fromTS and _to &lt;= toTS  then // delay if for the whole shift
		delayIsOnShift := true;
		fromTS := _from;
		toTS := _to;
	endif;

	if delayIsOnShift then
			numHoursDelaid := fromTS.differenceAsTime(toTS,posNeg, numOfDays).getTotalMilliseconds/ 60000;
	endif;

	return numHoursDelaid;
end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getShiftTimestamps" id="f85c1c51-d27c-49af-8d0d-2d832769e512">
        <source>getShiftTimestamps(workShifts : TimeStampArray input; _shifts : StringArray) ;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	
	tsTmp, tsFrom, tsTo, tsStrFrom, tsStrTo : TimeStamp;
	trans : CM_TITransactionByDateDict;
	posNeg, numOfDays, idx : Integer;
	dates : DateArray;
	aDate : Date;
	shift1, shift2, shift3 : Time;
begin
	if _shifts.isEmpty then
		shift1.setTime(7,0,0,0);
		shift2.setTime(15,0,0,0);
		shift3.setTime(23,0,0,0);
	else
		shift1.setTime(_shifts[1].Integer,0,0,0);
		if _shifts.size &gt;= 2 then
			shift2.setTime(_shifts[2].Integer,0,0,0);
		else
			shift2.setTime(15,0,0,0);
			shift3.setTime(23,0,0,0);
		endif;
		
		if _shifts.size = 3 then
			shift3.setTime(_shifts[3].Integer,0,0,0);
		else
			shift3.setTime(23,0,0,0);
		endif;
	endif;
	workShifts.clear;

	create trans transient;
	create dates transient;
	// ### for this jobsheet get all the loads and discharges from the transactions.
	trans.clear;
	self.allShipReceivals.copy(trans);
	self.allShipReleases.copy(trans);
	if trans.isEmpty then
		return;
	endif;

	
	// ### get the date range and store away each date that the work covers.
	tsFrom := trans.first.dateTime;
//aDate.setDate(22,3,2007);
//tsFrom.setDate(aDate);
	tsTo := trans.last.dateTime;
	aDate := tsTo.date + 1;
	tsTo.setDate(aDate);
	tsFrom.differenceAsTime(tsTo,posNeg, numOfDays);
	numOfDays := numOfDays + 1;
	aDate := tsFrom.date - 1;
	
	
	foreach idx in 1 to numOfDays do
		dates.add(aDate);
		aDate := aDate + 1;
	endforeach;
	// ### build up an array of shifts over the days
	foreach aDate in dates do
		tsTmp.setDate(aDate);
		// SHIFT 1
		tsTmp.setTime(shift1);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;
		// SHIFT 2
		tsTmp.setTime(shift2);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;
		// SHIFT 3
		tsTmp.setTime(shift3);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;
/*
		tsTmp.setDate(aDate);
		// SHIFT 1
		tsTmp.setTime(shift1);
		if tsTmp &lt; tsFrom and (tsTmp.date = tsFrom.date) then 
			tsTmp := tsFrom;	
		endif;
		if tsTmp &gt; tsTo and (tsTmp.date = tsTo.date) then 
			tsTmp := tsTo;
		endif;
		if not workShifts.includes(tsTmp) then
				workShifts.add(tsTmp);
		endif;
		
		// SHIFT 2
		tsTmp.setTime(shift2);
		if tsTmp &lt; tsFrom and (tsTmp.date = tsFrom.date)  then tsTmp := tsFrom;	endif;
		if tsTmp &gt; tsTo and (tsTmp.date = tsTo.date) then tsTmp := tsTo;endif;
				if not workShifts.includes(tsTmp) then
		workShifts.add(tsTmp);
			endif;
		// SHIFT 3
		tsTmp.setTime(shift3);
		if tsTmp &lt; tsFrom and (tsTmp.date = tsFrom.date)  then tsTmp := tsFrom;	endif;
		if tsTmp &gt; tsTo and (tsTmp.date = tsTo.date) then tsTmp := tsTo;endif;
			if not workShifts.includes(tsTmp) then
		workShifts.add(tsTmp);
			endif;
*/
	endforeach;

epilog
	delete trans;
	delete dates;
end;</source>
        <Parameter name="workShifts" type="TimeStampArray" usage="input"/>
        <Parameter name="_shifts" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getStartDateFromReceiveRelease" id="9a0a2ad2-d887-46fe-b147-0d37f71c62c5">
        <source>getStartDateFromReceiveRelease() : TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwrd1	Initial creation

*/


vars
	tmpWorkStarted : TimeStamp;
	aTran : CM_TITransaction;
	ls : Boolean;
begin
	tmpWorkStarted := self.workStarted;
	//app.cmsBeginLoad(ls);
	
	aTran := self.allShipReceivals.first;
	
	if aTran &lt;&gt; null then
		if aTran.dateTime.isValid then
			tmpWorkStarted :=  aTran.dateTime;
		endif;
	endif;
	
	aTran := self.allShipReleases.first;
	if aTran &lt;&gt; null then
		if aTran.dateTime.isValid and aTran.dateTime &lt; tmpWorkStarted then
			tmpWorkStarted :=  aTran.dateTime;
		endif;	
	endif;

	return tmpWorkStarted;
epilog

end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTheFirstJobBayId" id="557f22ae-fd7f-4f96-a820-2f3a2bbc4ec3">
        <source>getTheFirstJobBayId() : Integer;
// cnwvu1	31/10/2006	PAR12644
vars
	aJob : CM_Job;
	startBayJob : Integer;
	aBay : CM_Bay;
begin

	foreach aJob in self.allJobsByOrder do
		aBay := self.myVoyage.myCellularVoyageStructure.allBayVoyagesById[aJob.CM_VoyageJob.bayId];
		if aBay &lt;&gt; null then
			startBayJob := aBay.ordinalBay; //PAR12466
			return startBayJob;
		endif;
		
	endforeach;

	return 0;
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
