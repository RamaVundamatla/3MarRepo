    <JadeMethod name="getDetailForDisplay" id="3f650803-8da0-402e-b2c6-ec737c17cdef">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars
	str : String;
begin

	if not inheritMethod(_array) then
		return false;
	endif;

	self.addToArray(app.getErrorString(User), self.userCode, _array);	
	self.addToArray(app.getErrorString(Description), self.sourceDescId, _array);
	self.addToArray(app.getErrorString(Destination), self.toAddress, _array);
	self.addToArray(app.getErrorString(Sender), self.fromAddress, _array);
	self.addToArray(app.getErrorString(CC), self.ccAddresses, _array);
	self.addToArray(app.getErrorString(BCC), self.bccAddresses, _array);
	self.addToArray(app.getErrorString(Subject), self.subject, _array);
	self.addToArray(app.getErrorString(Message), self.message, _array);
	
	if self.numberOfRetries &gt; 0 then
		self.addToArray(app.getErrorString(Number_Of_Retries), self.numberOfRetries.String, _array);
	endif;
	foreach str in self.fileNames do
		self.addToArray(app.getErrorString(Attachment), str, _array);
	endforeach;
	return true;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="9120d377-6ccc-495e-a5a0-2ab2c30b5f21">
        <source>getTypeDescription(): String;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return app.getErrorString(Email);


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasExtraDetail" id="97329044-4a69-4085-96e9-e0f76263d76e">
        <source>hasExtraDetail(): Boolean;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	return (self.toAddress &lt;&gt; null) or
			app.myRoot.getConfig(BgpEmailTestMode).Boolean;	// When BGP Email Test Mode, toAddress can be null when it is blank in System Config. //25611 11/11/2010


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEmailAttributes" id="6857f64d-5bf2-4599-80bd-52b102e3072c">
        <updating/>
        <source>setEmailAttributes(_user : CM_User input; _toAddress, _fromAddress, _ccAddresses, _bccAddresses, _subject, _message, _sourceDescId : String; _sourceOfEmail, _numberOfRetries : Integer; _files : StringArray) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.description = null then
		if not app.myRoot.getConfig(BgpEmailTestMode).Boolean then
			self.setDescription(_sourceDescId &amp; ' ' &amp; app.getErrorString1(Successfully_Sent_Email, _toAddress));
		else	// Setting a specific description for BGP Email Test Mode. PAR 25611 11/11/2010
			if _toAddress.isBlank() then
				self.setDescription(_sourceDescId &amp; ' ' &amp; BgpEmailTestModeStr &amp;': '&amp; BgpTestEmailAddresNotSpecified);
			else
				self.setDescription(_sourceDescId &amp; ' ' &amp; BgpEmailTestModeStr &amp; ': '&amp; app.getErrorString1(Successfully_Sent_Email, _toAddress) );
			endif;
		endif;
	endif;
	
	self.toAddress 			:= _toAddress;
	self.fromAddress		:= _fromAddress;
	self.ccAddresses		:= _ccAddresses;
	self.bccAddresses		:= _bccAddresses;
	self.subject			:= _subject;
	self.message			:= _message;
	self.numberOfRetries	:= _numberOfRetries;
	self.sourceDescId		:= _sourceDescId[1:30];
	self.sourceOfEmail		:= _sourceOfEmail;
	if _user &lt;&gt; null then
		self.userCode			:= _user.code;
	endif;
	
	if not _files.isEmpty then
		_files.copy(self.fileNames);
	endif;

end;</source>
        <Parameter name="_user" type="CM_User" usage="input"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_fromAddress" type="String"/>
        <Parameter name="_ccAddresses" type="String"/>
        <Parameter name="_bccAddresses" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_sourceDescId" type="String"/>
        <Parameter name="_sourceOfEmail" type="Integer"/>
        <Parameter name="_numberOfRetries" type="Integer"/>
        <Parameter name="_files" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2048dcea-ced0-4a55-870e-5210eb62824c">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryEmail) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod(_proxy);
	self.sourceDescId		:= _proxy.sourceDescId;
	self.sourceOfEmail		:= _proxy.sourceOfEmail;
	self.toAddress			:= _proxy.toAddress;
	self.fromAddress		:= _proxy.fromAddress;
	self.ccAddresses		:= _proxy.ccAddresses;
	self.bccAddresses		:= _proxy.bccAddresses;
	self.subject			:= _proxy.subject;
	self.message			:= _proxy.message;
	self.numberOfRetries	:= _proxy.numberOfRetries;
	if not _proxy.fileNames.isEmpty then
		_proxy.fileNames.copy(self.fileNames);
	endif;


end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryEmail"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1ee44936-00f8-436a-ada9-1b65af321454">
        <updating/>
        <source>setForUpdate(_proxy: CM_ActivityHistoryEmail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
		self.sourceDescId		:= _proxy.sourceDescId;
	self.sourceOfEmail		:= _proxy.sourceOfEmail;
	self.toAddress			:= _proxy.toAddress;
	self.fromAddress		:= _proxy.fromAddress;
	self.ccAddresses		:= _proxy.ccAddresses;
	self.bccAddresses		:= _proxy.bccAddresses;
	self.subject			:= _proxy.subject;
	self.message			:= _proxy.message;
	self.numberOfRetries	:= _proxy.numberOfRetries;
	if not _proxy.fileNames.isEmpty then
		_proxy.fileNames.copy(self.fileNames);
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryEmail"/>
    </JadeMethod>
