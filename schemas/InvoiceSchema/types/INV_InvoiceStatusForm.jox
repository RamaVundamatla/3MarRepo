    <JadeMethod name="doSave" id="3161094a-faac-4334-b7b4-14fdc6eadd27">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	pxyInvStatus	: CM_InvoiceStatus;
	theReturn			: Integer;

begin

	if self.mode = Mode_Add then
		create pxyInvStatus transient;
	elseif self.mode = Mode_Update then
		pxyInvStatus := self.myProxyObject.CM_InvoiceStatus;
	else
		return false;
	endif;
	
	self.setProxyFromTable(pxyInvStatus);
	
	while true do
		if self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceStatusNew(pxyInvStatus, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			global.beep;
			theReturn := app.showErrorWarningDialog("Invoice Status", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvStatus;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="0b978442-129d-4534-9234-0ca5103c49d5">
        <source>doShowEmailForm();
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
22 July 2025 		navhn30		MTN-35477: 1090 exception when updating the Invoice Processes on the Invoice Process Maintenance form
*/

vars
	status, pxyStatus : CM_InvoiceStatus;
	emailDefault, pxyEmailDefaults : CM_InvStatusDefaultEmail;
	emailAdding : Boolean;
	pxyEmailTemplate, oldTemplate : CM_EmailTemplate;
	modalResult : Integer;
	loadState : Boolean;		
	invoiceProcess : CM_InvoiceProcess;
begin
	status := self.myCurrentObject.CM_InvoiceStatus;
	pxyStatus := self.myProxyObject.CM_InvoiceStatus;
	invoiceProcess := status.myInvoiceProcess;
	if status.myEmailTemplate = null then
		emailAdding := true;
		pxyEmailTemplate := pxyStatus.createPxyEmailTemplate();
		emailDefault := app.myRoot.allInvStatusDefaultEmails[invoiceProcess.pinEmailOffset + status.id];
	else
		pxyEmailTemplate := pxyStatus.myEmailTemplate;
		emailDefault := app.myRoot.allInvStatusDefaultEmails[status.myEmailTemplate.type];
	endif;
	
	pxyEmailDefaults := emailDefault.cloneSelf(true).CM_InvStatusDefaultEmail;
	
	if not emailAdding then	// there is some email info saved on invoice status before
		pxyEmailDefaults.setFromEmailTemplate(pxyEmailTemplate);	//prepare self.myEmailDefaults from persistent stored email template
		pxyEmailDefaults.setAddresses(pxyEmailTemplate.bccAddresses, pxyEmailTemplate.ccAddresses, pxyEmailTemplate.toAddresses);
	endif;
	
	modalResult := self.myAssistant.showInvoiceStatusEmailOptions(pxyEmailDefaults, false);
	
	if modalResult = IDOK then
		pxyEmailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the voyage status
		oldTemplate := pxyStatus.myEmailTemplate;
		if oldTemplate &lt;&gt; pxyEmailTemplate then
			delete oldTemplate;
		endif;
		pxyEmailTemplate.setMyParent(pxyStatus);
		/*if pxyEmailTemplate.canBeDeletedForVoyageStatus then		//22.07.2025	navhn30		MTN-35477
			pxyEmailTemplate.setMyParent(null);
			delete pxyEmailTemplate;
		endif;*/
	endif;
	
epilog
// ### TFS 56301 27JAN2023 NAVAB1	if modalResult &lt;&gt; IDOK then
// ### TFS 56301 27JAN2023 NAVAB1	the proxy status passed in already has an update proxy for the email template. pxyEmailTemplate is a reference to the 
// ### TFS 56301 27JAN2023 NAVAB1	proxy template on the proxy status, we should not delete it here because we are expecting it to always be available on the proxy status
// ### TFS 56301 27JAN2023 NAVAB1			delete pxyEmailTemplate;
// ### TFS 56301 27JAN2023 NAVAB1	endif;
	delete pxyEmailDefaults;
	if loadState then	
		app.cmsEndLoad(loadState);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="42f28dd2-e71e-4fcc-8757-d426bbf42220">
        <updating/>
        <source>initDataTable() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	area					: CM_TerminalArea;
	title					: String;
	
begin

	self.setTblDataEntRows(ETDef_InvoiceStatusDetail);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_InvoiceProcess, false);
	self.zAddSortColumn(ETRow_Description, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="d62c297d-c85e-454f-aec9-eced260eb686">
        <updating/>
        <source>initForm() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
begin

	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowTblDataSearch := true;
	self.allowDelete := false;
	self.allowAdd := false;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="931024dd-a156-4d08-8a6d-43f52b7832c1">
        <source>initTblEntDetail();
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvoiceStatusThumb);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="4c904d4e-90e4-4f37-9b6b-d8367d599612">
        <source>initTblThumb();
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars

	theTable		: CM_ThumbnailTable;
begin
	theTable := self.tblThumb;
	theTable.clear;
	theTable.scrollBars := Table.ScrollBar_Horizontal;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="6fcf19b2-de1c-4610-b537-1f2f5ff42902">
