    <JadeMethod name="registerForStartStop" id="91011782-cdf9-4ec9-a7d3-9926f0f0ea39">
        <source>registerForStartStop() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars

begin
	self.beginNotification(global, ITSServerControl.START_MACHINE, Response_Continuous, null);
	self.beginNotification(global, ITSServerControl.STOP_MACHINE, Response_Continuous, null);
	
	
