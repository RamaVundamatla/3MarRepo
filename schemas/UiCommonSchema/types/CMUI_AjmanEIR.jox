    <JadeMethod name="setDataFieldsFromObject" id="dbebadb2-7e85-42de-8a5c-85980036cfd6">
        <updating/>
        <source>setDataFieldsFromObject(_obj: CM_Object; _lineUp : Boolean; _showLabelArea : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

begin
	
	if _showLabelArea then
		//app.printer.print( self.testFrame );
		self.printLabelFieldAreaBoundary();	//21 July 2014	NDL Par 34611
	endif;
		
	if _lineUp then
		self.populateLineUp();
		return;
			
	elseif _obj &lt;&gt; null then
	
		self.myPopulatingObject := _obj;	//31 Jan 2014	NDL	Par 33181
	
		if _obj.isKindOf( CMGTE_Entity ) then
			self.setFromGTE( _obj.CMGTE_Entity );
		elseif _obj.isKindOf( CM_Container ) then
			self.setFromContainer( _obj.CM_Container );
		else
			self.populateLineUp();
		endif;
	
		return;
		
	endif;
	
	inheritMethod( _obj, _lineUp, _showLabelArea );

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
        <Parameter name="_showLabelArea" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromContainer" id="388dc0ce-9b50-4a20-a926-f32118157ec7">
        <updating/>
        <source>setFromContainer( cont : CM_Container ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	vvr : CM_VehicleVisitRecord;
	voyageCode : String;
	voyage : CM_Voyage;
	now : TimeStamp;
	vessel : CM_Vessel;
	vesselName : String;
//	shipLine : CM_ShippingLine;
	vehicle : CM_Vehicle;
	release : CM_BulkRelease;
	isReceipt : Boolean;
	dutyDoc: CM_DutyDoc;

begin

	self.myTrackedItem := cont;

	if not cont.allVisitRecords.isEmpty then
		vvr := cont.allVisitRecords.last;
		if vvr.allReleasedTrackedItems.includes(cont) then
			self.lblA.caption := app.getErrorString(OUT_YO);
		elseif vvr.allReceivedTrackedItems.includes(cont) then
			self.lblA.caption := app.getErrorString(IN_YO);
			isReceipt := true;
		endif;
	endif;

	if vvr &lt;&gt; null then
		self.lblB.caption := vvr.visitNumber;
		
		if vvr.timeOut.Date.isValid then
			self.lblC.caption := vvr.timeOut.Date.asStringJMT;
			self.lblD.caption := vvr.timeOut.Time.asStringJMT;
		elseif vvr.timeIn.Date.isValid then
			self.lblC.caption := vvr.timeIn.Date.asStringJMT;
			self.lblD.caption := vvr.timeIn.Time.asStringJMT;
		endif;
	endif;
	
	self.lblE.caption := cont.totalWeight.asStringWeightJMT;
	
	if cont.isOnSite then
		self.lblF.caption := cont.locationId;
	else
		if cont.isNotified then
			if cont.isPlannedToYard then
				self.lblF.caption := cont.myPrimaryPlannedLocation.getFullId();
			endif;
		else
			self.lblF.caption := cont.priorLocation;
		endif;
	endif;
	
	if vvr &lt;&gt; null then
		//02 Apr 2013	NDL	Par 31373
	//	self.lblG.caption := vvr.getLaneName_JRW;
	//	if self.lblG.caption = null then
			self.lblG.caption := vvr.getGateInName;
	//	endif;
	endif;
	
	self.lblH.caption := cont.id;
	self.lblI.caption := cont.getSealNumCustoms();
	
	if cont.is20 then 
		self.lblJ.caption := "20";
	elseif cont.is40 then 
		self.lblJ.caption := "40";
	elseif cont.is30 then 
		self.lblJ.caption := "30";
	elseif cont.is45 then 
		self.lblJ.caption := "45";
	elseif cont.is53 then 
		self.lblJ.caption := "53";
	endif;
	
	
	self.lblK.caption := cont.isoGroup;
	self.lblL.caption := cont.contentsStatusCode;

	voyage := cont.myVoyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
		/*vessel := voyage.getMyVessel();
		if vessel &lt;&gt; null then
			vesselName := vessel.name;
		endif;*/
		vesselName := voyage.vesselName;	// 11/04/2013 cnwar2 #31414
	endif;
	
	self.lblM.caption := vesselName;
	self.lblN.caption := voyageCode;
	
//	if shipLine &lt;&gt; null then
//		self.lblO.caption := shipLine.description;
//	endif;

	//09 Apr 2013	NDL	Par 31404 - Ajman changed their minds about teh data they wanted here.
	if cont.myOperator &lt;&gt; null then
		self.lblO.caption := cont.myOperator.description;
	endif;
	
	if voyage &lt;&gt; null then
		self.lblP.caption := voyage.externalRef;
	endif;
	
	if isReceipt then
		self.lblQ.caption := cont.consignor;
	else
		self.lblQ.caption := cont.consignee;
	endif;
	
	if cont.receivedDT.isValid then
		self.lblR.caption := cont.receivedDT.Date.asStringJMT;
	endif;
	
	if cont.releasedDT.isValid then
		self.lblS.caption := cont.releasedDT.Date.asStringJMT;
	endif;
		
	self.lblT.caption := null;
	
	if vvr &lt;&gt; null then
		vehicle := vvr.vehicle;
		if vehicle &lt;&gt; null then
			self.lblU.caption := vehicle.regNumber;
		endif;
	endif;
	
	if vvr &lt;&gt; null then
		self.lblV.caption := vvr.carrierCode;
	endif;
	
	// Par# 31551
	dutyDoc := cont.getDutyDoc();
	if dutyDoc &lt;&gt; null then
		self.lblW.caption := dutyDoc.deliveryOrder;
		self.lblX.caption := dutyDoc.deliveryOrderExpiryDate.asStringJMT();
	endif;
	
	self.lblY.caption := "";	//multi-line label populated directly in "doProcessLabelContents"

epilog

end;</source>
        <access>protected</access>
        <Parameter name="cont" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="setFromGTE" id="37447047-9958-4871-ab07-92720ddca0b1">
        <updating/>
        <source>setFromGTE( gteEntity : CMGTE_Entity ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	voyageCode : String;
	voyage : CM_Voyage;
	now : TimeStamp;
	vessel : CM_Vessel;
	vesselName : String;
//	shipLine : CM_ShippingLine;
	vehicle : CM_Vehicle;
	release : CM_BulkRelease;

begin

	if gteEntity.isReceipt then
		self.lblA.caption := app.getErrorString(IN_YO);
	else
		self.lblA.caption := app.getErrorString(OUT_YO);
	endif;
	
	vvr := gteEntity.myVehicleVisitRecord;
	if vvr &lt;&gt; null then
		self.lblB.caption := vvr.visitNumber;
		
		if vvr.timeOut.Date.isValid then
			self.lblC.caption := vvr.timeOut.Date.asStringJMT;
			self.lblD.caption := vvr.timeOut.Time.asStringJMT;
		elseif vvr.timeIn.Date.isValid then
			self.lblC.caption := vvr.timeIn.Date.asStringJMT;
			self.lblD.caption := vvr.timeIn.Time.asStringJMT;
		endif;
	endif;
	
	self.lblE.caption := gteEntity.weight.asStringWeightJMT;
	
	self.lblF.caption := gteEntity.yardLocationTxt;
	
	if vvr &lt;&gt; null then
		//02 Apr 2013	NDL	Par 31373
	//	self.lblG.caption := vvr.getLaneName_JRW;
	//	if self.lblG.caption = null then
			self.lblG.caption := vvr.getGateInName;
	//	endif;
	endif;
	
	ti := gteEntity.getTI;
	if ti &lt;&gt; null then
		self.myTrackedItem := ti;
		self.lblH.caption := ti.id;
	endif;
	
	if ti &lt;&gt; null then
		self.lblI.caption := ti.getSealNumCustoms();
	endif;
	
	if ti &lt;&gt; null and ti.isContainer then
		if ti.is20 then 
			self.lblJ.caption := "20";
		elseif ti.CM_Container.is40 then 
			self.lblJ.caption := "40";
		elseif ti.is30 then 
			self.lblJ.caption := "30";
		elseif ti.is45 then 
			self.lblJ.caption := "45";
		elseif ti.is53 then 
			self.lblJ.caption := "53";
		endif;
	endif;
	
	if ti &lt;&gt; null and ti.isContainer then
		self.lblK.caption := ti.CM_Container.isoGroup;
	endif;
	
	if ti &lt;&gt; null and ti.isContainer then
		self.lblL.caption := ti.contentsStatusCode;
	endif;
	
	voyageCode := gteEntity.voyageCode;
	if voyageCode &lt;&gt; null then
		now := app.actualTimeServer;
		voyage := gteEntity.myTerminal.allVoyagesByCode.getAtKeyLeq(voyageCode,now);
		if voyage = null then
			voyage := gteEntity.myTerminal.allVoyagesByCode.getAtKeyGeq(voyageCode,now);
		endif;
		if voyage &lt;&gt; null then
			/*vessel := voyage.getMyVessel();
			if vessel &lt;&gt; null then
				vesselName := vessel.name;
			endif;*/
			vesselName := voyage.vesselName;	// 11/04/2013 cnwar2 #31414
		endif;
	endif;
	
	self.lblM.caption := vesselName;
	
	self.lblN.caption := voyageCode;
	
//	if voyage &lt;&gt; null then
//		shipLine := voyage.myShippingLine;
//		if shipLine &lt;&gt; null then
//			self.lblO.caption := shipLine.description;
//		endif;
//	endif;
	
	//09 Apr 2013	NDL	Par 31404 - Ajman changed their minds about the data they wanted here.
	if gteEntity.getOperatorObject &lt;&gt; null then
		self.lblO.caption := gteEntity.getOperatorObject.description;
	endif;
	
	if voyage &lt;&gt; null then
		self.lblP.caption := voyage.externalRef;
	endif;
	
	if ti &lt;&gt; null then
		if gteEntity.isReceipt then
			self.lblQ.caption := ti.consignor;
		else
			self.lblQ.caption := ti.consignee;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		if ti.receivedDT.isValid then
			self.lblR.caption := ti.receivedDT.Date.asStringJMT;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		if ti.releasedDT.isValid then
			self.lblS.caption := ti.releasedDT.Date.asStringJMT;
		endif;
	endif;
		
	self.lblT.caption := null;
	
	if vvr &lt;&gt; null then
		vehicle := vvr.vehicle;
		if vehicle &lt;&gt; null then
			self.lblU.caption := vehicle.regNumber;
		endif;
	endif;
	
	if vvr &lt;&gt; null then
		self.lblV.caption := vvr.carrierCode;
	endif;
	
	if gteEntity.isKindOf( CMGTE_Release ) then
		release := gteEntity.CMGTE_Release.myBulkRelease;
		if release &lt;&gt; null then
			self.lblW.caption := release.code;
		endif;
	endif;
	
	self.lblX.caption := gteEntity.clientRef;
	
	self.lblY.caption := "";	//multi-line label populated directly in "doProcessLabelContents"

epilog

end;</source>
        <access>protected</access>
        <Parameter name="gteEntity" type="CMGTE_Entity"/>
    </JadeMethod>
</GUIClass>
