    <JadeMethod name="shouldAuditProperty" id="4bea8793-2924-4e69-b3e4-732f95ff9ca5">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2025 navhl20 Defect MTN-36235: Audits are not capturing date, time, and user for changes to photo.

*/

vars

begin
	if _property = null then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
