    <JadeMethod name="getObjectSequence" id="87f56243-8422-4539-bb67-a4a34bd7877e">
        <source>getObjectSequence(_finObject : CM_FinancialObject):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	str : String;
begin
	if _finObject.isKindOf(CM_Invoice) then
		
		str := _finObject.CM_Invoice.getExternalInvoiceNumber;
	elseif _finObject.isKindOf(CM_CashReceipt) then
		return _finObject.CM_CashReceipt.externalInvoiceNumber;
		
	elseif _finObject.isKindOf(CM_CashCredit) then
		return _finObject.CM_CashCredit.externalId; 
	endif;


	return str;
epilog

end;</source>
        <Parameter name="_finObject" type="CM_FinancialObject"/>
