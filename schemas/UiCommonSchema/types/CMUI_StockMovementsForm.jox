vars

begin
	self.origXPos := x;
	self.origYPos := y;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="46e12e60-84c1-496d-b204-853d101d6ee3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008170, locale);
	btnBack.translateCaption(Xlat_0000938, locale);
	btnClose.translateCaption(Xlat_0000936, locale);
	btnExecute.translateCaption(Xlat_0000935, locale);
	btnFixupStock.translateCaption(Xlat_0000933, locale);
	btnItemDtlsIn.translateCaption(Xlat_0000934, locale);
	btnItemDtlsOut.translateCaption(Xlat_0000932, locale);
	btnPrint.translateCaption(Xlat_0000937, locale);
	btnStkMoves.translateCaption(Xlat_0000939, locale);
	btnTransactions.translateCaption(Xlat_0000931, locale);
	btnValidate.translateCaption(Xlat_0000940, locale);
	mnuCargoDetailsIn.translateCaption(Xlat_0012224, locale);
	mnuCargoDetailsOut.translateCaption(Xlat_0012225, locale);
	mnuInItemDetails.translateCaption(Xlat_0008171, locale);
	mnuOutItemDetails.translateCaption(Xlat_0008172, locale);
	mnuStockMoves.translateCaption(Xlat_0008173, locale);
	mnuTblDataContext.translateCaption(Xlat_0008174, locale);
end;</source>
    </JadeMethod>
