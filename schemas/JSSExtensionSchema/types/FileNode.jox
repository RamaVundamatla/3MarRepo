<Class name="FileNode">
    <JadeMethod name="jssCopy" id="32f933d9-5d49-4557-b477-056f71a55f5e">
        <updating/>
        <source>jssCopy(pTarget:String):Boolean updating, abstract;</source>
        <abstract/>
