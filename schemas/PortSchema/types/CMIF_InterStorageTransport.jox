<Class name="CMIF_InterStorageTransport" id="7c9e0c19-07c1-478f-b05a-45d9b3ca392e">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allTrackedItems" id="7d6a3922-bdd1-4565-a1eb-6ad4e464781d">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="businessUnitMustChange" id="dd26d582-808a-47dc-b52f-8525ecd07c5c">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="companyCode" id="7751de0b-2484-45e7-ab2e-0dc86dedd335">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="dischargePort" id="aa9d1584-840e-41f3-a4cc-f6fa03431fe1">
