epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_adjacent" type="CM_ROROLocnDefn"/>
        <Parameter name="_orientation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="switchDischargeCCOnUnrotate" id="58bedd15-2a1c-4140-a369-c59ea0d277aa">
        <updating/>
        <source>switchDischargeCCOnUnrotate() updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slot : CM_ROROSlotDefn;
	disReq, fwdReq, aftReq : CM_ROROSlotRequest;
	fwdLC, aftLC : CM_ROROSlotController;
begin
	foreach slot in self.allROROSlotDefnByOrdinal discreteLock do
		disReq := slot.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge.CM_ROROSlotRequest;
		if disReq &lt;&gt; null then
			if disReq.getAttrIs40() then
				if not disReq.getAttrIsBackend() then
					fwdReq := disReq;
					aftReq := fwdReq.mySlotRequestAft;

					// ### SWITCH the aft and the forward discharge colour coding on the location controllers
					fwdLC := fwdReq.myROROController.CM_ROROSlotController;
					aftLC := aftReq.myROROController.CM_ROROSlotController;
					
					fwdLC.removeSlotRequest(fwdReq);
					aftLC.removeSlotRequest(aftReq);
					
					aftReq.setMyLC(fwdLC);
					fwdReq.setMyLC(aftLC);
					fwdLC.addSlotRequest(false,aftReq);
					aftLC.addSlotRequest(false,fwdReq);
					
				endif;
			endif;
		endif;
	endforeach;		

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="testHazardLoadCC" id="1c76312e-08be-42af-858c-bcb356754070">
        <source>testHazardLoadCC(	_vaHazs	: ObjectArray);
/*
Purpose:			
Date		Who		Reason
28 July 2011	cnwab1	Initial creation
*/

vars
	hazard : CM_Hazard;
	hazardClass			: CM_HazardClass;
	obj : Object;
	locnHazClasses : ObjectArray;
begin
	// convert our haz object to haz class object
	create locnHazClasses transient;
	foreach hazard in self.allHazardsAllowed  discreteLock do
		hazardClass := hazard.getClassObject();
		if hazardClass &lt;&gt; null then
			locnHazClasses.add(hazardClass);
		endif;
	endforeach;
	
	// if the passed in class are not in our ALLOWED collection then error.
	foreach obj in _vaHazs do
		hazardClass := obj.CM_HazardClass;
		
		if not locnHazClasses.includes(hazardClass) then
		
		// Hazardous validation : Colour coding cannot continue for location %1, because it does not allow hazard class of %2
			app.raiseCMWarning2(Hazar_valid_colou_codin_canno_, self.getFullId(),hazardClass.code &amp; " (" &amp; hazardClass.description &amp; ")", null, null, null);
		endif;
	endforeach;
epilog
	delete locnHazClasses;
end;</source>
        <Parameter name="_vaHazs" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="a3a9a0e3-dd68-41fd-aa43-c729150309c0">
        <source>validateDelete(_passport: CM_Passport input);
/*
Purpose:		 // PAR 31671	
Date		Who		Reason
11 July 2011	cnwab1	Initial creation
*/

vars

begin

		if self.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasTIs(REAL_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_actual_ca,self.code, null, null);
		endif;
		if self.hasTIs(PLANNING_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_planne_ca,self.code, null, null);
		endif;
		if self.hasTIs(QUEUE_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_queued_ca,self.code, null, null);
		endif;	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="c408a3dc-9d74-4871-8d79-53a8279ab279">
        <source>validateUpdate(_passport: CM_Passport);
/*
Purpose:			
Date		Who		Reason
06 January 2012	cnwab1	Initial creation
*/

vars
	realObject : CM_ROROLocnDefnVoyage;
begin

	
	realObject := self.pxyGetRealObject();
	
	if realObject &lt;&gt; null then
		if (realObject.myAdjacentSlotAft &lt;&gt; null and self.myAdjacentSlotAft = null)
		or (realObject.myAdjacentSlotFwd &lt;&gt; null and self.myAdjacentSlotFwd = null) 
		or (realObject.myAdjacentSlotFwd &lt;&gt; null and (realObject.myAdjacentSlotFwd &lt;&gt; self.myAdjacentSlotFwd)) 
		or (realObject.myAdjacentSlotAft &lt;&gt; null and (realObject.myAdjacentSlotAft &lt;&gt; self.myAdjacentSlotAft)) then
		
			if realObject.getFirst40Request(true) &lt;&gt; null then
				app.raiseCMException1(Canno_chang_linka_posit_40L, self.code, null, self);
			elseif realObject.getFirst40Request(false) &lt;&gt; null then
				app.raiseCMException1(Canno_chang_linka_posit_40D, self.code, null, self);
			
			elseif realObject.hasTIs40(REAL_MODE,true) then
				app.raiseCMException1(Canno_chang_linka_posit_40A, self.code, null, self);
			
			elseif realObject.hasTIs40(PLANNING_MODE,true) then
				app.raiseCMException1(Canno_chang_linka_posit_40P, self.code, null, self);
			
			
			elseif realObject.hasTIs40(QUEUE_MODE,true) then
				app.raiseCMException1(Canno_chang_linka_posit_40Q, self.code, null, self);
			
			endif;
		endif;
	endif;

	inheritMethod(_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
