    <JadeMethod name="finish" id="4f8d28a6-0aa8-41dc-ad60-06774fe90e97">
        <updating/>
        <source>finish() updating;

// cnwdvb1 30 June 2003 
/*

Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17543 - Prevent 1090 exceptions during shutdown

*/

vars

begin
	if app.myChangeTrackingInterface &lt;&gt; null then				// PAR #17543
		app.myChangeTrackingInterface.finalizeChangeTracker();
		delete app.myChangeTrackingInterface;
	endif;
	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="getAllRealClasses" id="0b39a263-ea6f-4112-8fec-c58005fac29a">
        <source>getAllRealClasses(_classes: ClassColl input) protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		Returns a unique list of all possible classes that could
//				be unloaded.  These are sorted into parent/sub-class groups.
//				Only Real (non-abstract) classes are included.
// ---------------------------------------------------------------------------
// 26/09/2006	PAR12534	cnwvu1
vars
	dumpClass : CM_DataDumpClass;
	subClasses : ClassColl;
	uniqueClasses : ClassSet;
	cls : Class;

begin

	create uniqueClasses transient;
	create subClasses transient;
	
	foreach dumpClass in app.myRoot.allDataDumpClasses do
		dumpClass.getRealSubClasses(subClasses, true);

		foreach cls in subClasses where
				not uniqueClasses.includes(cls) do
			// Don't want to unload the same class more than once.
			uniqueClasses.add(cls);
			_classes.add(cls);
		endforeach;
	endforeach;
	
epilog
	delete uniqueClasses;
	delete subClasses;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_classes" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFields" id="32227211-4e34-4df7-a4d6-a0bc4dcbe0ea">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_BgpIsServerEx);
	_allFields.add(ETRow_BgpRetainDays);
	_allFields.add(ETRow_BgpCommitFreq);
	_allFields.add(ETRow_BgpDebug);	//cnwrs1 par 25828 14 feb 2011
	_allFields.add(ETRow_BgpMaxTimeForRemoveToRun);	//cnwrs1 par 25828 14 feb 2011
	
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="b2c8eb21-5e80-49bd-b682-8bc634e77889">
        <updating/>
        <source>initApp() updating;

// cnwdvb1 14 May 2003 
/*

Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17713 - Set alias based on controller class for JSM moitoring of
					critical applications
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check

//03 Jan 2013	cnwrs1	32983 crash after user deleted.
*/

vars
	ls 			: Boolean;
	str,
	errorText	: String;
	errorCode	: Integer;
	msg : String;
begin

//	on Exception do app.alertExceptionHandler(exception, null, 'BGP Controller', errorCode, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; //cnwrs1 par 17287 June 2008
	
	app.setCnAppAlias(self.class.name);		// PAR #17713 //epr TFS 36655 29/4/19
	
	app.initialize();
	app.setIsBackGroundApp(true);
 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		app.exitLogFile();
		terminate;
		return;
	endif;
	
	// Now write changes to ini file - for change tracker app to use
	self.updateMyIniFile;		// 26/09/2006	PAR12534	cnwvu1

	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);
	
	create app.myChangeTrackingInterface transient;
	app.myChangeTrackingInterface.initializeChangeTracker;

epilog
	app.cmsEndLoad(ls);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isSetup" id="d269a100-41ff-4c91-9787-873f553e8b4a">
        <methodInvocation>mapping</methodInvocation>
        <source>isSetup(set: Boolean; _value: Boolean io) mapping;

/*

Purpose:			Determine whether the receiver has been set up yet

Parameters:			Mapping method

Return Value:		None


Date		Who		Reason
08 Jun 2009	cnwkpd1	PAR #19818 - commitFrequency must be non-zero to be "setup"

*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.commitFrequency &gt; 0 then
		inheritMethod(set, _value);
		return;
	endif;
	
	_value := false;
	

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="57b55caf-bcd2-499b-beed-1c873f1bac6f">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

vars

begin
	self.name				:= 'Change Tracker';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;

	self.retainTrackingDays     := 5;
	self.commitFrequency        := 10000;
	self.readLogServerExecution := false;
	self.debug := false;	//par25828 cnwrs1 14 Feb 2011
	self.maxTimeForRemoveToRunInSecs := 60000;	//par25828 cnwrs1 14 Feb 2011
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="73c1fb0f-9f83-4657-91ff-e94e9cfd5f1a">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

/*

Date		Who		Reason
12 May 2009	conkc1	Initial creation

*/

vars

begin
	inheritMethod(_cmif);

	_cmif.commitFrequency	 := self.commitFrequency;
	_cmif.retainTrackingDays := self.retainTrackingDays;
	_cmif.useServerExecution := self.readLogServerExecution;
	_cmif.debug := self.debug;	//par25828 cnwrs1 14 Feb 2011
	_cmif.maxTimeForRemoveToRunInSecs := self.maxTimeForRemoveToRunInSecs;	//par25828 cnwrs1 14 Feb 2011
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="36e4b8da-cc5b-4450-b0c5-ac7baf305468">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;

/*

Date		Who		Reason
12 May 2009	conkc1	Initial creation

*/

vars

begin
	inheritMethod(_cmif);

	self.retainTrackingDays     := _cmif.retainTrackingDays;
	self.commitFrequency        := _cmif.commitFrequency;
	self.readLogServerExecution := _cmif.useServerExecution;
	self.debug := _cmif.debug;	//par25828 cnwrs1 14 Feb 2011
	self.maxTimeForRemoveToRunInSecs := _cmif.maxTimeForRemoveToRunInSecs;	//par25828 cnwrs1 14 Feb 2011
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="updateMyIniFile" id="5a193c5d-7d7e-48c5-b5a9-7b019296213e">
        <source>updateMyIniFile() protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		The current interface to the Change Tracker peer schema is
//				via the settings changed by this method in the server's
//				ini file.
// ---------------------------------------------------------------------------
// 26/09/2006	PAR12534	cnwvu1

vars
	dumpClasses : ClassColl;
	dumpClass : Class;
	keyDumpStack, keyInitDays, keyReadServEx, keySnooze, keyDebug : String;
	keyTrackAll, keyKeepTrackingDays, keyCommitFreqency, keyIgnoreAnyMissedFiles: String;
	keyTerminateWaitSeconds, keyIncludeClass: String;
	keyMaxTimeForRemoveToRun : String;
	classLoadNum : Integer;

begin
	// Get the load classes to be written to ini file
	create dumpClasses transient;
	self.getAllRealClasses(dumpClasses);
	
	// Read in current ini file details - ignoring current load classes
	keyDumpStack := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_DumpCallStack, "true");
	keyInitDays := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_InitializationDays, "0");
	keySnooze := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_SnoozeFrequency, "100");
	keyDebug := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_Debug, "false");
	keyTrackAll := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_TrackAllClassesByDefa, "false");
	keyIgnoreAnyMissedFiles := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_IgnoreAnyMissedFiles, "false");
	keyTerminateWaitSeconds := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_TerminateWaitSeconds, "30");
	keyMaxTimeForRemoveToRun := app.getProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_MaxTimeForRemoveToRun, "3600");
	//
	//  Values kept on this object
	//
	keyReadServEx        := self.readLogServerExecution.String.toLower;
	keyKeepTrackingDays  := self.retainTrackingDays.String;
	keyCommitFreqency    := self.commitFrequency.String;
	keyDebug := self.debug.String;	//par25828 cnwrs1 14 Feb 2011
	keyMaxTimeForRemoveToRun := self.maxTimeForRemoveToRunInSecs.String;	//par25828 cnwrs1 14 Feb 2011
	
	// Remove entire section from ini file
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
			ProfileRemoveSection, null);
			
	// Write ini file - replacing non-load class values
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_DumpCallStack, keyDumpStack);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_InitializationDays, keyInitDays);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_ReadLogServerExecutio, keyReadServEx);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_SnoozeFrequency, keySnooze);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_Debug, keyDebug);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_TrackAllClassesByDefa, keyTrackAll);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_InitializationKeepTra, keyKeepTrackingDays);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_CommitFrequency, keyCommitFreqency);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_IgnoreAnyMissedFiles, keyIgnoreAnyMissedFiles);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_TerminateWaitSeconds, keyTerminateWaitSeconds);
	app.setProfileStringMyIni(self.ChangeTrackerIniSection,
		self.CTIniKey_MaxTimeForRemoveToRun, keyMaxTimeForRemoveToRun);

	// Now write the updated load class names to the ini file
	foreach dumpClass in dumpClasses do
		classLoadNum := classLoadNum + 1;
		app.setProfileStringMyIni(self.ChangeTrackerIniSection,
			self.CTIniKey_LoadClass &amp; classLoadNum.String.padLeadingZeros(3),
			dumpClass.name);
		app.setProfileStringMyIni(self.ChangeTrackerIniSection,
			self.CTIniKey_IncludeClass &amp; classLoadNum.String.padLeadingZeros(3),
			dumpClass.name);
	endforeach;
	
epilog
	delete dumpClasses;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d8770369-35b6-4aab-a1a6-96ba86f17db3">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jun 2009	cnwkpd1	PAR #19818 - Commit Frequency must be non-zero
// 10/12/2014  cnwdb2	PAR 35364

*/

vars

begin
	inheritMethod();

	if self.commitFrequency = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Commit Frequency', null, null);
		app.raiseCMException(Input_required_field_comitFreq, null, null); // cnwdb2	PAR 35364

	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
