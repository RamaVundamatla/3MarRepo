    <JadeMethod name="clickSelectedBtn" id="2af3cc45-49cb-4cb1-8375-1cdb086819d5">
        <updating/>
        <source>clickSelectedBtn( btn: Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	hasActions : Boolean;
	doActions : Boolean;
	doPackComplete : Boolean;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	opt4Str : String;
	returnValue : Integer;
	selectedTi : CM_TrackedItem;
	hasNoChildren : Boolean;

begin

	ti := btn.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
	if not self.allSelectedConts.includes(ti) then
		return;
	endif;
	
	hasNoChildren := ti.allChildren.size = 0;
	
/*	create resDetailSet transient;
	create bookingItemSet transient;
	if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
		hasActions := true;
	endif; */
	
	
	if hasActions and hasNoChildren then
		opt1Str := app.getErrorString( Unselect_container );
		opt2Str := app.getErrorString( Perform_document_actions );
		opt3Str := self.btnOne.caption;
		opt4Str := app.getErrorString(None_above_cancel);
		returnValue := self.optBox(opt1Str, opt2Str, opt3Str, opt4Str, 2, app.getErrorString(Select_option) );
		if returnValue = 1 then
			doActions := false;
			doPackComplete := false;
		elseif returnValue = 2 then
			doActions := true;
			doPackComplete := false;
		elseif returnValue = 3 then
			doActions := false;
			doPackComplete := true;
		else
			//bail
			return;
		endif;

/*	elseif hasActions then
		opt1Str := app.getErrorString( Unselect_container );
		opt2Str := app.getErrorString( Perform_document_actions );
		opt3Str := app.getErrorString(None_above_cancel);
		returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 2, app.getErrorString(Select_option) );
		if returnValue = 1 then
			doActions := false;
			doPackComplete := false;
		elseif returnValue = 2 then
			doActions := true;
			doPackComplete := false;
		else
			//bail
			return;
		endif;  */
		
	elseif hasNoChildren then
		opt1Str := app.getErrorString( Unselect_container );
		opt2Str := self.btnOne.caption;
		opt3Str := app.getErrorString(None_above_cancel);
		returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 2, app.getErrorString(Select_option) );
		if returnValue = 1 then
			doActions := false;
			doPackComplete := false;
		elseif returnValue = 2 then
			doActions := false;
			doPackComplete := true;
		else
			//bail
			return;
		endif;
		
	else
	
	endif;
	
	
	if doPackComplete then 
		self.doComplete( btn.userObject.CM_Container );
		
/*	elseif doActions then
		self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
		self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
		self.myMobileGenericAgent.setMyNextTiToAction( ti );
		
		self.myMobileGenericAgent.allConfirmedTis.clear();
		foreach selectedTi in self.allSelectedConts do
			self.myMobileGenericAgent.allConfirmedTis.add( selectedTi);
		endforeach;
		
		self.myMobileGenericAgent.setInward( self.chkByCont.value );
		self.myMobileGenericAgent.setDecimalField1( self.cmbSortBy.listIndex );
		self.myMobileGenericAgent.setStringField1( self.fldChildren.topSheet.caption );
		
		self.gotoForm( MOB_HHDocumentActions, false );
		return; */
		
	else
		self.allSelectedConts.remove( ti );
		
	endif; 
	
	self.populateContainers();
	self.doResizeControls(false);	//03 Mar 2017	NDL	TFS 3299

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
