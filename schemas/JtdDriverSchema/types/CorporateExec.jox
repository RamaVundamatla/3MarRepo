	keyCode:Integer;
begin
	myGTE_VehicleVisitEnqForm_2.cmbFiltCarrier.lostFocus(myGTE_VehicleVisitEnqForm_2.cmbFiltCarrier);
	keyCode:=18;
	myGTE_VehicleVisitEnqForm_2.keyDown(keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myGTE_VehicleVisitEnqForm_2.tblData.keyDown(myGTE_VehicleVisitEnqForm_2.tblData, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=9;
	myGTE_VehicleVisitEnqForm_2.tblData.keyUp(myGTE_VehicleVisitEnqForm_2.tblData, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myGTE_VehicleVisitEnqForm_2.tblData.keyUp(myGTE_VehicleVisitEnqForm_2.tblData, keyCode, 0);
	app.doWindowEvents(shortPause);
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
