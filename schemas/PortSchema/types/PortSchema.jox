/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation	Par 31770

*/

vars

begin

	return app.random(100).isEven;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveFile" id="38db6e31-48e5-4087-9047-cfdc35707e65">
        <source>moveFile(_sourceFile: File io; _dirName: String; _newFileName : String; _keepOriginal : Boolean): Boolean;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
vars
	destFile	: File;
	fileName	: String;
	fileLength	: Integer;
	blob		: Binary;
	lastModified : TimeStamp;
begin
	
	create destFile transient;
	_sourceFile.mode		:=	File.Mode_IO;
	_sourceFile.shareMode	:=	File.Share_Exclusive;
	_sourceFile.kind		:=	File.Kind_Binary;
	if not _sourceFile.tryOpen then
		app.writeLog('Unable to open file ' &amp; _sourceFile.fileName, LogINFO);
		return false;
	endif;
	lastModified := _sourceFile.lastModifiedTime;
	if _newFileName = null then //par 21121 cnwrs1 nov 2009
		fileName := self.getFileName(_sourceFile.fileName);
	else
		fileName := _newFileName;
	endif;
	destFile.fileName		:= _dirName &amp; '\' &amp; fileName;
	destFile.mode			:=	File.Mode_Output;
	destFile.shareMode		:=	File.Share_ReadWrite;
	destFile.kind			:=	File.Kind_Binary;
	destFile.readOnly		:=	false;
	
	app.writeLog('Moving file ' &amp; fileName &amp; ' to ' &amp; _dirName, LogINFO);
	if not destFile.tryOpen then
		app.writeLog('File ' &amp; destFile.fileName &amp; ' is unavailable', LogINFO);
		return false;
	endif;
	
	fileLength	:=	_sourceFile.fileLength();
	blob := _sourceFile.readBinary(fileLength);
	destFile.writeBinary(blob);
	destFile.lastModifiedTime := lastModified;
	if not _keepOriginal then
		_sourceFile.purge;
	endif;
	return true;
epilog
	if destFile &lt;&gt; null then
		destFile.close;
	endif;
	if _sourceFile &lt;&gt; null then
		_sourceFile.close;
	endif;
	delete destFile;
end;</source>
        <Parameter name="_sourceFile" type="File" usage="io"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_newFileName" type="String"/>
        <Parameter name="_keepOriginal" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveModeStatusEnumToString" id="e7dc6f87-1a47-4b61-b01d-a08c51c9c4a8">
        <source>moveModeStatusEnumToString(_moveMode : Integer) : String;
//--------------------------------------------------------------
//Created: 01 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	/*if _moveMode = REAL_MODE then
		return 'Instant Move';
	elseif _moveMode = QUEUE_MODE then
		return 'Queue Move';
	elseif _moveMode = PLANNING_MODE then
		return 'Planned Move';
	else
		return 'Unknown';
	endif;*/
	
	if _moveMode = REAL_MODE then
		return app.getErrorString(Instant_Move);
	elseif _moveMode = QUEUE_MODE then
		return app.getErrorString(Queued_Move);
	elseif _moveMode = PLANNING_MODE then
		return app.getErrorString(Planned_Move);
	elseif _moveMode = AUTO_PLAN_MODE then
		return app.getErrorString(Auto_Planned_Queued_Move);
	elseif _moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		return app.getErrorString(AutoPlan_On_Pickup);
	elseif _moveMode = AUTO_PLAN_ONLY_MODE then	//18 July 2014	NDL	Par 34602
		return app.getErrorString(Autoplan_plan_only);
	elseif _moveMode = INSTANT_PACK_MODE then	//31 July 2014	NDL	Par 34665
		return app.getErrorString(Pack);
	else
		return app.getErrorString(Unknown);
	endif;
	
	
	
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="moveModeStringToMoveMode" id="e3058403-6634-436a-a603-fb1661fccfb9">
        <source>moveModeStringToMoveMode(_moveModeStr : String) : Integer;

// Created by cnwdvb1 on 09 August 2006

vars

begin

	if _moveModeStr = app.getErrorString(Instant_Move) then
		return REAL_MODE;
	elseif _moveModeStr = app.getErrorString(Queued_Move) then
		return QUEUE_MODE;
	elseif _moveModeStr = app.getErrorString(Planned_Move) then
		return PLANNING_MODE;
	elseif _moveModeStr = app.getErrorString(Auto_plan_instant_move) then // TFS 6536
		return AUTO_PLAN_INSTANT_MODE; // TFS 6536
	elseif _moveModeStr = app.getErrorString(Auto_Planned_Queued_Move) then
		return AUTO_PLAN_MODE;
	elseif _moveModeStr = app.getErrorString(AutoPlan_On_Pickup) then  //cnwrd1 par 26734 CCMS 2014 plan on pickup
		return QUEUE_PLAN_ON_PICKUP;
	elseif _moveModeStr = app.getErrorString(Autoplan_plan_only) then	//18 July 2014	NDL	Par 34602
		return AUTO_PLAN_ONLY_MODE;
	elseif _moveModeStr = app.getErrorString(Pack) then	//18 July 2014	NDL	Par 34602
		return INSTANT_PACK_MODE;
	endif;
	
	
end;</source>
        <Parameter name="_moveModeStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
