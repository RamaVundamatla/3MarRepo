<Class name="UT_Chassis" id="045b6720-c2ad-4cb2-9f22-da4f5c956b35">
    <superclass name="UT_Gate"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
