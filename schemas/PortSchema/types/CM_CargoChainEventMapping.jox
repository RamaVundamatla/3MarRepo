    <JadeMethod name="isCreateManualInvoice" id="479648b3-50de-462b-b4e0-870588d7f8ed">
        <source>isCreateManualInvoice() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	parameters		: JadeDynamicObject;
begin
	
	if self.myParameters &lt;&gt; null then
		parameters  := self.myParameters;
	endif;
	if parameters &lt;&gt; null then
		if parameters.name = "CM_InvoiceLineDesc" then
			return true;
		endif;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
