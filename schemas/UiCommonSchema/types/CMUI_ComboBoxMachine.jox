<GUIClass name="CMUI_ComboBoxMachine" id="ca2a6345-d6fe-40cf-95aa-24568ba68937">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isCrane" id="9deb7c68-d43e-4c5e-ab29-28d4c52100a6">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="94210d18-0b13-4535-bd99-fd511608f2de">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="bd25cffa-0ef4-47f1-8e31-31f92982ebfa">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _machine: CM_Machine; lstIndex: Integer): String updating, clientExecution;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin

	if _machine = null then
		return null;
	endif;
	
	if isCrane and _machine.machineType &lt;&gt; MACHINETYPE_PORTAINER_CRANE then 
		return null;
	endif;
	
	if _machine.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _machine then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
		

	if (not _machine.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	return _machine.id.String &amp; Tab &amp; _machine.description;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="d9aeec6d-3dc5-46c8-8b27-41fceecffec8">
        <source>getCollectionJMT(): Collection protected;
// -------------------------------------------
// Created 15 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.machines;
	endif;


end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
