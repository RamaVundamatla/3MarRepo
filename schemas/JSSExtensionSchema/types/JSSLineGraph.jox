    <JadeMethod name="calculateGraphSize" id="c5a7cf34-ac70-4552-b8e9-25b330d08d30">
        <updating/>
        <source>calculateGraphSize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isShowLineLegend then
		self.graphHeight	:=	(self.height - self.graphLabelHeight - self.graphLabelHeight - self.graphLabelHeight - 0).Integer;
		self.graphWidth		:=	(self.width - self.maxScaleLabelWidth - 6).Integer;
	else
		self.graphHeight	:=	(self.height - self.graphLabelHeight - self.graphLabelHeight - 0).Integer;
		self.graphWidth		:=	(self.width - self.maxScaleLabelWidth - 6).Integer;
	endif;
	
	if self.borderStyle &lt;&gt; 0 then
		self.graphHeight	:=	self.graphHeight - 2;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkData" id="e6ccf69e-4207-4e08-896b-e8cae0e9beeb">
        <updating/>
        <source>checkData():String updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: String;
	numberOfLines 	: Integer;
	colorArray		: IntegerArray;
	position		: Integer;
	lineColor		: Integer;
	
begin
	numberOfLines := self.allLinesArray.size();
	
	if numberOfLines = 0 then
		if self.isShowTestData then
			self.clearGraph();
			self.setDefaultsInPainter();
			numberOfLines	:=	self.allLinesArray.size();
		else
			returnValue	:=	"No Data";
			return returnValue;
		endif;
	endif;
	
	if (numberOfLines * self.graphLabelHeight) &gt; self.graphWidth then
		returnValue	:=	"Too Much Data";
		return returnValue;
	endif;
	
	if self.isShowLineLegend then
		if numberOfLines &gt; self.allGraphColors.size() then
			returnValue	:=	"Not enough colors set";
			return returnValue;
		endif;
		
		create colorArray transient;
		
		foreach position in 1 to numberOfLines do
			lineColor	:=	self.allGraphColors[position];
			
			if not colorArray.includes(lineColor) then
				colorArray.add(lineColor);
			else
				returnValue	:=	"Color used more than once";
				return returnValue;
			endif;
		endforeach;
	endif; 
	
	return returnValue;
epilog
	delete colorArray;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="0386c80f-e5e9-482e-8add-a5dd80f967a3">
        <updating/>
        <source>clearGraph() updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.allXAxisLabels.purge();
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createLegendLabel" id="01c96a5f-2527-40de-9015-e6b97d9055aa">
        <updating/>
        <source>createLegendLabel() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLabel	: JSSLabel;
	
begin
	if self.isShowLineLegend then
		if self.myLegendLabel &lt;&gt; null then
			delete self.myLegendLabel;
		endif;
		
		create theLabel transient;
		
		theLabel.name		:=	self.LEGEND_LABEL;
		theLabel.parent		:=	self;
		theLabel.left		:=	1;
		theLabel.visible	:=	true;
		theLabel.height		:=	self.graphLabelHeight;
		theLabel.top		:=	self.graphLabelHeight + self.graphHeight + self.graphLabelHeight;
		theLabel.width		:=	self.width - 2;
		theLabel.backColor	:=	self.backColor;
		theLabel.foreColor	:=	Black;
		theLabel.alignment	:=	Label.Alignment_Center_Middle;
		self.form.addControl(theLabel);
		theLabel.caption	:=	"";
		self.myLegendLabel	:=	theLabel;
		
		self.setLegendLabel(0);
	else
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLines" id="8506e458-b54c-42e1-9c53-e44331b4fa17">
        <updating/>
        <source>createLines(pPointGap : Integer; pNumberOfPoints : Integer; pTheLine : Object; pLineNumber : Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startX						: Real;
	startY						: Real;
	endX						: Real;
	endY						: Real;
	lineColor					: Integer;
	unitValue					: Real;
	position					: Integer;
	lineValuesArray				: IntegerArray;
	numberOfPointsOnThisLine	: Integer;
	
begin
	position	:=	1;
	
	if pLineNumber &lt;= self.allGraphColors.size() then
		lineColor	:=	self.allGraphColors[pLineNumber];
	else
		lineColor	:=	Black;
	endif;
	
	unitValue		:=	self.graphHeight / self.maxValue;
	self.drawWidth	:=	2;
	
	create lineValuesArray transient;
	pTheLine.IntegerArray.copy(lineValuesArray);
	numberOfPointsOnThisLine	:=	lineValuesArray.size();
	
	if pNumberOfPoints &gt; 1 then
		
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfPointsOnThisLine do
//			// If the line position value is zero, then defer drawing the line.
//			
//			if lineValuesArray[position] = 0 then
//				continue;
//			endif;
			
			//set up x and y
			endX	:=	((position - 1) * pPointGap) + self.maxScaleLabelWidth;
			endY	:=	(self.graphHeight - (lineValuesArray[position] * unitValue)) + self.graphLabelHeight;
			
			if position = 1 then
				startX	:=	endX;
				startY	:=	endY;
			endif;
			
			//draw the line here
			self.drawLine(startX, startY, endX, endY, lineColor);
			
			startX	:=	endX;
			startY	:=	endY;
		endforeach;
	endif;
epilog
	delete lineValuesArray;
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pTheLine" type="Object"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e1bb2b0c-4c1b-481e-a943-6f490a6a135c">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddLine" id="dc07e113-1b5f-4baa-8ad9-dabfd149bbfd">
        <source>doAddLine() protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newLineArray	: IntegerArray;
	
begin
	create newLineArray transient;
	self.allLinesArray.add(newLineArray);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddValue" id="d7e85a9d-0d57-4d48-9a77-c13db3b1c7d5">
        <source>doAddValue(pValue:Integer; pLineNumber:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lineArray		: IntegerArray;
	numberOfLines	: Integer;
	
begin
	numberOfLines	:=	self.allLinesArray.size();
	
	while numberOfLines &lt; pLineNumber do
		self.doAddLine();
		numberOfLines	:=	numberOfLines + 1;
	endwhile;
	
	lineArray	:=	self.allLinesArray[pLineNumber].IntegerArray;
	lineArray.add(pValue);
	
	return true; 
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeValue" id="01feccf6-cc90-4b42-bdd4-092e6cb9194a">
        <source>doChangeValue(pValue:Integer; pLineNumber:Integer; pPosition:Integer ):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lineArray	: IntegerArray;
	
begin
	if self.allLinesArray.size() &lt; pLineNumber then
		return false;
	endif;
	
	lineArray	:=	self.allLinesArray[pLineNumber].IntegerArray;
	
	if lineArray.size() &lt; pPosition then
		return false;
	endif;
	
	lineArray[pPosition]	:=	pValue;
	
	return true;
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="c8e6b822-609c-4729-9f6a-bfcaed4c7286">
        <updating/>
        <source>drawGraph() updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	inheritMethod();
	
	errorMessage	:=	self.checkData();
	
	self.calculateGraphSize();
	
	if errorMessage = null then
		self.autoRedraw	:=	true;
		self.setMaxScaleLength();
		self.createLegendLabel();
		self.setScale();
		self.setupForm();
	else
		self.doDataError(errorMessage);
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="5f154e3d-381d-43a8-9863-608feab96f04">
        <updating/>
        <source>mouseUp(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(self, button, shift, x, y);
	
	if (not self.isInPainter()) then
		if self.isShowLineLegend then
			self.setLegendLabel(self.getPoint(x, y));
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="9e0a5458-341f-41b1-ac73-d7bcbd79b924">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.graphTitle	:=	self.name &amp; " - Sample data";
	
	self.doAddValue(10, 1);
	self.doAddValue(20, 1);
	self.doAddValue(50, 1);
	self.doAddValue(30, 1);
	self.doAddValue(40, 1);
	
	self.doAddValue(20, 2);
//	self.doAddValue(10, 2);
//	self.doAddValue(40, 2);
	self.doAddValue(0, 2);
	self.doAddValue(0, 2);
	self.doAddValue(25, 2);
	self.doAddValue(30, 2);
	
	self.doAddValue(30, 3);
	self.doAddValue(40, 3);
	self.doAddValue(15, 3);
	self.doAddValue(20, 3);
	self.doAddValue(15, 3);
	
	self.allGraphColors.add(Red);
	self.allGraphColors.add(Green);
	self.allGraphColors.add(Blue);
	
	self.allGraphLegends.add("1999");
	self.allGraphLegends.add("2000");
	self.allGraphLegends.add("2001");
	
	self.transparent := false;
	
	self.allXAxisLabels.add("January");
	self.allXAxisLabels.add("February");
	self.allXAxisLabels.add("March");
	self.allXAxisLabels.add("April");
	self.allXAxisLabels.add("May");
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLegendLabel" id="20e49c78-ea3a-4a0c-bbe0-479b4ea403cb">
        <source>setLegendLabel(pColor:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lineIndex		: Integer;
	theControl		: Control;
	theLabel		: Label;
	valueString		: String;
	
begin
	lineIndex	:=	self.allGraphColors.indexOf(pColor);
	
	if self.isInPainter() then
		valueString						:=	"Legend Label";
		self.myLegendLabel.foreColor	:=	Black;
	else
		if lineIndex &lt;&gt; 0 then
			if lineIndex &lt;= self.allGraphLegends.size() then
				valueString	:=	self.allGraphLegends[lineIndex];
			else
				valueString	:=	"No legend - ";
			endif;
			
			self.myLegendLabel.foreColor	:=	pColor;
		else
			valueString						:=	"Click on Line for Legends";
			self.myLegendLabel.foreColor	:=	Black;
		endif;
	endif;
	
	self.myLegendLabel.caption	:=	valueString;
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="600e78a6-51e8-495f-a91a-2444fc2f4e0f">
        <updating/>
        <source>setMaxScaleLength() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLabel		: Label;
	theLine			: Object;
	lineValue		: Integer;
	position		: Integer;
	numberOfLines	: Integer;
	
begin
	self.maxScaleLabelWidth	:=	0;
	numberOfLines	:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do
		theLine	:=	self.allLinesArray[position];
		
		foreach lineValue in theLine.IntegerArray do
			if lineValue &gt; self.maxValue then
				self.maxValue	:=	lineValue;
			endif;
		endforeach;
	endforeach;
	
	create theLabel transient;
	
	theLabel.caption		:=	lineValue.String;
	self.maxScaleLabelWidth	:=	theLabel.width.Integer;
epilog
	delete theLabel;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setScale" id="c3e4da93-08e3-4952-a3d8-3a61a48f2baa">
        <updating/>
        <source>setScale() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	position	: Integer;
	startY		: Integer;
	textValue	: String;
	
begin
	self.drawTextRotation	:=	0;
	
	foreach position in 1 to 5 do
		if position = 1 then
			textValue	:=	self.maxValue.String;
			startY		:=	self.graphLabelHeight;
		elseif position = 2 then
			textValue	:=	(self.maxValue * 0.75).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.25).Integer - 2;
		elseif position = 3 then
			textValue	:=	(self.maxValue * 0.5).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.50).Integer - 4;
		elseif position = 4 then
			textValue	:=	(self.maxValue * 0.25).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.75).Integer - 6;
		elseif position = 5 then
			textValue	:=	"0";
			
			if self.isShowLineLegend then
				startY	:=	(self.graphLabelHeight + self.graphHeight - 8).Integer;
			else
				startY	:=	(self.graphLabelHeight + self.graphHeight - 10).Integer;
			endif;
		endif;
		
		if self.maxValue &gt; 10 then
			textValue	:=	textValue.Integer.String;
		endif;
		
		self.drawTextAt(textValue, 1, startY, Black);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setXLabels" id="1a6693ad-f864-403c-b634-20235fc62d7a">
        <updating/>
        <source>setXLabels(pPointGap : Integer; pNumberOfPoints : Integer; pLineNumber : Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startX				: Real;
	startY				: Real;
	lineText			: String;
	textColor			: Integer;
	position			: Integer;
	numberOfXAxisLabels	: Integer;
	
begin
	position			:=	1;
	textColor			:=	Black;
	numberOfXAxisLabels	:=	self.allXAxisLabels.size();
	
	if pNumberOfPoints &gt; 1 then
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfXAxisLabels do
			lineText	:=	self.allXAxisLabels[position];
			
			while self.getTextExtent(lineText) &gt; pPointGap and lineText.length &gt; 1 do
				lineText	:=	lineText[1:(lineText.length - 1).Integer];
			endwhile;
			
			if lineText.length = 1 then
				if self.getTextExtent(lineText) &gt; pPointGap then
					lineText	:=	"";
				endif;
			endif;
			
			startX	:=	((position - 1) * pPointGap) + self.maxScaleLabelWidth - 7;
			startY	:=	self.graphLabelHeight + self.graphHeight;
			
			//draw the text here
			self.drawTextRotation	:=	0;
			self.drawTextAt(lineText, startX, startY, textColor);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2f7401bd-faef-400d-ab4c-609992db6509">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	numberOfLines		: Integer;
	pointCount			: Integer;
	maxNumberOfPoints	: Integer;
	pointGap			: Integer;
	theLine				: Object;
	position			: Integer;
	
begin
	numberOfLines	:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do
		pointCount	:=	self.allLinesArray[position].IntegerArray.size();
		
		if pointCount &gt; maxNumberOfPoints then
			maxNumberOfPoints	:=	pointCount;
		endif;
	endforeach;
	
	pointGap	:=	(self.graphWidth / (maxNumberOfPoints - .5 )).Integer;
	
	foreach position in 1 to numberOfLines do
		theLine	:=	self.allLinesArray[position];
		self.createLines(pointGap, maxNumberOfPoints, theLine, position);
	endforeach;
	
	self.setXLabels(pointGap, maxNumberOfPoints, position);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <DevControlTypes name="JSSLineGraph">
        <windowClass>AlBaseControl</windowClass>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
