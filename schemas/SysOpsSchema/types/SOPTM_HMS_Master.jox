    <JadeMethod name="setTableFromObjectSpecial" id="e909e070-74ef-4a68-a8b2-50521f515435">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;

/*
Date				Who		Reason
18 September 2012	cnwar2	#30239

*/
vars

begin
	inheritMethod(_tbl, _attrName, _row, _obj);

	if _attrName = ETRow_HasPEC then
		_tbl.setValue(_row, _obj.HMS_Master.hasAnyCurrentPEC());	
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTblData1Rows" id="fcd71675-c604-4090-8db8-cb3a4da6812a">
        <source>setTblData1Rows( _master	: HMS_Master);
//-----------------------------------------------------------------------
//	Created:	31 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	theForm 				: SOP_HMS_TableMaintForm;
	movement				: HMS_VoyageMovement;
	tmpDataTable			: CM_DataTable;
	idx						: Integer;	
begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
		
	tmpDataTable := theForm.tblData1;
	tmpDataTable.userInputEnabled := false;

	tmpDataTable.rows := 1;
	//now add the user terminal security roles	
	
	theForm.allClonedControls.purge();
//	theForm.newIndex := 0;

	if _master &lt;&gt; null then
		
		foreach movement in _master.allMovements do
		
			//05 Apr 2011	NDL	Par 27296
			if movement.getMyVessel = null then
				continue;
			endif;
			
			idx := tmpDataTable.addItemObject(movement, movement.moveType);
		
			tmpDataTable.accessCell(idx, 1).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVessel.name;
			
			tmpDataTable.accessCell(idx, 2).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVoyage.code;
			
			tmpDataTable.accessCell(idx, 3).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.moveType;
			
			tmpDataTable.accessCell(idx, 4).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.occursOnDTNEW.String;
			
			tmpDataTable.accessCell(idx, 5).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVessel.myHMSVesselData.dim_LengthOverall.String;
			
			tmpDataTable.accessCell(idx, 6).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVessel.myHMSVesselData.dim_DraftFore.String;
			
			tmpDataTable.accessCell(idx, 7).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVessel.myHMSVesselData.dim_DraftAft.String;
			
			tmpDataTable.accessCell(idx, 8).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.getMyVessel.myHMSVesselData.dim_GrossRegTonnes.String;
			
			tmpDataTable.accessCell(idx, 9).itemObject := movement;
			tmpDataTable.accessedCell.text := movement.isPilotExempt.cnEcGetYesNo.String;
			
		endforeach;
	endif;
end;</source>
        <Parameter name="_master" type="HMS_Master"/>
    </JadeMethod>
    <JadeMethod name="setTblShtData4" id="6a772ad6-4227-41d5-a05f-1513f602383c">
        <source>setTblShtData4( _master	: HMS_Master);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

	theForm : SOP_HMS_TableMaintForm;
	table	: CM_DataTable; 
	pilotExemptCert : HMS_PilotExemptionCertificate;
	master : HMS_Master;
	harbour : HMS_Harbour;
	
begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	table := theForm.tblShtData4;
	master := theForm.myCurrentObject.HMS_Master;
	harbour := theForm.myHarbour;
	
	table.rows := 1;
	if _master = null then
		return;
	endif;
	
	foreach pilotExemptCert in master.allPilotExemptionCertificates do
		if pilotExemptCert.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		table.addItemObject( pilotExemptCert, pilotExemptCert.getAttributeStringForDefArray(table.allTblDataEntRows) );
		table.accessedRow.selected := false;	// 13/09/2012 cnwar2 #30239
	endforeach;
	
epilog

end;</source>
        <Parameter name="_master" type="HMS_Master"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="c88879b2-6983-4e44-96cf-9ecbfcc33adb">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	pilotExemptTable : CM_DataTable;
	pilotExempt : HMS_PilotExemptionCertificate;
	theForm 	: SOP_TableMaintForm;
	tmpMenu		: MenuItem;

begin

	inheritMethod(conwin);
	theForm := self.myForm;

	pilotExemptTable := theForm.tblShtData4;
	if conwin = pilotExemptTable then
		if pilotExemptTable.row &gt; pilotExemptTable.fixedRows and pilotExemptTable.rows &lt;= pilotExemptTable.row then
			if pilotExemptTable.accessRow(pilotExemptTable.row).selected then
				pilotExempt := pilotExemptTable.accessRow(pilotExemptTable.row).itemObject.HMS_PilotExemptionCertificate;
			endif;
			if pilotExempt &lt;&gt; null then
				if pilotExempt.hasAudits then
					theForm.mnuContext1.enabled := true;
					theForm.mnuContext1.visible := true;
					theForm.mnuContext1.caption := "View Audits for " &amp; pilotExempt.auditId;
					theForm.mnuContext1.userObject := pilotExempt;
					tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f3346347-18f3-40c9-bf26-67b6fa3f99fa">
        <updating/>
        <source>setupThumbnailDetails() updating;
//-----------------------------------------------------------------------
//	Created:	01 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	
    inheritMethod();
	
	theForm.setTblDataEntRows(ETDef_HMSMaster);
	theForm.tblData.hideColumnByColName(ETRow_DateCertificateExpires);
	theForm.tblData.hideColumnByColName(ETRow_Loa);
	theForm.tblData.hideColumnByColName(ETRow_DateCertified);
	theForm.tblData.hideColumnByColName(ETRow_LastMovementDate);
	
	theForm.tblInput1.disableRowByName(ETRow_DateCertificateExpires);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7d8ab7f8-4188-40d6-9a16-2970405c62c3">
        <updating/>
        <source>showThumbnail(pObj: HMS_Master) updating;
//-----------------------------------------------------------------------
