    <JadeMethod name="changeLockKeeperKPIname" id="e05e7958-69fc-48a2-807a-8aa29a9c46c6">
        <source>changeLockKeeperKPIname();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 April 2019
TFS#		: 43817
Function	: Change Lock Keeper/KPI Name

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	root 			: CM_Root;
	bgpManager		: BGP_Manager;
	bgpController	: BGP_Controller;
begin	
	//Have we run it before
	/*if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;	*/
	
	app.initialize;
	
	app.writeLog( method.qualifiedName &amp; " Change Lock Keeper / KPI Name", LogINFO);
	
	/*if _controller &lt;&gt; null then
		_controller.logEntry(" Change Lock Keeper / KPI Name") ;	
	endif;*/
	// do not rely on the app.myRoot use the class itself
	root := CM_Root.firstInstance;
	
	beginTransaction;
	foreach bgpManager in root.allBGPManagers do
		foreach bgpController in bgpManager.allBGPControllers where bgpController.isKindOf(BGP_LockKeeperController) do
			app.writeLog("Fixing name for: " &amp; bgpController.getOidAsString, LogINFO);
			bgpController.setPropertyValue('name', 'Lock Keeper &amp; KPI');
		endforeach;
	endforeach;
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; " Change Lock Keeper / KPI Name - Complete", LogINFO);
	/*if _controller &lt;&gt; null then
		_controller.logEntry("  Change Lock Keeper / KPI Name - Complete") ;	
	endif;	
	// Log that it already ran.
	self.addScriptRun(method.name);*/
end;</source>
    </JadeMethod>
    <JadeMethod name="checkDischargePorts" id="8017a446-4360-46df-ae61-0bc14cff1156">
        <source>checkDischargePorts();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2012	cnwmc5	Initial creation

*/

vars
	mergeIter 	: MergeIterator;
	
	ti 			: CM_TrackedItem;
	terminal 	: CM_Terminal;
begin
	
	app.initialize();
	
	
	
	foreach terminal in app.myRoot.allTerminals discreteLock do
	
		delete mergeIter;
		create mergeIter transient;
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
		
		while mergeIter.next(ti) do
			if ti.dischargePort &lt;&gt; null and ti.dischargePort.trimBlanks().length &lt; 5 then
				write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.dischargePort &amp; Tab &amp; terminal.code &amp; Tab &amp; ti.creationTime.String;
			endif;
		endwhile;
		
	endforeach;
	
epilog
	delete mergeIter;
end;</source>
    </JadeMethod>
