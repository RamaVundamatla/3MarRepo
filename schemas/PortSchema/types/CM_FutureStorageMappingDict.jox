<CollClass name="CM_FutureStorageMappingDict" id="7d69567a-bdf9-4459-b6e9-a0691794dc4c">
    <loadFactor>66</loadFactor>
    <memberType name="CM_FutureStorageMapping"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_FutureStorageMapping::myStorageGroup"/>
    </MemberKey>
    <JadeMethod name="getStorageDetailAuditText" id="3d95f76b-98f2-448b-9a6e-56297c3e4886">
        <source>getStorageDetailAuditText():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2016	cnwndl1	Initial creation	TFS 1981

*/

vars

	retStr : String;
	fsm : CM_FutureStorageMapping;

begin

	foreach fsm in self do
		if fsm.myStorageGroup = null then
			continue;
		endif;
		if retStr &lt;&gt; null then
			retStr := retStr &amp; AuditStringSeparator;
		endif;
		retStr := retStr &amp; fsm.myStorageGroup.description;
	endforeach;
	
	return retStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
