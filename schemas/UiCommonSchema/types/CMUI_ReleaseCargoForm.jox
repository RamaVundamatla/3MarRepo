    <JadeMethod name="stub_SaveSelectedTrackedItems" id="11d942d7-cd2c-436d-be69-294af04f9835">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <source>stub_SaveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean;
// -----------------------------------------------------------------------------
// Created:		10 September 2009 by consw1
//
// Purpose:		Stub for IF_CMUI_TrackedItems interface (Cargo ID search).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	cell : JadeTableCell;
	row : JadeTableRow;
	control : Control;
	doSelect : Boolean;
	int : Integer;
begin
	int :=1;
	if _allTIs.isEmpty() then
		return true;
	endif;
	
	foreach ti in _allTIs do
		if not self.allSearchTIs.includes(ti) then
			self.allSearchTIs.add(ti);
		endif;
	endforeach;

	if self.updateMode &lt;&gt; self.Mode_Add then
		self.lstCargoIDvalues.clearSelected();
		self.lstCargoIDvalues.addSelectedObject(_allTIs.first);
	endif;
	
	self.txtCargoIDvalue.text := null;
	
	if self.allSearchTIs.size = 1 or _allTIs.size = 1 then
		if self.allSearchTIs.size = 1 then
			if not self.lstCargoIDvalues.findObjectInRow(self.allSearchTIs.first, int) then
				self.lstCargoIDvalues.clear();
				self.lstCargoIDvalues.addItem(self.allSearchTIs.first.CM_TrackedItem.id );
				self.lstCargoIDvalues.addSelectedObject(self.allSearchTIs.first);
			else
				self.lstCargoIDvalues.setSelected(self.allSearchTIs);
			endif;
			
		elseif _allTIs.size=1 then
			if not self.lstCargoIDvalues.findObjectInRow(_allTIs.first, int) then
				self.lstCargoIDvalues.clear();
				self.lstCargoIDvalues.addItem( _allTIs.first.id );
				self.lstCargoIDvalues.addSelectedObject(_allTIs.first);
			else
				self.lstCargoIDvalues.setSelected(_allTIs);
			endif;
		endif;
		self.lstCargoIDvalues.visible := true;
		self.txtCargoID.hasGotFocus(self.txtCargoID); //03 Feb 2011	NDL	Par 24754 - show the container you chose on the query form.
		self.txtCargoID.hasLostFocus(self.txtCargoID);
	else
		self.txtCargoID.hasGotFocus(self.txtCargoID);
		self.lstCargoIDvalues.setFocus();
	endif;
	return true;

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
