	tempStr	:= 'Adding Container ' &amp; CargoID2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
*/	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
