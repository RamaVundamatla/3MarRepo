    <JadeMethod name="getAllJobsForHold" id="89d971f3-dcb1-4ec8-b19c-4edd86088ec6">
        <source>getAllJobsForHold(_jobs:CM_VoyageJobArray input; _bayID : String)  ;
/*

Purpose:			
TFS 4796
Parameters:			

Return Value:		

Date		Who		Reason
13 July 2017	jlgrh7	Initial creation
13 Sep  2017    cnwma1	TFS #6810 POL - [Fwd: ##5579## : FW: Archiving Voyages]
*/

vars
	job : CM_Job;
	vJob : CM_VoyageJob;
	voyage : CM_Voyage;
	bay : CM_Bay;
	voyageBay : CM_BayVoyage;
	hold : CM_Hold;
	voyageHold : CM_VoyageHold;
	bayIDs : StringArray;
begin
	if _bayID = null then  //13.09.2017 cnwma1 TFS #6810
		return;
	endif;
	create bayIDs transient;
	if self.isKindOf(CM_VoyageJobSheet) then
		voyage :=self.CM_VoyageJobSheet.myVoyage;
	endif;
	if voyage &lt;&gt; null then
		bay := voyage.lookupBayVoyage(_bayID);
	endif;
	if bay &lt;&gt; null then
		hold := bay.myHold;
	endif;
	
	if hold &lt;&gt; null then
		voyageHold := hold.CM_VoyageHold;
	endif;
	
	foreach bay in voyageHold.allBays do
		bayIDs.add(bay.id);
	endforeach;
	
	foreach job in self.CM_VoyageJobSheet.allJobsByOrder   discreteLock do
		vJob := job.CM_VoyageJob;
		if bayIDs.indexOf( vJob.bayId ) &gt;0 then // in the same hold
			if not _jobs.includes(vJob) then
				_jobs.add(vJob);
			endif;
		endif;
	endforeach;
epilog
	delete bayIDs;
end;</source>
        <Parameter name="_jobs" type="CM_VoyageJobArray" usage="input"/>
        <Parameter name="_bayID" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="144c9781-6550-4da4-9a5b-5012a5e5c1da">
        <source>getAllWLEs(_wleArray : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 25 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job	: CM_Job;
begin

	foreach job in self.allJobsByOrder do
		if job.isKindOf(CM_VoyageJob) and
		   (not job.CM_VoyageJob.isLoadedToOperations) then
			continue;
		endif;
		
		if job.isKindOf(CM_RailJob) or job.isKindOf(CM_RoadJob) then
			continue;
		endif;
		
		job.getAllWLEs(_wleArray);		
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
