        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="facf18b0-ad69-44d3-b716-2cfcaa4dd6d5">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	match	: Boolean;
	obj		: Object;
	yaData  : CM_YAData;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	yaData := _criteria.myYAData;							
	
	foreach obj in yaData.CM_YADataObjects.allObjects do
		if obj.CM_TerminalAreaStorageGroup.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if yaData.isKindOf(CM_YADataPattern) and				
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="814b9fc8-4575-4920-b77d-d93e8a1a8b28">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/

vars
	taStorageGroup		: CM_TerminalAreaStorageGroup;
	yaData				: CM_YAData;
begin

	if _tiTrx &lt;&gt; null then								   
		if _tiTrx.myTrackedItem &lt;&gt; null then
			taStorageGroup := _tiTrx.myTrackedItem.getTAStorageGroup();
		endif;
	else
			taStorageGroup := _ti.getTAStorageGroup();
	endif;
	
	yaData := _criteria.myYAData;	
	if yaData.CM_YADataObjects.matchesStorage(taStorageGroup) then
		return true;
	endif;
	
	// default value
	if yaData.isKindOf(CM_YADataPattern) and			
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
