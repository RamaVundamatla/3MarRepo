    <JadeMethod name="addValue" id="ced9561c-9878-48e5-b9cb-58baa2aa1ca1">
        <updating/>
        <source>addValue(_label1, _label2 : String; _value, _color : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
begin

	self.allXAxisLabels.add(_label1);
	self.allXAxisLabels2.add(_label2);
	
	idx := self.allXAxisLabels.size;
	
	self.allGraphColors.atPut(idx, _color);
	self.allGraphValues.atPut(idx, _value);
	
	return idx;

end;</source>
        <Parameter name="_label1" type="String"/>
        <Parameter name="_label2" type="String"/>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_color" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateGraphSize" id="7b412103-2f37-4ef8-8cfc-c1c8a3889d1f">
        <updating/>
        <source>calculateGraphSize() updating, protected;

vars
	yLabelWidth,
	numLabels	: Integer;
begin

	if useXAxisLabelLine2 then
		numLabels := 3;	// heading + 2 lines of labels at the bottom
	else
		numLabels := 2;	// heading + 1 line of labels at the bottom
	endif;
	
	if xAxisHeading &lt;&gt; null then
		numLabels := numLabels + 1;
	endif;
	
	if yAxisHeading &lt;&gt; null then
		yLabelWidth := self.graphLabelHeight;
	endif;

	graphHeight	:= (clientHeight - (self.graphLabelHeight * numLabels)).Integer;
	graphWidth	:= (clientWidth - yLabelWidth - self.maxScaleLabelWidth - 6).Integer;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="700e9524-0fdc-4afc-8a23-19af7f51970a">
        <updating/>
        <source>clearGraph() updating;

begin
	inheritMethod();
	self.allXAxisLabels.purge();
	self.allXAxisLabels2.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createBars" id="a5ad9b56-7c82-4238-8b99-906af093fd1c">
        <updating/>
        <source>createBars(pBarWidth:Integer; pNumberOfBars:Integer; pMaxScale:Integer) updating, protected;

vars
	position			: Integer;
	leftPosition		: Integer;
	barHeight			: Integer;
	colorCount			: Integer;
	barColor			: Integer;
	leftCoordinate		: Integer;
	rightCoordinate		: Integer;
	topCoordinate		: Integer;
	bottomCoordinate	: Integer;

begin
	colorCount	:=	self.allGraphColors.size();

	foreach position in 1 to pNumberOfBars do
		leftCoordinate	:=	leftPosition + self.maxScaleLabelWidth;
		rightCoordinate	:=	leftCoordinate + pBarWidth;
		
		barHeight	:=	(self.allGraphValues[position] * (self.graphHeight / pMaxScale)).Integer;
		
		if barHeight = self.graphHeight then
			barHeight	:=	barHeight - 1;
		endif;
		
		topCoordinate	:=	(self.graphHeight + self.graphLabelHeight) - barHeight;
		bottomCoordinate	:=	topCoordinate + barHeight;		
		
		if position &lt;= colorCount then 
			barColor	:=	self.allGraphColors[position];
		else
			barColor	:=	0;
		endif;
		
		self.drawFillColor	:=	barColor;		
		self.drawFilledRectangle(leftCoordinate, topCoordinate, rightCoordinate, bottomCoordinate, barColor);
		
		leftPosition	:=	leftPosition + pBarWidth;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pBarWidth" type="Integer"/>
        <Parameter name="pNumberOfBars" type="Integer"/>
        <Parameter name="pMaxScale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="c01b56c1-a982-4f69-969d-72d32660c0be">
        <updating/>
        <source>drawGraph()updating;

vars
	numberOfBars	: Integer;
	
begin
	inheritMethod();
	
	numberOfBars	:=	self.allGraphValues.size();

	if numberOfBars &gt; 0 then
		self.setMaxScaleLength();	// R Barr 31/10/2006 Do this BEFORE calculating graph size
		self.calculateGraphSize();
		
		if (numberOfBars * 2) &gt; self.graphWidth then
			self.doDataError("Too Much Data");
		else
			self.autoRedraw	:=	true;
			//self.setMaxScaleLength();
			self.drawYAxis();
			self.setupForm();
		endif;
	else
		self.doDataError("No Data provided");
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawXAxis" id="471d68ea-6fee-4d97-bde4-df6f39914830">
        <updating/>
        <source>drawXAxis(pBarWidth:Integer; pNumberOfBars:Integer) updating, protected;

constants
	LabelSpacing	: Integer = 5;
	
vars
	labelHeight,
	startX,
	startY1,
	startY2				: Real; 
	lastEndPos1,
	lastEndPos2,
	textExtent			: Real;
	displayText1,
	displayText2		: String; 
	textColor			: Integer;
	idx					: Integer;
	numLabels1,
	numLabels2	: Integer;
	
begin

	numLabels1	:=	self.allXAxisLabels.size();
	numLabels2	:=	self.allXAxisLabels2.size();
	
	labelHeight := self.graphLabelHeight;

	startY1	:=	labelHeight + self.graphHeight;
	startY2	:=	startY1 + labelHeight;
	
	self.drawTextRotation	:=	0;
	
	foreach idx in 1 to pNumberOfBars do
		
		if idx &lt;= numLabels1 then
			displayText1 := self.allXAxisLabels[idx];
		else
			displayText1 := null;
		endif;

		if idx &lt;= numLabels2 then
			displayText2 := self.allXAxisLabels2[idx];
		else
			displayText2 := null;
		endif;
		
		startX := ((idx - 1) * pBarWidth) + self.maxScaleLabelWidth;				

		if startX &lt; lastEndPos1 and startX &lt; lastEndPos2 then
			continue;
		endif;
		
		if displayText1 &lt;&gt; null and startX &gt;= lastEndPos1 then
			self.drawTextAt(displayText1, startX, startY1, textColor);
			lastEndPos1 := startX + self.getTextExtent(displayText1) + LabelSpacing;
		endif;

		if displayText2 &lt;&gt; null and startX &gt;= lastEndPos2 then
			self.drawTextAt(displayText2, startX, startY2, textColor);
			lastEndPos2 := startX + self.getTextExtent(displayText2) + LabelSpacing;
		endif;
			
	endforeach;

	if self.xAxisHeading &lt;&gt; null then
		textExtent := self.getTextExtent(self.xAxisHeading);
		if textExtent &gt; self.clientWidth then
			startX := 1;
		else
			startX := ((self.clientWidth - textExtent) / 2);
		endif;
		if self.useXAxisLabelLine2 then
			self.drawTextAt(self.xAxisHeading, startX, startY2 + labelHeight, textColor);
		else
			self.drawTextAt(self.xAxisHeading, startX, startY1 + labelHeight, textColor);
		endif;
	endif;
	
	// now draw line across bottom
	self.drawLine(self.maxScaleLabelWidth,
				(self.graphHeight + self.graphLabelHeight),
				self.maxScaleLabelWidth + self.graphWidth,
				(self.graphHeight + self.graphLabelHeight),
				Black);		
end;</source>
        <access>protected</access>
        <Parameter name="pBarWidth" type="Integer"/>
        <Parameter name="pNumberOfBars" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawYAxis" id="b0defac0-cbc3-4542-b74f-93a7f246479f">
        <updating/>
        <source>drawYAxis() updating, protected;

vars
	textHeightOffset,
	textExtent	: Real;
	yMaxValue,
	position	: Integer;
	startX,
	startY		: Real;
	displayText	: String;	
	
begin

	textHeightOffset := getTextHeight('1') / 2;

	displayText := yAxisHeading;
	
	if displayText = null then
		startX := 1;
	else
		drawTextRotation		:= 90;
		drawTextCharRotation	:= 90;
		textExtent := getTextExtent(displayText);
		if textExtent &gt; graphHeight then
			startY := graphHeight + graphLabelHeight;
		else
			startY := ((graphHeight - textExtent) / 2) + graphLabelHeight + textExtent;
		endif;
		drawTextAt(displayText, 1, startY, Black);

		drawTextCharRotation := 0;

		startX := graphLabelHeight + 1;
	endif;

	drawTextRotation	:=	0;

	yMaxValue := maxValue;
	
	foreach position in 1 to 5 do
		if position = 1 then
			displayText	:=	yMaxValue.String;
			startY		:=	graphLabelHeight;
		elseif position = 2 then
			displayText	:=	(yMaxValue * 0.75).Real.String;
			startY		:=	graphLabelHeight + (graphHeight *.25).Integer;
		elseif position = 3 then
			displayText	:=	(yMaxValue * 0.5).Real.String;
			startY		:=	graphLabelHeight + (graphHeight *.50).Integer;
		elseif position = 4 then
			displayText	:=	(yMaxValue * 0.25).Real.String;
			startY		:=	graphLabelHeight + (graphHeight *.75).Integer;
		elseif position = 5 then
			displayText	:=	"0";
			startY		:=	(graphLabelHeight + graphHeight).Integer;
		endif;
		
		if maxValue &gt; 10 then
			displayText	:=	displayText.Integer.String;
		endif;
		
		drawTextAt(displayText, startX, startY - textHeightOffset, Black);	
		drawLine(maxScaleLabelWidth - 1, startY, maxScaleLabelWidth + 4, startY, Black);
	endforeach;

	// now draw line up left
	drawLine(maxScaleLabelWidth - 1,
				graphLabelHeight,
				maxScaleLabelWidth - 1,
				(graphHeight + graphLabelHeight + 1),
				Black);		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="598e4c4a-ff97-4f0b-989d-84dbff35ff46">
        <updating/>
        <source>init(_title, _xAxisHeading, _yAxisHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.graphTitle		:= _title;
	self.xAxisHeading	:= _xAxisHeading;
	self.yAxisHeading	:= _yAxisHeading;

end;</source>
        <Parameter name="_title" type="String"/>
        <Parameter name="_xAxisHeading" type="String"/>
        <Parameter name="_yAxisHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="7e240100-1f5e-4c0e-a3a1-b70f4f9d5ac1">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	inheritMethod();
	 
	self.allXAxisLabels.add("January"); 
	self.allXAxisLabels.add("February");
	self.allXAxisLabels.add("March");
	self.allXAxisLabels.add("April");
	self.allXAxisLabels.add("May");
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="852eb948-945d-48ac-a6ab-14b6b0229f6d">
        <updating/>
        <source>setMaxScaleLength() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14/11/2006 by R Barr
//
// Purpose:     Rewritten to predict y axis labels when calcualting left graph position
// ---------------------------------------------------------------------------
vars
	theLabel		: Label;
	scaleValue		: Integer;
	position		: Integer;
	yAxisLabel		: Decimal[12,2];
	yLabelExtent	: Integer;
	maxYLabelExtent	: Integer;
begin

	maxScaleLabelWidth	:=	0;
	
	maxValue := 1;	// R Barr 31/10/2006 Re-initialise before redraw
	maxYLabelExtent := getTextExtent(maxValue.String);

	// get the largest value
	foreach scaleValue in allGraphValues where scaleValue &gt; maxValue do
		maxValue :=	scaleValue;
	endforeach;

	// get text extent of longest y axis label
	// need to work out what the labels will be (see drawYAxis) 
	foreach position in 1 to 5 do
		yAxisLabel := maxValue * ((position - 1) / 4);
		yLabelExtent := getTextExtent(yAxisLabel.String);
		if maxYLabelExtent &lt; yLabelExtent then
			maxYLabelExtent := yLabelExtent;
		endif;
		
	endforeach;

	// add 10% to leave a space at left of graph
	maxYLabelExtent := (maxYLabelExtent * 1.1).rounded;

	// add the y axis label's height (it's is rotated 90%)
	if yAxisHeading &lt;&gt; null then
		maxScaleLabelWidth	:=	maxYLabelExtent	+ graphLabelHeight;
	endif;
	
epilog
	delete theLabel;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLengthOLD" id="2e71f004-32fa-478c-b0c8-0d149dacc2cd">
        <updating/>
        <source>setMaxScaleLengthOLD() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theLabel		: Label;
	scaleValue		: Integer;
	yLabelExtent	: Integer;
	maxYLabelExtent	: Integer;
begin
	maxScaleLabelWidth	:=	0;
	
	maxValue := 1;	// R Barr 31/10/2006 Re-initialise before redraw
	maxYLabelExtent := getTextExtent(maxValue.String);
	
	foreach scaleValue in allGraphValues do
		if scaleValue &gt; maxValue then
			maxValue	:=	scaleValue;
		endif;
		// get text extent of longest y axis label
		yLabelExtent := getTextExtent(scaleValue.String);
		if maxYLabelExtent &lt; yLabelExtent then
			maxYLabelExtent := yLabelExtent;
		endif;
app.writeStatement( scaleValue.String &amp;Tab&amp; maxYLabelExtent.String);
	endforeach;
	
/*	// add 10% to leave a space at top of graph
	if maxValue &lt;&gt; 100 then //&lt;&lt;-- displaying as %
		maxValue := (maxValue * 1.1).Integer;
	endif;
*/	
/*	R Barr 31/10/2006 Use getTextExtent to determine label width
	create theLabel transient;
	theLabel.caption	:=	scaleValue.String;
	maxScaleLabelWidth	:=	theLabel.width.Integer + 4;	
*/	maxScaleLabelWidth	:=	getTextExtent(maxValue.String) + 4;
	if yAxisHeading &lt;&gt; null then
//		maxScaleLabelWidth	:=	maxScaleLabelWidth	+ graphLabelHeight;
		maxScaleLabelWidth	:=	maxYLabelExtent	+ graphLabelHeight;
	endif;

	
epilog
	delete theLabel;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7d063e15-5d3a-4e21-a30c-45b66aea5e32">
        <updating/>
        <source>setupForm() updating, protected;

vars
	numberOfBars	: Integer;
	barWidth		: Integer;
	
begin
	numberOfBars	:=	self.allGraphValues.size();
	barWidth		:=	(self.graphWidth / numberOfBars).Integer;
	
	if self.maxBarWidth &lt;&gt; 0 and barWidth &gt; self.maxBarWidth then
		barWidth := self.maxBarWidth;
	endif;
	
	self.createBars(barWidth, numberOfBars, self.maxValue);
	self.drawXAxis(barWidth, numberOfBars);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="truncateLabelToBarWidth" id="2240f685-6ff6-443e-9627-5352dafccca2">
        <source>truncateLabelToBarWidth(_label : String; _barWidth : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     code to truncate labels - leave incase want to add as an option at sometime
// ---------------------------------------------------------------------------
vars
	rtnStr	: String;

begin

	rtnStr := _label;
	
	while (self.getTextExtent(rtnStr) &gt; _barWidth) and 
		  (rtnStr.length &gt; 1) do
		rtnStr	:= rtnStr[1:(rtnStr.length - 1).Integer];
	endwhile;
	
	if rtnStr.length = 1 then
		if self.getTextExtent(rtnStr) &gt; _barWidth then
			rtnStr	:=	"";
		endif;
	endif;	
	
	return rtnStr;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <Parameter name="_barWidth" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
