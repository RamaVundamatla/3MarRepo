    <JadeMethod name="trxUpdateInvoiceStatuses" id="2050e014-d83a-4cc9-b2ee-dbeba0f4d61c">
        <updating/>
        <source>trxUpdateInvoiceStatuses(_statuses : CMIF_Array; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2010 by cnwjre1, copied from trxUpdateInvoiceStatus
//
// Purpose:		Par 23341 handle multi-select invoice post in a single transaction
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
//22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
vars
	obj		: CMIF_Object;
	status	: CMIF_InvoiceStatus;
	pxyInvoiceLine : CM_InvoiceLine;
	realInvoice	: CM_Invoice;
	expectedEdition	: Integer;
	proxyInvoice 	: CM_Invoice;
	
	invoices : CM_InvoiceSet;
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;
begin
	
	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1



	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// validate all first
	foreach obj in _statuses do
		status := obj.CMIF_InvoiceStatus;
		proxyInvoice := status.myInvoice;
		proxyInvoice.raiseExceptionIfNotProxy(method);
		
		proxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
		proxyInvoice.toDT := status.toDT;	// PAR 24168 pass input closing date to proxy for validation
		app.myValUA.valInvoiceStatus(realInvoice, status);
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;

		if invoices.tryAddIfNotNull(realInvoice) then  // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
// ### JIRA 19932 21OCT2024 NAVAB1			reserveLock(realInvoice); 					//22.06.2024 navrv30 Task 64598
		endif;
	endforeach;

	app.setContinueCMExceptions(false);

	beginTransaction;

	foreach obj in _statuses do
		status := obj.CMIF_InvoiceStatus;
		if status.allInvoiceLines.isEmpty then
			app.myUtilityUA.utlUpdateInvoiceStatus( status, _passport);
			if _passport.hasErrors() then
				return;
			endif;
		else
			foreach pxyInvoiceLine in status.allInvoiceLines do
				app.myUtilityUA.utlUpdateInvoiceLineStatus( pxyInvoiceLine, status, _passport);
				if _passport.hasErrors() then
					return;
				endif;
			endforeach;
			
			// PAR #36909 see if we need to create a minimum charge invoice line for this invoice	// PAR #36909
			status.myInvoice.checkForMinimumCharge();												// PAR #36909
		endif;
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	if not _passport.hasErrorsOrWarnings() then
		foreach inv in invoices do
			inv.setTaxDetailsFromLines();
			inv.setTotalAmountFromLines();
			//11/10/2024	navkc1	JIRA 12538 - send notification to all linked invoices/credit notes
			inv.doNotifyLinkedInvoicesCNotes();
		endforeach;
	endif;
epilog
	delete invoices;

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_statuses" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
