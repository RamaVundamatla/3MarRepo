    <JadeMethod name="clear" id="fd1ac17f-75c5-4cbe-98c1-c44ba5bc11ed">
        <updating/>
        <source>clear() updating;
/*
 ------------------------------------------------------------------------
Created:			16 September 2002 by cnwdwq1
Purpose:			Clears the object.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.commodityGroup := null;
	self.consignee := null;
	self.dischargePort := null;
	self.disconnected := false;
	self.doorDirection := 0;
	self.isHazardous := false;
	self.isoType := null;
	self.isOverDimension := false;
	self.locationId := null;
	self.operatorCode := null;
	self.plannedLocationId := null;
	self.roughPlanLocationId := null;
	self.seqNumCustomPort := null;
	self.seqNumCustomStarboard := null;
	self.sequenceNumberPort := null;
	self.sequenceNumberWorkOrder := null;
	self.status := null;
	self.temperature := NULL_TEMPERATURE;
	self.tiType := null;
	self.toBeInspected := false;
	self.totalWeight := null;
	self.trackedItem := null;
	self.trackedItemId := null;
	//	self.wantSeqSheetInfo := false; Leave this
	self.warningsHaveBeenAcknowledged := false;
	self.workListEntry := null;
end;</source>
    </JadeMethod>
</Class>
