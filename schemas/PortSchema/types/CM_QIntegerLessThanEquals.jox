    <JadeMethod name="doMatch" id="afa3f365-695c-4e57-8180-03b27b393ffd">
        <source>doMatch(_value: Integer): Boolean;
//-----------------------------------------------------------------------
//	Created:	11 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	return _value &lt;= searchValue;

epilog

end;</source>
