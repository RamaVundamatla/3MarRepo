    <JadeMethod name="getMyBerth" id="85d7486d-96af-4214-9c44-0c7f2deb0cbf">
        <source>getMyBerth() : HMS_Berth;
// ---------------------------------------------------------------------------
// Created:     03 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
23/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	if self.myBerth &lt;&gt; null then
		return self.myBerth;
	endif;	
	
	return null;

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
