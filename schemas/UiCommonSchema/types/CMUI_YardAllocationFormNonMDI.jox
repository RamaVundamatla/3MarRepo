<GUIClass name="CMUI_YardAllocationFormNonMDI" id="467fdb3c-5871-45f0-b448-42040bac0c7f">
    <superclass name="CMUI_YardAllocationForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="create" id="ebf8c570-12d6-4dab-8913-15274f0a5ebf">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.setFormParent(app.mainForm);			// cnwab1 06/05/2005.
	self.permissionView	 := PmAdmYAMaint;
	self.permissionMaint := PmAdmYAMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="16b2e1f4-5607-4bed-9044-994e408ae9f6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008260, locale);
end;</source>
    </JadeMethod>
</GUIClass>
