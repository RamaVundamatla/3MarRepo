    <JadeMethod name="setDetailValues" id="c8e2383a-8a12-4db5-baeb-b29558bd6b87">
        <updating/>
        <source>setDetailValues(_tran: CM_TITransaction) updating;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	ti	:CM_TrackedItem;
begin
	inheritMethod(_tran);

	ti := _tran.myTrackedItem;
	
	// general cargo
	self.totalWeight 	:= self.totalWeight + ti.totalWeight;
	
	// epr CCMS 2274 break bulk changes get quantity from transaction for break bulk could discharge 50 rebar and merge it with rebar onsite 
	// therefore need the quantity of the transaction as the ti quantity won't be what was moved
	if _tran.isKindOf(CM_ReleaseShip) then
		self.quantity := self.quantity + _tran.CM_ReleaseShip.totalQuantity.max(1);
		
	elseif _tran.isKindOf(CM_ReceiveShip) then
		self.quantity := self.quantity + _tran.CM_ReceiveShip.totalQuantity.max(1);
	endif;
	 
	self.linearMetres	:= self.linearMetres + ti.getLinearMetres;
	self.volume			:= self.volume + ti.getMyTotalVolume;   // PAR 27868
	self.area			:= self.area + ti.getAreaInSquareMetres (REAL_MODE);
epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKeyValues" id="1888e869-4273-444d-9acb-0e0699476d16">
        <updating/>
        <source>setKeyValues(_cargoType: CM_CargoType; _cargoSubType: CM_Product; _moveType: Integer; _len: Integer; _contents: Integer; _isTranship: Boolean; _kpiEntity: CM_KPIVoyageEntity) updating;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	str	:String;
begin
	inheritMethod(_cargoType, _cargoSubType, _moveType, _len, _contents, _isTranship, _kpiEntity);
		
	// PAR 25363
	if _isTranship then
		str := self.getMoveTypeDescr() &amp; "/TS"; 
	else
		str := self.getMoveTypeDescr() &amp; "/NON TS"; 
	endif;
	
	self.keyValueString := str[1:30];
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_contents" type="Integer"/>
        <Parameter name="_isTranship" type="Boolean"/>
        <Parameter name="_kpiEntity" type="CM_KPIVoyageEntity"/>
    </JadeMethod>
</Class>
