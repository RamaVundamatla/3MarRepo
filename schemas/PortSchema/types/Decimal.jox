    <JadeMethod name="sedStringCSVFormat" id="20dbc79a-7361-4dfb-b742-e9d827e5fde3">
        <source>sedStringCSVFormat() : String;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnString : String;
begin
	rtnString := self.cnEcStripDecimalZeros().String;
	if (not rtnString.isInteger) then
		rtnString := self.asStringJMTWithPrecision($CM_Decimal1LeadingZero.decimalPlaces, true);
	endif;
	if self &lt; 0  then
		rtnString := '0';
	endif;
	return rtnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stringWithLeadingZeros" id="d0ef6127-1304-47a0-9d47-84de72662814">
        <source>stringWithLeadingZeros(digits:Integer):String;

vars
	padding:String;
	leadingZeros,index:Integer;
begin
	if self &lt; 10 then
		leadingZeros := digits - 1;
	elseif self &lt; 100 then
		leadingZeros := digits - 2;
	elseif self &lt; 1000 then
		leadingZeros := digits - 3;
	elseif self &lt; 10000 then
		leadingZeros := digits - 4;
	elseif self &lt; 100000 then
		leadingZeros := digits - 5;
	elseif self &lt; 1000000 then
		leadingZeros := digits - 6;
	elseif self &lt; 1000000 then
		leadingZeros := digits - 7;
	endif;
	if leadingZeros &lt; 1 then
		return self.String;
	else
		foreach index in 1 to leadingZeros do
			padding := padding &amp; "0";
		endforeach;
		return padding &amp; self.String;
	endif;
		 
end;</source>
        <Parameter name="digits" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
