	return self.rate;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRateEntry" id="2a40f05c-4ad8-460b-8fc0-67d3f25924f8">
        <source>getRateEntry() : CM_RateEntry;
// CCMS 1327 get the rate entry for CM_InvoiceLine::getTidalClassRateEntry 
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018 	cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	debtor	: CM_Debtor;
	re		: CM_RateEntry;
	vessel	: CM_Vessel;				// TFS 37794
	vesselType : HMS_VesselType;		//07.06.2018 cnwma1 ChangeRequest #38953
	visitType  : HMS_VisitType;			//07.06.2018 cnwma1 ChangeRequest #38953
	berth      : HMS_Berth;				//07.06.2018 cnwma1 ChangeRequest #38953
begin
	if self.status = VOID or
	   self.service = null then			// 36965 handle null service
		return null;
	endif;

	debtor := self.invoiceLine.debtor;
	if self.service.defaultRateTable = CM_Service.DEFAULT_RATE_TABLE then
		re := debtor.getServiceTimeRate(self.service, self.invoiceLine.getChargeTime);
	elseif self.service.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then						// TFS 37794
		vessel := self.invoiceLine.getMyVesselObject();												// TFS 37794
		if vessel &lt;&gt; null then																		// TFS 37794
			re := vessel.getVesselServiceTimeRate(self.service, self.invoiceLine.getChargeTime);	// TFS 37794
			if re = null then																		// TFS 37794
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);	// TFS 37794
			endif;																					// TFS 37794
		endif;																						// TFS 37794
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.service.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then
		vesselType := self.invoiceLine.getMyVesselTypeObject();												
		if vesselType &lt;&gt; null then																		
			re := vesselType.getVesselTypeServiceTimeRate(self.service, self.invoiceLine.getChargeTime);	
			if re = null then																		
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);	
			endif;																					
		endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.service.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then
		visitType := self.invoiceLine.getMyVisitTypeObject();												
		if visitType &lt;&gt; null then																		
			re := visitType.getVisitTypeServiceTimeRate(self.service, self.invoiceLine.getChargeTime);	
			if re = null then																		
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);	
			endif;																					
		endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.service.defaultRateTable = CM_Service.BERTH_RATE_TABLE then
		berth := self.invoiceLine.getMyBerthObject();												
		if berth &lt;&gt; null then																		
			re := berth.getBerthServiceTimeRate(self.service, self.invoiceLine.getChargeTime);	
			if re = null then																		
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);	
			endif;																					
		endif;
	else
		if self.invoiceLine.trackedItem &lt;&gt; null then
			re := debtor.getTradeServiceTimeRate(self.service, self.invoiceLine);
			if re = null then
				re := debtor.getServiceTimeRate(self.service, self.invoiceLine.getChargeTime);
			endif;
		else
			re := debtor.getServiceTimeRate(self.service, self.invoiceLine.getChargeTime);
		endif;
	endif;

	return re;
end;</source>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getRateFromTable" id="c98b544e-9596-4307-914c-fb6faf116b3c">
        <source>getRateFromTable(_total : Real io) : Real;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// TFS 42221 19DEC18 Lots of logging
// 18 Oct 2024	navlw1		JIRA MTN-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	rateHook	 	 : Integer;
	value			 : Real;
	valueIn, 
	valueOut		 : Real;
	calculationType  : CM_CalculationType;
	re				 : CM_RateEntry;
	trans			 : CM_Transaction;	
	cmifHook		 : CMIF_CalcTypeRateHook;		// cnwmc5 - 8 Oct 2015 - PAR 36920
	vessel 			 : CM_Vessel;					// TFS 37794
	vesselType 		 : HMS_VesselType;	    		//07.06.2018 cnwma1 ChangeRequest #38953
	visitType  		 : HMS_VisitType;				//07.06.2018 cnwma1 ChangeRequest #38953
	berth	   	     : HMS_Berth;					//07.06.2018 cnwma1 ChangeRequest #38953
	canLogExtra		 : Boolean;						//26.02.2025 navah1	#34141
	methodName  	 : String;
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	methodName	:= method.qualifiedName;				//5.3.25 navma1 #34141
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(methodName &amp; " STARTING", LogINFO.String);
	endif;
	if status = VOID or
	   self.service = null then		// 36965 handle null service
		value := 0.0;
		if canLogExtra then	//26.02.2025 navah1	#34141
			if status = VOID then
				app.invLog("RATE - ZERO - Status is VOID", LogINFO.String);
			elseif self.service = null then
				app.invLog("RATE - ZERO - No Service", LogINFO.String);
			endif;
		endif;
		return value;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(methodName &amp; " INV LINE: " &amp; self.invoiceLine.invoiceLineDesc.narration &amp; " DEBTOR: " &amp; self.invoiceLine.debtor.name
			&amp; " SERVICE: " &amp; self.service.name &amp; " DEFAULT RATE TABLE: " &amp; service.defaultRateTable.String, LogINFO.String);
	endif;
	if service.defaultRateTable = CM_Service.DEFAULT_RATE_TABLE then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(methodName &amp; " DEFAULT RATE", LogINFO.String);
		endif;
		re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);
		if re &lt;&gt; null then
			
			value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);
		else
			value := 0.0;
		endif;
	elseif service.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then									// TFS 37794
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(methodName &amp; " Service '" &amp; service.name &amp; "' is a VESSEL RATE", LogINFO.String);
		endif;
		vessel := self.invoiceLine.getMyVesselObject();													// TFS 37794
		if vessel &lt;&gt; null then																			// TFS 37794
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " found VESSEL " &amp; vessel.code, LogINFO.String);
			endif;
			re := vessel.getVesselServiceTimeRate(self.service, self.invoiceLine.getChargeTime);		// TFS 37794
			if re = null then																			// TFS 37794
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(methodName &amp; " rate not found for vessel, using DEFAULT RATE", LogINFO.String);
				endif;
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);		// TFS 37794
			endif;																						// TFS 37794
		else																							// TFS 37794
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " vessel not derived, using DEFAULT RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);			// TFS 37794
		endif;																							// TFS 37794
		if re &lt;&gt; null then																				// TFS 37794
			value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);		// TFS 37794
		else																							// TFS 37794
			value := 0.0;																				// TFS 37794
		endif;																							// TFS 37794
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif service.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(methodName &amp; " Service '" &amp; service.name &amp; "' is a VESSEL TYPE RATE", LogINFO.String);
		endif;
		vesselType := self.invoiceLine.getMyVesselTypeObject();	
		if vesselType &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " found VESSEL TYPE" &amp; vesselType.code, LogINFO.String);
			endif;
			re := vesselType.getVesselTypeServiceTimeRate(self.service, self.invoiceLine.getChargeTime);		
			if re = null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(methodName &amp; " rate not found for vessel type, using DEFAULT RATE", LogINFO.String);
				endif;
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);		
			endif;																						
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " vessel type not derived, using DEFAULT RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);			
		endif;																							
		if re &lt;&gt; null then																				
			value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);		
		else																							
			value := 0.0;																				
		endif;							
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif service.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(methodName &amp; " Service '" &amp; service.name &amp; "' is a VISIT TYPE RATE", LogINFO.String);
		endif;
		visitType := self.invoiceLine.getMyVisitTypeObject();	
		if visitType &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " found VISIT TYPE" &amp; visitType.code, LogINFO.String);
			endif;
			re := visitType.getVisitTypeServiceTimeRate(self.service, self.invoiceLine.getChargeTime);		
			if re = null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(methodName &amp; " rate not found for visit type, using DEFAULT RATE", LogINFO.String);
				endif;
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);		
			endif;																						
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " visit type not derived, using DEFAULT RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);			
		endif;																							
		if re &lt;&gt; null then																				
			value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);		
		else																							
			value := 0.0;																				
		endif;	
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif service.defaultRateTable = CM_Service.BERTH_RATE_TABLE then	
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(methodName &amp; " Service '" &amp; service.name &amp; "' is a BERTH RATE", LogINFO.String);
		endif;
		berth := self.invoiceLine.getMyBerthObject();	
		if berth &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " found BERTH" &amp; berth.code, LogINFO.String);
			endif;
			re := berth.getBerthServiceTimeRate(self.service, self.invoiceLine.getChargeTime);		
			if re = null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(methodName &amp; " rate not found for berth, using DEFAULT RATE", LogINFO.String);
				endif;
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);		
			endif;																						
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " berth not derived, using DEFAULT RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);			
		endif;																							
		if re &lt;&gt; null then																				
			value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);		
		else																							
			value := 0.0;																				
		endif;		
	else
		if invoiceLine.trackedItem &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " Service '" &amp; service.name &amp; "' is a SHIPPING LINE RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getTradeServiceTimeRate(service, invoiceLine);
			if re = null then
				//Problem! The container is not allowed in this trade!
				//use the default rate table to get a rate
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(methodName &amp; " rate not found for shipping line, using DEFAULT RATE", LogINFO.String);
				endif;
				re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);
			endif;
			if re &lt;&gt; null then
				value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);
			else
				value := 0.0;
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(methodName &amp; " DEFAULT RATE", LogINFO.String);
			endif;
			re := invoiceLine.debtor.getServiceTimeRate(service, invoiceLine.getChargeTime);
			if re &lt;&gt; null then
				value := re.getCostPerUnit(service, invoiceLine, _total, invoiceLine.getChargeTime);
			else
				value := 0.0;
			endif;
		endif;
	endif;

	// 24024 CCMS 1151 Aug 2010 cnwjre1 run user hook code for invoice rate
	//  34489 CCMS 1327 extended to HMS types
	calculationType := self.service.myCalculationType;
	if calculationType &lt;&gt; null and
	   calculationType.myHookCodeRate &lt;&gt; null then
		if calculationType.isVoyageCalcType then
			rateHook := HookType_HMSInvoiceRate;
		else
			rateHook := HookType_InvoiceRate;
		endif;
		valueIn := value;
		valueOut := value;
		if self.invoiceLine &lt;&gt; null then
			if calculationType.isVoyageCalcType then
				trans := self.invoiceLine.myTransactionHMS;
			// TFS 42161
			elseif self.invoiceLine.myTransactionWO &lt;&gt; null then
				trans := self.invoiceLine.myTransactionWO;
			elseif self.invoiceLine.myTransactionEvent &lt;&gt; null then
				trans := self.invoiceLine.myTransactionEvent;
			elseif self.invoiceLine.myTransactionBOL &lt;&gt; null then	//31 Oct 2019	NDL	TFS 47100
				trans := self.invoiceLine.myTransactionBOL;	
			else
				trans := self.invoiceLine.myTransactionTI;
			endif;
		endif;
		if trans &lt;&gt; null then
			// cnwmc5 - 8 Oct 2015 - PAR 36920
			create cmifHook transient;
			cmifHook.myTransaction := trans;
			cmifHook.origRate := valueIn;
			//cmifHook.myInvoiceLine := invLine;
		
			if rateHook = HookType_HMSInvoiceRate then
			//	invLine := self.invoiceLine;
				cmifHook.myInvoiceLine := self.invoiceLine;	//22 Mar 2016	NDL	TFS 1687
				valueOut := app.myHookAgent.runHookLinkPublic(rateHook, calculationType, calculationType, cmifHook).Real;
			else
				valueOut := app.myHookAgent.runHookLinkPublic(rateHook, calculationType, calculationType, cmifHook).Real;
			endif;
			value := valueOut;
		endif;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(methodName &amp; " Rate is " &amp; value.asStringJMT(), LogINFO.String);
	endif;
	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_total" type="Real" usage="io"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="8afd6847-4670-42a8-acbc-6868a1d4b66b">
        <source>getTI() : CM_TrackedItem;

vars

begin
	if self.invoiceLine = null then
		return null;
	endif;
	
	if self.invoiceLine.trackedItem = null then
		return null;
	endif;

	return self.invoiceLine.trackedItem;
	
	return null;


end;
</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForCharge" id="c46c95cf-8ab9-4dd5-9f65-2168022d5658">
        <source>getTaxAmountForCharge() : Real;
// ---------------------------------------------------------------------------
// Created:     September 2010 ANDREW BISHOP
// PAR 25720
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 18 Oct 2024		navlw1			JIRA MTN-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------

vars
	taxRateAmount : Real;
	taxAmount : Real;
	terminal: CM_Terminal;
	blurb: String;
begin
	taxRateAmount := self.getTaxRateForCharge();
	
	taxAmount := (self.total * (taxRateAmount /100));

	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null and terminal.getConfig(InvoiceRoundDownLineTax).Boolean then		// 20/8/18 MAP TFS40270
		if taxAmount &lt; 999999999 then // ### JIRA 35966 08DEC2025 NAVAB1
			blurb := method.qualifiedName &amp; Space &amp; self.invoiceLine.sequenceNum.String &amp; " Tax rounded from " &amp; taxAmount.String;
			taxAmount := taxAmount.Integer;
			app.invLog(blurb &amp; " to " &amp; taxAmount.String, LogINFO.String);
		else
			app.invLog(method.qualifiedName &amp; Space &amp; self.invoiceLine.sequenceNum.String &amp; " NOT ROUND DOWN is TOO LARGE (" &amp; taxAmount.String &amp; ")", LogINFO.String); // ### JIRA 35966 08DEC2025 NAVAB1

		endif;
	endif;

	return taxAmount;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForChargeTen" id="37cf49c5-a053-4feb-9a23-46afcfc4e1e8">
        <source>getTaxAmountForChargeTen() : Decimal;
/*

Purpose:			Return Charge's tax amount in 10 decimal

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2025	navkc1 JIRA EPIC-34131 STORY-34815 GPHA | XML Invoice Export 10DC - Ten Decimal Place Methods

*/

vars
	taxRateAmount		: Real;
	chargeTotal,
	taxAmount			: Decimal[23,10];
	
begin
	
	taxAmount := 0; // Set this so it display 10 decimal 
	
	taxRateAmount := self.getTaxRateForCharge();
	
	chargeTotal := self.getChargeTotalTen();
	
	taxAmount := (chargeTotal * (taxRateAmount/100));
	
	return taxAmount;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForChargeTenStr" id="f4b7f055-e360-4e9f-a06e-41cc0a59f73f">
        <source>getTaxAmountForChargeTenStr() : String;
/*

Purpose:			created for JRW so it displays 10 decimals

Parameters:			

Return Value:		

Date		Who		Reason
