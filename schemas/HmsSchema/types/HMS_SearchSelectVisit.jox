    <JadeMethod name="buildCombosForHarbour" id="30fd69a9-242b-4bb5-990e-f21f618bea29">
        <updating/>
        <source>buildCombosForHarbour() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	harbour:	HMS_Harbour;
	savePilot,
	pilot:		HMS_Pilot;
	saveBerth,
	berth :		HMS_Berth;
	idx: 		Integer;	
begin
	// This method loads all collections into comboboxes
	harbour := self.myTerminal.myHarbour;
	savePilot := self.cbxPilot.listObject.HMS_Pilot;
	self.cbxPilot.clear();
	saveBerth := self.cbxBerth.listObject.HMS_Berth;	
	self.cbxBerth.clear();	
	
  	// Load Pilots
  	// Add blank selection as first entry
  	self.cbxPilot.addItem(" N/A");
	// Add blank selection as first entry
  	self.cbxBerth.addItem(" N/A");  	
  	
  	if harbour &lt;&gt; null then
	  	foreach berth in harbour.allBerths do
	  		cbxBerth.addItem(berth.description);
	  		cbxBerth.itemObject[cbxBerth.newIndex] := berth;
	  	endforeach;
	  	foreach pilot in harbour.allPilots do
	  		cbxPilot.addItem(pilot.description);
	  		cbxPilot.itemObject[cbxPilot.newIndex] := pilot;
	  	endforeach;
	endif;
	
	if saveBerth &lt;&gt; null then
		idx := self.cbxBerth.findObject(saveBerth);
	endif;
	if idx &lt; 1 then
		idx := 1;
	endif;	
  	self.cbxBerth.listIndex := idx;
  	self.cbxBerth.text := self.cbxBerth.itemText[self.cbxBerth.listIndex];

	if savePilot &lt;&gt; null then
		idx := self.cbxPilot.findObject(savePilot);  	
	endif;
	if idx &lt; 1 then
		idx := 1;
	endif;
  	self.cbxPilot.listIndex := idx;
  	self.cbxPilot.text := self.cbxPilot.itemText[self.cbxPilot.listIndex];	  	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildMatchingVoyagesListMod" id="147942c2-04ef-4363-98b7-e70f95b6d23a">
        <updating/>
        <source>buildMatchingVoyagesListMod():Boolean updating, protected;

// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars

	searcher			: CMIF_HMSVoyageSearcher;
	voyage				: CM_Voyage;
	outputStr			: String;
	searchStartDTLocal		: TimeStamp;
	searchFinishDTLocal		: TimeStamp;
	searchStartDTSystem		: TimeStamp;
	searchFinishDTSystem	: TimeStamp;
	idx					: Integer;
	tmpHarbour			: HMS_Harbour;
begin

	self.tblMatchesFound.rows	:= self.tblMatchesFound.fixedRows;
	
	tmpHarbour := self.myAssistant.HMS_Assistant.myHarbour;
	if tmpHarbour = null then
		return false;
	endif;
 	// This method builds a list of voyages that match the target selection criteria
	create searcher transient;
 	// Get selection criteria
 	searcher.mySelectedShip			:= self.cbxShipName.itemObject[cbxShipName.listIndex].CM_Vessel;
 	searcher.mySelectedShipType		:= self.cbxShipType.itemObject[cbxShipType.listIndex].HMS_VesselType;
 	searcher.mySelectedShipLinesCo	:= self.cbxShipLineCo.itemObject[cbxShipLineCo.listIndex].CM_ShippingLine;
 	searcher.mySelectedPilot		:= self.cbxPilot.itemObject[cbxPilot.listIndex].HMS_Pilot;
 	searcher.mySelectedAgent		:= self.cbxAgent.itemObject[cbxAgent.listIndex].CM_ShippingAgent;
 	searcher.mySelectedBerth		:= self.cbxBerth.itemObject[cbxBerth.listIndex].HMS_Berth;

 	// Get search start and end date
 	if optArrvAfter.value then
 		searchStartDTLocal.setDate(self.txtDateVoyAfter.getDate()); 
 		searchStartDTLocal.setTime(self.txtTimeVoyAfter.getTime());
		searchStartDTSystem := self.localToSystemTime(searchStartDTLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		searchFinishDTSystem		:=  searchStartDTSystem.cnEcAddYears(1);
	elseif optArrvBefore.value then
		searchFinishDTLocal.setDate(self.txtDateVoyBefore.getDate()); 
		searchFinishDTLocal.setTime(self.txtTimeVoyBefore.getTime());
		searchFinishDTSystem := self.localToSystemTime(searchFinishDTLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		searchStartDTSystem		:= searchFinishDTSystem.cnEcAddYears(-1);
	else
		searchStartDTLocal.setDate(self.txtDateBtwA.getDate()); 
		searchStartDTLocal.setTime(self.txtTimeBtwA.getTime());
		searchStartDTSystem		:= self.localToSystemTime(searchStartDTLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		searchFinishDTLocal.setDate(self.txtDateBtwB.getDate()); 
		searchFinishDTLocal.setTime(self.txtTimeBtwB.getTime());
		searchFinishDTSystem := self.localToSystemTime(searchFinishDTLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	searcher.searchStartDT 	:= searchStartDTSystem;
	searcher.searchFinishDT	:= searchFinishDTSystem;

	searcher.allVoyagesFound.clear();
	searcher.exportsArray.clear();
		
	tmpHarbour.getMatchingVoyagesMovements(searcher, app.myPassport);
	
	foreach voyage in searcher.allVoyagesFound do
		outputStr := voyage.getAttributeStringForDefArray(self.tblMatchesFound.allTblDataEntRows);
		idx := self.tblMatchesFound.addItem(outputStr);
		self.tblMatchesFound.accessRow(idx).itemObject	:= voyage;		
	endforeach;

	self.tblMatchesFound.colourRows(self.colorRow1, self.colorRow2);
	self.exportArray.clear();
	searcher.exportsArray.copy(self.exportArray);

 	// Select first voyage in table if there is one
 	if self.tblMatchesFound.rows &gt; self.tblMatchesFound.fixedRows then
 		self.tblMatchesFound.column	:= 1;
 		self.highlightCurrentVoyage();
 		return true; // ie.  matches were found
 	else
 		// No voyages found
 		app.msgBox(app.getErrorString(HMS_No_Matches_Found), app.getErrorString(Search_Select_Visit_No_Match), MsgBox_OK_Only + MsgBox_Stop_Icon);
 		return false; // ie. NO matches were found
 	endif;

epilog
	delete searcher;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeViewRange" id="71ff4c67-be1d-41be-b674-eb17d7da9b12">
        <updating/>
        <source>changeViewRange(_targetVoyage: CM_Voyage; _preserveRange: Boolean) : Boolean updating;

vars
	//msgBoxType:		Integer;
	//msgString:		String;
	viewStartDT:	TimeStamp;
	viewFinishDT:	TimeStamp;
begin

	// Determine start and finish dates for view
	if _preserveRange then
		viewStartDT		:= self.myViewController.viewStartDT;
		viewFinishDT	:= self.myViewController.viewFinishDT;
	else
//		viewStartDT:=((_targetVoyage.arrivedDT.Date-2).date.String &amp; ", 00:00:00").TimeStamp;
//		viewFinishDT:=((viewStartDT.Date+7).date.String &amp; ", 00:00:00").TimeStamp;
		
		viewStartDT.setDate(_targetVoyage.arrivedDT.date-2);
		viewStartDT.setTime(null);
		viewFinishDT.setDate(viewStartDT.date+7);
		viewFinishDT.setTime(null);
	endif;

	return self.myViewController.changeViewRange(viewStartDT, viewFinishDT, null);
	
end;</source>
        <Parameter name="_targetVoyage" type="CM_Voyage"/>
        <Parameter name="_preserveRange" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
