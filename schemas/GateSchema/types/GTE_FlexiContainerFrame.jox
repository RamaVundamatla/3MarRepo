    <JadeMethod name="enableDoorsDirBtn" id="8c7d80e3-7c06-49dd-9d5f-fdfafc0c67fa">
        <updating/>
        <source>enableDoorsDirBtn(_show : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwas3	Initial creation

*/

begin

	self.myFlexiDoorsDirBtn.enabled := _show;

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDoorsDir" id="f1937cb4-3ed6-4410-9bd3-9cd1695bed45">
        <source>getDoorsDir() : Integer;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.hasDoors) or
	   (not self.myFlexiTruckLayoutFrame.myDoorsCheckBox.value) then
		return TI_DOORSDIRN_NULL;
	endif;

	if self.myFlexiDoorsDirBtn.doorsRight then
		return TI_DOORSDIRN_AFT;
	else
		return TI_DOORSDIRN_FWD;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideDoorsDirBtn" id="e6162b64-a564-4394-b0bf-3c9f3a92c6c8">
        <source>hideDoorsDirBtn();
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myFlexiDoorsDirBtn.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="paint" id="76677cd4-9970-4f0a-b798-007e0c6141c2">
        <updating/>
        <source>paint(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame);

	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.isBuilt := true;
		self.buildSelf;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="positionDoorsDirBtn" id="b8a6d292-20d5-425d-b7b3-b720318fe918">
        <source>positionDoorsDirBtn() protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myFlexiDoorsDirBtn.setWidth(self.clientWidth);
	self.myFlexiDoorsDirBtn.left := (self.clientWidth - self.myFlexiDoorsDirBtn.width) / 2;

end;</source>
        <access>protected</access>
    </JadeMethod>
