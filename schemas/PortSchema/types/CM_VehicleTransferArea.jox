epilog

end;</source>
        <Parameter name="_numGateLanes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0f9d9530-729e-4b29-a224-4159e12eb6e3">
        <updating/>
        <source>setProxy(	_id,
		 	_comment : String; 
		 	_type : Integer;
		 	_maxCapacity : Integer;
			_rel : Boolean;
			_term : CM_Terminal;
		 	_autoRestrictionEnabled,
		 	_stockControlled, 
		 	_autoPlanEnabled,
			_hideFromOverView,
			_isDualGate : Boolean;
		 	_numGateLanes : Integer;
			_allInterchangeAreas	:CM_InterchangeAreaArray; // par 24292
			_defaultInterchangeArea: CM_InterchangeArea) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx
26/05/2010		cnwcs5		par 24292 - change _allInterchangeAreas parameter to array
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.setProxyTerminalArea(_id, _comment, _type, _rel, _term, _autoRestrictionEnabled, _stockControlled,_hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	self.setMaxCapacity(_maxCapacity);
	self.setIsDualGate(_isDualGate);
	self.setNumGateLanes(_numGateLanes);
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_maxCapacity" type="Integer"/>
        <Parameter name="_rel" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_autoPlanEnabled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_isDualGate" type="Boolean"/>
        <Parameter name="_numGateLanes" type="Integer"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="updateId" id="514459ac-aba1-43ef-9715-c8e16a4eff79">
        <updating/>
        <source>updateId(_value :String)updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 October 2009 by cnwcs5:1
// Purpose:     Par 21404 - gate conversion issues  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	isDefault, isWarehouse	:Boolean;
	old_ID, new_ID			:String;
	job						:CM_Job;
begin
	if _value = self.id then
		return;	// nothing to do
	endif;
	
	old_ID		:= self.id;
	isDefault 	:= (old_ID = self.myTerminal.getConfig(DefRoadOpsArea).String);
	isWarehouse := (old_ID = self.myTerminal.getConfig(DefWarehouseArea).String);	

	inheritMethod(_value);

	new_ID := self.id;

	if isDefault then
		// update config setting
		self.myTerminal.setConfig(DefRoadOpsArea, new_ID);
	endif;
	
	if isWarehouse then
		// update config setting
		self.myTerminal.setConfig(DefWarehouseArea, new_ID);
	endif;
	
	// any road jobs with the old_ID on them need to be updated with the new_ID
	foreach job in self.myTerminal.myRoadJobSheet.allJobsByOrder do
		if job.CM_RoadJob.roadTransAreaId &lt;&gt; old_ID then
			continue;
		endif;
		
		job.setPropertyValue (CM_RoadJob::roadTransAreaId.name, new_ID);
	endforeach;
	
	// vehicle visit records have a roadTransAreaId property but this is not used post 7.7.3
	// also as at 17/02/2010 - it is not used for anything except when the road job is created
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="44f6f8ed-3712-4a9e-9420-934dd8a23f78">
        <source>validateForDelete();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 11 July 2007
//
//----------------------------------------------------------------------

vars

begin
	//This is created when a terminal is created and should never be deleted.
	if self.id = 'VTA' then
		app.raiseCMException(Canno_delet_this_item_base_dat, null, null);
	endif;
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
</Class>
