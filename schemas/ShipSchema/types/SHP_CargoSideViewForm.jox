    <JadeMethod name="addToolbarControls" id="f9bd04d3-7721-413c-b0ce-d73dfbdfcbef">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		    Who			Reason
21 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
26 July 2012	cnwcs5		par 29124
*/

vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnViewActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewProposed, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewExport, CMUI_Toolbar.Control_Alignment_Left); // PAR 31073
	toolbar.addButton(self.btnViewLoad, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBActualSub, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); // PAR 29466
	toolbar.addFrame(self.frmTBScale, CMUI_Toolbar.Control_Alignment_Left); // PAR 29466 move to here so that it does not get hidden if the tool bar button have captions on

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCCPalette, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeDisch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeDLR, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeSOB, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeErase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSummarise, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addFrame(self.frmTBScale, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefesh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeselect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawRemarks, CMUI_Toolbar.Control_Alignment_Left);	// par 29125 July 2012

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCCModeDLR_click" id="405a158b-95b6-496b-bc58-0d74dcb99134">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCCModeDLR_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
05 September 2011	cnwab1	Initial creation
*/

vars

begin
	self.myROROPlanningForm.updateSlotRequestAttribDLRSoB(DLR_MOVETYPE);
	self.doDeselectAll();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
