    <JadeMethod name="setLogDocketAutoMatch" id="6746545c-f9bb-4150-a1b3-d05641e12451">
        <source>setLogDocketAutoMatch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2016	cnwma1	Initial creation  TFS #2707:C3 - Docket Reconciliation

*/

vars
	term : CM_Terminal;
begin

	if self.hasScriptBeenRunAtAll(method.name,null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Setting Log Docket Auto Match Tickets Config Option", LogINFO);
	
	foreach term in CM_Terminal.instances do	
