    </JadeMethod>
    <JadeMethod name="doTblDataDragTrackedItem" id="1dacaf9b-15d5-4bb4-a1ba-82ce1cac01c5">
        <updating/>
        <source>doTblDataDragTrackedItem(_tbl : CM_DataTable) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 July 2007
//
//----------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	pic		: Picture;
	tbl	: CM_DataTable;
begin
	tbl :=  _tbl;
	if self.myCurrentWLE &lt;&gt; null and
	   self.myCurrentWLE.isKindOf(CM_WorkListEntry) then
	   theTI := self.myCurrentWLE.myTrackedItem;
	else
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI, tbl);
	tbl.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		tbl.dragCursor := pic.picture;
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraInfo" id="f9650dbd-ea94-4c30-bba1-082a8713556c">
        <updating/>
        <source>doTblExtraInfo(_obj : Object) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 09 August 2007
//
//----------------------------------------------------------------------

vars
	dataContainer	: CM_DataContainer;
	
begin
	// DISPLAY INFO
	self.tblExtraInfo.rows := 0;
	self.tblExtraInfo.userObject := null;
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	dataContainer.displayMode := DISPLAY_MODE_ACTUAL;
	
	if _obj.isKindOf(CM_WorkListEntry) then
		_obj.CM_WorkListEntry.getExtraInfo(dataContainer);
	else
		return;
	endif;
	
	self.tblExtraInfo.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblExtraInfo, false,false, 4, 1, 4, 1, 1);
	self.doResizeColumnWidths(self.tblExtraInfo, true);
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doTurnaroundAsRelease" id="0ae47365-ee45-43d4-88ef-c8881fd9a4a5">
        <updating/>
        <source>doTurnaroundAsRelease() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	proxyWLE	: CM_WorkListEntry;
	result		: Integer;
begin
	
	//Be sure the current one is a RECEIPT
	if self.myCurrentWLE = null then
		return;
	endif;
	
	self.myCurrentWLE.fetchLatest();
	
	mousePointer := MousePointer_HourGlass;

	proxyWLE := app.createUpdateProxy(self.myCurrentWLE).CM_WorkListEntry;
	
	while true do
		app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null,  app.myPassport);// cnwrd1 par 22624 3.5.2010
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Turn Around as Release',
												 app.myPassport, 
												 ErrWarnMode_AddUpdate + 
												 ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// copies errors to this form and shows in err/warnings window			
			self.setAllErrorWarnings(app.myPassport);	
		endif;
		break;
	endwhile;	

epilog
	delete proxyWLE;
	mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="3a8c82f1-d314-46d8-9122-b39d6f7c564e">
        <updating/>
        <source>doUnassignTI() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	wleSet.add(self.myCurrentWLE);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnassignTrailer" id="a12a5b61-c073-4f59-bb21-1ecf7260b06b">
        <updating/>
        <source>doUnassignTrailer(_wle : CM_WorkListEntry) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 June 2007
//
//----------------------------------------------------------------------
vars
	wleSet : CM_WLESet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if _wle = null then
		return;
	endif;
	
	if _wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	wleSet.add(_wle);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
