<Class name="SOPTM_HMS_PathSegment" id="b3383266-f236-4fa4-96fd-28079627edd4">
    <superclass name="SOPTM_HMS"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="8412ab3f-657a-4a61-896c-d3eb43a930e8">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_PathSegment;
	self.permissionView	 := PmHMSPathView;
	self.permissionMaint := PmHMSPathMaint;
	self.myDataClass := HMS_PathSegment;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="8bf913fa-e74b-4c51-a5ee-d40491c01351">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyPathSegment	: HMS_PathSegment;
	theForm : SOP_HMS_TableMaintForm;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_PathSegment transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyPathSegment := theForm.myProxyObject.HMS_PathSegment;
	theForm.tblInput1.setObjectFromTable(pxyPathSegment, null, false);

	// R Barr #12855 Harbour no longer relevant, parent is root
//	pxyPathSegment.setProxy(app.myRoot, theForm.cmbHarbour.listObject.HMS_Harbour);
	pxyPathSegment.setProxy(app.myRoot, null);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyPathSegment, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyPathSegment, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="b0dda023-47f5-4591-9b77-f89ad227656c">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return app.myRoot.allPathSegments;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getDefNameTblInput" id="0eb44aac-4f4d-4dbd-b955-57fb3c2ec8c8">
        <source>getDefNameTblInput(): String protected;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return ETDef_HMSPathSegment;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="bcec0dae-9a0d-4008-8284-f2d56ae4863d">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------
// Created:	05 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	defName	: String;
	theForm : SOP_HMS_TableMaintForm;
	
begin
    theForm	:=	self.myForm.SOP_HMS_TableMaintForm;
	theForm.useProxyObject	:=	true;
	theForm.setTblDataEntRows(ETDef_HMSTblDataPathSeg);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	theForm.shtTblInput1.caption	:=	'Details';
	
	defName	:=	self.getDefNameTblInput();
	
	if defName = null then //saftey net
		defName	:=	ETDef_HMSTblInput;
	endif;
	
	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible	:=	true;
	theForm.myAssistant.comboBoxHMSRegion(theForm.cmbRegionFrom, theForm.myHarbour, null);
	theForm.myAssistant.comboBoxHMSRegion(theForm.cmbRegionTo, theForm.myHarbour, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2d4dc9eb-2307-4d6b-b6cb-2e141c180b83">
        <updating/>
        <source>showThumbnail(pObj: HMS_PathSegment) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	assist : CMUI_Assistant;
	tmpCombo : CMUI_ComboBox;
	harbour : HMS_Harbour;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);
	
	// cnwdad1 04/03/2008 - PAR #15777.

	assist := theForm.myAssistant;
	tmpCombo := theForm.cmbRegionFrom;
	assist.comboBoxHMSRegion(tmpCombo, harbour, pObj.myRegionFrom);	
	tmpCombo.lostFocus(tmpCombo);

	tmpCombo := theForm.cmbRegionTo;		
	assist.comboBoxHMSRegion(tmpCombo, harbour, pObj.myRegionTo);				
	tmpCombo.lostFocus(tmpCombo);

end;</source>
        <Parameter name="pObj" type="HMS_PathSegment"/>
    </JadeMethod>
</Class>
