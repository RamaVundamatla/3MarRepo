    <JadeMethod name="create" id="be561caf-870f-40f2-bee5-0980fe0a48ff">
        <updating/>
        <source>create() updating;
// TFS 8390
vars
	specialStow 		: CM_QStringIsOneOf;
begin

	if self.isTransient then	
		return;
	endif;

	create specialStow as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(specialStow);
end;</source>
    </JadeMethod>
