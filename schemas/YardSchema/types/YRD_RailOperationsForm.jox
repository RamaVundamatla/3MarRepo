    <JadeMethod name="doTblWorkEntriesContextMnu" id="ee3ac663-1e3b-4f4d-9df8-03d2ce618253">
        <updating/>
        <source>doTblWorkEntriesContextMnu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//07 September 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 12 July 2022 navrk21 TFS ChangeRequest 53913: MTN - Rail Operations Inspect Object
vars
	train : CM_Train;
	wle : CM_YardWLE;
	user : CM_User;
begin
	
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.isKindOf(CM_YardWLE) then
		wle := self.myCurrentWLE.CM_YardWLE;
		if wle.job &lt;&gt; null and wle.job.isKindOf(CM_RailJob) then
			train := self.myCurrentWLE.CM_YardWLE.job.CM_RailJob.getMyTrain();
		endif;
	endif;
	
	self.mnuInspectWLE1.visible := app.isAllowedToInspect();  // 12.07.2022 navrk21 TFS 53913
	self.mnuInspectTI1.visible := app.isAllowedToInspect();	  // 12.07.2022 navrk21 TFS 53913
	self.mnuInspectJob1.visible := app.isAllowedToInspect();  // 12.07.2022 navrk21 TFS 53913
	user := app.getMyUser;
	
	if user.canDo(self.myTerminal, PmSealCheckType) then
		self.mnuRecSealCheck.visible := true;
		self.mnuRelSealCheck.visible := true;
		if train &lt;&gt; null then
			self.mnuRecSealCheck.caption := app.getString(Receiva_seal_check_type);
			self.mnuRelSealCheck.caption := app.getString(Release_seal_check_type);
			//+cnwml2 PAR25874 DCT CCMS 1131
			self.mnuRecSealCheck.caption := self.mnuRecSealCheck.caption &amp; " (" &amp; train.code &amp; ")";
			self.mnuRelSealCheck.caption := self.mnuRelSealCheck.caption &amp; " (" &amp; train.code &amp; ")";
	
			self.mnuRecSCDefault.checked := train.sealCheckReceival = SEAL_CHECK_DEFAULT;
			self.mnuRecSCFull.checked :=train.sealCheckReceival = SEAL_CHECK_FULL;
			self.mnuRecSCStrict.checked := train.sealCheckReceival = SEAL_CHECK_STRICT;
			self.mnuRecSCView.checked :=  train.sealCheckReceival = SEAL_CHECK_VIEW;
			self.mnuRecSCNone.checked :=  train.sealCheckReceival = SEAL_CHECK_NONE;				
			self.mnuRelSCDefault.checked := train.sealCheckRelease = SEAL_CHECK_DEFAULT ;
			self.mnuRelSCFull.checked := train.sealCheckRelease = SEAL_CHECK_FULL;
			self.mnuRelSCStrict.checked := train.sealCheckRelease = SEAL_CHECK_STRICT;
			self.mnuRelSCView.checked := train.sealCheckReceival = SEAL_CHECK_VIEW;
			self.mnuRelSCNone.checked := train.sealCheckReceival = SEAL_CHECK_NONE;
		else
			self.mnuRecSealCheck.visible := false;
			self.mnuRelSealCheck.visible := false;
		endif;
	else
		self.mnuRecSealCheck.visible := false;
		self.mnuRelSealCheck.visible := false;
	endif;
	return inheritMethod(cntrl, conwin, mouse, x, y);
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
