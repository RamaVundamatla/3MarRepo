    <JadeMethod name="utlUpdateDoorDirectionRule" id="d58fe973-76b9-436b-88ea-b68370c44d21">
        <source>utlUpdateDoorDirectionRule(_pxyDDRule : CM_DoorDirectionRule; _lcSet : CM_LCSet input; _passport : CM_Passport input);

// Created by cnwdvb1 on 16 August 2007
// 03/03/2011 cnwcs5 CCMS CPO 2027/PAR 27126 - audit location changes
vars

	rule 				: CM_DoorDirectionRule;
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();
	
	_pxyDDRule.pxyGetRealObjectAndEdition(rule, expectedEdition);

	if rule = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DoorDirectionRule.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(rule);
	
	if rule.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Door Direction Rule', null, null);
		return;
	endif;
	
	rule.setForUpdate(_pxyDDRule, _lcSet);

	if _passport.noErrors then
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of TA with audit that includes locations changes
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (rule.myTerminalArea, 
											_lcSet,CM_AuditTALocations.LocnTypeUpdate_DoorDirRules, 
											AuditUpdated, rule.getAuditTALocationDetails);
	endif;
end;</source>
