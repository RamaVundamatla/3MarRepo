    <JadeMethod name="doFindCargoButton" id="21a21103-a30a-4c28-88ed-644cb41ad8a6">
        <updating/>
        <source>doFindCargoButton( _cargoIdStr : String; _returnTi : CM_TrackedItem )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	cargoIdStr : String;
	ti : CM_TrackedItem;
	theTI : CM_TrackedItem;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	value : Real;
	index : Integer;
	obj : Object;
	scroll : VScroll;
	templateBtn : MOB_Button;
	size : Integer;
	frame : MOB_Frame;
	sheet : MOB_Sheet;

begin

	cargoIdStr := _cargoIdStr;
	if cargoIdStr = null and _returnTi = null then
		return;
	endif;
	
	if cargoIdStr = self.lblCargoId.caption.trimBlanks.toUpper then
		return;
	endif;
	
	size := self.compTempButtonCount;
	if size &gt; 0 then
		foreach buttonNumber in 1 to size do
			menuButton := self.btnToCompTemp.getControl(buttonNumber);
			if menuButton = null then	
				continue;
			endif;
			obj := menuButton.userObject;
			if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				if _returnTi &lt;&gt; null then
					if _returnTi = obj then
						theTI := ti;
						scroll := self.scrToComplete;
						templateBtn := self.btnToCompTemp;
						frame := self.frmToComplete;
						sheet := self.shtToComplete;
						break;
					endif;
				else
					if ti.id = cargoIdStr or ti.alternativeId = cargoIdStr then
						theTI := ti;
						scroll := self.scrToComplete;
						templateBtn := self.btnToCompTemp;
						frame := self.frmToComplete;
						sheet := self.shtToComplete;
						break;
					endif;
				endif;
			endif;
			if menuButton &lt;&gt; null then
				value := value + menuButton.height;
			endif;
		endforeach;
	endif;
	
	if theTI = null and _returnTi &lt;&gt; null then
		size := self.storedButtonCount;
		value := 0;
		if size &gt; 0 then
			//find the passed in tracked item
			foreach buttonNumber in 1 to size do
				menuButton := self.btnStoredTemp.getControl(buttonNumber);
				if menuButton = null then	
					continue;
				endif;
				obj := menuButton.userObject;
				if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
					ti := obj.CM_TrackedItem;
					if _returnTi &lt;&gt; null then
						if _returnTi = obj then
							theTI := ti;
							scroll := self.scrStored;
							templateBtn := self.btnStoredTemp;
							frame := self.frmStored;
							sheet := self.shtStored;
							break;
						endif;
					endif;
				endif;
				if menuButton &lt;&gt; null then
					value := value + menuButton.height;
				endif;
			endforeach;
			// It might have been ( zombied ) merged, find its new parent by its id.
			if theTI = null then
				cargoIdStr := _returnTi.id;
				value := 0;
				foreach buttonNumber in 1 to size do
					menuButton := self.btnStoredTemp.getControl(buttonNumber);
					if menuButton = null then	
						continue;
					endif;
					obj := menuButton.userObject;
					if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
						ti := obj.CM_TrackedItem;
						if ti.id = cargoIdStr or ti.alternativeId = cargoIdStr then
							theTI := ti;
							scroll := self.scrStored;
							templateBtn := self.btnStoredTemp;
							frame := self.frmStored;
							sheet := self.shtStored;
							break;
						endif;
					endif;
					if menuButton &lt;&gt; null then
						value := value + menuButton.height;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	if theTI &lt;&gt; null then
		self.fldStripped.topSheet := sheet;
		scroll.value := value.Integer;
		menuButton := templateBtn.getControl(buttonNumber);
		self.setMenuScrollStart( scroll, templateBtn, frame, size );
		menuButton.setFocus();
	endif;

epilog

end;</source>
        <Parameter name="_cargoIdStr" type="String"/>
        <Parameter name="_returnTi" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="6e96fa4a-8a8b-4897-959a-6dd847f4ebf7">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	//Left hand side
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	cWidth := ( stdWidth / 2 );
	cHeight := stdHeight * 2;
	tabIndex := 4000;
	
	if _initialSetup then
		self.lblBookings.setAndIncrementTabIndex( tabIndex );
		self.lblBookings.visible := true;
	endif;
	self.lblBookings.move( 	cLeft,
							cTop,
							stdWidth,
							cHeight );
							
	cTop := cTop + self.lblBookings.height + self.resizedMargin;
	if _initialSetup then
		self.cmbSourceLoc.setAndIncrementTabIndex( tabIndex );
		self.cmbSourceLoc.visible := true;
	endif;
	self.cmbSourceLoc.move( 	self.resizedMargin,
							cTop,
							cWidth,
							stdHeight );
							
	cTop := cTop + self.cmbSourceLoc.height + self.resizedMargin;
	if _initialSetup then
		self.txtTargetLoc.setAndIncrementTabIndex( tabIndex );
		self.txtTargetLoc.visible := true;
	endif;
	self.txtTargetLoc.move( 	self.resizedMargin,
								cTop,
								stdWidth,
								stdHeight );
							
	cTop := cTop + self.txtTargetLoc.height + (self.resizedMargin * 2);
	cHeight := ( self.clientHeight - cTop - self.getCMDButtonsHeight() - ( self.resizedMargin * 2 ) );					 
	//03 Mar 2017	NDL	TFS 3299
	if not self.docActsToDisplay.isEmpty then
		cHeight := cHeight - ( self.btnOne.height + self.resizedMargin);
		self.btnDocActions.visible := true;
	else
		self.btnDocActions.visible := false;
	endif;
	
	
	if _initialSetup then
		self.fldStripped.setAndIncrementTabIndex( tabIndex );
		self.fldStripped.visible := true;
	endif;
	self.fldStripped.move(	cLeft, 
							cTop, 
							stdWidth, 
							cHeight);
	
	//03 Mar 2017	NDL	TFS 3299
	if self.btnDocActions.visible then
		cTop := cTop + self.fldStripped.height + self.resizedMargin;
		self.btnDocActions.move(	self.resizedMargin, 
									cTop, 
									self.btnOne.width, 
									self.btnOne.height);
	endif;
							
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
		self.txtCargoId.parent := self.shtToComplete;
	endif;
	self.txtCargoId.move(	1,
							1,
							self.shtToComplete.width - self.resizedMargin,
							stdHeight
							);
							
	cTop := self.txtCargoId.top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.frmToComplete.setAndIncrementTabIndex( tabIndex );
		self.frmToComplete.visible := true;
	endif;
	self.frmToComplete.move(	1, 
								cTop, 
								shtToComplete.width - 2, 
								shtToComplete.height - cTop);
								
	self.lblNoToComplete.move(	1, 
								1, 
								shtToComplete.width - 2, 
								stdHeight);
								
	if _initialSetup then
		self.frmStored.setAndIncrementTabIndex( tabIndex );
		self.frmStored.visible := true;
	endif;
	self.frmStored.move(	1, 
							1, 
							shtStored.width - 2, 
							shtStored.height - 2);
							
	self.lblNoStored.move(	1, 
							1, 
							shtStored.width - 2, 
							stdHeight);
	
	//Right hand side
	cTop := self.cmbSourceLoc.top;
	cLeft := self.cmbSourceLoc.left + self.cmbSourceLoc.width + self.resizedMargin;
	
	if _initialSetup then
		self.cmbSortBy.setAndIncrementTabIndex( tabIndex );
		self.cmbSortBy.visible := true;
	endif;
	self.cmbSortBy.move( 	cLeft,
							cTop,
							cWidth,
							stdHeight );
							
						
							
	// resize the buttons and scroll bar
	self.resizeAllScrollButtons(); 

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="44dd9c47-8d05-40b3-ac7a-32d1af98d325">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	if self.txtTargetLoc.userObject &lt;&gt; null then
		tmpFoundLC := self.txtTargetLoc.userObject.CM_LocationsController;
	endif;
	
	dataString := self.txtTargetLoc.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblTargetLoc.caption.toUpper then
		self.txtTargetLoc.text := lblTargetLoc.caption.toUpper;
		self.txtTargetLoc.userObject := null;
		tmpFoundLC := null;
		return;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	term.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
	
	if tmpFoundLC &lt;&gt; null then
		self.txtTargetLoc.text := tmpFoundLC.getFullId;
		self.txtTargetLoc.userObject := tmpFoundLC;
		
	else
		errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		self.txtTargetLoc.text := lblTargetLoc.caption.toUpper;
		self.txtTargetLoc.userObject := null;
		tmpFoundLC := null;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtTargetLoc.setFocus();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
