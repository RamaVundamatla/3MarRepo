    <JadeMethod name="getDataClass" id="ff867226-289f-4177-8368-ad9fda2844cb">
        <source>getDataClass(pValue : Any) : Class protected;

vars
	theClass	: Class;
	
begin

	if pValue.isKindOf(Binary) then
		theClass := CM_StateBinary;
	elseif pValue.isKindOf(Decimal) then
		theClass := CM_StateDecimal;
	elseif pValue.isKindOf(Integer) then
		theClass := CM_StateInteger;
	elseif pValue.isKindOf(Real) then
		theClass := CM_StateReal;
	elseif pValue.isKindOf(CM_Object) then
		theClass := CM_StateReference;
	elseif pValue.isKindOf(Sound) then
		theClass := CM_StateSound;
	elseif pValue.isKindOf(DateArray) then	//19 Jun 2020	NDL	TFS 49569
		theClass := CM_StateDateArray;
	elseif pValue.isKindOf(Collection) or pValue.isKindOf(Set) then	// 14 May 2021 navmd1 TFS 51191
		theClass := CM_StateCollection;
	elseif pValue.isKindOf(StringArrayStateData) then
	//	theClass := CM_StateStringArray;
	else
		// set to "String" - the default
		theClass := CM_StateString;
	endif;
	
	return theClass;
	
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getStateData" id="b14e1062-273b-45e4-b52a-49030db8fc81">
        <source>getStateData(_key : String) : Any;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	data	: CM_StateData;
begin
	data := self.allStateData[_key];

	if data &lt;&gt; null then
		return data.getValue();
	else
		return null;
	endif;
	
end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="hasStateDataRefToObj" id="38e4ae9f-d0c5-4c49-8b60-d4708b03548c">
        <source>hasStateDataRefToObj( _obj : Object; _key : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

	stateData : CM_StateData;
	any : Any;
	edition : Integer;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, stateData, invalid );
	
	foreach stateData in self.allStateData discreteLock do
		if stateData = null then
			continue;
		endif;
		edition := stateData.edition;
		if invalid then
			invalid := false;
			continue;
		endif;
		any := stateData.getValue();
		if any = null then
			continue;
		endif;
		if any.isKindOf( Object ) then
			if any.Object = _obj then
				_key := stateData.key;
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_key" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5784832b-cb53-42ec-99d0-5b3f8cf1ef24">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	stateObjectProxy	: CM_StateObject;
	stateData,
	stateDataProxy		: CM_StateData;
	completedOK		: Boolean;
	
begin

	stateObjectProxy := inheritMethod();
	
	foreach stateData in self.allStateData do
		stateDataProxy := stateData.pxyCreateUpdateProxy();
		stateDataProxy.setMyStateObject(stateObjectProxy);	// adds into allStateData collection
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return stateObjectProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete stateObjectProxy;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b8e1a289-0220-46c4-957a-82c99caf0c60">
        <updating/>
        <source>setForCreate(pProxy : CM_StateObject) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyStateData,
	realStateData	: CM_StateData;
	
begin

	pProxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	foreach proxyStateData in pProxy.allStateData do
		realStateData := proxyStateData.cloneSelf(false);
		realStateData.setMyStateObject(self);
	endforeach;
	
end;</source>
        <Parameter name="pProxy" type="CM_StateObject"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7b94e79d-aad2-4bdf-8102-c0367f984748">
        <updating/>
        <source>setForUpdate(pProxy : CM_StateObject; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyStateData,
	realStateData	: CM_StateData;
	originalEdition	: Integer;
	
begin

	pProxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	foreach proxyStateData in pProxy.allStateData do
		proxyStateData.pxyGetRealObjectAndEdition(realStateData, originalEdition);
		if realStateData &lt;&gt; null then
			exclusiveLock(realStateData);
			if realStateData.edition &lt;&gt; originalEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'configuration details', null, null);
				return false;
			endif;
			if realStateData.class &lt;&gt; proxyStateData.class then
				delete realStateData;
				realStateData := null;
			endif;
		else
			realStateData := self.allStateData[proxyStateData.key];
			if realStateData &lt;&gt; null then
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  &gt;&gt; realObject found with no proxy');
			endif;
		endif;
		
		if realStateData &lt;&gt; null then
			realStateData.setValue(proxyStateData.getValue);
		else
			realStateData := proxyStateData.cloneSelf(false);
			realStateData.setMyStateObject(self);
		endif;
	endforeach;
	
epilog
	return _passport.noErrors;
	
end;</source>
        <Parameter name="pProxy" type="CM_StateObject"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setStateData" id="8a51932f-6037-429a-8248-22c3745ec3ff">
        <source>setStateData(pKey : String; pValue : Any; pCreateIfNotPresent : Boolean);

// Assumes that we are in transaction state

vars
	data		: CM_StateData;
	theClass	: Class;
	needCommit	: Boolean;
	
begin
	data := self.allStateData[pKey];

	if data &lt;&gt; null then
		theClass := self.getDataClass(pValue);
		
		if data.class &lt;&gt; theClass then
			// need to delete and re-add
			delete data;
			data := null;
		endif;
	endif;
	
	if data = null then
		if pValue = null then
			// no need to store null as the get will return null in this case
			return;
		endif;

		if (not pCreateIfNotPresent) then
			return;
		endif;
		
		theClass := self.getDataClass(pValue);

		if self.isTransient then
			create data as theClass transient;
		else
			create data as theClass persistent;
		endif;
		data.set(pKey, pValue, self);
	else
		data.setValue(pValue);
	endif;
end;</source>
        <Parameter name="pKey" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pCreateIfNotPresent" type="Boolean"/>
    </JadeMethod>
</Class>
