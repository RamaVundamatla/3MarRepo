    <JadeMethod name="create" id="831d01c6-4f8c-43f6-b667-c3f19be96b8c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.permissionView  := PmAdmReeferMaintView;
	self.permissionMaint := PmAdmReeferMaintMaint;
	self.helpFileName := HelpFile_Yard;

epilog

end;</source>
