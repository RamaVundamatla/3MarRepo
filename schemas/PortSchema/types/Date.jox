	if self.isValid() and self.year &gt; 1600 then
		return self.format(app.getDateShortFormat());
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="shortYearEDI" id="7d2b5bc0-2426-4792-9ee2-6e081de43443">
        <source>shortYearEDI() : String;

vars

begin
	return self.userFormat($CM_ShortYearFormat); //yyMMdd
end;</source>
        <ReturnType type="String"/>
