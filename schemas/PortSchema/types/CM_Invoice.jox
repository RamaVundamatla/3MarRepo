    <JadeMethod name="getSapLastActivitySuccess" id="5c800a30-63bf-4668-823c-b2e1dbfa2e02">
        <source>getSapLastActivitySuccess(_isProductionStatus : Boolean ):CM_ActivityHistoryExtInterface;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2018	jlgndl1	Initial creation	TFS 42116
03 Dec 2018 jlger1	 TFS 42116 - the SAP production status is determined by a different ws call for prepay 
*/

vars

	reqName : String;
	iter : Iterator;
	startObj : CM_ActivityHistoryExtInterface;
	actHist : CM_ActivityHistoryExtInterface;
	success : CM_ActivityHistoryExtInterface;

begin

	if self.allSAPActivity.isEmpty then
		return null;
	endif;

	if self.paymentType = PaymentType_AutoCollection then
		if self.status = CM_Invoice.INVOICE_PENDING then
			reqName := CM_SAPWSConsumerAgent::autocollPreInvoiceNewRequest_SI.name;
		elseif self.status = CM_Invoice.INVOICE_POSTED then
			reqName := CM_SAPWSConsumerAgent::autocollInvoiceRequest_SI.name;
		endif;
	elseif self.paymentType = PaymentType_PostPay then
		reqName := CM_SAPWSConsumerAgent::postBillInvoiceRequest_SI.name;
	elseif self.paymentType = PaymentType_PrePay then
		if _isProductionStatus then
			reqName := CM_SAPWSConsumerAgent::preBillProdDataReq_SI.name;
		else 
			reqName :=CM_SAPWSConsumerAgent::preBillPaidInvoiceRequest_SI.name;
		endif;
	endif;
	if reqName = null then
		return null;
	endif;

	startObj := self.allSAPActivity.getAtKeyGeq( reqName, null );
	if startObj = null or startObj.requestName &lt;&gt; reqName then
		return null;
	endif;
	iter := self.allSAPActivity.createIterator;
	iter.startAtObject( startObj );
	
	while iter.next( actHist ) do
		if reqName &lt;&gt; actHist.requestName then
			break;
		endif;
		if actHist.success then
			success := actHist;
		endif;
	endwhile;
	
	return success;  // i.e. the last successful one of this request tuype.

epilog

	delete iter;

end;</source>
        <Parameter name="_isProductionStatus" type="Boolean"/>
        <ReturnType type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
    <JadeMethod name="getSapPerformanceStatus" id="96004ce0-8272-4e27-8146-9f5dc4aeceb1">
