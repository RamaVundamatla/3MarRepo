03 Jan 2025		navah1  Change 33742: MTN - 22.0.24.12 - Unit Tests Review - [2]
04 Apr 2025		navdap1	MTN-14781 CPL | Increase BOL Field Length
01 May 2025		navpw1	JIRA: MTN-34698 - Added fixes for truncating cargo type description, commodity and commodity description. 
											They now pull the length from the property instead of being hardcoded and use getLengthForString because of how these are stored in Jade
											See Jade PAR 48540 for more details
*/

vars
	weight			 	: Integer;
	contRange 		 	: CM_ContRange;
	cargoType		 	: CM_CargoType;
	len, pos 		 	: Integer;
	operatorCode,
	delimiter 		 	: String;
	str, 
	type			 	: String;												
	subCargoTypeCode 	: String;
	cargoTypeId 	 	: Integer;
	found 		     	: Boolean;
	xlationCode 	 	: String;
	root			 	: CM_Root;
	isTotalWeightZero,						// 17 Oct 2024		navcs2	MTN-33066
	isKg,									// 17 Oct 2024		navcs2	MTN-33066
	shouldChange		: Boolean;			// 17 Oct 2024		navcs2	MTN-33066
	value				: String;			// 17 Oct 2024		navcs2	MTN-33066
begin

	if _propName = ETRow_WeightTons then
		if _processedValue = null then
			self.setPropertyValue(ETRow_Weight, NULL_WEIGHT);
		else
			weight := (_processedValue.asDecimalJMT() * 1000).Integer;		//4/9/24   navsaa30  #63853
			self.setPropertyValue(ETRow_Weight, weight.Decimal);  			//ccms 1060 cnwrd1 12.1.09
		endif;
		return true;
		
	elseif _propName = ETRow_Weight or _propName = ETRow_TotalWeight then	//+cnwml2 MSL CCMS 1017
		if _processedValue = null then 										// null string - NULL WEIGHT
			self.setPropertyValue(ETRow_Weight, NULL_WEIGHT);
		else
			self.setPropertyValue(ETRow_Weight, _processedValue.asDecimalJMT); //ccms 1060 cnwrd1 12.1.09   //4/9/24   navsaa30  #63853
		endif;
		return true;
		
	elseif _propName = ETRow_Commodity or _propName = ETRow_CommodityDescription then //Par 13379 cnwrs1 feb 2007
		// par 31259 - commodity code/description gets translated at end once we have temperature
		//           - at this stage we just want to store the raw value which could be longer than the value we can store in the proprty
		//			 - so just to make sure i will put it in extra data
		if _propName = ETRow_Commodity and _xlationOperator &lt;&gt; null then
			// save raw value until we xlate it
			self.saveRawCommodityCode (_processedValue);
		// ### JIRA: MTN-34698 01May2025 NAVPW1
		elseif _propName = ETRow_Commodity and 
				(self.isEDIBOLDtlTI or self.isLoadListTI or self.isEdiPackTI or self.isEdiTranshipTi) and 
				_xlationOperator = null 
		then																									//This field has a length of 30
			self.setStringValue (_propName, _processedValue, CM_EDIBOLDtlTI::commodity.getLengthForString());
		elseif _propName = ETRow_Commodity and 
				(self.isEdiPackTI) and 
				_xlationOperator = null 
		then																									//This field has a length of 5
			self.setStringValue (_propName, _processedValue, CM_EDIPackTI::commodity.getLengthForString());
		elseif _propName = ETRow_Commodity and _xlationOperator = null then 									//This field has a length of 4
			// just update property now as it is the comodity code and we are not translating
			self.setStringValue (_propName, _processedValue, CM_EDICargoTI::commodity.getLengthForString());
		// ### JIRA: MTN-34698 01May2025 NAVPW1
		else
			// just update property now - if it is commodityDescripition we may use it for xlation laster
			self.setStringValue (_propName, _processedValue,30);												//07.12.2022 navma1	#55783
		endif;
		return true;
		
	elseif _propName = ETRow_Temperature then								//non-multiplied
		if _processedValue = null then										//i.e. null STRING - NULL_TEMPERATURE - other wise '0' is a valid temp
			self.setPropertyValue(ETRow_Temperature, NULL_TEMPERATURE);
		else
			self.setPropertyValue(ETRow_Temperature, _processedValue.Real);
		endif;
		return true;
	elseif _propName = CM_EDITrackedItem::temperatureAbsolute.name then	//ccms 1976 cnwrs1 16 Dec 2010
		if _processedValue &lt;&gt; null then
			self.temperatureAbsolute := self.extractNumber(_processedValue.String);
		endif;
	elseif _propName = CM_EDITrackedItem::temperatureSign.name then	//ccms 1976 cnwrs1 16 Dec 2010
		if _processedValue &lt;&gt; null then
			self.temperatureSign := _processedValue.Character;
		endif;
	elseif _propName = ETRow_Humidity then//non-multiplied
		if _processedValue = null then//i.e. null STRING - NULL_Humidity - other wise '0' is a valid humidity
			self.setPropertyValue(ETRow_Humidity, NULL_HUMIDITY);
		else
			self.setPropertyValue(ETRow_Humidity, _processedValue.asDecimalJMT);         //4/9/24   navsaa30  #63853
		endif;
		return true;		
		
	elseif _propName = ETRow_Ventilation then//non-multiplied
		if _processedValue = null then//i.e. null STRING - NULL_VENTILATION - other wise '0' is a valid vent
			self.setPropertyValue(ETRow_Ventilation, NULL_VENTILATION);
		else
			self.setPropertyValue(ETRow_Ventilation, _processedValue.asDecimalJMT);				//4/9/24   navsaa30  #63853
		endif;
		return true;	

	elseif _propName = ETRow_Vent then//non-multiplied
		if _processedValue = null then//i.e. null STRING - NULL_VENTILATION - other wise '0' is a valid vent
			self.setPropertyValue(ETRow_Vent, NULL_VENTILATION);
		else
			self.setPropertyValue(ETRow_Vent, _processedValue.asDecimalJMT);				//4/9/24   navsaa30  #63853
		endif;
		return true;	
		
	elseif _propName = ETRow_CarbonDioxide then
		if _processedValue = null then
			self.setPropertyValue(ETRow_CarbonDioxide, NULL_CARBON_DIOXIDE);
		else
			self.setPropertyValue(ETRow_CarbonDioxide, _processedValue.asDecimalJMT);   //4/9/24   navsaa30  #63853
		endif;
		return true;
	
	elseif _propName = ETRow_Oxygen then
		if _processedValue = null then
			self.setPropertyValue(ETRow_Oxygen, NULL_OXYGEN);
		else
			self.setPropertyValue(ETRow_Oxygen, _processedValue.asDecimalJMT);			//4/9/24   navsaa30  #63853
		endif;
		return true;

	// if there is no isotype in the file look it up from the container range 
	elseif _propName = CM_EDITrackedItem::id.name then 								//par 13379 cnwrs1 Feb 2007
		if self.hasPropIsoType and self.getPropertyValue(ETRow_IsoType) = null then	//18.11.2022 navma1 #55424
			self.setId(_processedValue.toUpper[1:30]);								//20 Feb 2014	NDL	Par 32535
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.setPropertyValue(ETRow_IsoType, contRange.isoType);
			endif;
		endif;
		// cnwrl1 04/12/2009 PAR 21718 - start of coding
		if self.isKindOf(CM_EDIBookingHeaderTI) or 
		   self.isKindOf(CM_EDIBookingItemTI) then
			// for these classes make sure the Id entered is in upper case.
			self.setPropertyValue(ETRow_Id, _processedValue.toUpper);
			if self.isKindOf(CM_EDIBookingHeaderTI) then //cnwrs1 Jan 2010 Par 21718
				if self.myEDIData.isKindOf(CM_EDIDataBooking) then				//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
					self.myEDIData.setPropertyValue(CM_EDIDataBooking::currentBookingItemCode.name, _processedValue[1:30].toUpper); 
				endif;
			elseif self.isKindOf(CM_EDIBookingItemTI) and //cnwrs1 Jan 2010 Par 21718
			   _processedValue = null and
			   self.myEDIData.isKindOf(CM_EDIDataBooking) then					//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				self.setPropertyValue(ETRow_Id, self.myEDIData.getCurrentBookingItemCode());
			endif;
			return true;
		endif;
		// cnwrl1 04/12/2009 PAR 21718 - end of coding
		if self.isKindOf(CM_EDIBOLHdrTI) or
		   self.isKindOf( CM_EDIReleaseRequestTI ) or				// cnwrl1 06/05/2010 PAR 23847
		   self.isKindOf(CM_EDIBOLDtlTI) then
			// for these classes make sure the Id entered is in upper case.
			//self.setPropertyValue(ETRow_Id, _processedValue.toUpper);
			self.setId(_processedValue.toUpper[1:35]);	//20 Feb 2014	NDL	Par 32535	// MTN-14781
			return true;
		endif;

	elseif _propName = ETRow_VoyageCode then 
		// par 31259 - we can't xlate voyage till we have a vessel so just save off voyage and 
		//			 - sort out xlation in processAttributeDependencies
		if _xlationOperator &lt;&gt; null and
		   self.hasPropVoyageCode   then									//18.11.2022 navma1 #55424
			// save raw value until we xlate it
			self.saveRawVoyageCode(_processedValue);
			self.setVoyageCode(_processedValue);	//otherwise the null voyage will be used
		else
			// just update property now - its not going to be xlated
			self.setVoyageCode(_processedValue);
		endif;
		
		return true;
		
	elseif _propName = ETRow_ImCodes or 	// par17696 cnwrs1 SEPT 2008
	   _propName = ETRow_Hazards or			// 02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
	   _propName = ETRow_Hazardous then
		if _processedValue &lt;&gt; null and
		   self.class.findProperty(ETRow_ImCodes) &lt;&gt; null then
			self.setImCodes(_processedValue);			// MES1008 allow imCodes in toehr classes. Was typecasting to self.CM_EDIPrenoteTI.imCodes.add(_processedValue);
		endif;
		return true;
	elseif _propName = ETRow_CargoTypeDescr then
		// attempt to match the supplied data to either the cargo type abbreviation or the description.
		root      := app.myRoot;																//18.11.2022 navma1 #55424
		cargoType := root.getCargoTypeFromAbbrevOrDescr(_processedValue);
		if cargoType = null then
			if _xlationOperator &lt;&gt; null then
				cargoTypeId := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_CARGOTYPE_BYOP, found).Integer;
				cargoType   := root.allCargoTypesById[cargoTypeId];								//18.11.2022 navma1 #55424
				if cargoType &lt;&gt; null then
					self.setPropertyValue(ETRow_CargoType,		cargoType.id);
					self.setPropertyValue(ETRow_CargoTypeDescr, cargoType.description);	// in case abbreviation supplied.
					return true;
				endif;
			endif;
			// par 29533 - if cargo type description is not valid then clear out cargo type which would have been set
			// in the constructor and also setForCreate
			self.cargoType		:= null;	// par 29533
			// ### JIRA: MTN-34698 29Apr2025 NAVPW1
			if _propName = CM_EDICargoTI::cargoTypeDescr.name and _processedValue.length &lt;= CM_EDICargoTI::cargoTypeDescr.getLengthForString() then //Length should be 30
				self.cargoTypeDescr := _processedValue;
				//return true; //Cannot return true here as we are calling this from a class that gives us a cargoType and we are not setting a cargo type. For Example:
								//Unit Test tEDITIUpdateTest2 and method is CM_EDIHazDetailsTI::assignValueSpecial
			endif;
			// ### JIRA: MTN-34698 29Apr2025 NAVPW1
			return false;		// this will default the screen to the supplied value
		else
			self.setPropertyValue( ETRow_CargoType, cargoType.id );
			self.setPropertyValue( ETRow_CargoTypeDescr, cargoType.description );	// in case abbreviation supplied.
			return true;
		endif;
	elseif _propName = ETRow_ParentCargoType then //cnwgb1 PAR 23419 9.4.2010
		// attempt to match the supplied data to either the cargo type abbreviation or the description.
		if self.isKindOf( CM_EDIPrenoteTI ) or self.isKindOf( CM_EDICargoTI ) then
			root        := app.myRoot;
			cargoType	:= root.getCargoTypeFromAbbrevOrDescr( _processedValue );	//18.11.2022 navma1 #55424
			if cargoType = null then
				if _xlationOperator &lt;&gt; null then
					cargoTypeId := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_CARGOTYPE_BYOP, found).Integer;
					cargoType   := root.allCargoTypesById[cargoTypeId];				//18.11.2022 navma1 #55424
					if cargoType &lt;&gt; null then
						self.setPropertyValue("parentCargoTypeCode", cargoType.id);
						self.setPropertyValue(ETRow_ParentCargoType, cargoType.description);	// in case abbreviation supplied.
						return true;
					endif;
				endif;
				return false;		// this will default the screen to the supplied value
			else
				self.setPropertyValue( ETRow_ParentCargoType, cargoType.description );	// in case abbreviation supplied.
				self.setPropertyValue( "parentCargoTypeCode", cargoType.id ); //cnwgb1 PAR 23419 
				return true;
			endif;
		endif;
	elseif _propName = ETRow_Product then
		if self.class.findProperty(ETRow_Product) &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then
				subCargoTypeCode := _xlationOperator.getXlationSystemCode_CargoSubT(_processedValue,app.myRoot.allCargoTypesById[self.cargoType], found).String;
				self.setPropertyValue(ETRow_Product, subCargoTypeCode);
				return true;
			endif;
		endif;
	elseif _propName = ETRow_OperatorCode then
		if _processedValue = null and 
		   _xlationOperator &lt;&gt; null then // null string - NULL Operator
			self.setPropertyValue(ETRow_OperatorCode, _xlationOperator.code);
		else
			if self.cargoType = null and
			   self.cargoTypeDescr &lt;&gt; null and
	   		   _xlationOperator &lt;&gt; null then // null string - NULL Operator
				cargoTypeId := _xlationOperator.getXlationSystemCode(self.cargoTypeDescr, XLATION_TYPE_CARGOTYPE_BYOP, found).Integer;
				cargoType   := app.myRoot.allCargoTypesById[cargoTypeId];
				if cargoType &lt;&gt; null then
					self.setPropertyValue(ETRow_CargoType, cargoType.id);
					self.setPropertyValue(ETRow_CargoTypeDescr, cargoType.description);	// in case abbreviation supplied.
				endif;
			endif;
			return false;
		endif;		
	//14 Oct 2009 cnwrs1 / cnwrl1 PAR 21331
	elseif _propName = ETRow_TrainCode then
		// for an EDI train consist format if the train code has not been entered on the wagon data then
		// default to the train code previously saved on the EDI Data during the processing of the train data.
		if self.myEDIData.isKindOf( CM_EDIDataTrainConsist ) then
			if _processedValue = null and
			   self.isKindOf( CM_EDIWagonTI ) then
				if self.myEDIData.CM_EDIDataTrainConsist.currentTrainCode &lt;&gt; null then
					self.setPropertyValue( ETRow_TrainCode, self.myEDIData.CM_EDIDataTrainConsist.currentTrainCode );
				endif;
				return true;		// special value has been set
			endif;
			// for an EDI train consist format if have the train code then save off the default train code
			if self.isKindOf( CM_EDITrainTI ) then			// save even if blank
				self.myEDIData.CM_EDIDataTrainConsist.setPropertyValue(	CM_EDIDataTrainConsist::currentTrainCode.name,
																			_processedValue.toUpper[ 1 : CM_EDIDataTrainConsist::currentTrainCode.getLengthForString ] );
			endif;
		endif;
		return false;				// no special value has been set
	elseif _propName = ETRow_WagonNumber then
		// for an EDI train consist format if the wagon number has not been entered on the PreNote data then
		// default to the wagon number previously saved on the EDI Data during the processing of the last wagon data.
		if self.myEDIData.isKindOf( CM_EDIDataTrainConsist ) then
			if _processedValue = null and
			   self.isKindOf( CM_EDIPrenoteTI ) then
				if self.myEDIData.CM_EDIDataTrainConsist.currentWagonCode &lt;&gt; null then
					self.setPropertyValue( ETRow_WagonNumber, self.myEDIData.CM_EDIDataTrainConsist.currentWagonCode );
				endif;
				return true;		// special value has been set
			endif;
			// for an EDI train consist format if have the wagon number then save off the this last wagon number
			if self.isKindOf( CM_EDIWagonTI ) then			// save even if blank
				self.myEDIData.CM_EDIDataTrainConsist.setPropertyValue(	CM_EDIDataTrainConsist::currentWagonCode.name,
																			_processedValue.toUpper[ 1 : CM_EDIDataTrainConsist::currentWagonCode.getLengthForString ] );
			endif;
		endif;
		return false;				// no special value has been set
	//14 Oct 2009 cnwrs1 / cnwrl1 PAR 21331
	// cnwrl1 04/12/2009 PAR 21718 - start of coding
	elseif _propName = ETRow_ReleaseRequestNumber then
		if self.isKindOf( CM_EDIBookingHeaderTI ) or
		   self.isKindOf( CM_EDIBookingItemTI ) or
		   self.isKindOf( CM_EDIReleaseRequestTI ) then
			// for these classes make sure the Release Request Number entered is in upper case.
			self.setPropertyValue( ETRow_ReleaseRequestNumber, _processedValue.toUpper );
			return true;
		endif;

	elseif _propName = ETRow_MessageMode then
		if _processedValue = null then //dont do anything leave the default value
			return true;
		endif;
	elseif _propName = ETRow_DischargePorts then
		if _processedValue &lt;&gt; null then
			self.setOptDischargePorts(_processedValue);
		endif;
		return true;
	elseif _propName = ETRow_TranshipPortCodes then  //PAR25736 cnwsh3 14/09/2010 - an earlier piece of code relating to tranship port codes moved here
		if self.isKindOf(CM_EDIPortTI) then
			self.addTranshipPortCodes(_processedValue);// Moved this code to the a reimpelemented method as part of PAR25736
			return true;
		elseif self.isKindOf(CM_EDILoadListTI) then //cnwrs1 CCMS 1137 01 July 2010
			if _processedValue &lt;&gt; null and
				self.class.findProperty(ETRow_TranshipPortCodes) &lt;&gt; null then
				self.addTranshipPortCodes(_processedValue);
			endif;
			return true;
		endif;
	elseif _propName = ETRow_NetWeight then	//cnsrs1 ccms 2044 21 Apr 2011
		if self.isKindOf(CM_EDIPackTI) then
			self.CM_EDIPackTI.weightNet := _processedValue.asDecimalJMT;			//4/9/24   navsaa30  #63853
			return true;
		endif;
	elseif _propName = ETRow_TareWeight then	//cnsrs1 ccms 2044 21 Apr 2011
		if self.isKindOf(CM_EDIPackTI) then
			self.CM_EDIPackTI.weightTare := _processedValue.asDecimalJMT;			//4/9/24   navsaa30  #63853
			return true;
		endif;
	elseif _propName = ETRow_ValidOperators then // cnwgb1 PAR 23207 16.3.2010
		if self.isKindOf(CM_EDIVoyageTI) then
			len := _processedValue.length;
			pos := 1;
			while true do
				operatorCode := _processedValue.getDelimitedToken(pos, ' ', delimiter);
				if not self.CM_EDIVoyageTI.allValidOperatorCodes.includes(operatorCode) then	//15 Nov 2016	NDL	TFS 2905
					self.CM_EDIVoyageTI.allValidOperatorCodes.add(operatorCode);
				endif;
				if pos &gt; len then
					break;
				endif;
			endwhile;
			return true;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverHeight
	or _propName = ETRow_OverLengthFront
	or _propName = ETRow_OverLengthBack
	or _propName = ETRow_OverWidthLeft
	or _propName = ETRow_OverWidthRight then
		if _processedValue = null then
			self.setPropertyValue(_propName, NULL_INTEGER.Decimal);
		else
			self.setPropertyValue(_propName, _processedValue.asDecimalJMT);		//4/9/24   navsaa30  #63853
		endif;
		return true;
		
	elseif _propName.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width) then		// PAR #34664
		self.setPropertyValue(_propName, _processedValue.asDecimalJMT);				// PAR #34664			//4/9/24   navsaa30  #63853
		return true;
	elseif _propName = ETRow_Volume then										// PAR #34874
		if self.class = CM_EDIProductTI then 									//03.01.2025 navah1 #33742
			self.setPropertyValue(_propName, _processedValue.asRealJMT);		//03.01.2025 navah1 #33742		 
		else
			self.setPropertyValue(_propName, _processedValue.asDecimalJMT);				// PAR #34874			//4/9/24   navsaa30  #63853
		endif;
		return true;
	elseif _propName = ETRow_TotalWeight then									// TFS #1699
		self.setPropertyValue(_propName, _processedValue.asDecimalJMT);				// TFS #1699			//4/9/24   navsaa30  #63853
		return true;
	elseif _propName = ETRow_CountryOfOriginCode then //jlier1 TFS 54846 30/9/22
		
		if _xlationOperator &lt;&gt; null then
			xlationCode:=_xlationOperator.getXlationSystemCode_Country(_processedValue.String, found).String;	
		endif;
		if found  then
			self.countryOfOriginCode := xlationCode;
		else
			self.countryOfOriginCode := _processedValue.String;
		endif;	
		return true;
	elseif _propName.isMeasurementType then																						// PAR #33005
		_propName.getRowNameMeasureType(str, type);																				// PAR #33005	
		
		// 17 Oct 2024		navcs2	MTN-33066 Start
		if str = ETRow_Weight or str = ETRow_WeightTons or str = ETRow_TotalWeight then
			isTotalWeightZero 	:= self.getTotalWeight = 0;
			isKg				:= type = self.KGString;
			value 				:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
			shouldChange		:= (isTotalWeightZero and not value = null) or (isKg and not value = null);
		endif;
		
		if str = ETRow_WeightTons then
			if shouldChange then
				if value = null then
					self.setPropertyValue(ETRow_Weight, NULL_WEIGHT);
				else
					weight := (value.asDecimalJMT() * 1000).Integer;		
					self.setPropertyValue(ETRow_Weight, weight.Decimal); 
				endif;
			endif;
			return true;
			
		elseif (str = ETRow_Weight or str = ETRow_TotalWeight) then	
			if shouldChange then
				if value = null then 	
					if self.isStopTI or self.isVGMTi then
						self.setPropertyValue(ETRow_TotalWeight, NULL_WEIGHT);
					else
						self.setPropertyValue(ETRow_Weight, NULL_WEIGHT);
					endif;
				else
					if self.isStopTI or self.isVGMTi then
						self.setPropertyValue(ETRow_TotalWeight, value.asDecimalJMT); 
					else
						self.setPropertyValue(ETRow_Weight, value.asDecimalJMT); 
					endif;
				endif;
			endif;
			return true;
		else
		// 17 Oct 2024		navcs2	MTN-33066 End
			self.assignValueSpecial(str, value, _xlationOperator); 												
			return true;																											
		endif;
	elseif _propName = ETRow_ContractIdForTIstring then // 11/01/2023	navkc1	TFS CR 55625 TASK 55660
		self.setPropertyValue(_propName, _processedValue.String);
		return true;

	elseif _propName = ETRow_HsCode then	// TFS 56028
		self.setHSCode(_processedValue);	// TFS 56028
		return true;
	elseif _propName = CM_EDIRequestHeaderTI::regNumber.name then											//navra1 - TFS 59666 - 9th Aug 2023
		if self.isKindOf(CM_EDIRequestHeaderTI) then														//navra1 - TFS 59666 - 9th Aug 2023
			self.setPropertyValue(CM_EDIRequestHeaderTI::regNumber.name, _processedValue);					//navra1 - TFS 59666 - 9th Aug 2023
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="8870bc2e-0835-4692-97ab-763d2ff14556">
