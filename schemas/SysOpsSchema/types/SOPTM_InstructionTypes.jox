    <JadeMethod name="setControlsForAddEdit" id="65717c79-377a-4238-8648-0ef639b8db6e">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
31 Aug 2023	jlizm1	TFS 59567 Kiosk instruction type maint
*/

vars
	theForm : SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	
	
	entTableDef := app.myController.getEntTableDef(ETDef_InstructionType);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
		theForm.mulSelect1.setSelected(null);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_InstructionType);
		theForm.tblInput1.disableRowByName(ETRow_Code);
	endif;
    theForm.tblInput1.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="6145a107-9f9b-4b3e-967f-cccf1f9967ee">
