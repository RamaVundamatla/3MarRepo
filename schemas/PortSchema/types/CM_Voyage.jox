    <JadeMethod name="getVoyageActivity" id="c6eb472a-c8a3-4db2-af79-f5ca718487dc">
        <source>getVoyageActivity(): CMIF_VoyageActivityArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
						  This Method Used by LINX for the Activity Report
23 March 2017	cnwma1	  TFS #3841:LNX Reporting on Voyage Job information and Delays
26 April 2017 	cnwma1	  TFS #4216:Workpoints - Jobs not stored against Events
05 May 2017		cnwma1	  TFS #4346:Activity Report Timezone Issues
24 May 2017		cnwma1	  TFS #4526:Shift Report Cargo Sub-Type Activity Start time
22 Nov 2017		jlgdap1	  TFS 7948 Volume reporting incorrectly
14 Nov 2018		jlgma1		ChangeRequest 41760: Pelindo Timesheet - Daily report transaction From - To times
15 OCt 2021		jlier1		TFS 51963 - just get default voyage activity
*/


