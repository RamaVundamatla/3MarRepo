<Class name="CM_TerminalArea">
    <JadeMethod name="getNextQuickCargoID2" id="61f4da39-9248-43d9-b46d-a85c562b65b3">
        <source>getNextQuickCargoID2(_cargoType : CM_CargoType io; _useDuplicateID, _doGetNextID : Boolean; _nextNum : Integer io) : String;

/*

Purpose:		

Date			Who		Reason
03/11/2014		cnwmh5	Initial creation
						Replaces the GUI version as for unit tests able to 
						create ti's with different cargo types and looks
						really strange with multiple ti's of different
						cargo types with the same id

*/

vars
	
	ti						: CM_TrackedItem;
	
	nextID					: String;
	nextNum 				: Integer;
	
begin

	if _nextNum = 0 then
		_nextNum := 1112221;
	endif;
	
	while true do
		nextID := "YARD" &amp; _nextNum.String;
		ti := self.myTerminal.allOnsiteTIsByIdCargoType[nextID,_cargoType.id].CM_TrackedItem;
		if ti = null then
			////write class.name &amp; "::" &amp; method.name &amp; Tab &amp; ti.String &amp; Tab &amp; nextID &amp; Tab &amp; _cargoType.id.String &amp; Tab &amp; 
			////	_cargoType.description;
			return nextID;
		else
			if ti.myTerminalArea &lt;&gt; self then
				if _cargoType.allowDuplicates and _useDuplicateID and not _doGetNextID then
					_nextNum := _nextNum + 1;
					return nextID;
				endif;
			endif;
		endif;
		_nextNum := _nextNum + 1;
	endwhile;
	
	return nextID;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType" usage="io"/>
        <Parameter name="_useDuplicateID" type="Boolean"/>
        <Parameter name="_doGetNextID" type="Boolean"/>
        <Parameter name="_nextNum" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
