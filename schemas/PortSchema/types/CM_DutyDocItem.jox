    <JadeMethod name="validateUpdate" id="d4c1f8c8-ff1d-4907-a18c-dec9aa411eca">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if self.hsCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Duty_code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Duty_code), null, null); // cnwdb2	PAR 35364
	endif;
	
	//22 Apr 2013	NDL	Par 31424
	if self.deliveryOrderExpiryDate &lt;&gt; null and self.deliveryOrderExpiryDate.isValid then
		if self.deliveryOrderExpiryDate &lt; app.actualTimeServer.Date then				// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			app.raiseCMWarning1(Should_not_before_today,"DO Exp. Date",null,null,null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
