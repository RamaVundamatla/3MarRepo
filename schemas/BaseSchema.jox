			o cnEcDefaultSuffix():String;
			o cnEcReadFromFile(pFileName:String; pIsFindFile:Boolean):Boolean updating;
			o cnEcWriteToFile(pFileName:String; pIsFindFile:Boolean):Boolean updating;
		
