    <JadeMethod name="doCancel" id="6e40d9ec-16d3-4318-91dd-45ec80a8ea14">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes

*/

vars

begin
	self.unloadForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="750f8ec8-c435-4e29-b559-475c64796ec4">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 February 2023    navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars
	heading,
	description,
	remarks 		: String;
	category 		: CM_FileDataCategory;
	pxyFileData 	: CM_FileData;
	context 		: Integer; 
begin
	category 		:= self.cmbCategory.listObject.CM_FileDataCategory;
	heading 		:= self.txtHeading.text;
	description 	:= self.txtDescription.text;
	remarks			:= self.txtRemarks.text;
	
	if self.chkAutoPrint.value then					//22.2.2023 navhl20	#56625[56517]
		context := FileContext_AutoPrintOnKiosk;
	else
		context := FileContext_Null;
	endif;
	
	pxyFileData := app.createUpdateProxy(self.myFileData).CM_FileData;								//24.2.2023 navhl20	#56625[56517]
	

	pxyFileData.setProxy(description,heading,remarks,pxyFileData.myParent,category,context);		//22.2.2023 navhl20	#56625[56517]

	app.myTrxUA.trxUpdateFile(pxyFileData,app.myPassport);
	
	if app.myPassport.hasErrors then
		return;
	else
		self.unloadForm();
	endif;
epilog
	delete pxyFileData;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="9aad41b5-f620-4fff-a264-2f633a096590">
        <updating/>
        <source>init(_masterObj : CM_Object; _caption : String) updating;
/*
Date				Who		Reason
6 Dec 2022			navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
*/
vars

begin
	self.btnOk.enabled := false;          																													
	self.myMasterObject := _masterObj;
	//self.caption := 'File Load for ' &amp; _caption;																											
	if self.myMasterObject &lt;&gt; null and self.myMasterObject.isKindOf(CM_CargoBOLType) then																	
		self.caption := 'Edit File Attachment ' &amp; self.myMasterObject.CM_CargoBOLType.abbreviation &amp; " " &amp; self.myMasterObject.CM_CargoBOLType.description;		
	else																																					
		self.caption := 'Edit File Attachment ' &amp; _caption;																										
	endif;																																					
end;
</source>
        <Parameter name="_masterObj" type="CM_Object"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCategory" id="32e9df6a-91c7-4854-90f4-e569ab46dcf3">
        <source>loadCategory();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes

*/

vars
	fileCategory : CM_FileDataCategory;
	category : Integer;
begin
	if self.myMasterObject &lt;&gt; null then
		category := self.myMasterObject.getFileCategory(); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
		foreach fileCategory in app.myRoot.allFileDataCategories where fileCategory.categoryContext = category do // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
			self.cmbCategory.itemObject[ self.cmbCategory.addItem( fileCategory.description ) ] := fileCategory;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ae48cdb6-bb27-45a3-b831-22f15615296e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 February 2023    navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars
	workOrder : CM_WorkOrder;
begin
		
		self.handleMenusForModalDisplay();
		self.txtHeading.text :=myFileData.heading;
		self.txtDescription.text := myFileData.description;
		self.txtRemarks.text := myFileData.remarks;
		self.loadCategory();
		
		if self.myFileData.actionContext = FileContext_AutoPrintOnKiosk then	//22.2.2023 navhl20 #56625[56517]
			self.chkAutoPrint.value := true;
		endif;
		
		if self.myMasterObject.isKindOf(CM_WorkOrder) then						//22.2.2023 navhl20	#56625[56517]
			workOrder := self.myMasterObject.CM_WorkOrder;
			if workOrder.allowAttachDocsToPrintKiosk() then
				self.chkAutoPrint.visible := true;
				if workOrder.taskStatus = WO_STATUS_CANCELLED 
				or workOrder.taskStatus = WO_STATUS_COMPLETE 
				or workOrder.archived then
					self.chkAutoPrint.enabled := false;
				endif;
			endif;
		endif;
		
		self.cmbCategory.listObject := myFileData.myCategory;
		self.btnOk.enabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="290ed34d-4d4c-44dd-9b39-0cdcc7a0ce7e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:09:45.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025227, locale);
	chkAutoPrint.translateCaption(Xlat_0025571, locale);
	lblCategory.translateCaption(Xlat_0025228, locale);
	lblDescription.translateCaption(Xlat_0025229, locale);
	lblHeading.translateCaption(Xlat_0025230, locale);
	lblRemarks.translateCaption(Xlat_0025231, locale);
end;</source>
    </JadeMethod>
</GUIClass>
