    <JadeMethod name="hasJobActivityType" id="bbb1f3f8-cb57-4711-843e-a7024752c3b3">
        <source>hasJobActivityType(_type : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 CR62696 Task 62944: UI - Retrospective UI Stop Start Option

*/

vars
	wo				: CM_WorkOrder;
	wodtl			: CM_WorkOrderDtl;
	woTxn			: CM_WOTransaction;
	ts				: TimeStamp;
begin
	wodtl := self.getMyWorkOrderDtl();
	
	if wodtl = null then
		return false;
	endif;
	
	wo := wodtl.myParent;
	
	if wo = null then
		return false;
	endif;
	
	ts := null;
	
	woTxn := wo.getNextJobActionTxn(ts, _type);
	
	return woTxn &lt;&gt; null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasJobStarted" id="b3a45ccc-e8f4-474e-917f-26af57e8e055">
        <source>hasJobStarted() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2017	jlgab1	Initial creation		//+TFS4796
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle	: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.status = WLE_COMPLETED do
		return true;
	endforeach;
	
	return false;
epilog

end;</source>
