    <JadeMethod name="getOIDSQLFormat" id="d715d22c-b7fe-4cb3-bfe6-60c7302e3c68">
        <source>getOIDSQLFormat(_oidFormat: Integer; _sqlTableCreate : Boolean) : String;

// 17/05/2010 - conkc1

vars
	parameterString : String;
begin
	if _sqlTableCreate = true then
		if _oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
			parameterString := " [binary] (06)"; //02/09/2010 cnwdz2 par25621
		elseif _oidFormat = CM_DataDumpExtractDef.OIDFormatString then
			parameterString := " [nvarchar] (16)";
