    <JadeMethod name="getExtraCriteriaMatchData" id="036846aa-6ac3-4ea4-b89c-8591136051c3">
        <source>getExtraCriteriaMatchData(_criteriaType: Integer): CM_YAData;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2016	cnwndl1	Initial creation TFS 2527

*/

vars

	extraCriteria : CM_ReleaseByTypeCriteria;
	yaCriteria : CM_YACriteria;

begin

	extraCriteria := self.getReserveSelectionCriteria;
	if extraCriteria &lt;&gt; null then
		yaCriteria := extraCriteria.getCriteriaFor( _criteriaType );
		if yaCriteria &lt;&gt; null then
			return yaCriteria.myYAData;
		endif;
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_criteriaType" type="Integer"/>
        <ReturnType type="CM_YAData"/>
    </JadeMethod>
    <JadeMethod name="getFoundLocation" id="279f163c-fb9d-4e85-8736-0ffbaeca7f13">
        <source>getFoundLocation(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars

begin
	if self.allFoundLCs.isEmpty() then
		if not self.allPassedLocationsRestricted.isEmpty then //cnwrd1 par 29269 14.3.2012
			return self.allPassedLocationsRestricted.first;
		else
			return null;
		endif;
	endif;
	
	return self.allFoundLCs.first;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
