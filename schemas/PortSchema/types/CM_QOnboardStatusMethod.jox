<Class name="CM_QOnboardStatusMethod" id="4b6cb177-a40e-40ba-80a7-ec0feb10ec24">
    <superclass name="CM_QIntegerLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="7c8db50f-9377-434b-99c1-e640e3fef785">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars
	length	:Integer;
	
begin
	length := false.getYesNo().length;
	length := length.max(app.getErrorString(Mafi).length);
	length := length.max(app.getErrorString(Trailer).length);
	
	return length;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="41a7e719-57f8-4e5c-bbce-073762553d9d">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars

begin
	return _obj.sendMsg(self.propertyName);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
