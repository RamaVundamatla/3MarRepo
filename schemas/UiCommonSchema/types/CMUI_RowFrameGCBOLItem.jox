    <JadeMethod name="buildSelf" id="6e432df9-7fda-430d-85d8-4ae854e55950">
        <updating/>
        <source>buildSelf() updating;
//-----------------------------------------------------------------------
//	Created:	04 April 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------

vars
	tmpForm		: CMUI_BOLEntryGCVoyage;
	idx			: Integer;
	tmpLbl		: CMUI_RowLabel;
begin

	inheritMethod();

	if self.isInPainter then
		return;
	endif;
	
	self.ignoreSkin := true;	

	frmText.drawLine(0,18,1000,18, 0);
	self.width := 800;
	
	frmInput.autoRedraw := true;
	frmInput.move(0, 0, 800, 240);
	frmInput.caption := self.getInputFrameCaption();
	frmInput.drawLine(0,239,1000,239, 0);
	
	frmText.move(0, 0, 800, 19);

	frmText.autoRedraw := true;
	frmText.drawTextAlign := Frame.DrawTextAlign_Left;
	
	if self.form &lt;&gt; null and self.form.isKindOf(CMUI_BOLEntryGCVoyage) then
		tmpForm := self.form.CMUI_BOLEntryGCVoyage;
	else
		return;
	endif;
	
	self.myForm := tmpForm;
	
	idx := tmpForm.nextControlNum;
	if idx = 0 then
		idx := 1;
	endif;
	tmpForm.nextControlNum := idx + 1;
	
	self.myCmbCargoType := tmpForm.cmbCargoType.loadControl(idx).CMUI_ComboBox;
	self.myCmbCargoType.parent := self;
	self.myForm.loadCargoTypesCombo(self.myCmbCargoType);

	self.myCmbHatch := tmpForm.cmbHatch.loadControl(idx).CMUI_ComboBox;
	self.myCmbHatch.parent := self;
	self.myForm.loadCmbHatch(self.myCmbHatch);

	self.myCmbHeightCodes := tmpForm.cmbHeightCodes.loadControl(idx).CMUI_ComboBox;
	self.myCmbHeightCodes.parent := self;

	self.myCmbLengthCodes := tmpForm.cmbLengthCodes.loadControl(idx).CMUI_ComboBox;
	self.myCmbLengthCodes.parent := self;

	self.myCmbProduct := tmpForm.cmbProduct.loadControl(idx).CMUI_ComboProduct;
	self.myCmbProduct.parent := self;

	self.myCmbTypeCodes := tmpForm.cmbTypeCodes.loadControl(idx).CMUI_ComboBox;
	self.myCmbTypeCodes.parent := self;

	self.myCmbWidthCodes := tmpForm.cmbWidthCodes.loadControl(idx).CMUI_ComboBox;
	self.myCmbWidthCodes.parent := self;

	self.myTblProductDtls := tmpForm.tblProductDtls.loadControl(idx).CM_EntryTable;
	self.myTblProductDtls.parent := self;
	self.myTblProductDtls.setEntTableDefByName(ETDef_BreakBulkProdDtls);

	self.myTxtDescription := tmpForm.txtDescription.loadControl(idx).CMUI_TextBox;
	self.myTxtDescription.parent := self;

	self.myTxtID:= tmpForm.txtID.loadControl(idx).CMUI_TextBox;
	self.myTxtID.parent := self;

	self.myTxtMarks:= tmpForm.txtMarks.loadControl(idx).CMUI_TextBox;
	self.myTxtMarks.parent := self;

	self.myTxtMarksNo := tmpForm.txtMarksNo.loadControl(idx).CMUI_TextBox;
	self.myTxtMarksNo.parent := self;

	self.myTxtPurchaseOrder := tmpForm.txtPurchaseOrder.loadControl(idx).CMUI_TextBox;
	self.myTxtPurchaseOrder.parent := self;

	//self.myTxtQuantity := tmpForm.txtQuantity.loadControl(idx).CMUI_TextBox;
	//self.myTxtQuantity.parent := self;

	self.myTxtRemarks := tmpForm.txtRemarks.loadControl(idx).CMUI_TextBox;
	self.myTxtRemarks.parent := self;

	//self.myTxtVolume := tmpForm.txtVolume.loadControl(idx).CMUI_TextBox;
	//self.myTxtVolume.parent := self;

	//self.myTxtWeight := tmpForm.txtWeight.loadControl(idx).CMUI_TextBox;
	//self.myTxtWeight.parent := self;
	
	self.myLblNumberedEntry := tmpForm.lblNumeredEntry.loadControl(idx).CMUI_RowLabel;
	self.myLblNumberedEntry.parent := self.frmInput;


// Now clone all the labels

	tmpLbl := tmpForm.lblCargoType.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblHatch.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblProduct.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblDescription.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblId.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblMarks.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblMarksNo.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblPurchaseOrder.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblQuantity.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblRemarks.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblVolume.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	tmpLbl := tmpForm.lblWeight.loadControl(idx).CMUI_RowLabel;
	tmpLbl.parent := self.frmInput;

	
	self.setTabOrder (idx, idx,true);

end;</source>
    </JadeMethod>
    <JadeMethod name="clear" id="4663d175-a76b-4a39-a95f-8d7f3def7696">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myCmbCargoType.text 	:= null;
	self.myCmbHatch.text 		:= null;
	self.myCmbProduct.setObject(null);
	self.myTblProductDtls.clearValues();
	self.myTxtDescription.text 	:= null;
	self.myTxtID.text			:= null;
	self.myTxtMarks.text 		:= null;
	self.myTxtMarksNo.text 		:= null;
	self.myTxtPurchaseOrder.text:= null;
	//self.myTxtQuantity.text 	:= null;
	self.myTxtRemarks.text 		:= null;
	//self.myTxtVolume.text 		:= null;
	//self.myTxtWeight.text 		:= null;

	self.frmText.caption := self.getShortDesc();

	if self.myCMIFAttach &lt;&gt; null then
		delete self.myCMIFAttach.myProxyTrackedItem;
	endif;
	
	delete self.myCMIFAttach;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="8eb4729e-52f3-4606-aeb4-b386d9659c60">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
//----------------------------------------------------------------
//	Created:	13 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myCMIFAttach &lt;&gt; null
	and global.isValidObject(self.myCMIFAttach) then
		delete self.myCMIFAttach.myProxyTrackedItem;
		delete self.myCMIFAttach;
	endif;
	
end;</source>
    </JadeMethod>
