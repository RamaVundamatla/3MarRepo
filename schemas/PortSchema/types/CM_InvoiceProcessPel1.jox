<Class name="CM_InvoiceProcessPel1" id="b80afe70-e643-4bf2-bdcf-34759feccacd">
    <superclass name="CM_InvoiceProcess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 39618</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="getNextValidStatuses" id="ec0e7b74-fce8-42f0-bd2c-6c9f0b733075">
        <source>getNextValidStatuses(_invoice: CM_Invoice; _nextStatuses: CM_InvoiceStatusByPriority input; _includeAll: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
17 Dec 2018	jlgsl4	39618 	LNX - Approved Invoice Status
03 Feb 2020	jlgdi1	48442	PEL1 - Added user restriction check in determining allowable next valid status.
							Included conditions are user's security role and restrictions relating to 
							payment type, current invoice status and invoice payment status (ref. BRD 41111)
26/01/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
*/

vars
	currentStatus : Integer;
	bank : CM_Bank;
	
begin
	if _includeAll then
		self.allStatuses.copy(_nextStatuses);
		return;
	endif;
	
	// Invoice restrictions condition check
	if not _invoice.canUpdate() then 
		return;
	endif;
	
	/*
	bank := _invoice.bank;
	
	currentStatus := _invoice.status;
	if currentStatus = CM_Invoice.INVOICE_OPEN then
		if bank.userCanSet(CM_Invoice.INVOICE_DISPUTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_DISPUTED]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_PREPEND) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PREPEND]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_PREPEND then
		if bank.userCanSet(CM_Invoice.INVOICE_DISPUTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_DISPUTED]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_PENDING then
		if bank.userCanSet(CM_Invoice.INVOICE_POSTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED]);
		endif;
		if bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_POSTED then // if invoice needs to be returned
		if bank.userCanSet(CM_Invoice.INVOICE_POSTED_REVERSE) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_DISPUTED then
		if bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_SUSPENSE then
		if bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif currentStatus = CM_Invoice.INVOICE_VOID then // TFS 39618 PATCH 1
		if bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]); // TFS 39618 PATCH 1
		endif;
	endif; // other statuses eg. Posted Reversed, Posted Credit can't be changed	
	*/
	
	self.getStatuses(_nextStatuses, _invoice.status, _invoice.previousStatus, _invoice.bank);
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_nextStatuses" type="CM_InvoiceStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStatuses" id="eb3ffff3-3f35-437e-adff-9149f6d6dfaa">
        <source>getStatuses(_nextStatuses: CM_InvoiceStatusByPriority input; _status: Integer; _prevStatus: Integer; _bank: CM_Bank);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation  TFS CR 55305 TASK 55537

*/

vars

begin
	if _status = CM_Invoice.INVOICE_OPEN then
		if _bank.userCanSet(CM_Invoice.INVOICE_DISPUTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_DISPUTED]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_PREPEND) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PREPEND]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_PREPEND then
		if _bank.userCanSet(CM_Invoice.INVOICE_DISPUTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_DISPUTED]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_PENDING then
		if _bank.userCanSet(CM_Invoice.INVOICE_POSTED) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED]);
		endif;
		if _bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_POSTED then // if invoice needs to be returned
		if _bank.userCanSet(CM_Invoice.INVOICE_POSTED_REVERSE) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_DISPUTED then
		if _bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_SUSPENSE then
		if _bank.userCanSet(CM_Invoice.INVOICE_VOID) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
		
	elseif _status = CM_Invoice.INVOICE_VOID then // TFS 39618 PATCH 1
		if _bank.userCanSet(CM_Invoice.INVOICE_PENDING) then
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]); // TFS 39618 PATCH 1
		endif;
	endif; // other statuses eg. Posted Reversed, Posted Credit can't be changed	

epilog

end;</source>
        <Parameter name="_nextStatuses" type="CM_InvoiceStatusByPriority" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_prevStatus" type="Integer"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="isPelindo1Process" id="7a123efb-796e-4246-889a-f1204f698ccc">
