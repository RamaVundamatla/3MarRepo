    <JadeMethod name="canUserRunReport" id="7f8ba556-d44d-4c86-a9fd-0178cd69e5d1">
        <source>canUserRunReport(_user: CM_User): Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	class : Class;

begin
	
	class := inheritMethod(_user);
	if class &lt;&gt; null then
		return class;
	endif;
	
	if not _user.canUserAccessObj(self.getMyConsignee, CM_ConsigneeConsignor) then
		return CM_ConsigneeConsignor;
	endif;
	
	return null;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="clear" id="e2e48526-c2d5-4992-8f4d-3fc4481a9f8f">
        <updating/>
        <source>clear() updating;

vars

begin

	self.setMyVoyageGlobal( null );
	self.allLogLots.clear;
	self.myOperator := null;
	self.setMyDischargePort( null );
	self.setMyConsignee( null );
	self.showWeightColumn := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="5f0834ba-765d-4bc9-ba54-12c711bfd410">
        <updating/>
        <source>cloneReferences(_obj: CMQF_SOHLocationLog; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	self.allLogLots.clear();
	_obj.allLogLots.copy(self.allLogLots);
	
	self.setMyVoyageGlobal( _obj.getMyVoyageGlobal );
	self.setMyDischargePort( _obj.getMyDischargePort );
	self.setMyConsignee( _obj.getMyConsignee );
	self.showWeightColumn 			:= _obj.showWeightColumn;

end;</source>
        <Parameter name="_obj" type="CMQF_SOHLocationLog"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="d3d76db0-b5cf-4dbb-ae4e-c0127109670f">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	location	: CM_LogVoyageController;
	soh			: CM_SOHLocation;
	iter,
	iter2		: Iterator;
	ls			: Boolean;
	tmpLogLot	: CM_LogLot;
	voyage		: CM_Voyage;
	breakOut	: Boolean;
	failedDAC  :CM_DataAccessController;
begin
	
	app.cmsBeginLoad(ls);

	if self.getMyVoyageGlobal &lt;&gt; null then	
		sharedLock(self.getMyVoyageGlobal);
		foreach voyage in self.getMyVoyageGlobal.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do : voyageLoop
//			if (not CM_LogVoyage.hasInstance(voyage)) then
			if (voyage.myLogVoyageStructure = null) then			
				continue;
			endif;
			
			delete iter;
//			iter := voyage.CM_LogVoyage.allLocationsByHatchPlaceLot.createIterator;
			iter := voyage.myLogVoyageStructure.allLocationsByHatchPlaceLot.createIterator;
			while iter.next(location) do : voyageLocationLoop
				sharedLock(location);
				delete iter2;
				iter2 := location.allProductLocations.createIterator;
				while iter2.next(soh) do
					sharedLock(soh);
					if self.myOperator = null 
					or self.myOperator = soh.myOperator then
					   
						if not soh.canUserAccessSelf(null, failedDAC, app.myPassport) then
							continue;
						endif;
						
						tmpLogLot := location.myLogLot;
						
						if self.allLogLots.isEmpty or 
						   self.allLogLots.includes(tmpLogLot) then
							if (self.getMyConsignee = null or self.getMyConsignee = location.myLogLot.myConsignee) and
						      (self.getMyDischargePort = null or self.getMyDischargePort = location.myLogLot.myDischargePort)	then
						      	if self.checkStatusIncludesObject(location, _passport, breakOut) then
//						if self.includesObject(location, _passport, breakOut) then
									_collection.add(soh);
//							if breakOut then
///							break voyageLoop;
//							endif;
								endif;
							endif;
						endif;
					endif;		
				endwhile;
			endwhile;
		endforeach;
	endif;
	
epilog

	app.cmsEndLoad(ls);
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2229dc05-92bc-4f25-9129-ad94678ce060">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate,oid);
/*
	if _attrName = ETRow_SrcLocation then
		return self.sourceLocation;
	elseif _attrName = ETRow_SrcSubLocation then
		return self.sourceSubLocation;
	elseif _attrName = ETRow_SrcSubSubLocation then
		return self.sourceSubSubLocation;
		
	elseif _attrName = ETRow_DischargePort then
		if self.myDischargePort &lt;&gt; null then
			return self.myDischargePort.code;
		endif;
	elseif _attrName = ETRow_Consignee then
		if self.myConsignee &lt;&gt; null then
			return self.myConsignee.code;
		endif;
	elseif _attrName = ETRow_ShowWeight then
		return self.showWeightColumn.cnEcGetTableCheckBoxValue;
	
	endif;
	
	
	
	return inheritMethod(_attrName, _getCalculatedDate);
	*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyConsignee" id="b15919f7-dcab-4b47-9320-ac80541b369b">
        <source>getMyConsignee():CM_ConsigneeConsignor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_ConsigneeConsignor;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myConsignee;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getMyDischargePort" id="550ccbea-415c-4cda-93b4-3b217acc3374">
        <source>getMyDischargePort():CM_Port;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Port;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myDischargePort;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="1005b5e5-f648-47eb-91e6-4cfcda1fa342">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_SrcLocation then
		return self.sourceLocation;
	elseif _attrName = ETRow_SrcSubLocation then
		return self.sourceSubLocation;
	elseif _attrName = ETRow_SrcSubSubLocation then
		return self.sourceSubSubLocation;
		
	elseif _attrName = ETRow_DischargePort then
		if self.getMyDischargePort &lt;&gt; null then
			_oid := self.getMyDischargePort.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyDischargePort.code;
		endif;
	elseif _attrName = ETRow_Consignee then
		if self.getMyConsignee &lt;&gt; null then
			_oid := self.getMyConsignee.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyConsignee.code;
		endif;
	elseif _attrName = ETRow_ShowWeight then
		return self.showWeightColumn.cnEcGetTableCheckBoxValue;
	
	endif;
	
	
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="f2729c21-1977-49c5-ac4d-c45037e4224a">
        <updating/>
        <source>includesObject(_lc: CM_LocationsController; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	querySelf			: CMQF_SOHLocationLog;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	querySelf.numFound := querySelf.numFound + 1;
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
