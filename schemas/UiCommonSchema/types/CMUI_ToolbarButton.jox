    <JadeMethod name="drawCharacter" id="b84faca3-927f-47a6-bdee-b50bdcd0a29e">
        <source>drawCharacter(_fontName : String; _character : Character; _colour : Integer);
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     Draw the character on the picture control so that it does
//				not get cleared out when we do clearGraphics on the borders
// ---------------------------------------------------------------------------
vars
	pic		: CMUI_ToolbarPicture;
	tmpColour	: Integer;
	middle : Real;
begin

	pic := self.myToolbarPicture;
	if pic = null then
		return;
	endif;

	if self.enabled then
		tmpColour	:= _colour;
	else
		tmpColour	:= Gray;
	endif;
	
	middle :=  pic.width / 2; // ### TFS 50421 27OCT2021 NAVAB1
	
	pic.clearGraphics();
	pic.drawFontName	:= _fontName;
	pic.drawFontBold 	:= false;
	pic.drawFontSize 	:= 20; // ### TFS 50421 27OCT2021 NAVAB1 was 12;
	pic.drawTextAlign := Picture.DrawTextAlign_Center;  // ### TFS 50421 27OCT2021 NAVAB1
	pic.drawTextAt(_character,middle, 0, tmpColour);
	
	
	
	pic := self.myToolbarPictureCaption;
	if pic = null then
		return;
	endif;

	if self.enabled then
		tmpColour	:= _colour;
	else
		tmpColour	:= Gray;
	endif;
	
	middle :=  pic.width / 2; // ### TFS 50421 27OCT2021 NAVAB1
	
	pic.clearGraphics();
	pic.drawFontName	:= _fontName;
	pic.drawFontBold 	:= false;
	pic.drawFontSize 	:= 20; // ### TFS 50421 27OCT2021 NAVAB1 was 12;
	pic.drawTextAlign := Picture.DrawTextAlign_Center;  // ### TFS 50421 27OCT2021 NAVAB1
	pic.drawTextAt(_character,  middle, 0, tmpColour);
	
	
end;</source>
        <Parameter name="_fontName" type="String"/>
        <Parameter name="_character" type="Character"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawString" id="36f31033-b5c7-4464-bf83-9fcc467f6f4c">
        <source>drawString(_fontName : String; _label : String; _colour : Integer);
// ---------------------------------------------------------------------------
// Created:		April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pic		: CMUI_ToolbarPicture;
	tmpColour	: Integer;
begin

	pic := self.myToolbarPicture;
	if pic = null then
		return;
	endif;

	if self.enabled then
		tmpColour	:= _colour;
	else
		tmpColour	:= Gray;
	endif;
	
	pic.clearGraphics();
	pic.drawFontName	:= _fontName;
	pic.drawFontBold 	:= false;
	pic.drawFontSize 	:= 12;
	pic.drawTextAt(_label, 0, 0, tmpColour);
	
	

	pic := self.myToolbarPictureCaption;
	if pic = null then
		return;
	endif;

	if self.enabled then
		tmpColour	:= _colour;
	else
		tmpColour	:= Gray;
	endif;
	
	pic.clearGraphics();
	pic.drawFontName	:= _fontName;
	pic.drawFontBold 	:= false;
	pic.drawFontSize 	:= 12;
	pic.drawTextAt(_label, 0, 0, tmpColour);
	
end;</source>
        <Parameter name="_fontName" type="String"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enabled" id="ae4c9068-6cad-4258-905c-af667629abc1">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>enabled(_set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 25/10/2012	cnwcs5	par 28376  - redraw button when enabling it
vars
	btn	:CMUI_ButtonForToolbar;
begin
	inheritMethod(_set, _value);
	
	btn := self.myButtonForToolbar;
	
	if btn = null or self.style = Button.Style_Normal then
		return;
	endif;
	
	// if we are enabling the button and it is a two state button
	// then we need to redraw the button
	if _set and _value then
		if btn.value then
			self.drawButtonDown;
		else
			self.drawButtonNormal;
		endif;
	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
