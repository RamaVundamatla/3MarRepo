<Class name="CMIF_CargoReviewCustDocAgent" id="ca3091c2-e135-440a-aed5-94b23d16ef4c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="customs"/>
    <Constant name="TrackedByQuantity" id="38047244-212d-48fe-9242-07070fec6e06">
        <source>'quantity'</source>
        <type name="String"/>
    </Constant>
    <Constant name="TrackedByVolume" id="64416190-679c-4d99-9b81-381308799940">
        <source>'volume'</source>
        <type name="String"/>
    </Constant>
    <Constant name="TrackedByWeight" id="68d2d751-4a05-4915-b137-2ea6f98e50a5">
        <source>'weight'</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="allCargoReviewCustDocDetails" id="64a5a6c1-e82f-4e68-aef9-629a818a9d62">
        <memberTypeInverse/>
        <type name="CMIF_CRCustDocDetailByCodes"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTIs" id="e47b60fd-36fd-43ee-a7a3-7e663703d8e4">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="displayQuantity" id="62fa06a5-8793-4e12-aa8a-3088e44eea18">
        <embedded/>
