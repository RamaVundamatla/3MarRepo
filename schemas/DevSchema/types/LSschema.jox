        <type name="LSclassByName"/>
        <Inverse name="LSclass::mySchema"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="allConstants" id="72cfbba0-13da-4cdc-a56b-b5a034ce4576">
