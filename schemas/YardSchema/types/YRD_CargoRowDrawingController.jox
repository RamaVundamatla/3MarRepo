    <JadeMethod name="notableObjectArmNotes" id="ee7565c3-3629-4704-a831-05b463b856b7">
        <source>notableObjectArmNotes(_obj: Object);
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
