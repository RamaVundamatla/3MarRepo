    <JadeMethod name="isPaginated" id="ecf533d2-bec5-47ea-9116-803ab751434b">
        <source>isPaginated() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"

*/

vars

begin
	return self.myPaginationParams &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPaginatedNotification" id="e7303196-76ac-496e-93cc-16a2a51c1acc">
        <source>isPaginatedNotification() : Boolean;
/*

Purpose:			Check whether the table is paginated, and whether the form is listening to notification

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2025	navkc1 JIRA MTN 34973 MTN | Pagination - Work Order Enquiry

*/

vars
	baseform : CM_BaseForm;
begin
	
	if self.form.isKindOf(CM_BaseForm) then
		baseform := self.form.CM_BaseForm;
	endif;
	
	return self.isPaginated() and self.myPaginationParams.doNotify and (baseform &lt;&gt; null and baseform.notificationLevel = baseform.NoteLevelDoNotes);
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="dbdfe3be-0e4d-4be1-8cff-d22ab664cc2a">
        <updating/>
        <source>keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: JadeTableRow;
	theObject	: Object;
	col : Integer;
begin

	inheritMethod(table, keyCode, shift);
	

	if table.CM_DataTable.multiSelect &lt;&gt; MultiSelect_None then
		if shift.bitAnd(2) &lt;&gt; 0 then
			self.controlKeyDown := true;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyUp" id="36a0771a-0c49-45ad-8f77-c27da3a0705a">
        <updating/>
        <source>keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(table, keyCode, shift);

	if table.CM_DataTable.multiSelect &lt;&gt; MultiSelect_None and shift.bitAnd(2) = 0 then
		self.controlKeyDown := false;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="1e78414e-a5e2-4a4a-901a-1f7a68d394b6">
        <updating/>
        <source>lostFocus(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(table);
	
	self.fromMouseDown := false;

	if self.controlKeyDown then
		self.controlKeyDown := false;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="bb56cf27-41a1-4ab0-9259-3867e40dbd7d">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	jRow			: JadeTableRow;
	selectFrom,
	selectTo,
	idx,
	currentRow,
	initRow,
	startIdx,endIdx: Integer;
	iter : Iterator;
	obj, currentObj : Object;
begin
	self.origXPos 			:= x;
	self.origYPos 			:= y;
	self.longStart 			:= app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.longLeftClick 		:= false;
	self.longRightClick 	:= false;
	self.longDidDBLClick 	:= false;


	self.fromMouseDown := true;

	inheritMethod(table, button, shift, x, y);

	if table.CM_BaseTable.multiSelect = MultiSelect_None then	
		self.controlKeyDown := false;
		return;
	endif;
	//test control  held
	if shift.bitAnd(2) &lt;&gt; 0 then
		self.controlKeyDown := true;
	else
		self.controlKeyDown := false;
	endif;
	
	currentRow := self.row;
	//test shift held
	if shift.bitAnd(1) = 0 then
		self.initialSelectRow := currentRow;
		//jlier1 9/6/25 MTN-34771
		jRow := accessRow(currentRow);
		if jRow &lt;&gt; null then
			self.myInitialSelectObject:=jRow.itemObject;
		endif;
		
		if not self.controlKeyDown and	// 31434 April 2013 restore Control button clearing the selection
		not button = 2 and	//26 Feb 2014	NDL	Par 33483 - right click to get context menu don't want to add the last one we de-selected
		//06 Sep 2012	NDL	Par 30217
		   currentRow &gt; self.fixedRows and currentRow &lt;= self.rows then
			
			if jRow &lt;&gt; null and jRow.visible and not jRow.selected then
				// This can occur when the the form has been updated by a note and the current row is no longer selected.
				// the effect is that the click appears not to action until the user forces a row column change.
				self.selectRow(currentRow,false);
			endif;
		endif;

		
		return;
	endif;

	self.clearAllSelected();
	initRow := self.initialSelectRow;
	if (initRow &lt;= self.fixedRows) or (initRow &gt; self.rows) then

		return;
	endif;

	//jlier1 9/6/25 MTN-34771
	if self.isPaginated then
		if not self.findObjectInRow(self.myInitialSelectObject,initRow) then
			jRow := accessRow(currentRow);
			currentObj:=jRow.itemObject;		
			initRow:=self.fixedRows + 1;
			iter:=self.getCollection.createIterator;
			startIdx:=self.getCollection.indexOf(self.myInitialSelectObject);
			endIdx:=self.getCollection.indexOf(currentObj);
			if startIdx &lt; endIdx then
				iter.startAtObject(self.myInitialSelectObject);
				initRow:=2;
			else
				iter.startAtObject(currentObj);
				initRow:=self.rows; //
			endif;
		
			while iter.next(obj) do
				self.allSelectedObjects.tryAddIfNotNull(obj);
				if startIdx &lt; endIdx then
					if obj = currentObj then
						break;
					endif;
				else
					if obj = self.myInitialSelectObject then
						break;
					endif;
				endif;		
			endwhile;
		endif;
	endif;
	
	
	selectFrom := initRow.min(currentRow);
	selectTo := initRow.max(currentRow);
	foreach idx in selectFrom to selectTo do
		jRow := accessRow(idx);
		if not jRow.visible then
			//dont select invisible rows - JC
			continue;
		endif;
		//epr par 23089 15/3/10
		self.selectRow(idx,false);
		
	endforeach;

epilog
	delete iter;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
