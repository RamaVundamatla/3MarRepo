    <JadeMethod name="addCargoItemMoved" id="77926875-d895-40a1-8e5a-48595d08f344">
        <source>addCargoItemMoved( _ti : CM_TrackedItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
19 November 2010	cnwrd1	Initial creation
08 May 2023			navpw1	TFS: 57643 - Added date to the end of Id to make it the same as PortSchema::CM_TrackedItem::setBulkReleaseReleased. Was causing duplictaes in collection

*/

vars
	rtsf : String;
	date : Date;	// ### TFS 57643 08May2023 NAVPW1
	
begin
	rtsf := _ti.id &amp; Tab &amp; date.format("ddd dd MMM yy");
	//rtsf := _ti.id;	// ### TFS 57643 08May2023 NAVPW1
	if not self.releasedItemStrings.includes(rtsf) then
		self.releasedItemStrings.add(rtsf);	
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addRequestFromProxy" id="4653d415-b4c2-4f82-a94a-183b42f60f13">
        <source>addRequestFromProxy(pProxyRequest : CM_Request);
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRequest	: CM_Request;
	
begin

	pProxyRequest.raiseExceptionIfNotTransient(method);

	create theRequest as pProxyRequest.class persistent;
	
	theRequest.setBulkRelease(self);		//shifted up so we can tell the dif btwn release req's and bulk rel. req's in set method
	theRequest.setForCreate(pProxyRequest);
	
end;</source>
        <Parameter name="pProxyRequest" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="addReserveFromProxy" id="c9e60e4d-e321-435a-9953-017a4eef26cf">
        <updating/>
        <source>addReserveFromProxy(_pxyReserveDetail : CM_ReserveDetail):CM_ReserveDetail updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	newReserveDetail	: CM_ReserveDetail;
	
begin
	_pxyReserveDetail.raiseExceptionIfNotTransient(method);

	create newReserveDetail as _pxyReserveDetail.class persistent;
	newReserveDetail.setPackType(_pxyReserveDetail.packType);
	newReserveDetail.setMyHeader(self);
	newReserveDetail.setForCreate(_pxyReserveDetail);
	
	return newReserveDetail;
end;</source>
        <Parameter name="_pxyReserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="addReserveTiReleased" id="47c3ccd7-2a8f-477e-bd53-aa7c1185ea90">
        <updating/>
        <source>addReserveTiReleased(_ti : CM_TrackedItem input; _errLinkObject : Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19/08/2024		navcs2	Bug 65450: Release Request is not updated with the corrected data on the vehicle visit
*/
vars
	tmpReserveTI	: CM_ReserveTI;
	tmpReserveSel	: CM_ReserveSelection;
begin	
	if _ti.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, '_ti should be persistent');
		return;
	endif;
	
	if self.allTrackedItemsAssigned.includes(_ti) then
		return;
	endif;
	
	if self.releaseByType then
		tmpReserveSel := self.getMatchingReserveSelection(_ti);
		if tmpReserveSel = null then
			app.raiseCMException3(NoReleaseDtlLineFound, self.code, _ti.cargoTypeDescr, _ti.id, null, _errLinkObject);
			return;
		endif;
		
		tmpReserveSel.addTI(_ti);
	else
		create tmpReserveTI persistent;
		tmpReserveTI.setMyHeader(self);
		tmpReserveTI.addTIReleased(_ti);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_errLinkObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addTIAssigned" id="25537206-64a4-4cfa-99bd-394accff672f">
        <updating/>
        <source>addTIAssigned(	_ti : CM_TrackedItem input;
				_packType : Integer	// #26529 10/01/2011. If _packType not null, a ti will be assigned to a corresponding reserve line on a bulk release. It is used for packing/unpacking in the Pack/Unpack screen.
				) updating;

/*
Date		Who		Reason
28 January 2010	cnwrd1	Initial creation

*/

vars
	woSource			: CM_WorkOrderTISource;
	reserveDetail		: CM_ReserveDetail;
	bestMatch			: CM_ReserveDetail;
	reserveCollection	: CM_ReserveDetailSet;
	trx  : CM_RelRequestAssign;
begin

	if not self.allTrackedItemsAssigned.includes(_ti) then
		self.allTrackedItemsAssigned.add(_ti);
		//16 May 2016	NDL	TFS 1995
		if not self.isTransient and not _ti.isTransient then	
			self.createAssignedTransaction( _ti, false );	
		endif;
	endif;

	if _ti.isOnSite() then // but am on site
		foreach woSource in  self.allWorkOrderSources do
			woSource.addTrackedItemToParent( _ti );
		endforeach;
	endif;
	
	/* #26529. 31/12/2010. 
	---------------------------------------------------------------------
					MANAGING RESERVE LINES - START
	---------------------------------------------------------------------
	When a child is unpacked, it should be shown as not packed in the Release Requests screen.
	When a container was unpacked and it is empty now, it should be shown as not packed, too.
	In this case, when unpacking, ti reference should be removed from reserveDetail.allTrackedItemsReleased collection and added to reserveDetail.allTrackedItems.
	*/
	foreach reserveDetail in _ti.allReserveDetails do
		if reserveDetail.myReserveHeader = self then
			reserveDetail.addTI(_ti);
			//break;
			return;
		endif;
	endforeach;
	
	foreach reserveDetail in _ti.allReserveDetailsReleased do
		if reserveDetail.myReserveHeader = self then
			reserveDetail.addTI(_ti);
			
			//break;
			return;
		endif;
	endforeach;
	
	// #26529 10/11/2011
	// It will try to find the best matching reserve. 
	// Logic copied from CM_BulkRelease.addTIReleased()
	if _packType = CM_ReserveDetail.PackType_Child then
		reserveCollection := self.allReservePackingChildren;//try to match it with a child packing line
	elseif _packType = CM_ReserveDetail.PackType_Parent then
		reserveCollection := self.allReserveDetails;		//try to match it with a parent packing line
	else
		return;  // don't attach to any reserve line
	endif;
	
	foreach reserveDetail in reserveCollection do 		
		if reserveDetail.CM_ReserveSelection.myCargoType = _ti.myCargoType then
			bestMatch := reserveDetail;
			if reserveDetail.CM_ReserveSelection.isMatchForISOTypeProduct(_ti, true) then
				break;
			endif;
		endif;
	endforeach;
	
	if bestMatch = null and reserveCollection.size &gt; 0 then
		bestMatch := reserveCollection.first;
	endif;

	if bestMatch &lt;&gt; null then
		//bestMatch.addTIReleased(_ti);
		bestMatch.addTI(_ti);
	endif;
	/*
	---------------------------------------------------------------------
					MANAGING RESERVE LINES - END
	---------------------------------------------------------------------
	*/
	
epilog

end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTIReleased" id="37ccd544-2da3-4a6d-afe3-905bbcda60cb">
        <source>addTIReleased(_ti : CM_TrackedItem input; _packType : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	reserveDetail		: CM_ReserveDetail;
	bestMatch			: CM_ReserveDetail;
	reserveCollection	: CM_ReserveDetailSet;
begin
	//first look to see if the item is already assigned to a rserve selection - if so
	//use this one regarless of you well it may or may not match cargo type/ISO type/product etc.
	// Need to check both the assigned and released collections
	foreach reserveDetail in _ti.allReserveDetails do
		if reserveDetail.myReserveHeader = self then
			reserveDetail.addTIReleased(_ti);
			return;
		endif;
	endforeach;
	foreach reserveDetail in _ti.allReserveDetailsReleased do
		if reserveDetail.myReserveHeader = self then
			reserveDetail.addTIReleased(_ti);
			return;
		endif;
	endforeach;
	
	if not self.releaseByType then
		return;//should have been assigned to a CM_ReserveTI and thus resolved above
	endif;
	
	//if we got are here, then the item was not previously assigned to a packing line
	// Par 19222 The rest of the code has been refactored to make it sensible
	// It will try to find the best matching reserve
	if _packType = CM_ReserveDetail.PackType_Child then
		reserveCollection := self.allReservePackingChildren;//try to match it with a child packing line
	else
		reserveCollection := self.allReserveDetails;		// Par 19222
	endif;
	
	foreach reserveDetail in reserveCollection do 		
		if reserveDetail.CM_ReserveSelection.myCargoType = _ti.myCargoType then
			bestMatch := reserveDetail;
			if reserveDetail.CM_ReserveSelection.isMatchForISOTypeProduct(_ti, true) then
				break;
			endif;
		endif;
	endforeach;
	
	if bestMatch = null and reserveCollection.size &gt; 0 then
		bestMatch := reserveCollection.first;
	endif;

	if bestMatch &lt;&gt; null then
		bestMatch.addTIReleased(_ti);
	endif;
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="allocTIsForRelease" id="bf6db8ba-011f-4314-828c-e74c8e712db2">
        <updating/>
        <source>allocTIsForRelease(_trackedItems : CM_TIArray; _doNotAssignTI : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	
begin
	self.allTrackedItemsAssigned.clear;
	
	if _doNotAssignTI then
		// Bulk Release is being created for Gate Out process only 
		// i.e. not created via the Empty Release Request form
		// Don't add ti to the assigned collect as subsequent releases with the same number
		// will not pass the validation that check to see if the TI is assigned
		return;
	endif;
	
	if _trackedItems = null then
		return;
	endif;
	
	//trackedItems.copy(self.allTrackedItemsAssigned);
	
	foreach ti in _trackedItems do//cnwrd1 ccms 1075 28.1.2010
		self.addTIAssigned( ti, null);
	endforeach;
	
end;</source>
        <Parameter name="_trackedItems" type="CM_TIArray"/>
        <Parameter name="_doNotAssignTI" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIToBulkRelease" id="ff590e43-d176-4d7f-8802-cf2b20cc92b1">
        <updating/>
        <source>assignTIToBulkRelease(_ti : CM_TrackedItem input; _errLinkObject : Object) updating;
/* ---------------------------------------------------------------------------
Created:     09 March 2010 by cnwrs2

Purpose:    Adds the ti to this bulk release.  
			Assumes that both self and the TI passed in are persistent
			
Change Date	Who		Reason
21 Aug 2024 navsp1  TFS Bug 65496: CUX | POST/releaseRequest by Id - Issues on Total Quantity Field
------------------------------------------------------------------------------*/
vars
	tmpReserveTI	: CM_ReserveTI;
	tmpReserveSel	: CM_ReserveSelection;
begin

	self.raiseExceptionIfNotTransient(method);
	
	if _ti.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, '_ti should be persistent');
		return;
	endif;
	
	if self.allTrackedItemsAssigned.includes(_ti) then
		// ti is already assigned
		return;
	endif;
	
	if self.releaseByType then
		tmpReserveSel := self.getMatchingReserveSelection(_ti);
		if tmpReserveSel = null then
			app.raiseCMException3(NoReleaseDtlLineFound, self.code, _ti.cargoTypeDescr, _ti.id, null, _errLinkObject);
			return;
		endif;
		
		tmpReserveSel.addTI(_ti);
	else
		// need to add a reserve ti
		create tmpReserveTI transient;			// 37189 was persistent
		tmpReserveTI.setMyHeader(self);
		tmpReserveTI.addTI(_ti);
		if _ti.myCargoType.isTrackByWeight or _ti.myCargoType.isTrackByVolume then	//TFS 65496
			tmpReserveTI.setWeightRequested(_ti.totalWeight);						//TFS 65496
		else																		//TFS 65496
			tmpReserveTI.setTotalRequested(_ti.totalQuantity);						//TFS 65496
		endif;																		//TFS 65496
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_errLinkObject" type="Object"/>
    </JadeMethod>
