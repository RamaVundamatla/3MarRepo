    <JadeMethod name="createQueuedMove" id="adad5734-d190-476d-ba28-281210384c36">
        <source>createQueuedMove(_lc : CM_LocationsController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
18 May 2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	moveController		: CMIF_MoveController;
	workOrder           : CM_WorkOrderTI;
	ti                  : CM_TrackedItem;
begin
	 
	workOrder  := self.myParent.CM_WorkOrderTI;
	ti		   := self.CM_WorkOrderTIDtl.allSelectedTIs.first();					//08.02.2023 navma1 #56457 Task#56458 
	create moveController transient;
	
	moveController.setMyTrackedItem(ti);	
	moveController.setAllOtherTrackedItems(self.CM_WorkOrderTIDtl.allSelectedTIs);	//08.02.2023 navma1 #56457 Task#56458
	moveController.allOtherTrackedItems.remove(ti);									//08.02.2023 navma1 #56457 Task#56458
	moveController.setMyToPrimaryLocation(_lc);
	moveController.setMoveMode(QUEUE_MODE);
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
	
epilog
	delete moveController; // 18/05/2022 53038 navcs2
end;</source>
