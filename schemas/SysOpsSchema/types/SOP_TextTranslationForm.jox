    <JadeMethod name="doSave" id="94b96fbc-b673-4884-b757-e97bb1a6d623">
        <updating/>
        <source>doSave():Boolean updating, protected;
/*
Date		Who		Reason
27 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/

vars
	result		: Integer;
	msgStr		: String;
	table		: CM_TextTranslationTable;
	proxy		: XLAT_TranslationsAndGCProxy;
	row			: Integer;
	text		: String;
	shortText	: String;
begin

	table := zGetTopTable;

	if self.myTranslatableText &lt;&gt; null then
		msgStr := 'Please confirm updating the selected translation';
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only + MsgBox_Stop_Icon);
		return true;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		displayTranslations();
		return true;
	endif;


	while true do
		// create a proxy object, and collate all text for each locale in the table
		create proxy transient;
		proxy.myTranslatableText := self.myTranslatableText;
		//********************************************************************************************************
		// 06/06/2008 BeeJay Par: N/A
		//********************************************************************************************************
		// When the XLAT_TranslationsAndGCProxy::myConstant is null then the code in XLAT_TranslationsAndGCProxy::zBuildXmlForFormControlConstan
		// will not correctly setup the following strings:  schemaName  className  controlName  controlProperty
		// This results in null strings in these fields in the underlying XML data in the associated global constant text.
		if self.myTranslatableText &lt;&gt; null then
			proxy.setConstant(self.myTranslatableText.myGlobalConstant);
		endif;
		//********************************************************************************************************

		foreach row in tblTranslations.fixedRows + 1 to tblTranslations.rows do
			text := tblTranslations.getCellText(row, Col_Text);
			if self.myTranslatableText.myCategory.usesShortText then
				shortText := tblTranslations.getCellText(row, Col_ShortText);
			endif;
			proxy.addText(tblTranslations.accessRow(row).itemObject.CM_Locale, text, shortText, self.myTranslatableText.myCategory);
		endforeach;

		// now do the update
		self.myAgent.trxUpdateTranslatableText(self.myTranslatableText, self.zGetTranslatableTextEdition(table), proxy, app.myPassport);

		// cnwjk3 PAR 18461 27/11/08
		// This does not look right to me, as the current code is not using the transaction framework correctly
		/*
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();

			// refresh the tables
			table.displayTranslatableText(self.myTranslatableText, table.row, colorRow1, colorRow2);
			displayTranslations;
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		*/
		break;
	endwhile;	

	return result = IDOK;
epilog
  	delete proxy;
	doBaseFormCancel;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="3ff30bde-225b-404a-bfe6-cc5d8dcb57eb">
        <updating/>
        <source>doSearch()updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: RBarr
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/02/2015	cnwdap1		PAR #35670 Added case insensitive option
vars
//	idx			: Integer;
	table 		: CM_TextTranslationTable;
	partsDone	: Integer;
	searchResults	: XLAT_SearchResults;
	
begin
	// clear each table
	foreach table in self.allDataTables do
		table.rows := table.fixedRows;
		table.refreshNow();
		// cnwrl1 03/11/2009 PAR 21295 - start of coding
		// clear any previous search results on each of the form sheets
		searchResults	:= self.myAgent.allSearchResults[ table.myTranslationCategory.constantCategoryName ];
		searchResults.allTranslatableText.clear();
		// cnwrl1 03/11/2009 PAR 21295 - end of coding
	endforeach;
	
	// set up filters from user settings

	// locales
	self.myLocale := cmbLocale.listObject.CM_Locale;

	// search phrase and words
	self.searchPhrase := txtSearch.text.trimBlanks;
	self.searchWords.clear();
	self.searchPhrase.getWords(self.searchWords);

	// to be reviewed flag
	self.toBeReviewed := chkFilterReview.value;
	
	// filter All / Any words option
	self.matchAll := chkAllWords.value;
	
	// refine existing search, or new global search?
	self.refineExisting := chkSearchTables.value;
	
	// search case-insensitive?										// PAR #35670
	self.caseInsensitive := self.chkInsensitive.value;				// PAR #35670
	
	// selected, or all categories?
	self.allCategories.clear();
	
	if chkTextMessages.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Exceptions]);
	endif;
	if chkFormCaptions.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_FormCaptions]);
	endif;
	if chkMenuEntities.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Menus]);
	endif;
	if chkPermissions.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Permissions]);
	endif;
	if chkReportNames.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_ReportNames]);
	endif;
	if chkTableEntities.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[EntTableRows]);
	endif;

	if self.allCategories.isEmpty() then
		app.msgBox("At least one category must be selected", self.caption, MsgBox_Stop_Icon);
		return;
	endif;
	
	statusLine.caption := "";
	statusLine.refreshNow();
	on Exception do searchExceptionHandler(exception);
	
	if self.chkTransForForm.value then
		if self.txtSearch.text = null then
			app.msgBox("Type in the name of a form in the 'search text' field", self.caption, MsgBox_Stop_Icon);
			self.txtSearch.setFocus();
			return;
		endif;
		self.myAgent.doShowTranslationsForForm(self.allCategories, self.txtSearch.text, self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
	elseif self.chkNumOnly.value then
		if self.txtSearch.text.isInteger() then
			self.myAgent.doNumberSearch(self.txtSearch.text.Integer,self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
		else
			self.myAgent.doConstantSearch(self.txtSearch.text,self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
		endif;
	elseif self.chkNoTransEntry.value then //+ cnwmd1, Par 20524
		if self.myLocale = null then	// 26733 Jan 2011 add option for all locales
			app.msgBox("Please select an actual locale", self.caption, MsgBox_Stop_Icon);
			self.cmbLocale.setFocus();
			return;
		endif;
		self.myAgent.doShowNoTranslationEntry(self.allCategories, self.myLocale, self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
	elseif self.searchWords.size() = 0 then
		if self.myLocale = null then	// 26733 Jan 2011 add option for all locales
			app.msgBox("Please select an actual locale", self.caption, MsgBox_Stop_Icon);
			self.cmbLocale.setFocus();
			return;
		endif;
		self.myAgent.doGlobalSearch(self.allCategories,
									self.myLocale,
									self.refineExisting,
									self.toBeReviewed,
									self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
	else
		self.myAgent.doKeywordSearch(self.allCategories,
									self.myLocale,
									self.matchAll,
									self.refineExisting,
									self.searchWords,
									self.toBeReviewed,
									self.caseInsensitive,										// PAR #35670
									self,
									SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
									SOP_TextTranslationForm::zUpdateProgressMonitor.name);
	endif;

	// show final amount
	self.myProgress.updateProgress(null, self.myProgress.partsInJob, self.myProgress.partsDone);
	self.zFinaliseProgressMonitor();
	statusLine.caption := self.myAgent.progressCount.String &amp; " rows found.";
	self.zInitialiseProgressMonitor(0, self.myAgent.progressCount, "Loading translatable text into tables");

	// populate each table
	foreach table in self.allDataTables do
		self.displayTranslatableText(table, partsDone);
	endforeach;		
	
	// hide the search frame
	if self.tblMessages.rows &gt; self.tblMessages.fixedRows then
		self.frmSearch.visible := false;
	endif;
	
	self.setButtonsEnabled();				// 10/08/2012 cnwmh5 #30187
	
	self.mode := self.Mode_View;
epilog	
	if self.myProgress &lt;&gt; null then
		self.zFinaliseProgressMonitor();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
