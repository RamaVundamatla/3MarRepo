    <JadeMethod name="exportSelf" id="25a202fd-f7fc-434b-ace4-842e54d58dc3">
        <source>exportSelf(_files : CM_ObjectArray; _attributes : StringArray) : Boolean ;
// ---------------------------------------------------------------------------
// Created:		12 December 2002 By Jason Chapman cnwjc2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property	:	Property;
	csvOutput	:	String;
	xmlOutput	:	String;
	object,
	fileObject	: 	Object;
	item 		:	CM_Object;
	int 		:	Integer;
	iter 		: 	Iterator;
	str,
	propName,
	tagString	:	String;
begin
	csvOutput := "";
	xmlOutput := "";
	
	int := self.class.name.pos('_',1);
	tagString := self.class.name[int+1:self.class.name.length];
	
	xmlOutput := CrLf &amp; ("&lt;"&amp;tagString&amp;"&gt;");
	
	foreach str in _attributes do
		//write str;
		property := self.class.getProperty(str);
		propName := property.getName;	
		if property.isKindOf(Attribute) then
			if property.type = StringArray then
				
				//foreach str in self.getPropertyValue(property.getName).StringArray do //this dosnt work
				//	message := message &amp; "," &amp; str;
				//endforeach;
				//_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
			else
				xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;"&amp;propName&amp;"&gt;"&amp;self.getPropertyValue(propName).String.trimBlanks&amp;"&lt;/"&amp;propName&amp;"&gt;");
				
				csvOutput := csvOutput &amp; ", " &amp; (self.getPropertyValue(propName).String.trimBlanks);
				
				
			endif;
		else
			
			object := self.getPropertyValue(propName).Object;
			if object &lt;&gt; null then
				if object.isKindOf(CM_Object) then
					//self.exportMyReferences(_file, _objArray, property);
					
					xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;"&amp;propName&amp;"&gt;"&amp;object.String.trimBlanks&amp;"&lt;/"&amp;propName&amp;"&gt;");
				
					csvOutput := csvOutput &amp; ", " &amp; (object.String.trimBlanks);
				
				elseif object.isKindOf(Collection) then
					//self.exportMyCollections(_file, _objArray, property);
					
					xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;"&amp;propName&amp;"&gt;");
				/*	iter := object.Collection.createIterator;
					while (iter.next(item)) do
	    				xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;"&amp;item.getName[1:item.getName.pos('/',1)-1]&amp;"&gt;"&amp;item.String&amp;"&lt;/"&amp;item.getName[1:item.getName.pos('/',1)-1]&amp;"&gt;");
						//don't output collections for csv
						//csvOutput := csvOutput &amp; ", " &amp; (object.String.trimBlanks);
					endwhile;
				*/	xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;/"&amp;propName&amp;"&gt;");
				endif;
			endif;
		endif;	
	endforeach;
	xmlOutput := xmlOutput &amp; CrLf &amp; ("&lt;/"&amp;tagString&amp;"&gt;");

	foreach fileObject in _files do
		//if fileObject.CM_TargetFileOLD.fileFormat = XML_FORMAT then	
		//	fileObject.CM_TargetFileOLD.file.writeString(xmlOutput);
		//elseif fileObject.CM_TargetFileOLD.fileFormat = CSV_FORMAT then
		//	fileObject.CM_TargetFileOLD.file.writeString(csvOutput[3:csvOutput.length] &amp; CrLf);
		//endif;
	endforeach;



	return true;
epilog

	delete iter;
end;</source>
        <Parameter name="_files" type="CM_ObjectArray"/>
        <Parameter name="_attributes" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportXSD" id="cad6354d-d02a-4a57-af59-4110776989ea">
        <source>exportXSD(_file:File; _objArray:ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property:Property;
	popColl:PropertyNDict;
	object: Object;
	str,message: String;
begin
	// check if we have already been called. if so bugger off. 
	if _objArray.includes(self) then
		return;
	else
		_objArray.add(self);
	endif;
	popColl := self.class.getProperties;
	_file.writeLine("&lt;"&amp;self.class.name&amp;"&gt;");

	foreach property in popColl do
		if property.isKindOf(Attribute) then
			if property.type = StringArray then
				foreach str in self.getPropertyValue(property.getName).StringArray do //this dosnt work
					message := message &amp; "," &amp; str;
				endforeach;
				_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
			else
				_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
				app.writeStatement(("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;"));
			endif;
		else
			object := self.getPropertyValue(property.getName).Object;
			if object &lt;&gt; null then
				if object.isKindOf(CM_Object) then
					self.exportMyReferences(_file, object, property);
				elseif object.isKindOf(Collection) then
					self.exportMyCollections(_file, _objArray, property);
				endif;
			endif;
		endif;	
	endforeach;
	_file.writeLine("&lt;/"&amp;self.class.name&amp;"&gt;");

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="formatAuditText" id="9bd79547-2b38-4375-b63f-235356570395">
