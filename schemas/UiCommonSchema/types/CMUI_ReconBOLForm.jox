    <JadeMethod name="setCaption" id="429ad3f5-94b2-437f-9163-bff9daa438d4">
        <updating/>
        <source>setCaption(_caption: String) updating;
//21 January 2010	cnwml2


vars
	str : String;
begin
	str := "BOL Reconciliation ";
	if _caption = str &amp; self.myTerminal.code then
		return;
	else
		inheritMethod(str);
	endif;
	

