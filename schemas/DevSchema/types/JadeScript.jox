    <JadeMethod name="eprTestEDIData" id="b327f7ad-462a-4edb-bb05-e95dc7a3c364">
        <source>eprTestEDIData();
/*

Date		Who		Reason
20 February 2017	cnwer1	Initial creation TFS

*/

vars
	dataTIs,
	dd				: DynaDictionary;	
	ediTi 			: CM_EDITrackedItem;
	ediData : CM_EDIData;
	iter : Iterator;
begin
	ediData :="10733.642896".asOid.CM_EDIData;
	ediTi:="2150.858386".asOid.CM_EDITrackedItem;
	
	//write ediTi.class.name;
	
	
	create dataTIs transient;
	dataTIs.setMembership(CM_EDITrackedItem);
	dataTIs.addExternalKey(String,30,false,true); //class name
	dataTIs.addExternalKey(String,30,false,false); //id
	dataTIs.endKeys(true);
	
	foreach ediTi in ediData.allEDITrackedItems do
		dataTIs.putAtKey(ediTi.class.name,ediTi.id,ediTi);	
	endforeach;
	
	foreach ediData in ediData.myEDIFile.allEDIData do
		foreach ediTi in ediData.allEDITrackedItems do
			dataTIs.putAtKey(ediTi.class.name,ediTi.id,ediTi);	
		endforeach;
	endforeach;
	
	iter:=dataTIs.createIterator;
	dataTIs.startKeyGeq("CM_EDIBookinItemTI",null,iter);
	
	while iter.next(ediTi) do
		
		if not ediTi.class = CM_EDIBookingItemTI then
			break;
		endif;
		write ediTi;
	endwhile;
	
dataTIs.inspect;
epilog
	delete iter;
	delete dataTIs;
end;</source>
    </JadeMethod>
