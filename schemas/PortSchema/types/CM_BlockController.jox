        <updating/>
        <source>initializeForActivityPrefix(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables;_gKey : String) updating;
/*
Purpose:			

Date		Who		Reason
27MAY2022	navsp1	TFS#53700
*/
vars
	opsviewtable : CMIF_SpatialBins;
	stack : CMIF_XpsStackStatus;
	terminal : CM_Terminal;
	block	: CM_BlockStack;
begin
	inheritMethod(_ewsOpsView,_opsViewTable,_gKey);
	if _opsViewTable.isKindOf(CMIF_SpatialBins) then
		opsviewtable 					:= _opsViewTable.CMIF_SpatialBins;		
		if _gKey &lt;&gt; null then
			opsviewtable.parent_bin_gkey := _gKey.Integer64;
		else
			opsviewtable.parent_bin_gkey := 0;
		endif;		
	elseif _opsViewTable.isKindOf(CMIF_XpsStackStatus) then
	endif;
end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
        <Parameter name="_gKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="isAvailForMultiMove" id="6305a223-dacb-4ae1-afc6-7899e7569a16">
        <source>isAvailForMultiMove(): Boolean;

/*

Purpose:			

Parameters:		determine if this location is available for
					a move during a multi cargo move ?	

Return Value:		


Date		Who		Reason
18 Nov 2011	cnwndl1	Initial creation	Par 28692

*/

vars

	termArea : CM_TerminalArea;
	blockStack : CM_BlockStack;
	
	itemCount : Integer;  //cnwrd1 31736 break bulk counting
begin

	itemCount := self.getTrackedItemCount();
	
	termArea := self.myTerminalArea;
	if termArea &lt;&gt; null and termArea.isKindOf( CM_BlockStack ) then
		blockStack := termArea.CM_BlockStack;
		if blockStack.enforceMaxCapacity and blockStack.maxCapacity &gt; 0 then
			if itemCount &gt;= blockStack.maxCapacity then   //cnwrd1 31736 break bulk counting
				return false;
			else
				return true;
			endif;
		else
			return true;
		endif;
	endif;
	
	return inheritMethod();
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
