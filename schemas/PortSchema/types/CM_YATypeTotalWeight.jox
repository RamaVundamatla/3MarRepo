    <JadeMethod name="isSnapShotDataMatch" id="dd361b2f-06c0-4b1b-8d10-fcb8be8e0424">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataString.value.Decimal = _propertyValue.Decimal or
	   _criteria.myYAData.CM_YADataString.value = null then
		return true;
	endif;
	
	return false;

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="c6e05da8-dcbd-4263-9581-084105035663">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*
Purpose:			 // TFS 4271
Date		Who		Reason
30 June 2017	cnwab1	Initial creation
*/

vars
	val : String;
begin
//	self.getCriteriaValueForTi( _ti, val);
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		val := _tiTrx.totalWeight.String;
	else
		self.getCriteriaValueForTi( _ti, val);
	endif;
	
	if _criteria.myYAData.CM_YADataString.doesValueMatch(val) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
