    <JadeMethod name="getAttrEmpty" id="ea7dc044-06c9-46e4-9189-ac83d5afb694">
        <source>getAttrEmpty() : Boolean;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria : CM_YACriteria;	
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;
	voyAlloc : CM_VoyageAllocation;
begin
	voyAlloc := self.allAllocations.first().CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
	if voyAlloc &lt;&gt; null then // 11/10/2022	navkc1	#54935
		//criteria := self.getAttrByType(YACriteriaType_CommodityGroup); 
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;	
			if commGroup &lt;&gt; null then
				return commGroup.isEmptyCommodity();
			endif;
		else
			//criteria := self.getAttrByType(YACriteriaType_Commodity); 
			criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_Commodity); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;	
				if comm &lt;&gt; null then
					return comm.isEmpty;
				endif;
			endif;
		endif;		
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
