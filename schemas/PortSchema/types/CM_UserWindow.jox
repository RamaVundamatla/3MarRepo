    <JadeMethod name="isSameAs" id="91a98eb7-a8fc-4501-8703-4885e47982e2">
        <source>isSameAs(_userWindow : CM_UserWindow) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 January 2008 by cnwrs2
//
// Purpose:     There have been some cases of users repeatedly opening the
//				same window.  When closing down it preserved all the same and
//				so reopened multiple copies on close down.  This method used
//				to compare windows for startup and eliminate duplicates
// ---------------------------------------------------------------------------
vars

begin
	if self.appName = _userWindow.appName and
	   self.height = _userWindow.height and
	   self.left = _userWindow.left and
	   self.top = _userWindow.top and
	   self.width = _userWindow.width and
	   self.windowClassName = _userWindow.windowClassName and
	   self.windowState = _userWindow.windowState and
	   self.xmlInfo = _userWindow.xmlInfo then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
