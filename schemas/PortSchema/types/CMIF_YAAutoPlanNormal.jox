    <JadeMethod name="isContentsStatus_Match" id="d1d780a0-edfb-4b3a-a9fc-1a578bac138d">
        <source>isContentsStatus_Match(_yaData: CM_YADataObjects): Boolean;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars

	contentsStatus	: CM_ContentsStatus;
	contents		: Integer;
	
begin

	contents := self.myTrackedItem.getContentsStatus();
	contentsStatus := app.myRoot.allContentsStatuses[contents];
	if contentsStatus = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(contentsStatus);


end;</source>
