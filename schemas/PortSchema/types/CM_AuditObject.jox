    <JadeMethod name="setSubject" id="0cf8acea-9b45-427f-b521-c85be16da5bd">
        <updating/>
        <source>setSubject(_subject : CM_Object) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011  cnwmh5	PAR #27142 - rmove exception handler as null check is suffient
*/

vars
	invalid			: Boolean;
	
begin
	// Inverse maintenance doesn't do anything if reference values are the same
	self.mySubject := _subject;
	
	if _subject &lt;&gt; null then
		///on Exception do app.handleDeletedObject(exception, _subject, invalid);
		self.subjectIdString := _subject.auditIdDisplay();
	endif;
end;</source>
