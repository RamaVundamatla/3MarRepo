    <JadeMethod name="getName" id="9f73bd0d-d5b1-4b1d-b46a-adf4bb06fa08">
        <source>getName(): String;
/*
Purpose:			
Date		Who		Reason
25 August 2011	cnwab1	Initial creation
*/

vars
	meTxt : String;
begin

	if self.isDischarge then
		meTxt := app.getErrorString(Discharge) &amp; " " &amp; self.numSeqForward.String;
	else
		meTxt := app.getErrorString(Load) &amp; " " &amp; self.numSeqForward.String;
	endif;
	
	if self.myROROController &lt;&gt; null and
	   global.isValidObject(self.myROROController) then
		meTxt := meTxt &amp; " " &amp; self.myROROController.getFullId();
	endif;
	
	meTxt := meTxt &amp; " " &amp; self.getAllocationISOGroup();
	
	return inheritMethod() &amp; " " &amp; meTxt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
