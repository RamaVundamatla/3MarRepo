    <JadeMethod name="cmbCalendar_click" id="114d482b-ddca-4e0a-b99f-683f45f8accf">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCalendar_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

	calendar : CM_Calendar;

begin

	calendar := self.cmbCalendar.listObject.CM_Calendar;
	
	if calendar &lt;&gt; null then
		self.txtTimeFrom.enabled := calendar.hasTime;
		self.txtTimeTo.enabled := calendar.hasEndTime;
	else
		self.txtTimeFrom.enabled := false;
		self.txtTimeTo.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
