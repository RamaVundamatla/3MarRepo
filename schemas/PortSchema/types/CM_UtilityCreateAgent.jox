    <JadeMethod name="utlCreateRTQueue" id="17e5fd1f-ad8d-44ec-bd5e-9ed6340bddb4">
        <source>utlCreateRTQueue(	_proxySubQueue			: CM_RadioTelemetryQueue input;
						_newSubQueue		: CM_RadioTelemetryQueue output;
						_allCriteria 		: CMIF_Array;
						_passport 			: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	theCloned : CM_SubQueue;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxySubQueue,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newSubQueue as _proxySubQueue.class persistent;
	_newSubQueue.setForCreate(_proxySubQueue,_passport);
	
	if _passport.noErrors and _allCriteria &lt;&gt; null then
		_newSubQueue.persistCriteria(_allCriteria, _passport);
	endif;

	if _passport.noErrors then
		_newSubQueue.causeEvent(_passport.myTerminal.getTerminalEvent(RTQueue_Create_Event), false, null);
		self.myCreateAuditAgent.audCreateGeneric(_newSubQueue);
	endif;	
end;</source>
