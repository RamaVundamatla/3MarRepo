		inheritMethod();	//closes the form
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2e88bf0f-0c9a-4a7b-8237-77e714ca57e5">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417
19 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
17 Jun 2021	navdap1	TFS 51362 ASPA Bulk Create
*/

vars

	prefix : String;
	number : Integer;
	msg : String;
	eventTypes : CM_EventTypeSet;
	pxyVoyage : CM_Voyage;
	result : Integer;
	voyCode : String;
	padLength : Integer;
	tis : CM_TIArray;						// TFS 50878
	vessels : CM_ObjectArray;				// TFS 50878
	pxyTi, newPxyTi : CM_TrackedItem;		// TFS 50878
	
begin

	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	
	// TFS 50878 start - refactor validation code
	if not self.validatePrefixAndNumber(true) then
		return false;
	endif;
	// TFS 50878 end
	
	if number &lt; 10 then
		padLength := 1;
	else
		padLength := 2;
	endif;
	
	create eventTypes transient;
	self.mulEvents.getSelected( eventTypes );
	
	voyCode := prefix &amp; 1.padLeadingWith('0',padLength);
	
	pxyVoyage := self.setPxyVoyage( voyCode );
	if pxyVoyage = null then
		return false;
	endif;
	
	// TFS 51362 Check cargo details and show warnings
	if self.chkCreateCargo.value then
		if self.cmbCargoType.listIndex &lt; 1 then
			if app.msgBox(app.getErrorString(No_cargo_will_be_created), app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Question_Mark_Icon) = MsgBox_Return_Cancel then
				return false;
			endif;
		elseif self.allTrackedItems.isEmpty then
			if app.msgBox(app.getErrorString(Not_specified_cargo_details), app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Question_Mark_Icon) = MsgBox_Return_Cancel then
				return false;
			endif;
		endif;
	endif;
	// TFS 51362 end
	// TFS 50878 setup, validation
	self.setCargoDetails(pxyVoyage);
	create tis transient;
	create vessels transient;
	if self.chkCreateCargo.value and self.allTrackedItems.isEmpty then
		app.msgBox(app.getErrorString(Create_cargo_no_details), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	// TFS 50878 end setup, validation
	
	while true do
		app.mousePointer :=	Busy;
		
		// need to clone tis because utlCreateTrackedItem deletes the proxy
		tis.purge;													// TFS 50878
		foreach pxyTi in self.allTrackedItems do					// TFS 50878
			newPxyTi := pxyTi.cloneSelf(true);						// TFS 50878
			newPxyTi.cloneReferences(pxyTi, null, app.myPassport);	// TFS 50878
			tis.add(newPxyTi);										// TFS 50878
		endforeach;													// TFS 50878
		vessels.clear;												// TFS 50878
		self.allVessels.copy(vessels);								// TFS 50878
		
		//app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, prefix, number, padLength, app.myPassport );				// TFS 50878
		app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, prefix, number, padLength, tis, vessels, app.myPassport );	// TFS 50878
		
		if app.myPassport.trxCompletedOK then
			return true;
			break;
			
		else
			app.mousePointer :=	Idle;
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
	
		endif;
		return false;
		
	endwhile;
	
	return false;

epilog

	delete pxyVoyage;
	delete eventTypes;
	if tis &lt;&gt; null then			// TFS 50878
		tis.purge;				// TFS 50878
	endif;						// TFS 50878
	delete tis;					// TFS 50878
	delete vessels;				// TFS 50878
	app.mousePointer :=	Idle;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCargoDetailsForm" id="54eb991d-89db-40b1-8f1e-1822f7a6dfb2">
        <updating/>
        <source>doShowCargoDetailsForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	form : SHP_BulkBargeCargoDetails;
	prefix, voyCode : String;
	number, padLength : Integer;

begin
	if not self.validatePrefixAndNumber(true) then
		return;
	endif;
	if self.cmbVessel.listIndex &lt; 0 then
		app.msgBox(app.getErrorString(Input_required_field_vessel), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(SHP_BulkBargeCargoDetails, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_BulkBargeCargoDetails;
	form.myBulkCreateForm := self;
	form.setBulkCargoAndVessels(self.allTrackedItems, self.allVessels);
	form.showModal();
	// if the cargo details form gave us back some TIs, then disable the cargo details on this form
	if form.modalResult = IDOK and self.allTrackedItems.size &gt; 0 then
		self.doEnableDisableCargoFields(false);
	endif;
	
epilog
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="5e9dbdc8-baa9-4455-9386-517240908afe">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation

*/

vars

	xml		: String;

begin

	xml	:= inheritMethod();
	if self.myCurrentVessel &lt;&gt; null then
		xml := xml &amp;  global.formatAsXML( self.cmbVessel.name, self.myCurrentVessel.name );
	endif;
	
	return xml;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="238742b6-5250-48af-9d87-7790d9cc4a3a">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	xmlInfo : String;
	vesselName : String;
	pos : Integer;

begin

	self.myCurrentVessel := null;
	
	inheritMethod(_userWindow);
	
	xmlInfo :=	_userWindow.xmlInfo;
	vesselName := xmlInfo.cnEcGetNextTagValueOfName(self.cmbVessel.name, pos);
	
	if vesselName &lt;&gt; null then
		self.myCurrentVessel := app.myRoot.allVesselsByName.getAtKey( vesselName );
	endif;
	
	

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="onCargoSubTypeChange" id="49805d00-fed3-4437-b4b4-c3a4ddc91e6a">
        <updating/>
        <source>onCargoSubTypeChange(_cargoSubType : CM_Product) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	measureType : CM_MeasurementType;

begin
	if _cargoSubType = null then
		return;
	endif;
	
	if _cargoSubType.getMyWeight &lt;&gt; null and _cargoSubType.getMyWeight.myMeasurementType &lt;&gt; null then
		measureType := _cargoSubType.getMyWeight.myMeasurementType;
		if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
			self.txtTotalWeight.setup(Type_Weight, self.backColor);
			self.txtTotalWeight.setValues(Space &amp; measureType.shortName);
			self.lblTotalWeight.caption := app.getErrorString(Total) &amp; Space &amp; app.getErrorString(WeightCaption) &amp; Colon;
		endif;
	elseif _cargoSubType.getMyVolume &lt;&gt; null and _cargoSubType.getMyVolume.myMeasurementType &lt;&gt; null then
		measureType := _cargoSubType.getMyVolume.myMeasurementType;
		if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
			self.txtTotalWeight.setup(Type_Volume, self.backColor);
			self.txtTotalWeight.setValues(Space &amp; measureType.shortName);
			self.lblTotalWeight.caption := app.getErrorString(Total) &amp; Space &amp; app.getErrorString(Volume) &amp; Colon;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="onCargoTypeChange" id="2b7164b9-8b52-49ba-974e-2f2a4dae9644">
        <updating/>
        <source>onCargoTypeChange(_cargoType : CM_CargoType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars

begin
	self.cmbCargoSubtype.setCargoType(_cargoType);
	
	// do we need to change measurement type?
	if _cargoType.isTrackByWeight and _cargoType.myWeightMeasurementType &lt;&gt; self.txtTotalWeight.getMeasurementType then
		self.txtTotalWeight.setup(Type_Weight, self.backColor);
		self.txtTotalWeight.setValues(Space &amp; _cargoType.myWeightMeasurementType.shortName);
		self.lblTotalWeight.caption := app.getErrorString(Total) &amp; Space &amp; app.getErrorString(WeightCaption) &amp; Colon;
	elseif _cargoType.isTrackByVolume and _cargoType.myVolumeMeasurementType &lt;&gt; self.txtTotalWeight.getMeasurementType then
		self.txtTotalWeight.setup(Type_Volume, self.backColor);
		self.txtTotalWeight.setValues(Space &amp; _cargoType.myVolumeMeasurementType.shortName);
		self.lblTotalWeight.caption := app.getErrorString(Total) &amp; Space &amp; app.getErrorString(Volume) &amp; Colon;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setBulkCargoAndVessels" id="612fb3b8-2c0c-4fbd-86d9-8283331e1bf0">
        <updating/>
        <source>setBulkCargoAndVessels(_tiArray : CM_TIArray; _vesselSet : CM_ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
// 17/06/2021	navdap1		TFS 51362 ASPA Bulk Create
//
vars

begin
	self.allTrackedItems.clear;
	_tiArray.copy(self.allTrackedItems);
	
	self.allVessels.clear;
	_vesselSet.copy(self.allVessels);
	
	if not self.allVessels.isEmpty then													// TFS 51362
		self.cmbVessel.listIndex := self.cmbVessel.findObject(self.allVessels.first);	// TFS 51362
	endif;																				// TFS 51362
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_vesselSet" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setCargoDetails" id="58e4a0b9-2cef-4149-a17d-8c48e700f2c7">
        <source>setCargoDetails(_voyage : CM_Voyage);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
// 17/06/2021	navdap1		TFS 51362 ASPA Bulk Edit
//
vars
	ti : CM_TrackedItem;
	index, number : Integer;
	cargoType : CM_CargoType;
	cargoSubtype : CM_Product;
	weight : Decimal [14,4];
	specialStow : CM_SpecialStow;
	cargoId : String;

begin
	number := self.txtTotal.text.trimBlanks.Integer;
	// we can press OK without having been to the Details screen - this should just create cargo with the defaults
	if self.chkCreateCargo.value = false then
		foreach index in 1 to number do
			self.allVessels.add(_voyage.getMyVessel);
		endforeach;
		return;
	endif;
	if self.allTrackedItems.isEmpty then
		cargoType := self.cmbCargoType.listObject.CM_CargoType;
		if cargoType = null then
			foreach index in 1 to number do						// TFS 51362
				self.allVessels.add(_voyage.getMyVessel);		// TFS 51362
			endforeach;											// TFS 51362
			return;
		endif;
		cargoSubtype := self.cmbCargoSubtype.listObject.CM_Product;
		weight := self.txtTotalWeight.getConvertedValue();
		specialStow := self.cmbSpecialStow.listObject.CM_SpecialStow;
		foreach index in 1 to number do
			cargoId := self.myAssistant.generateCargoIdForBargeCargo(_voyage.code, index, _voyage.getMyVessel);
			create ti as cargoType.myClassToCreate transient;
			ti.zSetPxyId(cargoId);
			if cargoType &lt;&gt; null then
				ti.setCargoType(cargoType.id);
			endif;
			ti.setMyProduct(cargoSubtype);
			ti.setTotalWeight(weight, null, app.myPassport);
			if specialStow &lt;&gt; null then
				ti.zSetPxySpecialStow(specialStow.code);
			endif;
			self.allTrackedItems.add(ti);
			self.allVessels.add(_voyage.getMyVessel);
		endforeach;
	endif;
	
	foreach ti in self.allTrackedItems do
		// set voyage, operator, terminal
		ti.zSetPxyVoyage(_voyage, null);
		ti.zSetPxyOperator(self.cmbOperator.listObject.CM_Operator);
		ti.zSetPxyTerminal(self.myTerminal);
		ti.zSetPxyState(TI_STATE_ONSHIP);
		ti.zSetPxyImexStatus(TI_IMEX_STATUS_IMPORT);
		ti.zSetPxyDischargePort(self.myTerminal.getConfig(PortDestCode).String);
	endforeach;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setPxyVoyage" id="af5826f6-063f-46a5-96e8-f7e6bc916967">
        <source>setPxyVoyage( _code : String ):CM_Voyage protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	msg : String;
	bargeVessel : CM_Vessel;
	operator : CM_Operator;
	shipLine : CM_ShippingLine;
	bank : CM_Bank;
	extReference : String;
	arrDateTime : TimeStamp;
	depDateTime : TimeStamp;
	dummyVoyage : CM_Voyage;
	pxyVoyage : CM_Voyage;

begin

	bargeVessel := self.cmbVessel.listObject.CM_Vessel;
	if bargeVessel = null then
		msg := app.getErrorString( Input_required_field_vessel );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbVessel.setFocus();
		return null;
	endif;
	
	operator := self.cmbOperator.listObject.CM_Operator;
	if operator = null then
		msg := app.getErrorString( Input_required_field_operator );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbOperator.setFocus();
		return null;
	endif;
	
	shipLine := self.cmbShipLine.listObject.CM_ShippingLine;
	if shipLine = null then
		msg := app.getErrorString( Input_required_field_shipLine );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbShipLine.setFocus();
		return null;
	endif;
	
	bank := self.cmbBusUnits.listObject.CM_Bank;
	if bank = null then
		msg := app.getErrorString( Input_required_field_BusUnit );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbBusUnits.setFocus();
		return null;
	endif;
	
	extReference := self.txtExtRef.text.trimBlanks;
	if extReference = null then
		msg := app.getErrorString( Input_requir_extern_refere_fie );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtExtRef.setFocus();
		return null;
	endif;
	
	arrDateTime.setDate( self.txtDateArr.getDate );
	arrDateTime.setTime( self.txtTimeArr.getTime );
	if not arrDateTime.date.isValid then
		msg := app.getErrorString( Input_required_field_arrivDate );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtDateArr.setFocus();
		return null;
	endif;
	
	depDateTime.setDate( self.txtDateDep.getDate );
	depDateTime.setTime( self.txtTimeDep.getTime );
	if bargeVessel.hasHarbourDetails then
		if not depDateTime.date.isValid then
			msg := app.getErrorString( Input_required_field_deptDate );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			self.txtDateDep.setFocus();
			return null;
		endif;
	endif;
	
	create dummyVoyage transient;
	dummyVoyage.setArrivalDepartureDT( arrDateTime, depDateTime, false);
	dummyVoyage.pxySetBaseBarge( operator, shipLine, bank, extReference, bargeVessel );
	pxyVoyage := dummyVoyage.pxyFromBargeUsingVesselAndCode( bargeVessel, _code, self.myTerminal );

	return pxyVoyage;

epilog

	delete dummyVoyage;

end;</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupCargoFields" id="9526f121-e186-456d-9b25-5cc815e3d556">
        <updating/>
        <source>setupCargoFields() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars

begin
	self.cmbCargoType.clear;
	self.cmbCargoType.myTerminal := self.myTerminal;
	self.cmbSpecialStow.clear;
	self.cmbCargoSubtype.clear;
	self.cmbCargoSubtype.setCargoType(null);
	self.cmbCargoSubtype.setOperator(null);
	self.txtTotalWeight.setup(Type_Weight, self.backColor);
	
	self.chkCreateCargo.value := true;
	self.chkCreateCargo_click(self.chkCreateCargo);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="80079b4c-d9a5-45f2-a11c-542116583a86">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation
19 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	allAvailableEvents : ObjectSet;
	iter : Iterator;
	eventType : CM_EventType;

begin

	if self.myAssistant = null then
		create self.myAssistant as SHP_Assistant;
		self.myAssistant.setMyTerminal( self.myTerminal );
	endif;

	self.cmbVessel.listCollection( app.myRoot.allVessels, true, 0 );
	self.cmbOperator.listCollection(app.myRoot.allOperators, true, 0);
	self.cmbShipLine.isDisplayByName := self.myTerminal.getConfig(ComboByNameLine).Boolean;
	self.cmbShipLine.initialise(false);
	self.myAssistant.comboBoxBankNotSuspended(self.cmbBusUnits, null);
	
	if self.myCurrentVessel &lt;&gt; null then
		self.cmbVessel.listIndex := self.cmbVessel.findObject( self.myCurrentVessel );
	endif;
	self.changeVessel();
	
	self.mulEvents.distanceFromBottom := 35;
	self.mulEvents.distanceFromRight := 10;
	self.mulEvents.lockBottom := false;
	self.mulEvents.lockRight := false;
	self.mulEvents.stretchHeight := true;
	self.mulEvents.stretchWidth := true;
	self.mulEvents.formDisplayEntryMethodName := "displayEventType";
	
	create allAvailableEvents transient;
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	app.myRoot.allEventTypesByCategory.startKeyGeq(4,null,iter);

	while iter.next(eventType) do
		if eventType.category &lt;&gt; 4 then
			break;
		endif;
		if not eventType.canUserAdd( self.myTerminal ) then	
			continue;
		endif;
		allAvailableEvents.add( eventType );
	endwhile;
	self.mulEvents.setAvailable( allAvailableEvents, true );
	self.mulEvents.availableHeading := app.getErrorString(Event_types_available);
	self.mulEvents.selectedHeading := app.getErrorString(Event_types_selected); 
	
	self.setupCargoFields();			// TFS 50878
	
	inheritMethod();
	
	self.txtVoyageCode.setFocus();

epilog

	delete allAvailableEvents;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="39277c2c-65a3-4d98-bad6-435e2ca56285">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2021 10:13:47.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023905, locale);
	btnDetails.translateCaption(Xlat_0024354, locale);
	chkCreateCargo.translateCaption(Xlat_0024355, locale);
	lblArrivalDT.translateCaption(Xlat_0023906, locale);
	lblBusUnit.translateCaption(Xlat_0023907, locale);
	lblCargoSubtype.translateCaption(Xlat_0024356, locale);
	lblCargoType.translateCaption(Xlat_0024357, locale);
	lblDepartDT.translateCaption(Xlat_0023908, locale);
	lblExtRef.translateCaption(Xlat_0023909, locale);
	lblOperator.translateCaption(Xlat_0023910, locale);
	lblShipLine.translateCaption(Xlat_0023911, locale);
	lblSpecialStow.translateCaption(Xlat_0024358, locale);
	lblTotal.translateCaption(Xlat_0023912, locale);
	lblTotalWeight.translateCaption(Xlat_0024359, locale);
	lblVessel.translateCaption(Xlat_0023913, locale);
	lblVoyageCode.translateCaption(Xlat_0023914, locale);
end;</source>
    </JadeMethod>
