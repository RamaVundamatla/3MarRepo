    <JadeMethod name="tblSelection_lostFocus" id="c733d7e5-5552-4199-a251-053c59fa47e5">
        <controlMethod name="CM_EntryTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelection_lostFocus(table: Table input) updating;

vars
	ctrl : Control;

begin

	ctrl := table.accessCell(table.row, table.column).cellControl;
	if ctrl &lt;&gt; null and (not ctrl.isKindOf(ComboBox)) then
		self.startSearch();
	endif;

end;</source>
