    <JadeMethod name="doBtnPrint" id="29810a28-2fee-47b5-bca3-6f030cdeb71a">
        <updating/>
        <source>doBtnPrint() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	pxyJadeReport	: JadeReport;
