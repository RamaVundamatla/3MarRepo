    <JadeMethod name="uGetGoodVsBadTableNames" id="8a1b3e1a-aa27-4491-94f5-63fcf076f818">
        <source>uGetGoodVsBadTableNames()  : String;
/*

Purpose:			
This simply returns the string value of the good and bad string array's for the purpose of 
ensuring correct naming conventions are used for table headings.
This has id,comm and name removed, refer to copy for all naming conventions.
Parameters:			

Return Value:		

Date		Who		Reason
06 June 2014	cnwdb2	PAR 33977 

*/

vars

begin

return"(hours) ,(hrs)
(kg/hour),(kg)(per hr)
(m/hour),(m)(per hr)
(minutes),(Mins)
(minutes),(mins)
(minutes),(min)
(system alert),Sys.Aler
10-foot,10 Foot
20-foot,20'
20-foot,20ft
20-foot,20 Foot
30-foot,30'
30-foot,30 Foot
40-foot,40'
40-foot,40 ft
40-foot,40 Foot
45-foot,45 Foot
45-foot,45'
53-foot,53 Foot
53-foot,53'
back (days),Back Days
between,Btw
cargo\BOL ,Cargo\BOL
check period,Check Period
Code,HS 
delivery release number,Del Rel Num
departure,Depart
description,desc
Email,E-mail
file number,File No
Hand-held,Hand Held
Hand-held apps - hide Move Confirmation screen,Hand Held Hide Move Confirmation
hi-cube,Hicube
IDs,ids
IMEX,imex
Information,info
Inter-terminal,Inter Terminal
Last Run Time,LastRunTime
limited quantity,LQ
log file size (MB),Log Size
Maximum ,Max 
Maximum,Max.
Minimum,Min
Minimum,Min.
multiple,Multi
