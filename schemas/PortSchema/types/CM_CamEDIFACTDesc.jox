    <JadeMethod name="makeNADSegment" id="d9954eb9-8f94-42f6-bc9b-ea0fca9c49f6">
        <source>makeNADSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input;_type, _code :String; _qual1, _qual2 :String):String protected;
/*
Purpose:	Make a UNZ segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "NAD";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_type &amp; plus &amp; 
			_code.String;
			
	if _qual1 &lt;&gt; null then
		msg := msg &amp; colon &amp; _qual1.String;
		if _qual2 &lt;&gt; null then
			msg := msg &amp; colon &amp; _qual2.String;
		endif;
	endif;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_qual1" type="String"/>
        <Parameter name="_qual2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeNAD_VGMSegment" id="25d6bacb-3997-4128-98ec-26d0287f530a">
        <source>makeNAD_VGMSegment(_protocol : CM_CamProtocol; _group : HugeStringArray input; _type, _code : String; _qual1, _qual2 : String) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/05/2016	cnwdap1		Initial creation TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
//
constants
	MESSAGE	= "NAD";
	
vars
	msg	: String;
	plus, colon, singleQuote : Character;
	
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_type &amp; plus &amp; plus &amp; plus &amp;
			_code.String;
			
	if _qual1 &lt;&gt; null then
		msg := msg &amp; colon &amp; _qual1.String;
		if _qual2 &lt;&gt; null then
			msg := msg &amp; colon &amp; _qual2.String;
		endif;
	endif;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
