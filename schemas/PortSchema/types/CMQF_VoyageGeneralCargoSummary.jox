        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="queryBOLs" id="26929d96-c3d8-4d53-820a-e6613690380d">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="queryCargo" id="bf6d8896-95e5-40a8-b658-349915810046">
