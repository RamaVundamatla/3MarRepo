    <JadeMethod name="buildAndCreateInterfaceHistory" id="c156cf36-2dbe-4c6d-a830-5b8856576ef5">
        <source>buildAndCreateInterfaceHistory( _tcpInterfaceAgent : CM_TCPInterfaceAgent );

/*

Purpose:		This method will "decide" if an InterfaceHistory is required if so
				it will build the required data and create the instance.

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	requestStr				: String;
	responseStr				: String;
	prxInterfaceHistory		: CM_InterfaceHistory;
	realInterfaceHistory	: CM_InterfaceHistory;
	
begin
	if not self.isFunctionRequired then
		return;
	endif;
	
	// OK this one is required so create the required data.
	self.createFormatedStrings( requestStr, responseStr );

	// create the proxy and update with required data
	create prxInterfaceHistory transient;
	self.setupProxyInterfaceHistory( prxInterfaceHistory, requestStr, responseStr );
	
	// Now create the real instance via a transaction controller.
	// NOTE: This is done separately to the main transaction in case it fails.
	// At this stage do nothing extra but might need to do a JMT alert later.
	app.myTrxCA.trxCreateInterfaceHistory( prxInterfaceHistory, realInterfaceHistory, app.myPassport );
	
epilog
	delete prxInterfaceHistory;
	
end;
</source>
        <Parameter name="_tcpInterfaceAgent" type="CM_TCPInterfaceAgent"/>
    </JadeMethod>
    <JadeMethod name="buildFormattedString" id="3d105eef-ec53-4f63-90af-adf2ac1ba1fd">
        <source>buildFormattedString( _toBeFormatedStr : String ) : String protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	returnStr		: String;
	
begin
	// Get the formatted string for the property value if it is not null.
	returnStr	:= self.getAuditTextForProperty( self.class.getProperty( _toBeFormatedStr ), true );
	
	return returnStr;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_toBeFormatedStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildOutputResponseString" id="09c2bddd-f239-47f1-bc6b-8d6a407f9613">
        <updating/>
        <source>buildOutputResponseString() : String updating;

/*

Purpose:			Generate an output response for the receiver (incorporatng any 
					error information from the current CM_Passport)

Parameters:			None

Return Value:		String value to return to the client


Date		Who		Reason
12 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
17 Nov 2008	cnwkpd1	PAR #18377 - Ignore warning messages
17 Nov 2008	cnwkpd1	PAR #18374 - Remove "Code : &lt;number&gt;" from messages returned
17 Nov 2008	cnwkpd1	PAR #18376 - Need to specifically treat "No_Tasks" error as if it is a warning
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change to use ini file options to suppress warnings and error codes
18/05/2009	cnwrl1	PAR 19668 - CCMS 1814 - process InterfaceHistory
*/

vars
	passport		: CM_Passport;
	respLine		: CMIF_InterfaceResponse;
	returnVal,
	errorString,
//	errorMsg,								// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
	respLineString	: String;
//	errorIndicator	: Integer;				// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
	errorObject		: CM_Error;
	
begin
	// First construct error message details for the start of each response line
	passport := app.myPassport;
	
	// Convert any "No_Tasks" errors into warnings - PAR #18526
	foreach errorObject in passport.allErrors do
		if errorObject.errorCode = No_Tasks then
			errorObject.removeFromPassport();
			errorObject.setErrorText(errorObject.text, true);
			errorObject.setMyWarningPassport(passport);
		endif;	
	endforeach;
	
	if passport.hasErrors() then
		errorObject := passport.allErrors.first;								// PAR #18376
//		errorIndicator := CM_TCPInterfaceAgent.ERROR_INDICATOR_CRITICAL;	// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814 - what it was
		setErrorIndicator( self.ERROR_INDICATOR_CRITICAL );
	
	elseif passport.hasWarnings() and not self.suppressWarnings then			// PAR #18526
//		errorIndicator := CM_TCPInterfaceAgent.ERROR_INDICATOR_WARNING;		// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814 - what it was
		setErrorIndicator( self.ERROR_INDICATOR_WARNING );
		errorObject := passport.allWarnings.first;
	
	else
//		errorIndicator := CM_TCPInterfaceAgent.ERROR_INDICATOR_OK;			// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814 - what it was
		setErrorIndicator( self.ERROR_INDICATOR_OK );
		errorObject := null;
	endif;
	
	// Now get the details from the first error/warning (if there is one)
	if errorObject &lt;&gt; null then
		if self.returnErrorCodes then
//			errorMsg := errorObject.text;									// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
			self.setErrorMsg( errorObject.text );
		else
//			errorMsg := errorObject.getDetailsAsStringNoCode();				// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
			self.setErrorMsg( errorObject.getDetailsAsStringNoCode() );
		endif;
	endif;	
	
	errorString := self.errorIndicator.display &amp; CNEC_COMMA &amp; self.errorMsg.csvFormat;
	
	// Overall response string is one line per CMIF_InterfaceResponse for this message, each
	// line starting with the same error message details
	returnVal := null;
	foreach respLine in self.allResponseLines do
		// Each response line is separated by CrLf
		if returnVal &lt;&gt; null then
			returnVal := returnVal &amp; CrLf;
		endif;
		
		// Start each line with the errorString
		returnVal := returnVal &amp; errorString;
		
		// Get the output response for this line
		respLineString := respLine.buildOutputResponseString;
		
		if respLineString &lt;&gt; null then
			returnVal := returnVal &amp; CNEC_COMMA &amp; respLineString;
		endif;
	endforeach;
	
	// Handle error condition where there are no response lines
	if returnVal = null then
		returnVal := errorString;
	endif;
	
	self.setOutputResponse( returnVal );		// cnwrl1 15/05/2009 PAR 19668 - CCMS 1814
	
	// And return the response
	return returnVal;
	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearResponsePreDeadlockRetry" id="adcf25f3-76e9-4afb-beaa-850d708f1f6e">
        <source>clearResponsePreDeadlockRetry();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwndl1	Initial creation	Par 26304

*/

vars

begin

	self.allResponseLines.purge;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createDefaultResponse" id="4749e53e-2a86-414d-876d-5c8458019c4b">
        <updating/>
        <source>createDefaultResponse(_numberOfFields : Integer) updating;

/*

Purpose:			If there are no response lines for the receiver, then create a
					default response line with the passed in number of blank fields.
					Will be used to ensure that the correct number of fields is always 
					returned

Parameters:			Number of fields to create in a default response

Return Value:		None


Date		Who		Reason
08 Dec 2008	cnwkpd1	PAR #18615 - Pass empty strings when NextJob returns no job

*/

vars
	response		: CMIF_InterfaceResponse;
	index			: Integer;
	
begin
	// Only do anything if there are no response lines
	if self.allResponseLines.isEmpty() then
		response := self.createResponseLine();
		foreach index in 1 to _numberOfFields do
			response.allResponseFields.add(null);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_numberOfFields" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createFormatedStrings" id="ca47eaaf-06bc-4669-9c10-4a6b192868b6">
        <source>createFormatedStrings(
	_request	: String io;
	_response	: String io ) protected;

/*

Purpose:		To build the required formated strings of the request and response.
				These will be dependent on the message functions, only non-null values will be added.
				Also do not need values like error indicator and machine which are stored or obtainable separately.

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814

*/

vars
	requestStr			: String;				// ie the input string formatted
	responseStr			: String;				// ie the output string formatted
	
begin
	// Create the appropriate formatted request and response strings based on operation name.
	// Note The buildFormattedString method will ignore values with null.
	
	// All responses start with following, do not need error indicator as this is specifically set in resposeStatus.
	responseStr	:= self.buildFormattedString( CMIF_InterfaceMsgController::errorMsg.name );
	
	if self.functionName = TCP_FUNCTION_INITIALISE then
		// NOTE - this one will never actually be done since machine at least is null.
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::userCode.name );
		// nothing extra for responseStr
		
	elseif self.functionName = TCP_FUNCTION_LOGON then
		// will only be done if machine is not null.
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::userCode.name );
		
		// Note: If there is an error (only time process logon then the Question will be null).
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::uniqueId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::driverResponse.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::machineIsTwinLift.name );
		
	elseif self.functionName = TCP_FUNCTION_LOGOFF then
		// nothing for either string.
		
	elseif self.functionName = TCP_FUNCTION_SENDFAULTRESPONSE then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::uniqueId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::driverResponse.name );
		// nothing extra for responseStr
		
	elseif self.functionName = TCP_FUNCTION_NEXTJOB then
		// nothing for requestStr
		
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::jobType.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::isUniqueId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::isUniqueIdTwin.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerAttributes.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::locationSource.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::locationDestination.name );
		
	elseif self.functionName = TCP_FUNCTION_REJECT then
		// nothing for either string.
		
	elseif self.functionName = TCP_FUNCTION_PICKUP then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name );
		
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::locationDestination.name );
		
	elseif self.functionName = TCP_FUNCTION_VALIDATEMOVE then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::partialContainerId.name );
		
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::numberOfMatches.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name );
						
	elseif self.functionName = TCP_FUNCTION_VALIDATEDISCHARGE then	//29 Mar 2011	NDL	Par 27290
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::partialContainerId.name );
		
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::numberOfMatches.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name );
		
	elseif self.functionName = TCP_FUNCTION_VALIDATECRANEQUE then	//29 Mar 2011	NDL	Par 27290
		// nothing for requestStr
		
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::craneId.name );
		
	elseif self.functionName = TCP_FUNCTION_GETDESTINATION then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name );
		
		// NOTE This is only returned if there was an error in which case do not know the Twin Destination!
		responseStr	:=	responseStr &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::locationDestination.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name );
		
	elseif self.functionName = TCP_FUNCTION_SETDOWN then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name );
		// nothing extra for responseStr
		
	elseif self.functionName = TCP_FUNCTION_SWAP then
		requestStr	:=	self.buildFormattedString( CMIF_InterfaceMsgController::containerId.name ) &amp;
						self.buildFormattedString( CMIF_InterfaceMsgController::containerId2.name );
		// nothing extra for responseStr
		
	else
		// Invalid function name - ignore it here.
	endif;
	
	_request	:= requestStr;
	_response	:= responseStr;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_request" type="String" usage="io"/>
        <Parameter name="_response" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createResponseLine" id="101a40c8-d683-4814-a980-cf33ffdd8d54">
        <updating/>
        <source>createResponseLine() : CMIF_InterfaceResponse updating;

/*

Purpose:			Create object which is used to return response text to the receiver.

Parameters:			None

Return Value:		New response object.


Date		Who		Reason
19 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	response : CMIF_InterfaceResponse;
	
begin
	create response transient;
	self.allResponseLines.add(response);

	return response;
	
epilog

end;</source>
        <ReturnType type="CMIF_InterfaceResponse"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e5f140e0-ff6e-4627-bb8f-fd17c3e87564">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	self.allResponseLines.purge;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTask" id="cb178b3a-4f64-45e5-916c-829273de3acf">
        <source>getTask() : CM_RTQueueTask;

/*

Purpose:			Get current task for machine

Parameters:			None

Return Value:		Current task


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
01 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change to get task from machine, not mediator
					
*/

vars
	
begin
	return self.myMachine.currentQueueTask;

	
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getTwinTask" id="cbee1ddf-760b-4d64-97a5-e7d684396541">
        <source>getTwinTask() : CM_RTQueueTask;

/*

Purpose:			Get current twin task for machine (if there is one)

Parameters:			None

Return Value:		Current twin task


Date		Who		Reason
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	
begin
	return self.myMachine.getCurrentTwinTask();
	
	
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="isFunctionRequired" id="10584fdb-9168-42fe-b6ba-bba073990f6e">
        <source>isFunctionRequired() : Boolean protected;

/*

Purpose:		This method will return true if this function is required to have an Interface History created.
				The business rules covering this are:
				
				The functions that will create Interface History are:
				
				NextJob (when there is a job returned)
				Reject
				Pickup
				ValidateMove
				SetDown
				Swap
				
				Function calls that will not normally be logged are:
				
				Initialise
				Logon
				Logoff
				SendFaultResposne
				GetDestination
				NextJob (when there are no available jobs)
				
				The exceptions to the above list are:
				1) If no interface definition or machine have been set up.
				2) That an Error Response Status is being returned then an Interface History log object will be created.

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	functionRequired	: Boolean;
	exceptionStatus		: Boolean;
	
begin
	// if the interface definition or machine are not set then no point continuing here.
	if self.myInterfaceDefinition = null or self.myMachine = null then
		return false;
	endif;
	
	// Establish if there has been an exception ie Error Response Status is being returned.
	exceptionStatus	:= self.errorIndicator &lt;&gt; self.ERROR_INDICATOR_OK;
	
	if self.functionName = TCP_FUNCTION_INITIALISE then
		// should never get to here (since machine at least will be null) but just in case.
		functionRequired	:= false;
		
	elseif self.functionName = TCP_FUNCTION_LOGON then
		functionRequired	:= exceptionStatus;
		
	elseif self.functionName = TCP_FUNCTION_LOGOFF then
		functionRequired	:= exceptionStatus;
		
	elseif self.functionName = TCP_FUNCTION_SENDFAULTRESPONSE then
		functionRequired	:= exceptionStatus;
		
	elseif self.functionName = TCP_FUNCTION_NEXTJOB then
		// should be true if there is an exception or was a job to find.
		functionRequired	:= exceptionStatus or self.jobType &lt;&gt; null;
		
	elseif self.functionName = TCP_FUNCTION_REJECT then
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_PICKUP then
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_VALIDATEMOVE then
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_VALIDATEDISCHARGE then	//29 Mar 2011	NDL	Par 27290
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_VALIDATECRANEQUE then	//29 Mar 2011	NDL	Par 27290
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_GETDESTINATION then
		functionRequired	:= exceptionStatus;
		
	elseif self.functionName = TCP_FUNCTION_SETDOWN then
		functionRequired	:= true;
		
	elseif self.functionName = TCP_FUNCTION_SWAP then
		functionRequired	:= true;
	else
		// unknown function
		functionRequired	:= false;
	endif;
	
	return functionRequired;
	
epilog
	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
