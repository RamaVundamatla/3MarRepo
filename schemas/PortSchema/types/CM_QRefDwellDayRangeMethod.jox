    <JadeMethod name="setComboValues" id="b557d80a-97ca-4a7d-b938-6930e917d102">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	dwellDayRange : CM_DwellDayRange;
	dwellDayRangeDict : CM_DwellDayRangeByLowerDict;
	selectedStr : String;

begin

	_combo.clear();
	
	dwellDayRangeDict := app.myRoot.allDwellDayRanges;
	
	foreach dwellDayRange in dwellDayRangeDict do
		_combo.itemObject[_combo.addItem(dwellDayRange.getDisplayValue)] := dwellDayRange;
	endforeach;

	/* TFS 7821
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectedStr := _queryOperator.CM_QStringLookup.selectionValue;	
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectedStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

	if selectedStr &lt;&gt; null then
		_combo.listIndex := _combo.findStringExact(1,selectedStr);
		if _combo.listIndex &gt; 0 then
			_combo.listObject := _combo.itemObject[ _combo.listIndex ];
		endif;
	endif;
	*/
	
	// TFS 7821	//Highlight selected
	if _queryOperator &lt;&gt; null then
		if _queryOperator.isKindOf(CM_QReferenceLookup) then
			_combo.listObject := _queryOperator.CM_QReferenceLookup.mySelectionValue;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a1ee97b2-0673-4a05-a51d-4b9f2bc1d934">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	dwellDayRange : CM_DwellDayRange;
	dwellDayRangeDict : CM_DwellDayRangeByLowerDict;
	idx : Integer;
	selectionValue : Integer;
	
begin

	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	if _params = null then
		return;
	endif;
	
	dwellDayRangeDict := app.myRoot.allDwellDayRanges;
	
	foreach	dwellDayRange in dwellDayRangeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null then
			if _operator.isKindOf(CM_QReferenceIsOneOf) and _operator.CM_QReferenceIsOneOf.allSelectionValues.includes(dwellDayRange) then
				selectionValue := 1;
			endif;
		endif;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; dwellDayRange.getDisplayValue);
		_tbl.accessRow(idx).itemObject := dwellDayRange;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="3ca5cf37-7241-4959-8cc0-dc712ca84c81">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	str : String;
	numRows,
	idx : Integer;
	dwellDateRangeArray : ObjectSet;
	dwellDateRange : Object;

begin

	create dwellDateRangeArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			dwellDateRange := _tbl.accessRow(idx).itemObject;
			dwellDateRangeArray.add(dwellDateRange);
		endif;
	endforeach;
	
	_op.setSearchValue(dwellDateRangeArray);
	
epilog

	delete dwellDateRangeArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="4c3ee457-ac81-4d1d-9f85-eee9a488c923">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if _value.isKindOf(CM_DwellDayRange) then
		if _value &lt;&gt; null then
			return _value.CM_DwellDayRange.getDisplayValue;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="86d37828-175b-4af0-bd67-e0de47ee03b0">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	invalidObj 		: Boolean;
	object			: CM_DwellDayRange;
	returnVal		: String;
	
begin

	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_DwellDayRange) then
			// TFS 7821 object := _value.CM_DwellDayRange;
			return _value.CM_DwellDayRange;
		endif;
	endif;
	/* TFS 7821
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getDisplayValue;
	endif;
	*/
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="7fdf0d68-af40-4a11-86a2-ef4b6ccead48">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selectior query parameters
//
vars
	dwellDay : CM_DwellDayRange;
	obj : Object;
	rtnVal, str, valueStr : String;
	strArray : StringArray;
	coll : ObjectSet;

begin
	if _value.isKindOf(CM_DwellDayRange) then
		return _value.CM_DwellDayRange.getDisplayValue;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			valueStr := _value.String;
			create strArray transient;
			create coll transient;
			valueStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				foreach dwellDay in app.myRoot.allDwellDayRanges discreteLock do
					if dwellDay.getDisplayValue = str then
						coll.addNoDuplicates(dwellDay, false);
					endif;
				endforeach;
			endforeach;
			return coll;
		endif;
		
		foreach dwellDay in app.myRoot.allDwellDayRanges discreteLock do
			if dwellDay.getDisplayValue = _value.String then
				return dwellDay;
			endif;
		endforeach;
		
		return _value.String;
		
	elseif _value.isKindOf(ObjectSet) then
		foreach obj in _value.ObjectSet do
			dwellDay := obj.CM_DwellDayRange;
			if dwellDay &lt;&gt; null then
				rtnVal := rtnVal &amp; dwellDay.getDisplayValue &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
