        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/08/2009	cnwmd1	Initial creation
02/10/2019  cnwma1	Bug 46853: PEL1 - (TOP URGENT) Pindah| Caught exception:
*/

vars

begin
	//epr TFS 41310 17/10/18
	if self.myMainForm.isKindOf(YRD_TaskJobMaintForm) then 
		if self.myCurrentProxyTask &lt;&gt; null then                       //02.10.2019 cnwma1 #46853     
			if self.myCurrentProxyTask.pxyGetRealObject = null then
				delete self.myCurrentProxyTask;
			endif;
		endif;
		self.myMainForm.YRD_TaskJobMaintForm.refreshFromChildTaskForm();
	endif;
	self.unloadForm();
epilog

end;</source>
