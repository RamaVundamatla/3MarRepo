    <JadeMethod name="comboBoxFinancialIOClass" id="d17d9864-3271-4f4f-8203-8de5ef88fe7a">
        <source>comboBoxFinancialIOClass(pCmb : CMUI_ComboBox input; _financialIO : Class);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/06/2025	navcs2	MTN-34987
// ---------------------------------------------------------------------------
vars
	ioClass:   CM_ExtFinanceIO;
	default : CM_ExtFinanceIO;
	clsCol : ClassNDict; // PAR 17620 //ClassColl;
	cls : Class;
	str : String;
begin
	/* WAS PAR 33572
	create clsCol transient;
	cls := currentSchema.getClass(CM_ExtFinanceIO.name);
	cls.getAllSubclassesAnywhere(clsCol); // PAR 17620 , get sub classes in sub schemas as well so that CentrePorts own classes get picked up.


	pCmb.clear;
	foreach cls in clsCol do
		if not cls.abstract then
			if cls.name = "CM_Nimbus" then // AKB2014JAN Unit Testing
				continue;
			endif;
			pCmb.addItemObject(cls.getNiceName(),cls);
		endif;
	endforeach;
	
	if _financialIO &lt;&gt; null then
		pCmb.text := _financialIO.getNiceName();
		pCmb.listObject := _financialIO;
	endif;
	NOW */

	pCmb.clear;
	foreach ioClass in app.myRoot.myRootCompany.ioClasses do
		if ioClass.name = "Pelindo1Interface" then				// 11/06/2025	navcs2	MTN-34987 // No longer required but dont delete
			continue;											// 11/06/2025	navcs2	MTN-34987
		endif;													// 11/06/2025	navcs2	MTN-34987
		if ioClass.name = "Nimbus" then // AKB2014JAN Unit Testing this was intended for Port Nelson but they did not go a head
			continue;
		endif;
		if ioClass.name = "Decfin" then // PAR 35572 this is Port Otago's old system no longer used
			continue;
		endif;
		
		
		if ioClass.name = "Maximise" then // PAR 35572 this is Centreport's old system no longer used
			continue;
		endif;
		if ioClass.name = "CODA" then // PAR 35572 this is Centreport's old system no longer used
			continue;
		endif;
		pCmb.addItem(ioClass.getNiceName());
		pCmb.itemObject[pCmb.newIndex] := ioClass;
		
		if _financialIO &lt;&gt; null then
			if ioClass.class = _financialIO then
				default := ioClass;
			endif;
		endif;
	endforeach;
	
	if default&lt;&gt; null then
		pCmb.text := default.getNiceName();
		pCmb.listObject := default;
	
	endif;

epilog
	//delete clsCol;
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_financialIO" type="Class"/>
    </JadeMethod>
    <JadeMethod name="comboBoxFullContainers" id="ece14c45-136a-41ca-affe-674416c7a828">
        <source>comboBoxFullContainers(_combo : ComboBox input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwjk3	Initial creation
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	ti				: CM_TrackedItem;
	dict			: CM_TIByCargoTypeIdDict;
	iter			: Iterator;
	idStr			: String;
	cargoType		: Integer;
	ls,
	maxCountExceeded: Boolean;
	count			: Integer;
begin
	_combo.clear;
	dict := self.myTerminal.allOnsiteTIsByCargoTypeId;

	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	dict.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType, idStr); //MTN-35226
		if cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		if not ti.isFull() then
			continue;
		endif;
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;		
		_combo.itemObject[_combo.addItem(idStr)] := ti;				
	endwhile;
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
