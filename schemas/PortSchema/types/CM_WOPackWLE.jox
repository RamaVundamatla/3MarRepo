<Class name="CM_WOPackWLE" id="b0fc7b3f-45cf-4467-8db6-e7600b1d28b7">
    <superclass name="CM_WOWLE"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="erase" id="b0bae65b-668a-4cc6-afb7-b1b6e8cac201">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/


vars
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		//AJA 31/3/00: Yard internals
		sharedLock(self.myRequest.myJob);
	endif;

	
	//=======================
	// automatics should take care
	// of the job.wles and request.wles collections.
	//=======================

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);				  	

  	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChildren" id="132f062d-8cff-4b59-98c9-821fe8eb8c36">
        <source>getChildren(_childColl : CM_TISet input) abstract;</source>
        <abstract/>
        <Parameter name="_childColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eb1f52eb-3139-469d-bd12-94d6f8c2a82d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
21 Jun 2023 navhl20 ChangeRequest 58769: EUP - Delivery Dispatch – Job’s Cargo Details - Pack unpack
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
*/

vars
	wod 		: CM_WodRelease;
	bulkRelease : CM_BulkRelease;
	reserve	    : CM_ReserveDetail;
	cargoType	: CM_CargoType;
	ti			: CM_TrackedItem;
	request		: CM_Request;
	product		: CM_Product;
	isoType		: CM_ISOType;
begin
	
	if _attrName = ETRow_IsoGroup then
	//_attrName 	 = ETRow_IsoType or
	//_attrName 	 = ETRow_CargoSubType then
		
		if self.myTrackedItem &lt;&gt; null then
			self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		elseif self.myRequest &lt;&gt; null then												//21.6.2023 navhl20 #58769
			self.myRequest.getDisplayStringForAttribute(_attrName, _short);
		else
			return null ;
		endif;
	elseif _attrName = ETRow_Type then											//25.03.2024 navhl20 #62300
		if self.job.CM_WOPackJob.isPackParentJob then
			return app.getErrorString(Parent);
		else
			return app.getErrorString(Child);
		endif;
	elseif _attrName = ETRow_CargoSubType then									//25.03.2024 navhl20 #62300
		if self.myTrackedItem &lt;&gt; null then
			self.myTrackedItem.getCargoSubTypeDescr();
		elseif self.myRequest &lt;&gt; null then
			product := self.myRequest.getCargoSubType();
			if product &lt;&gt; null then
				return product.code;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_IsoType then									//25.03.2024 navhl20 #62300
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getISOType();
		elseif self.myRequest &lt;&gt; null then
			isoType := self.myRequest.CM_WOPackRequest.getIsoType();
			if isoType &lt;&gt; null then
				return isoType.code;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_Commodity then									//25.03.2024 navhl20 #62300
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getCommodityDesc();
		elseif self.myRequest &lt;&gt; null then
			if self.job.CM_WOPackJob.isPackParentJob then
				return self.myRequest.getReqCommodity(true);
			else
				return self.myRequest.getReqCommodity(false);
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_CargoGroupId then									//25.03.2024 navhl20 #62300
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getMyCargoGroupId();
		elseif self.myRequest &lt;&gt; null then
			return self.myRequest.getChildCargoGrpId();
		endif;
		return null;
	else
		return inheritMethod (_attrName, _short);	
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="c1914ac7-65f2-44f5-9306-42d40964659f">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin
	
	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTi" id="21ead232-3e99-40d6-9c4e-26faa8d54fba">
        <source>getTi(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2023	navhl20	ChangeRequest 58769: EUP - Delivery Dispatch – Job’s Cargo Details - Pack unpack
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars

begin
	/*
	//19.03.2024 navhl20 #62863
	if self.job &lt;&gt; null then
		if not self.job.CM_WOPackJob.isPackParentJob and self.job.myWODtl &lt;&gt; null then
			return self.job.myWODtl.CM_WodPack.allPackingTIs.first;
		endif;
	endif;*/
	return self.myTrackedItem;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
