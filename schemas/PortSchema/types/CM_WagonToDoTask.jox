<Class name="CM_WagonToDoTask" id="128391cd-8845-45a1-9ddd-b1e0d85a1753">
    <superclass name="CM_ToDoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="myWagonComplete" id="8dc67570-dd22-484a-80d3-0a6d3b9edbac">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Wagon"/>
