    <JadeMethod name="getSeqNum" id="d16e8f98-7384-4620-a27e-0c29e2209c0d">
        <source>getSeqNum() : Integer;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	isStarboard : Boolean;
begin
	//take the local load.discharge info type
	
	isStarboard := self.getVoyage.starboardBerthed;
	
	if isStarboard then
		//return numSeqStarBoard;
		return self.numSeqStarboardCustom;
	else
		//Starboard
//		return numSeqPort;
		return self.numSeqPortCustom;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumDefn" id="ce045451-e1cb-4396-827e-36d444d3d5fd">
        <source>getSeqNumDefn(_params : CMIF_SeqParams) : Integer;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	seqNum : Integer;

begin	
	seqNum := self.mySlotController.getSequence(_params.isDischarge, _params.isStarBoard);
	//----------------------
	//Get the config
	//----------------------

	if self.ordinalDeck = DeckOnDeck then
		if _params.isForty then
			seqNum := seqNum + self.myTerminal.getConfig(StartSeqNum40_OverDeck).Integer;
		else
			seqNum := seqNum + self.myTerminal.getConfig(StartSeqNum20_OverDeck).Integer;
		endif;
	else
		if _params.isForty then
			seqNum := seqNum + self.myTerminal.getConfig(StartSeqNum40_UnderDeck).Integer;
		else
			seqNum := seqNum + self.myTerminal.getConfig(StartSeqNum20_UnderDeck).Integer;
		endif;
	endif;
	return seqNum;
end;</source>
        <Parameter name="_params" type="CMIF_SeqParams"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumString" id="f10df03d-e5bb-4e61-b982-68c89b885a7d">
        <source>getSeqNumString(_params : CMIF_SeqParams) : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	SEQNUM_SUFFIX_BASE = 'a'.Character;

vars
	seqNum : Integer;
	seqNumStr : String;
	subSeqNum : Integer;

begin

	if self.myTerminal = null then
		return null;
	endif;
	if _params.displaySequenceType = STANDARD_SEQUENCE then
		seqNum := getSeqNumDefn(_params);
	elseif _params.displaySequenceType = PLANNED_SEQUENCE then
		seqNum := self.allWorkListEntries.size;
	else
		if _params.isStarBoard then
			//seqNum := numSeqStarBoard;
			seqNum := self.numSeqStarboardCustom;
		else	//Port
			//seqNum := numSeqPort;
			seqNum := self.numSeqPortCustom;
		endif;
	endif;

	if self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean then
		seqNumStr := seqNum.String;
	else
		seqNumStr :=  seqNum.padLeadingWith('0', 3);
	endif;

	if _params.showWithSuffix then

		if self.isLoad then
			subSeqNum := 0;	//Was ordinalSlot. We may need to derive a location in the futureMoves array.
		else
			subSeqNum := 1;
		endif;
		seqNumStr := seqNumStr &amp; (SEQNUM_SUFFIX_BASE.Integer + subSeqNum).Character;
	endif;

	return seqNumStr;

end;</source>
        <Parameter name="_params" type="CMIF_SeqParams"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumStringForXML" id="9a1debda-6d54-424b-aa0b-70c6e45b3399">
        <source>getSeqNumStringForXML(_isTwinLiftView,_isStarBoard, _showWithSuffix: Boolean; _removeZeros : Boolean; _isPrinting: Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	SEQNUM_SUFFIX_BASE = 'a'.Character;

vars
	seqNum : Integer;
	seqNumStr : String;
	subSeqNum : Integer;
	linkedRequest: CM_SlotRequest;

begin

	if _isStarBoard then
		if _isTwinLiftView then
			seqNum := self.numSeqStarboardTwinCustom;
		else
			//seqNum := self.numSeqStarBoard;	
			seqNum := self.numSeqStarboardCustom;	
		endif;
	else
		if _isTwinLiftView then
			seqNum := self.numSeqPortTwinCustom;
		else
			//seqNum := self.numSeqPort;
			seqNum := self.numSeqPortCustom;
		endif;
	endif;

	if seqNum = 0 and _isPrinting then		// 22/8/17 MAP TFS5493
		linkedRequest := self.myRequestLinkedDischarge.CM_SlotRequest;
		if linkedRequest &lt;&gt; null then
			if _isStarBoard then
				if _isTwinLiftView then
					seqNum := linkedRequest.numSeqStarboardTwinCustom;
				else
					seqNum := linkedRequest.numSeqStarboardCustom;	
				endif;
			else
				if _isTwinLiftView then
					seqNum := linkedRequest.numSeqPortTwinCustom;
				else
					seqNum := linkedRequest.numSeqPortCustom;
				endif;
			endif;
		endif;
	endif;

	if _removeZeros then
		seqNumStr := seqNum.String;
	else
		seqNumStr :=  seqNum.padLeadingWith('0', 3);
	endif;

	if _showWithSuffix then
		if (self.isLoad) then
			subSeqNum := 0;	//Was ordinalSlot. We may need to derive a location in the futureMoves array.
		else
			subSeqNum := 1;
		endif;
		seqNumStr := seqNumStr &amp; (SEQNUM_SUFFIX_BASE.Integer + subSeqNum).Character;
	endif;

	return seqNumStr;

end;</source>
        <Parameter name="_isTwinLiftView" type="Boolean"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_showWithSuffix" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <Parameter name="_isPrinting" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipPlanningPowerType" id="02473fcb-cbe2-4576-a628-d53597b776a1">
