    <JadeMethod name="doTranslations" id="d728af7f-4689-49d9-8870-4139ca4c2372">
        <source>doTranslations( _requestStr : String io; _responseStr : String io ) protected;

/*

Purpose:		This method will take the suppied strings and via a hardcoding translate what it can.
				The possible translations are the class properties on MobileServerSchema::CMIF_InterfaceMsgController
				See also the method createFormatedStrings on the same class for what is put into each string.
				Currently (21/05/2009) these are:
					containerAttributes
					containerId
					containerId2
					driverResponse
					errorMsg
					isUniqueId
					isUniqueIdTwin
					jobType
					locationDestination
					locationSource
					machineIsTwinLift
					numberOfMatches
					partialContainerId
					uniqueId
					uniqueIdTwin
					userCode

Date				Who		Reason
21 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	if _requestStr = null and _responseStr = null then
		// nothing to translate might as well return now.
		return;
	endif;
	
	// First handle those that request can have.
	if _requestStr &lt;&gt; null then
		_requestStr.string_To_JMT_Translation( 'containerId', ContainerID );
		_requestStr.string_To_JMT_Translation( 'containerId2', Twin_ContainerID );
		_requestStr.string_To_JMT_Translation( 'driverResponse', DriverResponse );
		_requestStr.string_To_JMT_Translation( 'partialContainerId', PartialContainerID );
		_requestStr.string_To_JMT_Translation( 'uniqueId', UniqueID );
		_requestStr.string_To_JMT_Translation( 'userCode', CM_User_Code );
	endif;
	
	// Now handle those that response can have.
	if _responseStr = null then
		// nothing to translate might as well return now.
		return;
	endif;
	
	_responseStr.string_To_JMT_Translation( 'containerAttributes', ContainerAttributes );
	_responseStr.string_To_JMT_Translation( 'containerId', ContainerID );
	_responseStr.string_To_JMT_Translation( 'containerId2', Twin_ContainerID );
	_responseStr.string_To_JMT_Translation( 'driverResponse', DriverResponse );
	_responseStr.string_To_JMT_Translation( 'errorMsg', Error );
	_responseStr.string_To_JMT_Translation( 'isUniqueId', IDIsUnique );
	_responseStr.string_To_JMT_Translation( 'isUniqueIdTwin', Twin_IDIsUnique );
	_responseStr.string_To_JMT_Translation( 'jobType', JobType );
	_responseStr.string_To_JMT_Translation( 'locationDestination', Destination );
	_responseStr.string_To_JMT_Translation( 'locationSource', Source );
	_responseStr.string_To_JMT_Translation( 'machineIsTwinLift', CM_Twin_Lift );
	_responseStr.string_To_JMT_Translation( 'numberOfMatches', NumberOfMatches );
	_responseStr.string_To_JMT_Translation( 'uniqueId', UniqueID );
	_responseStr.string_To_JMT_Translation( 'craneId', CraneID );	// 30 Mar 2011	NDL	Par 27290
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_requestStr" type="String" usage="io"/>
        <Parameter name="_responseStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="052030fa-1b41-4075-b19c-e46e71a7b6d7">
        <source>getDisplayString() : String;

/*

Purpose:		This method will return a Tab delimited string suitable to display in tables etc.

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	returnStr				: String;
	responseStr				: String;
	formattedResponseStr	: String;
	formattedRequestStr		: String;
	interval				: TimeStampInterval;
	
begin
	interval	:= self.responseTimeStamp - self.requestTimeStamp;
	
	if self.responseStatus = 1 then				// ie CMIF_InterfaceMsgController.ERROR_INDICATOR_WARNING
		responseStr	:= app.getErrorString( Warning );
	elseif self.responseStatus = 2 then			// ie CMIF_InterfaceMsgController.ERROR_INDICATOR_CRITICAL
		responseStr	:= app.getErrorString( Critical );
	else
		responseStr	:= app.getErrorString( Normal );
	endif;
	
	formattedRequestStr		:= self.formattedRequest.getAuditTextDetails( ColonAndSpace, CNEC_COMMA &amp; Space );
	formattedResponseStr	:= self.formattedResponse.getAuditTextDetails( ColonAndSpace, CNEC_COMMA &amp; Space );
	self.doTranslations( formattedRequestStr, formattedResponseStr );
	
	returnStr	:=	self.requestTimeStamp.display &amp; Tab &amp;
					self.responseTimeStamp.time.display &amp; Tab &amp;
					interval.getMilliseconds.Decimal.asStringJMTWithPrecision( null, true ) &amp; Tab &amp;
					responseStr &amp; Tab &amp;
					self.myTCPInterfaceDefinition.name &amp; Tab &amp;
					self.userCode &amp; Tab &amp;
					self.functionName &amp; Tab &amp;
					formattedRequestStr &amp; Tab &amp;
					formattedResponseStr;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="242e3a5e-901d-450a-92d4-de9f706b5b20">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					self.functionName.padBlanks( 20 ) &amp; Tab &amp;
					self.userCode.padBlanks( 10 );
	
	if self.myMachine &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; 'machine ' &amp; self.myMachine.id;
		if self.myMachine.myTerminal &lt;&gt; null then
			returnStr	:= returnStr &amp; Tab &amp; 'terminal ' &amp; self.myMachine.myTerminal.code;
		endif;
	endif;
	
	if self.myTCPInterfaceDefinition &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTCPInterfaceDefinition.name.display;
	endif;
	
	/*
	returnStr	:=	returnStr &amp; Tab &amp;
					self.creationTime.cnEcShortFullFormat &amp; Tab &amp;
					self.rawRequest.display &amp; Tab &amp;
					self.rawResponse.display &amp; Tab &amp;
					self.formattedRequest.display &amp; Tab &amp;
					self.formattedResponse.display;
	*/
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a99a8d7b-2718-4fc2-8d19-e420d4549cec">
        <updating/>
        <source>setForCreate( _pxyObject : CM_InterfaceHistory ) updating;
/*
Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/
	
vars
	
begin
	setForUpdate( _pxyObject );
	
	// having set up the various attributes set the inverse references
	self.myMachine					:= _pxyObject.myMachine;
	self.myTCPInterfaceDefinition	:= _pxyObject.myTCPInterfaceDefinition;
	
	// to force the machine class notification to go off.
	self.updateObjectEdition (self.myMachine);	// par 30292
	
epilog
	
end;
</source>
        <Parameter name="_pxyObject" type="CM_InterfaceHistory"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8a809df6-9771-473b-977f-89d68cc5cccc">
        <updating/>
        <source>setForUpdate( _pxyObject : CM_InterfaceHistory ) updating;
	
/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814

*/
	
vars
	
begin
	self.formattedRequest	:= _pxyObject.formattedRequest;
	self.formattedResponse	:= _pxyObject.formattedResponse;
	self.functionName		:= _pxyObject.functionName;
	self.rawRequest			:= _pxyObject.rawRequest;
	self.rawResponse		:= _pxyObject.rawResponse;
	self.responseStatus		:= _pxyObject.responseStatus;
	self.responseTimeStamp	:= _pxyObject.responseTimeStamp;
	self.userCode			:= _pxyObject.userCode;
	
	// do this last as it is the key of the collection.
	self.requestTimeStamp	:= _pxyObject.requestTimeStamp;
	
epilog
	
end;
</source>
        <Parameter name="_pxyObject" type="CM_InterfaceHistory"/>
    </JadeMethod>
