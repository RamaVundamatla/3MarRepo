    <JadeMethod name="doSortGates" id="5c4d940a-67a3-4b2b-be73-f415bb9cdd87">
        <updating/>
        <source>doSortGates(moveUp : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2022	navlw1	Initial creation TFS# 52455

*/

vars
	coll 			: CM_IntegerArray;
	int 			: Integer;
	listBoxCount 	: Integer;
	selectedGate    : CM_Gate;
	gate 			: CM_Gate;
	arrayPosition 	: Integer;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);
	create coll transient;
	listBoxCount := lstGates_Select.listCount;
	lstGates_Select.getSelectedEntries (coll);
	foreach int in coll do
		if moveUp then
			//sort ascending
			arrayPosition := int - 1;
		else 
			//sort descending
			arrayPosition := int + 1;
		endif;
		
		//check to make sure that we are not sorting out of the array index of the listbox
		if int - 1 &lt; 1 and moveUp then	
			continue;
		elseif int + 1 &gt; listBoxCount and moveUp = false then
			continue;	
		endif;
		//get the selected terminal area that we want to sort
		selectedGate := lstGates_Select.itemObject[int].CM_Gate;
		//get the item before or after the current selected area
		gate := lstGates_Select.itemObject[arrayPosition].CM_Gate;
		if invalidObject then			
			invalidObject := false;
			continue;					
		endif;
		//swap the positions in the item object
		lstGates_Select.itemObject[arrayPosition] := selectedGate;
		lstGates_Select.itemObject[int] := gate;
		//change the text in the list box for the item object as we have swapped them
		lstGates_Select.itemText[int] := gate.name;
		lstGates_Select.itemText[arrayPosition] := selectedGate.name;
		//clear the selected item
		lstGates_Select.clearAllSelected();
		//select the item we have sorted
		lstGates_Select.selectObject(selectedGate);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="moveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSortICAreas" id="abc5c30f-e598-40c9-b777-9c8ff032f099">
        <updating/>
        <source>doSortICAreas(moveUp : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2022	navlw1	Initial creation TFS# 52455

*/

vars
	coll 			: CM_IntegerArray;
	int 			: Integer;
	listBoxCount 	: Integer;
	selectedArea    : CM_TerminalArea;
	area 			: CM_TerminalArea;
	arrayPosition 	: Integer;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, area, invalidObject);
	create coll transient;
	listBoxCount := lstICAreas_Sel.listCount;
	lstICAreas_Sel.getSelectedEntries (coll);
	
	foreach int in coll do
		if moveUp then
			//sort ascending
			arrayPosition := int - 1;
		else 
			//sort descending
			arrayPosition := int + 1;
		endif;
		//check to make sure that we are not sorting out of the array index of the listbox
		if int - 1 &lt; 1 and moveUp then	
			continue;
		elseif int + 1 &gt; listBoxCount and moveUp = false then
			continue;	
		endif;
		//get the selected terminal area that we want to sort
		selectedArea := lstICAreas_Sel.itemObject[int].CM_TerminalArea;
		//get the item before or after the current selected area
		area := lstICAreas_Sel.itemObject[arrayPosition].CM_TerminalArea;
		if invalidObject then			
			invalidObject := false;
			continue;					
		endif;
		//swap the positions in the item object
		lstICAreas_Sel.itemObject[arrayPosition] := selectedArea;
		lstICAreas_Sel.itemObject[int] := area;
		//change the text in the list box for the item object as we have swapped them
		lstICAreas_Sel.itemText[int] := area.getDisplayName(true);
		lstICAreas_Sel.itemText[arrayPosition] := selectedArea.getDisplayName(true);
		//clear the selected item
		lstICAreas_Sel.clearAllSelected();
		//select the item we have sorted
		lstICAreas_Sel.selectObject(selectedArea);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="moveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSortOperators" id="afaa190d-442a-4c2c-9967-81c5e96f4ca3">
        <updating/>
        <source>doSortOperators(moveUp : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	coll 				: CM_IntegerArray;
	int 				: Integer;
	listBoxCount 		: Integer;
	selectedOperator    : CM_Operator;
	operator 			: CM_Operator;
	arrayPosition 		: Integer;
	invalidObject		: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, operator, invalidObject);
	create coll transient;
	listBoxCount := lstOperators_Sel.listCount;
	lstOperators_Sel.getSelectedEntries (coll);
	foreach int in coll do
		if moveUp then
			//sort ascending
			arrayPosition := int - 1;
		else 
			//sort descending
			arrayPosition := int + 1;
		endif;
		//check to make sure that we are not sorting out of the array index of the listbox
		if int - 1 &lt; 1 and moveUp then	
			continue;
		elseif int + 1 &gt; listBoxCount and moveUp = false then
			continue;	
		endif;
		//get the selected Operator that we want to sort
		selectedOperator := lstOperators_Sel.itemObject[int].CM_Operator;
		//get the item before or after the current selected area
		operator := lstOperators_Sel.itemObject[arrayPosition].CM_Operator;
		if invalidObject then			
			invalidObject := false;
			continue;					
		endif;
		
		//swap the positions in the item object
		lstOperators_Sel.itemObject[arrayPosition] := selectedOperator;
		lstOperators_Sel.itemObject[int] := operator;
		
		//27/07/2022 navmv20 54200 - start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then   
            lstOperators_Sel.itemText[int] := operator.description;
			lstOperators_Sel.itemText[arrayPosition] := selectedOperator.description;
		else
			lstOperators_Sel.itemText[int] := operator.code;
			lstOperators_Sel.itemText[arrayPosition] := selectedOperator.code;
        endif;  
		//27/07/2022 navmv20 54200 - end
		
		//change the text in the list box for the item object as we have swapped them
		//lstOperators_Sel.itemText[int] := operator.code; //27/07/2022 navmv20 54200
		//lstOperators_Sel.itemText[arrayPosition] := selectedOperator.code; //27/07/2022 navmv20 54200
		//clear the selected item
		lstOperators_Sel.clearAllSelected();
		//select the item we have sorted
		lstOperators_Sel.selectObject(selectedOperator);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="moveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSwapRelReq" id="148c138b-7afd-45c6-9047-e5b53b61c84b">
        <updating/>
        <source>doSwapRelReq(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theReturn : Integer;
begin
	if self.myCurrentWLE = null then
		return;
	endif;
	if not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest) then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateDelReqFromResDetail(self.myCurrentWLE.myRequest.CM_DeliveryRequest,menuItem.userObject.CM_ReserveSelection,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("REQUEST SWAP", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSwapTasks" id="0cef0831-20e3-465e-9ebc-66cfc290d587">
        <updating/>
        <source>doSwapTasks() updating;

/*

Purpose: to swap 2 release tasks between two trucks.
			Tasks must be releases!

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2013	cnwrd1	Initial creation
//nds TFS 2867 17/01/17 PKT - Bulk Process
*/

vars
	wleArray	: CM_WLEArray;	
	wleTable 	: CM_DataTable;
	wle1,
	wle2		: CM_WorkListEntry;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	//this does some basic checking - may be easier to redo in the trx as it will be needed anyhow!
	if not self.showSwapTaskMenuOption then
		return;
	endif;
	
	create wleArray transient;

	wleTable := self.myCurrentTable;
	if wleTable = null then
		if self.mnuTableContext.userObject.CM_DataTable = null then
			return ;
		else
			wleTable:=self.mnuTableContext.userObject.CM_DataTable;
		endif;
	endif;

	self.getAllWLEsInTableSelected(wleArray,wleTable,false);	//nds TFS 2867 17/01/17 PKT - Bulk Process

	if wleArray.size &lt;&gt; 2 then
		return ;
	endif;
	
	//ok we have 2 wle's now check to see if theya re suitable.
	
	wle1 := wleArray[1];
	wle2 := wleArray[2];
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxSwapTruckTasks(wle1,wle2, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Swap Tasks', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;	
	delete wleArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="c23f9053-576d-48b0-8026-a6002f18225d">
        <updating/>
        <source>doUnassignTI(_all : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	result		: Integer;
begin



	app.mousePointer := MousePointer_HourGlass;	

	if self.myCurrentWLE = null then
		return;
	endif;

	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	

	create wleSet transient;
	
	wleSet.add(self.myCurrentWLE);

	while true do
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);

		if (not app.myPassport.trxCompletedOK) then
			result :=	 app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUndoAssign" id="591fc070-f6cf-4b3f-bbed-f102380e9745">
        <source>doUndoAssign() protected;
/*

Date		Who		Reason
18 March 2014	cnwer1	Initial creation PAR 33718

*/

vars
	theReturn : Integer;
begin
	while true do
		app.myTrxUA.trxUndoReleaseByTypeAssign(self.myCurrentWLE, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
