    <JadeMethod name="create" id="c4ba03fe-5f42-43dd-a666-3c2c2ad36a5b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	form : Form;
	callingForm : CM_BaseForm;

begin

	//Can be called form multiple places that would have different permissions
	form := app.activeForm;
	if form &lt;&gt; null and form.isKindOf( CM_BaseForm ) then
		callingForm := form.CM_BaseForm;
		if callingForm &lt;&gt; null then
			self.permissionView  := callingForm.permissionView;
			self.permissionMaint := callingForm.permissionMaint;
			return;
		endif;
	endif;

	//should be done above, but if its not just chose one that seemed appropriate
	//to teh sort of role that should be allowed to do this.
	self.permissionView  := PmAdmSFTPEntityMaint;
	self.permissionMaint := PmAdmSFTPEntityMaint;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="7452b5af-0825-4576-9de9-3112683cd128">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	newPass	: String;
	newPass2 : String;
	result : Integer;
	prop : Property;
	msg : String;

begin

	app.mousePointer := MousePointer_HourGlass;
	
	newPass 	:= self.txtNewPassword.text;
	newPass2	:= self.txtNewPassword2.text;
	
	if newPass &lt;&gt; newPass2 then
		app.msgBox( app.getErrorString(ERR_PSWDS_DIFFER), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.txtNewPassword2.setFocus;
		return;
	endif;
	
	if self.maxLength &gt; 0 and newPass.length &gt; self.maxLength then
		msg := self.lblObjDescr.caption &amp; " " &amp; app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '30');
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtNewPassword.setFocus;
		return;
	endif;
	
	self.encryptedPassword := app.pwEnCode( newPass );
	
	if self.myPxyObject &lt;&gt; null then
		if configAttributeName = CM_SFTPEntity::passPhrase.name and self.myPxyObject.isKindOf( CM_SFTPEntity ) then	//06 Sep 2021	NDL	TFS 51165
			self.myPxyObject.setProxyPw( self.encryptedPassword, CM_SFTPEntity::passPhrase.name );
		elseif configAttributeName = CM_KiwiRailCheckInWSDef::messagePassword.name and self.myPxyObject.isKindOf( CM_KiwiRailCheckInWSDef ) then
			self.myPxyObject.setProxyPw( self.encryptedPassword, CM_KiwiRailCheckInWSDef::messagePassword.name );
		else
			self.myPxyObject.setProxyPw( self.encryptedPassword, null );
		endif;
	elseif self.myCMIFConfig &lt;&gt; null then
		self.myCMIFConfig.setPropertyValue( self.configAttributeName, self.encryptedPassword );
	elseif self.isNew then
		//nothing to update directly will be taken from the return value
	else
		self.modalResult := 99;
		self.unloadForm;
		return;
	endif;
	
	self.modalResult := 0;
	self.unloadForm;
	
epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyPxyObject" id="3cd6c941-5605-490e-a615-64f6efddda52">
        <updating/>
        <source>setMyPxyObject( _mode : Integer; _obj : CM_Object; _config : CMIF_Config; _configField : String; _maxRawLength : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	etGroup : EntTableGroup;
	etRow : EntTableRow;

begin

	self.isNew := _mode = CM_TableViewForm.Mode_Add;
	self.myPxyObject := _obj;
	self.myCMIFConfig := _config;
	self.configAttributeName := _configField;
	self.maxLength := _maxRawLength;

		//moved to setupForm 06 Sep 2021	NDL	TFS 51165
/*	if self.myPxyObject &lt;&gt; null then
		lblObjDescr.caption := self.myPxyObject.getDisplayDetails( true );
	elseif self.myCMIFConfig &lt;&gt; null then
		etGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_ConfigGroup);
		if etGroup &lt;&gt; null and self.configAttributeName &lt;&gt; null then
			etRow := etGroup.getEntTableRow( self.configAttributeName );
		endif;
		if etRow &lt;&gt; null then
			lblObjDescr.caption := etRow.getHeading(null, null, app.myCurrentLocale);
		else
			lblObjDescr.caption := self.configAttributeName.cnEcFirstToUpper();
		endif;
		
	endif; */

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_config" type="CMIF_Config"/>
        <Parameter name="_configField" type="String"/>
        <Parameter name="_maxRawLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a4b61500-ff63-4c6c-b0f2-87a6d6d099ea">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51165
13 March 2023		navmd1	TFS 57047 Fix default caption showing when creating new SFTP entitiy

*/

vars

	etGroup : EntTableGroup;
	etRow : EntTableRow;

begin

	inheritMethod();
	
	if self.myPxyObject &lt;&gt; null then
	
		if configAttributeName = CM_SFTPEntity::passPhrase.name and self.myPxyObject.isKindOf( CM_SFTPEntity ) then
			etGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_SFTPEntityMaint);	
		elseif configAttributeName = CM_KiwiRailCheckInWSDef::messagePassword.name and self.myPxyObject.isKindOf( CM_KiwiRailCheckInWSDef ) then
			etGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_ExtWebService);
		elseif configAttributeName = CM_SFTPEntity::password.name then
			//Reaal just anything that uses 'password'
			etGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_SFTPEntityMaint);
		endif;
		if etGroup &lt;&gt; null and self.configAttributeName &lt;&gt; null then
			etRow := etGroup.getEntTableRow( self.configAttributeName );
		endif;
		
		if etRow &lt;&gt; null then
			lblObjDescr.caption := self.myPxyObject.getDisplayDetails( true ) &amp; "  (" &amp; etRow.getHeading(null, null, app.myCurrentLocale) &amp; ")";
		else
			lblObjDescr.caption := self.myPxyObject.getDisplayDetails( true );
		endif;
		
			
	elseif self.myCMIFConfig &lt;&gt; null then
		etGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_ConfigGroup);
		if etGroup &lt;&gt; null and self.configAttributeName &lt;&gt; null then
			etRow := etGroup.getEntTableRow( self.configAttributeName );
		endif;
		if etRow &lt;&gt; null then
			lblObjDescr.caption := etRow.getHeading(null, null, app.myCurrentLocale);
		else
			lblObjDescr.caption := self.configAttributeName.cnEcFirstToUpper();
		endif;
		
	else
		// Probably a create of a new object, so for now, display nothing
		lblObjDescr.caption := null;		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="14234b06-5d96-4f7d-bc19-15f93d659c33">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 August 2021 15:30:30.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024447, locale);
	lblNewPassword.translateCaption(Xlat_0024448, locale);
	lblNewPassword2.translateCaption(Xlat_0024449, locale);
	lblObjDescr.translateCaption(Xlat_0024450, locale);
end;</source>
    </JadeMethod>
</GUIClass>
