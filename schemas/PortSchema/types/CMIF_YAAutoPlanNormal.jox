    <JadeMethod name="isTrain_Match" id="491f8f33-219c-4bf7-9767-313f8924ffc2">
        <source>isTrain_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:		The scenarios are as follows:
					If a container is coming off a ship and it has no assigned train then the TI will not be placed into a train YA.
					If a container is coming off a ship and it has myTrainedAssigned as ABC then the train will be placed into YA train ABC
					if a container is received by train ABC and no myTrainAssigned it will be placed into YA train ABC
					If a container is recieved by train ABC and myTrainAssigned is XYZ it will be placed into YA XYZ.  Kind of confusing but need to keep existing behaviour
					If a container prenotified to be on ABC but is currently sitting on train XYZ then it will be placed into YA XYZ.  Actually location is KING

Date			Who		Reason
11 June 2009	conkc1	Initial creation
12 August 2010	cnwjo3	par 25389
*/
vars
	ti : CM_TrackedItem;
	train : CM_Train;
begin
	ti := self.myTrackedItem;
	if ti.receiptTransportMode = TI_TRANSMODE_RAIL and ti.myTrainAssigned = null then
		train := ti.getMyCurrentTrain(true);
		
		if train = null then
			train := ti.getMyNotifiedTrain();	
		endif;
	else
		train := ti.myTrainAssigned;
	endif;
	
	if train &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(train);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
