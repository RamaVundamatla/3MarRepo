    <JadeMethod name="validateForUpdate" id="66d26d84-2c84-425e-9803-6f24b16d5f39">
        <source>validateForUpdate();
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Standard validation method for when the receiver is updated.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07/10/2019	jlgsl4		TFS 46856 - MSL - Allocations with same criteria
// 18/03/2021	navdap1		TFS 50946 PRP Auto Delete of Yard Allocations
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	optionsObj	: CM_YADeckingOptions;
	yardAllocation : CM_YardAllocation; // TFS 46856
begin
	foreach blockObj in self.allYABlocksIn do
		blockObj.validate();
		
		optionsObj	:=	blockObj.myDeckingOptions;
		
		if optionsObj &lt;&gt; null then
			optionsObj.validateForDecking();	//add validation - test if OK for decking
			optionsObj.validate();
		endif;
	endforeach;
	if self.isTransient and self.myTerminal &lt;&gt; null then // --&gt; TFS 46856
		yardAllocation := self.myTerminal.allYardAllocatonsByCode[self.code];
		if yardAllocation &lt;&gt; null and yardAllocation &lt;&gt; self.pxyGetRealObject() then // allocation with same code exists
			app.raiseCMException1(Err_YA_AlreadyExists, yardAllocation.code, null, null);
		endif;	// that isn't proxy's real object, so raise exception
	endif; // &lt;-- TFS 46856
	
	self.validateBGPForNoCargoExpiry();			// TFS 50946
end;</source>
    </JadeMethod>
</Class>
