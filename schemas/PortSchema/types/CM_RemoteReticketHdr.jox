    <JadeMethod name="processExternal" id="4dfb93a7-3900-4449-9bde-bb2452f6acde">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	response		: String;
	err				: Integer;
	errTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;

begin
	
	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createReticketDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return self.doBuildMessage(self.xmlResponse(err, errTxt));
			endif;
		endif;
		response := app.getErrorString1(Err_XML, 'reticket');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processInternal" id="cb3c15c6-e1d2-4d98-a2c4-694a1ca02d7e">
        <updating/>
        <source>processInternal(_cmif: CMIF_Remote; _passport : CM_Passport input): Boolean updating;

// cnwdvb1 20 November 2002 

vars
	reticket			: CM_RemoteReticketDtl;
	huge				: HugeStringArray;
	tiString			: String;
	realRemoteHdr		: CM_RemoteDataHdr;
	
begin
	
	inheritMethod(_cmif, _passport);
	
	self.setAreaLocationWhenInternal(_cmif);	// PAR 21218 24/02/2010. Need to save location, when logs are moving to a new location.

	create reticket transient;
	reticket.setProxyForReticket(self, _cmif.allTis, '"LOG"');
	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);

	return _passport.trxCompletedOK;


end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="f1ae0dfa-133f-417c-ac66-8d343d3153e0">
        <source>runProcess(_errorSet : CM_ErrorSet input; _isBackGround : Boolean) : Boolean;

vars

	myTerminal			: CM_Terminal;
	remoteReticketDtl	: CM_RemoteDataDtl;	
	reticketTISet,
	errorTISet			: CMIF_TIReticketSet; 
	reticket			: CMIF_TIReticket;
	pos					: Integer;
	location			: CM_LocationsController;
	termArea			: CM_TerminalArea;
	term, loc			: String;
	errorArray			: StringArray;
	

	

begin

	//PAR 21218  23/02/2010. This par touches BGP Internal mode only, when the Background button is turned on in the LOG_ReticketForm and a user presses the Save button.
	if _isBackGround and (self.messageId = self.MessageIdInternal) then	// It means, if there are some validation warnings, a system allert is created to show this warnings and logs are not processed.
		app.myPassport.setIsBackgroundWarningsIgnored(false);	// For example, to stop moving logs, when Inspected/Fumigated status to be changed on a log row or on the logs.
	endif;

	myTerminal := app.myPassport.myTerminal;

	if self.areaLocation &lt;&gt; null then
		// If area location is null then we don't want to move so continue.
		pos 	:= 1;
		term	:= self.areaLocation.scanUntil(',', pos);
		loc		:= self.areaLocation[pos + 1: end];
		termArea := myTerminal.allTerminalAreas[term];
		if termArea = null then
			app.raiseCMException1(Err_InvalidTerminalArea, term, null, null);
		endif;	
		location := termArea.getLocationsControllerFromId(loc);
		if location = null then
			app.raiseCMException1(Err_InvalidLocation, loc, null, null);
		endif;
	endif;
	create errorArray transient;
	create reticketTISet transient;	
	create errorTISet transient;
	foreach remoteReticketDtl in self.allRemoteDataDtl do
		remoteReticketDtl.CM_RemoteReticketDtl.doReticket(_errorSet, reticketTISet, myTerminal);
	endforeach;
	// Need to do location stuff in XML first;
	app.myTrxUA.trxUpdateReticketTI(reticketTISet, errorTISet, TI_CargoType_Log, TA_TYPE_LOGAREA, location, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	endif;
	foreach reticket in errorTISet do
		//self.addError(RemoteDataError, reticket.errorDescription, _errorSet);
		self.addError(reticket.errorCode, reticket.errorDescription, _errorSet);//13 Sep 2012	NDL	Par 30366
		errorArray.add(reticket.oldId &amp; ',' &amp; reticket.newId);
	endforeach;
	
	reticketTISet.purge;
	errorTISet.purge;
	return inheritMethod(_errorSet, _isBackGround);

epilog
	
	delete errorArray;
	delete errorTISet;
	delete reticketTISet;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="14497973-bb81-410e-b0a6-5d2096c82fc8">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;

// cnwdvb1 21 January 2003 

vars

begin
	inheritMethod(_table, _entryTableColumns);
	self.areaLocation := _table.accessCell(3, _entryTableColumns).text.trimBlanks;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAreaLocationWhenInternal" id="db1e7fa7-399a-4c1f-8cb0-c126ca08685f">
        <updating/>
        <source>setAreaLocationWhenInternal(_cmif : CMIF_Remote) updating;
/* ---------------------------------------------------------------------------
Created:	24 February 2010	by cnwvu1

Purpose:	PAR 21218
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _cmif.terminalAreaTo &lt;&gt; null and _cmif.location &lt;&gt; null then
		self.areaLocation := _cmif.terminalAreaTo &amp;","&amp; _cmif.location;	// the same format as external XML loading
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2372451d-f012-4315-a380-168787a3fd9b">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteReticketHdr) updating;

// cnwdvb1 21 January 2003 

vars

begin
	inheritMethod(_proxy);
	self.areaLocation := _proxy.areaLocation;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteReticketHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForReticket" id="5b01ca3e-2331-4897-ac67-15e0371adda1">
        <updating/>
        <source>setProxyForReticket(_areaLocation : String) updating;

// cnwdvb1 21 January 2003 

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.areaLocation := _areaLocation;

end;</source>
        <Parameter name="_areaLocation" type="String"/>
    </JadeMethod>
</Class>
