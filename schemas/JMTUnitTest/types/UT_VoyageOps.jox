    <JadeMethod name="tLOLOSOBMoves" id="b6bf758f-0acd-4b04-be8d-afc77244a55f">
        <source>tLOLOSOBMoves();

/*

Purpose:		SOB moves (Milaha style)

Date			Who		Reason
04/03/2013		cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	
	VoyageId						: String = "VOYLOLOSOB";
	VesselId						: String = "TRIP";

vars

	voyage							: CM_Voyage;
	operator						: CM_Operator;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// initialisations
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNull(operator);

	// create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString); 
	self.assertNotNull(voyage);

	// create the 20 and 40 foot containers on the voyage
	self.xCreateLOLOSOBContainers(voyage);
	
	// discharge colour code and discharge 2 x 20 and 2 X 40 containers
	// SOB Colour code 3 x 20 (one to backend 40 and 1 each to front 20 and 40) and 1 x 40 
	self.xDischCCDischLOLOSOB(voyage);
	
	// move the 4 SOB's 
	self.xDischCCDischSOBLOLOSOB(voyage);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
