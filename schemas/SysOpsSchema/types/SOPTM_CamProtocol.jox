    <JadeMethod name="loadJRWDesignNameComboBox" id="f75bc5d0-b4a9-4d35-bc5c-2c6fe8ce7cf3">
        <updating/>
        <source>loadJRWDesignNameComboBox(_view : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwphb1	Initial creation

*/

vars
	str		: String;
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	if _view = theForm.JRWView_Transaction then
		if theForm.jrwView &lt;&gt; theForm.JRWView_Transaction then
			self.populateJRWReports();			// PAR 21905 CCMS MES 1008 - PHB
			theForm.cmbJRWDesignName.sorted := true;
			theForm.cmbJRWDesignName.clear;
			foreach str in self.allJRWReportsTransactionView do
				theForm.cmbJRWDesignName.addItem(str);
			endforeach;
			theForm.jrwView := theForm.JRWView_Transaction;
		endif;
	elseif _view = theForm.JRWView_TrackedItem then
		if theForm.jrwView &lt;&gt; theForm.JRWView_TrackedItem then
			self.populateJRWReports();			// PAR 21905 CCMS MES 1008 - PHB
			theForm.cmbJRWDesignName.clear;
			foreach str in self.allJRWReportsTrackedItemView do
				theForm.cmbJRWDesignName.addItem(str);
			endforeach;
			theForm.jrwView := theForm.JRWView_TrackedItem;
		endif;
	else
		theForm.cmbJRWDesignName.clear;
		theForm.jrwView := theForm.JRWView_None;
	endif;
end;</source>
        <Parameter name="_view" type="Integer"/>
    </JadeMethod>
