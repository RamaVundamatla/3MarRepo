<Class name="EntTableTextBox">
    <JadeMethod name="initialiseFieldFrame" id="e4ac51b9-2332-487e-9fa2-a71dce504c95">
        <updating/>
        <source>initialiseFieldFrame(_frame: Frame) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwdap1	Initial creation

*/
vars
	fieldFrame : CMUI_FieldTextBox;

begin
	if not _frame.isKindOf(CMUI_FieldTextBox) then
		return;
	endif;
	
	fieldFrame := _frame.CMUI_FieldTextBox;
	fieldFrame.setInputType(TextBox.DataType_AlphaNumeric);
	fieldFrame.setTextCase(self.case);
	fieldFrame.setMaxLength(self.maxLength);
	fieldFrame.setInputKind(fieldFrame.KIND_STRING);
epilog

end;</source>
        <Parameter name="_frame" type="Frame"/>
    </JadeMethod>
</Class>
