<GUIClass name="ComboBox">
    <JadeMethod name="getCurrentItemData" id="5049224d-22d6-4940-b073-29852ad96e72">
        <source>getCurrentItemData() : Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin

	idx := self.listIndex;
	if idx &lt;= 0 then
		return 0;
	endif;
	
	return self.itemData[idx];

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentItemObject" id="66265981-a59f-4083-bdf8-cbd64d6bfde4">
        <source>getCurrentItemObject(): Object;
/*
Purpose: Return the Object associated with the current item displayed in combo box		

Date		Who		Reason
26 April 2011	cnwdw1	Initial creation
*/
vars
	idx	: Integer;
begin
	idx := self.listIndex;
	if idx &lt;= 0 then
		return null;
	endif;
	
	return self.itemObject[idx];
epilog

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="97f2932b-a603-4095-bce5-5e2f1ec0aa00">
