<Class name="BGP_AutoProcessExpiredPTI" id="4849b59d-c089-4ad8-a327-6aecdb1b33b5">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Process Expired PreTrip Inspection&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myToDoTaskDesc" id="c2fe0e37-5cdb-48a3-82db-43dc05711034">
        <embedded/>
        <type name="CM_ToDoTaskDesc"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="df3e9b0c-9f68-48d6-b029-0be382f1bdeb">
        <updating/>
        <source>action(): Boolean updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.processPTIExpired();
epilog

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString2(Successfully_Processed_PTI, self.myToDoTaskDesc.shortDescription, self.myTerminal.code), false, false);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="f95c628c-03c9-40b5-a3d3-ed80dc79691e">
        <source>getDisplay(): String;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return inheritMethod &amp; Tab &amp; 'Check PreTrip Inspection Expired';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="c74a84b1-d58a-42b5-a486-451a5ad39a23">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskPTIExpired) updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.myToDoTaskDesc	:= _task.myToDoTaskDesc;		
	inheritMethod(_task);
end;</source>
        <Parameter name="_task" type="CM_AutoTaskPTIExpired"/>
    </JadeMethod>
    <JadeMethod name="processPTIExpired" id="8328d0a7-8b95-46bb-bca5-907c46927dd7">
        <updating/>
        <source>processPTIExpired()updating, protected;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  PTI Expired Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate terminal', null, null);
		return;
	endif;
	
	if self.myToDoTaskDesc = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate To Do Task for PTI', null, null);
		return;
	endif;
		
	app.myPassport.setMyTerminal(self.myTerminal);

	app.myTrxUA.trxAutoProcessExpiredToDoTask(self.myTerminal, self.myToDoTaskDesc, app.myPassport);
			
	if (not app.myPassport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process PTI Expired',null, app.myPassport.allErrors, null, true, true);
	endif;
	msg := "=====================  PTI Expired Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053		
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
