    <JadeMethod name="setProxy" id="27753e76-0ff3-44e6-92de-19204b23c4e7">
        <updating/>
        <source>setProxy(	_sealNum 		: String;
			_sealNumArray 	: HugeStringArray;
			_prevSeal 		: String;
			_sealType 		: String;
			_sealedDT 		: TimeStamp;
			_myTrackedItem 	: CM_TrackedItem
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


/* Changes

Date		Name	TFS#		Description
============================================================================
10/09/2010	cnwndl1	Par 25608	Initial creation	
12/02/2019	jlgka1	42861		Change Seals field size to maximum.
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
begin

	self.raiseExceptionIfNotTransient(method);
	
	self.allSealNums.clear();
	
	if _sealNumArray &lt;&gt; null and not _sealNumArray.isEmpty then
		_sealNumArray.copy( self.allSealNums );
	elseif  _sealNum &lt;&gt; null then
		self.allSealNums.add( _sealNum );
	endif;
	
	self.previousSeal := _prevSeal;
	self.sealType := _sealType;
	self.sealedDT := _sealedDT;
	self.myTrackedItem := _myTrackedItem;	
end;</source>
        <Parameter name="_sealNum" type="String"/>
        <Parameter name="_sealNumArray" type="HugeStringArray"/>
        <Parameter name="_prevSeal" type="String"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_sealedDT" type="TimeStamp"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
