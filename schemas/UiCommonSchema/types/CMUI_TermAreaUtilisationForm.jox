//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	delete app.myPassport.myCMIFMonitor;	
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySpaceTable" id="726e305a-861a-4515-b518-bc4bdfb7a918">
        <updating/>
        <source>displaySpaceTable( _fromColOrg : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars

	tmpKPILocn : CM_KPILocation;
	tmpKPITA : CM_KPITerminalArea;
	tmpKPI : CM_KPI;
	line : String;
	idx : Integer;
	colIndex : Integer;
	jadeTableColumn : JadeTableColumn;
	leftAlignIndices : IntegerArray;
	ta : CM_TerminalArea;
	localColl : CM_KPIByTypeCodeTS;
	showGridded : Boolean;
	showBlocks : Boolean;
	showBulk : Boolean;
	showGC : Boolean;
	showRoRo : Boolean;
	summaryLines : IntegerArray;
	
begin

	self.tblData.rows := self.tblData.fixedRows;
	
	if self.myQueryAgent = null then
		return;
	endif;

	if _fromColOrg then
		self.tblData.sortColumn[1] := null;
	else	
		if self.myQueryAgent.allQryTerminalAreas.isEmpty then
			app.msgBox(app.getErrorString(YoMustSelectATerminalArea), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			self.fldQuery.topSheet := self.shtQuery1;
			return;
		endif;
		self.mySummaryLine.clearSummaryData( app.getErrorString(Summary) );
		self.myBSSummary.clearSummaryData( app.getErrorString(Block_stack) );
		self.myBulkSummary.clearSummaryData( app.getErrorString(Bulk_area) );
		self.myGCSummary.clearSummaryData( app.getErrorString(GCArea) );
		self.myGridSummary.clearSummaryData( app.getErrorString(Grid_area) );
		self.myRoroSummary.clearSummaryData( app.getErrorString(Roro_lane) );
		self.initTableData(null);
	endif;
	
	create summaryLines transient;
	create localColl transient;
	
	//gridded areas
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas do
		if localColl.includes( tmpKPI ) then
			continue;
		endif;
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		ta := tmpKPITA.getTA.CM_TerminalArea;
		
		if ta.type  = TA_TYPE_STRADDLE_STACK
		or ta.type = TA_TYPE_FORK_LIFT_STACK
		or ta.type = TA_TYPE_RTG 
		or ta.type = TA_TYPE_RMG
		then
			if not showGridded then
				self.addSubHeadingLine( self.myGridSummary, summaryLines );
			endif;
			self.addBodyLine( tmpKPITA, _fromColOrg, self.myGridSummary, localColl );
			showGridded := true;
		endif;
	endforeach;
	if showGridded then
		self.addSubTotalLine( self.myGridSummary, summaryLines );
	endif;
	
	// block stacks
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas do
		if localColl.includes( tmpKPI ) then
			continue;
		endif;
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		ta := tmpKPITA.getTA.CM_TerminalArea;
		
		if ta.type = TA_TYPE_BLOCK_STACK then
			if not showBlocks then
				self.addSubHeadingLine( self.myBSSummary, summaryLines );
			endif;
			self.addBodyLine( tmpKPITA, _fromColOrg, self.myBSSummary, localColl );
			showBlocks := true;
		endif;
	endforeach;
	if showBlocks then
		self.addSubTotalLine( self.myBSSummary, summaryLines );
	endif;
	
	// bulk areas
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas do
		if localColl.includes( tmpKPI ) then
			continue;
		endif;
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		ta := tmpKPITA.getTA.CM_TerminalArea;
		
		if ta.type = TA_TYPE_BULK then
			if not showBulk then
				self.addSubHeadingLine( self.myBulkSummary, summaryLines );
			endif;
			self.addBodyLine( tmpKPITA, _fromColOrg, self.myBulkSummary, localColl );
			showBulk := true;
		endif;
	endforeach;
	if showBulk then
		self.addSubTotalLine( self.myBulkSummary, summaryLines );
	endif;
	
	//General Cargo Areas
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas do
		if localColl.includes( tmpKPI ) then
			continue;
		endif;
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		ta := tmpKPITA.getTA.CM_TerminalArea;
		if ta.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
			if not showGC then
				self.addSubHeadingLine( self.myGCSummary, summaryLines );
			endif;
			self.addBodyLine( tmpKPITA, _fromColOrg, self.myGCSummary, localColl );
			showGC := true;
		endif;
	endforeach;
	if showGC then
		self.addSubTotalLine( self.myGCSummary, summaryLines );
	endif;
	
	//Roro lanes
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas do
		if localColl.includes( tmpKPI ) then
			continue;
		endif;
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		ta := tmpKPITA.getTA.CM_TerminalArea;
		
		if ta.type = TA_TYPE_RORO_LANE_AREA then
			if not showRoRo then
				self.addSubHeadingLine( self.myRoroSummary, summaryLines );
			endif;
			self.addBodyLine( tmpKPITA, _fromColOrg, self.myRoroSummary, localColl );
			showRoRo := true;
		endif;
	endforeach;
	if showRoRo then
		self.addSubTotalLine( self.myRoroSummary, summaryLines );
	endif;
	
	if showGridded or showBlocks or showBulk or showGC or showRoRo then
		line :=  self.mySummaryLine.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		idx := self.tblData.addItemObject(self.mySummaryLine, line.trimBlanks);
		self.tblData.accessRow(idx).fontBold := true;
	endif;
	
	create leftAlignIndices transient;
	
	colIndex := self.tblData.getColumnByRowName(ETRow_Area);
	if colIndex &gt; 0 then
		leftAlignIndices.add(colIndex);
	endif;
	
	foreach colIndex in 1 to self.tblData.columns do
		if leftAlignIndices.includes( colIndex ) then
			continue;
		endif;
		jadeTableColumn := self.tblData.accessColumn(colIndex);
		if jadeTableColumn &lt;&gt; null then
			jadeTableColumn.alignment := Table.Alignment_Right_Middle;
		endif;
	endforeach;
	
	self.tblData.accessRow(1).alignment := Table.Alignment_Left_Middle;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	foreach idx in summaryLines do
		self.tblData.accessRow(idx).backColor := LightGray;
	endforeach;
	
epilog

	delete leftAlignIndices;
	delete localColl;
	delete summaryLines;
	
end;</source>
        <Parameter name="_fromColOrg" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComboTABuild" id="ffbdd16c-7b94-4180-8b41-b1c48bbd8a13">
        <source>doComboTABuild();
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTAs : CM_TerminalAreaMasterSet;
	tmpTA : CM_TerminalAreaMaster;
	tmpKPI : CM_KPI;
	iter : Iterator;
begin
	create tmpTAs transient;
	
	iter := self.myTerminal.allKPIbyTypeCodeTS.createIterator();
	tmpKPI := self.myTerminal.allKPIbyTypeCodeTS.getAtKeyGeq(KPI_Type_TerminalArea,null,null);
	if tmpKPI &lt;&gt; null then
		iter.startAtObject(tmpKPI);
		
		tmpTA := self.myTerminal.allTerminalAreaMastersById[tmpKPI.code];
		if tmpTA &lt;&gt; null then
			tmpTAs.addNoDuplicates(tmpTA,false);
		endif;
	endif;
	
	while iter.next(tmpKPI) do 
		if tmpKPI.type &lt;&gt; KPI_Type_TerminalArea then
			break;
		endif;

		tmpTA := self.myTerminal.allTerminalAreaMastersById[tmpKPI.code];
		if tmpTA &lt;&gt; null then
			tmpTAs.addNoDuplicates(tmpTA,false);
		endif;

	endwhile;
	
epilog
	delete tmpTAs;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExport" id="34858736-05cb-4204-9e29-8a33ebc034c6">
        <source>doExport();
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ts	: TimeStamp;
begin
//	self.showExportFrame();
	ts := app.actualTimeServer;

	if self.fldMain.topSheet = self.shtSpace then
		self.tblData.outputAsCSV("JMTAreaUtil" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxTermAreaBuild" id="55d63ba7-8131-422b-90b9-802c0bd72af6">
        <updating/>
        <source>doListBoxTermAreaBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
============================================================================*/
vars

	aTerminalAreaMaster : CM_TerminalAreaMaster;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	passport := app.myPassport;
	self.lstTermArea.zOrder(1);
	self.lstTermArea.rows := 0;
	
	app.cmsBeginLoad(ls);
	foreach aTerminalAreaMaster in self.myTerminal.allTerminalAreaMastersById 
				where aTerminalAreaMaster.type  = TA_TYPE_STRADDLE_STACK
				or aTerminalAreaMaster.type = TA_TYPE_FORK_LIFT_STACK
				or aTerminalAreaMaster.type = TA_TYPE_RTG 
				or aTerminalAreaMaster.type = TA_TYPE_RMG
				or aTerminalAreaMaster.type = TA_TYPE_BLOCK_STACK   
				or aTerminalAreaMaster.type = TA_TYPE_RORO_LANE_AREA	
				or aTerminalAreaMaster.type = TA_TYPE_IRREGULAR_BLOCK_AREA	
				or aTerminalAreaMaster.type = TA_TYPE_BULK
				or aTerminalAreaMaster.type = TA_TYPE_MAFI
				do
		if aTerminalAreaMaster.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstTermArea.addItemObject(aTerminalAreaMaster.getID() &amp; " - " &amp; aTerminalAreaMaster.typeString,aTerminalAreaMaster);
			self.lstTermArea.accessRow(idx).backColor := White;
			self.lstTermArea.accessRow(idx).foreColor := Black;
		endif;
	endforeach;
	app.cmsEndLoad(ls);

	self.lstTermArea.userInputEnabled := true;
epilog
	endLoad;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="36417e3e-d7b9-4478-a023-caed7ed0c84b">
        <source>doMnuInspectObject();
// ---------------------------------------------------------------------------
// Created:		08 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	anObject : Object;
begin
	if self.fldMain.topSheet = self.shtSpace then
		idx :=  self.tblData.row;
		if idx &gt; self.tblData.fixedRows then
			anObject := self.tblData.accessRow(idx).itemObject;
			if anObject &lt;&gt; null then
				anObject.inspect;
			endif;
		endif;
	else
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="47d9e211-f5cc-4fd3-a85f-000cccc69e6f">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
