    <JadeMethod name="lastRunDTIsValid" id="e0055b82-f9d4-4bb6-b536-3a687aa22969">
        <source>lastRunDTIsValid(): Boolean protected;
//----------------------------------------------------------------
//	Created:	01 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 11/Dec 2012	cnwcs5	par 30855 / CCMS SFW 1294 - minor tweaks
vars
	today	: Date;
	ts		: TimeStamp;
begin
	ts := self.lastRunDateTime;
	
	if ts = null or (not ts.isValid) or ts.date.year &lt; today.year - 2 then
		//only go back two years at most
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nextDueDateTime" id="5b8de96b-d5ee-47c4-8f30-82aaf55456fb">
        <source>nextDueDateTime(_nowDateTime : TimeStamp; _nextStartDateTime : TimeStamp io; _nextEndDateTime : TimeStamp io);

vars
	camTaskHistory : CM_CamTaskHistory;
	dueDateTime : TimeStamp;
	date : Date;
	numEntrys : Integer;
	i : Integer;
begin
	numEntrys := scheduleTimes.size;
	// if there is no schedule it will never be due
	if numEntrys = 0 then
		_nextStartDateTime := null;
		_nextEndDateTime := null;
		return;
	endif;

	self.dueDateTimes(_nowDateTime, _nextStartDateTime, _nextEndDateTime);

end;</source>
        <Parameter name="_nowDateTime" type="TimeStamp"/>
        <Parameter name="_nextStartDateTime" type="TimeStamp" usage="io"/>
        <Parameter name="_nextEndDateTime" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onHold" id="40bb2669-33e8-4ec3-8529-ab083b73d39d">
        <methodInvocation>mapping</methodInvocation>
        <source>onHold(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	29 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if app.myProxyManager.allReals.includesKey(self) then //cnwrs1 Feb 2007 suspend cams for this protocol while it is being updated
		_value := true;
	else
		_value := (self.status = CAM_HOLDSTATUS);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="protocolExceptionHandler" id="5cf2c084-d508-41f6-9ce4-23e4982e9d15">
        <updating/>
        <source>protocolExceptionHandler(ex : Exception) : Integer updating;

/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks
17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
*/

vars
	message : String;
	callStack : ProcessStackArray;
	methodCallDesc: MethodCallDesc;
	stack : String;
begin
	app.writeLog("CAM XHandler Start", LogINFO);

	on NormalException do null;
	message := ex.text;
	if (ex.errorCode &gt; 30335 and ex.errorCode &lt; 30341) or (ex.errorCode &gt; 16000 and ex.errorCode &lt; 16009) then
	//	message := terminal.getMessage("",ex.errorCode);
	endif;
	if process.isInTransactionState() then
	else
		beginTransaction;
	endif;
/*	if self.camTask &lt;&gt; null then	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
		self.camTask.setErrorStatus(message);
	endif;*/
	commitTransaction;

	app.writeLog("Error : Processing error " &amp; message &amp; " " &amp; ex.currentMethodDesc.display &amp; " " &amp; ex.errorObject.String, LogINFO);
	app.writeLog("Error : " &amp; ex.errorItem.trimBlanks &amp; " " &amp; ex.extendedErrorText.trimBlanks &amp; ".", LogINFO);
	
	create callStack;
	process.currentStack(callStack);
	
	foreach methodCallDesc in callStack do
		stack := stack &amp; methodCallDesc.display &amp; " ";
	endforeach;
	
	app.writeLog(stack, LogINFO);
	
//	if self.myCamControllerAgent.armExceptionHandler then
//		on NormalException do protocolExceptionHandler(exception) global;
//	endif;

	return Ex_Abort_Action;
epilog
	if callStack &lt;&gt; null then		//PAR #18009
		callStack.purge();
		delete callStack;
	endif;
end;</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purgeExceptionHandler" id="4e998982-4174-4614-a838-d51331995580">
        <source>purgeExceptionHandler(_exc : Exception;  _invalidObject : Boolean io) : Integer;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich  MES1011 28/7/09             

 Purpose:     Exception handler to deal with deleted transactioons on allProcessedTransactions.
				Copied method on app and modified

 Parameters:  

 Returns:     Standard Exception return codes, and _invalidObject set to true if
					the specified object reference caused the exception.

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin

	returnVal := Ex_Pass_Back;
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		_invalidObject := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog
	return returnVal;	
end;
</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9e3bfb67-3057-4b5e-9d32-32f5e3885df6">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 15 May 2014	cnwrs1		Par 34159 - include Chassis in Codeco
// 05 Jun 2014	cnwrs1		Par 34323 - cargo type in Cam Protocol
// 30 Apr 2015	cnwrs1		Par35784 - increased exclusion reason logging to include non excluded
// 03 Feb 2021	jlgdap1		TFS 50726 GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
// 29 Mar 2022	jlika1		TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
// 18 Jul 2022	jlizm1		TFS 54142 AAT - Add NAD+MS to Standard COARRI SMDG213
// 06 Dec 2022	navdap1		TFS 55159 MTN - Export CAMS to JSON API Endpoint
// ---------------------------------------------------------------------------
vars
	tmpCamProtocol : CM_CamProtocol;
	completedOK		: Boolean;
begin

	tmpCamProtocol := inheritMethod();
	if tmpCamProtocol.registeredTransactions = null then
		create tmpCamProtocol.registeredTransactions transient;
	endif;
	if tmpCamProtocol.allRegisteredCargoTypes = null then
		create tmpCamProtocol.allRegisteredCargoTypes transient;
	endif;
	tmpCamProtocol.camGroup := self.camGroup;
	tmpCamProtocol.myEmailEntity := self.myEmailEntity;
	tmpCamProtocol.myFTPEntity := self.myFTPEntity;	// CCMS 1143 cnwrs1 10 Aug 2010
//	tmpCamProtocol.emailAddress	:= null;	//can remove
	tmpCamProtocol.protocolDesc := self.protocolDesc;
	tmpCamProtocol.myQFCamTransactionTemplate	:= self.myQFCamTransactionTemplate;
	self.allCoarriExportPorts.copy(tmpCamProtocol.allCoarriExportPorts);

	self.allCopyEmailEntities.copy(tmpCamProtocol.allCopyEmailEntities);
	self.registeredTransactions.copy(tmpCamProtocol.registeredTransactions);
	self.allRegisteredCargoTypes.copy(tmpCamProtocol.allRegisteredCargoTypes);
	self.packExportConsignees.copy(tmpCamProtocol.packExportConsignees);
	self.packOperators.copy(tmpCamProtocol.packOperators);
	self.allEditTriggerFields.copy(tmpCamProtocol.allEditTriggerFields);
	self.allTrainEventTypes.copy(tmpCamProtocol.allTrainEventTypes);	// PAR 21905 CCMS MES 1008 - PHB
//	self.scheduleTimes.copy(tmpCamProtocol.scheduleTimes);	// don't need this here - TimeArray done by clone
	tmpCamProtocol.mySelector:=self.mySelector;
	tmpCamProtocol.setLogExcludedTransactions(self.getLogExcludedTransactions());
	tmpCamProtocol.setLogIncludedTransactions(self.getLogIncludedTransactions());
	
	tmpCamProtocol.setIncludeLOC7InterTerm(self.getIncludeLOC7InterTerm);		// TFS 50726
	tmpCamProtocol.setIsCustomsProtocol(self.getIsCustomsProtocol);
	tmpCamProtocol.setIncludeNADMSCOARRISMDG213(self.getIncludeNADMSCOARRISMDG213); // TFS 54142
	
	tmpCamProtocol.myExternalWebServiceDef := self.myExternalWebServiceDef;		// TFS 55159
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpCamProtocol;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpCamProtocol;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresCargoType" id="5c633a94-bcfd-4b05-936a-d4653e139a2d">
