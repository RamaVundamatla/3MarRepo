    <JadeMethod name="doResize" id="e25d9a4c-425c-41b7-83ed-ce7a911b829a">
        <updating/>
        <source>doResize() updating;

vars

begin
	inheritMethod();
	
	if self.width &gt;= 300 then
		self.tblDecks.width := self.width - (2 * self.tblDecks.left)  - 8;
	endif;

end;
</source>
    </JadeMethod>
