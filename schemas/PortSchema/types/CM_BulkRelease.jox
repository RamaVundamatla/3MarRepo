    <JadeMethod name="includesReserveWithIsoGroup" id="601b458b-b376-4ff7-a74a-17c0e43ca7b8">
        <source>includesReserveWithIsoGroup( _isoGroup : CM_ISOTypeGroup ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2011	cnwndl1	Initial creation	Par 27642

*/

vars

	aReserve : CM_ReserveDetail;
	isoGroup : CM_ISOTypeGroup;

begin

	if _isoGroup &lt;&gt; null then
		foreach aReserve in self.allReserveDetails discreteLock do
			isoGroup :=  aReserve.getISOGroup();
			if isoGroup = null then
				continue;
			endif;
			if isoGroup = _isoGroup then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_isoGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
