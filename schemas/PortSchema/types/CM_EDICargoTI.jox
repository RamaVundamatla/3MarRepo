    <JadeMethod name="getCargoTypeObj" id="3b045b74-dc7a-46b9-9eda-460719dcb1a5">
        <source>getCargoTypeObj():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2017	jlgma1	Initial creation
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI
*/

vars

	cType : CM_CargoType;

begin

	cType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cType = null then
		if self.cargoTypeDescr.isInteger then
			cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
		else
			cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		endif;
	endif;
	
	return cType;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
