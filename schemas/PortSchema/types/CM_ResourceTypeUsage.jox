    <JadeMethod name="differsFrom" id="9ed52213-5b60-41a7-a79d-c7e3a34ee2c2">
        <source>differsFrom( _resourceTypeUsage : CM_ResourceTypeUsage ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation

*/

vars

begin

	if _resourceTypeUsage.myResourceType &lt;&gt; self.myResourceType then
		return true;
	endif;
	if _resourceTypeUsage.quantity &lt;&gt; self.quantity then
		return true;
	endif;
	if _resourceTypeUsage.remarks &lt;&gt; self.remarks then
		return true;
	endif;
	if _resourceTypeUsage.noCharge &lt;&gt; self.noCharge then
		return true;
	endif;
	if _resourceTypeUsage.status &lt;&gt; self.status then
		return true;
	endif;
	
	//13 Apr 2017	NDl TFS 3414
	if _resourceTypeUsage.fromDateTime &lt;&gt; self.fromDateTime then
		return true;
	endif;
	if _resourceTypeUsage.toDateTime.time &lt;&gt; self.toDateTime.time then
		return true;
	endif;
	if _resourceTypeUsage.myPalletType &lt;&gt; self.myPalletType then
		return true;
	endif;
	if _resourceTypeUsage.isHeatTreated &lt;&gt; self.isHeatTreated then
		return true;
	endif;
	if _resourceTypeUsage.isStoreOnPallet &lt;&gt; self.isStoreOnPallet then
		return true;
	endif; 
	
	return false;
	
epilog

end;</source>
        <Parameter name="_resourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayLine" id="4c79728f-c31a-448f-9f76-d76b187cf8b0">
        <source>displayLine():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation

*/

vars

	str : String;
	
begin

	if self.myResourceType &lt;&gt; null then
		str :=  self.quantity.asStringJMTWithPrecision(self.myResourceType.decimalPlaces,false) &amp; " "
				&amp; self.myResourceType.unitDescription
				&amp; " [ " &amp; self.myResourceType.description &amp; " ]";
	endif;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllInvoiceLines" id="3427fae2-3eab-433d-838e-f9668a2d03a0">
        <source>getAllInvoiceLines() : String;
/*
Purpose:			
Date		Who		Reason
21 May 2014	cnwab1	Initial creation
*/

vars

	rec : CM_InvoiceLine;
	docStr : String;
begin

 
	foreach rec in allInvoiceLines discreteLock do
		if docStr = "" then
			docStr := rec.getOidString; //	.oidAsBin;
		else
			docStr := docStr &amp; "," &amp; rec.getOidString; // oidAsBin;
		endif;
 
	endforeach;
	
	return docStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
