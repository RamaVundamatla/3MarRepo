    <JadeMethod name="updateTableItem" id="9a43155e-d5eb-4285-ac50-28e20dbbb4ea">
        <source>updateTableItem(_deck : CM_Deck input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	idx : Integer;
	str : String;
begin
	idx:=_deck.ordinal;
	if self.tbRoRolDecks.findObjectInRowReversed(_deck,idx) then
		self.tbRoRolDecks.removeItem(idx);
		str := _deck.getAttributeStringForDefArray(self.tbRoRolDecks.allTblDataEntRows);
		self.tbRoRolDecks.addItemObjectAt(_deck,str,idx);
		if _deck.isKindOf(CM_DeckVesselSub) or _deck.isKindOf(CM_DeckVoyageSub) then
			self.tbRoRolDecks.accessRow(idx).backColor:=LightSkyBlue;
		else
			self.tbRoRolDecks.accessRow(idx).backColor:=SkyBlue;
		endif;
	else
		self.addTableItem(_deck);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="11e87d54-7a43-474d-809d-52fe2330a16c">
