    </JadeMethod>
    <JadeMethod name="generateSnapshotDataFromColl" id="3b72a8c4-edf3-43dc-8bd4-52ae228db3c3">
        <source>generateSnapshotDataFromColl(	_coll : Collection;	// collection of data to process
								_optName : String;	// optional name.
								_ts			: TimeStamp;	// timestamp for snapshot
								_terminal : CM_Terminal;
								_user : CM_User
								):CM_SnapshotData;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
08 December 2009	cnwndl1	Initial creation
17/12/2009			cnwcs5	Delete transient
12/08/2010			cnwcs5	par 23706 - added _ts parameter
*/

vars

	agent : CMIF_OutputFormatAgent_SS;
	snapshotData : CM_SnapshotData;
	
begin

	create agent transient;
	snapshotData := agent.generateSnapshotData( self,	//_format : CM_OutputFormat_XTAB;
										_coll,	//_coll : Collection
										_optName,	//_name : String;
										_ts, 		// _ts :TimeStamp
										_terminal,	//_terminal : CM_Terminal;
										_user	//_User : CM_User
										);
	return snapshotData;
	
epilog
	delete agent;	// cms 17/12/2009
end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_optName" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="CM_SnapshotData"/>
    </JadeMethod>
