    <JadeMethod name="showThumbnailData" id="3e4c4bdd-d7aa-4e67-b4c8-e45d12cfbb67">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
// 21 May 2009	concms1	Par 19715 - VVRD changes
// 26/11/2024	jlizm1	MTN 33235 Delete current entry reverting already exported cargo
vars

	tmpVVRec		: CM_VehicleVisitRecord;
	str,
	dataStr			: String;
	headings		: StringArray;
	hugeHeadings	: HugeStringArray;
	data			: HugeStringArray;
	dataSize,
	i				: Integer;
	
begin

	tmpVVRec := obj.CM_VehicleVisitRecord;

	tblThumb.rows := 0;
		
	create headings transient;
	create data transient;
	
	tmpVVRec.showThumbnailData_TI(headings, data);	// par 19715
	
	if data.size &gt; 0 then							// par 19715
		headings.add (null);	data.add (null);	// par 19715
	endif;											// par 19715
	
	tmpVVRec.getDataForDef(self.myThumbDef, headings, data, self.myTerminal);
	
	headings.add (null);	data.add (null);		// par 19715
	
	create hugeHeadings transient;
	headings.copy(hugeHeadings);
	tmpVVRec.showThumbnailData_VVRD(hugeHeadings, data);
	
	dataSize := data.size;
	
	
	
	foreach str in hugeHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr :=data[i];
		
		
		
		if str &lt;&gt; null then
			if  self.isHideThumbnailEmtpy then
				if dataStr = null then
					continue;
				endif;
				if dataStr.isDecimal and dataStr.Decimal = 0 then
					continue;
				endif;
			endif;
		endif;
		tblThumb.addItem(str &amp; Tab &amp; dataStr);
	endforeach;

	// set up the extra context menu
	self.mnuCancelVVR.visible := false;
	if tmpVVRec.isIncomplete then
		if (app.myCurrentUserCan(self.myTerminal, self.permissionMaint) and tmpVVRec.timeOut = null) then
			self.mnuCancelVVR.visible := true;
		endif;
	endif;

epilog
	delete hugeHeadings;
	delete headings;
	delete data;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="c5d0e9ab-3821-4a1d-a793-8f5d7823bfbd">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date		Who		Reason
18 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;

	inheritMethod(eventTag);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0844b10b-4055-4a6c-9de4-9afd77592913">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2025 10:14:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005520, locale);
	btnEventTrans.translateBubbleHelp(Xlat_0020030, locale);
	btnEventTrans.translateCaption(Xlat_0020031, locale);
	btnPhotos.translateCaption(Xlat_0027108, locale);
	btnVehicleTurn.translateBubbleHelp(Xlat_0005521, locale);
	btnVehicleTurn.translateCaption(Xlat_0005522, locale);
	mnuAssocBooking.translateCaption(Xlat_0018158, locale);
	mnuCancelVVR.translateCaption(Xlat_0017963, locale);
	mnuCargoReview.translateCaption(Xlat_0026471, locale);
	mnuChangeStatus.translateCaption(Xlat_0025435, locale);
	mnuCheckSeals.translateCaption(Xlat_0025929, locale);
	mnuContextExtras.translateCaption(Xlat_0017567, locale);
	mnuCorrectReleaseData.translateCaption(Xlat_0026691, locale);
	mnuDisAssocBooking.translateCaption(Xlat_0019044, locale);
	mnuMaintainSeals.translateCaption(Xlat_0025930, locale);
	mnuRecordWeight.translateCaption(Xlat_0022030, locale);
	mnuRegenerateBarrierIn.translateCaption(Xlat_0026068, locale);
	mnuRegenerateBarrierOut.translateCaption(Xlat_0026069, locale);
	mnuReprint.translateCaption(Xlat_0017568, locale);
	mnuSendBarrierIn.translateCaption(Xlat_0026465, locale);
	mnuSendBarrierOut.translateCaption(Xlat_0026466, locale);
	mnuSendInspection.translateCaption(Xlat_0025438, locale);
	mnuSendReport.translateCaption(Xlat_0027109, locale);
	mnuStatusInCompleted.translateCaption(Xlat_0025439, locale);
	mnuStatusInFailed.translateCaption(Xlat_0025440, locale);
	mnuStatusInNA.translateCaption(Xlat_0025441, locale);
	mnuStatusInPending.translateCaption(Xlat_0025442, locale);
	mnuStatusOutCompleted.translateCaption(Xlat_0025443, locale);
	mnuStatusOutFailed.translateCaption(Xlat_0025444, locale);
	mnuStatusOutNA.translateCaption(Xlat_0025445, locale);
	mnuStatusOutPending.translateCaption(Xlat_0025446, locale);
	mnuSubCarrierUpdate.translateCaption(Xlat_0024922, locale);
	mnuUpdBarrierInTime.translateCaption(Xlat_0026070, locale);
	mnuWeigh.translateCaption(Xlat_0019576, locale);
end;</source>
