    <JadeMethod name="tiExceptionHandler" id="01184927-28c0-4351-990b-4fea835426ea">
        <source>tiExceptionHandler(_exObj: LockException; _ti: CM_TrackedItem io): Integer;
//----------------------------------------------------------------
//	Created:	27 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if _exObj.errorCode = 1027 
	or _exObj.errorCode = 4 then
	
		_ti := null;
		return Ex_Resume_Next;
		
	else
		return Ex_Pass_Back;
		
	endif;
end;</source>
        <Parameter name="_exObj" type="LockException"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="transmissionDateVerify" id="d0e5c729-56df-443a-a885-5f6138fc9193">
        <source>transmissionDateVerify(_terminal : CM_Terminal) : String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 May 2008
//
//----------------------------------------------------------------------
vars
	value: Integer;
	message: String;
