    <JadeMethod name="buildComboConfirm" id="e86df3e8-f3ff-4d01-b214-7c48be9decc2">
        <updating/>
        <source>buildComboConfirm() protected, updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
17JAN2024 	navra1	CR 62045/Task 62050 - UI - Import Container Confirmation Location
17JAN2024 	navra1	CR 62045/Task 62049 - UI - Export Container Confirmation Location
24 JAN 2024 navra1	Moved CMIF_VoyLiveLcnsCmbFiller from ShipSchema to UiCommonSchema as CMIF_VoyLiveLcnCmbFiller
29 May 2024	jlika1	TFS 64049 CUX | UAT FLP - Retain previous location in Voyage Ops Live Checks
*/

vars	
	//cmifComboFiller: CMIF_VoyLiveLcnsCmbFiller;
	cmifComboFiller: CMIF_VoyLiveLcnCmbFiller;
	indx : Integer;	
begin

	create cmifComboFiller transient;
	
	cmifComboFiller.fillCmbWithPotentialLcns(self.cmbLocnConfirm, self.myCurrentVoyage, self.myCurrentTrackedItem);
	
	//Only set the combo box value if it is not yet set 
	if self.cmbLocnConfirm.listObject = null and self.myDefaultLocation &lt;&gt; null and self.cmbLocnConfirm.listCount &lt;&gt; 0 then
		foreach indx in 1 to self.cmbLocnConfirm.listCount do
			if self.cmbLocnConfirm.itemObject[indx] = self.myDefaultLocation then
				self.cmbLocnConfirm.listObject := self.myDefaultLocation;
				break;
			endif;
		endforeach;		
	endif;
	
epilog	
	delete cmifComboFiller;	
end;</source>
        <access>protected</access>
    </JadeMethod>
