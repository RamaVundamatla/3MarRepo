    <JadeMethod name="setForProxy" id="aef98664-6be1-4288-815c-2af84e07a0e3">
        <updating/>
        <source>setForProxy(_code, _description : String; _codeGroup : CM_CodeGroup; _availabilityGrade : CM_MTGrade) updating;

vars

begin

	self.setSuperClassDetailsForProxy(_code, _description, false, _codeGroup);
	self.myMTGrade := _availabilityGrade;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_codeGroup" type="CM_CodeGroup"/>
        <Parameter name="_availabilityGrade" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aac95c27-903b-4b0e-acc2-cae84e4eda9b">
        <updating/>
        <source>setForUpdate(_proxy: CM_MTGradeCode) updating;

vars

begin
	inheritMethod(_proxy);
	self.myMTGrade := _proxy.myMTGrade;
end;</source>
        <Parameter name="_proxy" type="CM_MTGradeCode"/>
    </JadeMethod>
    <JadeMethod name="validate" id="947a6c5c-468d-43d4-8857-5ed1dca2a789">
        <source>validate();
// -------------------------------------------
// Created 11 November 2004 by cnwdvb1
