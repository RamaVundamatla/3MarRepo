<Class name="CM_RemoteRegradingDtl">
    <JadeMethod name="loadRemoteArray" id="b885ab69-b67f-4c9b-b501-8d17b1741331">
        <updating/>
        <source>loadRemoteArray(_table: CM_EntryTable io) updating;

// cnwdvb1 21 November 2002 

constants
	ColumnHeading = 'New Id';
	AllTiArrayRow = 10;
	
vars
	ti		: String;
	theRow	: Integer;
	

begin

	// PAR 23972 10/05/2010
	theRow := AllTiArrayRow;
	if self.isLogId then
		theRow := theRow + 2;
	endif;
	if _table.row = theRow then
		inheritMethod(_table);
		_table.setColumnHeadings(RegradeItemArray, ColumnHeading);
		foreach ti in self.allTis do
			self.addRemoteRow(_table, ti, ti, null);
		endforeach;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="825b5f3e-5c9a-47f2-bbff-d30386a5bd88">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 21 November 2002 
begin

	//PAR 23972 10/05/2010
	inheritMethod(_table);
	_table.setColumnHeadings('Attribute', 'Value');
	self.addRemoteRow(_table, 'New Operator', self.operator, null);
	self.addRemoteRow(_table, 'New Species', self.species, null);
	self.addRemoteRow(_table, 'New Grade', self.grade, null);
	self.addRemoteRow(_table, 'New Type', self.type, null);
	self.addRemoteRow(_table, 'New Treatment', self.treatment, null);
	self.addRemoteRow(_table, 'New Length', self.length, null);
	self.addRemoteRow(_table, 'New Area', self.terminalArea, null);
	self.addRemoteRow(_table, 'New Location', self.location, null);
	if self.isLogId then
		self.addRemoteRow(_table, 'New SEDMax', self.sedMax.String, null);
		self.addRemoteRow(_table, 'New SEDMin', self.sedMin.String, null);
	endif;
	self.addRemoteRow(_table, 'All Regrades', Click, self);
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
