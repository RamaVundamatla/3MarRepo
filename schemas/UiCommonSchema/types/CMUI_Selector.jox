    <JadeMethod name="setDefaultDates" id="87bff112-ef28-4d92-8548-52f921e48075">
        <source>setDefaultDates();
// ---------------------------------------------------------------------------
// Created:     03 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	today      : Date;
	
begin
	
	today := self.systemToLocalTime(app.actualTimeServer()).date - 1;	// 6/5/16 cnwmp6 TFS 488 - Multi timezone support
	self.txtFromDate.setDate(today - 1);
	self.txtToDate.setDate(today);
	
	//14 may 2012	NDL:	Par 29532
	self.txtFromTime.setTime("00:00".Time);
	self.txtToTime.setTime("23:59".Time);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="18f4bcc7-238d-4cb6-9845-9b422a06ecb9">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013
*/
vars

begin
	if self.displayMode &lt;&gt; _mode then
		self.displayMode := _mode;
		self.frmStatusLine.displayMode := _mode;
	endif;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForPermissionLevel" id="c2afd742-6fa3-44c5-ac06-2ccb09eb28d5">
        <updating/>
        <source>setForPermissionLevel() protected, updating;
/* ---------------------------------------------------------------------------
Created:     16 January 2004	cnwth2

Purpose:     

Date		Who		TFS	  Reason
-----------	------	---------------------------------
04 Oct 2019	jlgdi1	46820 Comment out some of the buttons visibility to balance the appearance of the form
						  Set the cmbSelectorMode enable even for those users with out maint permission
-----------------------------------------------------
*/
vars
	user			: CM_User;
begin
	////////////////////////////////////////
	/*Permission setup stuff - 
	
	*View perm is for external users - can only run pre-existing queries - no 'add-hock' queries
	or save/update queries etc.
	
	*Entry perm is for normal users - can run pre-exisiting queries and create 'add-hock' queries
	no save/update queries. Unable to specify 'unavailableAtRunTime':
	
	*Maint perm - can do anything they like.
	
	*/
	user := app.getMyUser();
		//18/09/2009 cnwdz2 20591
	if (not user.canDo(self.myTerminal, self.permissionMaint)) then 
		//we've got an entry enabled user
		
		self.btnShowHideSave.visible := false;
		self.btnShowHideSave.enabled := false;
		self.chkUnavailable.visible := false;
		self.chkUnavailable.enabled := false;		
		self.btnShowHideBR.visible := false;
		self.btnMoveIt.visible := false; // TFS 2198
		self.mnuMove.enabled:= false; // TFS 2198
		self.mnuMoveItem.enabled:= false; // TFS 2198
		self.mnuUnassignRelease.enabled:= false; // TFS 2198
		
		//18/09/2009 cnwdz2 20591
		if (not user.canDo(self.myTerminal, self.permissionEntry)) then
			//we've got an external or 'view only' user.
			self.isViewPermisionOnly := true;
			// TFS 2198 self.mnuOrganiseColumn.enabled := false;
			
			self.btnAdd.enabled := false;
			self.btnUpdate.enabled := false;
			self.btnRemove.enabled := false;
			self.btnAddSheet.enabled := false;
			self.btnRemoveSheet.enabled := false;
			
			self.cmbAttr.enabled := false;
			self.cmbOperator.enabled := false;
			self.tblQueryEnt.enabled := false;
			
			// 45802 Start
			self.cmbArgument.enabled := false;
		endif;
	endif;
	
	self.mnuSummarise.visible	:= self.bAllowSummaryDefn;				// CCMS SFW 1047 (Recaps)
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setModeFromCargoType" id="c9553110-282e-4498-88f5-1f6774747c88">
        <updating/>
        <source>setModeFromCargoType( _cargoType : CM_CargoType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2012	cnwrd1	Initial creation

*/

vars

begin

	if _cargoType.id = TI_CargoType_Container then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, _cargoType.id];
	elseif _cargoType.id = TI_CargoType_Log then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 9];
	elseif _cargoType.id = TI_CargoType_Generator then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 4];
	elseif _cargoType.id = TI_CargoType_COU then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 2];
	elseif _cargoType.id = TI_CargoType_Timber then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 6];
	elseif _cargoType.id = TI_CargoType_LCL then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 8];
	elseif _cargoType.isBreakBulk() then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 3];		// TI_CargoType_BreakBulk
	elseif _cargoType.productType = ProductType_Trailer then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 10];		// TI_CargoType_Chassis
	elseif _cargoType.productType = ProductType_Vehicle then
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 7];		// TI_CargoType_Car
	else
		self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="7de52a93-7e44-435b-af2c-9ab75d078f5b">
        <updating/>
        <source>setMoveMode(_mode: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013
*/
vars
	moveMode	: Integer;

begin
	if _mode = REAL_MODE then
		moveMode := self.frmStatusLine.MENU_MOVE_INSTANT;
	elseif _mode = QUEUE_MODE then
		moveMode := self.frmStatusLine.MENU_MOVE_QUEUED;
	elseif _mode = PLANNING_MODE then
		moveMode := self.frmStatusLine.MENU_MOVE_PLAN;
	endif;
	
	if self.moveModeForm &lt;&gt; moveMode then
		self.moveModeForm := moveMode;
	endif;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPictureDragCursor" id="6c13f523-8dc0-4808-bb64-84fc7088425d">
        <source>setPictureDragCursor(_picture: Picture input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013 Reimplement
*/
vars
	moveMode	: Integer;

begin
	moveMode := self.getMoveMode;
	
	if moveMode = REAL_MODE then
		_picture.picture := self.picMvInstantCur.picture;
	elseif moveMode = QUEUE_MODE then
		_picture.picture := self.picMvQueueCur.picture;
	elseif moveMode = PLANNING_MODE then
		_picture.picture := self.picMvPlanCur.picture;
	endif;
epilog

end;</source>
        <Parameter name="_picture" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPropertyValueAndOperator" id="b3b0f3bb-8756-49fd-985f-841242c8a6a3">
        <source>setPropertyValueAndOperator(_existingCriteriaLine : CM_SelectorCriteriaLine; _preValidated : Boolean) : CM_SelectorCriteriaLine protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwth2
//
// Purpose:     _criteriaLine passed will be null if adding a new criteria line, else existing passed in will updated
//				If null passed in and criteria line with existing property exists, it will chuck.
//
//				Returns true if a new line was sucessfully added.
//
// ---------------------------------------------------------------------------
vars
	persistentProp,
	tmpProp			: CM_QueryProperty;
	persistentOp,
	tmpOp			: CM_QueryOperator;
	criteriaLine 	: CM_SelectorCriteriaLine;
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	tmpDateArray	: DateArray;
	tmpTimeArray : TimeArray;
	tmpIntArray		: IntegerArray;
	str				: String;
	value			: Any;
	measure			: CM_MeasurementType;								// PAR #31155

begin
	
	criteriaLineHolder := self.tblCriteria.accessSheet(self.tblCriteria.topSheet).itemObject.CM_QueryCriteriaLineHolder;
		
	persistentProp		:= cmbAttr.listObject.CM_QueryProperty;
	persistentOp 		:= cmbOperator.listObject.CM_QueryOperator;
	
	if persistentProp = null or persistentOp = null then
		app.msgBox(app.getErrorString(CMUI_Selector_MustSelAttr), app.getErrorString(InsufficientInput), MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	tmpProp := persistentProp.cloneSelf(true);
	tmpOp := persistentOp.cloneSelf(true);
	
	// PAR #31155 If we have a measurement type selector option, set the measurement type on the query property
	if self.cmbMeasure.visible then																	// PAR #31155
		measure := self.cmbMeasure.listObject.CM_MeasurementType;									// PAR #31155
		if CM_QDecimalProperty.hasInstance(tmpProp) then											// PAR #31155
			tmpProp.CM_QDecimalProperty.myMeasurementType := measure;								// PAR #31155
		elseif CM_QDecimalMethod.hasInstance(tmpProp) then											// PAR #31155
			tmpProp.CM_QDecimalMethod.myMeasurementType := measure;									// PAR #31155
		endif;																						// PAR #31155
	endif;																							// PAR #31155
	
	if txtArgument.visible and (not self.txtArgument1.visible) then
		value := txtArgument.text;
		value := tmpProp.translateToSearchValue(value);
		tmpOp.setSearchValue(value);
	elseif self.txtArgument.visible and self.txtArgument1.visible then
		create tmpIntArray transient;
		tmpIntArray.add(self.txtArgument.text.Integer);
		tmpIntArray.add(self.txtArgument1.text.Integer);
		tmpOp.setSearchValue(tmpIntArray);
	elseif cmbArgument.visible then
		value := cmbArgument.listObject;
		//if value = null or value.isKindOf (CM_Bay) then//changed by cnwyl1 for PAR12265 // not the best solution - took out by AER 31/07/08 
		if value = null then
			value := cmbArgument.text;
		endif;
		value := tmpProp.translateToSearchValue(value);

		if value.String = '** not initialised **' then
			value := null;
		endif;
		tmpOp.setSearchValue(value);

	elseif tblArgument.visible or self.frmArgument.visible then
		tmpProp.setValuesFromList(tblArgument, tmpOp);
		self.lblargList.caption := tmpOp.getSearchValueStr(tmpProp);
		
	elseif (self.txtFromDate.visible) and 
	       (not self.txtToDate.visible) then
		value := self.txtFromDate.getDate();
		tmpOp.setSearchValue(value.Date);

	elseif self.txtFromDate.visible and 
	       self.txtToDate.visible then
		create tmpDateArray transient;
		tmpDateArray.add(self.txtFromDate.getDate());
		tmpDateArray.add(self.txtToDate.getDate());
		tmpOp.setSearchValue(tmpDateArray);
	
	//14 May 2012	NDL	Par 29532
	elseif (self.txtFromTime.visible) and 
	       (not self.txtToTime.visible) then
		value := self.txtFromTime.getTime();
		tmpOp.setSearchValue(value.Time);

	elseif self.txtFromTime.visible and 
	       self.txtToTime.visible then
		create tmpTimeArray transient;
		tmpTimeArray.add(self.txtFromTime.getTime());
		tmpTimeArray.add(self.txtToTime.getTime());
		tmpOp.setSearchValue(tmpTimeArray);
	endif;
	

	if _existingCriteriaLine &lt;&gt; null then
		criteriaLine := criteriaLineHolder.allCriteriaByPropertyName[tmpProp.propertyName, tmpProp.propertyClassName];
		
		if not _preValidated then // ### TFS BUG 61210 26FEB2024 NAVAB1
			if (criteriaLine &lt;&gt; null) and (criteriaLine &lt;&gt; _existingCriteriaLine) then
				//there is already a DIFFERENT line with that property, so winge
				app.msgBox(app.getErrorString(CMUI_Selector_DupCriteria), app.getErrorString(CMUI_Selector_Duplicate_Line), MsgBox_Exclamation_Mark_Icon);
				return null;
			else
				criteriaLine := _existingCriteriaLine;
			endif; 
		else
			criteriaLine := _existingCriteriaLine;
		endif;
	else
		if criteriaLineHolder.allCriteriaByPropertyName.includesKey(tmpProp.propertyName, tmpProp.propertyClassName) then
			app.msgBox(app.getErrorString(CMUI_Selector_DupCriteria), app.getErrorString(CMUI_Selector_Duplicate_Line), MsgBox_Exclamation_Mark_Icon);
			return null;
		else
			create criteriaLine transient;
		endif;
	endif;
	
	criteriaLine.set(tmpProp, tmpOp, self.chkUnavailable.value);
	return criteriaLine;

epilog
	if criteriaLine = null then
		delete tmpProp;
		delete tmpOp;
	endif;
	
	self.cmbAttr.setFocus();
	delete tmpDateArray;
	delete tmpIntArray;
	delete tmpTimeArray;

end;</source>
        <access>protected</access>
        <Parameter name="_existingCriteriaLine" type="CM_SelectorCriteriaLine"/>
        <Parameter name="_preValidated" type="Boolean"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="8add13bc-316d-43d2-8137-a6ae836a2848">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	entTableRow : EntTableRow;

begin
	// JIRA 14794 - NAVAB1 30OCT2024
	if self.useEntDefColumns then
		
		self.displayResultsEntDef();

		self.allVisibleColumns.clear();
		foreach entTableRow in self.tblResults.allTblDataEntRows do
			if entTableRow = null then 
				continue;
			endif;
			self.allVisibleColumns.add (entTableRow.name );
		endforeach;
	
	else
		//th2 do nothing - already done in self.doCreateTableOrganisor
		//inheritMethod(_theTable);
		self.allVisibleColumns.clear();
		foreach entTableRow in self.tblResults.allTblDataEntRows do
			//self.allVisibleColumns.add (entTableRow.controlName);
			if entTableRow = null then // Can happen in a 'Set from Default' from the Column Organiser
				continue;
			endif;
			self.allVisibleColumns.add (entTableRow.getOriginalColumnName());	// 34658 save name which may be &gt; 30 characters
		endforeach;
		
		self.displayResultColumns(self.allVisibleColumns, null);
		
		//self.executeQueries();
		//lets not redo the serach but just display the results with new columns
		self.displayResults();
	endif;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupArgumentView" id="9c617b57-4e31-4e77-8f68-db9fa2f4d1db">
        <source>setupArgumentView(_qOperator : CM_QueryOperator);
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Reversed changes made for PAR #17569 to allow null values in combobox
					fields
10 May 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
04 Oct 2019	jlgdi1	45802 View permission cannot do any update
03 Jul 2025	navhl20 Defect MTN-35231: Selector Query - Cargo Transaction Days Passed less than 0 is not returning any data
*/

vars
	prop,
	tmpProp					: CM_QueryProperty;
	controlType				: Integer;
	currentCriteriaLine		: CM_SelectorCriteriaLine;
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	enableArgumentChange	: Boolean;
	tbl						: CM_DataTable;
	tblSheet				: JadeTableSheet;
	dateBoxArray,
	textBoxArray,
	timeBoxArray			: ObjectArray;
	theRow					: Integer;
begin
	tbl := self.tblCriteria;
	tblSheet := tbl.accessSheet(tbl.topSheet);
	criteriaLineHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;

	enableArgumentChange := true;
	
	theRow := tblSheet.row;
	if theRow &lt;&gt; 0 then
		currentCriteriaLine := tblSheet.accessRow(theRow).itemObject.CM_SelectorCriteriaLine;
	endif;
	
	if currentCriteriaLine &lt;&gt; null then
		if (currentCriteriaLine.isUnavailableAtRunTime or self.isViewPermisionOnly) then
			enableArgumentChange := false;
		endif;
	endif;
	
	self.btnUpdate.enabled := enableArgumentChange;
	self.txtFromDate.visible 	:= false;
	self.txtToDate.visible 		:= false;
	self.txtFromTime.visible 	:= false;
	self.txtToTime.visible 		:= false;
	self.lblAnd.visible 		:= false;
	self.txtArgument.visible 	:= false;
	self.txtArgument1.visible 	:= false;
	self.cmbArgument.visible 	:= false;
	self.tblArgument.visible 	:= false;
	self.frmArgument.visible 	:= false;	//05 Sep 2019	NDL	TFS 45891
	self.lblargList.visible := false; // ### TFS BUG 61210 26FEB2024 NAVAB1
	
	// PAR #31155 create a transient tmpProp so we can set its measurement type									// PAR #31155
	//tmpProp := cmbAttr.listObject.CM_QueryProperty;															// PAR #31155 code before
	//tmpProp := cmbAttr.listObject.CM_QueryProperty.cloneSelf(true);											// PAR #31155 changed code, moved down now
	// cnwjre1 17/06/2014 from testing, after mode change there is no property but still an Operation entry so check for this before cloning
	prop := cmbAttr.listObject.CM_QueryProperty;
	
	if prop = null or
	   _qOperator = null then
		return;
	endif;
	
	tmpProp := prop.cloneSelf(true);																			// PAR #31155
	if self.cmbMeasure.visible then																				// PAR #31155
		if CM_QDecimalProperty.hasInstance(tmpProp) then														// PAR #31155
			tmpProp.CM_QDecimalProperty.myMeasurementType := self.cmbMeasure.listObject.CM_MeasurementType;		// PAR #31155
		elseif CM_QDecimalMethod.hasInstance(tmpProp) then														// PAR #31155
			tmpProp.CM_QDecimalMethod.myMeasurementType := self.cmbMeasure.listObject.CM_MeasurementType;		// PAR #31155
		endif;																									// PAR #31155
	endif;																										// PAR #31155
	
	controlType := tmpProp.getControlTypeForOperator(_qOperator);
	
	if controlType = QueryControl_TextBox then
		tmpProp.setTextValues(self.txtArgument, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtArgument.visible := true;
		self.txtArgument.enabled := enableArgumentChange;
		if _qOperator.isKindOf(CM_QDateDayLessThan) then														//03.07.2025 navhl20 #35231
			self.txtArgument.dataType := TextBox.DataType_Numeric;
		endif;
		
	elseif controlType = QueryControl_ComboBox then
		tmpProp.setComboValues(cmbArgument, criteriaLineHolder, _qOperator, app.myPassport);
		
		self.cmbArgument.visible := true;
		self.cmbArgument.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_MultiSelect then	
		tmpProp.setListValues(tblArgument, criteriaLineHolder, _qOperator, app.myPassport);
		
		// ### TFS BUG 61210 26FEB2024 NAVAB1 - sort the list of arguments
		self.tblArgument.sortColumn[1]	:= 2;    
		self.tblArgument.sortAsc[1]		:= true;
		self.tblArgument.sortCased[1]	:= false;
		self.tblArgument.resort();
		
		self.tblArgument.visible := true;
		self.tblArgument.enabled := enableArgumentChange;
		
		//05 Feb 2019	NDL	TFS 45891
		self.frmArgument.visible := true;
		self.frmArgument.enabled := enableArgumentChange;
		self.btnArgFind.enabled := enableArgumentChange;
		self.lblargList.caption := _qOperator.getSearchValueStr(tmpProp);
		self.lblargList.visible := true; // ### TFS BUG 61210 26FEB2024 NAVAB1
		
	elseif controlType = QueryControl_Date then
		tmpProp.setDateValues(self.txtFromDate, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromDate.visible := true; //always use fromDate box for single date comparison
		self.txtFromDate.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_DateRange then
		create dateBoxArray transient;
		dateBoxArray.add(self.txtFromDate);
		dateBoxArray.add(self.txtToDate);
		if tmpProp.isKindOf(CM_QDateProperty) then
			tmpProp.CM_QDateProperty.setDateRangeValues(dateBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		else
			tmpProp.CM_QDateMethod.setDateRangeValues(dateBoxArray, criteriaLineHolder, _qOperator, app.myPassport);	// 27/01/2009 CCMS-1734 (#18809) cnwar2
		endif;
		self.txtFromDate.visible := true;
		self.txtToDate.visible := true;
		self.lblAnd.visible := true;
		
		self.txtFromDate.enabled := enableArgumentChange;
		self.txtToDate.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_NumTextBoxRange then
		create textBoxArray transient;
		textBoxArray.add(self.txtArgument);
		textBoxArray.add(self.txtArgument1);
		if tmpProp.isKindOf(CM_QDateProperty) then
			tmpProp.CM_QDateProperty.setTextRangeValues(textBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		else
			tmpProp.CM_QDateMethod.setTextRangeValues(textBoxArray, criteriaLineHolder, _qOperator, app.myPassport);	// 27/01/2009 CCMS-1734 (#18809) cnwar2
		endif;
		self.txtArgument.visible := true;
		self.txtArgument1.visible := true;
		self.lblAnd.visible := true;
		
		self.txtArgument.enabled := enableArgumentChange;
		self.txtArgument1.enabled := enableArgumentChange;
		
	//14 May 2012	NDL	Par 29532
	elseif controlType = QueryControl_Time then
		tmpProp.setTimeValues(self.txtFromTime, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromTime.visible := true; //always use fromTime box for single date comparison
		self.txtFromTime.enabled := enableArgumentChange;
	
	//14 May 2012	NDL	Par 29532
	elseif controlType = QueryControl_TimeRange then
		create timeBoxArray transient;
		timeBoxArray.add(self.txtFromTime);
		timeBoxArray.add(self.txtToTime);
		tmpProp.CM_QTimeMethod.setTimeRangeValues(timeBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromTime.visible := true;
		self.txtToTime.visible := true;
		self.lblAnd.visible := true;
		
		self.txtFromTime.enabled := enableArgumentChange;
		self.txtToTime.enabled := enableArgumentChange;
	endif;

epilog
	delete dateBoxArray;
	delete textBoxArray;
	delete timeBoxArray;
	delete tmpProp;																								// PAR #31155
end;</source>
        <Parameter name="_qOperator" type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f5b42484-667a-4b43-9f92-8383162b4623">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/01/2011	cnwdap1		PAR #26830 CCMS 2013 allow move from selector
// 14/11/2011	cnwcs5		par 28574 - new update event
// 21 Dec 2022  navsa20     ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS
// ---------------------------------------------------------------------------
vars

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.minimumWidth := 850;	//02 Sep 2019	NDL	TFS 45891
	self.minimumHeight := 450;	//02 Sep 2019	NDL	TFS 45891
	self.btnDown.caption := 226.Character; //02 Sep 2019	NDL	TFS 45891
	self.btnDown.fontName := "Wingdings";	//02 Sep 2019	NDL	TFS 45891
	self.btnUp.caption := 225.Character;	//02 Sep 2019	NDL	TFS 45891 
	self.btnUp.fontName := "Wingdings";	//02 Sep 2019	NDL	TFS 45891
	self.evaluateUpDown();	//02 Sep 2019	NDL	TFS 45891
	self.tblCriteria.selectMode := CM_DataTable.SelectMode_Single;	//03 Sep 2019	NDL	TFS 45891

	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	//epr par 33058 30/4/14 - tidying up some resizing issues - status bar was overlapping the results table and query list
	self.lstQuery.height := self.grpQryDetails.clientHeight - self.lblUsreQueries.clientHeight - self.lblUsreQueries.top - 10;
	self.lstQuery.parentAspect 		:= Table.ParentAspect_StretchBoth;
	
	inheritMethod();
	
	//02 Nov 2015	NDL - found during testing par 37094.
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.tblResults.selectionType 	:= CM_DataTable.SelectionType_Row;
	self.tblResults.selectMode 		:= CM_DataTable.SelectMode_None;				//+cnwml2 PAR25715
	self.tblResults.multiSelect 	:= CM_DataTable.MultiSelect_Simple;

	//cnwjo3 par 23349
	self.tblResults.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;

	if app.myRoot.myQueryMenuRoot &lt;&gt; null then
		beginNotification(app.myRoot.myQueryMenuRoot, SelectorProperty_Create_Event, Response_Continuous, null);
		beginNotification(app.myRoot.myQueryMenuRoot, SelectorProperty_Update_Event, Response_Continuous, null);
		beginNotification(app.myRoot.myQueryMenuRoot, SelectorProperty_Delete_Event, Response_Continuous, null);
	endif;

	self.setNavigatorHeading(self.caption);
	self.tblCriteria.columns := 1;
	self.cmbAttr.setFocus();
	
	self.setForPermissionLevel();
	
	// PAR #26830 start
	self.frmStatusLine.initFrame();
	if not app.myCurrentUserCan(self.myTerminal, PmYardMoveView) then
		self.mnuMoveItem.enabled := false;
		self.frmStatusLine.visible := false;
		self.staLine.visible := true;
		self.staLine.zOrder(1);
	else
		self.mnuMoveItem.enabled := true;
		self.frmStatusLine.visible := true;
		self.staLine.visible := false;
		self.frmStatusLine.zOrder(1); //epr par 33058 30/4/14 
	endif;
	
	
	// PAR #26830 end
	
	self.btnClear.enabled := false;    //21.12.2022 navsa20 TFS 55106
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFrame" id="3f12ceb0-4eec-44d5-9542-45f248a8e431">
        <source>showHideFrame(_frm : CMUI_Frame input; _show, _modal : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     22 March 2004	cnwth2
			 
/*

Date		Who		Reason
29 Jul 2008	cnkpd1	PAR #17642 - Change code to delete invisible forms, because if they have
					never been shown then they do not get deleted following an unload
19 Jun 2013	cnwcs5		par 31678 - centre frame over window
*/

vars
	obj : Object;
begin
	if _frm = null then
		return;
	endif;
	
	if _show then
		//disables everything else and brings the frame front and centre
		if _modal then
			self.sptMain.enabled := false;
			self.frmToolbar.enabled := false;
		endif;
		
		_frm.parent := self;
		_frm.zOrder(1);
		_frm.enabled:= true;
		
		_frm.centreWindow;	// par 31678
		
		_frm.visible := true;
		if _frm = self.frmSendToScreen then
			self.btnSendScreen.default := true;
			self.tblScreens.setFocus();
		elseif _frm = self.frmPrintOptions then
			self.btnPrintReport.default := true;
			self.cmbJRWReport.setFocus();
		elseif _frm = self.frmSaveQuery then
			self.btnSaveQuery.default := true;
			
		endif;	
	else
		_frm.visible := false;
		self.sptMain.enabled := true;
		self.frmToolbar.enabled := true;
		self.btnAdd.default := true;
		
		// CCMS Tranship: unload the unused forms that were created in self.showScreensToSendTo();
		foreach obj in self.allDefaultForms do
			if app.isValidObject(obj) then //added by cnwyl1 06062006 to validate the object. 
				if (not obj.Form.visible) then
					obj.Form.unload();
					self.allDefaultForms.remove(obj);			// PAR #17642 - Need to actually delete forms to stop transient leaks
					delete obj;
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frm" type="CMUI_Frame" usage="input"/>
        <Parameter name="_show" type="Boolean"/>
        <Parameter name="_modal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHidePrintOptions" id="bed1ea0d-e0a3-4629-a358-fbb8330fbde0">
        <updating/>
        <source>showHidePrintOptions(_show : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _show then
		if self.myEnqController.allObjects.isEmpty then
			app.msgBox(app.getErrorString(CMUI_Selector_No_Results), app.getErrorString(CMUI_Selector_No_Results), MsgBox_Exclamation_Mark_Icon);
			return;	
		endif;
	endif;

	if self.cmbJRWReport.listCount = 0 then
		self.loadReports();
	endif;
	
	// ### JIRA 33575 06DEC2024 NAVAB1
	if cmbFormats.listCount &lt; 1 then
		self.txtFileName.enabled := false;
		self.btnBrowse.enabled := false;

		self.buildReportOutputOptions();
	endif;
	self.cmbFormats.listIndex := 1;
	self.txtFileName.text := "";
	self.chkPrintPreview.value := true;
	self.chkPrintPreview.enabled := true;
	
	
	
	self.showHideFrame(self.frmPrintOptions, true, true);
	
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMoveForm" id="9012049d-e59d-48ea-bed1-c37d8089435c">
        <source>showMoveForm();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013
*/
vars
	tiArray	: CM_TIArray;

begin
	create tiArray transient;

	self.tblResults.allSelectedObjects.copy(tiArray);

	if tiArray.size &lt; 2 then
		self.myAssistant.showMoveItForm(tiArray, REAL_MODE);	
	else
		self.myAssistant.showMoveItForm(tiArray, AUTO_PLAN_MODE);
	endif;
	
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="showQuery" id="2322cd09-65f9-425a-b7e3-2837fc638df6">
        <updating/>
        <source>showQuery(_userQuery : CM_MenuUserQuery input) updating;
// ---------------------------------------------------------------------------
// Created:     22 April 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 08/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

	transCrit,
	persistentCrit		: CM_SelectorCriteriaLine;
	tmpProp				: CM_QueryProperty;
	tmpOperator			: CM_QueryOperator;
	persistentCritHolder,
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	tblSheet			: JadeTableSheet;
	tbl					: CM_DataTable;
	idx					: Integer;
	hasOldDuffedQueryProperty : Boolean;	//05 Sep 2019	NDL	TFS 45891
	msg : String;	//05 Sep 2019	NDL	TFS 45891
	
begin
	//epr TFS 47132 18/12/19
	if _userQuery = null then
		return;
	endif;
	
	self.updateStatus();
	tbl := self.tblCriteria;
	self.queryLineChanged := false;
	self.myCurrentQuery := _userQuery;
	
	self.myQDef := app.myRoot.allQueryDefinitionObjects[_userQuery.getType, _userQuery.queryMode];
	self.resetForMode(_userQuery);
	
	self.tblQueryEnt.setValueByName(ETRow_QueryName, _userQuery.heading);
	self.tblQueryEnt.setValueByName(ETRow_QueryDescr, _userQuery.description);
	
	foreach persistentCritHolder in _userQuery.allCriteriaLineHolders do
		tblSheet := tbl.accessSheet(tbl.topSheet);
		criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
		
		foreach persistentCrit in persistentCritHolder.allCriteriaLines do
			//tmpProp := self.myQDef.allQueryProperties[persistentCrit.myQueryProperty.propertyName];
			tmpProp := persistentCrit.myQueryProperty.cloneSelf(true);
			persistentCrit.myQueryProperty.cloneReferences(tmpProp);									// PAR #31155
			if criteriaHolder.allCriteriaByPropertyName.includesKey(tmpProp.propertyName, tmpProp.propertyClassName) then
				continue;//property already present - this should never happen
			endif;
			
			tmpOperator := persistentCrit.myQueryOperator.cloneSelf(true);
			persistentCrit.myQueryOperator.cloneReferences(tmpOperator);
			
			create transCrit transient;
			transCrit.set(tmpProp, tmpOperator, persistentCrit.isUnavailableAtRunTime);
			transCrit.setMyCriteriaLineHolder(criteriaHolder);					
			idx := tblSheet.addItem(transCrit.getDescriptionString);
			tblSheet.accessRow(idx).itemObject := transCrit;
			
			//05 Sep 2019	NDL	TFS 45891
			if tmpProp.performanceRating = 0 then
				hasOldDuffedQueryProperty := true;
			endif;
			
	//		if persistentCrit.isUnavailableAtRunTime then
	//			tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_UNAVAILABLE;
	//		else
				//tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_AVAILABLE;
				tblSheet.accessRow(idx).backColor := persistentCrit.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
	//		endif;
			
		endforeach;
	
		if persistentCritHolder &lt;&gt; _userQuery.allCriteriaLineHolders.last then
			self.doAddSheet();
		endif;
	endforeach;
	
	//05 Sep 2019	NDL	TFS 45891
	if hasOldDuffedQueryProperty then
		msg := app.getErrorString(More_query_crite_this_query_lo);
		msg := msg &amp; CrLf &amp; app.getErrorString(Offen_lines_have_been_colou_ap);
		msg := msg &amp; CrLf &amp; app.getErrorString(Color_legen_right_click_conte_);
		msg := msg &amp; CrLf &amp; app.getErrorString(Pleas_remov_crite_line_updat_s);
		app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only);
	endif;
	
	if self.myCurrentQuery &lt;&gt; null then
		self.lstQuery.selectObject(self.myCurrentQuery);
		if self.lstQuery.listIndex &gt; 0 then
			if not self.lstQuery.itemVisible(self.lstQuery.listIndex) then
				self.lstQuery.expandParentsUntilVisible( self.lstQuery.listIndex );
			endif;
		endif;
	endif;

	
end;</source>
        <Parameter name="_userQuery" type="CM_MenuUserQuery" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showResultsInRowEnquiry" id="8dd94557-0ca1-43da-942a-33cad4c723dd">
        <source>showResultsInRowEnquiry(_selOnly : Boolean);
// ---------------------------------------------------------------------------
// Created:		31 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theTerminalArea : CM_GridArea;
	theArea : CM_TerminalArea;
	rows : CM_ObjectArray;
	objs : ObjectSet;
	theENQ : CM_EnquiryController;
	obj : Object;
begin
	// Mar 2012 limit to cargo enquiry 
	if self.myQDef &lt;&gt; null and
	   self.myQDef.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	create objs transient;

	if _selOnly then
		self.tblResults.allSelectedObjects.copy(objs);
	else
		self.myEnqController.allObjects.copy(objs);
	endif;

	//+cnwml2 PAR24707
	obj := objs.first;
	if obj.isKindOf(CM_TrackedItem) then
		self.myAssistant.myTerminal := obj.CM_TrackedItem.myTerminal;
	else
		self.myAssistant.myTerminal := self.myTerminal;
	endif;
	
	self.myAssistant.showYardRowEnquiryForm(objs, self.myMasterMenuAction,  self.myEnqController,false, VIEW_DISPORT, 1, null); // PAR 19913

	self.myAssistant.myTerminal := null;				//+cnwml2 PAR24707

epilog
	delete rows;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_selOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showScreensToSendTo" id="a66f6523-17b9-45e8-9054-38a237904456">
        <source>showScreensToSendTo() protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
/*

Date		Who		Reason
31 Jul 2008	cnwkpd1	PAR #17642 - Rework code to get first Terminal to take account of whether
					objects have been selected or not
15 dec 2008 concms1	CCMS SFW 1047 - moved send-to code to base form so it can be used by summaries
					as well
*/

vars
	
begin
	app.mousePointer := Busy;

	// CCMS 1047 - use code from base form for selector now.
	self.doSendToScreen_ShowPopup (self.myEnqController.allObjects, self.tblResults.allSelectedObjects,
								tblScreens, self.allDefaultForms);


epilog
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTblResultFontDialog" id="bb6bb0c6-443b-496d-801e-0974d7a6adbc">
        <source>showTblResultFontDialog() protected;
// ---------------------------------------------------------------------------
// Created:     25 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	fontDialog			: CMDFont;
	tbl					: CM_DataTable;
begin
	tbl := self.tblResults;
	
	create fontDialog transient;
	fontDialog.fontName 		:= tbl.fontName;
	fontDialog.fontSize 		:= tbl.fontSize;
	fontDialog.fontBold 		:= tbl.fontBold;
	fontDialog.fontItalic 		:= tbl.fontItalic;
	fontDialog.fontStrikethru 	:= tbl.fontStrikethru;
	fontDialog.fontUnderline 	:= tbl.fontUnderline;
	fontDialog.textColor 		:= tbl.foreColor;
	
	if fontDialog.open() &lt;&gt; null then
		return;
	endif;
	
	tbl.fontName 		:= fontDialog.fontName;
	tbl.fontSize 		:= fontDialog.fontSize;
	tbl.fontBold 		:= fontDialog.fontBold;
	tbl.fontItalic 		:= fontDialog.fontItalic;
	tbl.fontStrikethru 	:= fontDialog.fontStrikethru;
	tbl.fontUnderline 	:= fontDialog.fontUnderline;
	tbl.foreColor 		:= fontDialog.textColor;
	
	
	
	
epilog
	delete fontDialog;

end;</source>
        <access>protected</access>
    </JadeMethod>
