    <JadeMethod name="getQuantity" id="b036e423-0ed9-434e-8b07-83086a788637">
        <source>getQuantity(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		if self.myReserveSelection.quantitySelection &gt; 0 then
			returnStr := self.myReserveSelection.quantitySelection.String;
		endif;
	endif;
	if returnStr = null then
		if self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_DeliveryRequest) then
			if self.myRequest.CM_DeliveryRequest.quantity &gt; 0 then
				returnStr := self.myRequest.CM_DeliveryRequest.quantity.String;
			endif;
		endif;
	endif;
	if returnStr = null then
		returnStr := "0";
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
