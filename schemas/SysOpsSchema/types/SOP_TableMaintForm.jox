    <JadeMethod name="doCancel" id="f40a58ba-a5c4-49fb-83f2-fe2c17120bc8">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 16 September 2003
//
//-----------------------------------------------------------------------
begin
	if (self.shtTblInput1.visible and self.tblInput1.hasChanged)
	or (self.shtTblInput2.visible and self.tblInput2.hasChanged)
	or (self.shtTblInput3.visible and self.tblInput3.hasChanged)
	then
		return self.confirmCancel('the current item');
	endif;
	
	return true;
epilog
	btnAdvanced.enabled		:=	true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCellInputReady" id="ac332964-9621-4455-ad24-313b200da824">
        <updating/>
        <source>doCellInputReady(table: CM_EntryTable; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 11/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
//	06 Sep 2022 navtnr20 ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train
// 21 Sep 2022	navak20	TFS Bug 54856: MTN - On the Edit mode scroll bar is invisible when tabbing out on the terminal config form
// 13 Sep 2023 	navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
vars
	tbl	: CM_EntryTable;
	jadeRow : JadeTableRow;							// PAR #36421
begin
	tbl := table;			// PAR #31155 

	if inputControl.name = self.tblSetStop.name or 
	   inputControl.name = self.tblCheckStop.name or 
	   inputControl.name = self.tblProcessStop.name or 
	   inputControl.name = self.lstTermRelease.name or 
	   inputControl.name = self.lstTermVoyInland.name or 
	   inputControl.name = self.lstTidalModels.name or
	   inputControl.name = self.lstWODtlType.name or									//13.9.2023 navhl20 #60063
	   inputControl.name = self.lstPackGroup.name or									// PAR #36421
	   inputControl.name = self.lstSecClasses.name or									// PAR #36421
	   inputControl.name = self.tblForecastReqd.name then								// 06.09.2022 navak20 TFS 54505
		self.myAssistant.listTableCellInputReady(tbl, cheight, self.saveRowHeight);
		//tbl.adjustHeight(500);		// 21.09.2022 navak20 TFS 54856
		
		if inputControl.name = self.lstPackGroup.name then								// PAR #36421
			jadeRow := tbl.accessRow(tbl.row);											// PAR #36421
			jadeRow.height := 55;														// PAR #36421
		endif;																			// PAR #36421
		//06.09.2022 navtnr20 54505
		if inputControl.name = self.tblForecastReqd.name then
			jadeRow := tbl.accessRow(tbl.row);
			jadeRow.height := 74;
		endif;
		//06.09.2022 navtnr20 54505
		if inputControl.name = self.lstWODtlType.name then								//13.9.2023 navhl20 #60063
			jadeRow := tbl.accessRow(tbl.row);
			jadeRow.height := 38;
			tbl.adjustHeight(500);
		endif;
	endif;

	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #31155
		app.doMeasureTableCellInputReady(tbl, inputControl);											// PAR #31155
	endif;																								// PAR #31155
end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
