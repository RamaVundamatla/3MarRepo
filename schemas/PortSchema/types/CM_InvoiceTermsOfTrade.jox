    <JadeMethod name="getAuditTextForProperty" id="bdedd3a4-df94-482a-80cc-5370b6f4124b">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61331: Jade - Terms Audits

*/

vars
	prop,
	str		: String;
begin

	prop := _property.name;
	
	if _property.name = CM_InvoiceTermsOfTrade::dueRule.name then
		str := CM_InvoiceTermsOfTrade@getDueRuleString(self.dueRule);
		return self.formatAuditText(prop, str);
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c6bcacc4-caf9-4d2e-a074-47d23c987d0a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_Code3 then
		return self.code;
	elseif _attrName = ETRow_Description30 then
		return self.description;
	elseif _attrName = ETRow_DueDays then //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
		return self.dueDays.asStringJMT();
	elseif _attrName = ETRow_DueRule then //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
		return CM_InvoiceTermsOfTrade@getDueRuleString(self.dueRule);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
