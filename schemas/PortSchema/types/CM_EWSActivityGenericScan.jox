        <source>setSequence() updating;
/*

Purpose:			Sets our sequence to the instance id

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
21 February 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.sequence := self.cnGetInstanceId(self);

end;</source>
