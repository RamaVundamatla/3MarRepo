  	theForm.shtMultiSelect1.visible := true;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="516ea3f9-e4cb-4874-afed-273ee407eb1f">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
		theForm : SOP_TableMaintForm;
		delay	: 	CM_DelayType;
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DelaysMain);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_DelaysMainTbl);
	theForm.shtTblInput1.visible := true;
	

	

end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2bccbdf4-d1c3-436a-9244-b5260b6b19bc">
        <updating/>
        <source>showThumbnail(_delayType: CM_DelayType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02/04/2011	cnwcs5		ccms 1132 - add is not available for entry
06/09/2011	cnwcs5		CCMS MES 1033 - add requires workpoint
*/
vars
	form 	: SOP_TableMaintForm;
	table	: CM_EntryTable;
begin
	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	table.clearValues;
	
	table.setValueByName(ETRow_RequiresMachine, _delayType.getDisplayStringForAttribute(ETRow_RequiresMachine, true)); 			// may need to cast string to boolean
	table.setValueByName(ETRow_IsNotAvailableForEntry, _delayType.getDisplayStringForAttribute(ETRow_IsNotAvailableForEntry, true));	// may need to cast string to boolean
	table.setValueByName(ETRow_Operational, _delayType.getDisplayStringForAttribute(ETRow_Operational, true));						// may need to cast string to boolean
	table.setValueByName(ETRow_Description,	_delayType.getDisplayStringForAttribute(ETRow_Description, true)); 
	table.setValueByName(ETRow_RequiresVoyage, _delayType.getDisplayStringForAttribute(ETRow_RequiresVoyage, true)); 				// may need to cast string to boolean	
	table.setValueByName(ETRow_RequiresWorkpoint, _delayType.getDisplayStringForAttribute(ETRow_RequiresWorkpoint, true));
	table.setValueByName(ETRow_CanScheduleInAdvance,	_delayType.getDisplayStringForAttribute(ETRow_CanScheduleInAdvance, true));	// may need to cast string to boolean
	table.setValueByName(ETRow_DelayTypeOrder,	_delayType.getDisplayStringForAttribute(ETRow_DelayTypeOrder, true)); 
	
	//24 Aug 2018	NDL	TFS 40309
	table.setValueByName(ETRow_MyVoyageEvent, null); 
	self.myForm.cmbVoyageEvent.listIndex := -1;
	if _delayType.requiresVoyage then
		if _delayType.myEventTypeToCreate &lt;&gt; null then
			self.myForm.cmbVoyageEvent.listIndex := self.myForm.cmbVoyageEvent.findObject( _delayType.myEventTypeToCreate );
			table.setValueByName(ETRow_MyVoyageEvent,	_delayType.getDisplayStringForAttribute(ETRow_MyVoyageEvent, true)); 
		endif;
	endif;
	
	if _delayType.myMachineAvailability &lt;&gt; null then
		table.setValueByName(ETRow_Code, _delayType.getDisplayStringForAttribute(ETRow_Code, true));
	endif;
	
	form.myAssistant.comboBoxMachineAvailability(form.cmbMachineCode,_delayType.myMachineAvailability);

	form.mulSelect1.setSelected(_delayType.allDelayTypeGroups);
	self.disableMulSelect1Contents();
	
	self.changeRequiresVoyage( _delayType.requiresVoyage );	//24 Aug 2018	NDL	TFS 40309
epilog

end;
</source>
        <Parameter name="_delayType" type="CM_DelayType"/>
    </JadeMethod>
</Class>
