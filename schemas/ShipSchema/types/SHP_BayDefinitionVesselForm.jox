    <JadeMethod name="setToViewMode" id="3aa4bd34-2708-4b43-8975-2df5482b7425">
        <updating/>
        <source>setToViewMode() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isFirstActivateComplete
	and self.mode = self.Mode_View then
		return;
	endif;
	
	self.mode := self.Mode_View;

	self.setControlsForView();
		
	if self.viewModeOnly
	or self.myCurrentCellularVessel = null then
		self.btnEditTV.enabled := false;
	elseif self.myCurrentCellularVessel &lt;&gt; null then
		self.btnEditTV.enabled := true;
	endif;

	self.btnCancelBase.enabled := false;		
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="d0fd955d-1723-4346-82d0-67cde6f1a9fb">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := app.myRoot.allDrawingAttributes;

	app.cmsBeginLoad(ls);	
	
	drawAttr := atttDict[PicTIDoorsAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIDoorsAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors40.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor40.setFontFromDrawingAttr(drawAttr);
	endif;

	// PAR 18682 CCMS SFW 1055
	drawAttr := atttDict[PicTI45Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen45.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTI40Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen40.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI30Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen30.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI53Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen53.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIMTOnly];
	if drawAttr &lt;&gt; null then
		self.btnPenEmpty.setFontFromDrawingAttr(drawAttr);
	endif;
/*
	self.btnPenHeavy.fontCharacter	:= 72;
	self.btnPenHeavy.fontColour		:= Red;
	self.btnPenHeavy.fontName		:= "Verdana";
	*/
	drawAttr := atttDict[PicTIHeavy];
	if drawAttr &lt;&gt; null then
		self.btnPenHeavy.setFontFromDrawingAttr(drawAttr);
	endif;
/*
	self.btnPenVoltage.fontCharacter	:= 86;
	self.btnPenVoltage.fontColour		:= Red;
	self.btnPenVoltage.fontName		:= "Verdana";
	*/
	drawAttr := atttDict[PicTIVoltageSingle];
	if drawAttr &lt;&gt; null then
		self.btnPenVoltage.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIConnected];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIReefer];
	if drawAttr &lt;&gt; null then
		self.btnPenReefer.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIUnavail];
	if drawAttr &lt;&gt; null then
		self.btnPenUnavail.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIWaterCooled];
	if drawAttr &lt;&gt; null then
		self.btnPenWaterCool.setFontFromDrawingAttr(drawAttr);
	endif;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="acab0a01-8055-4d95-b3b3-feea723ffc9a">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpIntArray : IntegerArray;
begin
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	
	self.viewModeOnly := (not app.myCurrentUserCan(null, PmShipBayDefMaint));
	
	//28 July 20101	NDL	Par 25127
	create tmpIntArray transient;
	tmpIntArray.add(J_key_Tab);
	self.tblOnCellDims.registerKeys(tmpIntArray);
	self.tblUnderCellDim.registerKeys(tmpIntArray);

	self.initForm();
epilog
	delete tmpIntArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="showBayIDFrame" id="9cb7e484-cc81-480f-9ee7-0b94c40a6ba0">
        <source>showBayIDFrame();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
begin
	if self.frmGetBayID.visible then
		return;
	endif;
	self.txtGetBayID.text := null;
	self.frmGetBayID.visible := true;
	// ### Build Vessel Combo
	self.cmbgetBayIDBays.clear;
	if self.myCurrentCellularVessel &lt;&gt; null then
		foreach aBay in self.myCurrentCellularVessel.allBaysByOrdinal do
			self.cmbgetBayIDBays.addItemObject(aBay.id,aBay);
		endforeach;
	endif;
	self.frmGetBayID.zOrder(1);
	self.frmGetBayID.centreWindow();
	self.txtGetBayID.setFocus();

end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="1560beb3-1999-43c6-ad47-471ebd13e115">
        <updating/>
        <source>showWithObjectMode(_structure: CM_CellularVesselStructure; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	07 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_structure, _doMode);
	self.myCurrentCellularVessel := _structure;

	if self.myCurrentCellularVessel &lt;&gt; null then
		if _doMode then
			// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected vessel
			self.mode := self.Mode_Update;
		endif;
	elseif _doMode then
		// set to add mode. self.loadDataForFirstTime() will init form in add mode
		self.mode := self.Mode_Add;			
	endif;
	
	self.show();
		
end;</source>
        <Parameter name="_structure" type="CM_CellularVesselStructure"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWizardFrame" id="a6050600-fcff-454a-b408-602049a78677">
        <source>showWizardFrame();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 17912
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	frame : Frame;
begin
	if not  self.myCurrentCellularVessel.allBaysByLabel.isEmpty() then
		app.msgBox("Can only use bay definition creation wizard if no structure exists. Vessel '" &amp; self.myCurrentCellularVessel.myVessel.code &amp; "' already has bays defined.", "Bay Creation Wizard", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	frame := self.frmWizard;
	if frame.visible then
		return;
	endif;

	self.txtWBayOrder.text := "01-31";
	self.txtWOnDeckCells.text := "10-09";
	self.txtWOnDeckTier.text := "82-92";
	self.txtWUnderDeckCel.text := "08-07";
	self.txtWUnderDeckTr.text := "02-14";

	frame.zOrder(1);
	frame.centreWindow();
	frame.visible := true;
	self.txtWBayOrder.setFocus();

end;</source>
    </JadeMethod>
