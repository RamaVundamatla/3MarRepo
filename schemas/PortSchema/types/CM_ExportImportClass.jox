    <JadeMethod name="createProperty" id="e91e5ba7-13b7-4682-a3c9-e8b5a33b4828">
        <source>createProperty(_proxyAttr: CM_ExportImportProperty) : CM_ExportImportProperty;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
	prop : CM_ExportImportProperty;

begin
	create prop persistent;
	prop.setForCreate(_proxyAttr);
	self.allProperties.add(prop);
	
	return prop;
end;</source>
