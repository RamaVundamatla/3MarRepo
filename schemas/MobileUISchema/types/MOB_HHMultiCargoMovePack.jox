    <JadeMethod name="addCargoToTable" id="30161dcb-e6a2-4238-b752-5578b8c1248c">
        <updating/>
        <source>addCargoToTable( ti : CM_TrackedItem; _setUpMultiMove : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	desc : String;
	measureType : CM_MeasurementType;
	size : Integer;
	index : Integer;
	mmg : CM_MultiMoveGroup;
	relatedTi : CM_TrackedItem;
	derivedLocation : String;
	includeAutoPlan : Boolean;
	

begin

	if allMultiMoveCargo.includes( ti) then
		size := self.tblProspects.rows;
		foreach index in 1 to size do
			if self.tblProspects.accessRow(index).itemObject = ti then
				self.tblProspects.accessCell(index,1).text := "1";	// make sure its selected.
				break;
			endif;
		endforeach;
	
	else
		self.allMultiMoveCargo.add( ti );

		if ti.isBulkByQuantity then
			desc := ti.totalQuantity.String;
		elseif ti.isBulkByWeight then
			measureType := ti.myCargoType.getMeasurementTypeFor(Type_Weight, true);
			desc := app.convertMeasurementForDisplay(measureType.shortName, ti.totalWeight) &amp; " " &amp; measureType.shortName;
		elseif ti.isBulkByVolume then
			measureType := ti.myCargoType.getMeasurementTypeFor(Type_Volume, true);
			desc := app.convertMeasurementForDisplay(measureType.shortName, ti.totalVolume) &amp; " " &amp; measureType.shortName;
		endif;
		if desc &lt;&gt; null then
			index := self.tblProspects.addItem( "1" &amp; Tab &amp; ti.id &amp; "(" &amp; desc &amp; ")" );
		else
			index := self.tblProspects.addItem( "1" &amp; Tab &amp; ti.id );
		endif;
		self.tblProspects.accessRow(index).itemObject := ti;
	
	endif;
	
	//16 sep 2015	NDL	Par 36906
	if _setUpMultiMove then
	
		mmg := ti.myMultiMoveGroup;
		if mmg &lt;&gt; null then
			// add the other associated cargo items to the table.
			foreach relatedTi in mmg.allAssociatedCargo do
				if relatedTi = ti then
					continue;
				endif;
				self.addCargoToTable( relatedTi, false );
			endforeach;
		endif;
	
		if self.optMove.value then
			//if we are doing a move with either an 'Multi Move Group' or a 'Cargo Group'
			// attempt to derive the target location
			
			if ( self.txtLocation.text = null) or (self.txtLocation.text = self.lblLocation.caption.toUpper) then
				includeAutoPlan := true;
			endif;
			derivedLocation := ti.getTargetLocnForHHMultiMove( includeAutoPlan );
			
			//if we got something, populate it, otherwise leave it be...
			if derivedLocation &lt;&gt; null then
				self.txtLocation.text := derivedLocation;
				self.txtLocation_lostFocus( self.txtLocation );
			endif;
		endif;
		
		self.txtCargoId.text := null;
		self.txtCargoId_lostFocus( self.txtCargoId );
		
	endif;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_setUpMultiMove" type="Boolean"/>
    </JadeMethod>
