<Class name="CM_RemoteReticketDtlNew">
    <JadeMethod name="loadRemoteArray" id="2f60000f-2554-4461-94fa-9a1a460e19a4">
        <updating/>
        <source>loadRemoteArray(_table: CM_EntryTable io) updating;

// cnwdvb1 12 June 2003 

constants

	AllTiArrayRow = 3;
	ColumnHeading = 'Old/New';
	
vars

	ti 					: String;

begin

	if _table.row = AllTiArrayRow then
		inheritMethod(_table);
		_table.setColumnHeadings(ReticketItemsArray, ColumnHeading);
		foreach ti in self.oldAndNew do
			self.addRemoteRow(_table, ti, ti, null);
		endforeach;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="91513c2e-ffd9-453b-9f99-33f159da76ce">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 12 June 2003 

vars

begin

	inheritMethod(_table);

	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Area and Location', self.areaLocation, null);
	self.addRemoteRow(_table, 'All Reticket Items', Click, self);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
