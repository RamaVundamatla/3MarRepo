    <Constant name="ReportType_DischargeSummary" id="53dd5e39-feee-43f6-920b-43fcaca639e5">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="ReportType_LoadSummary" id="5ff1e653-d54b-4734-a74e-dc658b68165a">
        <source>0</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="myVoyage" id="f67bb1fe-7181-418b-abee-58798b9b60e1">
