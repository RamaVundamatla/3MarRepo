    <JadeMethod name="getName" id="cb6ed490-4080-4c26-9fd8-15bf63c45585">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myTranMapCargo &lt;&gt; null then
		if self.myTranMapCargo = self.myTranMapCargo.bank.currentTransactionMap then
			return self.myTranMapCargo.name &amp; " (Active)";
		else
			return self.myTranMapCargo.name;
		endif;
	elseif self.myTranMapVTMIS &lt;&gt; null then
		if self.myTranMapVTMIS = self.myTranMapVTMIS.myBank.myCurrentTranMapVoyage then
			return self.myTranMapVTMIS.name &amp; " (Active)";
		else
			return self.myTranMapVTMIS.name;
		endif;
	
	elseif self.myTranMapEvent &lt;&gt; null then
		if self.myTranMapEvent = self.myTranMapEvent.myBank.myCurrentTranMapEvent then
			return self.myTranMapEvent.name &amp; " (Active)";
		else
			return self.myTranMapEvent.name;
		endif;
	elseif self.myTranMapWO &lt;&gt; null then // TFS 39236
		if self.myTranMapWO = self.myTranMapWO.myBank.myCurrentTranMapWorkOrder then
			return self.myTranMapWO.name &amp; " (Active)";
		else
			return self.myTranMapWO.name;
		endif;
		
	 //31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapBOL &lt;&gt; null then
		if self.myTranMapBOL = self.myTranMapBOL.myBank.myCurrentTranMapBOL then
			return self.myTranMapBOL.name &amp; " (Active)";
		else
			return self.myTranMapBOL.name;
		endif;
	
	elseif self.myTranMapSSSummary &lt;&gt; null then
		if self.myTranMapSSSummary = self.myTranMapSSSummary.myBank.myCurrentTranMapSnapShot then
			return self.myTranMapSSSummary.name &amp; " (Active)";
		else
			return self.myTranMapSSSummary.name;
		endif;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		if self.myCurrentMapTMCargoAllocation = self.myCurrentMapTMCargoAllocation.myBank.myCurrentTranMapCargoAlloc then // PAR 35833
			return self.myCurrentMapTMCargoAllocation.name &amp; " (Active)"; // PAR 35833
		else
			return self.myCurrentMapTMCargoAllocation.name; // PAR 35833
		endif;
	elseif self.myTranMapInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1

		if self.myTranMapInventory = self.myTranMapInventory.myBank.myCurrentTranMapInventory then  // ### TFS 51219 25MAY2021 NAVAB1
			return self.myTranMapInventory.name &amp; " (Active)";  // ### TFS 51219 25MAY2021 NAVAB1
		else
			return self.myTranMapInventory.name;  // ### TFS 51219 25MAY2021 NAVAB1
		endif;

	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
