    <JadeMethod name="validateForUpdate" id="605b2560-53f2-48e6-8360-e6165468bf4b">
        <source>validateForUpdate(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	voyageStatus, realStatus : SelfType;

begin
	if self.isTransient then
		realStatus := self.pxyGetRealObject().CM_VoyageStatus;
	else
		realStatus := self;
	endif;
	voyageStatus := app.myRoot.allVoyageStatuses[self.id];
	if voyageStatus &lt;&gt; null and voyageStatus &lt;&gt; realStatus then
		app.raiseCMException1(Gate_Error16, self.id.String, null, null);
	endif;
	self.validateMe();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="47d9e7cb-1a24-402a-a811-614b85bf9314">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	niceName : String;
	resource : HMS_Resource;

begin
	if self.priority = null then
		app.raiseCMException(No_Priority_entered, "priority", null);
	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, "description", null);
	endif;
	
	//11 Jun 2018	NDL	TFS 38795
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_VoyageStatusDetail);
	entTableRow := entTableDef.getEntTableRow( ETRow_ReportToRun );
	if entTableRow &lt;&gt; null then
		niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
	else
		niceName := "Report To Run";
	endif;
	app.validateReportName( self.reportToRun, niceName, "CM_VoyageView");	//01 Jun 2018	NDL	TFS 38905
	
	//02 Aug 2018	NDL	TFS 39900
	foreach resource in self.allHMSResourcesApproval do
		if not  self.allHMSResourcesAllowed.includes( resource ) then
			app.raiseCMWarning1(Appro_resou_must_inclu_withi_e, resource.getDisplayDetails(false), null, null, null );
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
</Class>
