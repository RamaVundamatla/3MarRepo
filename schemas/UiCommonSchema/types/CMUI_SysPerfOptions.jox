    <JadeMethod name="doOK" id="e34a21ed-f20a-4335-aae1-e6543bf593a4">
        <updating/>
        <source>doOK() updating;
/*
------------------------------------------------------------------------
Created:			15 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	agent : CMUI_SysPerformAgent;
begin
	agent := self.myPerfForm.mySysPerformAgent;
	agent.showAvgAbort := self.chkAvgAbort.value;
	agent.showAvgBegnNote := self.chkAvgBgnNotes.value;
	agent.showAvgCommit := self.chkAvgCommit.value;
	agent.showAvgCreates := self.chkAvgCreates.value;
	agent.showAvgDeletes := self.chkAvgDeletes.value;
	agent.showAvgDlvNotes := self.chkAvgDlvNotes.value;
	agent.showAvgDlvNotes := self.chkAvgDlvNotes.value;
	agent.showAvgEndNotes := self.chkAvgEndNotes.value;
	agent.showAvgGetLocks := self.chkAvgGetLocks.value;
	agent.showAvgGets := self.chkAvgGets.value;
	agent.showAvgLocks := self.chkAvgLocks.value;
	agent.showAvgServerExec := self.chkAvgServerExec.value;
	agent.showAvgUnlocks := self.chkAvgUnlocks.value;
	agent.showAvgUpdates := self.chkAvgUpdates.value;
	agent.showChkNumAvailFat := self.chkNumAvailFat.value;
	agent.showChkNumAvailThin := self.chkNumAvailThin.value;
	agent.showChkThin := self.chkNumThin.value;
	agent.showChkNumProcesses := self.chkNumProcesses.value;
	agent.showChkNumProcLic := self.chkNumProcLic.value;
	agent.numToRetrieve := self.mskNumToGet.getTextAsInteger;
	inheritMethod();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="28fc8d84-e09e-446a-9372-30ec3774647c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008177, locale);
	cMUI_GroupBox1.translateCaption(Xlat_0000952, locale);
	cMUI_Label3.translateCaption(Xlat_0000964, locale);
	chkAvgAbort.translateCaption(Xlat_0000965, locale);
	chkAvgBgnNotes.translateCaption(Xlat_0000953, locale);
	chkAvgCommit.translateCaption(Xlat_0000963, locale);
	chkAvgCreates.translateCaption(Xlat_0000958, locale);
	chkAvgDeletes.translateCaption(Xlat_0000959, locale);
	chkAvgDlvNotes.translateCaption(Xlat_0000954, locale);
	chkAvgEndNotes.translateCaption(Xlat_0000955, locale);
	chkAvgGetLocks.translateCaption(Xlat_0000956, locale);
	chkAvgGets.translateCaption(Xlat_0000966, locale);
	chkAvgLocks.translateCaption(Xlat_0000967, locale);
	chkAvgServerExec.translateCaption(Xlat_0000949, locale);
	chkAvgUnlocks.translateCaption(Xlat_0000960, locale);
	chkAvgUpdates.translateCaption(Xlat_0000961, locale);
	chkNumAvailFat.translateCaption(Xlat_0000957, locale);
	chkNumAvailThin.translateCaption(Xlat_0000950, locale);
	chkNumProcLic.translateCaption(Xlat_0000962, locale);
	chkNumProcesses.translateCaption(Xlat_0000951, locale);
	chkNumThin.translateCaption(Xlat_0000968, locale);
end;</source>
    </JadeMethod>
