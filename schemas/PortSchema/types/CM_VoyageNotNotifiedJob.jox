<Class name="CM_VoyageNotNotifiedJob" id="21091c37-a32c-4707-8738-579771e9d4c7">
    <superclass name="CM_VoyageJob"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>#################
#################

	For discharge of cargo created on the fly
	via hand held on a LOLO, CONRO or RORO voyage.
	
	It will be in the NotNotified Block stack.
	
#################
#################

</text>
    <DbClassMap file="operatn"/>
    <JadeMethod name="cleanup" id="72581a82-80e7-4ebe-bbbb-1be83a34a6de">
        <updating/>
        <source>cleanup(numCleaned: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars

begin

	if self.status = JOB_COMPLETE then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;
	if 	self.allEntries.isEmpty  then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;

epilog

end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createForQueuedJob" id="d33ad02a-32c1-481f-9831-2944370a1088">
        <updating/>
        <source>createForQueuedJob(_voy : CM_Voyage; _ti : CM_TrackedItem; _otherTiSet : CM_TISet; _moveType : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars
	wle : CM_VoyageWLE;
	req : CM_SlotRequest;
	voy : CM_Voyage;
	moveType : Integer;
	cr : CM_Crane;
	wp : CM_WorkPoint;
	
	otherTi : CM_TrackedItem;

begin
	create wle;
	create req;
	voy := _voy;

	self.myVoyage := voy;
	wle.updateRequest(req);
	wle.setJob(self);
	wle.setMyTrackedItem(_ti);
	req.setMoveType(_moveType);
	
	//28 Jun 2010	NDL	Par 24583
	if _otherTiSet &lt;&gt; null then
		foreach otherTi in _otherTiSet do
			create wle;
			create req;
			wle.updateRequest(req);
			wle.setJob(self);
			wle.setMyTrackedItem(otherTi);
			req.setMoveType(_moveType);
		endforeach;
	endif;
	
	if _moveType = LOAD_MOVETYPE then
		self.isDischarge := false;
	else
		self.isDischarge := true;
	endif;

	self.setJobNum("NOPRE");
	
	cr := self.getJobCrane;
	// Get the RORO queue, which is the first crane queue on the voyage, where the queue's crane has no jobsheet on the voyage. 
	if cr = null then
		cr := voy.getCraneWithNoJS();
		if cr &lt;&gt; null then
			self.craneId := cr.id;
		endif;
	else
		//13 June 2012	NDL	Par 29621
		wp := voy.getWorkPointWithNoJS();
		if wp &lt;&gt; null then
			self.craneId := wp.code;
		endif;
	endif;
	
	self.setIsLoaded(true); //epr 28/11/2013 CCMS 2323
epilog

end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_otherTiSet" type="CM_TISet"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="30ce185b-bce5-45ef-b226-9e9aa5b80e23">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars

begin

	self.workListEntries.purge;
	self.allRequests.purge;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDischargeLane" id="b7dcdbb6-86f6-4b71-bd5a-1e19b3d67425">
        <source>getDefaultDischargeLane(): CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars

	crane : CM_Crane;
	wp : CM_WorkPoint;
	
begin
	
	//13 June 2012	NDL	Par 29621
	wp := self.getJobWorkPoint();
	if wp &lt;&gt; null then
		return wp.getDefaultDischargeLane(true);
	endif;
	
	crane := self.getJobCrane();
	if crane &lt;&gt; null then
		return crane.getDefaultDischargeLane();
	endif;
	
	app.raiseCMException(Crane_not_found_voyage,null,self);
	return null;
		
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getJobClassNiceString" id="9027d0bd-1440-484b-b534-2dfa25be7dda">
        <source>getJobClassNiceString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

begin
	
	return app.getErrorString( Unnotified );

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobCrane" id="4d2581bd-7d50-4f5f-b72f-1083ad65a91a">
        <source>getJobCrane(): CM_Crane;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars

	js : CM_VoyageJobSheet;
	mach : CM_Crane;

begin

	js := self.myVoyage.allJobSheets.first;
	if js &lt;&gt; null then	
		mach := js.getMyCrane;
		if mach &lt;&gt; null then
			return mach;
		endif;			
	endif;
		
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getJobWorkPoint" id="4544d27b-12d3-4dbf-9b2d-0d1303b29940">
        <source>getJobWorkPoint():CM_WorkPoint;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2012	cnwndl1	Initial creation	Par 29621

*/

vars

	js : CM_VoyageJobSheet;
	wp : CM_WorkPoint;

begin

	
	js := self.myVoyage.allJobSheets.first;
	if js &lt;&gt; null then	
		wp := js.getMyWorkPoint;			
	endif;
	
	return wp;

epilog

end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
