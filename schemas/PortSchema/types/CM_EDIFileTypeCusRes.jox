    <JadeMethod name="create" id="6ff1dfc4-74fb-4667-9a4e-e4857be3124c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "CUSRES - Customs Response";
	self.type	:= EDIFileType_CusRes;
end;</source>
