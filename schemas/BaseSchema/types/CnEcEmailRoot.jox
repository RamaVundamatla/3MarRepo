vars
	errorMessage	: String;
	vBaseDataNew	: CnEcEmailBaseData;

begin
	errorMessage := createEmailBaseData(	null,//app.computerName,	//pComputerName:String;
											".cnw.co.nz",//app.computerName.toLower &amp; ".cnw.co.nz",	//pEmailClientName:String;
											null,	//pEmailReturnAddress:String;
											"smtp.cnw.co.nz",	//pEmailServerName:String;
											"dc=aoraki,dc=co,dc=nz",	//pDefaultLdapBase:String;
											"ldap.cnw.co.nz",	//pDefaultLdapHost:String;
											self,	//pMyEmailBaseRoot:CnEcEmailRoot;
											vBaseDataNew	//pCnEcEmailBaseDataNew : CnEcEmailBaseData output
											);  


	// Attributes (Non Keys)
	

	// Attributes (Keys)


	// Singleton References

	self.myDefaultBaseData := 	vBaseDataNew;
	
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
