    <JadeMethod name="getMatchingItem" id="b7ff840a-04d2-4971-89be-d7587730f0aa">
        <source>getMatchingItem(_cargo : CM_CargoBOLType; _commodCode : String;
				_isoType : CM_ISOType; _product, _marks,
				_markNumber, _colour, _purchaseOrder,
				_serviceOrder	: String;
				_reason : String output) : CM_BookingRefItem;
/*
	Created on 29 February 2008 by Debby Hutchison
	
	Purpose: Finds a booking item that matches the cargo, commodity, isotype and product.
	
	If the booking reference only has a iso group rather than a type - this will match the
	type to the group (PAR 25954)
	
	Changed On	By			Reason
	----------	--------	--------------------------------------------------------------
	21/03/2012	cnwdap1		CCMS SFW 1250 PAR #26287 Check number of TIs already assigned to 
							booking items, returning one that still has spare allocation, or
							if none have space then the first matching one
	13/06/2013	cnwcs5		par 31670 - fix breakbulk quantities
	05/04/2023	navpw1		TFS: 56707 (56712) - Added more criteria to Booking items
	05/04/2024	navkc1 		Bug 63509: STWO- MTN TEST- Split Booking Error
*/
vars
	brItem		: CM_BookingRefItem;
	checkedAll	: Boolean;				// PAR #26287
begin
	while true do						// PAR #26287
		foreach brItem in self.allBookingRefItems do
			//epr par 36632 28/8/15 refactored code block into method on bookingRefItem for reuse
			if brItem.doesCargoMatch(_cargo ,_commodCode,_isoType,_product, _marks, _markNumber, _colour, _purchaseOrder, _serviceOrder, checkedAll, _reason) then
				return brItem;
			endif;
		endforeach;

		if not checkedAll then						// PAR #26287
			checkedAll := true;						// PAR #26287
		else										// PAR #26287
			break;									// PAR #26287
		endif;										// PAR #26287
	endwhile;										// PAR #26287
	
	return null;
end;
</source>
        <Parameter name="_cargo" type="CM_CargoBOLType"/>
        <Parameter name="_commodCode" type="String"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_product" type="String"/>
        <Parameter name="_marks" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getMatchingItemForTI" id="fdac0e7d-f819-40fe-a0d3-6817d335873b">
        <source>getMatchingItemForTI(_ti : CM_TrackedItem; _reason : String output):CM_BookingRefItem;
/*
	Created on Unknown by Unknown
	
	Purpose: Finds a booking item that matches the Ti.
	
	Changed On	By			Reason
	----------	--------	--------------------------------------------------------------
	05/04/2023	navpw1		TFS: 56707 (56712) - Added more criteria for getting a Booking item
	05/04/2024	navkc1 		Bug 63509: STWO- MTN TEST- Split Booking Error
*/
vars
	iso 		: CM_ISOType;
	prodCode 	: String;
	commodity	: String;
	brItem 		: CM_BookingRefItem;		//cnwmc5 - 31 July 2014 - PAR 34468
	
begin

	commodity := _ti.commodity;
	if _ti.isKindOf(CM_Container) then
		iso :=  app.myRoot.allISOTypes[_ti.CM_Container.isoType];
	else
		iso := null;
	endif;
	if _ti.myProduct &lt;&gt; null then
		prodCode := _ti.myProduct.code;
		commodity := "";		// PAR 18782
	else
		prodCode := null;
	endif;
	
	//cnwmc5 - 31 July 2014 - PAR 34468
	brItem := self.checkForPrenotedItem(_ti);
	if brItem &lt;&gt; null then
		return brItem;
	endif;
	
	return self.getMatchingItem(_ti.myCargoType,
							commodity,
							iso,
							prodCode,
							_ti.mark,
							_ti.markNumber,
							_ti.getColour,
							_ti.purchaseOrder,
							_ti.serviceOrder,
							_reason //05/04/2024	navkc1 Bug 63509
							);
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getMatchingLinkedStockBookItem" id="ee190f1d-f91e-4948-9c39-cc583480125f">
        <source>getMatchingLinkedStockBookItem(_ti : CM_TrackedItem input) : CM_BookingRefItem;
/*

Date			Who		Reason
28 August 2015	cnwer1	Initial creation PAR 36632
05 April 2023	navpw1	TFS: 56707 (56712) - Added more criteria for getting a Booking item
*/

vars
	brItem		: CM_BookingRefItem;	
	checkedAll	: Boolean;	
	cargo : CM_CargoBOLType; 
	commodity	: String;
	isoType : CM_ISOType; 
	product : String;
	reason	: String; //05/04/2024	navkc1 Bug 63509
begin
	if self.allLinkedStockBookingItems.isEmpty then
		return null;
	endif;
	
	commodity := _ti.commodity;
	if _ti.isKindOf(CM_Container) then
		isoType :=  app.myRoot.allISOTypes[_ti.CM_Container.isoType];
	else
		isoType := null;
	endif;
	if _ti.myProduct &lt;&gt; null then
		product := _ti.myProduct.code;
		commodity := "";		
	else
		product := null;
	endif;
	
	while true do						
		foreach brItem in self.allLinkedStockBookingItems do		
			if brItem.doesCargoMatch(_ti.myCargoType ,commodity,isoType,product, _ti.mark, _ti.markNumber, _ti.getColour, _ti.purchaseOrder, _ti.serviceOrder, checkedAll, reason) then
				return brItem;
			endif;		
		endforeach;

		if not checkedAll then						
			checkedAll := true;	
		else										
			break;									
		endif;										
	endwhile;										
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="82e46c6c-cf10-48a3-9716-c788596532dc">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Date		Who		Reason
19 March 2013	cnwdap1	Initial creation
*/
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.getTotalWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMultiItemCommodityGroupsStr" id="adc7eb2f-84d8-4d80-a251-1d3b502fffb3">
        <source>getMultiItemCommodityGroupsStr() : String;
// --------------------------------------------------------------------------------
// Created:		27 October 2009 by cnwjo3
//
// Purpose:		Return all the different commodity groups for a multiitem booking reference.  For NFS 21418
//
// Returns:		String of Commodity Groups
vars
	tmpStr : String;
	brItem 	: CM_BookingRefItem;
	tmpCommodity	: CM_Commodity;
	cgString		: String;
begin
	foreach brItem in self.allBookingRefItems do
		if brItem.commodity &lt;&gt; null then
			tmpCommodity := app.myRoot.allCommodities[brItem.commodity];
			if tmpCommodity &lt;&gt; null then
				if tmpCommodity.myCommodityGroup &lt;&gt; null then
					cgString := tmpCommodity.myCommodityGroup.code &amp; ", ";
					if tmpStr.pos(cgString,1) &lt; 1 then
						tmpStr := tmpStr &amp; cgString;
					endif;
				endif;
			endif;
		endif;
	endforeach;

	if tmpStr.pos(",",1) &gt; 0 then  //remove the comma at end
		tmpStr := tmpStr[1:tmpStr.length-2];
	endif;	
	
	return tmpStr[1:60];		//This is so the key length of the dictionary is no bigger than 60  PAR25705
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMultiItemCommodityString" id="4b155602-f7c6-4947-a4f4-b49f06b286b5">
        <source>getMultiItemCommodityString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwrd1	Initial creation

*/

vars
	brItem 			: CM_BookingRefItem;
	returnString 	: String;
	first 			: Boolean;
	strArray		: StringArray;
	
begin
	
	if allBookingRefItems.size =1 then
		brItem := allBookingRefItems.first;
		return  brItem.commodity;
		
	else
		create strArray transient;
		first := true;
		foreach brItem in self.allBookingRefItems do
			if brItem.commodity = '' 
			or strArray.includes(brItem.commodity)	// avoiding duplicates. Par 18692, Dec2 2008
			then
				continue;
			endif;
			if first then
				returnString := brItem.commodity;
				first := false;
			else
				returnString := returnString &amp; ", " &amp; brItem.commodity;
			endif;
			strArray.add(brItem.commodity);
		endforeach;
		
	endif;
	
	return returnString;
	
epilog
	delete strArray;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
