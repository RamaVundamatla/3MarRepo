    <JadeMethod name="getStateData" id="78f885e3-df04-4c78-8aef-8c915b5f29fa">
        <source>getStateData(pSubSystem : Integer; pKey : String) : Any;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	if pSubSystem &lt; 1 or pSubSystem &gt; self.allSubSystemStateObjects.size then
		return null;
	endif;
	app.myPassport.myActivityCapture.logConfig('SubSystem:' &amp; pSubSystem.String &amp; ' Key:' &amp; pKey);
	
	stateObj := self.allSubSystemStateObjects[pSubSystem];
	
	if stateObj &lt;&gt; null then
		return stateObj.getStateData(pKey);
	else
		return null;
	endif;

end;</source>
        <Parameter name="pSubSystem" type="Integer"/>
        <Parameter name="pKey" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
