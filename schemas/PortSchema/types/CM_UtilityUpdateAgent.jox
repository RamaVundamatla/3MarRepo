    <JadeMethod name="utlUpdateTermCashOpts" id="cf2950b3-a721-4021-9246-c256e9211d04">
        <source>utlUpdateTermCashOpts(	_terminal : CM_Terminal;
						_cmif : CMIF_InvoiceCashModule;
						_allConfigBanks : CMIF_ConfigBankByBankDict;
						_passport : CM_Passport input
						);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2012	cnwndl1	Initial creation	Par 29968
02/08/2017	cnwdap1	TFS 5520 SSL Print Proforma Invoice
08/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
08 Jan 2018	NDL	TFS 40010 - move some configs to CM_Bank
05 Apr 2019 jlgdi1	TFS 44087 Added setting the value of CheckCashDebtorOnRelease configuration
19 Mar 2020 cnwma1  Bug 48897: SNO - New cargo enquiry screen
27 Jun 2024 navbs1  CR 64834 Task 64847: UI - Terminal and Cash Configurations
*/

vars
	taxCode		: CM_TaxCode;
	codeList	: String;
	bankConfig : CMIF_ConfigBank;
begin

	self.initialiseActivity();
	exclusiveLock( _terminal );
	
	_cmif.validateConfig();			//cnwmc5 - 11 Sep 2015 - PAR 36895
	
	//08 Jan 2019 NDL	TFS 40010
	if not _allConfigBanks.isEmpty then
		foreach bankConfig in _allConfigBanks do
			bankConfig.validateConfig();
		endforeach;
	endif;

	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminal, true);
	endif;
	
	if _passport.noErrors then
		//_terminal.setConfig(CashProcUnderpayIsError, _cmif.cashProcUnderpayIsError);
		_terminal.setConfig(CashOnlyInDebtOption, _cmif.cashOnlyInDebtOption);	//30 May 2018	NDL	TFS 38952
		// 32851 more cash options
		_terminal.setConfig(CashCollectAllowUnderpay, _cmif.allowCashCollectUnderpay);
		_terminal.setConfig(CashCollectAllowOverPay, _cmif.allowCashCollectOverpay);
		_terminal.setConfig(CashACforGL, _cmif.cashACforGL);
		_terminal.setConfig(GateCashReceiptReport, _cmif.cashReceiptReport);
		_terminal.setConfig(CashOnlyReceiptReport, _cmif.cashOnlyReceiptReport);		// 33523
		_terminal.setConfig(CashCreditReport, _cmif.cashCreditReport);		// 37141
		_terminal.setConfig(GateCashInvReceiptReport, _cmif.cashInvReceiptReport);
		_terminal.setConfig(DutyDocumentReport, _cmif.dutyDocumentReport);	//18 Dec 2012	NDL	Par 30901
		_terminal.setConfig(DutyDocCarReport, _cmif.dutyDocCarReport);	//18 Dec 2012	NDL	Par 30901
		
		// 31602 additional cash entry for Gulftainer
		_terminal.setConfig(CashAllowSecondCurrency, _cmif.allowSecondCurrency);
		_terminal.setConfig(CashSecondPayCurrency, _cmif.secondCurrencyType);
		_terminal.setConfig(NoConsolidateRoadExit, _cmif.noConsolidateRoadExit);	//16 Aug 2019	NDL	TFS 44261
		_terminal.setConfig(CashDebtorType, _cmif.cashDebtorType);
		_terminal.setConfig(CashInvoiceEveryReceipt, _cmif.invoiceEveryCashReceipt);
		_terminal.setConfig(CashFullCustomsAgentID,_cmif.cashFullCustomsAgentID); //epr par 35304 2/12/14 
		//_terminal.setConfig(ProFormaItemQuery, _cmif.proFormaItemQuery);	      //08 Jan 2013	NDL	Par 30901	- 19.03.2020 cnwma1 #48897
		_terminal.setConfig(ProFormaInclDDTicket, _cmif.proFormaInclDDTicket);	  //08 Jan 2013	NDL	Par 30901	
		_terminal.setConfig(ProFormaInclDDBill, _cmif.proFormaInclDDBill);	      //08 Jan 2013	NDL	Par 30901	
		
		// 34917 GPHA cash options
		_terminal.setConfig(PaymentDetailsMandatory, _cmif.paymentMethodDetailsMandatory);
		/* TFS 45953
		_terminal.setConfig(CashShowInvoiceLineType, _cmif.showInvoiceLineType);
		_terminal.setConfig(CashShowParentAndChildItems, _cmif.showParentAndChildItems);
		_terminal.setConfig(CashShowCargoItemsWithParent, _cmif.showCargoItemsWithParent);
		_terminal.setConfig(CashNoDuplicatesActualEst, _cmif.noDuplicatesActualEstimated);
		*/
//		_terminal.setConfig(CashTaxInvLineType, _cmif.cashTaxInvoiceLineType);
		foreach taxCode in _cmif.allTaxCodes do
			codeList := codeList &amp; taxCode.code &amp; ",";
		endforeach;
		_terminal.setConfig(CashAllCashTax, codeList);
		_terminal.setConfig(GateCashReceiptReport, _cmif.cashReceiptReport);		    // TFS 5520
		_terminal.setConfig(CashDebtorType, _cmif.cashDebtorType);					    // TFS 5520	
		_terminal.setConfig(CashProformaReport, _cmif.cashProformaReport);				// TFS 5740
		_terminal.setConfig(ShowDebtorForPayment, _cmif.showDebtorForPayment);			// TFS 5740
		_terminal.setConfig(ShowDebtorForProforma, _cmif.showDebtorForProforma);		// TFS 5740
		_terminal.setConfig(CheckCashDebtorOnRelease, _cmif.validateCashDebtorOnRelease);		// TFS# 44087
		_terminal.setConfig(CurrencyCodeForAPI, _cmif.currencyCodeForAPI);				//27.06.2024  navbs1  CR 64834 Task 64847
		_terminal.setConfig(InvProformaInvoiceReport, _cmif.invProformaInvoiceReport);	// ### TFS CR 65810 TASK 65812 27AUG2024 NAVAB1
		_terminal.setConfig(CashRoadExitChkServices, _cmif.cashRoadExitChkServices); //25/02/2025	navkc1 JIRA Story MTN-33928
	endif;
	
	//08 Jan 2019 NDL	TFS 40010
	if _passport.noErrors then
		if not _allConfigBanks.isEmpty then
			foreach bankConfig in _allConfigBanks do
				bankConfig.setBankFromCMIF();
			endforeach;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminal, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cmif" type="CMIF_InvoiceCashModule"/>
        <Parameter name="_allConfigBanks" type="CMIF_ConfigBankByBankDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTermConfigFromString" id="57c413d7-5696-4cf8-a409-1e53d0e38989">
        <source>utlUpdateTermConfigFromString(	_cmif : CMIF_ConfigOptionsDisplay input;
								_term : CM_Terminal;
								_newValue : String;
								_passport : CM_Passport input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	oldValue : Any;

begin

	if _cmif = null or not _cmif.appliesToTerm then
		return;
	endif;

	self.initialiseActivity();
	exclusiveLock( _term );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_term, true);
	endif;
	
	oldValue := _term.getConfig( _cmif.constantName );
	if ( oldValue &lt;&gt; null and oldValue.isKindOf(String) and oldValue.String = _cmif.currentValue )
	or ( oldValue = null and _newValue = "true" or _newValue.isReal )
	then
		_term.setConfig( _cmif.constantName, _newValue );
		if _newValue &lt;&gt; _term.getConfig( _cmif.constantName ).String then
			app.raiseCMException(Failed_update, _cmif.optionName, null );
		else
			_cmif.currentValue := _newValue;
		endif;
	else
		app.raiseCMException(Failed_update, _cmif.optionName, null );
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_term, false);
	endif;

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ConfigOptionsDisplay" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_newValue" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTermDrCashOnly" id="aa65c200-1d41-45fc-93dc-6b1b40e5df44">
