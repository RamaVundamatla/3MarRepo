    <JadeMethod name="isDensity_Match" id="3d80f2c5-1c31-4c0a-a373-3fabf8d5a285">
        <source>isDensity_Match(_yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/

vars
	trackedItem : CM_TrackedItem;
	density 	: String;
begin
	trackedItem := self.myTransaction.myTrackedItem;
	
	if trackedItem &lt;&gt; null then
		return _yaData.doesValueMatch(trackedItem.getDensity().asStringWeightJMT());
	elseif self.myTrackedItem &lt;&gt; null then
		return _yaData.doesValueMatch(self.myTrackedItem.getDensity().asStringWeightJMT());
	endif;
epilog

end;</source>
