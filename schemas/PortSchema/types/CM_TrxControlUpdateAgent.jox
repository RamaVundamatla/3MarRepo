    <JadeMethod name="trxUpdateCustDocsDetails" id="951a74e9-d08f-42af-81bf-52c306ce6d51">
        <updating/>
        <source>trxUpdateCustDocsDetails(_cmifCustomDocumentDtl : CMIF_CustomDocumentDetail io;
						_passport : CM_Passport input)updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	pxyCustomDocumentDetail, realDetail: CM_CustomDocumentDetail;
begin
	//Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	if _passport.hasErrors() then
		return;
	endif;
	
	foreach pxyCustomDocumentDetail in _cmifCustomDocumentDtl.allProxyCustDocDetails do
		if pxyCustomDocumentDetail.pxyIsProxy() then 
			app.myUtilityUA.utlUpdateCustDocDetail(pxyCustomDocumentDetail, _passport);
		else
			app.myUtilityCA.utlCreateCustDocDetail(pxyCustomDocumentDetail, realDetail,_passport);
			
			// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
			if (not self.checkValidationWithPassport(_passport)) then
				continue;
			endif;

			_cmifCustomDocumentDtl.allRealCustDocDetails.add(realDetail);
		endif;

		// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
	endforeach;
	
	_cmifCustomDocumentDtl.validateTIs(); // ### TFS 60508 15SEP2023 NAVAB1
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_cmifCustomDocumentDtl" type="CMIF_CustomDocumentDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
