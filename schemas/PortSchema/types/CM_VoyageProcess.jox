        <source>setReportNames(	_ediPrenoteFormat : String;
				_reportInvoiceEstimate : String;
				_reportInvoicePreinvoice : String;
				_reportInvoiceTaxinvoice : String;
				_workOrderReceivalReport : String;
				_workOrderReleaseReport : String
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars

begin

	self.ediPrenoteFormat := _ediPrenoteFormat[1:100];
	self.reportInvoiceEstimate := _reportInvoiceEstimate[1:100];	
	self.reportInvoicePreinvoice := _reportInvoicePreinvoice[1:100];
	self.reportInvoiceTaxinvoice := _reportInvoiceTaxinvoice[1:100];
	self.workOrderReceivalReport := _workOrderReceivalReport[1:100];	//11 Jun 2018	NDL	TFS 38795
	self.workOrderReleaseReport := _workOrderReleaseReport[1:100];	//11 Jun 2018	NDL	TFS 38795

epilog

end;</source>
