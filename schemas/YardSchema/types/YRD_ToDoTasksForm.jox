    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="581fdc4c-4291-408a-ab2b-c17ef6f2d378">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
begin
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(Voyage);
	lstTable := self.lstVoyage;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;

	sht := self.shtQuery2;
	sht.caption := app.getErrorString(Operators);
	lstTable := self.lstOperator;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery3;
	sht.caption := app.getErrorString(TerminalAreas);
	lstTable := self.lstTermArea;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery4;
	sht.caption := app.getErrorString(CargoTypes);
	lstTable := self.lstCargoType;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;

	sht := self.shtQuery5;
	sht.caption := app.getErrorString(Tasks);
	lstTable := self.lstTasks;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery6;
	sht.caption := app.getErrorString(SearchOptions);
	sht.visible := true;
	
	self.cmbToDoOpt.addItem(CMQF_TerminalTIs.TASKS_TODO_TRUE);
	self.cmbToDoOpt.addItem(CMQF_TerminalTIs.TASKS_TODO_FALSE);
	self.cmbToDoOpt.addItem(CMQF_TerminalTIs.TASKS_TODO_EITHER);
	self.cmbToDoOpt.listIndex := 1;
	
	self.cmbCompleteOpt.addItem(CMQF_TerminalTIs.TASKS_COMPLETE_TRUE);
	self.cmbCompleteOpt.addItem(CMQF_TerminalTIs.TASKS_COMPLETE_FALSE);
	self.cmbCompleteOpt.addItem(CMQF_TerminalTIs.TASKS_COMPLETE_EITHER);
	self.cmbCompleteOpt.listIndex := 1;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableData" id="0989aa2f-ba53-4b9f-a686-ecb36b149fff">
        <source>initTableData(_theEntDef : String);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aToDoTasksDesc 	: CM_ToDoTaskDesc;
	idx 			: Integer;
	theArray 		: ObjectArray;
	theLine 		: String;
	numCols 		: Integer;
	tbl				: CM_DataTable;
	
begin

	tbl := self.tblData;
	
	create theArray transient;
	tbl.rows 		 := 0;
	tbl.cnEcResizeContents();
	tbl.fixedColumns := 0;
	tbl.columns 	 := self.TaskStartColumn - 1;
	numCols 		 := tbl.columns;
	
	theLine := app.getErrorString(CM_ID) 	   &amp; Tab &amp; 
			   app.getErrorString(CM_Location) &amp; Tab &amp;
			   app.getErrorString(Voyage) 	   &amp; Tab &amp; 
			   app.getErrorString(Operator);
			   
	foreach aToDoTasksDesc in app.myRoot.allToDoTaskDescriptions where aToDoTasksDesc.type = TODO_TYPE_GROUP_TI  do  // ### TFS  #56634[54259] 22NOV2022 NAVAB1	

		theLine := theLine &amp; Tab &amp;  aToDoTasksDesc.shortDescription ;
		numCols := numCols + 1;
		theArray.atPut(numCols,aToDoTasksDesc);
	endforeach;
	
	tbl.columns := numCols;
	idx 		:= tbl.addItem(theLine);

	foreach numCols in self.TaskStartColumn to tbl.columns do
		tbl.accessColumn(numCols).itemObject := theArray[numCols];
	endforeach;
	
	tbl.fixedRows 	 := 1;
	tbl.fixedColumns := 1;
	self.setColorsForTable(tbl);

epilog
	delete theArray;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeWithTI" id="de81e7d9-4cf3-409c-b05c-0bf8f63cd2f3">
        <updating/>
        <source>initializeWithTI() protected, updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if (not self.myTIQueryFilter.allQryTrackedItems.isEmpty) then
		self.displayTIs(self.myTIQueryFilter.allQryTrackedItems);
		self.frmQuery.visible := false;
		self.btnAddComplete.enabled := true;
		self.btnRemoveTasks.enabled := true;
		self.btnEnquire.enabled := false;
		self.btnEdit.enabled 	:= false;	// cnwvu1	PAR13649	19/02/2007
	endif;

	if self.myInitializationTI &lt;&gt; null and self.myInitializationTI.isTransient then
	//add end
		if (not self.isBaseFormModal) then //all bad
			app.raiseUnexpectedProgramError(class.name, method.name, 'Form must be launched modal when updating a proxy');
			self.unloadForm();
		endif;
		
		//we are dealing with a transient proxy sent from another form
		self.btnShowSearcher.enabled := false;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="ee6aa842-48af-446f-8343-c4a102a08109">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3
	and app.isControlKeyDown()
	and not app.isAltKeyDown()
	and not app.isShiftKeyDown()
	then
		self.showSelector();
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCargoTypes" id="b19e8be6-f17c-454e-bd38-2148025c5a19">
        <updating/>
        <source>loadCargoTypes() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aCargoType 		: CM_CargoType;
	idx 			: Integer;

begin

//	self.lstCargoType.accessCell(1,2).text := " CargoTypes...";
	foreach aCargoType in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		if not aCargoType.allTerminals.includes(self.myTerminal) then
			continue;
		endif;
		idx := self.lstCargoType.addItem('0' &amp; Tab &amp; aCargoType.abbreviation &amp; " - " &amp; aCargoType.description);
		self.lstCargoType.accessRow(idx).itemObject := aCargoType;
		
		// #################
		// DEFAULT TO CONTAINER
		if aCargoType.id = TI_CargoType_Container then
			self.lstCargoType.accessRow(idx).selected := true;

			self.lstCargoType.accessCell(idx,1).text := true.cnEcGetTableCheckBoxValue;
			if not self.lstCargoType.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
				self.lstCargoType.allSelectedObjects.add(aCargoType);
			endif;
		endif;
	endforeach;

	self.lstCargoType.lostFocus(self.lstCargoType);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="3b88f7d6-86c5-4057-8c22-ef8cfcf582b5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.loadVoyages();
	self.loadToDoTasks();
	self.loadOperators();
	self.loadTermAreas();
	self.loadCargoTypes();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOperators" id="d2e6922f-4116-42fd-a61f-017796a3f9cc">
        <updating/>
        <source>loadOperators() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aOperator 		: CM_Operator;
	idx 			: Integer;
begin

	foreach aOperator in app.myRoot.allOperators do
		idx := self.lstOperator.addItem('0' &amp; Tab &amp; aOperator.code &amp; " - " &amp; aOperator.description);
		self.lstOperator.accessRow(idx).itemObject := aOperator;
	endforeach;

//	self.tblQuery.setValueByName(ETRow_Operator, Any_String);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTermAreas" id="a1d93893-822a-49f2-9808-bb81b9c18eeb">
        <updating/>
        <source>loadTermAreas() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aTerminalArea 	: CM_TerminalArea;
	idx 			: Integer;
	

begin
	foreach aTerminalArea in self.myTerminal.allTerminalAreas do
		idx := self.lstTermArea.addItem('0' &amp; Tab &amp; aTerminalArea.myType.description &amp; " - " &amp; aTerminalArea.id.trimBlanks);
		self.lstTermArea.accessRow(idx).itemObject := aTerminalArea;
	endforeach;

//	self.tblQuery.setValueByName(ETRow_TermArea, Any_String);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadToDoTasks" id="840ff526-8e5a-48e0-95c2-477b80e06d4a">
        <updating/>
        <source>loadToDoTasks() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aToDoTasksDesc 	: CM_ToDoTaskDesc;
	idx 			: Integer;
begin

	foreach aToDoTasksDesc in app.myRoot.allToDoTaskDescriptions where aToDoTasksDesc.type = TODO_TYPE_GROUP_TI  do  // ### TFS  #56634[54259] 22NOV2022 NAVAB1 do	

		idx := self.lstTasks.addItem('0' &amp; Tab &amp; aToDoTasksDesc.description);
		self.lstTasks.accessRow(idx).itemObject := aToDoTasksDesc;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadVoyages" id="8312f573-c020-4dea-9393-8595111a3e6e">
        <updating/>
        <source>loadVoyages() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/07/2018	cnwma1		Bug 39388: STWO - JMT Prod To Do Task Menu
// ---------------------------------------------------------------------------

vars
	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	theVoyages	    : CM_VoyageSet;
begin
	//6/7/2018 cnwma1  #339388 
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,true, false);
	
	/*
	6/7/2018 cnwma1  #339388 
	foreach aVoyage in self.myTerminal.allVoyagesByCode do
		if aVoyage.myCellularVoyageStructure &lt;&gt; null then
			idx := self.lstVoyage.addItem('0' &amp; Tab &amp; aVoyage.getDisplayDetails(false));
			self.lstVoyage.accessRow(idx).itemObject := aVoyage;
		endif;
	endforeach;
	*/
	// 6/7/2018 cnwma1  #339388 
	foreach aVoyage in theVoyages do
		idx := self.lstVoyage.addItem('0' &amp; Tab &amp; aVoyage.getDisplayDetails(false));
		self.lstVoyage.accessRow(idx).itemObject := aVoyage;
	endforeach;
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateRowWithTasks" id="70f25284-259a-4eff-807c-e6260e7a7dfb">
        <source>populateRowWithTasks(_tbl : CM_DataTable input; 
					_taskArray : CM_ToDoTaskArray; 
					_row : Integer;
					_toDo : Boolean);
// ---------------------------------------------------------------------------
// Created:     10 April 2003		cnwth2	
//
// Purpose:     if not _toDo, then it will be for completed toDoTasks
// ----------   ----------  --------------------------------------------------
vars
	task					: CM_ToDoTask;
//	taskDesc				: CM_ToDoTaskDesc;
	tbl						: CM_DataTable;
	numCols,
	col						: Integer;
	columnSet				: Boolean;
begin
	tbl := _tbl;
	numCols := tbl.columns;
	
	foreach task in _taskArray do
	//	columnSet := false;
		foreach col in self.TaskStartColumn to numCols do
			
			if task.toDoTaskDescShort = tbl.accessCell(1,col).text then
		//		columnSet := true;

				tbl.accessCell(_row, col);
				if tbl.accessedCell.inputType &lt;&gt; Table.InputType_CheckBox 
				and task.toDoTaskDesc = null then
					tbl.accessedCell.inputType := Table.InputType_CheckBox;
				endif;
				tbl.accessedCell.text :=  true.cnEcGetTableCheckBoxValue;
				tbl.accessedCell.itemObject := task;
				
				if _toDo then
					tbl.accessedCell.backColor := self.COLOUR_TO_DO_VIEW;
				else
					tbl.accessedCell.backColor := self.COLOUR_COMPLETED_VIEW;
				endif;
				break;
			endif;
		endforeach;
		
	/*	if not columnSet then
			tbl.columns := tbl.columns + 1;
			tbl.accessCell(1,tbl.columns).text := task.toDoTaskDescShort;
			tbl.accessedCell.backColor := Red;

			
			tbl.accessCell(_row, tbl.columns);
			tbl.accessedCell.inputType := Table.InputType_CheckBox;

			tbl.accessedCell.text :=  true.cnEcGetTableCheckBoxValue;
			tbl.accessedCell.itemObject := task;
			
			if _toDo then
				tbl.accessedCell.backColor := self.COLOUR_TO_DO_VIEW;
			else
				tbl.accessedCell.backColor := self.COLOUR_COMPLETED_VIEW;
			endif;
		endif; */
	endforeach;


end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_taskArray" type="CM_ToDoTaskArray"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_toDo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="e56b3484-8208-45ae-a7cd-2fcfba6a632a">
