    <JadeMethod name="getCalcType" id="ab705e4f-5cf5-42ee-8f68-30bb308116f6">
        <source>getCalcType() : CM_CalculationType;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCT : CM_CalculationType;
	aService : CM_Service;
begin
	// 24024 use myCalculationType if set
	if self.myCalculationType &lt;&gt; null then
		return self.myCalculationType;
	endif;

	foreach aService in self.services do
		if aService.myCalculationType &lt;&gt; null then
			aCT := aService.myCalculationType;
			break;
		endif;
	endforeach;
	
	return aCT;
end;</source>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
