    <JadeMethod name="userNotificationUpdateLocal" id="687dec22-1d46-4f53-a325-32e4d62670b7">
        <updating/>
        <source>userNotificationUpdateLocal(_event: Integer; _noteobj : CM_Object; _any : Any) updating;
// ---------------------------------------------------------------------------
// Created:		07 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		These notes will only be received if the BGP LockKeeper is running
//
// ---------------------------------------------------------------------------

// ### NOTE: These notes will only be received if the BGP LockKeeper is running





vars
	idx, bCol : Integer;
	kpi : CM_KPITerminalArea;
	line : String;
	anLC : CM_LocationsController;
begin
	return;
