    <JadeMethod name="handleTblDataDblClick" id="dd0fc1b7-6090-4ea4-9aa4-0f83873406bc">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
//--------------------------------------------------
// Created:	05 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	theTI	: CM_TrackedItem;

begin
	
	theTI := tblData.accessRow(_row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		// want to open cargo edit with this object
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);
	endif;

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="1ee92dbd-a52d-41c7-b4b5-48259005e9a8">
        <updating/>
        <source>includeObject(_ti: CM_TrackedItem; _passport : CM_Passport): Boolean updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	localFrom,
	localTo,
	systemFrom,
	systemTo: TimeStamp;
	
begin

	if _ti = null 
	or ((not _ti.isExport) and (not _ti.isTranshipItem)) //+ cnwmd1 Par 25463 - added tranship
	or (_ti.site &lt;&gt; TI_SITE_ONSITE and _ti.state &lt;&gt; TI_STATE_NOTIFIED) 
	or (self.emptiesExcluded and _ti.isEmpty)
	or (not self.allCargoTypesForCEDO.includesKey(_ti.cargoType)) then
		return false;
	endif;
	
	//epr TFS 2409 tiding up move from tblDataDisplayRow
	if (self.filterCEDO &lt;&gt; null and not _ti.customExportEntryNumber.startsWith(filterCEDO)) or
	   (self.filterCEDOSet = self.View_Has_CEDO and _ti.customExportEntryNumber = null) or
	   (self.filterCEDOSet = self.View_No_CEDO and _ti.customExportEntryNumber &lt;&gt; null) or	   
	   (self.filterOperatorCode &lt;&gt; null and _ti.operatorCode.trimRight &lt;&gt; self.filterOperatorCode) or
	   (self.myFilterVoyage &lt;&gt; null and _ti.myVoyage &lt;&gt; self.myFilterVoyage) then
	   	return false;
	endif;
	
	if _ti.isChild then
		return false;
	endif;
	
	if self.filterDateFrom.isValid and self.filterDateTo.isValid then
		localFrom.setDate(self.filterDateFrom);
		localFrom.setTime("0:00:00".Time);
		localTo.setDate(self.filterDateTo + 1);
		localTo.setTime("0:00:00".Time);
		systemFrom := self.localToSystemTime(localFrom);
		systemTo := self.localToSystemTime(localTo);
		//if (not _ti.createdTime.date.cnEcIsBetween(self.filterDateFrom, self.filterDateTo)) then
		if (_ti.receivedDT &lt; systemFrom) or (_ti.receivedDT &gt;= systemTo) then	// 4/5/16 cnwmp6 TFS 488 - Multi timezone support
			return false;
		endif;
	endif;	
	
	
			//this call takes a while only do if necessary
	return _ti.canUserAccessSelf(null, failedDAC, _passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="bb75645f-1fdf-460a-b24e-c0368629ca0e">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/06/2016	cnwdap1		TFS #1949 VGM Process Requirements - Allocations
// ---------------------------------------------------------------------------
vars
	row : EntTableRow;
begin

	self.allowMultiSelectEdit := true;
	// Stops are in a class of their own now so add all of them AKB2002JUNE
	self.addStopsColumns();
	
	// setup table columns
	self.setTblDataEntRows(ETDef_ExportReleaseTblData);
	self.columnCEDO := tblData.getColumnByRowName(ETRow_CustomExportEntryNumber);	
	self.columnHeld := tblData.getColumnByRowName(ETRow_CustomExportStop);
	self.columnHasVGM := self.tblData.getColumnByRowName(ETRow_HasVGM);					// TFS #1949
end;</source>
