    <JadeMethod name="addRow" id="3e599bd4-25b0-4d53-9613-34b4ee6ce743">
        <updating/>
        <source>addRow(obj: Object):CMUI_RowFrame  updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCtrl	: CMUI_RowFrame;
begin

/*
	// minimise all other rows
	foreach tmpCtrl in self.allRowFrames do
		if tmpCtrl.frmInput.visible then
			tmpCtrl.click(tmpCtrl);
		endif;		
	endforeach;
*/
	self.rowCount := self.rowCount + 1;
	if self.allUnusedRowFrames.isEmpty then
		tmpCtrl := self.myMasterRowFrame.loadControl(self.rowCount).CMUI_RowFrame;
	else
		tmpCtrl := self.reuseCurrentRow();
	endif;
	
	self.allRowFrames.add(tmpCtrl);
	
	tmpCtrl.setPictureClosed(self.binPicClosed);
	tmpCtrl.setPictureOpen(self.binPicOpen);
	
	tmpCtrl.parent := self.myScrollingFrame;
	tmpCtrl.top := self.myScrollingFrame.clientHeight;
	
	if obj &lt;&gt; null then
		tmpCtrl.setForUpdate(obj);
	endif;

	tmpCtrl.visible := true;

	self.resizeRow(tmpCtrl, tmpCtrl.height);
	tmpCtrl.redoCaption();
	
	// 25/5/06 Lorcan Scroll form to new row
	self.scrollTo (0,tmpCtrl.top.Integer);
	//th2 - commented back out again - caused bug for 'copy current' - everything blank
	//self.setCurrentRowFrame(tmpCtrl);
	return tmpCtrl;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="CMUI_RowFrame"/>
    </JadeMethod>
    <JadeMethod name="clearRow" id="1f2653a5-c37e-4475-aa26-cc505716ec0f">
        <source>clearRow(_idx: Integer) protected;
//----------------------------------------------------------------
//	Created:	18 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpRowFrame	: CMUI_RowFrame;
begin

	tmpRowFrame := self.allRowFrames[_idx];
	
	if tmpRowFrame &lt;&gt; null then
		tmpRowFrame.clear();	
	endif;
		
	
end;</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="collapseAll" id="4a7f55e0-5d4a-45c2-a149-b5fc9220d4b8">
        <updating/>
        <source>collapseAll() updating;
//-----------------------------------------------------------------------
//	Created:	13 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpRowFrame	: CMUI_RowFrame;
	totHeight,
	nextTop		: Real;

begin

	
	foreach tmpRowFrame in self.allRowFrames do
		tmpRowFrame.redoCaption();
		tmpRowFrame.frmInput.visible := false;
		tmpRowFrame.frmText.visible := true;
		tmpRowFrame.picClosed.visible := true;
		tmpRowFrame.picOpen.visible := false;
		tmpRowFrame.height := tmpRowFrame.frmText.height;
		totHeight := totHeight + tmpRowFrame.frmText.height;
		tmpRowFrame.top := nextTop;
		nextTop := nextTop + tmpRowFrame.height;
		tmpRowFrame.setTabOrder ( self.allRowFrames.indexOf(tmpRowFrame),self.allRowFrames.size,false) ;

	endforeach;
	
	if self.myCurrentRowFrame = null then
		self.setCurrentRowFrame(self.allRowFrames.first);
	endif;
	self.showCurrent();
	
	self.resizeScrollingFrame(self.myScrollingFrame.width, totHeight);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="copyCurrent" id="c25bad1a-97c5-4e46-9f55-6642d3e3d725">
        <updating/>
        <source>copyCurrent() updating;
//----------------------------------------------------------------
//	Created:	18 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpCtrl	: CMUI_RowFrame;
begin
	
	tmpCtrl := self.addRow(null);

	if self.myCurrentRowFrame = null then
		return;
	endif;
	
	tmpCtrl.setControlsFromRowFrame(self.myCurrentRowFrame);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="expandAll" id="2793a97e-58d3-483c-afad-8b2fc13cef58">
        <updating/>
        <source>expandAll() updating;
//-----------------------------------------------------------------------
//	Created:	13 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpRowFrame	: CMUI_RowFrame;
	totHeight,
	nextTop		: Real;

begin

	
	foreach tmpRowFrame in self.allRowFrames do
		tmpRowFrame.frmText.visible := false;
		tmpRowFrame.frmInput.visible := true;
		tmpRowFrame.picClosed.visible := false;
		tmpRowFrame.picOpen.visible := true;
		tmpRowFrame.height := tmpRowFrame.frmInput.height;
		totHeight := totHeight + tmpRowFrame.frmInput.height;
		tmpRowFrame.top := nextTop;
		nextTop := nextTop + tmpRowFrame.height;
		tmpRowFrame.setTabOrder ( self.allRowFrames.indexOf(tmpRowFrame),self.allRowFrames.size,true) ;
	endforeach;
	
	if self.myCurrentRowFrame = null then
		self.setCurrentRowFrame(self.allRowFrames.first);
	endif;
	self.showCurrent();
	
	self.resizeScrollingFrame(self.myScrollingFrame.width, totHeight);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getRowCount" id="974ecd62-8244-4940-bf65-d71820d68005">
        <source>getRowCount(): Integer;
//-----------------------------------------------------------------------
//	Created:	21 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	return self.rowCount;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resizeRow" id="456dad5c-1cc0-4af4-b25c-0ea649ed6197">
        <updating/>
        <source>resizeRow(_rowFrame : CMUI_RowFrame; _newHeight : Real) updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRowFrame	: CMUI_RowFrame;
//	idx,
//	numRows		: Integer;
	totHeight,
	nextTop		: Real;

begin

//	idx := self.allRowFrames.indexOf(_rowFrame);
//	numRows := self.allRowFrames.size;
	self.resizeScrollingFrame(1000, self.myScrollingFrame.height);	
	foreach tmpRowFrame in self.allRowFrames do
		
		if tmpRowFrame = _rowFrame then
			tmpRowFrame.height := _newHeight;
			totHeight := totHeight + _newHeight;
		else
			totHeight := totHeight + tmpRowFrame.height;
		endif;
		tmpRowFrame.top := nextTop;
		nextTop := nextTop + tmpRowFrame.height;
		
		if tmpRowFrame.height = tmpRowFrame.frmText.height then
			// is it "hidden" - turn off tabbing
			tmpRowFrame.setTabOrder ( self.allRowFrames.indexOf(tmpRowFrame),self.allRowFrames.size,false) ;
		else
			tmpRowFrame.setTabOrder ( self.allRowFrames.indexOf(tmpRowFrame),self.allRowFrames.size, true) ;
		endif;
		
	endforeach;
	
	// turn off tabiing for all the frames currently unused
	foreach tmpRowFrame in self.allUnusedRowFrames do
		tmpRowFrame.setTabOrder ( self.allRowFrames.indexOf(tmpRowFrame),self.allUnusedRowFrames.size, false) ;
		tmpRowFrame.visible := false;
	endforeach;

	if self.myCurrentRowFrame = null then
		self.setCurrentRowFrame(_rowFrame);
	endif;
	self.showCurrent();

	self.resizeScrollingFrame(self.myScrollingFrame.width, totHeight);

end;</source>
        <Parameter name="_rowFrame" type="CMUI_RowFrame"/>
        <Parameter name="_newHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="reuseCurrentRow" id="10dbce10-7fc3-4099-a1a5-381e8fad1d4b">
        <source>reuseCurrentRow(): CMUI_RowFrame;
//-----------------------------------------------
//	Created:	12 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpCtrl	: CMUI_RowFrame;
begin
	tmpCtrl := self.allUnusedRowFrames.first;
	self.allUnusedRowFrames.remove (tmpCtrl);
	tmpCtrl.height := tmpCtrl.frmInput.height;
	tmpCtrl.clear();
	tmpCtrl.frmInput.visible 	:= true;
	tmpCtrl.frmText.visible 	:= false;
	return tmpCtrl;
epilog

end;</source>
        <ReturnType type="CMUI_RowFrame"/>
    </JadeMethod>
    <JadeMethod name="setCurrentRowFrame" id="d8ac5c54-33c5-41e8-ab2d-63c069ce4271">
        <updating/>
        <source>setCurrentRowFrame(_rowFrame : CMUI_RowFrame) updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myCurrentRowFrame := _rowFrame;
	self.showCurrent();
end;</source>
        <Parameter name="_rowFrame" type="CMUI_RowFrame"/>
    </JadeMethod>
