    <JadeMethod name="queryUnload" id="7bf6b2da-abd8-4e81-8b8b-d599d6a1f037">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars
	changedProperties : PropertySet;
	result : Integer;
begin
	//basically just if user closes from control box if they click cancel or save we handle this on the button clicks
	
	if reason = Form.QueryUnload_User and  self.checkHasChanged(changedProperties) then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			cancel:=1;
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeSelectedTIHazard" id="92f49ef5-a1b0-4f04-bd6d-ca488e1f3f01">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_TIHazardListTableControl::removeSelectedTIHazard"/>
        </interfaceImplements>
        <source>removeSelectedTIHazard(_tihazard : CM_TIHazard);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwer1	Initial creation

*/

vars
	selHazard : CM_TIHazard;
	bookingRefItem : CM_BookingRefItem;
	
	hazardsDict : CM_HazardByCodeDict;
begin
	selHazard:=self.myProxyBookingRef.allTIHazards[_tihazard.code].CM_TIHazard;
	if selHazard = null then
		return;
	endif;
	
	if self.myProxyBookingRef.checkForHazardOnBookingRefItem(_tihazard,bookingRefItem) then
		//app.msgBox
	endif;
	
	self.myProxyBookingRef.allTIHazards.remove(selHazard);
	if selHazard &lt;&gt; null then
		delete selHazard;
	endif;
	
	//cnwjo3 need to update hazards as we go
	create hazardsDict transient;
	self.lstHazards.allSelectedObjects.copy(hazardsDict);
	self.myProxyBookingRef.setPxyHazards(hazardsDict);
epilog
	delete hazardsDict;
end;</source>
        <Parameter name="_tihazard" type="CM_TIHazard"/>
    </JadeMethod>
    <JadeMethod name="saveDataToProxyBookingRef" id="815960dd-3486-4b06-9cd2-4f9131686577">
        <source>saveDataToProxyBookingRef(_proxyBookingRef : CM_BookingRef input);
// adm 160310 				Par 22937 remove bolType
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 05 Jun 2018	jlgrs1		TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
vars
	destPort		: String;
	dischPort		: String;
	customsAgentStr	: String;						// cnwrl1 17/02/2010 PAR 22393
	portsArray		: StringArray;
	edi				: CM_EDIBookingRefTI;
	transhipPort	: CM_Port;
	
begin
	create portsArray transient;
	self.myAssistant.saveListTablePorts(self.lstOptionalPorts, portsArray);

	edi := _proxyBookingRef.myEDIBookingRefTI;

	if self.cmbDestinPort.listObject &lt;&gt; null then
		destPort := self.cmbDestinPort.listObject.CM_Port.code;
	endif;
	/*on bulk release
	if self.cmbLoadPort.listObject &lt;&gt; null then
		loadPort := self.cmbLoadPort.listObject.CM_Port.code;
	endif;
	*/
	
	if self.cmbDischargePort.listObject &lt;&gt; null then
		dischPort := self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	
	if self.cmbTranshipPort.listObject &lt;&gt; null then
		transhipPort := self.cmbTranshipPort.listObject.CM_Port;
	endif;
	/* on bulk release
	if self.cmbCarrier.listObject &lt;&gt; null then
		carrier := self.cmbCarrier.listObject.CM_Carrier.code;
	endif;
	*/
	
	// cnwrl1 18/02/2010 PAR 22393 - start of coding
	if self.cmbCustomsAgent.listObject.CM_CustomsAgent &lt;&gt; null then
		customsAgentStr	:= self.cmbCustomsAgent.listObject.CM_CustomsAgent.code;
	endif;
	// cnwrl1 18/02/2010 PAR 22393 - end of coding
	
	// the fields that are being loaded as 0 or null here are now bookrefitem fields
	_proxyBookingRef.setProxy(	self.txtBookingRef.text,
								null,
								null,
								null, 
								null,//txtShipper.text, 
								null, 
								destPort, 
								dischPort,transhipPort, 
								portsArray,
								lstHazards.allSelectedObjects,
								//0, false, null, null, null, 
								//NULL_HUMIDITY, false, null, null, null,   //par 19554 cnwjo3		//-cnwml2 PAR19845 CCMS SFW 1079
								NULL_HUMIDITY, 
								false, 
								null,											//+cnwml2 PAR19845 CCMS SFW 1079
								self.cmbConsignor.listObject.CM_ConsigneeConsignor,					//+cnwml2 PAR19845 CCMS SFW 1079
								self.cmbConsignee.listObject.CM_ConsigneeConsignor,					//+cnwml2 PAR19845 CCMS SFW 1079
								cmbOperator.listObject.CM_Operator, 
								cmbVoyage.listObject.CM_Voyage,
								0,
								txtRemarks.text,
								null, 
								NULL_TEMPERATURE, 
								NULL_VENTILATION, 
								0,
								0,
								0,
								null,
								null,
								null, 
								null,
								0, 
								0, 
								0, 
								0, 
								0, 
								self.myTerminal,
								null, 
								//_proxyBookingRef.allBookingRefItems.size &gt; 1,			//-cnwml2 PAR22595
								true,													//+cnwml2 PAR22595
								//false, 												//-cnwml2 PAR19782 CCMS SFW 1079
								self.chkReceiveAsStoc.value,							//+cnwml2 PAR19782 CCMS SFW 1079
								edi,
								_proxyBookingRef.rawEDIData,
								//null,													//-cnwml2 PAR19845 CCMS SFW 1079
								self.txtShipRef.text.trimBlanks,						//+cnwml2 PAR19782 CCMS SFW 1079
								self.txtCarrierRef.text.trimBlanks,				// par 27460 cnwcs5
								null,//self.cmbConsignor.text.trimBlanks,				//+cnwml2 PAR19782 CCMS SFW 1079
								null, //self.cmbConsignee.text.trimBlanks,				//+cnwml2 PAR19782 CCMS SFW 1079
								self.cmbPriority.listObject.CM_CustomerPriority,
								self.cmbSpecialStow.listObject.CM_SpecialStow,
								self.chkHoldPartials.value,
								self.chkNoFullsIn.value,
								self.chkNoEmptiesOut.value,
								self.chkMilitary.value,
								self.txtVNum.text.trimBlanks,
								self.chkOverrideCut.value,
								self.chkOverDimension.value,
								self.chkFumigation.value,
								self.chkStopped.value,
								//_proxyBookingRef.status,						//-cnwml2 PAR19782 CCMS SFW 1079
								self.getBookingStatusFromCmb(),					//+cnwml2 PAR19782 CCMS SFW 1079
								null,
								lstSpecialLift.allSelectedObjects,				//+cnwml2 PAR20173 SFW CCMS 1091
								_proxyBookingRef.allLinkedStockBookingItems,	//+cnwml2 MSL CCMS 1012
								self.chkRecieveAsTran.value,					//+cnwml2 MSL CCMS 1012
								self.cmbFromVoyage.listObject.CM_Voyage,		//+cnwml2 MSL CCMS 1012
								self.getPackAsFromCmb(),						//+cnwml2 MSL CCMS 1012
								customsAgentStr, 			// cnwrl1 18/02/2010 PAR 22393
								null, 		// edivoyageCode
								null,
								self.chkDirDel.value,	//29 jan 2013	NDL	Par 31102
								self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor,		// PAR #31596
								null, 	//carrier
								self.cmbStevedore.listObject.CM_Stevedore);		//02.10.2020 cnwma1 TFS #50112
epilog
	delete portsArray;
end;
</source>
        <Parameter name="_proxyBookingRef" type="CM_BookingRef" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveDataToProxyBulkRelease" id="193262ff-c87d-4ded-a46a-84b18f74759b">
        <source>saveDataToProxyBulkRelease(_pxyBulkRelease : CM_BulkRelease input; _pxyBookingRef :CM_BookingRef input);
/****Changes

Date		Name	TFS#			Description
============================================================================
18/11/2008	cnwer1					Initial creation
23/09/2009	consw1	SFW1035 		Get info from ReserveDetail rather than Yard Request	
24/11/2011	cnwcs5	CCMS POL 2122 / 
					PAR 28696 - 	Needs Review property
07/11/2011	cnwrs1	CCMS POL 2122 / 
					PAR 28696 - 	New property allEDIFiles
23/04/2012	cnwcs5	CCMS POL 2172 / 
					Par 29480 - 	Coparn release updates
28/05/2013	cnwdap1	PAR #31596 		Added freight forwarder to bulk release
24/01/2018	jlgka1	TFS 41708		Add BOLIn that's being used to validate the
									BOL of a container versus the Release Request BOL.
29.10.25	Navcs2	MTN-36399		CUX | Booking with Release empties - Dev Changes
============================================================================*/
vars
	carrierCode,
	deliveryReasonDesc	: String;
	customsAgentStr		: String;						// cnwrl1 19/02/2010 PAR 22393
	carrier				: CM_Carrier;
	deliveryReason		: CM_DeliveryReleaseReason;
	consigneeStr		: String;
	consignorStr		: String;
	packLocs			: StringArray;
	freightFwdrStr		: String;						// PAR #31596
	voyage				 : CM_Voyage; 					// 29.10.25	Navcs2	MTN-36399
begin
	if _pxyBulkRelease = null then
		return;
	endif;
	
	if self.myTerminal.getConfig(BookingAutoRelReqVoyage).Integer = NoVoyage then			// 29.10.25	Navcs2	MTN-36399
		voyage := null;																		// 29.10.25	Navcs2	MTN-36399
	else 																					// 29.10.25	Navcs2	MTN-36399
		voyage := _pxyBookingRef.myVoyage;													// 29.10.25	Navcs2	MTN-36399
	endif;																					// 29.10.25	Navcs2	MTN-36399
	
	carrier :=self.cmbCarrier.listObject.CM_Carrier;
	
	if carrier &lt;&gt; null then
		carrierCode	:=	carrier.code;
	endif;
	
	deliveryReason	:=	self.cmbDelivRelReasn.listObject.CM_DeliveryReleaseReason;
	
	if deliveryReason &lt;&gt; null then
		deliveryReasonDesc	:=	deliveryReason.description;
	endif;
	
	// cnwrl1 19/02/2010 PAR 22393 - start of coding
	if self.cmbCustomsAgent.listObject.CM_CustomsAgent &lt;&gt; null then
		customsAgentStr	:= self.cmbCustomsAgent.listObject.CM_CustomsAgent.code;
	endif;
	// cnwrl1 19/02/2010 PAR 22393 - end of coding

	//+cnwml2 PAR26326
	if self.cmbConsignee.listObject &lt;&gt; null then
		consigneeStr := self.cmbConsignee.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	//+cnwml2 PAR26326
	if self.cmbConsignor.listObject &lt;&gt; null then
		consignorStr := self.cmbConsignor.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	if self.cmbFreightFwdr.listObject &lt;&gt; null then										// PAR #31596
		freightFwdrStr := self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor.code;	// PAR #31596
	endif;																				// PAR #31596
	
	// cnwrd1 ccms pol 2103 par 27856 14.7.2011
	create packLocs transient;
	self.lstPackLocations.getSelectedAsStringArray(packLocs);
	
	
	_pxyBulkRelease.setProxy(	_pxyBookingRef.bookingReference, //code same as this booking reference number
								self.getTransTypeFromCmb(), 
								true, //(not self.chkReservedOnly.value),  //release by type - not chkIsReservedOnly Now always true adm 070710 Par 24741
								BR_ACTIVE,
								null, ///availability grades null set on reserve selections
								null,//booking confirmation 
								carrierCode, //carrier
								null, //cargo remarks
								consigneeStr,		//consigneeCode									//+cnwml2 PAR26326
								null, //_pxyBookingRef.consigneeDesc, //consigneeDesc				//-cnwml2 PAR19845 CCMS SFW 1079
								consignorStr,		//consignor Code								//+cnwml2 PAR26326
								null, //_pxyBookingRef.consignorDesc,//consignor desc				//-cnwml2 PAR19845 CCMS SFW 1079
								null,//_consignorVoyageCode 
								null, //date requested
								self.dtPackBy.getDate().TimeStamp,//_dateEstimatedRequired
								null,//_deliveryReasonCode
								deliveryReasonDesc,//_deliveryReasonDescr
								self.txtDelReleaseNo.text,//_deliveryReleaseNumber
								null,//_doorsDirection
								null,//_freightPayerCode
								_pxyBookingRef,//CM_BookingRef
								self.cmbLoadPort.listObject.CM_Port,//_loadPort
								null,//_destinationPort	//04 Nov 2009	NDL Par 21519
								self.cmbDischargePort.listObject.CM_Port,//_dischargePort
								//self.cmbTranshipPort.listObject.CM_Port,
								//null,//_freightForwarder											// PAR #31596
								freightFwdrStr,//_freightForwarder									// PAR #31596
								null,//_transferToTerminal
								_pxyBookingRef.myTerminal,
								_pxyBookingRef.myOperator,//_operator
								null,//_operatorGroup
								voyage,//_voyage													// 29.10.25	Navcs2	MTN-36399
								null,		//_businessUnit	
// TFS 2686									null,		//_removeStops,
								null,		//_fullRelease	
								packLocs,  //pack locations
								self.cmbPoolPartner.listObject.CM_Operator,
								self.txtDispatchLocn.text.trimBlanks,
								self.myTerminal.getDefaultSubTerminalForRel(self.getTransTypeFromCmb()),
								self.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target  //cnwrd1 par 23219 17.3.2010
								null,	//_assignedTrain : CM_Train	//04 Nov 2009	NDl Par 21519
								false,
								customsAgentStr,				// cnwrl1 19/02/2010 PAR 22393
								false,							// cnwrl1 19/02/2010 PAR 22393
								false,							// May 2011 cnwjre1 27097 POL CCMS 2043
								_pxyBulkRelease.needsReview,	// don't change ot from here???
								_pxyBulkRelease.blockEDIUpdates, 	// par 29481 - don't change from here par 29480 April 2012
								null,	// CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	_pxyBulkRelease.requests.purge();
epilog
	delete packLocs;
end;
</source>
        <Parameter name="_pxyBulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_pxyBookingRef" type="CM_BookingRef" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="b643e48d-ab57-49a5-aef2-8e842e9f1ee1">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>saveSelectedTrackedItems(_allTIs: CM_TIArray) : Boolean updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2008	cnwer1	Initial creation
*/

vars
	row : Integer;
	bookingRefItem : CM_BookingRefItem;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	
	row := self.tblBookingItems.accessedRow.row;
	
	
	if row &gt; 1 then
		bookingRefItem := self.tblBookingItems.accessRow(row).itemObject.CM_BRefItemContainer;	
	endif;
	
	if bookingRefItem = null or
		bookingRefItem.myReserveDetail.maxToRelease = 0 then
		return false;
	endif;
	
	
	if _allTIs.size &gt;  bookingRefItem.myReserveDetail.maxToRelease then
		app.msgBox(app.getString(Selected_Greater_Max), app.getString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); 
		return false;
	endif;
	
	if not bookingRefItem.myReserveDetail.allTrackedItems.membersSame(_allTIs) then
		self.hasReserveDetailsChanged:=true;
	endif;
	
	bookingRefItem.myReserveDetail.allTrackedItems.clear;
	
	//13 Dec 2017	NDL	TFS 8091
	if not bookingRefItem.myReserveDetail.isTransient then
		self.updateObjectEdition( bookingRefItem.myReserveDetail );	
	endif;
	
	iter:=_allTIs.createIterator;
	while iter.next(ti) do
		if not bookingRefItem.myReserveDetail.allTrackedItems.includes(ti) then
			bookingRefItem.myReserveDetail.allTrackedItems.add(ti);
		endif;
	endwhile;
	
	self.loadBookingItemTable();
	self.loadTotals(self.myProxyBookingRef);
	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBookingDetails" id="cb5f5050-3d48-4874-8a98-de9b85aadd0e">
        <source>setBookingDetails(_bookingref: String; _voyage : CM_Voyage; _mode : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
*/

vars

begin
	self.txtBookingRef.text := _bookingref;
	if self.cmbVoyage.findObject(_voyage) &gt; 0 then
		self.cmbVoyage.listObject := _voyage;
		self.cmbVoyage.lostFocus(self.cmbVoyage);							//17.04.2023 navma1 #55440:[54990]
	endif;
	self.cmbTransType.listIndex := self.cmbTransType.findString(1,_mode);
epilog

end;</source>
        <Parameter name="_bookingref" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="11a55929-c705-4f59-a1ed-0017721a1a28">
        <updating/>
        <source>setCaption(_caption: String) updating;
//25 August 2009	cnwml2


vars
	captionStr : String;
begin
	if self.myCurrentBookingRef = null then
		captionStr:="Adding Booking ";
	else
		captionStr:="Editing Booking " &amp; self.myProxyBookingRef.bookingReference ;
	endif;
	
	inheritMethod(captionStr);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="34b1544b-7c1e-4b4c-bd3f-6ab4e17a5f57">
        <source>setControlsForAddEdit();
// ---------------------------------------------------------------------------
// Created:     10 March 2010 by cnwcs5
// Purpose:     par 22605 - implement view security
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	booking	:CM_BookingRef;
begin
	booking	:= self.myCurrentBookingRef;
	
	if booking &lt;&gt; null and booking.status &lt;&gt; BOOKING_REF_PENDING then
		if not self.canUpdateNonPendingBooking then
			// its not a pending booking and they don't have security to update a non-pending booking
			self.setControlsForView; 
			// treat as view access only
			return;
		endif;
	endif;
	
	if not self.canReserve then
		self.btnReserve.enabled := false; 
	endif;
	
	// probably don't need to do anything else here as form set up to assume user can update
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="2c475fe8-6bb1-45dc-9c1b-a002b29002b1">
