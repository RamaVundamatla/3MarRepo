    <JadeMethod name="assignTrailer" id="15669a4c-c40d-46b4-a3a3-3ce93b87ecf2">
        <source>assignTrailer( job : CM_Job input; _trailer : CM_TrackedItem; _error : String output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2014	cnwndl1	Initial creation	Par 34562

*/

vars

	wle : CM_WorkListEntry;
	mode : Integer;

begin

	if _trailer = null then
		_error := app.getErrorString(Trailer_required);
		return;
	endif;

	foreach wle in job.workListEntries do
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if wle.myTrackedItem &lt;&gt; null then
			continue;
		endif;
		if  wle.isReleaseByType then
			if wle.myRequest.CM_DeliveryRequest.myCargoType &lt;&gt; _trailer.myCargoType then
				continue;
			endif;
			mode:=NO_MODE;
			if wle.allRTQueueEntries.size &gt; 0 then
				mode:=QUEUE_MODE;
			endif;
			self.myMobileGenericAgent.assignTIToReleaseRequest( wle, _trailer, mode );
			return;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="job" type="CM_Job" usage="input"/>
        <Parameter name="_trailer" type="CM_TrackedItem"/>
        <Parameter name="_error" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="checkFindAndAssignTrailer" id="d633a57d-3668-4621-8c55-7d006eb3eda1">
        <source>checkFindAndAssignTrailer():Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2014	cnwndl1	Initial creation
20 October 2014 cnwma1  PAR #35009 1090 on hand-held Gate Checker app

*/

vars

	truck : CM_Vehicle;
	currentLocation : CM_LocationsController;
	gateLocation	: CM_GateAreaLaneController;
	errorMess : String;
	job : CM_Job;
	trailerId : String;
	trailerObj : CM_TrackedItem;

begin

	truck := self.findTruck( errorMess, true );
	errorMess := null;
	gateLocation := self.myMobileGenericAgent.myGateAreaLaneController;   // 20/10/2014 cnwma1 PAR #35009
	if truck &lt;&gt; null and gateLocation &lt;&gt; null  then							// 20/10/2014 cnwma1 PAR #35009
		currentLocation	:= truck.myPrimaryActualLocation;
		if currentLocation &lt;&gt; null
		and currentLocation.isYardLocation
		and currentLocation.CM_YardController.isInterchangeAreaLocation
		//and not self.myHandHeldCheckerAgent.myGateAreaLaneController.isInsideYard()	// 20/10/2014 cnwma1 PAR #35009
		and not gateLocation.isInsideYard()												// 20/10/2014 cnwma1 PAR #35009
		then
	
			// moving out of yard into outward gate lane. The job must be complete or have everything done
			// except identifying the real trailer if it was using a realease trailer by type..
			job :=  truck.allRoadJobs.first;
			if job &lt;&gt; null and job.status &lt;&gt; JOB_COMPLETE then
				//check to see if all we need is just the trailer id.
				if self.txtAssignTrailer.visible then
					trailerId := self.txtAssignTrailer.text;
					trailerObj := self.findTrailer(trailerId,errorMess);
					if errorMess &lt;&gt; null then
						self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
						return false;
					endif;
					self.assignTrailer(job,trailerObj,errorMess);
					if errorMess &lt;&gt; null then
						self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
						return false;
					endif;
				elseif not truck.myUnknownChassis.allTrackedItems.isEmpty then
					//make the trailer id text box visible so we can catch the data.
					errorMess := "Must enter the trailer id first";
					self.txtAssignTrailer.visible := true;
					self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
					return false;
				endif;
			endif;
			
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
