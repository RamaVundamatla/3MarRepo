    <JadeMethod name="getMachineRuleTerminalArea" id="e46f4be6-0d9d-432b-8d69-b80d1ec91bb0">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
/*

Date		Who		Reason
22/09/2014	cnwer1	Initial creation PAR 34930
20/09/2017	jlgdap1	TFS 6935 SNO Changes for Hold Jobs loaded to Operations
*/

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	js : CM_JobSheet;						// TFS 6935
begin

	queueObj := self.myVoyage.myQueue;
	if queueObj = null then	//17 Jun 2010	NDL found while testing Par 24382
		return null;
	endif;

	foreach queueItem in queueObj.allSubQueuesById where queueItem.isCraneQueue do	//23 May 2012	NDL	Par 29621
		if not self.myVoyage.hasCraneGotJS(queueItem.CM_VoyageCraneQueue.crane) then
			if queueItem.CM_VoyageCraneQueue.crane &lt;&gt; null then
				return queueItem.CM_VoyageCraneQueue.crane.transferArea;
			endif;
		endif;
 	endforeach;
	
	//epr  par 35893 20/3/15
	foreach queueItem in queueObj.allSubQueuesById 	where queueItem.isWorkPointQueue do	
		if not self.myVoyage.hasWorkPointGotJS(queueItem.CM_VoyageWorkPointQueue.myWorkPoint) then
			if queueItem.CM_VoyageWorkPointQueue.myWorkPoint &lt;&gt; null then
				return queueItem.CM_VoyageWorkPointQueue.myWorkPoint.myWorkPointInterchangeArea;
			endif;
		else																											// TFS 6935
			// Voyage Hold Jobs do have a job sheet, but are still planned / queued to the voyage ship block 			// TFS 6935
			// controller. They're not picked up above, because that's doing drag-drop type jobs from the Voyage		// TFS 6935
			// Operatinos screen. So we have a double-check here														// TFS 6935
			js := self.myVoyage.allJobSheets[queueItem.CM_VoyageWorkPointQueue.myWorkPoint.code.trimBlanks];			// TFS 6935
			if js &lt;&gt; null and js.isVoyageHoldJobSheet then																// TFS 6935
				if queueItem.CM_VoyageWorkPointQueue.myWorkPoint &lt;&gt; null then											// TFS 6935
					return queueItem.CM_VoyageWorkPointQueue.myWorkPoint.myWorkPointInterchangeArea;					// TFS 6935
				endif;																									// TFS 6935
			endif;																										// TFS 6935
		endif;
 	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getMachineRuleTerminalAreaType" id="d001cdc4-588d-4cab-9515-213551373768">
        <source>getMachineRuleTerminalAreaType(): CM_TerminalAreaType;
/*

Date				Who		Reason 
22 September 2014	cnwer1	Initial creation PAR 34930
02 August 2019		jlgzm1	TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars

	taType : CM_TerminalAreaType;
begin
	
	taType := inheritMethod();
	
	if taType &lt;&gt; null then
		return taType;
	endif;
	
	// Hold jobs don't use cranes, so if doing hold job, then use wpi
	if self.myVoyage.hasHoldJobSheet then										//TFS 42872
		return app.myRoot.allTerminalAreaTypes[TA_TYPE_WORKPOINT_INTERCHANGE];	//TFS 42872
	endif;
	return app.myRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];

epilog

end;</source>
        <ReturnType type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="getOnShipCraneDescription" id="21a6a902-550c-430c-b403-7f1176cbe160">
        <source>getOnShipCraneDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwmp6	Initial creation

*/

vars

begin

	if self.onShipCrane = BayOnShipCrane_None then
		return BayOnShipCraneStr_None;
	elseif self.onShipCrane = BayOnShipCrane_OnP then
		return BayOnShipCraneStr_OnP;
	elseif self.onShipCrane = BayOnShipCrane_OnC then	// cnwvu1 14/11/2006	ccms1048
		return BayOnShipCraneStr_OnC;
	elseif self.onShipCrane = BayOnShipCrane_OnS then
		return BayOnShipCraneStr_OnS;
	elseif self.onShipCrane = BayOnShipCrane_Before then
		return BayOnShipCraneStr_Before;
	elseif self.onShipCrane = BayOnShipCrane_After then
		return BayOnShipCraneStr_After;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProposedCargo" id="46b7be47-9f2d-45cc-9c04-6b72af063a6b">
        <source>getProposedCargo(_ti : CM_TrackedItem output; _numTIs : Integer output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	theTI : CM_TrackedItem;

begin
	theTI := self.getTIAtIndex(PLANNING_MODE, 1);
	if theTI &lt;&gt; null then
		_numTIs := self.numPlannedTIs;
		// PAR 8207 . Whilst things are planned up this worked OK. However once the Load was complete, there were only actual TIs and no Planned
		if _numTIs = 0 then // PAR 8207
			_numTIs := self.numTIs; // PAR 8207
		endif;
	endif;

	_ti := theTI;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_numTIs" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="c2ef936c-2e30-4234-9dd3-f91f4d4680f1">
        <source>getQueues(_queueSet: CM_RTQueueSet io);
// ---------------------------------------------------------------------------

// 23/9/14  created for PAR 34939 

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
	craneWP : CM_Object;
	craneId : String;
begin

	_queueSet.clear;
	
	queueObj := self.myVoyage.myQueue;

	if queueObj = null then
		//Master Queue time
		term := self.myVoyage.getMyTerminal;	
		if term.radioTelemetry = null then
			return;
		endif;
		_queueSet.add(term.radioTelemetry.masterQueue);
		return;
	endif;
	
	
	// PAR 35397 - if this location is mapped to a crane or work point, that is the queue.
	// THIS is because the user has used option in voyage operations to allocate WPs to RT Qs
	craneWP := self.myVoyage.allCranesWPByHolds.getAtKey(self);
	if craneWP &lt;&gt; null then
		if craneWP.isKindOf(CM_Crane) then
			craneId := craneWP.CM_Crane.code;
		elseif craneWP.isKindOf(CM_WorkPoint) then
			craneId := craneWP.CM_WorkPoint.code;
		endif;
		
		if craneId &lt;&gt; null then
			foreach queueItem in queueObj.allSubQueuesById do	
				if (queueItem.isCraneQueue and queueItem.CM_VoyageCraneQueue.crane.id = craneId)
				or (queueItem.isWorkPointQueue and  queueItem.CM_VoyageWorkPointQueue.myWorkPoint.code = craneId) then
					_queueSet.add(queueItem);
					return;
				endif;
			endforeach;		
		endif;
	endif;


	foreach queueItem in queueObj.allSubQueuesById where queueItem.isCraneQueue do	//23 May 2012	NDL	Par 29621
		if not self.myVoyage.hasCraneGotJS(queueItem.CM_VoyageCraneQueue.crane) then
			_queueSet.add(queueItem);
		endif;
 	endforeach;
	
	// ### PAR 34743
	foreach queueItem in queueObj.allSubQueuesById where queueItem.isWorkPointQueue do	
		// TFS 4859 - this 'if' statement was written for voyage operation 'hidden' jobs which do not have a job sheet
		// TFS 4859 - however there is now a different type of job that might be for this location and that is a hold job, 
		// TFS 4859 - which does have a job sheet and already has a work point; so just include all wp queues that are defined.
		// TFS 4859 if not self.myVoyage.hasWorkPointGotJS(queueItem.CM_VoyageWorkPointQueue.myWorkPoint) then
			_queueSet.add(queueItem);
		// endif;
 	endforeach;
	
	
	//--------------
	//Return the Voyage queue
	//--------------
	if _queueSet.isEmpty() then
		_queueSet.add(queueObj);
	endif;
	
end;</source>
        <Parameter name="_queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getStowageId" id="09e08f90-72d9-4c52-a5df-7cbf6c066b59">
