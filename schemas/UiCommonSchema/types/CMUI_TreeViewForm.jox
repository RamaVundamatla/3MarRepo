    <JadeMethod name="buildDockFrameMenu" id="ff87a921-d248-4432-a3c9-f608bd9a89b3">
        <source>buildDockFrameMenu() protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	re-implement and inherit as necessary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cloneMenu			: MenuItem;
	mnuIdx				: Integer;
	showMainMenu		: Boolean;
begin
	self.mnuDockFrame.visible := false;
	
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopLeft, self.mnuDockFrameSub, mnuIdx);
	if self.allowFrameTopLeft and self.dkbTopLeft.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomLeft, self.mnuDockFrameSub, mnuIdx);
	if self.allowFrameBottomLeft and self.dkbBottomLeft.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomRight, self.mnuDockFrameSub, mnuIdx);
	if self.allowFrameBottomRight and dkbBottomRight.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopRight, self.mnuDockFrameSub, mnuIdx);
	if self.allowFrameTopRight and self.dkbTopRight.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	/*
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcLeftMain, self.mnuDockFrameSub, mnuIdx);
	if self.dkcLeftMain.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcRightMain, self.mnuDockFrameSub, mnuIdx);
	if self.dkcRightMain.isFloating then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	*/

	if showMainMenu then
		self.mnuDockFrame.visible := true;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildFloatFrameMenu" id="30a914a7-ab05-4f27-8146-068d5982a65f">
        <source>buildFloatFrameMenu() protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	re-implement and inherit as necessary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cloneMenu			: MenuItem;
	mnuIdx				: Integer;
	showMainMenu		: Boolean;
begin
	self.mnuFloatFrame.visible := false;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopLeft, self.mnuFloatFrameSub, mnuIdx);
	if self.allowFrameTopLeft and (not self.dkbTopLeft.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomLeft, self.mnuFloatFrameSub, mnuIdx);
	if self.allowFrameBottomLeft and (not self.dkbBottomLeft.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomRight, self.mnuFloatFrameSub, mnuIdx);
	if self.allowFrameBottomRight and (not self.dkbBottomRight.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopRight, self.mnuFloatFrameSub, mnuIdx);
	if self.allowFrameTopRight and (not self.dkbTopRight.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	/*
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcLeftMain, self.mnuFloatFrameSub, mnuIdx);
	if (not self.dkcLeftMain.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcRightMain, self.mnuFloatFrameSub, mnuIdx);
	if (not self.dkcRightMain.isFloating) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	*/
	if showMainMenu then
		self.mnuFloatFrame.visible := true;
	endif;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildHideFrameMenu" id="23c7109d-c520-4b35-851b-b65b71e2b0e2">
