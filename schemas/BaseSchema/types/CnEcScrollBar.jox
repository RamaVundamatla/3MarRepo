    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myJACDesignTable" id="69e03c68-b5d2-4f6f-a699-a31e65308d8c">
        <embedded/>
        <type name="CnEcDesignTable"/>
        <access>protected</access>
        <Inverse name="CnEcDesignTable::myVerticalScrollBar"/>
    </ExplicitInverseRef>
    <JadeMethod name="change" id="d2ea815e-5239-4ed5-9813-e56956bd0ee7">
        <updating/>
        <source>change(scroll: ScrollBar input) updating;

begin
	mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doScrollLarge" id="8fc7dbfc-5b1f-44fd-b63b-cafe49f6ad4b">
        <updating/>
        <source>doScrollLarge(pPages:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		19 November 2001 by cnwdad1
//
// Purpose:		Scrolls the bar in large increments.
//
// Parameters:	pPages - The number of pages to scroll the scroll bar.  A positive
//				value will scroll forward, whilst a negative value will scroll
//				backwards.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	scrollAmount	: Integer;
	
begin
	if pPages = 0 then
		return;
	endif;
	
	scrollAmount	:=	self.largeChange * pPages;
	
	if pPages &lt; 0 then
		self.value		:=	self.value - scrollAmount - 2;
	else
		self.value		:=	self.value - scrollAmount + 2;
	endif;
	
	self.myJACDesignTable.scrollTable();
end;</source>
        <Parameter name="pPages" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="b12610c3-85e7-4102-abd1-8d91ac81c7f6">
        <updating/>
        <source>gotFocus(scroll: ScrollBar input) updating;

begin
	if self.myJACDesignTable &lt;&gt; null then
		self.myJACDesignTable.setFocus();
	endif;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="0f1d81dc-cb31-4f9e-b989-bed27ae6de43">
        <updating/>
        <source>scrolled(scroll: ScrollBar input; scrollBar: Integer) updating;

begin
	app.mousePointer	:=	Busy;
	
	if self.myJACDesignTable &lt;&gt; null then
		self.myJACDesignTable.scrollTable();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
