<Class name="CM_AutoTaskWebCam" id="95ed8e28-c5b3-4a50-8004-8781169c65c2">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Web Cam Update&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="webCamFileName" id="885e88d5-98bc-4617-a17a-5186fd74438a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="9415e40e-43f2-45c6-bc2b-4f7ab8acbb27">
        <source>getEntryTableViewName(): String;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return 'bgpAutoViewWebCam';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="5951b8de-4e7d-49d2-a01f-357c9ac6a6b1">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _rowName = ETRow_BgpAutoFilePathAndName then
		return self.webCamFileName;
	endif;
	
	return inheritMethod(_rowName, _obj);


end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1b318a82-195e-4a42-92ee-ec347207b85f">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskWebCam) updating;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_WebCamRequest.name;
	self.webCamFileName		:= _pxyAutoTask.webCamFileName;


end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskWebCam"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="42d5c083-7c17-45ee-b935-5e1a69132f5b">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskWebCam) updating;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.webCamFileName		:= _pxyAutoTask.webCamFileName;


end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskWebCam"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="0b774943-6ca2-4c15-8ce3-933ed84aa451">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _rowName = ETRow_BgpAutoFilePathAndName then
		self.webCamFileName := _value.String;
	else
		inheritMethod(_rowName, _value);
	endif;


end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="31799793-7695-4e6d-9dea-64542c70e2b4">
        <source>validate();
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	if self.webCamFileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Web Cam File', ETRow_BgpAutoHoursAhead, null);
		app.raiseCMException(Input_required_field_WebCamFle, ETRow_BgpAutoHoursAhead, null); // cnwdb2	PAR 35364


	endif;
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
</Class>
