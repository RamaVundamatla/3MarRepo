    <JadeMethod name="cmbDriverCode_displayEntry" id="c3aa6983-4fce-4bcd-9b85-4e8457af5feb">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDriverCode_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/

vars
	driver : CM_DriverDetails;
	
begin
	driver := obj.CM_DriverDetails;
	if driver = null then
		return null;
	endif;
	
	if driver.myTerminal &lt;&gt; self.myTerminal then
		return null;
	endif;
	
	return driver.code;

epilog

end;</source>
