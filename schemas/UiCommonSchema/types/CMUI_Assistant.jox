    <JadeMethod name="displayEntryEventTypes" id="55be734c-80d1-4c93-a1cf-5072dd3b32f6">
        <source>displayEntryEventTypes(_eventType : CM_EventType; _selected : Boolean) : String;
/*
----------   ----------  --------------------------------------------------
Created:	23 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user		: CM_User;
	term		: CM_Terminal;
begin

	if _eventType = null then
		return null;
	endif;

	
	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _eventType.name;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; _eventType.name;
	endif;
	
end;


</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
