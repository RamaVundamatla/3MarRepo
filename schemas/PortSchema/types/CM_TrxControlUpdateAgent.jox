	yaCritieria : CM_YACriteria;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);
	
	app.setContinueCMExceptions(false);
	sortValue	:=	0;
	
	
	

	// Now calculate the Yard Allocation priority values on the proxy objects, keeping the original order
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		if app.myPassport.hasErrors then
			break;	// TFS 7659
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	if app.myPassport.hasErrors then
		return;		// TFS 7659
	endif;
	
	beginTransaction;	
	if _realAlloc &lt;&gt; null  then  //19/06/2017 cnwma1 TFS #4498
