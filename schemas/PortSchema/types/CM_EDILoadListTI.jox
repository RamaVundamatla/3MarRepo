    <JadeMethod name="setTranshipVoyageCode" id="da1847be-2366-44d0-9de9-605eaf3bea4d">
        <updating/>
        <source>setTranshipVoyageCode(_transhipVoyageCode : String) updating;

//23/06/2015 cnwma1 PAR #36044 EDI Load List - Tranship voyage code missing
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
	ediData			:CM_EDIData;
begin
	 //self.setVoyageCode(_transhipVoyageCode);  // 23/06/2015 cnwma1 PAR #36044
	
	// 23/06/2015 cnwma1 PAR #36044
	config := self.myEDIConfig;              
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.transhipVoyageCode;

	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey(codeUpper, self) then
			coll.removeKeyEntry(codeUpper, self, self);
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code := _transhipVoyageCode[1 : self.transhipVoyageCode.maxLength];
	self.transhipVoyageCode	:= _transhipVoyageCode;     
	
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey(codeUpper, self) then
			coll.putAtKey(codeUpper, self, self);
		endif;
	endif;
	// 23/06/2015 cnwma1 PAR #36044
end;</source>
        <Parameter name="_transhipVoyageCode" type="String"/>
    </JadeMethod>
