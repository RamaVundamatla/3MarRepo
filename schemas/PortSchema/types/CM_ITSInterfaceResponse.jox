        <length>17</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="messageVersion" id="b47ff833-de61-4564-b4a1-018e6156777f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRTQueueEntry" id="71a91399-b1c9-4bdd-ab17-a26b6d62605a">
        <transientToPersistentAllowed/>
