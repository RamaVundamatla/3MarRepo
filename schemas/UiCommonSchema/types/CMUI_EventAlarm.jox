    <JadeMethod name="setupForm" id="8c0496f2-4d22-46b7-9c02-88e45b0d247e">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	bubbleHelpStr			: String;
begin
	inheritMethod();
	
	bubbleHelpStr := app.getErrorString(Event_alarm_bubblehelp);
	self.bubbleHelp := bubbleHelpStr;
	self.frmEventInfoOff.bubbleHelp := bubbleHelpStr;
	self.frmEventInfoOn.bubbleHelp := bubbleHelpStr;
	
	self.setupMinimised();
	
	self.frmEventInfoOn.visible := true;
	self.frmEventInfoOff.visible := false;
	
	self.beginTimer(500, Timer_Continuous, 1);

end;


</source>
    </JadeMethod>
    <JadeMethod name="setupMinimised" id="905cc031-d6c2-438e-aca4-e061edf4c725">
        <updating/>
        <source>setupMinimised() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	defaultLeft,
	defaultTop	: Real;
	str			: String;
	userWindow	: CM_UserWindow;
	mainForm	: Form;
begin
	mainForm := app.mainForm;
	defaultTop 	:= 0;
	defaultLeft := mainForm.width - (self.width + 10);
	
	self.controlBox 	:= false;
	self.clipControls 	:= false;
	self.borderStyle 	:= self.BorderStyle_Single;
	self.frmPic.parentBottomOffset:=0;
	self.frmPic.parentRightOffset:=0;
	self.frmPic.top 	:= 0;
	self.frmPic.left	:= 0;
	self.frmPic.visible:=true;
	self.frmPic.setFocus;
	
	self.width 			:= self.frmPic.width;
	self.height 		:= self.frmPic.height;
	
	
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;

	if userWindow = null then
		self.top := defaultTop;
		self.left := defaultLeft;
		return;
	endif;
	
	str := userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SAVETOP);
	if str = null then
		self.top := defaultTop;
	else
		self.top := str.Integer;
	endif;
	
	str := userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SAVETOP);
	if str.Integer &lt; 1 or str.Integer &gt; mainForm.height then
		self.top := defaultTop;
	else
		self.top := str.Integer;
	endif;
	
	str := userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SAVELEFT);
	if str.Integer &lt; 1 or str.Integer &gt; mainForm.width then
		self.left := defaultLeft;
	else
		self.left := str.Integer;
	endif;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showEvents" id="3d51eea0-0a45-482c-8fcd-dafbcaa8d37b">
        <updating/>
