    <JadeMethod name="doShowPrinterSetup" id="7491a469-1b2c-4355-84fa-6817848001fb">
        <source>doShowPrinterSetup();
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	thePrintCMD		: CMDPrint;
	
begin
	create thePrintCMD transient;
	
	thePrintCMD.printSetup	:=	true;
	thePrintCMD.open();
epilog
	delete thePrintCMD;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="982688ce-a33b-49fc-9f5e-f387cd6bd75f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	rulRuler.move(1, 1, self.width, rulRuler.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuFileExit_click" id="99b07530-5953-410c-8448-938a8b3da6c2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileExit_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFilePrintSetup_click" id="74df4910-fee2-4dc0-b575-7ef0d6c28387">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFilePrintSetup_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doShowPrinterSetup();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuLicEdit_click" id="ceea321c-dbb4-4ce3-b247-99aa385abfe0">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuLicEdit_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	productCode	: String;
	
begin
	productCode	:=	app.myLicense.editLicenseKey(null, null);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuLicFullVersion_click" id="182fd0ce-4168-4788-a04c-6d3b44328445">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuLicFullVersion_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	write app.myLicense.getVersionFull();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuLicMaintain_click" id="611486f6-cba7-45f4-b8d3-e8363b63bfd8">
