    <JadeMethod name="getValidCurrentStatuses" id="c829b5ae-0dcd-47ac-811c-075f1866213d">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	pelindo1VoyProcess : CM_VoyageProcess;
	includeLessThanPriorityValue : Integer;
	voyageStatus : CM_VoyageStatus;

begin

	//Any with Priority less than the Priority of Voyage_Status_IVoyageArrived 

	voyageStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IVoyageArrived );
	if voyageStatus &lt;&gt; null then
		pelindo1VoyProcess := voyageStatus.myProcess;
	
		includeLessThanPriorityValue := voyageStatus.priority;
	
		foreach voyageStatus in pelindo1VoyProcess.allStatuses do
			if voyageStatus.priority &gt;= includeLessThanPriorityValue then
				break;
			endif;
			_validStatuses.add( voyageStatus.id );
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="9e0f231a-3bbc-4db9-a02c-891c96a21ccb">
        <source>processMessage( voyage : CM_Voyage io );
/*

Purpose:			

Parameters:	
"	This is the INAPORTNET Web Service equivalent functionality to completely cancelling a pending Voyage.
"	Voyage must be able to be identified by PKK number.

		

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars



begin

	self.doUpdateVoyageStatus(voyage);
epilog



end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="083fd7bb-b212-4d32-a312-ba1a51229e75">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation		TFS 38135

*/

vars

	term : CM_Terminal;
	arrivalStatus,
	voyageStatus : CM_VoyageStatus;

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	term := app.myPassport.myTerminal;
	
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
	if _voyage = null then
		app.raiseCMException3(Value_field_not_resolve, self.nomorPkk, WS_EntryIjinGerakRequest::nomorPkk.name, app.getErrorString(Voyage), null, null);
		return false;
	endif;
	if _voyage &lt;&gt; null then
		voyageStatus := _voyage.getVoyageStatusObject;
		if voyageStatus &lt;&gt; null then
			arrivalStatus:= voyageStatus.myProcess.allStatusesById[Voyage_Status_IVoyageArrived];
		endif;
		if voyageStatus = null and arrivalStatus &lt;&gt; null and voyageStatus.priority &gt;= arrivalStatus.priority then
			app.raiseCMException2( Voyage_incorr_status_this_acti, _voyage.code, voyageStatus.description, null, null );
		endif;
	endif;

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="cb6e2307-df1d-497b-bd21-f2710f9641aa">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. self.nomorPkk -Number PKK, Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPembatalanPKKRequest::nomorPkk.name, null, null);
	endif;
	
	//4. self.portCode - Checked in superClass ::validareCredentials

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
