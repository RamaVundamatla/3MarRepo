    <JadeMethod name="comboBoxRORODeckItems" id="6aaf0594-d0ad-49d0-9817-aecdb9a74f3d">
        <source>comboBoxRORODeckItems(	_cmb : CMUI_ComboBox input;
						_deck : CM_Deck;
						_selectedDeckItem : CM_DeckItem);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deckItem : CM_DeckItem;
	idx : Integer; 
begin
	_cmb.clear;
	_cmb.sorted:=false;
	
	foreach deckItem in _deck.allDeckItems discreteLock where (deckItem.isRamp() or deckItem.isMachinery() or deckItem.isGeneralItem())  do
		idx:=_cmb.addItemObject(deckItem.code,deckItem);
	endforeach;
	
	if _selectedDeckItem &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_selectedDeckItem);
	endif;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_selectedDeckItem" type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRORODecks" id="8febf5e8-12b7-4645-81ef-72d2b38cda6b">
        <source>comboBoxRORODecks(	_cmb : CMUI_ComboBox input;
							_roroStructure : CM_Object;
							_selectedDeck : CM_Deck);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars
	subDeck,
	deck : CM_Deck;
	idx  : Integer;
	iter, subDeckIter  : Iterator;
begin
	_cmb.clear;
	_cmb.sorted:=false;

	if _roroStructure.isKindOf(CM_ROROVesselStructure) then
		iter:=_roroStructure.CM_ROROVesselStructure.allDecks.createIterator;
	elseif _roroStructure.isKindOf(CM_ROROVoyageStructure) then
		iter:=_roroStructure.CM_ROROVoyageStructure.allDecks.createIterator;
	endif;
	
	while iter.next(deck) do
	
		
		idx:=_cmb.addItemObject(deck.code,deck);
		_cmb.itemLevel[_cmb.newIndex]:=1;
		_cmb.itemExpanded[_cmb.newIndex]:=true;
		
		delete subDeckIter;
		subDeckIter:=deck.getSubDeckCollection.createIterator;
		while subDeckIter.next(subDeck) do

			idx:=_cmb.addItemObject(subDeck.code,subDeck);
			_cmb.itemLevel[_cmb.newIndex]:=2;
			_cmb.itemExpanded[_cmb.newIndex]:=true;
		endwhile;
		
	endwhile;
	
	if _selectedDeck &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_selectedDeck);
	endif;
epilog
	delete iter;
	delete subDeckIter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_roroStructure" type="CM_Object"/>
        <Parameter name="_selectedDeck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="comboBoxROROVessel" id="5ebb9eff-63d0-4cb9-ad48-d49261ebfab4">
        <source>comboBoxROROVessel(_cmb : CMUI_ComboBox input; 
					_selectedROROVesselStruct : CM_ROROVesselStructure);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	tmpTerm : CM_Terminal;
	tmpUser	: CM_User;
	tmpUserT	: CM_UserTerminal;
	showVesselByName : Boolean;
	roroVesselStructure : CM_VesselStructure;
	iter 		: Iterator;
	vessel		: CM_Vessel;
begin
	_cmb.clear;
	

	// hacky way of getting the terminal because the config is set per terminal 
	tmpTerm := app.getMyTerminalDO_NOT_USE();
	if tmpTerm = null then
		tmpUser := app.getMyUser();
		if tmpUser &lt;&gt; null then
			tmpUserT := tmpUser.allUserTerminals.first;
			if tmpUserT &lt;&gt; null then
				tmpTerm := tmpUserT.getRealTerminal;
			endif;
		endif;
	endif;
	
	if tmpTerm &lt;&gt; null then
		showVesselByName:= tmpTerm.getConfig(VesselComboByName).Boolean;
	endif;
	
	iter:=app.myRoot.allVesselROROStructures.createIterator;
	while iter.next(roroVesselStructure) do
		if not roroVesselStructure.isKindOf(CM_ROROVesselStructure) then
			continue;
		endif;
		vessel:=roroVesselStructure.myVessel;
		
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,roroVesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",roroVesselStructure); 
		endif;
	endwhile;
	
	
	if _selectedROROVesselStruct &lt;&gt; null then
		_cmb.listIndex:=_cmb.findObject(_selectedROROVesselStruct);
	endif;


epilog
	delete iter;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_selectedROROVesselStruct" type="CM_ROROVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="comboBoxROROVesselExtRamps" id="d300c812-6efc-40fe-88e1-bbb74ecbc6bd">
