    <JadeMethod name="validateRange" id="76e6eff1-1385-418a-8bfd-148e270058de">
        <source>validateRange(pFrom:Any; pTo:Any):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Valiadte the range of the receiver's values.
//
// Parameters:	pFrom - The lower end of the range.
//				pTo - The upper end of the range.
//
// Returns:		True if the range is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pFrom.cnEcIsGreaterThan(pTo) then
		CnEcBaseSchemaException.raise_(CNEC_X_83000, "Invalid range: [" &amp; pFrom.String &amp; "] is greater than [" &amp; pTo.String &amp; "].");
		return false;
	else
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFrom" type="Any"/>
        <Parameter name="pTo" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
