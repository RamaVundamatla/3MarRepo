    <JadeMethod name="setProxyCargoId" id="822e1920-ca21-4ea7-bf51-b77468611f34">
        <updating/>
        <source>setProxyCargoId(_cargoId : String)updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.cargoId := _cargoId;
end;</source>
