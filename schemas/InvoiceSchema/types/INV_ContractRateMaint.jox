    <JadeMethod name="btnRemoveRate_click" id="2c6a041b-6aa4-405f-b83b-c85ff990ed06">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemoveRate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars
	service: CM_Service;
	rate :CM_InvoiceContractRate;
begin
	service := self.cmbService.listObject.CM_Service;
	rate := self.myContractDetails.allInvContractRatesByService[service];
	self.doRemoveRate(rate);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
