    <JadeMethod name="testOverstowLCAvailability" id="952d24c5-3e5a-44f9-9b0e-d75a200afd9a">
        <source>testOverstowLCAvailability(pLCToTest : CM_GridController) : Integer;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	accessHeight, heightAllowed,accessLocn	: Integer;
	//lcToTest								: CM_GridController;
//	gridRow									: CM_GridRow;
begin

	return pLCToTest.testOverstowLCAvailability();
	
	
/*	
	// if I have a height restriction, either none at all or a ' nothing from...' setting then use that to calculate the height. 
	// If the pad is generally available then go along the row to find the average height
	accessHeight := 0;
	if pLCToTest.availability = PAD_UNAVAILABLE then 
		heightAllowed := 0;
		accessHeight := heightAllowed;
	elseif pLCToTest.availability &lt;&gt; PAD_AVAILABLE and pLCToTest.availability &lt;&gt;  PAD_USER_UNAVAILABLE then
		heightAllowed := pLCToTest.availability - PAD_USER_UNAVAILABLE - 1;
		accessHeight := heightAllowed;
	else			
		accessHeight := self.heightOfStack;
	endif;
	return accessHeight;
	*/		
end;</source>
        <Parameter name="pLCToTest" type="CM_GridController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="6494a41f-e6f2-4c3c-8782-6c8f57a7b514">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MAX_BLOCK_HEIGHT : Integer = 8; // PAR 16315 this was 9999! which is crazy 
vars

begin
	inheritMethod();
	
	if self.numberOfRows &lt; 1 or self.numberOfRows &gt; 1000 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Rows", "Please enter a value between 1 and 1000", null, null);
	endif;
	if self.numberOfColumns &lt; 1 or self.numberOfColumns &gt; 1000 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Columns", "Please enter a value between 1 and 1000", null, null);
	endif;
	if self.heightOfStack &lt; 1 or self.heightOfStack &gt; MAX_BLOCK_HEIGHT then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Height", "Please enter a value between 1 and " &amp; MAX_BLOCK_HEIGHT.String, null, null);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateControllersRestriction" id="e0e79ecf-bb63-45bc-9fdb-d6ad8d5cef73">
        <source>validateControllersRestriction(pLCArray : CM_LCArray);
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController		: CM_LocationsController;
begin

	foreach lController in pLCArray do
		if not lController.testIsControllerAvailSubBlock(true, true, false)  then
			break;
		endif;
      endforeach;
end;</source>
        <Parameter name="pLCArray" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="validateConvertToSubBlock" id="0a016f76-b5bb-4668-a2f1-261c3bcfc290">
        <source>validateConvertToSubBlock(pLCArray : CM_LCArray);
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController		: CM_LocationsController;

begin

	if not self.testAreWeTogether(pLCArray) then // AKB2001DEC
		app.raiseCMException1(ERR_CONTROLLERS_NOT_CONTIGUOUS, " Converting " &amp; self.myTerminal.code &amp; " "  &amp; self.id &amp; " To A Sub Block Stack.", null, null);
	endif;
	
	foreach lController in pLCArray do
		if not lController.CM_GridController.testIsControllerAvailSubBlock(false, false, true) then
			break;
		endif;
	endforeach;

epilog
end;</source>
        <Parameter name="pLCArray" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="93a21bfc-32bb-45d1-af43-2b5ebd1424d1">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2008	cnwjk3	CCMS 1032

*/

vars

begin
	self.validateTwinLiftStates();
	
	//epr par 21526 3/11/09
	self.validateRowColumnLabels();
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="4180cb47-07e7-4a48-8d6e-ef85d7f41e03">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//Prevents orphaned sub block stacks
	if self.allSubBlockStacks.isNotEmpty then
		app.raiseCMException2(CannotDeleteSubBlock, self.id , self.allSubBlockStacks.first.id, null, null);
	endif;
	
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7d66dd71-2e58-4764-9727-ddf2142d0edb">
        <source>validateForUpdate(pRealGridArea : CM_GridArea);
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyGridCntrl,
	realGridCntrl	: CM_GridController;
	giveError		: Boolean;
	deckingOptions	: CM_YADeckingOptions;
	gridRow			: CM_GridRow;
	gridColumn		: CM_GridColumn;
	firstPathFound : CM_ReeferBlock;	//08 Apr 2021	NDL	TFS 51042
	realGridRow : CM_GridRow;	//08 Apr 2021	NDL	TFS 51042
	realGridColumn : CM_GridColumn;	//08 Apr 2021	NDL	TFS 51042
begin

	self.checkHeightAlterationOnTA();
	
	//epr par 21526 3/11/09
	self.validateRowColumnLabels();
	
	// go through the real areas controllers and check that nothing is on a pad that is being changed.
	// We are checking pad by pad, If it is changing has it got anything on it?
	giveError := false;

	foreach realGridCntrl in pRealGridArea.allGridControllersByRowColumn do
		if realGridCntrl.hasTIs() then
			app.raiseCMException2(ERR_INVALID_VALUE, "Area " &amp; realGridCntrl.getID, "This area has TIs, cannot change.", null, null);
			giveError := false;
		endif;
	endforeach;

	deckingOptions := pRealGridArea.myYADeckingOptions;
	
	if deckingOptions &lt;&gt; null then
		if (deckingOptions.inOptionType = DeckingRule_Custom or deckingOptions.outOptionType = DeckingRule_Custom) then
			app.raiseCMWarning(WARN_DELETING_DECKING, 'myYADeckingOptions', null, pRealGridArea);
		endif;
	endif;
	
	if self.allYardAllocations.isNotEmpty then
		app.raiseCMWarning(WARN_YA_LOCATIONS, 'myYADeckingOptions', null, pRealGridArea);
	endif;	
	
	//08 Apr 2021	NDL	TFS 51042
	foreach realGridRow in pRealGridArea.allGridRows do
		if realGridRow.pxyGetProxyObject = null then
			if realGridRow.hasReeferWalkPaths(firstPathFound) then
				app.raiseCMException2(Colum_not_remov_still_decla_re, realGridRow.getLabel, firstPathFound.name, null, null);
			endif;
		endif;
	endforeach;
	foreach realGridColumn in pRealGridArea.allGridColumns do
		if realGridColumn.pxyGetProxyObject = null then
			if realGridColumn.hasReeferWalkPaths(firstPathFound) then
				app.raiseCMException2(Colum_not_remov_still_decla_re, realGridColumn.getLabel, firstPathFound.name, null, null);
			endif;
		endif;
	endforeach;
	
	inheritMethod(pRealGridArea);

end;</source>
        <Parameter name="pRealGridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateInUse" id="da65864f-a7e5-415a-934e-620ce59242fb">
        <source>validateForUpdateInUse(pRealGridArea : CM_GridArea);
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
//
//	When		Who		Why
//	15/10/2009	cnwdap1	PAR #21350 Display warning if rows increase as well as columns
//20 September 2017 jlgns1 TFS 6956 QNS - RT Queue error
// ---------------------------------------------------------------------------
vars
	
	realController,
	controller			: CM_LocationsController;
	expectedEdition		: Integer;
	realGridRow			: CM_GridRow;
	realGridColumn,pxyGridColumn		: CM_GridColumn;
	pxySize,size				: Integer;
	msg					: Integer;
	firstPathFound : CM_ReeferBlock;	//08 Apr 2021	NDL	TFS 51042
	
begin

	//epr par 21526 3/11/09
	self.validateRowColumnLabels();
	
	self.checkHeightAlterationOnTA();
	foreach controller in self.allGridControllersByRowColumn do
		controller.pxyGetRealObjectAndEdition(realController, expectedEdition);
		controller.validateForUpdate(realController, app.myPassport);
	endforeach;

	// cnwjk3 CCMS 1032 15/12/2008
	// Check for invalid twin lift states
	self.validateTwinLiftStates();	

	
	// we are the proxy grid area. we will have had any rows already removed from us.
	// so compare to real area and validate the ones being removed
	foreach realGridRow in pRealGridArea.allGridRows do
		//epr par 33070 11/12/13 if there is no proxy will get deleted check that rather than rows by name 
		// if user deleted row and re-added it back with same name wouldn't do the validate for delete when it needed to 
		if realGridRow.pxyGetProxyObject = null then
		//	realGridRow.validateForDelete();
			//08 Apr 2021	NDL	TFS 51042
			if realGridRow.hasReeferWalkPaths(firstPathFound) then
				app.raiseCMException2(Colum_not_remov_still_decla_re, realGridRow.getLabel, firstPathFound.name, null, null);
			endif;
			
		elseif self.allGridRows[realGridRow.row] = null then
			realGridRow.validateForDelete();
		endif;
	endforeach;

	// we are the proxy grid area. we will have had any columns already removed from us.
	// so compare to real area and validate the ones being removed
	foreach realGridColumn in pRealGridArea.allGridColumns do
		//epr par 33070 11/12/13
		if realGridColumn.pxyGetProxyObject = null then
		//	realGridColumn.validateForDelete();
			//08 Apr 2021	NDL	TFS 51042
			if realGridColumn.hasReeferWalkPaths(firstPathFound) then
				app.raiseCMException2(Colum_not_remov_still_decla_re, realGridColumn.getLabel, firstPathFound.name, null, null);
			endif;
			
//		if self.allGridColumns[realGridColumn.column] = null then
		elseif self.allGridColumnsByLabel[realGridColumn.label] = null then
			realGridColumn.validateForDelete();
		endif;
	endforeach;
	
	// PAR #21350 set message for columns or rows as appropriate
	if self.allGridColumns.size &gt; pRealGridArea.allGridColumns.size then
		msg := Have_inser_colum_exist_yard_al;
	elseif self.allGridRows.size &gt; pRealGridArea.allGridRows.size then
		msg := Have_inser_rows_exist_yard_all;
	endif;
	
	if msg &gt; 0 then
		if not pRealGridArea.allYardAllocations.isEmpty
		or not pRealGridArea.allRestrictionsLocation.isEmpty
		or not pRealGridArea.allSubAreas.isEmpty
		or not pRealGridArea.allRestrictionsLabour.isEmpty then
//			app.raiseCMWarning1(Full_Replacement_Message,"You have inserted new column(s). " &amp; pRealGridArea.id &amp; 
//					" has existing Yard Allocations, Sub Areas or Restrictions setup that may need the new column added to. THIS MUST BE DONE MANUALLY", null,null, self);		
			app.raiseCMWarning1(msg, pRealGridArea.id, null,null, self);		
		endif;
	endif;
	
	if not self.checkReduceSize(pRealGridArea) then											//TFS 6956
		app.raiseCMException1(Cant_reduce_size_becaus_cargo ,pRealGridArea.id,null,null);	//TFS 6956
	endif;																					//TFS 6956
	
	inheritMethod(pRealGridArea);


end;</source>
        <Parameter name="pRealGridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="validateRowColumnLabels" id="3614c8f2-2753-44f4-a8ff-df4201ee995b">
        <source>validateRowColumnLabels();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2009	cnwer1	Initial creation

*/

vars
	gridRow			: CM_GridRow;
	gridColumn		: CM_GridColumn;
begin
	foreach gridRow in self.allGridRows do
		gridRow.validateForUpdate();
	endforeach;
	
	foreach gridColumn in self.allGridColumns do
		gridColumn.validateForUpdate();
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTwinLiftStates" id="bc9009ec-540b-49dd-9a28-5527b3ad7ff6">
        <source>validateTwinLiftStates();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2008	cnwjk3	CCMS 1032

*/

vars
	pxyController, 
	pxyPrevController 	: CM_GridController;
	pxyGridRow			: CM_GridRow;	
	column 				: Integer;
begin
	foreach pxyGridRow in self.allGridRows do
		pxyPrevController := null;
		column := 1;
		foreach pxyController in pxyGridRow.allControllersByColumn do
			if pxyPrevController &lt;&gt; null then
				if pxyPrevController.canTwinLiftWithNextController then
					if not pxyController.canTwinLiftWithPrevController then
						// Previous contoller has no adjacent twin lift controller to the right
						app.raiseCMWarning1(TwinLiftNoRightDefined , pxyPrevController.getFullId(), null,null, self);		
					endif;
				endif;
				if pxyController.canTwinLiftWithPrevController then
					if not pxyPrevController.canTwinLiftWithNextController then
						// Current contoller has no adjacent twin lift controller to the left
						app.raiseCMWarning1(TwinLiftNoLeftDefined , pxyPrevController.getFullId(), null,null, self);		
					endif;					
				endif;
			endif;
			column := column + 1;
			pxyPrevController := pxyController;
		endforeach;
		// Check last controller in the row		
		if pxyPrevController &lt;&gt; null then
			if pxyPrevController.canTwinLiftWithNextController then
				if not pxyController.canTwinLiftWithPrevController then
					// Previous contoller has no adjacent twin lift controller to the right
					app.raiseCMWarning1(TwinLiftNoRightDefined , pxyPrevController.getFullId(), null,null, self);		
				endif;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocks" id="8376c54c-154c-414a-80c3-2f1dda45e52d">
        <source>// PAR 19106

yaBuildBlocks(	pYardAllocationObj:CM_YardAllocation;
				pAllControllersObj: CM_LCArray;
				pAllBlocksInObj: CM_YABlockArray input;
				pAllBlocksOutObj:CM_YABlockArray input):Boolean;
// ---------------------------------------------------------------------------
// Created:     19 April 2005 by cnwrs2
//
// Purpose:     Refer to superclass implementation.
// ---------------------------------------------------------------------------

vars
	blockObj			: CM_YABlock;
	gridRowObj			: CM_GridRow;
	controllerObj		: CM_LocationsController;
	gridControllerObj	: CM_GridController;
	controllerSetObj	: CM_LCArray;
	deleteBlockSet		: CM_YABlockSet;
	doDelete			: Boolean;
	
begin
	// *** Do not inherit any behaviour ***
	//inheritMethod(pAllControllersObj, pAllBlocksObj);
	
	// Need to split by row.
	
	create controllerSetObj transient;
	create deleteBlockSet transient;
	
	foreach blockObj in pAllBlocksInObj where blockObj.myTerminalArea = self do
		deleteBlockSet.add(blockObj);
	endforeach;
	
	blockObj := null;
	foreach controllerObj in pAllControllersObj do
	
		if pYardAllocationObj = null or pYardAllocationObj.getBlockMode() = CM_YardAllocation.ROW_MODE then
			doDelete := true;
		endif;
		
		if (not CM_GridController.hasInstance(controllerObj)) then
			// This should not ever happen!!
			continue;
		endif;
		
		gridControllerObj	:=	controllerObj.CM_GridController;
		gridRowObj			:=	gridControllerObj.myGridRow;
		
		// Find a YA Block for the Grid Row in pAllBlocksObj.
		// Note that whilst we only look up a YA Block from the "In" collection, we will
		// add any new blocks to both the "In" and "Out" collections. This is because
		// both the "In" and the "Out" collections contain the same objects, the only
		// difference is that they may be in a different order.
		
		if pYardAllocationObj = null or pYardAllocationObj.getBlockMode() = CM_YardAllocation.ROW_MODE then
			blockObj	:=	pAllBlocksInObj.getGridRowBlock(gridRowObj);
		endif;
		
		if blockObj &lt;&gt; null and deleteBlockSet.includes(blockObj) then
			// Need to clear out controllers for first time.
			blockObj.allYardControllers.clear();
			deleteBlockSet.remove(blockObj);
		endif;
		
		controllerSetObj.add(controllerObj);
		
		// If a YA Block wasn't found for the Grid Row, one will be created here.
		
		self.yaAddControllersToBlock(pYardAllocationObj, controllerSetObj, blockObj, pAllBlocksInObj, pAllBlocksOutObj);
		controllerSetObj.clear();
	endforeach;
	
	if doDelete then

		foreach blockObj in deleteBlockSet do
			if pAllBlocksInObj.includes(blockObj) then
				pAllBlocksInObj.remove(blockObj);
				pAllBlocksOutObj.remove(blockObj);
			endif;
		endforeach;
		deleteBlockSet.purge();
	endif;
	
	return true;
epilog
	delete controllerSetObj;
	delete deleteBlockSet;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaFindLCs" id="c89b5585-0b85-40b9-bce6-baa4ab181ba7">
        <source>yaFindLCs(pFromId:String; pToId:String; pAllControllersObj:CM_LCArray input);
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	gridRowObj		: CM_GridRow;
	iteratorObj		: Iterator;
	locationId		: String;
	
begin

	if self.allGridControllersByName[pFromId] &lt;&gt; null then
		iteratorObj	:=	self.allGridControllersByName.createIterator();
		self.allGridControllersByName.startKeyGeq(pFromId, iteratorObj);
		self.yaIterateControllerRange(iteratorObj, pFromId, pToId, pAllControllersObj);
		
	elseif self.allGridRowsByLabel[pFromId] &lt;&gt; null then
		iteratorObj	:=	self.allGridRowsByLabel.createIterator();
		self.allGridRowsByLabel.startKeyGeq(pFromId, iteratorObj);
		
		while iteratorObj.next(gridRowObj) do
			locationId	:=	gridRowObj.label;
			
			if locationId = pFromId then
				foreach controllerObj in gridRowObj.allControllersByColumn do
					if controllerObj.yaHasSubBlockStack() then
						continue;
					endif;
					
					pAllControllersObj.add(controllerObj);
				endforeach;
			else
				if pToId &lt;&gt; null then
					if locationId &gt; pToId then
						break;		// We've gone past the end of the range.
					endif;
					
					foreach controllerObj in gridRowObj.allControllersByColumn do
						if controllerObj.yaHasSubBlockStack() then
							continue;
						endif;
						
						pAllControllersObj.add(controllerObj);
					endforeach;
				endif;
			endif;
		endwhile;
	endif;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaGetBlockType" id="cf3ad462-3018-4d38-95e6-432f03c2595a">
        <source>yaGetBlockType(): Class;
// --------------------------------------------------------------------------------
// Created:		15 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return CM_YABlockGridArea;
end;</source>
        <ReturnType type="Class"/>
