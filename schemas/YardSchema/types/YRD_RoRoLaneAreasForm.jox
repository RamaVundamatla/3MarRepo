    <JadeMethod name="setDisplayMode" id="04e6d4e8-6a30-42cb-98bb-26490841add4">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	newMode,
	theIndex : Integer;
	cdc : YRD_RoRoLaneDrawingController;
	anObj : Object;
begin
	
	if _mode = DISPLAY_MODE_ACTUAL then
	elseif _mode = DISPLAY_MODE_PLAN then
	elseif _mode = DISPLAY_MODE_QUEUE then
	else
		return;
	endif;

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_RoRoLaneDrawingController;
		cdc.setDisplayMode(_mode);
		cdc.drawSelf(true);
	endforeach;

	self.frmStatusLine.displayMode := _mode;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setInitialiseWithObject" id="cdc10450-a284-4319-8317-e5dd181a20d4">
