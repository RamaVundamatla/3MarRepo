    <JadeMethod name="valAssignWleToWagonController" id="32ba6587-f57a-45bd-aa9c-a1712c2acd87">
        <source>valAssignWleToWagonController(_wle : CM_YardWLE input; _otherLoc : CM_LocationsController input; _posInStack : Integer; _controller : CM_WagonController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwndl1	Initial creation

*/

vars
	tiActual, tiQueue : CM_TrackedItem;
	isoTypeCode : String;
	isoType : CM_ISOType;
	isoTypeGroupCode : String;
	isoTypeGroup : CM_ISOTypeGroup;
begin
	
	self.raiseExceptionIfNull(_wle, app.getErrorString(Release_request));
	self.raiseExceptionIfNull(_controller, app.getErrorString(Null_location_control_passed));
	
	if _wle.isRailBreakBulk then	//11 July 2014	NDL	Par 34552
		// do nothing here.
	else
		isoTypeCode := _wle.myRequest.CM_DeliveryRequest.isoType;
		isoTypeGroupCode := _wle.myRequest.CM_DeliveryRequest.isoGroup;	//10 May 2010	NDL Par 24064
		if isoTypeCode &lt;&gt; null then
			isoType	:=	app.myRoot.allISOTypes[isoTypeCode];
		elseif isoTypeGroupCode &lt;&gt; null then	//10 May 2010	NDL Par 24064
			isoTypeGroup	:=	app.myRoot.allISOTypeGroups[isoTypeGroupCode];
		endif;
	
	endif;
	
	//Par 22343	NDL	Par 22343
	if not _controller.isReallyAvailable( null, _otherLoc, _posInStack, isoType, isoTypeGroup) then//10 May 2010	NDL Par 24064
		app.raiseCMException2(ERR_NO_SPACE, _wle.id, _controller.myWagon.id, null, null);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_posInStack" type="Integer"/>
        <Parameter name="_controller" type="CM_WagonController"/>
    </JadeMethod>
