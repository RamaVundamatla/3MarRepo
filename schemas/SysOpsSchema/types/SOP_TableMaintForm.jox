    <JadeMethod name="initShtSingleSelect1" id="ffb1f7ac-9ce0-4bd5-9ed6-b9413dc802cf">
        <source>initShtSingleSelect1();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2009	cnwer1	Initial creation

*/

constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;
vars

begin
	if (self.shtSingleSelect1.visible = true) then
		lstSingleSelect1.top:=self.frmTBSingle.top + self.frmTBSingle.height;
		lstSingleSelect1.left	:= LeftMargin;	
		lstSingleSelect1.width 	:= lstSingleSelect1.parent.width-(LeftMargin*2);
		lstSingleSelect1.height 	:= lstSingleSelect1.parent.height - lstSingleSelect1.top - TopMargin;
        lstSingleSelect1.cnEcResizeContents();	
	endif;

epilog

end;</source>
    </JadeMethod>
