    <JadeMethod name="getVesselName" id="15269745-2ae2-44ed-8c8c-fba69155cdf1">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTi: CM_EDITrackedItem;
	voyageEventTI : CM_EDIVoyageEventTI;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
begin
	foreach ediTi in self.allEDITrackedItems do
		voyageEventTI := ediTi.CM_EDIVoyageEventTI;
		terminal := voyageEventTI.getMyTerminal;
		if terminal &lt;&gt; null then
			voyage := terminal.lookupVoyage(voyageEventTI.voyageCode, null, false);
			if voyage &lt;&gt; null then
				return voyage.vesselName;
			endif;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
