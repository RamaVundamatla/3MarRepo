    <JadeMethod name="getMenuUserDtl" id="fb5f8e0e-85ca-487d-8c66-d2fea3aaa13f">
        <source>getMenuUserDtl(_userTerminal :CM_UserTerminal):CM_MenuUserItem;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	userDtl		: CM_MenuUserItem;
	menuRoot	: CM_MenuRoot;
begin
	if _userTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User terminal object was null');
		return null;
	endif;
	
	foreach	userDtl in self.allMenuUserItems do
		menuRoot := userDtl.getMyMenuRoot();
		if menuRoot = null then
			continue;
		endif;
		
		if menuRoot.isKindOf(CM_MenuRootReportUserTerminal) then
			if menuRoot.CM_MenuRootReportUserTerminal.myUserTerminal = _userTerminal then
				return userDtl;
			endif;
		endif;
		
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_userTerminal" type="CM_UserTerminal"/>
        <ReturnType type="CM_MenuUserItem"/>
    </JadeMethod>
    <JadeMethod name="getNameForLockKeeper" id="75aec05e-11d7-49a8-a640-8081ecb3d80a">
        <source>getNameForLockKeeper(_nameIdx : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.isFormBasedReport then
		return 'STATIC Report ' &amp; self.formClassName;
	else
		if _nameIdx &lt; 1 then
			return 'Filtering ' &amp; self.filterClassName;
		elseif _nameIdx &gt; self.jrwReportName.size then
			return '&lt;unknown&gt;';
		else
			return 'JRW Report ' &amp; self.jrwReportName[_nameIdx];
		endif;
	endif;

end;</source>
        <Parameter name="_nameIdx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
