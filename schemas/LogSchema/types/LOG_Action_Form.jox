    <JadeMethod name="setupForm" id="62392e9c-6f3c-471b-b216-0574cfb83d57">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int : Integer;
begin

	inheritMethod();
	
	self.logCargoType	:= app.myRoot.allCargoTypesById[TI_CargoType_Log];
	self.logDocketCargoType	:= app.myRoot.allBOLTypes[BOLType_Log];
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.terminologyForOperatorLog := app.getTerminologyAlternate(self.logCargoType, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	self.terminologyForOperatorDocket := app.getTerminologyAlternate(self.logDocketCargoType, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	self.optSpecs.caption := self.terminologyForOperatorLog &amp; '/Specs';
// cnwdad1 24/07/2006 - As part of PAR #11909, but not directly related.
	self.cmbLocation.automaticCellControl	:=	true;
	
	int := getTextExtent(self.optSpecs.caption);
	
	if int &gt; 97 then // width of option button on form painter (dont want any smaller)
		self.optSpecs.width := int + 20; // plus 20 for good luck as value returned seems to always be a tad short
	endif; 
	
	self.initTables();
	self.doRefresh(); // 27/02/09 cnwdz2 par 18116
end;</source>
    </JadeMethod>
