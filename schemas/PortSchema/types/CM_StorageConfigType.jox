    <JadeMethod name="getNumWorkAndCompChargeDays" id="6de4810d-6b2d-4920-9b2a-fd1ec408cd77">
        <source>getNumWorkAndCompChargeDays(	_workCal : CM_Calendar;
								_compCal : CM_Calendar;
								_startDate : Date;
								_endDate : Date;
								_tiTrx : CM_TITransaction
								):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 November 2017	jlgndl1	Initial creation	TFS 7032
23 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	numDaysToCheck : Integer;
	testDate : Date;
	numDaysChecked : Integer;
	calendarDate : CM_CalendarDate;
	daysToCharge : Integer;
	ti : CM_TrackedItem;
	eofWeekDt : Date;
	recTrx : CM_TITransaction;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " _startDate: " &amp; _startDate.String &amp; " _endDate: " &amp; _endDate.String, LogINFO.String);
	endif;
	
	if not _startDate.isValid or not _endDate.isValid then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning ZERO - invalid dates", LogINFO.String);
		endif;
		return 0;
	endif;
	
	numDaysToCheck := _endDate - _startDate;	//06 Dec 2017	NDL	TFS 7032
	if numDaysToCheck &lt;= 0 then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning Zero - Date range &lt; 1", LogINFO.String);
		endif;
		return 0;
	endif;
	
	if _workCal = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No 'Days Excluded Calendar' for storage config", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	if _compCal = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No 'Compulsory Days Calendar' for storage config", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	
	if _workCal.allCalendarDates.isEmpty and _compCal.allCalendarDates.isEmpty then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No Dates in Calendars", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	
	eofWeekDt := null;
	if _tiTrx &lt;&gt; null then
		ti := _tiTrx.myTrackedItem;
		if ti &lt;&gt; null then
			recTrx := ti.findLastReceivalTrans();
			if recTrx &lt;&gt; null then		
				if _workCal.getFirstCalendarDateForDay(recTrx.dateTime.Date) &lt;&gt; null then
					eofWeekDt := recTrx.dateTime.Date + 2;
				else
					eofWeekDt := recTrx.dateTime.Date + 7;
				endif;
			endif;
		endif;
	endif;
	//This is the bit that re-adjusts for when the cargo actually arrives in the weekend.
	if eofWeekDt = null then
		if _workCal.getFirstCalendarDateForDay(_startDate) &lt;&gt; null then
			eofWeekDt := _startDate + 2;
		else
			eofWeekDt := _startDate + 7;
		endif;
	endif;
	
	//OK should be good to go now.
	//Need to return the count of the number of days between the start and end, and subtract the days that are 
	//weekends (i.e. the days declared in the days excluded calendar for the first physical week mon-sun irrespective
	//of the s=day it arrives ) and those that are in the compulsory days calendar. DO NOT double count any days
	//that occur in both.
	
	testDate := _startDate;
	while true do
		testDate := testDate + 1;
		numDaysChecked := numDaysChecked + 1;
		calendarDate := null;
		if testDate &lt;= eofWeekDt then
			calendarDate := _workCal.getFirstCalendarDateForDay(testDate); // check for a weekend date in the first week (mon-sunday week)
		endif;
		if calendarDate = null then
			calendarDate := _compCal.getFirstCalendarDateForDay(testDate); // check for any compulsory day in the period
		endif;
		if calendarDate = null then	// not a weekend/holiday or compulsory day
			daysToCharge := daysToCharge + 1;
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Excluding Date - " &amp; calendarDate.date.String, LogINFO.String);
			endif;
		endif;
		if numDaysChecked = numDaysToCheck then
			break;
		endif;
	endwhile;
	
	return daysToCharge;

epilog

end;</source>
        <Parameter name="_workCal" type="CM_Calendar"/>
        <Parameter name="_compCal" type="CM_Calendar"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
