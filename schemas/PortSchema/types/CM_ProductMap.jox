    <JadeMethod name="getTransactionCode" id="82064831-9381-44c1-9620-f0d3e982e354">
        <source>getTransactionCode() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
vars
	code : String;
begin
	if self.myProduct = null then
		code := CM_FinancialObject.Extract_Default;
	else
		code := self.myProduct.code;
	endif;
	return code;
end;
</source>
