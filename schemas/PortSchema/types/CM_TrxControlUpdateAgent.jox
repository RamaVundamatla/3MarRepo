    </JadeMethod>
    <JadeMethod name="trxResetSystemDefForView" id="9c4449f4-7729-47f7-9a2f-c439952e72a6">
        <updating/>
        <source>trxResetSystemDefForView(_view : EntTableView; _rowArray : EntTableRowArray; _def : EntTableDef; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtilityUA.utlResetSystemDefForView(_view, _rowArray, _def, _passport);

epilog
