    <JadeMethod name="setupFoldersToList" id="236caa92-5412-4215-96d3-c8d6055c9b9a">
        <updating/>
        <source>setupFoldersToList() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iniFileName		: String;
	iniFile			: File;
	cardLogDir,
	jadeLogDir,
	jadeCrashDir,
	dbaseDir,
	transientDir,
	tempDir			: String;
	ff				: FileFolder;
	checkTemp		: Boolean;
	
begin

	if self.useAppServerFileSystem then
		iniFileName 	:= app.getIniFileNameAppServer();
		cardLogDir		:= app.getProfileStringAppServer(iniFileName, 'CardLog', 'LogPath', null);
		jadeLogDir		:= app.getProfileStringAppServer(iniFileName, 'JadeLog', 'LogDirectory', null);
		jadeCrashDir	:= app.getProfileStringAppServer(iniFileName, 'FaultHandling', 'CrashLogDirectory', null);
		transientDir	:= app.getProfileStringAppServer(iniFileName, 'JadeClient', 'TransientDbPath', null);
	else
		iniFileName 	:= app.getIniFileName();
		cardLogDir		:= app.getProfileString(iniFileName, 'CardLog', 'LogPath', null);
		jadeLogDir		:= app.getProfileString(iniFileName, 'JadeLog', 'LogDirectory', null);
		jadeCrashDir	:= app.getProfileString(iniFileName, 'FaultHandling', 'CrashLogDirectory', null);
		transientDir	:= app.getProfileStringAppServer(iniFileName, 'JadeClient', 'TransientDbPath', null);
	endif;

	dbaseDir		:= app.dbPath;
	
	create ff transient;
	ff.usePresentationFileSystem := (not self.useAppServerFileSystem);
	
	beginTransaction;
	
	self.logEntry('Ini file &gt;&gt; ' &amp; iniFileName);
	
	if self.useCardLogDir then
		self.logEntry('Card Log &gt;&gt; ' &amp; cardLogDir);
		ff.fileName := cardLogDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(cardLogDir)) then
				self.allFoldersToList.add(cardLogDir);
			endif;
		else
			checkTemp := true;
			self.logEntry('  *** Card Log Directory is not available ***');
		endif;
	endif;
	
	commitTransaction;
	beginTransaction;

	if self.useJadeLogDir then
		self.logEntry('Jade Log &gt;&gt; ' &amp; jadeLogDir);
		ff.fileName := jadeLogDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(jadeLogDir)) then
				self.allFoldersToList.add(jadeLogDir);
			endif;
		else
			checkTemp := true;
			self.logEntry('  *** Jade Log Directory is not available ***');
		endif;
	endif;

	commitTransaction;
	beginTransaction;

	if self.useJadeCrashLogDir then
		self.logEntry('Jade Crash Log &gt;&gt; ' &amp; jadeCrashDir);
		ff.fileName := jadeCrashDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(jadeCrashDir)) then
				self.allFoldersToList.add(jadeCrashDir);
			endif;
		else
			checkTemp := true;
			self.logEntry('  *** Jade Crash Log Directory is not available ***');
		endif;
	endif;

	commitTransaction;
	beginTransaction;

	if self.useDbaseDir then
		self.logEntry('Jade Database Dir &gt;&gt; ' &amp; dbaseDir);
		ff.fileName := dbaseDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(dbaseDir)) then
				self.allFoldersToList.add(dbaseDir);
			endif;
		else
			self.logEntry('  *** Jade DBase Directory is not available ***');
		endif;
	endif;

	commitTransaction;
	beginTransaction;

	if self.useDbaseDir then
		self.logEntry('Jade Transient Database Dir &gt;&gt; ' &amp; transientDir);
		ff.fileName := transientDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(transientDir)) then
				self.allFoldersToList.add(transientDir);
			endif;
		else
			checkTemp := true;
			self.logEntry('  *** Jade Transient Database Directory is not available ***');
		endif;
	endif;

	commitTransaction;
	beginTransaction;

	if self.useTempDir or checkTemp then
		if checkTemp then
			self.logEntry('Not all log directories are valid - checking TEMP dir');
		endif;
		if self.useAppServerFileSystem then
			tempDir := app.getTempDirAppServer;
		else
			tempDir := app.getTempDir;
		endif;
		self.logEntry('TEMP Dir &gt;&gt; ' &amp; tempDir);
		ff.fileName := tempDir;
		if ff.isAvailable then
			if (not self.allFoldersToList.includes(tempDir)) then
				self.allFoldersToList.add(tempDir);
			endif;
		else
			self.logEntry('  *** TEMP Directory is not available ***');
		endif;
	endif;

	commitTransaction;

epilog
	delete ff;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6256821f-382a-43bb-8af2-982deb2761b5">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if eventType = NR_NodeRequestCancelEvent then
		if (not process.isInTransactionState) then
			beginTransaction;
		endif;
		self.isBeingActioned	:= false;
		self.isRequestComplete 	:= true;
		self.logEntry('Terminating due to user request to cancel');
		commitTransaction;

		self.causeEvent(NR_NodeRequestCompleteEvent, true, self);
		if self.runAsSeperateProcess then
			terminate;
		else
			return;
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
