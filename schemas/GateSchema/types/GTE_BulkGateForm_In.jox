    <JadeMethod name="allowAddToTruck" id="b59e4e8c-3a95-4ece-9fdf-c5027a0195ca">
        <source>allowAddToTruck(tmpVVR	: CM_VehicleVisitRecord);

/*
Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars

	truck 	 : CM_Vehicle;
	location : CM_LocationsController;
	termArea : CM_TerminalArea;
	gateArea : CM_GateArea;
	enable 	 : Boolean;

begin

	// so are we allowed to add to this truck.
	truck := tmpVVR.vehicle;
	if truck = null or ( self.myBulkGateAgent.myRealVVR &lt;&gt; truck.visitRecords.last ) then
		// we don't have a trcuk, or are trying to look at a previous visit record,
		// we certainly shouldn't be able to add to this.
		return;
	endif;
	
	location := truck.myPrimaryActualLocation;	
	if location = null then
		// the truck has left, too late.
		return;
	endif;
	
	if location.isGateAreaLocation then
		// make sure its not an exit gate, cos that's too late as well.
		if location.isKindOf( CM_GateAreaLaneController ) then
			if location.CM_GateAreaLaneController.isOut then
				return;
			endif;
		elseif location.isKindOf( CM_BlockController ) then
			termArea := location.CM_BlockController.myTerminalArea;
			gateArea := termArea.CM_GateArea;
			if gateArea.isOutGate and not gateArea.isInGate then
				return;
			endif;
		endif;
	endif;

	// Ok the truck is still on this visit and still either entering the yard or in the yard, we can add items
	// but not maintain thos already on the visit.
		
	enable := app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
		
	self.txtPIN.enabled := enable;
	self.lblPIN.enabled := enable;
	self.btnSave.enabled := enable;

end;
</source>
        <Parameter name="tmpVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="applyRFIDtoJob" id="fda71ba1-3fdf-4c70-8380-9909f2b86030">
        <updating/>
        <source>applyRFIDtoJob( roadJob : CM_RoadJob input):Boolean updating;
/*
Created:     09 December 2016 by cnwns1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

*/
vars
	rfid 	: CM_RFIDTag;
	detail	: CM_VehicleVisitRecordDetail;						
	bat		: String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	if roadJob = null then
		return true;
	endif;
	
	
	detail := roadJob.myVehicleVisit.getSecurityGateArrivedDetail;				
	if detail &lt;&gt; null then 														
		bat := detail.getExtraInfo_AssignRFIDTag;								
	endif;																		
	
	
	if not self.cmbRFID.visible and bat = null then								
		return true;
	endif;
	
	rfid := self.cmbRFID.listObject.CM_RFIDTag;
	if rfid = null then
		rfid := self.myTerminal.allRFIDTagsByCode[bat];							
		if rfid = null then														
			// no tag selected, this is ok too. (if they wanted it compulsory they can select to be prompted on te Gate definition.)
			return true;
		endif;																	
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRoadJobRFIDTag(roadJob,rfid,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Rfid_Tag), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="roadJob" type="CM_RoadJob" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
