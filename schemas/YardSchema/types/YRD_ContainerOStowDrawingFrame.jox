    <JadeMethod name="drawEllipse" id="554b71f2-4330-45a7-8085-6e81ce4e2c20">
        <executionLocation>client</executionLocation>
        <source>drawEllipse(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _color: Integer) clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
20 November 2009	cnwphb1	Initial creation

*/

vars

begin
	if self.swapXY then
		if self.drawFillColor = _color then //21 Sep 2011	NDL	Par 27984
			self.drawEllipse1(_y1 + self.swapYadjustment, _x1 + self.swapXadjustment, _y2 + self.swapYadjustment, _x2 + self.swapXadjustment, _color);
		else
			inheritMethod(_y1 + self.swapYadjustment, _x1 + self.swapXadjustment, _y2 + self.swapYadjustment, _x2 + self.swapXadjustment, _color);
		endif;
	else
		if self.drawFillColor = _color then //21 Sep 2011	NDL	Par 27984
			self.drawEllipse1(_x1, _y1, _x2, _y2, _color);
		else
			inheritMethod(_x1, _y1, _x2, _y2, _color);
		endif;
	endif;
end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
