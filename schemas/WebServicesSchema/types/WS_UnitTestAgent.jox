<Class name="WS_UnitTestAgent" id="833a5394-b17a-47d3-b514-b6cd815511c9">
    <superclass name="CM_UnitTestAgent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
NOTE
====

This class is here to support Unit testing of the Web Services messages
before adding a method here, read the instructions in the method "webServiceCall"
on the class "UT_DSL" in teh schema "JMTUnitTest".
The method you add should also be added to the class "CM_UnitTestAgent" in PortSchema.

There is a reference "myTerminal" and "myUser" that you can read from
on this class.
These values are set in the create method of the super class and should
not be changed, they are set to 'UT terminal' and 'Superuser' respectively.
This is done because we have no "currentSession" (because we are not a
true web service) we have to bypass some of the security.

This is also done in "WS_WebServiceProvider::initialisePassport".
Similarly, "WS_WebServiceProvider::validateCurrentSession" will always
return true.
</text>
    <DbClassMap file="WebTest"/>
    <Constant name="PASSWORD" id="52b28383-b2eb-492f-b4bc-29a600ca2270">
        <source>"S0meS3cretP@ssword!"</source>
        <type name="String"/>
    </Constant>
    <Constant name="USERCODE" id="fd5230d6-710b-4ddc-8775-ccbf5a3b4ef2">
        <source>"UT_RESTUSR"</source>
        <type name="String"/>
    </Constant>
    <Constant name="UT_TERMINAL_CODE" id="d9315499-2c41-46ba-a2ca-a4696123e31b">
        <source>"UT"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="checkEachCriteria" id="466fcf21-bfdf-4968-b284-39b9052dc190">
        <source>checkEachCriteria( 	_queryReqService : JMTUserInterfaceService input;
					_queryReqObject : WS_QueryRequest;
					_queryRequest : WS_TrackedItemQueryRequest input;
					_index : Integer;
					_forQuery : String
					):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwndl1	Initial creation

*/

vars

	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	ti : WS_TrackedItem;
	id : String;
	oldStringArray : StringArray;
	newStringArray : StringArray;
	difference : StringArray;
	str : String;
	msg : String;

begin

	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTiType.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTerminalArea.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterYardLocation.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterOperator.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBOL.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBookingRef.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterCarrier.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignee.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTransportMode.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignee.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterISOType.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterIMEX.name,null);
	_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyage.name,null);
	
	
	if _forQuery = "getTIsForCargoEnquiry" then
	
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"UT");
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,"1".String);
	
		if _index = 1 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTiType.name,"1".String);
		elseif _index = 2 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTerminalArea.name,"UTBSM");
		elseif _index = 3 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterYardLocation.name,"CTA1 1");
		elseif _index = 4 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterOperator.name,"UTOP");
		elseif _index = 5 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,null);
		elseif _index = 6 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBOL.name,"BOL002");
		elseif _index = 7 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBookingRef.name,"BOOKING");
		elseif _index = 8 then 
			return null;
			//only used during get tis for release request query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterCarrier.name,"UT_CA2");
		elseif _index = 9 then 
			return null;
			//only used during get tis for release request query AND for the prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignee.name,"CCS");
		elseif _index = 10 then 
			return null;
			//only used during get tis for the prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTransportMode.name,"Road");
		elseif _index = 11 then 
			return null;
			//only used during get tis for the prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignor.name,"FONTE");
		elseif _index = 12 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterISOType.name,"2200");
		elseif _index = 13 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterIMEX.name,"1".String);
		elseif _index = 14 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyage.name,"UTKPVOY01");
		else
			return null;
		endif;
		
	elseif _forQuery = "getTIsForImportRelease" then
	
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"UT");
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,"1".String);
	
		if _index = 1 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTiType.name,"1".String);
		elseif _index = 2 then
			return null;
			//only used during the general get ti query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTerminalArea.name,"UTBSM");
		elseif _index = 3 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterYardLocation.name,"CTA1 1");
		elseif _index = 4 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterOperator.name,"UTOP");
		elseif _index = 5 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,null);
		elseif _index = 6 then 
			return null;
			//only used during the general get ti query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBOL.name,"BOL002");
		elseif _index = 7 then 
			return null;
			//only used during the general get ti query and prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBookingRef.name,"BOOKING");
		elseif _index = 8 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterCarrier.name,"UT_CA2");
		elseif _index = 9 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignee.name,"CCS");
		elseif _index = 10 then 
			return null;
			//only used during get tis for the prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTransportMode.name,"Road");
		elseif _index = 11 then 
			return null;
			//only used during get tis for the prenotes query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignor.name,"FONTE");
		elseif _index = 12 then
			return null;
			//only used during the general get ti query 
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterISOType.name,"2200");
		elseif _index = 13 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterIMEX.name,"1".String);
		elseif _index = 14 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyage.name,"UTKPVOY01");
		else
			return null;
		endif;
		
	elseif _forQuery = "getTIsForPreNotes" then
	
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"PRE");
		_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,TI_STATE_NOTIFIED.String);
	
		if _index = 1 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTiType.name,"1".String);
		elseif _index = 2 then 
			return null;
			//Not valid for pre-notes
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTerminalArea.name,"UTBSM");
		elseif _index = 3 then 
			return null;
			//Not valid for pre-notes
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterYardLocation.name,"CTA1 1");
		elseif _index = 4 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterOperator.name,"UTOP");
		elseif _index = 5 then 
			return null;
			//Not valid for pre-notes
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,null);
		elseif _index = 6 then 
			return null;
			//Only used in general cargo queries
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBOL.name,"BOL002");
		elseif _index = 7 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBookingRef.name,"BOOKING");
		elseif _index = 8 then 
			return null;
			//only used during get tis for release request query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterCarrier.name,"UT_CA2");
		elseif _index = 9 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"DT".String);
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignee.name,"ATWO");
		elseif _index = 10 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"Z".String);
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterTransportMode.name,"Rail");
		elseif _index = 11 then
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name,"D".String);
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterConsignor.name,"ABCNR");
		elseif _index = 12 then 
			return null;
			//only used during general get tis query for release request query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterISOType.name,"2200".String);
		elseif _index = 13 then 
			_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterIMEX.name,"1".String);
		elseif _index = 14 then 
			return null;
			//only used during general get tis query for release request query
			//_queryRequest.WS_TrackedItemQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyage.name,"PAR26798");
		else
			return null;
		endif;		
	else
		return "Invalid method called in 'checkEachCriteria'";
		
	endif;
	
	create oldStringArray transient;
	if _forQuery = "getTIsForCargoEnquiry" then
		queryResponse := _queryReqService.myWebServiceAgent.getTIsForCargoEnquiryOld(_queryReqObject.WS_TrackedItemQueryRequest);
	elseif _forQuery = "getTIsForImportRelease" then
		queryResponse := _queryReqService.myWebServiceAgent.getTIsForImportReleaseOld(_queryReqObject.WS_TrackedItemQueryRequest);
	elseif _forQuery = "getTIsForPreNotes" then
		queryResponse := _queryReqService.myWebServiceAgent.getTIsForPreNotesOld(_queryReqObject.WS_TrackedItemQueryRequest);
	endif;
	totalFound := queryResponse.allTrackedItems.size;
	if queryResponse.allTrackedItems.size &gt; 0 then
		foreach ti in queryResponse.allTrackedItems do
			oldStringArray.add( ti.idTextBox );
		endforeach;
	endif;
	delete queryResponse;
	
	if _forQuery = "getTIsForCargoEnquiry" then
		queryResponse := _queryReqService.findCargo(_queryReqObject.WS_TrackedItemQueryRequest);
	elseif _forQuery = "getTIsForImportRelease" then
		queryResponse := _queryReqService.findImportReleaseCargo(_queryReqObject.WS_TrackedItemQueryRequest);
	elseif _forQuery = "getTIsForPreNotes" then
		queryResponse := _queryReqService.findPreNoteCargo(_queryReqObject.WS_TrackedItemQueryRequest);
	endif;
	if totalFound &lt;&gt; queryResponse.allTrackedItems.size then
		create newStringArray transient;
		if queryResponse.allTrackedItems.size &gt; 0 then
			foreach ti in queryResponse.allTrackedItems do
				newStringArray.add( ti.idTextBox );
			endforeach;
		endif;
		create difference transient;
		if newStringArray.size &gt; oldStringArray.size then
			foreach str in newStringArray do
				if not oldStringArray.includes( str ) then
					difference.add(str);
				endif;
			endforeach;
		else
			foreach str in oldStringArray do
				if not newStringArray.includes( str ) then
					difference.add(str);
				endif;
			endforeach;
		endif;
		foreach str in difference do
			if msg &lt;&gt; null then
				msg := msg &amp; ",";
			endif;
			msg := msg &amp; str;
		endforeach;
		return "Test " &amp; _index.String &amp; " (" &amp; _forQuery &amp; "), queryResponse from OLD query found " &amp; totalFound.String
					&amp; ", queryResponse from NEW query found " &amp; queryResponse.allTrackedItems.size.String &amp; "["&amp; msg &amp;"]" ;
	endif;
	
	
	return null;
	
epilog

	delete queryResponse;
	delete oldStringArray;
	delete newStringArray;
	delete difference;

end;</source>
        <access>protected</access>
        <Parameter name="_queryReqService" type="JMTUserInterfaceService" usage="input"/>
        <Parameter name="_queryReqObject" type="WS_QueryRequest"/>
        <Parameter name="_queryRequest" type="WS_TrackedItemQueryRequest" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_forQuery" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearVehicleBooking" id="028bd17f-d749-4968-a3e4-5373baaede82">
        <source>clearVehicleBooking( _realVBTimeslot : CM_VehicleBookingTimeSlot input ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31393
17 Mar 2014 cnwmc5	CCMS SFW 1368 - remocing the JMTUpdateService
*/

vars

	updateRequest : WS_VehicleBookingUpdateRequest;
	//updateService : JMTUpdateService;
	webService : JMTUserInterfaceService;
	updateResponse : WS_VehicleBookingUpdResponse;

begin

	create updateRequest transient;
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::cmObjectId.name, _realVBTimeslot.getOidString);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::cmObjectEdition.name, _realVBTimeslot.edition);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::allDeliveryTiIds.name,null);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::allPuTiIds.name,null);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::carrier.name,null);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::driver.name,null);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::includesDelivery.name,false);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::includesPickup.name,false);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::remarks.name,null);
	updateRequest.setPropertyValue(WS_VehicleBookingUpdateRequest::vehicle.name,null);
		
	create webService transient;
	updateResponse := webService.updateVehicleBooking(updateRequest);
	if updateResponse = null then
		return "clearing booking data 1, updateResponse not returned.";
	endif;
	if updateResponse.hasErrors then
		return "clearing booking data 2, " &amp; updateResponse.getErrorsAsStringForTesting;
	endif;	
	delete updateResponse;
	
	return null;

epilog

	delete updateRequest;
	delete webService;
	delete updateResponse;

end;</source>
        <access>protected</access>
        <Parameter name="_realVBTimeslot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleCMException" id="480d075d-b025-427d-825b-449a857bffdc">
        <source>handleCMException(_exc : CM_Exception) : Integer protected;
/*

Purpose:			Arm the same exception handler used during pre-process request

Parameters:			

Return Value:		

Date				Who		Reason
16 January 2024		navmd1	Initial creation

*/

vars

begin
	app.writeLog(method.qualifiedName, LogTRACE);
	
	if _exc.isWarning then
		app.myPassport.addWarningFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc.mySubject);
		return Ex_Continue;
	else
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
		return Ex_Resume_Next;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loginREST" id="cbe35dd3-10fe-4dbf-89e4-363000ccdc5a">
        <source>loginREST(webService : MasterTerminalAPIService input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 April 2023		navra1	Initial creation along with TFS 56641
13 June 2024		navmd1	Moved to loginRestWithOperator so Operator isn't always just us

*/

vars
	
begin
	self.loginRestWithOperator(webService, "Navis");
epilog	
	
end;</source>
        <Parameter name="webService" type="MasterTerminalAPIService" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loginRestWithOperator" id="062db904-92ff-4c97-a0cc-a14e660d0f59">
        <source>loginRestWithOperator(_webService: WS_RestWebServiceProvider input; _operator: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 June 2024		navmd1	Initial creation TFS 61725
12 September 2024	navpw1	TFS: 65623 (65624) - Changed the webService parameter to be type of WS_RestWebServiceProvider instead of MasterTerminalAPIService

*/

vars
	terminalCode	: String;
	operator		: String;
	
	token			: String;
	loginJson		: String;
	
begin
	terminalCode := WS_UnitTestAgent.UT_TERMINAL_CODE;
	if _operator = null then
		operator := "Navis";
	else
		operator := _operator;
	endif;
	
	loginJson := '{
   "userId": "' &amp; WS_UnitTestAgent.USERCODE &amp; '",
   "password": "' &amp; WS_UnitTestAgent.PASSWORD &amp; '",
    "applicationId" : "JMTUnitTest",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "' &amp; operator &amp; '",
        "yardId" : "MTN"
    }}';
	
	self.wsRESTLogin(loginJson, token);
	
	if token &lt;&gt; null then				
		_webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", token);
	endif;

epilog
	

end;</source>
        <access>protected</access>
        <Parameter name="_webService" type="WS_RestWebServiceProvider" usage="input"/>
        <Parameter name="_operator" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateRequestFromXML" id="fd3ac357-543a-4ef3-b2db-5557e4b8d28c">
        <source>populateRequestFromXML(	_request : WS_Request input;
						_rawXMLString : String
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	rootElement : JadeXMLElement;
	childNode : JadeXMLNode;
	element : JadeXMLElement;
	subElement : JadeXMLElement;
	tagName : String;
	data : String;
	property : Property;
	wsSubElementRoot : JadeXMLNode;
	
	wsDocument : WS_Document;
	wsResourceUsed : WS_HMSResourceUsed;
	wsVoyageHoldCargo : WS_VoyageHoldCargo;
	

begin

	create xmlDocumentParser transient;
	create xmlDocument transient;
	
	xmlDocumentParser.parseDocumentString( xmlDocument, _rawXMLString );
	rootElement := xmlDocument.rootElement;
	
	foreach childNode in rootElement.childNodes do
		element := childNode.JadeXMLElement;
		data := element.textData.trimCharacters(CrLf).trimBlanks;
		
		
		if data &lt;&gt; null and _request.setFromXMLElement( element ) then
			continue;
			
		elseif data = null and not element.childNodes.isEmpty then	
			tagName := element.tagName;
			if _request.isKindOf( WS_VoyageHoldCargoRequest ) then
				if tagName = WS_VoyageHoldCargoRequest::allDocuments.name then
					foreach wsSubElementRoot in element.childNodes do
						if not wsSubElementRoot.childNodes.isEmpty then
							create wsDocument transient;
							_request.WS_VoyageHoldCargoRequest.allDocuments.add( wsDocument );
							foreach childNode in wsSubElementRoot.childNodes do
								subElement := childNode.JadeXMLElement;
								wsDocument.setFromXMLElement( subElement );
							endforeach;
						endif;
					endforeach;
					
				elseif tagName = WS_VoyageHoldCargoRequest::allHMSResourcesUsed.name then
					foreach wsSubElementRoot in element.childNodes do
						if not wsSubElementRoot.childNodes.isEmpty then
							create wsResourceUsed transient;
							_request.WS_VoyageHoldCargoRequest.allHMSResourcesUsed.add( wsResourceUsed );
							foreach childNode in wsSubElementRoot.childNodes do
								subElement := childNode.JadeXMLElement;
								wsResourceUsed.setFromXMLElement( subElement );
							endforeach;
						endif;
					endforeach;
					
				elseif tagName = WS_VoyageHoldCargoRequest::allVoyageHoldCargo.name then
					foreach wsSubElementRoot in element.childNodes do
						if not wsSubElementRoot.childNodes.isEmpty then
							create wsVoyageHoldCargo transient;
							_request.WS_VoyageHoldCargoRequest.allVoyageHoldCargo.add( wsVoyageHoldCargo );
							foreach childNode in wsSubElementRoot.childNodes do
								subElement := childNode.JadeXMLElement;
								wsVoyageHoldCargo.setFromXMLElement( subElement );
							endforeach;
						endif;
					endforeach;
				
				endif;
				// end of 'WS_VoyageHoldCargoRequest' special code
				
			elseif _request.isKindOf( WS_HMSResourcesUsedRequest ) then
				if tagName = WS_HMSResourcesUsedRequest::allHMSResourcesUsed.name then
					foreach wsSubElementRoot in element.childNodes do
						if not wsSubElementRoot.childNodes.isEmpty then
							create wsResourceUsed transient;
							_request.WS_HMSResourcesUsedRequest.allHMSResourcesUsed.add( wsResourceUsed );
							foreach childNode in wsSubElementRoot.childNodes do
								subElement := childNode.JadeXMLElement;
								wsResourceUsed.setFromXMLElement( subElement );
							endforeach;
						endif;
					endforeach;
					
				endif;
				// end of 'WS_HMSResourcesUsedRequest' special code
				
			else
				//Request type NOT coded for.  I.e. Not expecting any embbedded collections for this type.
			endif;
		
		endif;
	endforeach;
	
	

epilog

	delete xmlDocumentParser;
	delete xmlDocument;

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="WS_Request" usage="input"/>
        <Parameter name="_rawXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifyCustomers" id="0f6b4516-039a-4868-9e43-01dd2d3a99ab">
        <source>verifyCustomers(_customers : WS_CustomerArray ; _includeRelatedInfo : Boolean ; _includeSpecificConfig : Boolean ; startFrom:Integer; _errors : String output) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2023	navra1	Initial creation for TFS 56641
20/07/2023	navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice
26 Feb 2024 navhn30	ChangeRequest 59198: MTN - REST GET /Customers and /Customer/Id TerminalConfiguration optional
*/

vars
	debtorsArray : ObjectArray;
	debtor : Object;
	iter : Integer;
	carrier : CM_Carrier;	
	carrierNo : Integer;
	consignor : CM_ConsigneeConsignor;	
	consignorNo : Integer;
	operator : CM_Operator;	
	operatorNo : Integer;
	shippingLine : CM_ShippingLine;	
	shippingLineNo : Integer;
	stevedore : CM_Stevedore;	
	stevedoreNo : Integer;
	endAt : Integer;
	sizeExpected : Integer;
	debtorsExpectedArray : ObjectArray;
	copyIter : Integer;
	debtorTerminal : CM_DebtorTerminal;
	debtorTerminalNo : Integer;
	custAddressObj 	: WS_RestAddressObject;
begin
	_errors  := '';
	
	if _customers = null then
		_errors := _errors  &amp; ' Customers was null in response';
	endif;
	
	
	endAt := startFrom + 99;
	sizeExpected := 100;
	if endAt &gt; app.myRoot.myRootCompany.debtors.size() then
		endAt := app.myRoot.myRootCompany.debtors.size();
		sizeExpected := endAt - startFrom + 1;
	endif;
	
	
	if _customers.size() &lt;&gt; sizeExpected then
		_errors := _errors  &amp; ' There were ' &amp; _customers.size().String &amp; ' customers in the response, there should have been only ' &amp; sizeExpected.String;		
	endif;
	
	create debtorsArray transient;
	debtorsArray.addAll(app.myRoot.myRootCompany.debtors);
	
	create debtorsExpectedArray transient;
	copyIter := 1;
	foreach debtor in debtorsArray do	
		if copyIter &gt;= startFrom and copyIter &lt;= endAt then				//the start and end are included
			debtorsExpectedArray.add(debtorsArray[copyIter]);
		endif;
		copyIter := copyIter +1;
	endforeach;
		
	
	iter := 1;
	foreach debtor in debtorsExpectedArray do		
		
		if debtor.CM_Debtor.name &lt;&gt; _customers[iter].name then
			_errors:="Name of customer " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		//if debtor.CM_Debtor.code &lt;&gt; _customers[iter].debtorCode then			//JIRA-20787
		//	_errors:="Code of customer " &amp; iter.String &amp; " is not as expected";	//JIRA-20787
		//	return;																//JIRA-20787
		//endif;																//JIRA-20787
		
		if debtor.CM_Debtor.code &lt;&gt; _customers[iter].id then
			_errors:="Code of customer " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.name &lt;&gt; _customers[iter].name then
			_errors:="Code of name " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.longName &lt;&gt; _customers[iter].description then					// 20/07/2023	navcs2	ChangeRequest 57650
			_errors:="Code of description " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.decfinName &lt;&gt; _customers[iter].accountCode then
			_errors:="Code of accountCode " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.additionalInformation1 &lt;&gt; _customers[iter].additionalInfo1 then
			_errors:="Code of additionalInformation1 " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.additionalInformation2 &lt;&gt; _customers[iter].additionalInfo2 then
			_errors:="Code of additionalInformation2 " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.hasBadCredit &lt;&gt; _customers[iter].badCredit then
			_errors:="Code of badCredit info " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.isSuspended &lt;&gt; _customers[iter].suspended then
			_errors:="Code of isSuspended info " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		//if debtor.CM_Debtor.getBillingAddressString &lt;&gt; _customers[iter].billingAddress then	//JIRA-20787
		//	_errors:="Code of billingAddress info " &amp; iter.String &amp; " is not as expected";		//JIRA-20787
		//	return;																				//JIRA-20787
		//endif;																				//JIRA-20787
		
		foreach custAddressObj in _customers[iter].addresses do									//JIRA-20787
			if debtor.CM_Debtor.allAddressesByCode[custAddressObj.id] = null then				//JIRA-20787
				_errors := "Address info " &amp; iter.String &amp; " is not as expected";				//JIRA-20787
				return;																			//JIRA-20787
			endif;																				//JIRA-20787
		endforeach;																				//JIRA-20787
		
		if debtor.CM_Debtor.myTermsOfTrade &lt;&gt; null then
			if debtor.CM_Debtor.myTermsOfTrade.code &lt;&gt; _customers[iter].termsOfTradeId then
				_errors:="Code of termsOfTradeId info " &amp; iter.String &amp; " is not as expected";
				return;
			endif;
		endif;		
		
		
		if _includeRelatedInfo then
		
			carrierNo := 1;
			foreach carrier in debtor.CM_Debtor.allCarriers do
				
				if carrier.code &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].id then
					_errors:="relatedEntities.carriers[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.description &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].description then
					_errors:="relatedEntities.carriers[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isRail &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].rail then
					_errors:="relatedEntities.carriers[].rail info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isRoad &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].road then
					_errors:="relatedEntities.carriers[].road info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isSubCarrier &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].subCarrier then
					_errors:="relatedEntities.carriers[].subCarrier info " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				
				carrierNo := carrierNo+1;
			endforeach;
			
			consignorNo := 1;
			foreach consignor in debtor.CM_Debtor.consignors do				
				
				if consignor.code &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].id then
					_errors:="relatedEntities.consignors[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.description &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].description then
					_errors:="relatedEntities.consignors[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.isConsignor &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].consignor then
					_errors:="relatedEntities.consignors[].consignor info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.isConsignee &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].consignee then
					_errors:="relatedEntities.consignors[].consignee info " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				
				consignorNo := consignorNo + 1;
			endforeach;

			operatorNo := 1;
			foreach operator in debtor.CM_Debtor.operators do				
				
				if operator.code &lt;&gt; _customers[iter].relatedEntities.operators[operatorNo].id then
					_errors:="relatedEntities.operators[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; operatorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if operator.description &lt;&gt; _customers[iter].relatedEntities.operators[operatorNo].description then
					_errors:="relatedEntities.operators[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; operatorNo.String &amp; "is not as expected";
					return;
				endif;
				
				operatorNo := operatorNo + 1;
			endforeach;

			shippingLineNo := 1;
			foreach shippingLine in debtor.CM_Debtor.allShippingLines do				
				
				if shippingLine.code &lt;&gt; _customers[iter].relatedEntities.shippingLines[shippingLineNo].id then
					_errors:="relatedEntities.shippingLine[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; shippingLineNo.String &amp; "is not as expected";
					return;
				endif;
				
				if shippingLine.description &lt;&gt; _customers[iter].relatedEntities.shippingLines[shippingLineNo].description then
					_errors:="relatedEntities.shippingLine[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; shippingLineNo.String &amp; "is not as expected";
					return;
				endif;
				
				shippingLineNo := shippingLineNo + 1;
			endforeach;

			stevedoreNo := 1;
			foreach stevedore in debtor.CM_Debtor.allStevedores do				
				
				if stevedore.code &lt;&gt; _customers[iter].relatedEntities.stevedores[stevedoreNo].id then
					_errors:="relatedEntities.stevedores[stevedoreNo].id info of customer " &amp; iter.String &amp; " rel ent " &amp; stevedoreNo.String &amp; "is not as expected";
					return;
				endif;
				
				if stevedore.description &lt;&gt; _customers[iter].relatedEntities.stevedores[stevedoreNo].description then
					_errors:="relatedEntities.stevedores[stevedoreNo].description info of customer " &amp; iter.String &amp; " rel ent " &amp; stevedoreNo.String &amp; "is not as expected";
					return;
				endif;
				
				stevedoreNo := stevedoreNo + 1;
			endforeach;									
		endif;	
		if _includeSpecificConfig then
			debtorTerminalNo :=1;															// 22.02.24			navhn30		TFS # 59198
			foreach debtorTerminal in debtor.CM_Debtor.allDebtorTerminals do
				if debtorTerminal.isCashOnly &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].cashOnly then
					_errors:="terminalSpecificConfiuration[ebtorTerminalNo].cashOnly info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif; 

				if debtorTerminal.myCurrencyType &lt;&gt; null and debtorTerminal.myCurrencyType.code &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].currencyId then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].currencyId info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.myTerminal.code &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].id then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].id info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.interTerminalCode &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].intercompanyCode then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].interCompanyCode info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.defaultInvoiceJRW &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].invoiceReportName then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].invoiceReportName info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.myLocale &lt;&gt; null and debtorTerminal.myLocale.localeId &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].localeId then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].localeId info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.orgCode &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].organisationCode then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].orgCode info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if app.paymentTypeEnumToString(debtorTerminal.paymentType) &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].paymentType then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].payment info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				debtorTerminalNo := debtorTerminalNo+1;
			endforeach;
		endif;
		iter := iter+1;
	endforeach;
	
	
	
epilog
	
	delete debtorsArray;
	delete debtorsExpectedArray;

end;</source>
        <access>protected</access>
        <Parameter name="_customers" type="WS_CustomerArray"/>
        <Parameter name="_includeRelatedInfo" type="Boolean"/>
        <Parameter name="_includeSpecificConfig" type="Boolean"/>
        <Parameter name="startFrom" type="Integer"/>
        <Parameter name="_errors" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="verifySpecificCustomer" id="afdc98f9-dec9-447a-95be-3855acd377bf">
        <source>verifySpecificCustomer(_customers : WS_CustomerArray ; _includeRelatedInfo : Boolean ; _includeSpecificConfig : Boolean ;_custCode:String ; _errors : String output) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2023	navra1	Initial creation for TFS 56641
22 Feb	2024	navhn30	ChangeRequest 59198: MTN - REST GET /Customers and /Customer/Id TerminalConfiguration optional
*/

vars
	
	debtorIter : CM_Debtor;
	debtor : Object;
	iter : Integer;
	carrier : CM_Carrier;	
	carrierNo : Integer;
	consignor : CM_ConsigneeConsignor;	
	consignorNo : Integer;
	operator : CM_Operator;	
	operatorNo : Integer;
	shippingLine : CM_ShippingLine;	
	shippingLineNo : Integer;
	stevedore : CM_Stevedore;	
	stevedoreNo : Integer;
	endAt : Integer;
	sizeExpected : Integer;
	debtorsExpectedArray : ObjectArray;
	compareIter : Integer;
	debtorsDictionary : CM_DebtorByCodeDict;
	debtorTerminal	: CM_DebtorTerminal;
	debtorTerminalNo : Integer;
	custAddressObj	: WS_RestAddressObject;
begin
	_errors  := '';
	
	if _customers = null then
		_errors := _errors  &amp; ' Customers was null in response';
	endif;
	
	
	debtorsDictionary := app.myRoot.myRootCompany.allDebtorsByCode;
	
	create debtorsExpectedArray transient;
	foreach debtorIter in debtorsDictionary where debtorIter.code = _custCode do
		debtorsExpectedArray.add(debtorIter);
	endforeach;
	
	if debtorsExpectedArray.size() = 0 then
		if _customers.size() &lt;&gt; 0 then
			_errors := _errors  &amp; ' Customer was found when there is no customer with the code provided, code provided was ' &amp; _custCode;
			return;
		endif;
		return;
	else
		if _customers.size() &lt;&gt; debtorsExpectedArray.size() then
			_errors := _errors  &amp; ' Only some of the customers with the given code was found, code provided was ' &amp; _custCode;
			return;
		endif;
	endif;			
	
	iter := 1;
	foreach debtor in debtorsExpectedArray do		
		
		if debtor.CM_Debtor.name &lt;&gt; _customers[iter].name then
			_errors:="Name of customer " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		//if debtor.CM_Debtor.code &lt;&gt; _customers[iter].debtorCode then					//JIRA-20787
		//	_errors:="Code of customer " &amp; iter.String &amp; " is not as expected";			//JIRA-20787
		//	return;																		//JIRA-20787
		//endif;																		//JIRA-20787
		
		if debtor.CM_Debtor.code &lt;&gt; _customers[iter].id then
			_errors:="Code of customer " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.name &lt;&gt; _customers[iter].name then
			_errors:="Code of name " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.longName &lt;&gt; _customers[iter].description then				// 20/07/2023	navcs2	ChangeRequest 57650
			_errors:="Code of description " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.decfinName &lt;&gt; _customers[iter].accountCode then
			_errors:="Code of accountCode " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.additionalInformation1 &lt;&gt; _customers[iter].additionalInfo1 then
			_errors:="Code of additionalInformation1 " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.additionalInformation2 &lt;&gt; _customers[iter].additionalInfo2 then
			_errors:="Code of additionalInformation2 " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.hasBadCredit &lt;&gt; _customers[iter].badCredit then
			_errors:="Code of badCredit info " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		if debtor.CM_Debtor.isSuspended &lt;&gt; _customers[iter].suspended then
			_errors:="Code of isSuspended info " &amp; iter.String &amp; " is not as expected";
			return;
		endif;
		
		//if debtor.CM_Debtor.getBillingAddressString &lt;&gt; _customers[iter].billingAddress then	//JIRA-20787
		//	_errors:="Code of billingAddress info " &amp; iter.String &amp; " is not as expected";		//JIRA-20787
		//	return;																				//JIRA-20787
		//endif;																				//JIRA-20787
		
		foreach custAddressObj in _customers[iter].addresses do									//JIRA-20787
			if debtor.CM_Debtor.allAddressesByCode[custAddressObj.id] = null then				//JIRA-20787
				_errors := "Address info " &amp; iter.String &amp; " is not as expected";				//JIRA-20787
				return;																			//JIRA-20787
			endif;																				//JIRA-20787
		endforeach;																				//JIRA-20787
		
		if debtor.CM_Debtor.myTermsOfTrade &lt;&gt; null then
			if debtor.CM_Debtor.myTermsOfTrade.code &lt;&gt; _customers[iter].termsOfTradeId then
				_errors:="Code of termsOfTradeId info " &amp; iter.String &amp; " is not as expected";
				return;
			endif;
		endif;		
		
		
		if _includeRelatedInfo then
		
			carrierNo := 1;
			foreach carrier in debtor.CM_Debtor.allCarriers do
				
				if carrier.code &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].id then
					_errors:="relatedEntities.carriers[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.description &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].description then
					_errors:="relatedEntities.carriers[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isRail &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].rail then
					_errors:="relatedEntities.carriers[].rail info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isRoad &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].road then
					_errors:="relatedEntities.carriers[].road info of customer " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				if carrier.isSubCarrier &lt;&gt; _customers[iter].relatedEntities.carriers[carrierNo].subCarrier then
					_errors:="relatedEntities.carriers[].subCarrier info " &amp; iter.String &amp; " rel ent " &amp; carrierNo.String &amp; "is not as expected";
					return;
				endif;
				
				carrierNo := carrierNo+1;
			endforeach;
			
			consignorNo := 1;
			foreach consignor in debtor.CM_Debtor.consignors do				
				
				if consignor.code &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].id then
					_errors:="relatedEntities.consignors[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.description &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].description then
					_errors:="relatedEntities.consignors[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.isConsignor &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].consignor then
					_errors:="relatedEntities.consignors[].consignor info of customer " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if consignor.isConsignee &lt;&gt; _customers[iter].relatedEntities.consignors[consignorNo].consignee then
					_errors:="relatedEntities.consignors[].consignee info " &amp; iter.String &amp; " rel ent " &amp; consignorNo.String &amp; "is not as expected";
					return;
				endif;
				
				
				consignorNo := consignorNo + 1;
			endforeach;

			operatorNo := 1;
			foreach operator in debtor.CM_Debtor.operators do
				
				if operator.code &lt;&gt; _customers[iter].relatedEntities.operators[operatorNo].id then
					_errors:="relatedEntities.operators[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; operatorNo.String &amp; "is not as expected";
					return;
				endif;
				
				if operator.description &lt;&gt; _customers[iter].relatedEntities.operators[operatorNo].description then
					_errors:="relatedEntities.operators[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; operatorNo.String &amp; "is not as expected";
					return;
				endif;
				
				operatorNo := operatorNo + 1;
			endforeach;

			shippingLineNo := 1;
			foreach shippingLine in debtor.CM_Debtor.allShippingLines do				
				
				if shippingLine.code &lt;&gt; _customers[iter].relatedEntities.shippingLines[shippingLineNo].id then
					_errors:="relatedEntities.shippingLine[].id info of customer " &amp; iter.String &amp; " rel ent " &amp; shippingLineNo.String &amp; "is not as expected";
					return;
				endif;
				
				if shippingLine.description &lt;&gt; _customers[iter].relatedEntities.shippingLines[shippingLineNo].description then
					_errors:="relatedEntities.shippingLine[].description info of customer " &amp; iter.String &amp; " rel ent " &amp; shippingLineNo.String &amp; "is not as expected";
					return;
				endif;
				
				shippingLineNo := shippingLineNo + 1;
			endforeach;

			stevedoreNo := 1;
			foreach stevedore in debtor.CM_Debtor.allStevedores do				
				
				if stevedore.code &lt;&gt; _customers[iter].relatedEntities.stevedores[stevedoreNo].id then
					_errors:="relatedEntities.stevedores[stevedoreNo].id info of customer " &amp; iter.String &amp; " rel ent " &amp; stevedoreNo.String &amp; "is not as expected";
					return;
				endif;
				
				if stevedore.description &lt;&gt; _customers[iter].relatedEntities.stevedores[stevedoreNo].description then
					_errors:="relatedEntities.stevedores[stevedoreNo].description info of customer " &amp; iter.String &amp; " rel ent " &amp; stevedoreNo.String &amp; "is not as expected";
					return;
				endif;
				
				stevedoreNo := stevedoreNo + 1;
			endforeach;
		endif;
		
		if _includeSpecificConfig then
			debtorTerminalNo :=1;															// 22.02.24			navhn30		TFS # 59198
			foreach debtorTerminal in debtor.CM_Debtor.allDebtorTerminals do
				if debtorTerminal.isCashOnly &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].cashOnly then
					_errors:="terminalSpecificConfiuration[ebtorTerminalNo].cashOnly info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif; 

				if debtorTerminal.myCurrencyType &lt;&gt; null and debtorTerminal.myCurrencyType.code &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].currencyId then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].currencyId info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.myTerminal.code &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].id then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].id info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.interTerminalCode &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].intercompanyCode then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].interCompanyCode info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.defaultInvoiceJRW &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].invoiceReportName then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].invoiceReportName info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.myLocale &lt;&gt; null and debtorTerminal.myLocale.localeId &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].localeId then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].localeId info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if debtorTerminal.orgCode &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].organisationCode then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].orgCode info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				if app.paymentTypeEnumToString(debtorTerminal.paymentType) &lt;&gt; _customers[iter].terminalSpecificConfiguration[debtorTerminalNo].paymentType then
					_errors:="terminalSpecificConfiuration[debtorTerminalNo].payment info of customer " &amp; iter.String &amp; " term SpecficConfig " &amp; debtorTerminalNo.String &amp; "is not as expected";
					return;
				endif;
				
				debtorTerminalNo := debtorTerminalNo+1;
			endforeach;
		endif;
		
		iter := iter+1;
	endforeach;
	
	
	
epilog
	
	//delete debtorsArray;
	delete debtorsExpectedArray;

end;
</source>
        <access>protected</access>
        <Parameter name="_customers" type="WS_CustomerArray"/>
        <Parameter name="_includeRelatedInfo" type="Boolean"/>
        <Parameter name="_includeSpecificConfig" type="Boolean"/>
        <Parameter name="_custCode" type="String"/>
        <Parameter name="_errors" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="wsBookingMaint" id="248220bd-f974-4289-b3ae-8b8bb4b7ce65">
        <source>wsBookingMaint( _carrier : CM_Carrier; _operator : CM_Operator; _voyage : CM_Voyage ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2015	cnwmc5	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/
constants

	BOOKING			: String = "UTMCBK01";

vars

	ref 			: String;

	webService 		: JMTUserInterfaceService;
	request			: WS_BookingUpdateRequest;
	response		: WS_Response; 
	
	wsBooking		: WS_Booking;
	wsCarrier		: WS_Carrier;
	wsOperator		: WS_Operator;
	wsBookingStatus	: WS_BookingStatus;
	wsPort			: WS_Port;
	wsBookingItem	: WS_BookingItem;
	wsCargoType		: WS_CargoType;
	wsISOType		: WS_ISOType;
	wsCommodity		: WS_Commodity;
	
begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	// Create Booking
	// Booking related objects
	create wsCarrier transient;
	wsCarrier.setPropertyValue("code", _carrier.code);
	
	create wsOperator transient;
	wsOperator.setPropertyValue("code", _operator.code);
	
	create wsBookingStatus transient;
	wsBookingStatus.setPropertyValue("id", BOOKING_REF_ACTIVE);
	
	create wsPort transient;
	wsPort.setPropertyValue("code", "NZLYT");
	
	// Booking item related objects
	create wsCargoType transient;
	wsCargoType.setPropertyValue("id", 1);
	
	create wsISOType transient;
	wsISOType.setPropertyValue("code", "2200");
	
	create wsCommodity transient;
	wsCommodity.setPropertyValue("code", "GENL");
	
	create wsBookingItem transient;
	wsBookingItem.setPropertyValue("cargoType", wsCargoType);
	wsBookingItem.setPropertyValue("isoType", wsISOType);
	wsBookingItem.setPropertyValue("commodity", wsCommodity);
	wsBookingItem.setPropertyValue("quantity", 5);
	
	// Booking
	create wsBooking transient;
	wsBooking.setPropertyValue("carrier", wsCarrier);
	wsBooking.setPropertyValue("operator", wsOperator);
	wsBooking.setPropertyValue("status", wsBookingStatus);
	wsBooking.setPropertyValue("dischargePort", wsPort);
	wsBooking.setPropertyValue("bookingReference", BOOKING);
	wsBooking.setPropertyValue("voyageCode", _voyage.code);
	wsBooking.setPropertyValue("vesselCode", _voyage.vesselCode);
	wsBooking.allBookingItems.add(wsBookingItem);
	
	// Web service call
	create request transient;
	request.setPropertyValue('myBooking', wsBooking);
	
	create webService transient;
	response := webService.createBooking(request);
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBookingMaint.name; 

epilog


	delete response;
	delete webService;
	delete request;
	
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsBookingRelReqMaint" id="29f8c4db-35b1-482e-9ad9-d2a7898d25ef">
        <source>wsBookingRelReqMaint( _carrier : CM_Carrier; _operator : CM_Operator; _voyage : CM_Voyage ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/01/2026	navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/
constants

	BOOKING			: String = "UTMCBK01";

vars

	ref 			: String;

	webService ,
	webServiceUpdate,
	webserviceFind	: JMTUserInterfaceService;	
	request,
	requestUpdate	: WS_BookingUpdateRequest;
	requestFind     : WS_BookingQueryRequest;
	response, 
	responseUpdate,
	responseFind		: WS_Response; 
	
	wsBooking,
	wsBookingUpdate : WS_Booking;
	wsCarrier		: WS_Carrier;
	wsOperator		: WS_Operator;
	wsBookingStatus	: WS_BookingStatus;
	wsPort			: WS_Port;
	wsBookingItem,
	wsBookingItemUpdate: WS_BookingItem;
	wsCargoType		: WS_CargoType;
	wsISOType		: WS_ISOType;
	wsCommodity		: WS_Commodity;
	wsBulkRelease	: WS_BulkRelease;
	wsMyLoadPort	: WS_Port;
	
begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	// Create Booking
	// Booking related objects
	create wsCarrier transient;
	wsCarrier.setPropertyValue("code", _carrier.code);
	
	create wsOperator transient;
	wsOperator.setPropertyValue("code", _operator.code);
	
	create wsBookingStatus transient;
	wsBookingStatus.setPropertyValue("id", BOOKING_REF_ACTIVE);
	
	create wsPort transient;
	wsPort.setPropertyValue("code", "NZLYT");
	
	// Booking item related objects
	create wsCargoType transient;
	wsCargoType.setPropertyValue("id", 1);
	
	create wsISOType transient;
	wsISOType.setPropertyValue("code", "2200");
	
	create wsCommodity transient;
	wsCommodity.setPropertyValue("code", "GENL");
	
	create wsMyLoadPort transient;
	wsMyLoadPort.setPropertyValue("code", "NZLYT");
	
	create wsBookingItem transient;
	wsBookingItem.setPropertyValue("cargoType", wsCargoType);
	wsBookingItem.setPropertyValue("isoType", wsISOType);
	wsBookingItem.setPropertyValue("commodity", wsCommodity);
	wsBookingItem.setPropertyValue("quantity", 5);
	wsBookingItem.setPropertyValue("clean", true);
	wsBookingItem.setPropertyValue("grade", 17);
	wsBookingItem.setPropertyValue("heavyRated", true);
	wsBookingItem.setPropertyValue("inspected", true);
	wsBookingItem.setPropertyValue("maxToRelease", 5);
	
	
	create wsBulkRelease transient;
	wsBulkRelease.setPropertyValue("noFullsIn", true);
	wsBulkRelease.setPropertyValue("transType", 1);
	wsBulkRelease.setPropertyValue("deliveryReasonCode", 100);
	wsBulkRelease.setPropertyValue("myLoadPort", wsMyLoadPort);
	
	
	// Booking
	create wsBooking transient;
	wsBooking.setPropertyValue("carrier", wsCarrier);
	wsBooking.setPropertyValue("operator", wsOperator);
	wsBooking.setPropertyValue("status", wsBookingStatus);
	wsBooking.setPropertyValue("dischargePort", wsPort);
	wsBooking.setPropertyValue("bookingReference", BOOKING);
	wsBooking.setPropertyValue("voyageCode", _voyage.code);
	wsBooking.setPropertyValue("vesselCode", _voyage.vesselCode);
	wsBooking.setPropertyValue("bulkRelease", wsBulkRelease);
	wsBooking.allBookingItems.add(wsBookingItem);
	
	// Web service call
	create request transient;
	request.setPropertyValue('myBooking', wsBooking);
	
	create webService transient;
	response := webService.createBooking(request);
	
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	//findBookings method test
	// Create the query request
	create requestFind transient;
	requestFind.setPropertyValue('maxReturnedItems', 20);
	requestFind.setPropertyValue('filterBooking', 'UTMCBK01');	
	
	create webserviceFind transient;
	responseFind := webserviceFind.findBookings(requestFind);	
	
	if responseFind = null then
		return "test 3, find response not returned.";
	endif;
	if responseFind.hasErrors then
		return "test 4, " &amp; responseFind.getErrorsAsStringForTesting;
	endif;
	
	// Verify we got the booking back from find
	if responseFind.WS_BookingQueryResponse.allBookings.size = 0 then
		return "test 5, no bookings found after create.";
	endif;
	
	// Get the created booking and its item to obtain the cmObjectId for update
	wsBookingUpdate := responseFind.WS_BookingQueryResponse.allBookings.first;
	if wsBookingUpdate = null then
		return "test 6, booking not found in results.";
	endif;
	if wsBookingUpdate.allBookingItems.size = 0 then
		return "test 7, no booking items found in created booking.";
	endif;
	
	// Get the first booking item's OID for the update
	wsBookingItemUpdate := wsBookingUpdate.allBookingItems.first;
	
	// Now update the booking item properties for testing update
	wsBookingItemUpdate.setPropertyValue("grade", 9);  // Change grade from 17 to 9
	wsBookingItemUpdate.setPropertyValue("quantity", 7);  // Change quantity from 5 to 7
		
	// Note: wsBookingUpdate and wsBookingItemUpdate already contain the correct
	// booking reference, cmObjectId, and other properties from the find result*/
	
	// Web service call
	create requestUpdate transient;
	requestUpdate.setPropertyValue('myBooking', wsBookingUpdate);
	
	create webServiceUpdate transient;
	responseUpdate := webServiceUpdate.updateBooking(requestUpdate);
	
	if responseUpdate = null then
		return "test 8, update Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		return "test 9, " &amp; responseUpdate.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBookingRelReqMaint.name; 

epilog
		
	delete response;
	delete responseUpdate;
	delete webService;
	delete webserviceFind;
	delete webServiceUpdate;
	delete request;
	delete requestFind;
	delete requestUpdate;
	delete responseFind;
	
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsBulkReleaseById" id="89f88eba-3efc-46bb-9973-503bd3564be7">
        <source>wsBulkReleaseById() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2015	cnwdb2	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/

vars

	ref 				: String;
	
	bulkRelease			: WS_BulkRelease;
	webService 			: JMTUserInterfaceService;
	request  			: 	WS_BulkReleaseUpdateRequest ; 
	response			: WS_Response ; 
	responseUpdate 		: 	WS_BulkReleaseUpdateResponse ; 
	bulkType 			: WS_BulkReleaseType ; 
	bulkReserve			:  WS_ReserveTI ; 
	bulkOperator 		: WS_Operator ; 
	bulkSubTeminal 		: WS_SubTerminal ; 
	realBulkRelease 	: CM_BulkRelease ; 
	bulkCargoType 		: WS_CargoType ; 
	
		
begin
	
	// Test1 
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 
	
	//create the bulk Release by id
	create bulkReserve transient ; 
	bulkReserve.setPropertyValue("cargoID","UTP_MJC111") ; 
	bulkReserve.setPropertyValue("cargoType",bulkCargoType) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","DOUG") ; 
	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel") ; 
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	
	bulkRelease.allReserveDetails.add(bulkReserve) ; 
	
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	
	
	create webService transient;
	response := webService.createBulkRelease(request);

	if response = null then
		return "test 1, response not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;

	
	//delete all the crap
	delete response;
	delete request ; 


	//Test 2 Update
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel") ; 

	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	bulkType := bulkRelease.type;
	if bulkType &lt;&gt; null then
		bulkType.setPropertyValue("id",2) ;
	endif;
	
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	

	responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;	

	if responseUpdate = null then
		return "test 3, updated Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		return "test 4, " &amp; responseUpdate.getErrorsAsStringForTesting;
	endif;
	
	if bulkType &lt;&gt; null then
	//	delete bulkType ; 
	endif ;
	
	delete responseUpdate;
	delete request ; 

	
	// TEST 3 delete the Bulk Release	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel") ; 
	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1

	//update the values
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	
	// make the delete call
	response := webService.deleteBulkRelease(request) ; 
	// check the response again
	if response = null then
		return "test 5, response not returned.";
	endif;
	if response.hasErrors then
		return "test 6, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel") ; 
	if realBulkRelease &lt;&gt; null then
		return "test 7, code group not deleted" ; 
	endif; 	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBulkReleaseById.name;

epilog
	delete response;
	delete request ; 
	delete webService ; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsBulkReleaseByType" id="a2227c0e-ea64-4541-986c-ae158d7c5159">
        <source>wsBulkReleaseByType(): String;
/*

Purpose:			
	Create a bulk release by type
Parameters:			

Return Value:		

Date		Who		Reason
28 January 2015	cnwdb2	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/

vars

	ref 					: String;
	
	bulkRelease				: WS_BulkRelease;
	webService 				: JMTUserInterfaceService;
	request  				: 	WS_BulkReleaseUpdateRequest ; 
	response				: WS_Response ; 
	responseUpdate 			: 	WS_BulkReleaseUpdateResponse ; 
	bulkType 				: WS_BulkReleaseType ; 
	bulkReserve				:  WS_ReserveTI ; 
	bulkOperator 			: WS_Operator ; 
	bulkSubTeminal 			: WS_SubTerminal ; 
	realBulkRelease 		: CM_BulkRelease ; 
	bulkCargoType 			: WS_CargoType ; 
	bulkReserveSelection 	: WS_ReserveSelection ; 
	bulkISOType				:	WS_ISOType ; 

	
		
begin
	
	// Test1 CREATE
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","DOUG") ; 
	
	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel2") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 

	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	
	
	create webService transient;
	response := webService.createBulkRelease(request);

	if response = null then
		return "test 1, response not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;

	//delete all the crap
	delete response;
	delete request ; 


	//Test 2 Update
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel2") ; 

	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	bulkType := bulkRelease.type;
	if bulkType &lt;&gt; null then
		bulkType.setPropertyValue("id",2) ;
	endif;
	
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	

	responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;	

	if responseUpdate = null then
		return "test 3, updated Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		return "test 4, " &amp; responseUpdate.getErrorsAsStringForTesting;
	endif;
		
	delete responseUpdate;
	delete request ; 

	
	// TEST 3 delete the Bulk Release	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel2") ; 
	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1

	//update the values
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	
	// make the delete call
	response := webService.deleteBulkRelease(request) ; 
	// check the response again
	if response = null then
		return "test 5, response not returned.";
	endif;
	if response.hasErrors then
		return "test 6, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel2") ; 
	if realBulkRelease &lt;&gt; null then
		return "test 7, code group not deleted" ; 
	endif; 	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBulkReleaseByType.name; 

epilog
	delete response;
	delete request ; 
	delete webService ; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsBulkReleaseByTypeCarrierDAG" id="dc9190fb-7a40-400b-8f7e-666dc3b0df55">
        <source>wsBulkReleaseByTypeCarrierDAG(): String;
/*

Purpose:			
	Create a bulk release by type
Parameters:			

Return Value:		

Date		Who		Reason
25/9/17		jlgmp6	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
21/08/2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
*/
constants
	CarrierId				: String = "UTVSS";
	
vars

	ref 					: String;
	
	bulkRelease				: WS_BulkRelease;
	webService 				: JMTUserInterfaceService;
	request  				: 	WS_BulkReleaseUpdateRequest ; 
	response				: WS_Response ; 
	responseUpdate 			: 	WS_BulkReleaseUpdateResponse ; 
	bulkType 				: WS_BulkReleaseType ; 
	bulkReserve				:  WS_ReserveTI ; 
	bulkOperator 			: WS_Operator ; 
	bulkSubTeminal 			: WS_SubTerminal ; 
	realBulkRelease 		: CM_BulkRelease ; 
	bulkCargoType 			: WS_CargoType ; 
	bulkReserveSelection 	: WS_ReserveSelection ; 
	bulkISOType				: WS_ISOType ; 
	bulkCarrier				: WS_Carrier;
	carrier					: CM_Carrier;
	dac						: CM_DataAccessController;
	carrierSet : CM_CarrierSet;		
	cargoType : CM_CargoType;
	operator : CM_Operator;
	pxyCriteria : CM_YACriteria;
	criteria : CMIF_Array;						// TFS 45836
	cmifCriterion : CMIF_YACriteriaPriority;	// TFS 45836
	pxyOpCrit : CM_OperatorCarrierCriteria;		// TFS 45836
	realOpCrit : CM_ObjectMatchCriteria;		// TFS 45836
begin
	
	operator := app.myRoot.allOperators["DOUG"];
	
	create carrierSet transient;
	create criteria transient;					// TFS 45836
	
	carrier := app.myRoot.allCarriers["UT_OTHER"];
	carrierSet.add(carrier);
	cargoType := app.myRoot.allCargoTypesById[1];								// TFS 45836
	create pxyCriteria transient;												// TFS 45836
	pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], cargoType.getYAIdentifier, "Cargo Type");	// TFS 45836
	cmifCriterion := pxyCriteria.getTransient();								// TFS 45836
	criteria.add(cmifCriterion);												// TFS 45836
	create pxyOpCrit transient;													// TFS 45836
	pxyOpCrit.setProxy(criteria, null);											// TFS 45836
	carrierSet.copy(pxyOpCrit.allCarriers);										// TFS 45836
	pxyOpCrit.setMyOperator(operator);											// TFS 45836
	app.myTrxCA.trxCreateObjMatchCrit(pxyOpCrit, realOpCrit, app.myPassport);	// TFS 45836
	if operator.allOperatorCarrierCriteria.size &lt;&gt; 1 then						// TFS 45836
		return "Operator has no carrier criteria";								// TFS 45836
	endif;																		// TFS 45836
	//app.myTrxUA.trxUpdateOperatorAdvSettings(operator, null, null, carrierSet, carrierCargoType, app.myPassport);		// TFS 45836
		
	// Test1 CREATE
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","DOUG") ; 

	create bulkCarrier transient ; 
	bulkCarrier.setPropertyValue("code", CarrierId);

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel3") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 
	bulkRelease.setPropertyValue("carrier", bulkCarrier);
	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	
	
	create webService transient;
	response := webService.createBulkRelease(request);

	if response = null then
		return "test 1, response not returned.";
	endif;
	if response.allErrors.size &gt; 0 then
		if response.getErrorsAsStringForTesting.pos("90924", 1) = 0 then
			return "test 2, " &amp; response.getWarningsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the update without a carrier
			//delete bulkCarrier;
		//	delete response;
		//	response := webService.createBulkRelease(request);
		endif;
	else
		return "test 2, error 90495 should have occurred";
	endif;

	
	//delete all the crap
	delete response;
	delete request ; 

	//create without a carrier 
	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","DOUG") ; 

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel3") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 

	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	response := webService.createBulkRelease(request);
	if response = null then
		return "test 2b, updated Response not returned.";
	else 
		if response.hasErrors then
			return "test 2b created without carrier has errors";
		endif;
	endif;
	
	//delete all the crap
	delete response;
	delete request ; 
	
	//Test 2 Update
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel3") ; 

	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	bulkType := bulkRelease.type;
	if bulkType &lt;&gt; null then
		bulkType.setPropertyValue("id",2) ;
	endif;
	
	create bulkCarrier transient;		// reinstate the dodgy carrier
	bulkCarrier.setPropertyValue("code", CarrierId);
	bulkRelease.setPropertyValue("carrier", bulkCarrier);

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	

	responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;

	if responseUpdate = null then
		return "test 3, updated Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		if responseUpdate.getErrorsAsStringForTesting.pos("90924", 1) = 0 then
			return "test 4, " &amp; responseUpdate.getErrorsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the delete without a carrier	
			//delete responseUpdate;
			//responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;
		endif;
	else
		return "test 4, error 90495 should have occurred";
	endif;
	
	
	delete responseUpdate;
	delete request ; 

	
	// TEST 3 delete the Bulk Release	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel3") ; 
	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1

	//update the values
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	
	// make the delete call
	response := webService.deleteBulkRelease(request) ; 
	// check the response again
	if response = null then
		return "test 5, response not returned.";
	endif;
	if response.hasErrors then
		return "test 6, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel3") ; 
	if realBulkRelease &lt;&gt; null then
		return "test 7, code group not deleted" ; 
	endif; 	
	

	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBulkReleaseByTypeCarrierDAG.name; 

epilog

	if process.isInTransactionState then
		abortTransaction;
	endif;	
	beginTransaction;
	operator.allOperatorCarrierCriteria.purge;						// TFS 45836
	commitTransaction;

	delete response;
	//delete bulkRelease ;
	delete request ; 
	delete webService ; 
	delete carrierSet;
	if criteria &lt;&gt; null then										// TFS 45836
		criteria.purge;												// TFS 45836
	endif;															// TFS 45836
	delete criteria;												// TFS 45836
	delete pxyOpCrit;												// TFS 45836
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsBulkReleaseByTypeCarrierDAG2" id="b60cc098-47a8-4aa9-ade4-d93fc99d019f">
        <source>wsBulkReleaseByTypeCarrierDAG2(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2018	jlgns1	Initial creation

*/

constants
	CarrierId				: String = "UTVSS";
	
vars

	ref 					: String;
	
	bulkRelease				: WS_BulkRelease;
	webService 				: JMTUserInterfaceService;
	request  				: 	WS_BulkReleaseUpdateRequest ; 
	response				: WS_Response ; 
	responseUpdate 			: 	WS_BulkReleaseUpdateResponse ; 
	bulkType 				: WS_BulkReleaseType ; 
	bulkReserve				:  WS_ReserveTI ; 
	bulkOperator 			: WS_Operator ; 
	bulkSubTeminal 			: WS_SubTerminal ; 
	realBulkRelease 		: CM_BulkRelease ; 
	bulkCargoType 			: WS_CargoType ; 
	bulkReserveSelection 	: WS_ReserveSelection ; 
	bulkISOType				: WS_ISOType ; 
	bulkCarrier				: WS_Carrier;
	carrier					: CM_Carrier;
	dac						: CM_DataAccessController;
			

	mess	: String;
begin
	carrier := app.myRoot.allCarriers[CarrierId];
	dac := app.myRoot.allDataAccessControllers["CM_Operator", CarrierId];
	if not carrier.allDataAccessControllersRel.includes(dac) then
		if dac &lt;&gt; null then
			beginTransaction;
			carrier.allDataAccessControllersRel.add(dac);
			commitTransaction;
		endif;
	endif;
		

	// Test1 CREATE
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","123") ; 

	create bulkCarrier transient ; 
	bulkCarrier.setPropertyValue("code", CarrierId);

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel4") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 
	bulkRelease.setPropertyValue("carrier", bulkCarrier);
	
	
	
	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	
	
	create webService transient;
	response := webService.createBulkRelease(request);

	if response = null then
		return "test 1, response not returned.";
	endif;
	if response.hasErrors then
		mess := response.getErrorsAsStringForTesting;
		//if response.getErrorsAsStringForTesting.pos("90495", 1) = 0 then
		if not response.getErrorsAsStringForTesting.cnContains("90495") then
			return "test 2, " &amp; response.getErrorsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the update without a carrier
			//delete bulkCarrier;
		//	delete response;
		//	response := webService.createBulkRelease(request);
		endif;
	else
	return "OP_" &amp; bulkOperator.code &amp; " CA_" &amp; bulkCarrier.code;
		return "test 2, error 90495 should have occurred";
	endif;

	
	//delete all the crap
	delete response;
	delete request ; 

	//create without a carrier 
	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","123") ; 

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel4") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 

	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	response := webService.createBulkRelease(request);
	if response = null then
		return "test 2b, updated Response not returned.";
	else 
		if response.hasErrors then
			return "test 2b created without carrier has errors";
		endif;
	endif;
	
	//delete all the crap
	delete response;
	delete request ; 
	
	//Test 2 Update
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel4") ; 

	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	bulkType := bulkRelease.type;
	if bulkType &lt;&gt; null then
		bulkType.setPropertyValue("id",2) ;
	endif;
	
	create bulkCarrier transient;		// reinstate the dodgy carrier
	bulkCarrier.setPropertyValue("code", CarrierId);
	bulkRelease.setPropertyValue("carrier", bulkCarrier);

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	

	responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;

	if responseUpdate = null then
		return "test 3, updated Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		if responseUpdate.getErrorsAsStringForTesting.pos("90495", 1) = 0 then
			return "test 4, " &amp; responseUpdate.getErrorsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the delete without a carrier	
			//delete responseUpdate;
			//responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;
		endif;
	else
		return "test 4, error 90495 should have occurred";
	endif;
	
	
	delete responseUpdate;
	delete request ; 

	
	// TEST 3 delete the Bulk Release	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel4") ; 
	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	//update the values
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	
	// make the delete call
	response := webService.deleteBulkRelease(request) ; 
	// check the response again
	if response = null then
		return "test 5, response not returned.";
	endif;
	if response.hasErrors then
		return "test 6, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel4") ; 
	if realBulkRelease &lt;&gt; null then
		return "test 7, code group not deleted" ; 
	endif; 	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsBulkReleaseByTypeCarrierDAG2.name; 
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	beginTransaction;
	carrier.allDataAccessControllersRel.clear();						// TFS 45836
	commitTransaction;
	delete response;
	//delete bulkRelease ;
	delete request ; 
	delete webService ; 

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCargoMerge" id="20f8e74b-a8d3-4966-ab27-3bd8c121fd5c">
        <source>wsCargoMerge(_cargoTarget : CM_TrackedItem input; _cargoChild :CM_TrackedItem input ; _xtraTestString : String ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2016	cnwns1	Initial creation

*/

vars
	ref : String;
	
	webService : JMTUserInterfaceService;
	request	: WS_CargoMergeRequest;
	response : WS_Response;
	cargosToMerge : StringArray;
	invalidObject : Boolean;
begin
		on Exception do app.handleDeletedObject( exception, response, invalidObject );


	// Web service call
	create request transient;
	create cargosToMerge  transient;
	
	request.setPropertyValue(WS_CargoMergeRequest::cargoOid.name, _cargoTarget.getOidString);
	cargosToMerge.add(_cargoChild.getOidString);
	request.setPropertyValue(WS_CargoMergeRequest::mergeItems.name, cargosToMerge);
	
	create webService transient;
	response := webService.doMergeCargo(request);
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	if response.hasErrors then
		return _xtraTestString &amp; ", " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCargoMerge.name; 

epilog
	delete response;
	delete request ;
	delete cargosToMerge;
	delete webService;
end;</source>
        <Parameter name="_cargoTarget" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_cargoChild" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_xtraTestString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCheckWhiteListedMethods" id="c4643320-c7e0-4d47-9f9b-704a5f1c2b8a">
        <source>wsCheckWhiteListedMethods(_errors : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 July 2024		navmd1	Initial creation TFS 62228
03 October 2024		navsck1	MTN-32997 Move missed changes to WMast and test for defect ADO 65557
*/

vars
	ref			: String;
	webconfig	: CM_WebSiteConfig;
	user		: CM_User;
	session		: SWebServiceSchema;
	provider	: WS_WebServiceProvider;
	checkUser	: Boolean;
	methodName	: String;
	oa			: ObjectArray;
	obj			: Object;
begin
	// This could be any user, but may as well use whatever is set on the default config
	webconfig := app.myRoot.allWebSiteConfigs['WebServiceDefault'];
	if webconfig = null then
		return "Web Site Config 'WebServiceDefault' not found";
	endif;
	user := app.myRoot.allUsers[webconfig.publicUser];
	if user = null then
		return "Web Site Config as no or invalid Public User defined";
	endif;
	
	create session transient;
	session.setMyUser(user);
	checkUser := true;
	
	create provider	as JMTSecureService transient;
	provider.unitTestData.addAssoc("currentSession", session);
	provider.unitTestData.addAssoc("myPublicUser", user);
	
	// While the SOAP login requests still send in the anonymous session id to a login requests
	// We have to make sure that we don't reject those. (even if it shouldn't actually be doing that)
	
	// JMTSecureService
	methodName := JMTSecureService::logon.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::logonAsAnonymousUser.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::logonWithRequest.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::resetPassword.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::forceOffOldSessions.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::logonAndChangePassword.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTSecureService::logout.name;
