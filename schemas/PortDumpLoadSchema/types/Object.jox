    <JadeMethod name="theKey" id="5c6da2b6-2a52-4a79-959d-821e9c95e82f">
        <source>theKey():String;

vars
	str: String;
	property: Property;
begin
	property := self.class.findProperty("code");
	if property = null then
		property := self.class.findProperty("id");
	endif;
	if property = null then
		property := self.class.findProperty("type");
	endif;
	if property = null then
		property := self.class.findProperty("name");
	endif;
	if property = null then
		property := self.class.findProperty("description");
	endif;
	if property = null then
		property := self.class.findProperty("label");
	endif;
	if property = null then
		property := self.class.findProperty("createdTime");
	endif;
	if property = null then
		str := self.getInstanceIdForObject(self).String;
		if class &lt;&gt; CM_Root then
			app.writeLog("no key for "&amp;self.class.name, 0);
		endif;
	else
		str := self.getPropertyValue(property.name).String.trimBlanks();
	endif;
	return str; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
