    <JadeMethod name="canDoSplitOrRoll" id="775ab80a-0ace-4b6d-959e-ff36e2aa644c">
        <source>canDoSplitOrRoll(_coll :ObjectArray):Boolean protected;
/*
Purpose:			
Parameters:			
Return Value:	true if no bookings in _coll are closed or rolled	

Date			Who		Reason
========================================================
25 March 2010	cnwcs5	par 22602 - 
*/

vars
	obj		:Object;
	invalid	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, invalid);

	foreach obj in _coll do
		//if obj.CM_BookingRef.isRolledOrClosed then			// 04/05/2012 cnwar2 #29484
		if obj.CM_BookingRef.status = BOOKING_REF_CLOSED then	// 04/05/2012 cnwar2 #29484
			return false;
		endif;
		if invalid then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
