    <JadeMethod name="getServiceRateOwner" id="19b5a579-0fd9-4f31-b12d-8e797f994fbc">
        <source>getServiceRateOwner(service : CM_Service) : CM_LineGroupDebtor;

vars
	rate : CM_Rate;

begin

	rate := self.serviceRates[service];
	if rate &lt;&gt; null then
		return self;
	else
		return null;
	endif;

end;</source>
        <Parameter name="service" type="CM_Service"/>
        <ReturnType type="CM_LineGroupDebtor"/>
    </JadeMethod>
    <JadeMethod name="getServiceTimeRate" id="027368a6-3857-4166-aba6-e894a6555d3b">
        <source>getServiceTimeRate(company : CM_Bank; service : CM_Service; ts : TimeStamp) : CM_RateEntry;

vars
	rateEntry : CM_RateEntry;
	rate : CM_Rate;

begin

	rate := self.serviceRates[service];
	if rate &lt;&gt; null then
		rateEntry := rate.getTimeRate(company, ts);
	endif;
	if rateEntry &lt;&gt; null then
		return rateEntry;
	else
		return self.debtor.getServiceTimeRate(service, ts);
	endif;

end;</source>
        <Parameter name="company" type="CM_Bank"/>
        <Parameter name="service" type="CM_Service"/>
        <Parameter name="ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="92cd19be-a437-4051-b4a0-a8ce704de0d6">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	tmpLineGroupDebtor : CM_LineGroupDebtor;
	completedOK		: Boolean;
begin
	tmpLineGroupDebtor := inheritMethod();
	tmpLineGroupDebtor.debtor := self.debtor;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpLineGroupDebtor;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpLineGroupDebtor;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCode" id="2e20c993-9bbe-412a-9ca4-2eb2596636f1">
        <updating/>
        <source>setCode(_newCode: String) updating;
//----------------------------------------------------------------
//	Created:	08 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	valCode	: String;
begin

	if self.shipPortGroup &lt;&gt; null
	and self.shipPortGroup.shippingLine &lt;&gt; null
	and self.debtor &lt;&gt; null then
		//check ti see if its OK
		valCode := self.shipPortGroup.shippingLine.code.trimBlanks &amp; ' ' &amp; self.shipPortGroup.code.trimBlanks &amp; ' ' &amp; self.debtor.name.trimBlanks;
	
	endif;

	if valCode &lt;&gt; null
	and valCode &lt;&gt; _newCode then
		app.raiseUnexpectedProgramError(class.name, method.name, "the LGD code is being set to something that doesn't match the current references.");
	endif;
	
	self.code := _newCode;
	
	
end;</source>
        <Parameter name="_newCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="48768b9d-5231-49a4-b71e-273f653da248">
