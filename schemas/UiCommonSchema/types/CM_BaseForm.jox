    <JadeMethod name="doResize" id="c154c8a6-65d3-48c9-80dd-3e2e642fda12">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     Called on load and after a resize to position the
//				controls on the form correctly.
//				Should be overridden for each form.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/7/2010	cnwjo3		was attempting to resize 400 invisible controls on each resize!
// ---------------------------------------------------------------------------
vars
	tmpControl	: Control;
	tmpParent1,
	tmpParent2	: Window;
	numControls,
	i			: Integer;
begin
	// Then reposition or resize all the controls as necessary
	numControls := self.controlCount;
	
	foreach i in 1 to numControls do
		tmpControl := self.controls(i);

		tmpParent1 := tmpControl.parent;
	
		if CMUI_SplitContainer.hasInstance(tmpParent1) or
		   CMUI_ScrollableDrawingFrame.hasInstance(tmpParent1) or
		   CMUI_DrawingFrame.hasInstance(tmpParent1) then
		   	continue;
		endif;
		if Control.hasInstance(tmpParent1) then
			tmpParent2 := tmpParent1.Control.parent;
			if CMUI_SplitContainer.hasInstance(tmpParent2) or
			   CMUI_ScrollableDrawingFrame.hasInstance(tmpParent2) or
			   CMUI_DrawingFrame.hasInstance(tmpParent2) then
			   	continue;
			endif;
		endif;

		tmpControl.repositionAfterResize();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeColumnWidths" id="9f732c98-4db7-4cf6-9e33-f5426e580787">
        <source>doResizeColumnWidths(table : Table input; allowForScrollBar : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		04 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Purpose:		Resizes columns based on their original size
// ---------------------------------------------------------------------------

constants
	TableBorderWidth = 2;
	
vars
	totalWidth : Integer;
	colWidth, colWidthHdr, halfCols : Integer;
	col : Integer;
	tblWidth : Integer;
	jCol : JadeTableColumn;
	tmpW, scrollWidth : Integer;
	invalidTable : Boolean;
	
begin

    on Exception do app.handleDeletedObject(exception, table, invalidTable); // cnwrd1 13.3.09 par 18837
 
	if allowForScrollBar then
		scrollWidth := app.getVerticalScrollbarWidth;
	else
		scrollWidth := 0;
	endif;
	
	totalWidth := table.width.truncated - scrollWidth - TableBorderWidth;
	
	// cnwrd1 13.3.09 par 18837
	// not a valid table any more cant resize columns!
	if invalidTable then 
       return;
    endif;
	
	colWidthHdr := (totalWidth * .20).Integer;
	halfCols := (table.columns / 2).Integer;
	
// cnwdad1 23/06/2006 - Was getting division by zero exception on Terminal Area Enquiry form.
//	colWidth :=  ((totalWidth - (colWidthHdr * halfCols)) / halfCols).Integer ;
	if halfCols = 0 then
		colWidth :=  totalWidth;
	else
		colWidth :=  ((totalWidth - (colWidthHdr * halfCols)) / halfCols).Integer;
	endif;
//	colWidth := (totalWidth / table.columns).truncated;

	foreach col in table.fixedColumns + 1 to table.columns do
		jCol := table.accessColumn(col);
		tmpW := tmpW + jCol.width;

		if not jCol.visible then
			// Ignore invisible columns
			continue;
		endif;
		if col mod 2 = 0 then
			jCol.width := colWidth;
		else
			jCol.width := colWidthHdr;
		endif;	
		tblWidth := tblWidth + jCol.width;
	endforeach;
	
	// Apply any rounding error difference to the last column
	jCol := table.accessColumn(table.columns);
	jCol.width := jCol.width + totalWidth - tblWidth;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="allowForScrollBar" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAsSystemDefault" id="dad30ae0-b16d-4159-8efe-d252e65d73bc">
        <source>doSaveAsSystemDefault() protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;
	user			: CM_User;
	toolbarRoot		: CM_MenuRootForRoot;		
	menuEntity		: CM_MenuEntity;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	user := app.getMyUser;
	
	create agent transient;
	create toolbarRoot transient;
	
	foreach menuEntity in user.myMenuUserToolbarRoot.allMenuUserToolbarItems do
		toolbarRoot.allChildren.add(menuEntity);
	endforeach;
	
	agent.trxSaveToolbarMenuAsSysDefault(toolbarRoot);
	
epilog
	delete agent;	
	delete toolbarRoot;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
