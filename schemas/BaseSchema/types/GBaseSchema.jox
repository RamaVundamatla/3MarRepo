//				method, I can easily find work that I have not finished or need
//				to revisit.
begin
end;</source>
    </JadeMethod>
    <JadeMethod name="ecWriteServerFile" id="b35175ed-0a61-42ed-b7ae-0280cdb745ef">
        <source>ecWriteServerFile(param:Integer; message:String);
//	Description :	Cause a notification for server file write
//					'message' contains data to be written.
//
//					This is used to write to the log file and
//					to the server event files - these files
//					are maintained on the server, so the File
//					instance is in the server's transient database.
begin
	causeEvent(param, true, message);
end;</source>
        <Parameter name="param" type="Integer"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
</Class>
