    <JadeMethod name="setToDoTaskComplete" id="52f82c54-96d2-4f09-8252-01e176bae23f">
        <updating/>
        <source>setToDoTaskComplete( _toDoTask : CM_ToDoTask) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	nextTask 	: CM_WorkOrderDtl;
	parent	 	: CM_WorkOrderToDo;
	doComplete  : Boolean;
	job			: CM_Job;
	wle			: CM_WorkListEntry;
begin
	
	if _toDoTask = null then
		return;
	endif;
	
	parent := self.getMyParent.CM_WorkOrderToDo;
	
	// remove from available
	if self.allToDoTasks.includes( _toDoTask) then
		self.allToDoTasks.remove( _toDoTask);
	endif;		
	
	if self.isFirstTask and parent.taskStatus = WO_STATUS_APPROVED then
		parent.setTaskStatus(WO_STATUS_PARTCOMPLETE);
	endif;

	if self.allToDoTasks.isEmpty then
		self.setStatus(WO_STATUS_COMPLETE);
		if self.isLastTask  then
			self.completeMe();
		endif;
	else
		self.setStatus(WO_STATUS_PARTCOMPLETE);
	endif;

	//jlier1 29/5/25 MTN-34591 
	parent.causeTerminalEvent(Event_WorkOrder_Update);
	
epilog

end;</source>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="1730cb07-9147-429c-be4d-43288a2a6ba2">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1if	propName = CM_WorkOrderToDoDtl::overrideCalcType.name		or 
	if	propName = CM_WorkOrderToDoDtl::priority.name   			
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="19ad6beb-b485-4ecb-a006-893372de1d1e">
        <source>validate() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2022	navhl20	Task 56057(54344): WodToDoDetail validation

*/

vars
	bank : CM_Bank;
begin
	inheritMethod();
	
	if self.allToDoTasksDescs.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(To_Do_Task_description), null, null); 
	endif;
	
	// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null 
	and self.contractId &lt;&gt; null then
		bank := self.getMyBank();
		if bank &lt;&gt; null then
			if self.myDebtor.allInvoiceContracts[bank,self.contractId] = null then
				app.raiseCMWarning3(Contrac_not_valid_debtor,self.getTypeDescription, self.contractId, self.myDebtor.name,null,null, null);
			endif;
		else
			if self.myDebtor.getContractById(self.contractId) = null then
				app.raiseCMWarning3(Contrac_not_valid_debtor,self.getTypeDescription, self.contractId, self.myDebtor.name,null,null, null);
			endif;
		endif;
	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
