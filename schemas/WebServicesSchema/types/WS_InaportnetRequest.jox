    <JadeMethod name="getVoyage" id="6fc8872b-f078-4a12-b60e-1707c186a221">
        <source>getVoyage() : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2019	jlger1	Initial creation

*/

vars

begin
    if app.myPassport.myTerminal = null then
		return null;
	endif;
	
	return app.myPassport.myTerminal.allVoyagesByExternalCode[self.getExtVoyageCode];

end;
</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
