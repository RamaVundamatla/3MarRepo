    <JadeMethod name="jadeScript" id="c9155d3c-24ee-43d9-9a2a-9f5c885feb45">
        <source>jadeScript();
//----------------------------------------------------------------
//	Created:	21 June 2004	by Jason Chapman  (cnwjc2)
//
//
// Called from application JadeScript
// DO NOT CHANGE THIS METHOD - make changes to jadeScript::appJadeScript
//
vars
	js	: JadeScript;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";
	create js transient;
	/////////////////////
//	cnwjr2  -  commented out next line as it called a JadeScript method - these methods were deleted 12/12/2011 - temporarily in DummySchema
	js.appJadeScript();
	////////////////////
	userExitCode := 0;	
	fileMessage := "completedOK";
	file.writeLine(fileMessage);
epilog
	file.close;
	delete file;
	delete js;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	app.finalize;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="jmtLicenseApp" id="42145cdb-b372-4782-bf1a-b73db52aaf94">
        <source>jmtLicenseApp();
//
// par 19941 cnwrs1 June 2009
//
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	form : CMS_Modal;
	txtLicenseName : TextBox;
	txtLicenseKey : TextBox;
	cmbLicenseFor : ComboBox;
	productCode : String;
	productStr : String;
	label1 : Label;
	label2 : Label;
	msg : String;
	error : CM_Error;
begin
	app.initialize;
	if app.myRoot = null then
		app.msgBox("The License Key setting is not possible in this database ", "ERROR", 0);
		return;
	endif;
	create form transient;
	form.caption:= "JMT License Application.";
	form.width := form.width + 290;
	create cmbLicenseFor transient;
	form.addControl(cmbLicenseFor);
	cmbLicenseFor.move(5, 5, 350, cmbLicenseFor.height);
	create label1 transient;
	label1.caption := "License Name :";
	label1.parent := form;
	label1.transparent := true;
	form.addControl(label1);
	label1.move(5, cmbLicenseFor.top + cmbLicenseFor.height + 5, 100, label1.height);
	create txtLicenseName transient;
	txtLicenseName.parent := form;
	txtLicenseName.alignment := TextBox.Alignment_Left;
	txtLicenseName.visible := true;
	txtLicenseName.tabIndex := 0;
	form.addControl(txtLicenseName);
	txtLicenseName.move(5, label1.top + label1.height + 10, 350, txtLicenseName.height);
	create label2 transient;
	label2.caption := "License Key :";
	label2.parent := form;
	label2.transparent := true;
	form.addControl(label2);
	label2.move(5, txtLicenseName.top + txtLicenseName.height + 10, 100, label2.height);
	create txtLicenseKey transient;
	txtLicenseKey.parent := form;
	txtLicenseKey.alignment := TextBox.Alignment_Left;
	txtLicenseKey.visible := true;
	txtLicenseKey.tabIndex := 1;
	txtLicenseKey.scrollHorizontal := true;
	form.addControl(txtLicenseKey);
	txtLicenseKey.move(5, label2.top + label2.height + 10, 650, txtLicenseKey.height);
	txtLicenseName.setFocus();
	cmbLicenseFor.sorted := false;
	cmbLicenseFor.addItem(ProductStr_JMT);
	cmbLicenseFor.addItem(ProductStr_JMT_EDI);
	cmbLicenseFor.addItem(ProductStr_SUBS); // ### JIRA 33543 12DEC2024 NAVAB1
	cmbLicenseFor.addItem(ProductStr_EWS); // ### JIRA 33543 12DEC2024 NAVAB1
	cmbLicenseFor.listIndex := 1;
	form.btnCancel.visible := true;
	
	form.showModal();
	if form.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	productStr := cmbLicenseFor.text;
	if productStr = ProductStr_JMT then
		productCode := ProductCode_JMT;
	elseif productStr = ProductStr_JMT_EDI then
		productCode := ProductCode_JMT_EDI;
	elseif productStr = ProductStr_EWS then
		productCode := ProductCode_EWS;
	elseif productStr = ProductStr_SUBS then
		productCode := ProductCode_Subs;
	else
		app.msgBox("Unknown Product License type. Unable to continue", "ERROR", MsgBox_OK_Only);
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	app.myTrxUA.trxUpdateLicense(app.myRoot, txtLicenseName.text.trimBlanks, txtLicenseKey.text.trimBlanks, productCode, app.myRoot.edition, app.myPassport);
	if not app.myPassport.noErrors then
		foreach error in app.myPassport.allErrors do
			msg := msg&amp;error.text&amp;CrLf;
		endforeach;
		app.msgBox("The License Key setting failed."&amp;CrLf&amp;msg, "ERROR", 0);
	else
		app.msgBox("The License Key load was successful.", "FINISHED", 0);
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jmtReleaseApp" id="22324575-980a-4bb0-a50c-3318ad375cf2">
        <updating/>
        <source>jmtReleaseApp() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Jul 2008	cnwkpd1		PAR #17499 - Use app server file system so app can run thin client
//							Also need to return false if any upgrade process leaves errors
//							in the passport
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 29 Aug 2019	jlgdi1		45802	Added a method call on jtmSetSupportPW
// 19 Sep 2019	jlgzm1		TFS 46543 app_upgrade.log created in wrong location
// 21 Sep 2020  cnwma1 		ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// ---------------------------------------------------------------------------
vars
	newRelController : CnEcReleaseController;
	currVersion,
	priorVersion,
	currPatch : String;
	master : CnEcReleaseHistoryMaster;
	result,
	loadStateSet : Boolean;	
	theUser : CM_User;
	isMonthlyPatchUpgrade : Boolean;
	
begin
	self.initialize();
	
	self.cnEcInitializeBaseSchema();

	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	
	self.cmsBeginLoad(loadStateSet);
	sharedLock(self.myRoot);
	currVersion	:= self.myRoot.versionString;
	priorVersion := currVersion;
	currPatch	:= self.myRoot.patchLevel;
	self.cmsEndLoad(loadStateSet);

	app.writeLog('Processing Release - current version is (' &amp; currVersion &amp; ' ' &amp; currPatch &amp; ')', LogINFO);

	create newRelController transient;
	result := newRelController.processRelease(PortSchemaRelease, currVersion, master);
	
	result := result and app.myPassport.noErrors;		// PAR #17499
	if result then
		//epr FS 336 - monthly releases 27/5/15
		if master.myUpgrader &lt;&gt; null then
			//if we are doing a monthly release don't wipe the currPatch level
			isMonthlyPatchUpgrade:= master.myUpgrader.PortSchemaRelease.getVersionString = priorVersion;
			if not isMonthlyPatchUpgrade then
				currPatch:= null;
			endif;		
		endif;
		
		self.myTrxUA.trxCompleteRelease(master, self.myRoot, currVersion, currPatch, app.myPassport);
		result := self.myPassport.trxCompletedOK;
	endif;
	
	if result then
		beginTransaction;
		app.jmtSetSUPW(); 		// PAR 29802
		app.setJMTSupportPW();
		app.setNavOpsViewPW();  //21.09.2020 cnwma1 TFS #49758     
		commitTransaction;
	endif;

	// PAR #17499 - log detail of any errors that have caused the upgrade to fail
	if not result then
		app.writeLog('Release Upgrade failed', LogINFO);
		if app.myPassport.hasErrors then
			app.writeLog('Passport errors: ' &amp; app.myPassport.getErrorsAsString, LogINFO);
		endif;
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);			// 08/04/2011 cnwmh5 #27347
	delete newRelController;
	return result;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jmtSetSUPW" id="694f2d8f-07e4-400b-a249-9a71a6d6e8a1">
        <source>jmtSetSUPW() : String;
// ---------------------------------------------------------------------------
// Created:     19 June 2012 by cnwab1
// PAR 29802
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	PASSWORD = "L0rdOfTheReb@r";

vars
	user : CM_User;
	passwordBin : Binary;

begin
		user := app.myRoot.allUsers[SUPERUSER_Str];

		passwordBin := app.encryptPassword(SUPERUSER_Str, PASSWORD, true); 
		
		
		user.setPropertyValue(CM_User::currentPassword.name, passwordBin);
		user.setPropertyValue(CM_User::isUseStrongPassword.name, true); 
		user.setPropertyValue(CM_User::isNewEncryptionImplemented.name, true);

		return PASSWORD;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jobStatusEnumToString" id="49d41e0d-e017-402f-bbf7-3aa8c0b95282">
        <source>jobStatusEnumToString(_value : Integer) : String;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _value = JOB_UNACTIONED  then
		return "Job Unactioned";
	elseif	_value = JOB_PART_COMPLETE then
		return "Job Part Complete";
	elseif _value = JOB_COMPLETE then
		return "Job Complete";
	elseif _value = JOB_UNVERIFIED then
		return "Pre-check";
	elseif _value = JOB_TROUBLE then
		return "Trouble";
	else
		return "Unknown";
	endif;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
