    <JadeMethod name="goToVoyageNew" id="e711924d-2048-49a5-89fb-192c9586755c">
        <updating/>
        <source>goToVoyageNew() updating;


vars

	workingVoyage	: CMIF_HMS_WorkingVoyage;
	voy				: CM_Voyage;
	 
begin
	
	if self.myViewController = null then
		return;
	endif;
	voy := self.tblMatchesFound.accessRow(self.tblMatchesFound.row).itemObject.CM_Voyage;
	if voy = null then
		return;
	endif;
	
	workingVoyage := self.myViewController.allVoyagesViewedByArrvDT.getAtKey(voy.arrivedDT, voy.code);
	if workingVoyage = null then
		if not self.changeViewRange(voy, false) then
			return;
		endif;
		workingVoyage := self.myViewController.allVoyagesViewedByArrvDT.getAtKey(voy.arrivedDT, voy.code);
	endif;
	
	if workingVoyage &lt;&gt; null then
		// Set this as the new selected voyage
 		self.myViewController.view_NewSelectedMovement(workingVoyage.allWorkingMovements.first.CMIF_HMS_WorkingMovement, true);
 		self.unloadForm;
	endif;
	


end;</source>
    </JadeMethod>
