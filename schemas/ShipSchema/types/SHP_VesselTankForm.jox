    <JadeMethod name="doSaveNext" id="f9d31d1f-4d35-4e03-8426-b27608d0be0e">
        <updating/>
        <source>doSaveNext() updating;
/*
Date		    Who			Reason
19 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	maxIndex,
	listIndex 	: Integer;
	obj 		: Object;
begin
	self.doBaseFormSave();
	listIndex := self.cmbChild.listIndex;
	maxIndex := self.cmbChild.listCount;
	if listIndex &lt; maxIndex then
		listIndex := listIndex + 1;
		self.cmbChild.setIndex(listIndex);
		self.cmbChild.click(self.cmbChild);
		obj := self.myCurrentChild;
		if obj &lt;&gt; null then
			self.doEditChild();
			if self.txtWeight.visible then
				self.txtWeight.setFocus();
				self.txtWeight.selectAll();			
			endif;		
		endif;
	else
		self.doNewChild();
	endif;
	
epilog

end;</source>
    </JadeMethod>
