    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a13268d5-3549-4579-aa91-e8baf7739564">
        <source>pxyCreateUpdateProxy(): SelfType;

// cnwdvb1 23 October 2002 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyHeader : CM_StockOrderHeaderGeneric;
	completedOK		: Boolean;
	
begin
	
	pxyHeader := inheritMethod();
	pxyHeader.myTransferTerminal := self.myTransferTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyHeader;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyHeader;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ae3253a3-cda4-4f7e-b9fe-c85afffe387c">
        <updating/>
        <source>setForCreate(_pxyHdr: CM_StockOrderHeaderGeneric) updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin

	inheritMethod(_pxyHdr);

	self.consigneeCode			:= _pxyHdr.consigneeCode;
	self.myTransferTerminal		:= _pxyHdr.myTransferTerminal;
	self.user					:= _pxyHdr.user;
end;</source>
        <Parameter name="_pxyHdr" type="CM_StockOrderHeaderGeneric"/>
    </JadeMethod>
