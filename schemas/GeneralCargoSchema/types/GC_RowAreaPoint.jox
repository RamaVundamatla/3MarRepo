    </JadeMethod>
    <JadeMethod name="y1" id="57fa1f5e-fc3e-4af4-9aa5-173ee1acfb66">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>y1(set: Boolean; _value: Real io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
