    <JadeMethod name="doCancel" id="4b7dbf13-35fc-44fa-bcc9-4c2cfc001f48">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 26 September 2003
//
//-----------------------------------------------------------------------
//11/07/2018 	jlgns1	Bug 39368: STWO - Report Profile Issue
vars
	doCancel : Boolean;						//Bug 39368
begin
	if self.tblReportDtl.hasChanged then
		doCancel := self.confirmCancel(app.getErrorString(The_Current_Item));	//Bug 39368
	else 																		//Bug 39368
		doCancel := true;														//Bug 39368
	endif;																		//Bug 39368
																				//Bug 39368
	if doCancel then															//Bug 39368
		self.addSystemTypeToCombo();											//Bug 39368
																				//Bug 39368
		return inheritMethod();													//Bug 39368
	endif;																		//Bug 39368
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbParamTypeClick" id="814b7a88-ea89-4ec9-a4c4-68124dd2a899">
        <source>doCmbParamTypeClick() protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb			: CMUI_ComboBox;
	viewName 	: String;
	ts			: TimeStamp;
begin
	cmb := self.cmbParamType;
	viewName := self.myQueryParamLogicAgent.getViewNameForType(cmb.itemData[cmb.listIndex].Integer);
	self.tblParamEnt.showHideRowsByViewName(viewName, CM_EntryTable.ShowHideRows, false);
	ts := self.systemToLocalTime(app.actualTimeServer());	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	self.tblParamEnt.setValueByName(ETRow_DefaultValTime, ts.time);
	self.txtDefaultDate.setDate(ts.date);
	self.tblParamEnt.setValueByName(ETRow_DefaultValDate, ts.date);
	self.txtDefaultTime.setTime(ts.time);
	self.tblParamEnt.adjustHeight(200);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbReportTypeClick" id="2c5ba196-5d08-4fd9-934f-524c58da6444">
        <updating/>
        <source>doCmbReportTypeClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     18 August 2003	cnwth2
//
// Purpose:     Set the view for the selected report type and disabled the row - they
//				cannot choose a different view for a particular report category - UNLESS
//				the report type is RT_External - then they can pick any view.
//			 
// ----------   ----------  --------------------------------------------------
vars
	categoryStr 			: String;
	viewName				: String;
	tbl						: CM_EntryTable;
begin
	self.lblSelector.caption := null;
	tbl := self.tblReportDtl;
	self.tblDesigns.clear();
	self.tblDesigns.rows := null;
	categoryStr := self.cmbReportType.text;
	
	self.showViewForReportType(categoryStr);
	
	if (categoryStr = CM_QryReportUser.ReportTypeDescr_External) then
		self.tblReportDtl.enableRowByName(ETRow_ReportView);
		self.tblCriteria.visible := false;
		
	elseif (categoryStr = CM_QryReportUser.ReportTypeDescr_Selector) then
		self.tblReportDtl.disableRowByName(ETRow_ReportView);
		self.tblCriteria.visible := false;
		self.loadSelectorQueries();
		
		self.loadCriteria(self.myCurrentObject.CM_QryReport);	//19 Feb 2018	NDL	TFS 37091
		
	else
		self.tblReportDtl.disableRowByName(ETRow_ReportView);
		if self.mode = self.Mode_Add then
			self.loadCriteria(null);
		else
			self.loadCriteria(self.myCurrentObject.CM_QryReport);
		endif;
		
		self.tblCriteria.visible := true;
	endif;

	viewName := self.myReportAgent.getViewNameForTypeDescription(categoryStr);
	
	self.tblReportDtl.setValueByName(ETRow_ReportView, viewName);
	self.tblReportDtl.setValueByName(ETRow_JrwReport, null);
	
	self.cmbReportView.text := viewName;
	self.doCmbReportViewClick();
	
	//th2 no! PAR#13380 this is reloading everything from the JRW schema and taking ages - slwoing toll owens 
	//user can press F5 for refresh if a new report is not present in the list
	//if self.mode &lt;&gt; Mode_View then
		//self.loadJRWViews ();//added by cnwyl1 for PAR 9926 06072006
	//endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbReportViewClick" id="87c75951-388c-4dc9-b03f-3defdf7a8a1e">
        <updating/>
        <source>doCmbReportViewClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     18 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	reportType			: Integer;
	reportPath			: String;
	reportPath2			: String;
	jrwReport,
	jrwView				: CMUI_JRWEntityRepresentation;
	lstTbl				: CMUI_ListTable;
	ref                 : Reference;
	viewName            : String;
begin
	jrwView := self.cmbReportView.listObject.CMUI_JRWEntityRepresentation;
	
	if jrwView = null then
		return;
	endif;

	lstTbl := self.tblDesigns;
	lstTbl.allSelectedObjects.clear();
	lstTbl.rows := 0;
	if self.cmbReportType.listIndex &gt; 0 then
		reportType := self.cmbReportType.itemData[self.cmbReportType.listIndex].Integer;
	endif;
	if reportType = CM_QryReportUser.ReportType_CashTrx then
		reportPath := "allCashPayments";
	elseif reportType = CM_QryReportUser.ReportType_CashReceipt then
		reportPath := "allCashReceipts";
	elseif reportType = CM_QryReportUser.ReportType_CashCredit then
		reportPath := "allCashCredits";
	elseif reportType = CM_QryReportUser.ReportType_Invoice then
		reportPath := "allInvoices";
		reportPath2 := "allReportInvoiceSummaries";	// 35069 
	elseif reportType = CM_QryReportUser.ReportType_InvoiceLine then
		reportPath := "allInvoiceLines";
	elseif reportType = CM_QryReportUser.ReportType_InvoiceRate then
		reportPath := "allInvoiceRates";
	endif;

	
	foreach jrwReport in jrwView.allJRWRepresentationEntities do
		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting add reportPath to show the appropriate reports
		
		if reportPath = null then
			lstTbl.addItemObject(jrwReport.name, jrwReport);
		elseif jrwReport.reportsOn(reportPath) then
			lstTbl.addItemObject(jrwReport.name, jrwReport);
		elseif reportPath2 &lt;&gt; null and jrwReport.reportsOn(reportPath2) then	// 35069
			lstTbl.addItemObject(jrwReport.name, jrwReport);
		endif;
	endforeach;

	self.tblReportDtl.setValueByName(ETRow_JrwReport, null);
	self.tblReportDtl.adjustHeight(200);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbSelectorClick" id="2548f0be-e2ef-4c5e-9c7d-b03a0b7fdb0e">
        <updating/>
        <source>doCmbSelectorClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuUserQuery		: CM_MenuUserQuery;
	str					: String;
	viewName,
	newViewName			: String;
begin
	menuUserQuery := self.cmbSelector.listObject.CM_MenuUserQuery;
	if menuUserQuery = null then
		return;
	endif;
	//str := 'Selector Criteria:' &amp; CrLf &amp; CrLf;
	// from 34442 show the selector mode
	str := 'Selector Criteria:' &amp; CrLf &amp; "Mode: " &amp; menuUserQuery.getQueryDefinition().modeDescription &amp; CrLf &amp; CrLf;
	str := str &amp; menuUserQuery.getFullDescription;
	self.lblSelector.caption := str;

	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
	viewName := cmbReportView.text;
	newViewName := self.myReportAgent.getViewNameForSelectorMode(menuUserQuery.queryMode);
	if newViewName &lt;&gt; viewName then
		self.tblReportDtl.setValueByName(ETRow_ReportView, newViewName);
		self.tblReportDtl.setValueByName(ETRow_JrwReport, null);
	
		self.cmbReportView.text := newViewName;
		self.doCmbReportViewClick();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2bc548de-3f14-493c-a116-af51c846ffda">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		19 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	rtnValue	: Boolean;
	toDelete	: CM_QryReportUser;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	
	if self.myCurrentObject.isKindOf(CM_QryReportSystem) then
		app.msgBox('You may not remove system reports','Disallowed!',0);
		return false;
	endif;
	
	toDelete := self.myCurrentObject.CM_QryReportUser;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteQryReportUser(toDelete, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Cargo Update', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFldSheetChange" id="d2ec544e-01d2-4e79-88bd-e0ae10995599">
