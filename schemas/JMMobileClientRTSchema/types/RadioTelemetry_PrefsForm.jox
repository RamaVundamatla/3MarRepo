    <JadeMethod name="doApplyScreenColors" id="af6549a8-a0d8-412c-b97d-af615d649b0f">
        <updating/>
        <source>doApplyScreenColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		See superclass implementation.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	grpColors.backColor		:=	app.colorBackGeneral;
	grpColors.foreColor		:=	app.colorForeGeneral;
	grpGeneral.backColor	:=	app.colorBackGeneral;
	grpGeneral.foreColor	:=	app.colorForeGeneral;
	grpTables.backColor		:=	app.colorBackGeneral;
	grpTables.foreColor		:=	app.colorForeGeneral;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeToSelectedColors" id="3906b1d2-b08a-4850-a0ed-22f25d8a9646">
        <updating/>
        <source>doChangeToSelectedColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Applies the user's selected colors, not the ones held on APP.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor			:=	self.aGeneralBack;
	grpColors.backColor		:=	self.aGeneralBack;
	grpColors.foreColor		:=	self.aGeneralFore;
	grpGeneral.backColor	:=	self.aGeneralBack;
	grpGeneral.foreColor	:=	self.aGeneralFore;
	grpTables.backColor		:=	self.aGeneralBack;
	grpTables.foreColor		:=	self.aGeneralFore;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGetColor" id="f4a3a27c-eff2-4c2d-98d9-af89b3502e25">
        <source>doGetColor(_color:Integer io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Fetches a color using the Color Common Dialog.
//
// Parameters:	_color - The color that was selected by the user.
//
// Returns:		The selected color parameter, and true if a color was selected,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorObj	: CMDColor;
	
begin
	create colorObj transient;
	colorObj.preventFullOpen	:=	false;
	colorObj.color				:=	_color;
	
	if colorObj.open() = 0 then
		_color	:=	colorObj.color;
		return true;
	endif;
	
	return false;
epilog
	delete colorObj;
end;</source>
        <access>protected</access>
        <Parameter name="_color" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="06c9345e-e9ef-4a1c-9475-e07661d1d7f2">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard save method.
//
// Parameters:	None
//
// Returns:		True if the save was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorString	: String;
	state		: Integer;
	
begin
//	app.myRTGuiAgent.saveUserColors(self.aBackground, self.aForeground, errorString, state);
//	errorString	:=	"It's all rooted It's all rooted It's all rooted It's all rooted It's all rooted It's all rooted!!";
//	app.msgBox(errorString, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
//	return false;
	
	if app.myRTGuiAgent.saveUserColors(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore, errorString, state) then
		app.setApplicationColors(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
		app.writeSystemColorsToIni(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		return true;
	else
		app.msgBox(errorString, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectColor" id="19fc6984-6c68-4d0a-9c2a-1bca47f94b12">
        <updating/>
        <source>selectColor(_isBackground:Boolean; _isForTables:Boolean; _isDefault:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Selects a background and/or foreground color to be used by the whole
//				application.
//
// Parameters:	_isBackground - True if the background color is being set, otherwise
//					the foreground is assumed (if the default is not being set).
//				_isForTables - Trus if the color is being set for the Tables, otherwise
//					a color for the general background will be assumed.
//				_isDefault - True if the background and foreground colors are to be
//					set to the Windows default colors.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	selectedColor	: Integer;
	
begin
	if _isDefault then
		app.getSystemColorsFromIni(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
		self.doChangeToSelectedColors();
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		
	elseif _isForTables then
		if _isBackground then
			selectedColor	:=	self.aTablesBack;
		else
			selectedColor	:=	self.aTablesFore;
		endif;
		
		if self.doGetColor(selectedColor) then
			if _isBackground then
				self.aTablesBack	:=	selectedColor;
			else
				self.aTablesFore	:=	selectedColor;
			endif;
		endif;
		
	else
		if _isBackground then
			selectedColor	:=	self.aGeneralBack;
		else
			selectedColor	:=	self.aGeneralFore;
		endif;
		
		if self.doGetColor(selectedColor) then
			if _isBackground then
				self.aGeneralBack	:=	selectedColor;
			else
				self.aGeneralFore	:=	selectedColor;
			endif;
			
			self.doChangeToSelectedColors();
		endif;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isBackground" type="Boolean"/>
        <Parameter name="_isForTables" type="Boolean"/>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dfd34dec-d7b9-4055-8f3d-4a646e1f9074">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	centreWindow();
	self.aGeneralBack	:=	app.colorBackGeneral;
	self.aGeneralFore	:=	app.colorForeGeneral;
	self.aTablesBack	:=	app.colorBackTables;
	self.aTablesFore	:=	app.colorForeTables;
	self.doApplyScreenColors();
	self.modalResult	:=	self.MB_MODAL_CANCEL;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
</GUIClass>
