	self.myIsoTypeGroup := self.cmbIsoTypeGroup.listObject.CM_ISOTypeGroup;
	self.myVoyage:=self.cmbVoyage.listObject.CM_Voyage;
	self.myFiltConsignee:=null;
	self.myFiltDestination:=null;
	self.myFiltFreightFwdr:=null;
	self.myIMEXStatus:=null;
	self.myOperator:=null;
	self.myOperatorGroup:=null;
	self.includeOnShip:=self.chkIncludeOnShip.value;
	//self.checkISOGroup:=false;
