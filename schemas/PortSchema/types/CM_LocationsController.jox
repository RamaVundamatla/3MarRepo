    <JadeMethod name="pxyCreateUpdateProxy" id="6d18bc42-e674-49be-86cb-0dae1870625e">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	proxyLocationsController	: CM_LocationsController;
	ti							: CM_TrackedItem;
	completedOK		: Boolean;
	realProd, pxyProd: CM_TerminalAreaProductMinMax;
		
begin
	
	proxyLocationsController :=  inheritMethod();
	proxyLocationsController.myTerminalArea := self.myTerminalArea;
	
	//30 Mar 2021	NDL	TFS 49912
	foreach realProd in self.allProductMinMax discreteLock do
		pxyProd := app.createUpdateProxy(realProd).CM_TerminalAreaProductMinMax;
//		pxyProd.setMyLocationsController( proxyLocationsController );
		pxyProd.setMyParents( self.myTerminalArea.pxyGetProxyObject, proxyLocationsController );
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401	
	return proxyLocationsController;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyLocationsController;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
