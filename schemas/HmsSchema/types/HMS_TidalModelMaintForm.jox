    <JadeMethod name="initFilterTable" id="ed85c521-4858-41f1-9653-08ef18000ede">
        <updating/>
        <source>initFilterTable() updating;

vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;

begin

	theTable := self.tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_HMSTidalModelSearch);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(300);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef HMS Tidal Model Search not found');
	endif;
	

end;</source>
