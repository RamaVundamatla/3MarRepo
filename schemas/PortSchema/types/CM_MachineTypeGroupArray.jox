<CollClass name="CM_MachineTypeGroupArray" id="05597752-be0c-43eb-9d3f-a673bc30b474">
    <loadFactor>66</loadFactor>
    <memberType name="CM_MachineTypeGroup"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <JadeMethod name="has" id="bc4dedd0-6272-4d16-a4c8-3c9211289549">
        <source>has(_type : Integer): Boolean;

// Created by cnwdvb1 on 21 September 2007

vars
	group : CM_MachineTypeGroup;

begin

	foreach group in self do
		if group.type = _type then
			return true;
		endif;
	endforeach;	

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
