    <JadeMethod name="getCargoGroupDetailSites" id="539a0bf0-e183-4f55-9a1b-5e9d10f33103">
        <source>getCargoGroupDetailSites() : String;
/*
Purpose:			

Date		Who		Reason
04 September 2023	navab1	CR 59942 TASK 59943 
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgd : CM_CargoGroupDetail;
	locId, //24/03/2025	navkc1 JIRA Story MTN-34256
	retStr : String;
	ti	: CM_TrackedItem;
	
begin
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			locId := ti.locationId;
			
			if locId &lt;&gt; null then
				retStr.addStringToList(app.siteEnumToString(ti.site), ", ");
			endif;
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			if cgd.location &lt;&gt; null then
				if retStr = null then
					retStr := app.siteEnumToString(cgd.site);
				else
					retStr := retStr &amp; ", " &amp; app.siteEnumToString(cgd.site);
				endif;
			endif;
		endforeach;
	endif;
	
	return retStr;
epilog

end;</source>
