epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveRightSelectedDown" id="fbdc68e0-75fc-4445-b186-8b337408de66">
        <updating/>
        <source>doMoveRightSelectedDown() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	idx,
	currPos,
	totalCount		: Integer;
	currItem 		: Object;
	selectedIds		: IntegerArray;
begin
	if self.mySelectedListBox.selectedCount &lt; 1 then
		return;
	endif;
	
	create selectedIds transient;
	
	idx := 1;
	totalCount := self.mySelectedListBox.listCount();
	while idx &lt; totalCount do
		if self.mySelectedListBox.itemSelected[idx] then
			selectedIds.add(idx);
		endif;
		idx += 1;
	endwhile;
	
	idx := selectedIds.size();
	while idx &gt; 0 do
		currPos := selectedIds[idx];
		if currPos = parentCollectionRight.size() then
			idx -= 1;
			continue;
		endif;
		currItem := self.parentCollectionRight[currPos];
		self.parentCollectionRight.removeAt(currPos);
		self.parentCollectionRight.insert(currPos + 1, currItem);
		self.moveItem(currPos, currItem, 1);
		idx -= 1;
	endwhile;
epilog
	delete selectedIds;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveRightSelectedToBottom" id="ea1adaa8-bcf3-4f7e-a65e-bb984ee95e01">
        <updating/>
        <source>doMoveRightSelectedToBottom() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list

*/

vars
	listPos,
	currIndex,
	totalCount		: Integer;
	item			: Object;
	selectedItems,
	unselectedItems	: ObjectArray;
	hasNoFilter		: Boolean;
begin
	if self.mySelectedListBox.selectedCount &lt; 1 then
		return;
	endif;
	
	create selectedItems transient;
	create unselectedItems transient;
	
	currIndex := 1;
	totalCount := self.parentCollectionRight.size();
	while currIndex &lt;= totalCount do
		item := self.parentCollectionRight[currIndex];
		listPos := self.mySelectedListBox.findObject(item);
		if listPos &gt; 0 and self.mySelectedListBox.itemSelected[listPos] then
			selectedItems.add(item);
		else
			unselectedItems.add(item);
		endif;
		currIndex += 1;
	endwhile;
	
	self.parentCollectionRight.clear();
	
	foreach item in unselectedItems do
		self.parentCollectionRight.add(item);
	endforeach;
	
	foreach item in selectedItems do
		self.parentCollectionRight.add(item);
	endforeach;
	hasNoFilter := self.txtFilterBoxRight.text = Empty_String;
	self.clearRightFilter();
	if hasNoFilter then
		self.resetSelectedStatus(false, selectedItems.size());
	endif;
	
	self.mySelectedListBox.listIndex := self.mySelectedListBox.listCount();		//18.09.2024 navnk30 #66009
epilog
	delete selectedItems;
	delete unselectedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveRightSelectedToTop" id="2c7cc68b-b2c3-4762-9555-3adafa4f2486">
        <updating/>
        <source>doMoveRightSelectedToTop() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list
08/05/2025	navlw1	JIRA-34582: Improved how we move items to the top of the list box
04/06/2025	NAVKC1	JIRA-34965 MTN | Error 14011 in Various Forms when sorting Filter in column organiser
*/

vars
	currIndex,
	totalCount				: Integer;
	item					: Object;
	idx						: Integer;
	iter					: Iterator;
	selectedCollection 		: DynaDictionary;
	topIdx 					: Integer;
begin
	if self.mySelectedListBox.selectedCount &lt; 1 then
		return;
	endif;
	
	create selectedCollection transient;
	
	selectedCollection.setMembership(Object);
	selectedCollection.addExternalKey(Integer, null, false, false);
	selectedCollection.endKeys(false);
	
	currIndex := 1;
	//totalCount := self.parentCollectionRight.size();
	totalCount := self.mySelectedListBox.listCount(); // 04/06/2025 NAVKC1 JIRA 34965
	while currIndex &lt;= totalCount do
		item := self.mySelectedListBox.itemObject[currIndex];
		if currIndex &gt; 0 and self.mySelectedListBox.itemSelected[currIndex] then
			selectedCollection.putAtKey(currIndex, item);
		endif;
		currIndex += 1;
	endwhile;
	
	topIdx := 1;
	iter := selectedCollection.createIterator;
	while iter.next(item) do
		iter.getCurrentKeys(idx);
		self.moveItemTo(idx, item, topIdx);
		topIdx += 1;
	endwhile;
	
	// remove the item
	//selectedCollection.removeAt(2); //current position
	//selectedCollection.insert(1, theText); // should be first item?

	
	/*
	create selectedItems transient;
	create unselectedItems transient;
	
	currIndex := 1;
	totalCount := self.parentCollectionRight.size();
	while currIndex &lt;= totalCount do
		item := self.parentCollectionRight[currIndex];
		listPos := self.mySelectedListBox.findObject(item);
		if listPos &gt; 0 and self.mySelectedListBox.itemSelected[listPos] then
			selectedItems.add(item);
		else
			unselectedItems.add(item);
		endif;
		currIndex += 1;
	endwhile;
	
	self.parentCollectionRight.clear();
	foreach item in selectedItems do
		self.parentCollectionRight.add(item);
	endforeach;
	
	foreach item in unselectedItems do
		self.parentCollectionRight.add(item);
	endforeach;
	hasNoFilter := self.txtFilterBoxRight.text = Empty_String;
	self.clearRightFilter();
	if hasNoFilter then
		self.resetSelectedStatus(true, selectedItems.size());
	endif;
	
	self.mySelectedListBox.listIndex := 1;		//18.09.2024 navnk30 #66009
	*/
epilog
	delete selectedCollection;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveRightSelectedUp" id="bd684159-051b-402d-9615-e2d53e6f1037">
        <updating/>
        <source>doMoveRightSelectedUp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	idx,
	currPos,
	totalCount		: Integer;
	currItem		: Object;
	selectedIds		: IntegerArray;
	
begin
	if self.mySelectedListBox.selectedCount &lt; 1 then
		return;
	endif;
	
	create selectedIds transient;
	
	idx := 1;
	totalCount := self.mySelectedListBox.listCount();
	while idx &lt;= totalCount do
		if self.mySelectedListBox.itemSelected[idx] then
			selectedIds.add(idx);
		endif;
		idx += 1;
	endwhile;
	
	idx := 1;
	while idx &lt;= selectedIds.size do
		currPos := selectedIds[idx];
		if currPos &lt; 2 then
			idx += 1;
			continue;
		endif;
		currItem := self.parentCollectionRight[currPos];
		self.parentCollectionRight.removeAt(currPos);
		self.parentCollectionRight.insert(currPos - 1, currItem);
		self.moveItem(currPos, currItem, -1);
		idx += 1;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveSelectedToLeft" id="e760cbf2-b6c7-4268-a4d1-88cffb0a8abd">
        <updating/>
        <source>doMoveSelectedToLeft() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	fromCollection,
	toCollection	: Collection;
	fromListBox,
	toListBox		: CM_MultiSelectListBox;
	listIndex,
	movedIndex,
	itemCount		: Integer;
	listObj			: Object;
begin
	fromCollection	:= self.parentCollectionRight;
	toCollection	:= self.parentCollectionLeft;
	fromListBox		:= self.mySelectedListBox;
	toListBox		:= self.myAvailableListBox;
	
	itemCount := fromListBox.listCount();
	foreach listIndex in itemCount to 1 step -1 do
		if not fromListBox.itemSelected[listIndex] then
			continue;
		endif;
		listObj := fromListBox.itemObject[listIndex];
		fromListBox.removeItem(listIndex);
		fromCollection.tryRemove(listObj);
		toCollection.tryAdd(listObj);
		movedIndex := toListBox.addItem(self.displayEntry(listObj));
		toListBox.itemObject[movedIndex] := listObj;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveSelectedToRight" id="0a1a753f-9e31-4ddd-bac0-5dee1240de30">
        <updating/>
        <source>doMoveSelectedToRight() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	fromCollection,
	toCollection		: Collection;
	leftSelectedItems	: ObjectSet;
	fromListBox,
	toListBox			: CM_MultiSelectListBox;
	listIndex,
	movedIndex,
	itemCount			: Integer;
	listObj				: Object;
begin
	fromCollection	:= self.parentCollectionLeft;
	toCollection	:= self.parentCollectionRight;
	fromListBox		:= self.myAvailableListBox;
	toListBox		:= self.mySelectedListBox;
	create leftSelectedItems transient;
	
	itemCount := fromListBox.listCount();
	foreach listIndex in itemCount to 1 step -1 do
		if not fromListBox.itemSelected[listIndex] then
			continue;
		endif;
		listObj := fromListBox.itemObject[listIndex];
		fromListBox.removeItem(listIndex);
		fromCollection.tryRemove(listObj);
		toCollection.tryAdd(listObj);
		movedIndex := toListBox.addItem(self.displayEntry(listObj));
		toListBox.itemObject[movedIndex] := listObj;
	endforeach;

epilog
	delete leftSelectedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterAvailable" id="20b37727-0949-42da-afbb-8921a46b1b33">
        <updating/>
        <source>filterAvailable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control

*/

vars
	filterText,
	itemText			: String;
	object 				: Object;
	filteredCollection	: ObjectSet;
	iter				: Iterator;
begin
	create filteredCollection transient;
	iter := self.parentCollectionLeft.createIterator();
	
	filterText := self.txtFilterBoxLeft.text.toUpper;
	if filterText = null then 
		self.parentCollectionLeft.copy(filteredCollection);
	else
		while iter.next(object) do
			itemText := self.displayEntry(object).toUpper;
			if itemText.cnContains(filterText) then
				filteredCollection.add(object);
			endif;
		endwhile;
	endif;
	
	if filteredCollection.isEmpty then
		self.txtFilterBoxLeft.foreColor := Red;
	endif;
	
	self.setAvailable(filteredCollection, false);
epilog
	delete filteredCollection;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterLeftListBox" id="33cd6d61-2b4c-40cb-8837-1f8bd8dcb8b0">
        <updating/>
        <source>filterLeftListBox() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
30 Jul 2025	jlizm1	MTN 35372 Add table filter to auto schedule form

*/

vars
	filterText,
	itemText			: String;
	object 				: Object;
	filteredCollection	: ObjectSet;
	iter				: Iterator;
begin
	create filteredCollection transient;
	iter := self.parentCollectionLeft.createIterator();
	
	filterText := self.txtFilterBoxLeft.text.toUpper;
	if filterText = null then 
		self.parentCollectionLeft.copy(filteredCollection);
	else
		while iter.next(object) do
			itemText := self.displayEntry(object).toUpper;
			if itemText.cnContains(filterText) then
				filteredCollection.add(object);
			endif;
		endwhile;
	endif;
	
	if filteredCollection.isEmpty then
		self.txtFilterBoxLeft.foreColor := Red;
	else
		self.txtFilterBoxLeft.foreColor := getSystemColor(Color_WindowText);
	endif;
	
	self.showAvailable(filteredCollection);
epilog
	delete filteredCollection;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterRightListBox" id="d1eeaebf-85be-4084-854b-e5dfe23c8d05">
        <updating/>
        <source>filterRightListBox() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
30 Jul 2025	jlizm1	MTN 35372 Add table filter to auto schedule form

*/

vars
	filterText,
	itemText			: String;
	object 				: Object;
	filteredCollection	: ObjectArray;
	filterTextBoxRight	: CMUI_FilterTextBox;
	iter				: Iterator;
begin
	filterTextBoxRight := self.txtFilterBoxRight;
	self.myUpSelectedBtn.enabled := filterTextBoxRight.text = self.EmptyText;
	self.myDownSelectedBtn.enabled := filterTextBoxRight.text = self.EmptyText;
	create filteredCollection transient;
	iter := self.parentCollectionRight.createIterator();
	
	filterText := self.txtFilterBoxRight.text.toUpper;
	if filterText = null then 
		self.parentCollectionRight.copy(filteredCollection);
	else
		while iter.next(object) do
			if object.isKindOf(EntTableRow) and false then
				itemText := object.EntTableRow.getHeadingUnaltered();
			else
				itemText := self.displayEntry(object).toUpper;
			endif;
			if itemText.cnContains(filterText) then
				filteredCollection.add(object);
			endif;
		endwhile;
	endif;
	
	if filteredCollection.isEmpty then
		self.txtFilterBoxRight.foreColor := Red;
	else
		self.txtFilterBoxRight.foreColor := getSystemColor(Color_WindowText);
	endif;
	
	self.showSelected(filteredCollection);
epilog
	delete filteredCollection;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllDescCols" id="5e9f3088-86f6-4a4d-8fbb-285e451126c1">
        <source>getAllDescCols(_descEntRowSet : EntTableRowSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list

*/

vars
	idx,
	totalCount	: Integer;
begin
	if self.name &lt;&gt; CMUI_ColumnOrganiserForm::mulColumnSorter.name then
		return;
	endif;
	
	idx := 1;
	totalCount := self.mySelectedListBox.listCount();
	while idx &lt;= totalCount do
		if self.mySelectedListBox.itemText[idx].endsWith__(CMUI_ColumnOrganiserForm.Descending) then
			_descEntRowSet.add(self.mySelectedListBox.itemObject[idx].EntTableRow);
		endif;
		idx += 1;
	endwhile;
epilog

end;</source>
        <Parameter name="_descEntRowSet" type="EntTableRowSet" usage="io"/>
    </JadeMethod>
