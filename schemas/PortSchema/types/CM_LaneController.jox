    <JadeMethod name="setForCreate" id="39c96f74-ec2e-4ec8-b62d-73aa5dbeaaf4">
        <updating/>
        <source>setForCreate(_proxy: CM_LaneController; _terminalArea: CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy, _terminalArea);
epilog

end;</source>
