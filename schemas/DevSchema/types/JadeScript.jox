    <JadeMethod name="verifyXLAT" id="90d6706b-3dcf-4750-8cdc-c58ffce9a03d">
        <source>verifyXLAT();

//30 May 2008	cnwdw1	
// Verify and fix the translation text collections
// It is possible for the Global Constants that are referred to by XLAT_TranslatableText:myGlobalConstant
// get deleted, and then a invalid object reference is left behind :-( 
// This script will find all instances of this and delete the translatable text

constants
	UPDATE_REQUIRED	: Boolean = false;
vars
	root			: CM_Root;
	xlat			: XLAT_TranslatableText;
	stuffed			: XLAT_TranslatableTextByNumber;
	
begin
	//app.initialize();
	//on Exception do null global;
	//app.setPassBackExceptions(false, false);
	root := CM_Root.firstInstance;
	//app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	//app.writeStatement( "Verify and Fix Translatable Text");
	write "Verify and Fix Translatable Text";
	create stuffed transient;
	foreach xlat in root.allXLAT_TranslatableText do
		if xlat.myGlobalConstant = null or app.isValidObject(xlat.myGlobalConstant) then
			continue;
		endif;
		stuffed.add(xlat);
	endforeach;
	
	//app.writeStatement( "Found " &amp; stuffed.size.display &amp; " items that have invalid global constant reference");
	write "Found " &amp; stuffed.size.display &amp; " items that have invalid global constant reference";
	
	foreach xlat in stuffed do
		//app.writeStatement( "Deleting " &amp; xlat.number.display &amp; Space &amp; xlat.vConstantName &amp; Space &amp; xlat.vDefaultMessage );
		write "Deleting " &amp; xlat.number.display &amp; Space &amp; xlat.vConstantName &amp; Space &amp; xlat.vDefaultMessage;
		if UPDATE_REQUIRED then
			beginTransaction;
			delete xlat;
			commitTransaction;
		endif;
	endforeach;
	
	//app.writeStatement( "Translatable text has been verified" &amp; Tab &amp; stuffed.size.display );
	
epilog
	delete stuffed;
end;
</source>
    </JadeMethod>
    <JadeMethod name="verifyXLATFormCaptions" id="2ce92bcc-a12b-4dd2-aa01-10c8ea0733ed">
        <source>verifyXLATFormCaptions();

/*

Purpose:		Check that XLAT_FormCaptions are valid
				That the following aren't blanks
				- controlName
				- controlProperty
				- formClass
				- schemaName
				Get the details of the methods used in
				This method runs a validation version of the DevSchema::JadeScript::verifyXLATFormCaptions
				
				NOTE: Don't forget to delete the constants from XLAT_FormCaptions and fix any broken methods

Date			Who		Reason
27/11/2014		cnwmh5	Initial creation

*/

vars

	category					: XLAT_Category;
	translatableText 			: XLAT_TranslatableText;
	xmlDoc						: JadeXMLDocument;
	xmlAttribute				: JadeXMLAttribute;
	globalConstant				: GlobalConstant;
	meth						: Method;
	obj							: Object;
	
	errorTextArray				: StringArray512;
	tagsToCheckFor				: StringArray;
	methodsSet					: MethodSet;
	xlatToDelete				: ObjectArray;
	
	errorText					: String;
	str							: String;
	index						: Integer;
	lastModified				: TimeStamp;
	author						: String;
	methodsUsedIn				: String;
	updateRequired				: Boolean;

begin


	updateRequired := true;

	category := app.myRoot.allXLAT_Categories[XLAT_FormCaptions];
	if category = null then
		write "Unable to find XLAT_FormCaptions constant category.  Exiting JadeScript.";
		return;
	endif;

	create errorTextArray transient;
	create methodsSet transient;
	create xlatToDelete transient;
	
	create tagsToCheckFor transient;
	tagsToCheckFor.add("ControlName");
	tagsToCheckFor.add("ControlProperty");
	tagsToCheckFor.add("FormClass");
	tagsToCheckFor.add("SchemaName");
	
	foreach translatableText in category.allTranslatableText discreteLock do
		
		globalConstant := translatableText.myGlobalConstant;
		if not global.isValidObject(globalConstant) then
			continue;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(globalConstant.text);
		
		errorText := null;
		foreach index in 1 to tagsToCheckFor.size do
			xmlAttribute := xmlDoc.getElementByTagName("ErrorMsg").getAttributeByName(tagsToCheckFor[index]);
			if xmlAttribute &lt;&gt; null then
				str := xmlAttribute.value;
			endif;
			if xmlAttribute = null or str = null then
				if errorText &lt;&gt; null then
					errorText := errorText.trimBlanks() &amp; ", ";
				endif;
				str := tagsToCheckFor[index];
				str.firstCharToLower();
				errorText := errorText &amp; str;
			endif;
		endforeach;
		
		methodsUsedIn := null;
		if errorText &lt;&gt; null then
			// check to see where the constant is used
			methodsSet.clear();
			if globalConstant &lt;&gt; null then
				globalConstant.getMethodRefs(methodsSet);
			endif;
			foreach meth in methodsSet do //where meth.getSchemaType().name &lt;&gt; "JadeScript" do
				if methodsUsedIn &lt;&gt; null then
					methodsUsedIn := methodsUsedIn.trimBlanks() &amp; ", ";
				endif;
				methodsUsedIn := methodsUsedIn &amp; meth.getSchema().name &amp; "::" &amp; meth.name;
			endforeach;
			
			// write the details out
			lastModified := translatableText.myGlobalConstant.cnGetModifiedTimeStamp();
			author := translatableText.myGlobalConstant.cnGetModifierName();
			errorTextArray.add(translatableText.vConstantName &amp; " (" &amp; "oid: " &amp; translatableText.String &amp; 
				" created: " &amp; translatableText.creationTime.date.format("dd/MM/yyyy") &amp; " - " &amp;
				translatableText.createdTime.time.String &amp; " id: " &amp; translatableText.vConstantValue.String &amp; 
				" last modified: " &amp; lastModified.date.format("dd/MM/yyyy") &amp; " by " &amp; author &amp; "): " &amp; errorText &amp; 
				", methods used in: " &amp; methodsUsedIn);
			
			// save constant object for deletion
			xlatToDelete.add(translatableText);
			
		endif;
		
	endforeach;
	
	if not errorTextArray.isEmpty() then
		write "The following Form Caption details are invalid: ";
		errorText := errorTextArray.concatenate(CrLf);
		write errorText &amp; CrLf &amp; CrLf;
		if updateRequired then
			beginTransaction;
			foreach obj in xlatToDelete do
				translatableText := obj.XLAT_TranslatableText;
				write "Deleting XLAT_FormCaptions constant " &amp; translatableText.String &amp; Tab &amp; 
					translatableText.vConstantName &amp; " (" &amp; translatableText.vConstantValue &amp; ")";
			//	delete translatableText;
			endforeach;
			commitTransaction;
		endif;
	endif;
	
	
epilog

	delete errorTextArray;
	delete xmlDoc;
	delete tagsToCheckFor;
	delete methodsSet;
	delete xlatToDelete;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageActivity" id="18a860f2-c522-4f1e-949b-5f911672b163">
