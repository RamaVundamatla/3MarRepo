    <JadeMethod name="selectCargoGroupItem" id="d10d107c-7adf-4be5-b71b-4bb0e6f4c13d">
        <updating/>
        <source>selectCargoGroupItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cargoGroupId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	selectedTi : CM_TrackedItem;
	errMsg : String;
	
	cargoIdLength : Integer;
	//cargoType : CM_CargoType;
	
begin

	self.myCargoGroup := null;

	cargoGroupId := txtCargoGroupId.text.trimBlanks.toUpper;
	if cargoGroupId = lblCargoGroupId.caption.toUpper then
		cargoGroupId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	if cargoGroupId &lt;&gt; null then
	
		cargoIdLength := cargoGroupId.length;	
		
		firstTi := term.getCargoGroupItem( cargoGroupId );
		if firstTi &lt;&gt; null and firstTi.id.length &gt;= cargoIdLength and firstTi.id[1:cargoIdLength] = cargoGroupId then	
			iter := term.allCargoGroupsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id.length &lt; cargoIdLength then
					break;
				endif;
				if ti.id[1:cargoIdLength] &lt;&gt; cargoGroupId then
					break;
				endif;
				selectedTi := ti;
			endwhile;
			delete iter;
		endif;
		
	endif;
	
	self.setMyCargoGroup( selectedTi.CM_CargoGroup );
	
epilog

	delete iter;

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroup" id="75183ea4-ac14-456c-b591-78e19b2e8399">
        <updating/>
        <source>setMyCargoGroup(  _cargoGroup : CM_CargoGroup )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	gcId : String;

begin

	self.myCargoGroup := _cargoGroup;

	if self.myCargoGroup &lt;&gt; null then
		self.txtCargoGroupId.text := self.myCargoGroup.id;
		if self.myCargoGroup.myCargoType &lt;&gt; null then
			self.lblCGroupDesc.caption := self.myCargoGroup.myCargoType.abbreviation &amp; " " &amp; self.myCargoGroup.operatorCode;
		else
			self.lblCGroupDesc.caption := self.myCargoGroup.operatorCode;
		endif;
		
		lblMinWeight.caption := app.getErrorString(Min_weight_title) &amp; " : " &amp; self.myCargoGroup.getMeasureMinWeightUnit;
		lblMaxWeight.caption := app.getErrorString(Max_weight_title) &amp; " : " &amp; self.myCargoGroup.getMeasureMaxWeightUnit;
		lblWeightValue.caption := app.getErrorString(CM_Total_Weight) &amp; " : " &amp; self.myCargoGroup.getMeasureTotalWeightUnit;
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myCargoGroup.totalQuantity.String;
	
	else
		gcId := self.txtCargoGroupId.text;
		if gcId = null or gcId.toUpper = self.lblCargoGroupId.caption.toUpper then
			self.lblCGroupDesc.caption := null;
		else
			self.lblCGroupDesc.caption := "*** " &amp; app.getErrorString1( Cargo_group_not_found, gcId );
		endif;
		
		lblMinWeight.caption := app.getErrorString(Min_weight_title) &amp; " : ";
		lblMaxWeight.caption := app.getErrorString(Max_weight_title) &amp; " : ";
		lblWeightValue.caption := app.getErrorString(CM_Total_Weight) &amp; " : ";
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
		
	endif;

epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="55e4769f-6baf-4485-8454-6da5f09a2642">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation

*/

vars

begin			 
	
	self.doResizeControls(true);
	
	self.txtCargoGroupId.lostFocus( self.txtCargoGroupId );
	self.setMyCargoGroup( null );
	
epilog

end;</source>
    </JadeMethod>
