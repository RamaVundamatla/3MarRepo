	theForm.tblInput2.userInputEnabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4a34f5be-e844-4a9e-9fd7-1bc3e80caf60">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamageReason);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamageReason);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4d24888a-b040-4035-b07c-f7c198a42650">
        <updating/>
        <source>showThumbnail(_damageReason : CM_DamageReason) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damageReason.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damageReason.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damageReason.isNotAvalableForEntry);
epilog

end;</source>
        <Parameter name="_damageReason" type="CM_DamageReason"/>
    </JadeMethod>
</Class>
