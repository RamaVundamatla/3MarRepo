    <JadeMethod name="tFindLogDockets" id="a96d9bb8-3f87-4961-9ee7-526c130e638e">
        <source>tFindLogDockets();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlgma1	Initial creation

*/
constants
BOLlNumber ="UT_DOCK";

vars
	docOid : String;
	terminal : CM_Terminal;
	bolDict	: CM_BOLByTypeNumberDTDict;
	bol: CM_BOLIn;
begin

	terminal := self.getTerminal();
	
	bolDict := terminal.allBOLsReceivedByTypeNumberDT;
	bol := bolDict.getAtKeyGeq(BOLType_Log,BOLlNumber,null).CM_BOLIn;
	docOid := bol.getOidString ;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsFindLogDockets.name, docOid );
epilog

end;</source>
