<CollClass name="CM_ISOTypesByCodeGroupCodeDict" id="b6ddb61a-9832-4700-8bf6-53a6e3546d91">
    <memberType name="CM_ISOType"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_ISOType::code"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_ISOType::myISOTypeGroup"/>
        </keyPath>
        <property name="CM_Group::code"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="683cc7b1-c8ea-40f1-9b08-acd5121ab46c">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2016	cnwma1	Initial creation  TFS #1961 PAR #37474 Changing colour of ISO type only updates selected instance
*/

vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: String;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum ,iter);
			self.removeKey(keyCode,keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
