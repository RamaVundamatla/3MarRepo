    <JadeMethod name="xInvalidObject" id="8484a426-e4fc-45dd-bc40-693e8331e13d">
        <source>xInvalidObject(_exObj : Exception) : Integer;
// -------------------------------------------
// Created 08 April 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _exObj.errorCode = 4 then
		return Ex_Abort_Action;
	endif;
	return Ex_Pass_Back;
	

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
