    <JadeMethod name="makeControlTempSubSectXML" id="43d70657-015f-4fb2-a0cf-3ffc0ba29849">
        <source>makeControlTempSubSectXML( _reeferProp : CM_TIReeferProperties; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	ti : CM_TrackedItem;
	commodity : CM_Commodity;
	workStr : String;
	
begin

	rootElem := _parentElem.addElement('ControlTemperature');
	
	if _reeferProp = null then
		return;
	endif;
	
	if _reeferProp.myParent &lt;&gt; null and _reeferProp.myParent.isKindOf(CM_TrackedItem) then
		ti := _reeferProp.myParent.CM_TrackedItem; 
	endif;
	if ti &lt;&gt; null then
		commodity := ti.getCommodityObject;
	endif;
	
	workStr := null;
	if commodity &lt;&gt; null and commodity.hasTemp then
		workStr :=  _reeferProp.temperature.String;
	endif;
	xmlElem := rootElem.addElement('Temperature');
	xmlElem.setText( workStr );
	
	workStr := null;
	if commodity &lt;&gt; null and commodity.hasTemp then
		workStr := commodity.minTemp.String;
	endif;
	xmlElem := rootElem.addElement('MinimumTemperature');
	xmlElem.setText( workStr );
	
	workStr := null;
	if commodity &lt;&gt; null and commodity.hasTemp then
		workStr := commodity.maxTemp.String;
	endif;
	xmlElem := rootElem.addElement('MaximumTemperature');
	xmlElem.setText( workStr );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reeferProp" type="CM_TIReeferProperties"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeCurrentLocSectXML" id="ed7c6ad1-5ec4-465d-bd8c-d6429410719b">
        <source>makeCurrentLocSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	lc : CM_LocationsController;
	workStr : String;
	voyage : CM_Voyage;
	berth : HMS_Berth;
	
begin

	rootElem := _parentElem.addElement('CurrentLocation');
	
	if _ti = null then
		return;
	endif;
	
	workStr := null;
	lc := _ti.myPrimaryActualLocation;
	if lc &lt;&gt; null then
		if lc.isVehicle then
			workStr := "T";
		elseif lc.isVoyageController then
			workStr := "V";
		else
			workStr := "C";
		endif;
	endif;
	xmlElem := rootElem.addElement('LocationDescriptionType');
	xmlElem.setText( workStr );
	
	workStr := null;
	if lc &lt;&gt; null and lc.getMyTerminalArea &lt;&gt; null then
		workStr := lc.getMyTerminalArea.id;
	endif;
	xmlElem := rootElem.addElement('Block');
	xmlElem.setText( workStr );
	
	//tier - Bish guess
	workStr := null;
	if lc &lt;&gt; null and lc.isSlotController then
		workStr := lc.CM_SlotController.tierId;
	endif;
	xmlElem := rootElem.addElement('X_Position');
	xmlElem.setText( workStr );
	
	//cell - Bish guess
	workStr := null;
	if lc &lt;&gt; null and lc.isSlotController then
		workStr := lc.CM_SlotController.cellId;
	endif;
	xmlElem := rootElem.addElement('Y_Position');
	xmlElem.setText( workStr );
	
	//bay - Bish guess
	workStr := null;
	if lc &lt;&gt; null and lc.isSlotController then
		workStr := lc.CM_SlotController.getBayId(_ti);
	endif;
	xmlElem := rootElem.addElement('Z_Position');
	xmlElem.setText( workStr );
	
	/*
	xmlElem := rootElem.addElement('GPS_Northing');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('GPS_Easting');
	xmlElem.setText( null );
	*/
	
	workStr := null;
	if lc &lt;&gt; null and lc.isVoyageController then
		voyage := lc.CM_VoyageController.myVoyage;
		if voyage &lt;&gt; null then
			workStr := voyage.getMyVessel.code;
			berth := voyage.getMyBerth;
			if berth &lt;&gt; null then
				workStr := berth.description;
			endif;
		endif;
	endif;
	xmlElem := rootElem.addElement('Berth');
	xmlElem.setText( workStr );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
