    <JadeMethod name="sysNotify" id="a4f1b52a-4b6d-457a-8508-93a418cefce9">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(_eventType: Integer; _object: Object; _eventTag: Integer) updating;
//-----------------------------------------------------------------------
//	Created:	29 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
// 08/03/2012	cnwcs5	Unit tests create and delete objects in a short timeframe so make
//						sure we handle a create notify for an object that has subsequently been deleted
vars
	gotException	:Boolean;
	item			:SOP_TableMaintItem;
begin
	item := self.myCurrentTableItem;
	
	if item &lt;&gt; null then
		if _eventType = Object_Create_Event then
			if _object = null then
				return;
			endif;
			
			on Exception do app.handleDeletedObject (exception, _object, gotException);
			
			if (_object.class = item.myDataClass or _object.class.inheritsFrom(item.myDataClass)) then
				
				if item.isObjectRelevant(_object) then
					inheritMethod(_eventType, _object, _eventTag);
				else
					return;
				endif;
			endif;
			// if _object has already been deleted then code will resume here
			return;
		endif;
	endif;

	inheritMethod(_eventType, _object, _eventTag);
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
