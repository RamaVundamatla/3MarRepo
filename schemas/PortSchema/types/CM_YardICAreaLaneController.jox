    <JadeMethod name="isWorkPointLaneController" id="783d074f-e458-41e5-992b-a7c111f8a47e">
        <source>isWorkPointLaneController() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2013	cnwrd1	Initial creation

*/

vars

begin

	if  self.myGridArea &lt;&gt; null and  self.myGridArea.isKindOf(CM_WorkPointInterchangeArea) then
		return true;
	endif;
	
	return inheritMethod;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYardLocation" id="a4c72b9c-e40f-4fa8-9a75-79e37e103128">
        <source>isYardLocation(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2012	cnwrd1	Initial creation

*/

vars

begin

	//cnwrd1 30420 27.9.12 if we are for a workpoint we arnt technically a yard location so we dont stuff up tranship discharges.
	if  self.myGridArea &lt;&gt; null and  self.myGridArea.isKindOf(CM_WorkPointInterchangeArea) then
		return false;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
