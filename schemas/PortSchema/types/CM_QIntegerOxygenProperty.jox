    <DbClassMap file="query"/>
    <JadeMethod name="displayNull" id="f6d8875e-5e57-4c1b-a001-befa810b5321">
        <methodInvocation>mapping</methodInvocation>
        <source>displayNull(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	07 May 2009 cnwjo3
//----------------------------------------------------------------
begin
	_value := true;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="90671e7e-b1b4-4e4a-8a97-cb3a59674aa0">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     07 May 2009 cnwjo3
//
vars

begin
	if _value.Integer &lt;&gt; NULL_INTEGER then
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
