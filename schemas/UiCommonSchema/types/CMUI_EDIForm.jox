    <JadeMethod name="removeEDITI" id="e779a1f0-61f4-4067-a1dd-ea546ec09129">
        <source>removeEDITI( _index : Integer);
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// 28 May 2008	conks1		PAR #16789 - Handle deleted TI item
vars
	table		: CM_DataTable;
	lineText	: String;
	result		: Integer;
	row			: Integer;
	ediTIDict	: CM_EDITIById;
	msg			: String;
	obj			: Object;
	invalidObject : Boolean;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	
	table := self.tblEDITI.getControl(_index); // _index parameter added cnwgb1 28.9.09 MES 1011 Par 20320 
	row := table.row;
	if table.row = 1 then 
		return;
	endif;

	if table.allSelectedObjects.size &gt; 1 then
		msg := app.getErrorString2(ConfirmDelete, 'all selected', 'tracked items');
	else
		msg := app.getErrorString2(ConfirmDelete, 'tracked item', table.accessCell(row, 1).text);
	endif;
	
	result := app.msgBox(msg, "Confirm Delete", MsgBox_OK_Cancel);
	
	if result &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	create ediTIDict transient;
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	foreach obj in table.allSelectedObjects do
		ediTIDict.add(obj.CM_EDITrackedItem);
	endforeach;  
		
	//turn this off for now
	app.myPassport.setMyCMIFMonitor(null);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteEDITrackedItems(ediTIDict, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			table.removeItem(row);
			break;
		else
			theResult := app.showErrorWarningDialog('Delete EDI Item', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
epilog
	delete ediTIDict;
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeFileLine" id="70e59bcf-fa8d-45b7-a40e-96d10ff2d80b">
        <source>removeFileLine();
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	table		: CM_DataTable;
	lineText	: String;
	result		: Integer;
	row			: Integer;
	errors : CM_ErrorSet; //par17172 cnwrs1 July 2008
	error : CM_Error;
begin
	
	table := self.tblFileLine;
	
	if table.text.trimBlanks = "" then
		lineText := "&lt;empty line&gt;";
	else
		lineText := table.text;
	endif;
	create errors transient; //par17172
	
	result := app.msgBox(app.getErrorString2(ConfirmDelete, 'line', lineText),
						"Confirm Delete",MsgBox_OK_Cancel);
	
	if result = MsgBox_Return_OK then
		row := table.row;
		//beginTransaction;
		//	self.ediFile.messages.remove(table.itemObject.CM_LongString);
		//	self.table.removeItem(table.row);
		//commitTransaction;
		app.myPassport.allErrors.copy(errors);
		foreach error in errors do
			error.setMyErrorPassport(null);
		endforeach;
		app.myTrxDA.trxDeleteEDIMessage(self.myEDIFileInError, row, app.myPassport);
		if app.myPassport.trxCompletedOK then
			foreach error in errors do
				error.setMyErrorPassport(app.myPassport);
			endforeach;
			errors.clear;
			table.removeItem(row);
		endif;
	endif;
epilog
	delete errors;
end;</source>
    </JadeMethod>
    <JadeMethod name="replaceSubString" id="bf9256cf-5b7b-4eff-aaf8-1f2bd8a73c9c">
        <updating/>
        <source>replaceSubString(_all: Boolean; _theString: String io; _subStr1, _subStr2: String; _count: Integer output; _fullWord: Boolean): Boolean updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//	move this somewhere useful
//----------------------------------------------------------------

vars
	restart,
	intCount,
	charPos		: Integer;
	replStr,
	findStr,
	targetString,
	betweenText,
	newString	: String;
begin
	targetString	:= _theString;
	findStr			:= _subStr1;
	replStr			:= _subStr2;
	
	 // PAR 6868 AKB2003DEC if the find string is null it changed all  strings,
	 //	 						it did not compare it to what was in the actual text

	if findStr = null and _theString = null then
		_theString := replStr;
		_count := 1;
		return true;
	endif;
	
	charPos := targetString.pos(findStr,1);
	
	if charPos &lt; 1 then
		_count := 0;
		return false;
	endif;
		
	if _fullWord then
		if targetString = _subStr1 then
			_theString := _subStr2;
			_count := 1;
			return true;
		else
			_count := 0;
			return false;
		endif;
	elseif not _all then
		newString := targetString[1:charPos-1] &amp; replStr;
		if charPos + findStr.length &lt; targetString.length then
			newString := newString &amp; targetString[charPos + findStr.length:end];
		endif;
		_theString := newString;
		_count := 1;
		return true;
	else
		newString	:= "";
		betweenText	:= "";
		restart		:= 1;
		newString := targetString[1:charPos-1] &amp; replStr;
		intCount := 1;
		while true do
			//process.debug;
			restart := charPos + findStr.length;
			charPos := targetString.pos(findStr,restart);
			if charPos &lt; 1 then	
				if restart &lt;= targetString.length then
					newString := newString &amp; targetString[restart:end];
				endif;
				break;
			endif;
			intCount := intCount + 1;
			betweenText	:= targetString[restart:charPos-restart];
			newString := newString &amp; betweenText &amp; replStr;
		endwhile;
		_theString := newString;
		_count := intCount;
		return true;
	endif;
	
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_theString" type="String" usage="io"/>
        <Parameter name="_subStr1" type="String"/>
        <Parameter name="_subStr2" type="String"/>
        <Parameter name="_count" type="Integer" usage="output"/>
        <Parameter name="_fullWord" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="04885df2-ab5d-40e2-b646-b050f3232285">
        <source>resetNotifications();
// ---------------------------------------------------------------------------
// Created:     23 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
// 30 Nov 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	term : CM_Terminal;
begin
	inheritMethod();

	term := self.myTerminal;		//30.11.2022 navma1 #52499
	
	self.beginClassNotification(Global, false, term.getTerminalEvent(EDIData_Create_Event), Response_Continuous, 0);

	self.beginClassNotification(CM_EDIFile, false, term.getTerminalEvent(Event_CusResEDITI_Create), Response_Continuous, 0);
	
	//this one only fires for singleDataFiles
	self.beginClassNotification(CM_EDIData, false, term.getTerminalEvent(Event_EDITI_Delete), Response_Continuous, 0);

	self.beginNotification(term, term.getTerminalEvent(EVENT_EDI_EDITI_UPDATE)  , Response_Continuous, 0);
	self.beginNotification(term, term.getTerminalEvent(EVENT_EDI_EDIDATA_UPDATE), Response_Continuous, 0);
end;</source>
    </JadeMethod>
