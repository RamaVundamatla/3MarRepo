    <JadeMethod name="myNextSlotInHold" id="c51bee0e-8b22-4c24-ab80-f37293c64cc6">
        <methodInvocation>mapping</methodInvocation>
        <source>myNextSlotInHold(set: Boolean; _value: CM_SlotDefn io) mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwrs1
//
// Purpose:     Only valid if a forty footer will fit in this slot
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		if self.fortyFront 
		or self.is53 or self.is45 then // PAR 17841
			_value := self.myAftSlot;
		else
			app.writeLog(method.qualifiedName &amp; "Not getting AFT SLOT as " &amp; self.getName() &amp; " is not defined for 40s",LogINFO);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_SlotDefn" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myPreviousSlotInHold" id="79cbc853-457e-4491-a0c5-aa7c3256c6c7">
        <methodInvocation>mapping</methodInvocation>
        <source>myPreviousSlotInHold(set: Boolean; _value: CM_SlotDefn io) mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwrs1
//
// Purpose:     Only valid if a forty footer will fit in this slot
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		if self.fortyBack then
			_value := self.myForwardSlot;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_SlotDefn" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateNewUpdateProxy" id="bfe87419-1feb-453c-b62e-728c76906be5">
        <source>pxyCreateNewUpdateProxy();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
//				sort out the proxy copy else the TRX thinks that
//				some one else is updating because the edition of the slot has been changed in here

// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	bayDefn : CM_BayDefn;
	hatchLidsStart, hatchLidsEnd : Integer;
	proxyMeOld,proxyMeNew : SelfType;
	loadState : Boolean;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;

begin
	proxyMeOld := self.pxyGetProxyObject;
	if proxyMeOld &lt;&gt; null then
		// get the bits and pieces that we need
		bayDefn := proxyMeOld.myBay.CM_BayDefn;
		aTier := bayDefn.allTiersOnDeck[proxyMeOld.ordinalTier];
		aCell := bayDefn.allCellsOnDeckByOrdinal[proxyMeOld.ordinalCell];
		
		// delete the original proxy to release it from the bay and the proxy manager etc.
		delete proxyMeOld;

		// make a new proxy copy
		app.cmsBeginLoad(loadState);
		proxyMeNew := self.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		// attach the new proxy to the bay		
		proxyMeNew.setMyBay(bayDefn,true);
		proxyMeNew.setCellAndTierDefn(aCell,aTier);
	endif;

epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5d66aa7b-e2c4-4877-b332-4be5db466b8d">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	proxy:SelfType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();

	proxy.fortyFront := self.fortyFront or self.fortyBack; // in the GUI we are only interested in fortyFront. These 2 boolean are set correctly in setForUpdate
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAdjacentSlots" id="c19bbaa0-09b6-4ec6-8092-cfcc4beec975">
        <updating/>
        <source>setAdjacentSlots(_portSlot, _underfootSlot, _aftSlot:CM_SlotDefn) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myPortSlot := _portSlot;
	self.myUnderfootSlot := _underfootSlot;
	self.myAftSlot := _aftSlot;
	
	//22 Nov 2012	NDL	Par 30779 - edition 1 vessel def (after a jtv or XML load) will not
	// have the myAftSlot, myForwardSlot refs set on the CM_SlotDefn therefore setAsFortyFoot
	// will not have been able to establish the fortyBack attribute correctly.
	// If a user has just updated the cell heights or pile weights the back forty attributes would
	// have disappeared
	if _aftSlot &lt;&gt; null
// PAR 33443	and not _aftSlot.isTransient - removed since need to set this on proxies coming in from the WebService for updating a hold (updateVesselLOLOHoldDefn)
	and not _aftSlot.unavailable
	and not _aftSlot.fortyBack
	and self.fortyFront
	and self.myBay &lt;&gt; null
	and _aftSlot.myBay &lt;&gt; null
	and self.myBay.myHold = _aftSlot.myBay.myHold
	then
		self.setAsFortyFoot(true);
	endif; 
	
end;</source>
        <Parameter name="_portSlot" type="CM_SlotDefn"/>
        <Parameter name="_underfootSlot" type="CM_SlotDefn"/>
        <Parameter name="_aftSlot" type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="setAnAttributeFromController" id="30fc416f-c941-4fdd-9514-4629648edc5a">
        <updating/>
        <source>setAnAttributeFromController(_theAttribute : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aftSlot : CM_SlotDefn;
begin
//	write method.name;
	if _theAttribute = CM_SlotRequest.Attribute_Empty then
		self.mtOnly := not self.mtOnly;
	elseif _theAttribute = CM_SlotRequest.Attribute_Heavy then
		self.heavy := not self.heavy;
	elseif _theAttribute = CM_SlotRequest.Attribute_VoltageType then
		self.voltageType := self.voltageType + 1;
		if voltageType &gt; 2 then
			self.voltageType := 0;
		endif;

	// PAR 16415 CCMS 1029
	elseif _theAttribute = CM_SlotRequest.Attribute_FiftyThree then
		self.is53 := not self.is53;
		if not self.is53 then
			self.isBackend := false;
		else
			self.isBackend := self.myBay.isAftBay();
		endif;
		aftSlot := self.myAftSlot;
		if aftSlot &lt;&gt; null then
			aftSlot.is53 := self.is53; 
			if not aftSlot.is53 then
				aftSlot.isBackend := false;
			else
				aftSlot.isBackend := not self.isBackend;
			endif;
			
			aftSlot := aftSlot.myAftSlot;
	//		if aftSlot &lt;&gt; null then
			if aftSlot &lt;&gt; null and self.isKindOf(CM_SlotDefnVessel) then //22 Jun 2020	NDL	TFS 49408 - Not for Voyage ones
				aftSlot.is53 := self.is53; 
				if not aftSlot.is53 then
					aftSlot.isBackend := false;
				else
					aftSlot.isBackend := not self.isBackend;
				endif;
			endif;
		endif;
	elseif _theAttribute = CM_SlotRequest.Attribute_Thirty then
		self.is30 := not self.is30;
		if not self.is30 then
			self.isBackend := false;
		else
			self.isBackend := self.myBay.isAftBay();
		endif;
		aftSlot := self.myAftSlot;
		//if aftSlot &lt;&gt; null then
		if aftSlot &lt;&gt; null and self.isKindOf(CM_SlotDefnVessel) then //22 Jun 2020	NDL	TFS 49408 - Not for Voyage ones
			aftSlot.is30 := self.is30; 
			if not aftSlot.is30 then
				aftSlot.isBackend := false;
			else
				aftSlot.isBackend := not self.isBackend;
			endif;
		endif;
	// PAR 18682
	elseif _theAttribute = CM_SlotRequest.Attribute_FortyFive then
		self.is45 := not self.is45;
		if not self.is45 then
			self.isBackend := false;
		else
			self.isBackend := self.myBay.isAftBay();
		endif;
		aftSlot := self.myAftSlot;
		if aftSlot &lt;&gt; null then
			aftSlot.is45 := self.is45; 
			if not aftSlot.is45 then
				aftSlot.isBackend := false;
			else
				aftSlot.isBackend := not self.isBackend;
			endif;
		endif;

	elseif _theAttribute = CM_SlotRequest.Attribute_Forty then
		if self.isTransient then
			self.fortyFront := (not self.fortyFront);
		else
			self.setAsFortyFoot(not self.fortyFront);
			//self.setFortyAttributes(not self.fortyFront);
		endif;
	elseif _theAttribute = CM_SlotRequest.Attribute_Hicubed then
		self.highCubed := not self.highCubed;
	elseif _theAttribute = CM_SlotRequest.Attribute_Power then
		self.power := not self.power;
	elseif _theAttribute = CM_SlotRequest.Attribute_Reefer then
		self.reefer := not self.reefer;
	elseif _theAttribute = CM_SlotRequest.Attribute_Unavailable then
		self.unavailable := not self.unavailable;
	elseif _theAttribute = CM_SlotRequest.Attribute_Watercooled then
		self.watercooled := not self.watercooled;
	elseif _theAttribute = CM_SlotRequest.Attribute_D20 then
		self.doors20Aft := not self.doors20Aft;
	elseif _theAttribute = CM_SlotRequest.Attribute_D40 then
		self.doors40Aft := not self.doors40Aft;
	elseif _theAttribute = CM_SlotRequest.Attribute_M20 then
		self.motor20Aft := not self.motor20Aft;
	elseif _theAttribute = CM_SlotRequest.Attribute_M40 then
		self.motor40Aft := not self.motor40Aft;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown attribute (' &amp; _theAttribute.String &amp; ')');
	endif;

end;</source>
        <Parameter name="_theAttribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="setAsFortyFoot" id="5fcc4ca4-d931-4908-94fa-4bed7a1e51fa">
        <updating/>
        <source>setAsFortyFoot(_setForty : Boolean) updating;
//----------------------------------------------------------------
//	Created:	29 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	bay: CM_Bay;
	aftPxySlot, aftRealSlot, myPxySlot : CM_SlotDefn;
begin

	exclusiveLock(self);
	
/*	if self.unavailable 
	and  _setForty then
		return;
	endif; */
	
	//03 Feb 2012	NDL	Par 28640
	if self.unavailable then
		self.fortyFront := false;
		self.fortyBack := false;
		if self.myAftSlot &lt;&gt; null then	//15 Feb 2012	NDL	Par 28975
			self.myAftSlot.fortyBack := false;
		endif;
		return;
	endif;

	bay := self.myBay;
	if bay = null then
		// Do a db integrity check
		app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bay.id, "There is no aft bay.", null, null);
		return;
	endif;

	sharedLock(bay);
	
	//09 Feb 2012	NDL	Par 28640 - hold is not big enough for a 40

	if bay.myHold.allBays.size &lt; 2 then
		self.fortyFront := false;
		self.fortyBack := false;
		if self.myAftSlot &lt;&gt; null then	//15 Feb 2012	NDL	Par 28975
			self.myAftSlot.fortyBack := false;
		endif;
		return;
	endif;
	
	//  validation in validation method called by validation agent in TRX
	if (not bay.isLastInHold()) // &lt;&lt;&lt;&lt;&lt; 1st bay in a twin or 2nd in a triple
	and  self.myAftSlot &lt;&gt; null then

		exclusiveLock(self.myAftSlot);

		if _setForty 
		and self.myAftSlot.unavailable then
			return;
		endif;
		
		// ### if this is the 2nd of a triple and the 3rd in the tripple is not 40 then do not auto set the 3rd as a 40 back.
		if bay.bayType = BAY_TYPE_TRIPLE and (not bay.isFirstInHold()) then // ### 9447
			// I am in the middle bay of a tripple hold.
			aftPxySlot := self.myAftSlot.pxyGetProxyObject();// ### 9447
			if aftPxySlot &lt;&gt; null then// ### 9447
	
				self.myAftSlot.fortyBack := aftPxySlot.fortyFront;// ### 9447
				
			else			
				// Set the next slot to the same as the forty front
				self.myAftSlot.fortyBack := _setForty;// ### 9447
			endif;
		else
			// auto set the aft slot's 40 back end setting
			// Set the next slot to the same as the forty front
			self.myAftSlot.fortyBack := _setForty;
			
			//03 Feb 2012	NDL	Par 28640
			if _setForty then
				//self.myAftSlot.fortyFront := false;
				if bay.myHold = self.myAftSlot.myBay.myHold then	//09 Feb 2012	NDL	Par 28640
					// if the one behind me is in the same hold and I'm the front 40, it can't be a front 40.
					self.myAftSlot.fortyFront := false;
				endif;
			endif;
			
		endif;
	endif;
	
	//03 Feb 2012	NDL	Par 28640
	if bay = bay.myHold.getLastBayInHold then // takes into account part way through an update (ordinals change order of array.)
		self.fortyFront := false; // 13 Feb 2012 - last slot can't be a 40 front ever....
		if self.myAftSlot &lt;&gt; null then//08 Feb 2012	NDL	Par 28640
			// we are the last one in the hold and the guy behind is the first in the next hold, so can't be a back end 40
			self.myAftSlot.fortyBack := false;
		endif;
		if self.myForwardSlot = null or self.myForwardSlot.unavailable then
			// we are the last one in the hold and the guy in front doesnt exist
			// or is unavailable, we can only be a 20.
			self.fortyBack := false;
		endif;
		return;
	endif;
	
	
/* validation in validation method called by validation agent in TRX
	having validation in the update caused a conflict with the proxy bays.
	The current bay has been updated from the proxy, but teh aft bays has not yet. 
	The code came in here and compared this slot with a aft slot that had not yet been updated from the proxy.
	and failed. So moved the validation to validate the proxies and then in here can just update.

	if bay.bayType = BAY_TYPE_SINGLE then // if only a single bay =&gt; error
		if _setForty then //if setting 40' property ON
			app.setContinueCMExceptions(false);
			app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bay.id, "Bay " &amp; bay.id &amp; "is a single bay.", null, null);
			return;
		endif;
	else
		if (not bay.isLastInHold()) 
		and  self.myAftSlot &lt;&gt; null then

			exclusiveLock(self.myAftSlot);

			if _setForty 
			and self.myAftSlot.unavailable then
				app.raiseCMException3(ERR_FORTYBACK, self.getStowageId(false,true),bay.id,null, null, null);
				return;
			endif;
			// Set the next slot to the same as the forty front
			self.myAftSlot.fortyBack := _setForty;
		endif;
	endif;
	*/
	if bay.isLastInHold() then
		// do nothing.  This should be validated here but
		// can't be because of the pxyCreateUpdateProxy overrides
		// the fortyFront attribute
	else
		self.fortyFront := _setForty;
	endif;
end;</source>
        <Parameter name="_setForty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="dd2778d2-0807-4e9b-8aa0-b2083dcd83d3">
        <updating/>
        <source>setAttributes(_30 : Boolean; _53 : Boolean; _45 : Boolean; _fortyFront : Boolean;_power : Boolean;_reefer : Boolean;_watercooled : Boolean;
				_unavailable : Boolean;_doors20Aft : Boolean;_doors40Aft : Boolean;_mtOnly : Boolean;
				_motor20Aft : Boolean;_motor40Aft : Boolean; _heavy : Boolean; _voltage : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aftSlot : CM_SlotDefn;

begin
	self.raiseExceptionIfNotTransient(method);

	aBay := self.myBay;
	/* // PAR 16415 CCMS 1029
	if aBay.canHandle4045() and aBay.isForwardBay then // PAR 8541
		aftSlot := self.myAftSlot;
		if aftSlot &lt;&gt; null then // PAR 8541
			aftSlot.fortyFront := _fortyFront; // PAR 8541
			aftSlot.fortyBack := _fortyFront; // PAR 8541
		endif;
	endif;
	*/
	 // PAR 16415 CCMS 1029
	if aBay.isForwardBay then
		aftSlot := self.myAftSlot;
		if aftSlot &lt;&gt; null then
			if aBay.canHandle4045() then
				aftSlot.fortyFront := _fortyFront; // PAR 8541
				aftSlot.fortyBack := _fortyFront; // PAR 8541
			endif;
			aftSlot.is30 := _30; 
			aftSlot.is45 := _45; 
			aftSlot.is53 := _53; 

			if aftSlot.is30 or aftSlot.is45 or aftSlot.is53 then // PAR 22076
				aftSlot.isBackend := true; 
			else // PAR 22076
				aftSlot.isBackend := false; // PAR 22076
			endif;
			
			// For 53s set AFT AFT slot
			aftSlot := aftSlot.myAftSlot;
			if aftSlot &lt;&gt; null then
				aftSlot.is53 := _53; 
				if aftSlot.is53 then // PAR 22076
					aftSlot.isBackend := true; 
				endif;
			endif;
		endif;
	endif;

	self.fortyFront := _fortyFront;
	self.fortyBack := _fortyFront;
	self.is30 := _30; // PAR 16415 CCMS 1029
	self.is45 := _45; // PAR 16415 CCMS 1029
	self.is53 := _53; // PAR 16415 CCMS 1029
	// PAR 22076 self.isBackend := false; // PAR 16415 CCMS 1029
	self.isBackend := (not aBay.isForwardBay); // PAR 22076
	self.power := _power;
	self.reefer := _reefer;
	self.watercooled := _watercooled;
	self.unavailable := _unavailable;
	self.doors20Aft := _doors20Aft;
	self.doors40Aft := _doors40Aft;
	self.motor20Aft := _motor20Aft;
	self.motor40Aft := _motor40Aft;
	self.mtOnly := _mtOnly;
	self.heavy := _heavy;
	self.voltageType := _voltage;
end;</source>
        <Parameter name="_30" type="Boolean"/>
        <Parameter name="_53" type="Boolean"/>
        <Parameter name="_45" type="Boolean"/>
        <Parameter name="_fortyFront" type="Boolean"/>
        <Parameter name="_power" type="Boolean"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_watercooled" type="Boolean"/>
        <Parameter name="_unavailable" type="Boolean"/>
        <Parameter name="_doors20Aft" type="Boolean"/>
        <Parameter name="_doors40Aft" type="Boolean"/>
        <Parameter name="_mtOnly" type="Boolean"/>
        <Parameter name="_motor20Aft" type="Boolean"/>
        <Parameter name="_motor40Aft" type="Boolean"/>
        <Parameter name="_heavy" type="Boolean"/>
        <Parameter name="_voltage" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAttributesFromPxy" id="5277b419-f329-4a36-b80f-4094ccc19e76">
        <updating/>
        <source>setAttributesFromPxy(_fortyFront : Boolean;_power : Boolean;_reefer : Boolean;_watercooled : Boolean;
				_unavailable : Boolean;_doors20Aft : Boolean;_doors40Aft : Boolean;_mtOnly : Boolean;
				_motor20Aft : Boolean;_motor40Aft : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.fortyFront := _fortyFront;
	self.fortyBack := _fortyFront;
	self.power := _power;
	self.reefer := _reefer;
	self.watercooled := _watercooled;
	self.unavailable := _unavailable;
	self.doors20Aft := _doors20Aft;
	self.doors40Aft := _doors40Aft;
	self.motor20Aft := _motor20Aft;
	self.motor40Aft := _motor40Aft;
	self.mtOnly := _mtOnly;
end;</source>
        <Parameter name="_fortyFront" type="Boolean"/>
        <Parameter name="_power" type="Boolean"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_watercooled" type="Boolean"/>
        <Parameter name="_unavailable" type="Boolean"/>
        <Parameter name="_doors20Aft" type="Boolean"/>
        <Parameter name="_doors40Aft" type="Boolean"/>
        <Parameter name="_mtOnly" type="Boolean"/>
        <Parameter name="_motor20Aft" type="Boolean"/>
        <Parameter name="_motor40Aft" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCellAndTierDefn" id="afc34406-1f60-4997-bc41-9f00de6b5848">
        <updating/>
        <source>setCellAndTierDefn(_cd : CM_CellDefn;_td : CM_TierDefn) updating;
/*
 ------------------------------------------------------------------------
Created:			08 October 2002 by cnwdwq1
Purpose:			Set the 2 properties automatically.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	self.myTierDefinition := _td;
	self.myCellDefinition := _cd;
end;</source>
        <Parameter name="_cd" type="CM_CellDefn"/>
        <Parameter name="_td" type="CM_TierDefn"/>
    </JadeMethod>
    <JadeMethod name="setDefaultDoorDirections" id="50e2190b-7344-4989-8fdd-e626615d0db6">
        <updating/>
        <source>setDefaultDoorDirections(_dirController : CMIF_DirectionController) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1045 
//
// ---------------------------------------------------------------------------

vars
	dirController :  CMIF_DirectionController;
begin

	dirController := _dirController;
	
	if self.ordinalDeck = DeckOnDeck then
		self.doors20Aft := dirController.dirODDoors20AFT; //On Deck Doors20 AFT
		self.doors40Aft := dirController.dirODDoors40AFT; //On Deck Doors40 AFT
		self.motor20Aft := dirController.dirODMotor20AFT; //On Deck Motor20 AFT
		self.motor40Aft :=  dirController.dirODMotor40AFT; //On Deck Motors40 AFT
	else
		if self.myBay.isAftBay then
			self.doors20Aft := not dirController.dirUDDoors20AFTFWD; //Under Deck Doors20 In AftBay are FWD
			self.doors40Aft := dirController.dirUDDoors40AFT; //Under Deck Doors40 AFT
			self.motor20Aft := dirController.dirUDMotor20AFTAFT; //Under Deck Motor20 In AftBay AFT
			self.motor40Aft :=  dirController.dirUDMotor40AFT; //Under Deck Motor40 AFT
		else
			self.doors20Aft := dirController.dirUDDoors20FWDAFT; //Under Deck Doors20 In FwdBay AFT
			self.doors40Aft := dirController.dirUDDoors40AFT; //Under Deck Doors40 AFT
			self.motor20Aft := not dirController.dirUDMotor20FWDFWD; //Under Deck Motor20 In FwdBay FWD
			self.motor40Aft :=  dirController.dirUDMotor40AFT; //Under Deck Motor40 AFT
		
		endif;
	endif;
	

end;</source>
        <Parameter name="_dirController" type="CMIF_DirectionController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fd3eda1a-dce3-4080-aa8e-25b2ce2aaa4b">
        <updating/>
        <source>setForCreate (_proxy:SelfType; _passport : CM_Passport input) updating; //, serverExecution;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	_proxy.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxy,_passport);

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="814509c6-3752-40a1-96e0-e2b2cb4aeae7">
        <updating/>
        <source>setForUpdate(_proxy:SelfType; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bayIndex, bayType : Integer;
	amForty : Boolean;
	aftSlot : CM_SlotDefn;

begin
	self.cellId := _proxy.cellId;
	self.tierId := _proxy.tierId;
	self.ordinalCell := _proxy.ordinalCell;
	self.ordinalDeck := _proxy.ordinalDeck;
	self.ordinalTier := _proxy.ordinalTier;
	self.unavailable := _proxy.unavailable;	//03 Feb 2012	NDL	Par 28640 - moved up 
	
//03 Feb 2012	NDL	Par 28640
	if (not self.unavailable) then
		if (_proxy.myAftSlot &lt;&gt; null)
		and  (not _proxy.myAftSlot.unavailable) then
			self.setAsFortyFoot(_proxy.fortyFront);
		else
			self.setAsFortyFoot(false);
		endif;
	else
		self.setAsFortyFoot(false);
	endif;
	
	self.is30 := _proxy.is30; // PAR 16415 CCMS 1029
	self.is45 := _proxy.is45; // PAR 16415 CCMS 1029
	self.is53 := _proxy.is53; // PAR 16415 CCMS 1029
	self.isBackend := _proxy.isBackend; // PAR 16415 CCMS 1029 // PAR 17841
	
	self.doors20Aft := _proxy.doors20Aft;
	self.doors40Aft := _proxy.doors40Aft;
	
	self.motor20Aft := _proxy.motor20Aft;
	self.motor40Aft := _proxy.motor40Aft;
	self.power := _proxy.power;
	self.reefer := _proxy.reefer;
	self.mtOnly := _proxy.mtOnly;
	self.heavy := _proxy.heavy;
	self.voltageType := _proxy.voltageType;
	self.sequenceNumPortDis := _proxy.sequenceNumPortDis;
	self.sequenceNumPortLoad := _proxy.sequenceNumPortLoad;
	self.sequenceNumStarDis := _proxy.sequenceNumStarDis;
	self.sequenceNumStarLoad := _proxy.sequenceNumStarLoad;
	self.sequenceNumPortDis40 := _proxy.sequenceNumPortDis40; // PAR 13217
	self.sequenceNumPortLoad40 := _proxy.sequenceNumPortLoad40; // PAR 13217
	self.sequenceNumStarDis40 := _proxy.sequenceNumStarDis40; // PAR 13217
	self.sequenceNumStarLoad40 := _proxy.sequenceNumStarLoad40; // PAR 13217
	self.watercooled := _proxy.watercooled;
	
	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxy,_passport);
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
