    <JadeMethod name="createProxy" id="b9cd554f-d104-4b96-b6da-724f060ed9cc">
        <source>createProxy() : CM_DriverDetails;
/*

Date		Who		Reason
27/11/2014	cnwer1	Initial creation PAR 35304
18/10/20149	jlgdap1	TFS 46854 SNO Driver Identity Chceking for Cargo Release
*/

vars
	realDriver,
	proxy : CM_DriverDetails;
	allCarriers : CM_CarrierByCodeDict;
	allVehicles : CM_VehicleSet ;
begin
	
	if self.action = self.EDI_ACTION_ADD then
		create proxy transient;
	else
		realDriver:=self.getDriverDetails();
		if realDriver = null then
			return null;
		endif;
		proxy:=realDriver.pxyCreateUpdateProxy.CM_DriverDetails;
	endif;
	create allCarriers transient;
	self.getCarriers(allCarriers);
	
	create allVehicles transient;
	self.getVehicles(allVehicles); 
	
	//proxy.setProxy(self.name,self.code,self.secondaryCode,self.getDriverStatusInteger,self.getMyTerminal,allCarriers,allVehicles);		// TFS 46854
	proxy.setProxy(self.name,self.code,self.secondaryCode,self.getDriverStatusInteger,null,self.getMyTerminal,allCarriers,allVehicles);		// TFS 46854
	
	return proxy;
epilog
	delete allCarriers;
	delete allVehicles;
end;</source>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="getCarriers" id="c9b61259-723d-4359-bc83-ccb3c629f918">
        <source>getCarriers(_allCarriers : CM_CarrierByCodeDict input);
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	carrierCodes : StringArray;
	carrierCode : String;
	carrier : CM_Carrier;
begin
	if _allCarriers = null then
		return;
	endif;
	
	create carrierCodes transient;
	self.carriers.getTokensForDelimiter("|",carrierCodes);
	
	foreach carrierCode in carrierCodes do
		carrier:=app.myRoot.allCarriers[carrierCode.trimBlanks];
		if carrier &lt;&gt; null then
			if not carrier.isRoad then
				continue;
			endif;
			if  carrier.isNotAvailableForEntry then
				continue;
			endif;
			_allCarriers.addNoDuplicates(carrier,false);
		endif;
	endforeach;
	
epilog
	delete carrierCodes;
end;</source>
        <Parameter name="_allCarriers" type="CM_CarrierByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDriverDetails" id="95d43540-6c0d-4117-9c87-de6ae54ec6da">
        <source>getDriverDetails() : CM_DriverDetails;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	terminal : CM_Terminal;
begin
	terminal:=self.getMyTerminal();
	if terminal = null then
		return null;
	endif;
	
	return terminal.allDriversByCode[self.code];
epilog

end;</source>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="getDriverStatusInteger" id="9a3b6879-feda-4768-abae-145ccc7fd880">
        <source>getDriverStatusInteger() : Integer;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin
	if self.driverStatus = CM_DriverDetails.Status_Allowed_String   then
		return  CM_DriverDetails.Status_Allowed;
	elseif  self.driverStatus = CM_DriverDetails.Status_Suspended_String then
		return  CM_DriverDetails.Status_Suspended;
	elseif self.driverStatus =   CM_DriverDetails.Status_Banned_String then
		return CM_DriverDetails.Status_Banned;
	endif;	
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
