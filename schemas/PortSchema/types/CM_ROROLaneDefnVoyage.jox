    <JadeMethod name="getFirstUnplannedRequest" id="891d2a52-4a61-471f-bb3b-75d29b82b5fd">
        <source>getFirstUnplannedRequest(_isLoad : Boolean) : CM_RORORequest;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/


vars
	theReq : CM_RORORequest;
	theTI : CM_TrackedItem;
	theWLE : CM_VoyageWLE;
begin
	if _isLoad then
		theReq := self.myLaneController.myRORORequestLoad;
	else
		theReq := self.myLaneController.myRORORequestDischarge;
	endif;
	if theReq &lt;&gt; null then
		if not _isLoad then // DISCHARGE
			theTI := theReq.getFirstUnplannedTI();
			if theTI &lt;&gt; null then
				return theReq;
			endif;
		else // PAR 28942
			theWLE :=  theReq.getFirstUnusedWLE().CM_VoyageWLE;
			if theWLE &lt;&gt; null then
				if theWLE.myTrackedItem = null then
					return theReq;
				endif;
			endif;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="getKPIArea" id="18126090-a614-4159-b561-239bb7329621">
        <source>getKPIArea(_mode: Integer; _tis: CM_TIArray input; _area, _volume : Decimal output);
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars
	tmpTI : CM_TrackedItem;
begin
	//_tis.clear();
	_volume := 0;
	_area :=  0;
	
	// ### ACTUAL VIEW
	if _mode = ShpDisplayMode_Actual then
		self.getAllTIs(REAL_MODE, _tis, true);
	// ### PROPOSED VIEW
	elseif _mode = ShpDisplayMode_Proposed then
		self.getProposedTIs( _tis, true);
	endif;
	
	if not _tis.isEmpty() then
		_area := self.getAreaInSquareMetres();
	endif;
	
	foreach tmpTI in _tis discreteLock do
		_volume := _volume + tmpTI.totalVolume;
	endforeach;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_area" type="Decimal" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
    </JadeMethod>
