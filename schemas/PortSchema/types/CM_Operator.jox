    <JadeMethod name="getAllOperatorGroupsAsString" id="5f4ca6bb-f5e7-4c2f-a893-070be0bea694">
        <source>getAllOperatorGroupsAsString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2014	cnwrd1	Initial creation

*/

vars
	result,
 	separator 	: String;
	operGroup 		: CM_OperatorGroup;
begin

	separator := ' ';

	foreach operGroup in self.allOperatorGroups do
	
		result := result &amp; separator &amp; operGroup.code;
		separator := ', ';
	endforeach;
	
	return result;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
