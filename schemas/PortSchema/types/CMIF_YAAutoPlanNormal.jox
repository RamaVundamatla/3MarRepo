    <JadeMethod name="isVoyageInbound_Match" id="8a024513-0687-4a14-ab43-8022c516e324">
        <source>isVoyageInbound_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
*/
vars

begin
	// We don't have a voyage so no match.
	if self.myTrackedItem.voyageInbound = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Check to see whether voyage matches priority selection.
	return _yaData.matches(self.myTrackedItem.voyageInbound);
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageOperator_Match" id="d05cb21d-0acb-4fb8-a720-4a2a62dbd64b">
        <source>isVoyageOperator_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	voyOp	: CM_VoyageOperator;

begin

	if self.myTrackedItem.myVoyage = null then
		return false;
	endif;
	
	if self.myTrackedItem.myVoyage.allVoyageIOperators.isEmpty() then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	foreach voyOp in self.myTrackedItem.myVoyage.allVoyageIOperators discreteLock do
		if _yaData.matches(voyOp) then
			return true;
		endif;
	endforeach;
	
	return false;


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
