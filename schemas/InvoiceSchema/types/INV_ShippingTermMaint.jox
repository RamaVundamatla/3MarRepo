    <JadeMethod name="tblDisplayRow" id="4123498b-37cc-4567-bfb5-36e68a32bfe9">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	tbl					: CM_DataTable;
	invLineDesc			: CM_InvoiceLineDesc;
	idx					: Integer;
	str 				: String;
	//invLineDesc: 			CM_InvoiceLineDesc;
	mapping : CM_InvoiceShipTermMapping;
	invalid	: Boolean;
begin

	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	
	if self.myShipTerm = null then//or self.myShipTerm.allShipTermMappingsByInvLnType.isEmpty() then
		return;
	endif;
	
	foreach mapping in self.myShipTerm.allShipTermMappings do
		on Exception do app.handleDeletedObject( exception, mapping, invalid );
		
		if invalid then
			tbl.removeDeletedObject(mapping);
			return;
		endif;
		
		str := mapping.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := mapping;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="33a505fc-acb2-4e9f-85fb-43b6b7a61f81">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 October 2023 10:23:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025399, locale);
	btnAdd.translateCaption(Xlat_0025400, locale);
	btnAudits.translateCaption(Xlat_0025401, locale);
	btnClose.translateCaption(Xlat_0025402, locale);
	btnRemove.translateCaption(Xlat_0025403, locale);
	btnSave.translateCaption(Xlat_0025404, locale);
	btnUpdate.translateCaption(Xlat_0025405, locale);
	lblCode.translateCaption(Xlat_0025406, locale);
	lblDescription.translateCaption(Xlat_0025407, locale);
	lblcharge.translateCaption(Xlat_0026481, locale);
	mappings.translateCaption(Xlat_0025408, locale);
	msgInvlistTypes.translateCaption(Xlat_0026482, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateShipMapping" id="63b797c0-8695-4274-9439-6b8b71ad2683">
        <updating/>
        <source>updateShipMapping()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms

*/

vars
	charge,debtor : CM_DebtorType;
	pxyShippingTermMapping,
	realShippingTermMapping:CM_InvoiceShipTermMapping;
	bank : CM_Bank;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	theReturn : Integer;
begin
	realShippingTermMapping := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceShipTermMapping;
	if realShippingTermMapping = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	pxyShippingTermMapping := app.createUpdateProxy(realShippingTermMapping).CM_InvoiceShipTermMapping;
	if self.cmbCharge.listIndex &lt;&gt; -1 then
		charge := self.cmbCharge.itemObject[self.cmbCharge.listIndex].CM_DebtorType;
	endif;
	bank := self.myCurrentBank;
	debtor := app.myRoot.allDebtorTypes.first;
	create allInvoice transient;
	
	self.msgInvlistTypes.getSelected(allInvoice);
	
	pxyShippingTermMapping.setProxy(pxyShippingTermMapping.priority,pxyShippingTermMapping.myShippingTerm,charge,allInvoice);

		while true do
		app.myTrxUA.trxUpdateinvoiceShipMapping(pxyShippingTermMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_shippin_mapping_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyShippingTermMapping;
	delete allInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateShipTerm" id="6d9600b7-6b30-4cf5-917c-11aff0bd6146">
        <updating/>
        <source>updateShipTerm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint
30 Jan 2023 navtnr20	Bug 56311: EUP - Invoice Shipping Terms - Usability

*/

vars
	pxyShippingTerm,
	realShippingTerm:CM_InvoiceContractShipTerm;
	code,desc : String;
	theReturn : Integer;
begin
	pxyShippingTerm := app.createUpdateProxy(self.myShipTerm).CM_InvoiceContractShipTerm;
	if self.txtCode &lt;&gt; null then
		code := self.txtCode.text.String;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text.String;
	endif;	
	pxyShippingTerm.setProxy(code,desc,self.myCurrentBank);
	while true do
		app.myTrxUA.trxUpdateInvContractShpngTerms(pxyShippingTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Shippin_terms_update_success), app.getErrorString(Message),MsgBox_OK_Only);
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Shipping_term_updated), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyShippingTerm;
end;</source>
    </JadeMethod>
