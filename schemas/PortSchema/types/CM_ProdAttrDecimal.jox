    <JadeMethod name="initialize" id="5080f023-ace0-4925-8b6f-3a8815de0fcf">
        <updating/>
        <source>initialize(_name: String; _displayName: String) updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 07/03/2014	cnwdap1		PAR #33661 Set myMeasurementType if necessary
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
vars
	
begin
	inheritMethod(_name, _displayName);
	
	if _name.isOneOf(ETRow_MyWidth, ETRow_MyHeight, ETRow_MyLength) then
		self.myMeasurementType := app.getDefaultMeasurementForType(Type_Linear);
	elseif _name = ETRow_MyWeight then
		self.myMeasurementType := app.getDefaultMeasurementForType(Type_Weight);
	elseif _name = ETRow_MyVolume then
		self.myMeasurementType := app.getDefaultMeasurementForType(Type_Volume);
	elseif _name = ETRow_MyStowageFactor then												// PAR #33606
		self.myMeasurementType := app.getDefaultMeasurementForType(Type_StowageFactor);		// PAR #33606
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_displayName" type="String"/>
    </JadeMethod>
    <JadeMethod name="multiplyValue" id="7e478187-8a31-4e5f-9742-1f1c091d4396">
        <source>multiplyValue(_value: Decimal): Decimal;
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	//result			: Decimal[10,4];
	// cnwjk3 06/03/2009 - PAR 16505
	result			: Decimal[14,4];
begin
	result := _value * self.multiplier;
	
	if result mod 1 = 0 then
		return result.Integer;
	else
		return result;	
	endif;

	//return result.truncatedTo(0);
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="parseAndAssignRange" id="05660c7e-7123-452a-8399-11612b34580c">
        <updating/>
        <source>parseAndAssignRange(_range : String)  : String updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     Takes a string of format 'xxx-xxx', chops it up, and assigns
//				the results to min and max values. 
//				
//
// ----------   ----------  --------------------------------------------------
vars
	rangeStrArray		: StringArray;
begin
	
	rangeStrArray := _range.getTokens;
	if rangeStrArray.size &lt;= 1 then
		return 'Format does not equal "[number]:[number]"';
	endif;
		
	self.minValue := rangeStrArray[1].asDecimalJMT();	// PAR 22189 Feb 2010	
	self.maxValue := rangeStrArray[2].asDecimalJMT();	// PAR 22189 Feb 2010
	if self.minValue &gt; self.maxValue then
		return 'The minimum value specified is greater than the maximum';
	endif;
	//validate that the value is within the range specified
	if self.minValue &lt;&gt; null and self.maxValue &lt;&gt; null then
		if self.value &lt; self.minValue then
			return 'The value specified is less than the range minimum';
		elseif self.value &gt; self.maxValue then
			return 'The value specified is greater than the range maximum';
		endif;
	endif;
	
epilog
	delete rangeStrArray;
end;</source>
        <Parameter name="_range" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b6c7d534-ca29-4dd4-8281-c4a1a9afd2fc">
        <updating/>
        <source>setForUpdate(_pxyAttr: CM_ProdAttrDecimal) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_pxyAttr);
	//should have EITHER range OR value
	//should have EITHER range OR value
	if _pxyAttr.validationType = ValidationType_Value then
		self.value		:= _pxyAttr.value;
		self.multiplier := _pxyAttr.multiplier;
		self.minValue 	:= _pxyAttr.minValue;	
		self.maxValue 	:= _pxyAttr.maxValue;	
	endif;
	
	
end;</source>
        <Parameter name="_pxyAttr" type="CM_ProdAttrDecimal"/>
    </JadeMethod>
    <JadeMethod name="setFromAttrInt" id="adc36b0f-aece-4e3d-90be-6665e47fe6db">
        <updating/>
        <source>setFromAttrInt( _toCopy : CM_ProdAttrInteger) updating;
 
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwrd1	Initial creation

*/

vars

begin
	self.maxValue 			:= _toCopy.maxValue.Decimal;
	self.minValue 			:= _toCopy.minValue.Decimal;
	self.multiplier 		:= _toCopy.multiplier;
	self.value 				:= _toCopy.value.Decimal;
	self.myMeasurementType	:= _toCopy.myMeasurementType; 	// ### TFS 52193 22Nov2021 NAVPW1

	self.myType 			:= Decimal;
	self.myCode 			:= _toCopy.myCode;
	self.displayName 		:= _toCopy.displayName;
	self.isViewable 		:= _toCopy.isViewable;
	self.validationType 	:= _toCopy.validationType;
	self.name				:= _toCopy.name;				// ### TFS 52193 22Nov2021 NAVPW1
	
epilog

end;</source>
        <Parameter name="_toCopy" type="CM_ProdAttrInteger"/>
    </JadeMethod>
