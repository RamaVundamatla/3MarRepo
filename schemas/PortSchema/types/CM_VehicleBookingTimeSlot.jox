        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSendLoadNotification" id="74d7543d-dc35-416e-a6ea-49519203b55e">
        <source>canSendLoadNotification() : Boolean;
/*

Purpose:		has to be linked to a road release request  where the freight forwarder is marked as internal
				- the rr should only be linked to one VBS slot 
				- only sent when a release quantity is provided  ( if release line is missing quantiy ot is set as any id/amount

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023	jlier1	Initial creation 58839

*/

vars
	vbsSlotItem : CM_VehicleBookingTimeSlotItem;
	release : CM_BulkRelease;
	hasInternalFF : Boolean;
	bgpRequest : BGP_Request;
begin
	
	foreach bgpRequest in self.allAPIWSRequests discreteLock do
		if bgpRequest.BGP_APIWSRequest.datatype = BGP_APIWSRequest.Type_LoadNotification then
			app.writeLog(method.qualifiedName &amp; " A pending BGP request for LoadNA already exists, skipping", LogINFO);
			return false;
		endif;
	
	endforeach;
	
	foreach vbsSlotItem in self.allVehicleBookingItems discreteLock do 
		if release &lt;&gt; null and vbsSlotItem.myBulkRelease &lt;&gt; null and vbsSlotItem.myBulkRelease &lt;&gt; release then
			app.writeLog(method.qualifiedName &amp; " [" &amp; vbsSlotItem.String &amp; "] Multiple different Release Requests assigned to Slot, skipping", LogTRACE);
			return false;
		endif;
	
		
		if vbsSlotItem.myBulkRelease &lt;&gt; null then
			release:= vbsSlotItem.myBulkRelease;
			if not hasInternalFF and release.myFreightForwarder &lt;&gt; null and release.myFreightForwarder.isInternal then
				hasInternalFF:=true;
			endif;
			if vbsSlotItem.quantity  = null or vbsSlotItem.myReserveDetails.isKindOf(CM_ReserveSelection) and vbsSlotItem.myReserveDetails.CM_ReserveSelection.defaultAnyAmount then
				app.writeLog(method.qualifiedName &amp; " [" &amp; vbsSlotItem.String &amp; "] No/Unknown quantity, skipping", LogTRACE);
				return false;
			endif;
		endif;
		
	endforeach;
	
		
	if not hasInternalFF then
		app.writeLog(method.qualifiedName &amp; " At least one Freight Forwarder is not 'Internal', skipping", LogINFO);
		return false;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Returning True", LogINFO);
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEvent" id="852ba6be-0343-4bcb-85bd-ae678761ca15">
        <source>createEvent(_type : Integer; _time : TimeStamp; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl):CMEVT_VehicleBookingEvent;

/*

Purpose:

Parameters:			

Return Value:		


Date			Who		Reason
08 March 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	trans : CMEVT_VehicleBookingEvent;
	wod : CM_WorkOrderToDoDtl;
	cmifEventCtrl : CMIF_VehicleBookingCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	trans := app.createEvent(_type, _time, app.myPassport.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_VehicleBookingEvent; // ### TFS BUG 64545 11JUNE024 NAVAB1
	if trans  &lt;&gt; null then
		trans.setMyVehicleBookingSlot(self);
		 // ### TFS BUG 64545 11JUNE024 NAVAB1 trans.setMyTerminal(app.myPassport.myTerminal);
		if self.myVehicleVisitRecord &lt;&gt; null then
			trans.setMyVehicleVisit(self.myVehicleVisitRecord);
		endif;
		trans.addResourcesFromProxys(_resourceUsageProxys); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail().CM_WorkOrderToDoDtl; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setFromWOD(wod);// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1 // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
			//trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := _time;
	cmifEventCtrl.myTerminal := app.myPassport.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVehicleBookingSlot := self;
	cmifEventCtrl.myVehicleVisitRecord := self.myVehicleVisitRecord;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := _wod;
	
	if _resourceUsageProxys &lt;&gt; null then 
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VehicleBookingEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	return trans;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_VehicleBookingEvent"/>
    </JadeMethod>
    <JadeMethod name="createToDoTask" id="a9df494a-28e3-4bb9-8e63-f87451f455ab">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_VBSToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask : CM_VBSToDoTask;
	toDoDesc : CM_ToDoTaskDesc;
	found	 : Boolean;
	passport : CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_VBSToDoTask"/>
    </JadeMethod>
