    <JadeMethod name="getAllTIs" id="4a00e031-4fb2-4bc5-9d14-f6c94a2581fd">
        <source>getAllTIs( _allTis : CM_TISet input );
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	wod : CM_WorkOrderDtl;
begin

	
	foreach wod in self.allWoDtls discreteLock do												//08.02.2023 navma1 #56457:[56458
		wod.CM_WorkOrderTIDtl.allSelectedTIs.copyNoDuplicates(_allTis,false);
	endforeach;
	
	//self.allTIs.copy( _allTis );													//08.02.2023 navma1 #56457:[56458			
	
	/*
	12.01.2023 navma1 #56141:[56147]
	if _allTis.isEmpty() and self.mySource &lt;&gt; null then
		self.mySource.getAllTIs( _allTis );
	endif;
	*/
	
epilog

end;</source>
        <Parameter name="_allTis" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="fcf442c0-f60d-4cf3-a211-97af3165bee2">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Aug2009	cnwmd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141:[56147] EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	auditStr, 
	tmpStr 		: String;
begin
	auditStr := inheritMethod();
	
	/*
	31.03.2025 navma1 #MTN-34387
	tmpStr   := self.allTIs.listString(Comma,CM_TrackedItem::id.name);		//12.01.2023 navma1 #56141:[56147]
	if tmpStr &lt;&gt; null then													//08.02.2023 navma1 #56457:[56458]
		auditStr := auditStr &amp; 'Cargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	*/
	
epilog
	return auditStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBooking" id="52eec252-cf6d-41f0-a4d6-4a5a59facd7c">
        <source>getBooking() : CM_BookingRef;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

begin
	if not self.isWorkOrderForReceival then
		return null;
	endif;
	
	return self.allWoDtls.first.CM_WodReceive.myBookingRef;
epilog

end;</source>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ac314eb7-4a17-4386-9414-a432377ef851">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2019	jlgndl1	Initial creation	TFS 43019
27 Feb 2019 navnk30 Bug 62220: MTN - work order enquiry doesn't seem to search as expected

*/

vars
	
	dtl 		: CM_WorkOrderDtl;
	voyage 		: CM_Voyage;
	invalid 	: Boolean;
	edition 	: Integer; 
	completed   : Integer;
begin

	if _attrName = ETRow_Voyage then
	
		on Exception do app.handleDeletedObject( exception, voyage, invalid );
		
		/*foreach dtl in self.allWoDtls do				//27.02.2024 navnk30 #62220
			voyage := dtl.getMyVoyageObject();
			if voyage &lt;&gt; null then
				edition := voyage.edition;
				if invalid then
					invalid := false;
					continue;
				endif;
				return voyage.code;
			endif;
		endforeach;*/
		voyage := self.getMyVoyageObject();				//27.02.2024 navnk30 #62220
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_CompleteLastTask then
		foreach dtl in self.allWoDtls do
			completed := completed + dtl.CM_WorkOrderTIDtl.allCompleteTIs.size;
		endforeach;
		return completed.String;
	else
		return inheritMethod(_attrName, _short);
	
endif;	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="92e317f5-d941-4ab9-9a3e-a86a69fe796d">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date   			Who		Reason
25 Aug 2009		cnwrd1	Initial creation
28 Jan 2019 	cnwma1	ChangeRequest 40213: PEL1 - Cargo Work Order Print Once Job Order Report
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Jun 2023 	navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
29 Sep 2023 	navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
15 May 2024 	navhl20 ChangeRequest 64150: EUP - Work Order - Remedial
16 May 2024		navdap1	TFS 64055 EUP - lock/1038 when loading an EDI file while Work Order Screen is open
*/

vars
	block    : CM_DataContainerBlock;
	wod 	 : CM_WorkOrderDtl;
	details	 : CM_WorkOrderDtlArray;		// TFS 64055
begin
	inheritMethod(_dataContainer);
	
	//28.01.2019 cnwma1	#40213
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Number_Of_Prints), DC_Label, 1, self);
	block.addNewItem(self.numPrints.String, DC_Data, 1, self);
	
	if app.isSpecial then														//06.06.2023 navma1 #58339
		block := _dataContainer.addNewBlock;
		block.addNewItem('All TIs', DC_Label, 1, self);
		block.addNewItem(self.allTIs.size.String,DC_Data,1,null);
	endif;
	//13 Mar 2019	NDL	TFS 43405
	create details transient;							// TFS 64055
	self.allWoDtls.copy(details);						// TFS 64055
	//foreach wod in self.allWoDtls	discreteLock do		// TFS 64055
	foreach wod in details discreteLock do				// TFS 64055
		wod.getExtraInfo(_dataContainer);
	endforeach;
		
epilog
	delete details;			// TFS 64055
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyBank" id="2f7febee-04aa-4624-8961-1c4eb263ece0">
        <source>getMyBank() : CM_Bank;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation
04 Oct 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	bank 	: CM_Bank;
	ti 		: CM_TrackedItem;
	wod		: CM_WorkOrderDtl;
	gotException : Boolean;
begin

	wod := self.allWoDtls.first;
	
	if wod &lt;&gt; null then
		ti := wod.CM_WorkOrderTIDtl.allSelectedTIs.first;
	endif;
	on Exception do app.handleDeletedObject(exception, ti, gotException);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	
	if ti &lt;&gt; null then
		bank := ti.companyOid;
	endif;
	
	return bank;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="76c516e0-a87b-42e4-ade5-068cb49359ee">
        <source>getMyDebtor() : CM_Debtor;
/*

