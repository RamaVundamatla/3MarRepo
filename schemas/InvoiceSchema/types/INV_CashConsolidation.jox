    <JadeMethod name="doBtnAssign" id="e572beb0-64d3-4098-bb6e-a6dafac5dabc">
        <source>doBtnAssign();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	msg : String;
	obj : Object;
	cashPayment : CM_CashPayment;
	cashPaymentSet : CM_CashPaymentSet;
	theReturn : Integer;

begin

	if self.myCurrentTrackedItem = null then
		msg := app.getErrorString( No_Cargo_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	if self.myCurrentInvoiceLine = null then
		msg := app.getErrorString( Invoice_line_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create cashPaymentSet transient;
	foreach obj in self.tblUnassCashP.allSelectedObjects do
		if obj.isKindOf( CM_CashPayment ) then
			cashPaymentSet.add( obj.CM_CashPayment );
		endif;
	endforeach;
	if cashPaymentSet.isEmpty then
		msg := app.getErrorString( Unassig_cash_payment_selecte );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	while true do
	
		app.myTrxUA.trxCashPaymentsConsolidate( cashPaymentSet, self.myCurrentInvoiceLine, app.myPassport );
		if app.myPassport.trxCompletedOK then
			self.refreshObjectDisplay( self.myCurrentInvoiceLine );
			break;
		else
			theReturn := app.showErrorWarningDialog("Cash Consolidation - Assign", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
		
	endwhile;
	
	
epilog

	delete cashPaymentSet;
	self.enableActionButtons();

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAssignManual" id="fa0beb5b-eb80-4718-a192-ca8e275f80e5">
        <source>doBtnAssignManual();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	msg : String;
	obj : Object;
	cashPayment : CM_CashPayment;
	cashPaymentSet : CM_CashPaymentSet;
	cashInvoice : CM_Invoice;
	newInvLine : CM_InvoiceLine;
	theReturn : Integer;

begin

	if self.myCurrentTrackedItem = null then
		msg := app.getErrorString( No_Cargo_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create cashPaymentSet transient;
	foreach obj in self.tblUnassCashP.allSelectedObjects do
		if obj.isKindOf( CM_CashPayment ) then
			cashPaymentSet.add( obj.CM_CashPayment );
		endif;
	endforeach;
	if cashPaymentSet.isEmpty then
		msg := app.getErrorString( Unassig_cash_payment_selecte );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	elseif cashPaymentSet.size &gt; 1 then
		msg := app.getErrorString( Only_unass_cash_payme_permi_se );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	cashPayment := cashPaymentSet.first;
	cashInvoice := cashPayment.getInvoiceForManualAssign();
	if cashInvoice = null then
		msg := app.getErrorString( Invoic_not_found_unassi_paymen );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	elseif cashInvoice.isPostedOrReversal then 
		msg := app.getErrorString(Warning) &amp; CrLf &amp; app.getErrorString( CM_Invoice_Status ) &amp; " = " &amp; cashInvoice.getStatusDescription( cashInvoice.status );
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
	endif;
	
	self.showFrmManual( true );
	
epilog

	delete cashPaymentSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnClear" id="7e2e8931-341d-466a-b406-ae608446a091">
        <updating/>
        <source>doBtnClear( _tablesOnly : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

begin

	if not _tablesOnly then
		self.cmbVoyage.listIndex := -1;
		self.cmbBOL.listIndex := -1;
		self.cmbCargoType.listIndex := -1;
		self.txtCargoId.text := null;
	endif;
	
	self.tblInvLineCashP.rows := self.tblInvLineCashP.fixedRows;
	self.tblInvLineCashP.allSelectedObjects.clear();
	self.tblUnassCashP.rows := self.tblUnassCashP.fixedRows;
	self.tblUnassCashP.allSelectedObjects.clear();
	self.tblCargoInvL.rows := self.tblCargoInvL.fixedRows;
	self.tblCargoInvL.allSelectedObjects.clear();
	self.tblRelCargo.rows := self.tblRelCargo.fixedRows;
	self.tblRelCargo.allSelectedObjects.clear();
	
	self.myCurrentInvoiceLine := null;
	self.myCurrentTrackedItem := null;
	
	self.lastFindButton := null;
	
	self.enableButtons();

epilog

end;</source>
        <Parameter name="_tablesOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnFind" id="10b0091a-fef8-4352-b8b3-2e4811939d89">
        <updating/>
        <source>doBtnFind( btn : Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	voyage : CM_Voyage;
	bol : CM_BOL;
	cargoType : CM_CargoType;
	cargoId : String;
	
	iter : Iterator;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;
	
	unassignedOnly : Boolean;
	
	cashPayment : CM_CashPayment;
	cargoSet : CM_TISet;

begin

	app.mousePointer := Busy;

	self.doBtnClear( true );
	
	self.lastFindButton := btn;
	
	if btn = self.btnTermUnassign then
	
		self.doBtnClear( false );
		self.lastFindButton := btn;
		
		create cargoSet transient;
		iter := self.myTerminal.allUnassignedCashPayments.createIterator;
		while iter.next( cashPayment ) do
			ti := cashPayment.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if not ti.isOffSite then
				continue;
			endif;
			if cashPayment.cashValue = 0 then
				continue;
			endif;
			
			cargoSet.addNoDuplicates( ti, false );
			
		endwhile;
		
		foreach ti in cargoSet do
			self.tblRelCargo.addObject( ti );
		endforeach;
		
		return;
		
	endif;
	
	unassignedOnly := ( btn = self.btnFindUnassign );
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	bol := self.cmbBOL.listObject.CM_BOL;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	cargoId := self.txtCargoId.text.trimBlanks.String;
	
	if voyage = null and cargoType = null and cargoId = null then
		app.msgBox( app.getErrorString(Search_criteria_entered), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;

	if voyage &lt;&gt; null then
		iter := voyage.allOffsiteTIsByCargoTypeId.createIterator;
		if cargoType &lt;&gt; null then
			startObject := voyage.allOffsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, cargoId, null );
		else
			startObject := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( cargoId, null, null );
		endif;
	else
		iter := self.myTerminal.allOffsiteTIsByCargoTypeId.createIterator;
		if cargoType &lt;&gt; null then
			startObject := self.myTerminal.allOffsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, cargoId, null );
		else
			startObject := self.myTerminal.allOffsiteTIsByIdCargoType.getAtKeyGeq( cargoId, null, null );
		endif;
	endif;
	
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
	endif;
	while iter.next( ti ) do
		if cargoType &lt;&gt; null then
			if ti.myCargoType &lt;&gt; cargoType then
				break;
			endif;
		endif;
		if cargoId &lt;&gt; null then
			if ti.id &lt;&gt; cargoId then
				break;
			endif;
		endif;
		if bol &lt;&gt; null then
			if ( ti.myBOLDtl = null or ti.myBOLDtl.myBOL &lt;&gt; bol ) then
				continue;
			endif;
		endif;
		if unassignedOnly and not ti.hasUnassignedCashPayment()  then
			continue;
		endif;
		self.tblRelCargo.addObject( ti );
	endwhile;
		

epilog

	delete iter;
	delete cargoSet;
	app.mousePointer := Idle;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnMaInvlCancel" id="74673ea2-8215-4029-9e41-20f18ffcc4ee">
        <source>doBtnMaInvlCancel();
/*

