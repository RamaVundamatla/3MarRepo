    <JadeMethod name="timerEvent" id="423015c2-a593-4b5f-a234-3b4179759a4d">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2022	navtnr20	Initial creation 	TFS 52944

*/

vars

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;

	inheritMethod(eventTag);

epilog

end;</source>
