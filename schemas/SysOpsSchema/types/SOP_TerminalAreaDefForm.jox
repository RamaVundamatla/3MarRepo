    <JadeMethod name="deckingOptionsHaveChanged" id="c803cee1-8786-4b35-97b7-691783ccc691">
        <source>deckingOptionsHaveChanged(_proxyTA: CM_TerminalArea): Boolean;
//----------------------------------------------------------------
//	Created:	08 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myPxyDeckingOptions = null or not global.isValidObject(self.myPxyDeckingOptions) then
		return false;
	endif;
	
	if self.areaChanged then
		return true;
	endif;
	
	if CM_GridArea.hasInstance(self.myProxyObject) and 
	   self.myProxyObject.CM_GridArea.sizeChanged(self.myCurrentObject.CM_GridArea) then
		return true;
	endif;
	
	if self.myPxyDeckingOptions.inOptionType &lt;&gt; self.origDeckingIn then
		return true;
	endif;
	
	if self.myPxyDeckingOptions.outOptionType &lt;&gt; self.origDeckingOut then
		return true;
	endif;

	if CM_GridArea.hasInstance(_proxyTA) then
		if _proxyTA.CM_GridArea.defaultDeckingStartType &lt;&gt; self.origDeckDefDirection then
			return true;	
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_proxyTA" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="985c35e8-9863-4438-a541-c9869bd7da7e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myCMIFTerminalArea &lt;&gt; null then
		delete self.myCMIFTerminalArea;
	endif;
	if self.allCMIFGridLCsAssocICArea &lt;&gt; null then
		self.allCMIFGridLCsAssocICArea.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteBlockLocation" id="efc7cce3-a427-41b6-9b88-6041cedb9d39">
        <source>deleteBlockLocation();
// delete a location from the block area
vars
	locationProxy: CM_IrregularBlockController;
	region : PointArray;
begin
	locationProxy := self.frmBlkArea.myDrawingController.getSelectedLocation();
	if locationProxy &lt;&gt; null then
		self.frmBlkArea.myDrawingController.deleteLocation(locationProxy);
		delete locationProxy;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteRowColumn" id="0f3a866e-65b1-41d8-a33c-a8dbfa5d4bcf">
        <source>deleteRowColumn();
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

	gridRow	 		: CMUI_GridRow;
	gridColumn		: CMUI_GridColumn;
	isToDraw		: Boolean;
	idx				: Integer;
	gridObject 		: CM_GridObject;
begin
	// Not developed yet.
//	return;
	if not self.myCurrentObject.isKindOf(CM_GridArea) then
		return;
	endif;

	beginLoad;
	
	if self.myCurrentSOPGridArea.selectedRow &lt;&gt; 0 then
		idx := self.myCurrentSOPGridArea.selectedRow;
		
		//11/7/06 epr par 12048
		gridRow := self.myCurrentSOPGridArea.allGridRows[idx];
		gridObject := gridRow.myGridRow; //self.myCurrentObject.CM_GridArea.allGridRows[idx]; 
		
		if gridObject = null or self.validateStateOfRowColumn(gridObject) = Return_Continue then
			isToDraw := true;
			self.myCurrentSOPGridArea.deleteGridRow(gridRow);
			tblMain.setValueByName(ETRow_Rows,self.myCurrentSOPGridArea.allGridRows.size);
			return;
		else
			app.msgBox(app.getErrorString(CMUI_Row_InUse),app.getErrorString(CMUI_Remove_Row_Error),MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
	elseif self.myCurrentSOPGridArea.selectedColumn &lt;&gt; 0 then
		idx := self.myCurrentSOPGridArea.selectedColumn;
		gridColumn := self.myCurrentSOPGridArea.allGridColumns[idx];
		gridObject := gridColumn.myGridCol;//self.myCurrentObject.CM_GridArea.allGridColumns[idx];

		if gridObject = null or  self.validateStateOfRowColumn(gridObject) = Return_Continue then
			isToDraw := true;
			gridColumn := self.myCurrentSOPGridArea.allGridColumns[idx];
			self.myCurrentSOPGridArea.deleteGridColumn(gridColumn);
			tblMain.setValueByName(ETRow_Cols,self.myCurrentSOPGridArea.allGridColumns.size);
			return;
		else
			app.msgBox(app.getErrorString(CMUI_Column_InUse),app.getErrorString(CMUI_Remove_Column_Error),MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
	endif;


	
epilog
	endLoad;
	if isToDraw then
		self.frmMain.drawSelf();
	endif;
	self.myCurrentSOPGridArea.setSelected(0,0);
end;</source>
    </JadeMethod>
    <JadeMethod name="displayProductMinMax" id="10daceec-a1bb-4bf6-b13d-12f3dd17a067">
        <updating/>
        <source>displayProductMinMax(_prodMinMax : CM_TerminalAreaProductMinMax) updating ;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 24/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 13/05/2021	navdap1		TFS 49858 PRP Defaul Capacity per Location for GC Areas
vars
	measureType	 : CM_MeasurementType;
	measureTable : CMUI_MeasurementTable;
	unit		: String;
	converted	: String;
	lc 			: CM_LocationsController;				// TFS 49858
begin
	if _prodMinMax &lt;&gt; null then
		
		//30 Mar 2021	NDL	TFS 49912
		if _prodMinMax.myLocationsController = null then
			self.cmbColGroup.listIndex := 1;
		else
			self.populateCmbColGroup( self.myCurrentObject.CM_TerminalAreaMaster );
			if _prodMinMax.myLocationsController.isTransient then																// TFS 49858
				lc := _prodMinMax.myLocationsController.pxyGetRealObject;														// TFS 49858
			else																												// TFS 49858
				lc := _prodMinMax.myLocationsController;																		// TFS 49858
			endif;																												// TFS 49858
			//self.cmbColGroup.listIndex := self.cmbColGroup.findObject( _prodMinMax.myLocationsController.pxyGetRealObject );	// TFS 49858
			self.cmbColGroup.listIndex := self.cmbColGroup.findObject( lc );													// TFS 49858
			self.tblExtra.setValueByControlName(self.cmbColGroup.name, self.cmbColGroup.text);
		endif;
		
		if self.cmbCargoType.findObject(_prodMinMax.myCargoType) &gt; 0 then
			self.cmbCargoType.listObject:=_prodMinMax.myCargoType;
			self.doChangeCargoType;
		endif;

		if _prodMinMax.myProduct &lt;&gt; null and cmbProduct.findObject(_prodMinMax.myProduct) &gt; 0 then
			self.cmbProduct.listObject := _prodMinMax.myProduct;
		else
			self.cmbProduct.listObject :=null;
			 
		endif;
		tblExtra.setValueByName(ETRow_Product,	  self.cmbProduct.text);
	else
		tblExtra.clearValues();
		self.populateCmbColGroup( null );	//26 Jul 2021	NDL	TFS 51166
		self.tblExtra.clearMeasurementValues();			// TFS 49453
		self.cmbProduct.listIndex := -1;
		self.cmbCargoType.listIndex:=-1;
	endif;
	
	tblExtra.goToRowByName(ETRow_CargoType);
	//29 Mar 2021	NDL	TFS 49912
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_GeneralCargoAllocRowArea) then
		if not self.myCurrentObject.CM_GeneralCargoAllocRowArea.allRowControllersById.isEmpty then
			tblExtra.goToRowByName(ETRow_ColumnGroup);
		endif;
	endif;
	tblExtra.setFocus();
end;</source>
        <Parameter name="_prodMinMax" type="CM_TerminalAreaProductMinMax"/>
    </JadeMethod>
    <JadeMethod name="displayProductMinMaxs" id="4975757f-d048-4291-b448-d887aaf496e4">
        <source>displayProductMinMaxs(_tam : CM_TerminalAreaMaster);
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 07/07/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	prodMinMax : CM_TerminalAreaProductMinMax;
	theDataLine : String;
begin
	self.tblExtraList.rows := self.tblExtraList.fixedRows;
	if _tam = null then
		return;
	endif;
	
	//20 Jun 2016	NDL	TFS 1752
	self.frmPerUnit.width := 400;	//29 Mar 2021	NDL`TFS 49912
	self.lblPerUnit.width := 400;	//29 Mar 2021	NDL`TFS 49912
	if _tam.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
		self.lblPerUnit.caption := app.getErrorString(Values_applied_square_metre);
	elseif _tam.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then									// TFS 49453
		self.lblPerUnit.caption := app.getErrorString(Values_applied_column);			// TFS 49453
	else
		self.lblPerUnit.caption := app.getErrorString(Values_applied_termina_area);
	endif;
	
	self.populateCmbColGroup( _tam );	//29 Mar 2021	NDL	tFS 49912
	
	self.tblExtraList.visible := true;
	foreach prodMinMax in _tam.allProductMinMax discreteLock do
		theDataLine := prodMinMax.getAttributeStringForDefArray(self.tblExtraList.allTblDataEntRows);
		self.tblExtraList.addItemObject(prodMinMax, theDataLine);
	endforeach;
	
	self.btnExtraSave.visible := true; //08 Sep 2020	NDL	TFS 49984 - Only used for Product Mini Maxs
	self.frmTBExtra.positionToolbarControls();	 //08 Sep 2020	NDL	TFS 49984
	
end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="displayStackHeightCriteria" id="596f8643-9549-47bb-8b2a-46b6df6bbd62">
        <source>displayStackHeightCriteria( _obj : CM_GriddedTAStackHeight );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	proxyTA : CM_TerminalArea;
	form : CMUI_GriddedStackHeightForm;

begin

	proxyTA := self.myProxyObject.CM_TerminalArea;
	if proxyTA = null then
		return;
	endif;

	create form transient;
	form.setBaseData( _obj, self );
	form.showModal();
	
	self.displayStackHeights( proxyTA );

epilog

end;</source>
        <Parameter name="_obj" type="CM_GriddedTAStackHeight"/>
    </JadeMethod>
    <JadeMethod name="displayStackHeights" id="70f25e87-d8c0-4958-b380-320c423bcc0c">
        <source>displayStackHeights( _taMaster : CM_TerminalAreaMaster );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	stackHeight : CM_GriddedTAStackHeight;
	theDataLine : String;
	
begin

	self.tblExtraList.rows := self.tblExtraList.fixedRows;
	if _taMaster = null then
		return;
	endif;
	
	self.lblPerUnit.caption := null;
	
	self.tblExtraList.visible := true;
	foreach stackHeight in _taMaster.allGriddedTAStackHeights discreteLock do
		theDataLine := stackHeight.getAttributeStringForDefArray(self.tblExtraList.allTblDataEntRows);
		self.tblExtraList.addItemObject(stackHeight, theDataLine);
	endforeach;
	
	self.btnStackEdit.enabled := false;
	self.btnExtraDelete.enabled := false;
	self.btnExtraSave.visible := false; // Not used for Stack Heights
	self.frmTBExtra.positionToolbarControls();

end;</source>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
