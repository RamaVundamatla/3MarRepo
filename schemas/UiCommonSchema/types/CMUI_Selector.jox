    <JadeMethod name="evaluateUpDown" id="e071491e-0fc8-488e-abb1-4474f154fa74">
        <source>evaluateUpDown();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2019	jlgndl1	Initial creation	TFS 45891
04 Oct 2019	jlgdi1	46820 Added form permission check
*/

vars
	tblSheet : JadeTableSheet;
	criteriaLine : CM_SelectorCriteriaLine;

begin
	self.btnDown.enabled := false;	
	self.btnUp.enabled := false;	
	
	if self.isViewPermisionOnly then 
		return;
	endif;
	
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	
	if tblSheet = null or tblSheet.row = 0 then
		return;
	endif;
	
	criteriaLine := tblSheet.accessRow(tblSheet.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null or not tblSheet.accessRow(tblSheet.row).selected then
		return;
	endif;
	
	if tblSheet.rows = tblSheet.fixedRows + 1 then
		return; // There is only one row, so can't move up or down
	elseif tblSheet.row = tblSheet.rows then
		self.btnUp.enabled := true;
	elseif tblSheet.row = tblSheet.fixedRows + 1 then
		self.btnDown.enabled := true;
	else
		self.btnDown.enabled := true;	
		self.btnUp.enabled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="executeQueries" id="16a8f536-7add-4266-b10a-730abae56ce6">
        <updating/>
        <source>executeQueries() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor				: CMIF_Monitor;
	idx,
	returnValue 			: Integer;
	tbl						: CM_DataTable;
	tblSheet				: JadeTableSheet;

	obj : Any;
	startTime : TimeStamp;	//14 Oct 2019	NDL	TFS 47010
	endTime : TimeStamp;	//14 Oct 2019	NDL	TFS 47010
	timeInterval : TimeStampInterval;	//14 Oct 2019	NDL	TFS 47010
	
	mode : Integer;
	prof	 : JadeProfiler;
	starTM   : Decimal[19,0];
begin
	if process.isMohamed or process.isHari then
		app.myRoot.startJadeProfiler(prof,method.getNiceName,20,true,'MA',starTM);
	endif;
	startTime := app.actualTimeAppServer;	//14 Oct 2019	NDL	TFS 47010

	self.tblResults.allSelectedObjects.clear();
	tbl := self.tblCriteria;
 
	mode := self.isCriteriaUpdate();
	
//   	if self.queryLineChanged then - need to know if it is update or add
	// ### TFS BUG 61210 23FEB2024 NAVAB1. Handle whether an update or a new criteria line
	if mode = CMUI_Selector.Mode_Update then
		if self.chkSupressMessage.value then
			 returnValue := MB_YES;
		else
			returnValue := app.msgBox("Line detail has been changed, do you want to update the query line?", "TITLE",MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		endif;
		
		if returnValue = MB_YES then
			self.updateCriteriaLine(true);
			self.doWindowEvents(0);
		elseif returnValue = MB_CANCEL then
			return;
		endif;
	elseif mode = CMUI_Selector.Mode_Add then // ### TFS BUG 61210 26FEB2024 NAVAB1
		if self.chkSupressMessage.value then
			 returnValue := MB_YES;
		else
			returnValue := app.msgBox(app.getErrorString(CMUI_Selector_Check_Line) &amp; Cr &amp; app.getErrorString(Add) &amp;'?', app.getErrorString(CMUI_Selector_Add_Changed_Line), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		endif;
		
		if returnValue = MB_YES then
			if (not self.addCriteriaLine()) then //adding line could fail
				return;
			endif;
			//so user can see added line before query executes - is this too ugly?
			self.doWindowEvents(0);
		elseif returnValue = MB_CANCEL then
			return;
		endif;
	endif;
	
	/* // ### TFS BUG 61210 23FEB2024 NAVAB1. 
		returnValue := app.msgBox(app.getErrorString(CMUI_Selector_Check_Line) &amp; Cr &amp; app.getErrorString(Add) &amp;'?', app.getErrorString(CMUI_Selector_Add_Changed_Line), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if returnValue = MB_YES then
			if (not self.addCriteriaLine()) then //adding line could fail
				return;
			endif;
			//so user can see added line before query executes - is this too ugly?
			self.doWindowEvents(0);
		elseif returnValue = MB_CANCEL then
			return;
		endif;
		*/
//	endif;
	
//	if not self.doPerformanceCheck() then
//		return;
//	endif;

	self.queryLineChanged := false;	
	on Exception do self.doHandle1066AfterCancel(exception); //18 Jun 2012	NDL	Par 29508 - After a Cancel during a search
																// some objects are registered for notes and some are not...
	foreach obj in self.myEnqController.allObjects discreteLock do
		self.endNotification(obj.Object, Object_Delete_Event);
	endforeach;
	on Exception do null;	//18 Jun 2012	NDL	Par 29508

	//cnwth2 - reminder - change to public property
	self.myEnqController.allObjects.clear();
	self.myEnqController.setPropertyValue(CM_EnquiryController::numItemsFound.name, 0);		// navmd1 TFS 55110 11/10/22 why don't we just change this?!
	//if self.optClearFirst.value then
	//	self.myEnqController.allObjects.clear();
	//endif;
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);
	self.btnModalOpt1.width := self.btnModalOpt1.width + 20;	// 13/03/2009 cnwar2 #19144
	self.btnModalOpt1.left	:= self.btnModalOpt1.left - 20;		// Adjust size of button to fit caption 'Return Data'
	self.modalDialogShow(null, null, app.getErrorString(CMUI_Return_Data), app.getErrorString(Cancel), app.getErrorString(CMUI_Retreiving_Data), cmifMonitor.message);
	self.lblModalMessage.caption := 'Retrieving items for sheet 1';
	
	foreach idx in 1 to tbl.sheets do
		tblSheet := tbl.accessSheet(idx);
		
		if tblSheet = null then
			continue;
		endif;
		
		returnValue := self.executeQuery(tblSheet.itemObject.CM_QueryCriteriaLineHolder, idx);
		
		if returnValue = cmifMonitor.MonitorReturnValue_Cancel then
			return;
		elseif returnValue = cmifMonitor.MonitorReturnValue_Return then
			break;
		endif;
	endforeach;
	
	self.displayResults();
	
	endTime := app.actualTimeAppServer;	//14 Oct 2019	NDL	TFS 47010
	timeInterval := endTime - startTime;
	self.doPerformanceCheck( timeInterval );
	
epilog
	endLoad;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.myRoot.stopJadeProfiler(prof,starTM);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="executeQuery" id="02ee98c8-f106-4fdb-8057-1122beda0367">
        <source>executeQuery(_criteriaLineHolder : CM_QueryCriteriaLineHolder; _sheetNo : Integer) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     26 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	startTime			: TimeStamp;
begin

		
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	self.lblModalMessage.caption := 'Retrieving items for sheet ' &amp; _sheetNo.String;
	self.lblModalMessage.refreshNow();		// TFS 55110 navmd1 11/10/2022
	
	startTime := app.actualTimeServer;
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Selector criteria: ' &amp; _criteriaLineHolder.getFullDescription(), app.myPassport);

	self.myEnqController.myCriteriaLineHolder := _criteriaLineHolder;	
	self.myEnqController.doQuery(self.myQDef);


epilog
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		return app.myPassport.myCMIFMonitor.monitorReturnValue;	
	else
		return null;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_sheetNo" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileSilentExceptionHandler" id="f9ae89a5-0fbe-451d-8a7c-698d7495361a">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	JIRA 33575
*/
vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="filterByMode" id="0b0347e0-350b-4006-b626-61da28e8a52d">
        <source>filterByMode(_menuEntity	: CM_MenuEntity) : Boolean;
/*

Purpose:			JLGAB1 - When the mode is clicked only show queries for that mode

Parameters:			 // TFS 47297

Return Value:		

Date		Who		Reason
30 July 2019	jlgab1	Initial creation

*/

vars
	userQuery : CM_MenuUserQuery;
	qdef : CM_QueryDefinition;
begin
	
	if self.myQDef = null then
		return true;
	endif;
	
	if _menuEntity.isKindOf(CM_MenuUserQuery) then
		userQuery := _menuEntity.CM_MenuUserQuery;
	else	
		return true;
	endif;
	
	
	qdef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];
	
	return (qdef = self.myQDef);

epilog

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
