    </JadeMethod>
    <JadeMethod name="getSystemName" id="e88be1f2-08f4-4f02-afab-af8740389942">
        <source>getSystemName(_systemNameType : Integer) : String;

/*

Purpose:		Return the System Name	
				0 - full name 		e.g. 8.1.1 CNWWMAST
				1 - Alpha			e.g. CNWWMAST
				2 - Numeric			e.g. 8.1.1

Date			Who		Reason
26 June 2012	cnwmh5	Initial creation

*/
vars

	systemName 			: String;

begin
	
	systemName := app.myRoot.getConfig(SystemTitle).String;
	
	if _systemNameType = 0 then
		// do nothing
	elseif _systemNameType = 1 then
		systemName := systemName[systemName.pos(" ", 1) + 1:end].trimBlanks();
	elseif _systemNameType = 2 then
		systemName := systemName[1:systemName.pos(" ", 1)].trimBlanks();
	endif;
	
	return systemName;
	
epilog

end;</source>
        <Parameter name="_systemNameType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
