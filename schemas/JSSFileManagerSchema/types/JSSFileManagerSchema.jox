    <JadeMethod name="initializeBackgroundCopy" id="61bc55b9-fc31-4eb2-bf76-64492559b45d">
        <updating/>
        <source>initializeBackgroundCopy(pCopyObj:JSSFMBackgroundCopy) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Initializes the Background Copy application.
//
// Parameters:	pTheCopy - The Background Copy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	copyObj		: JSSFMBackgroundCopy;
	
begin
	self.initialize();	
	self.initializeRoot();
	
	on Exception do app.xHandlerGeneral(exception) global;
	on JSSException do app.xHandlerFileManager(exception) global;
	
	create self.myServiceObject transient;
	
	self.isBackgroundCopy	:=	true;
	copyObj					:=	pCopyObj;
	copyObj.doCopy(self.myServiceObject.myFileAgent);
	self.myServiceObject.getTA().trxDeleteBackgroundCopy(copyObj);
	
	terminate;
end;</source>
        <Parameter name="pCopyObj" type="JSSFMBackgroundCopy"/>
    </JadeMethod>
    <JadeMethod name="initializeFileBrowser" id="5aaf9f4d-5121-4b0d-806e-a5ac10ad7c54">
        <updating/>
        <source>initializeFileBrowser() updating;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		Initializes the File Browser application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14 May 2025  navlc30 	JIRA 34699 - Add User Authentication to JSSFileBrowser - Implementation
// --------------------------------------------------------------------------------
constants

JMTSUPPORT_Str = "JMTSUPPORT";
SUPERUSER_Str = "SUPERUSER";
vars
    context 	: ApplicationContext;
	packageCls  : CMIF_SSOHelper;
	cmsLogonObj : CMS_Logon;
begin
	self.initialize();
	
	self.initializeRoot();

	create packageCls transient;																							//14.05.2025 navlc30 #34699	
	context := packageCls.getContext();
	create cmsLogonObj transient;
	if context &lt;&gt; null then	
		cmsLogonObj.showModal() in (context);
		if cmsLogonObj.modalResult &lt;&gt; 0 then          // user not logged in 
			//app.writeLog("Login closed without success, exiting", true);
			// App log isn't defined (well) here, so just exit without logging anything
			return;
		endif;
		
		if not cmsLogonObj.userID.text.toUpper.isOneOf(SUPERUSER_Str, JMTSUPPORT_Str) then									//23.05.2025 navlc30 #34699
			app.msgBox ("User is not authorized to login.", "Authorization Failed",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;		
	endif;
	
	on JSSException do app.xHandlerFileManager(exception) global;
	
	create self.myServiceObject transient;
//	self.myServiceObject.addBasePathName("d:\jscdjss\server", JSSFMFileManagerService.NODE_SOURCE_DBSERVER);
	self.myServiceObject.showFileBrowser(false, Form.MdiChild_NotMdi);
epilog
	delete packageCls;				//14.05.2025 navlc30 #34699
	delete cmsLogonObj;				//14.05.2025 navlc30 #34699
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeRoot" id="67efe841-6237-4057-8329-bf06abae15e6">
        <updating/>
        <source>initializeRoot() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Instantiates the File Manager's singleton root object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rootObj		: JSSFMRoot;
	
begin
	rootObj	:=	JSSFMRoot.firstInstance();
	
	if rootObj = null then
		beginTransaction;
		create rootObj persistent;
		commitTransaction;
	endif;
	
	self.myRoot	:=	rootObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logException" id="ed30c4fa-e8c3-4621-8b59-4ccbd2703c9c">
        <executionLocation>server</executionLocation>
        <source>logException(pErrorMessage:String) protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad2
//
// Purpose:		Logs an error message to a file.
//
// Parameters:	pErrorMessage - The message to write to the log file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	jadeLogObj	: JadeLog;
	
begin
	create jadeLogObj transient;
	
	jadeLogObj.filePath			:=	app.dbPath();
	jadeLogObj.fileName			:=	app.name;
	jadeLogObj.fileExtension	:=	".log";
	jadeLogObj.bufferOutput		:=	false;
	jadeLogObj.formatOutput		:=	true;
	
	jadeLogObj.logServer(pErrorMessage);
epilog
	delete jadeLogObj;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFileManager" id="b7c529c2-bd5d-40d2-8e44-b940a09f8e72">
        <source>xHandlerFileManager(pExceptionObj:JSSException):Integer;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Handler for File Manager exceptions.
//
// Parameters:	pExceptionObj - The JSS exception object.
//
// Returns:		An abort action.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorCode		: Integer;
	errorMessage	: String;
	
begin
	errorCode		:=	pExceptionObj.errorCode;
	errorMessage	:=	pExceptionObj.extendedErrorText;
	
	if self.isBackgroundCopy then
		// Log the error to a file.
		app.logException(errorMessage);
	else
		app.msgBox(errorMessage, "Error " &amp; errorCode.String, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;
	
	return Ex_Abort_Action;
end;</source>
        <Parameter name="pExceptionObj" type="JSSException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGeneral" id="1e5f73ed-3497-400a-8898-1a1877ff70b2">
        <source>xHandlerGeneral(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad2
//
// Purpose:		Handler for general exceptions.
//
// Parameters:	pExceptionObj - The JADE exception object.
//
// Returns:		An abort action.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	abortTransaction;
	
	errorMessage	:=	"Error " &amp; pExceptionObj.errorCode.String &amp;
						": " &amp; pExceptionObj.errorItem &amp; CrLf &amp;
						pExceptionObj.extendedErrorText;
	
	// Log the error to a file.
	app.logException(errorMessage);
	
	return Ex_Abort_Action;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
