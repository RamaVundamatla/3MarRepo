<Class name="CM_ExtraDetailShipLogLst" id="ffc4b93c-eba9-4419-a6da-5cad45459960">
    <superclass name="CM_ExtraDetail"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allShipLogLstExtra" id="87ed8ca4-d96b-496c-8be8-e6af3cd010c3">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="0e4ec6dd-aaec-40cf-a55d-6c220ca757aa">
        <source>cloneReferences(_pxyExtraDetailShipLogLst : CM_ExtraDetailShipLogLst);

// cnwdvb1 30 October 2002 

vars

	pxyCmif,
	newCmif	: CMIF_ShipLogListExtra;
	iter	: Iterator;

begin

	iter := _pxyExtraDetailShipLogLst.allShipLogLstExtra.createIterator;
	while iter.next(pxyCmif) do
		newCmif := pxyCmif.cloneSelf(false);
		newCmif.cloneReferences(pxyCmif);
		self.allShipLogLstExtra.add(newCmif);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_pxyExtraDetailShipLogLst" type="CM_ExtraDetailShipLogLst"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6ac96e0e-a1bd-4905-995e-0f8b11a5a331">
        <updating/>
        <source>delete() updating;

// cnwdvb1 01 April 2003 

vars

begin

	self.allShipLogLstExtra.purge;

end;</source>
    </JadeMethod>
