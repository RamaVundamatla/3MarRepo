    <JadeMethod name="setMyPreviousController" id="c2d53d60-3e27-41f1-b33c-1a055e1c51ae">
        <updating/>
        <source>setMyPreviousController(lPreviousController: CM_GridController) updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		We used to have 'next' which was the next location, 'nextTower' which was the next Tower Controller and 'nextGap' for the gap controller
// 				We now only have myNextController, a location controller can only have one tower or gap next to it, or it can have a tower and then a gap
// 				but not a gap and then a tower.
// 				the order is LC&gt;TC&gt;GC&gt;LC, if we have a TC and a GC, else it can be LC&gt;TC&gt;LC or LC&gt;GC&gt;LC or LC&gt;LC
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNC, lPC, lGC, lLC, lTC	: CM_GridController;
begin
	// ############################
	// Remove a link
	// ############################

	if lPreviousController = null then
		// if I am a tower then take me out of the chain, link my previous with my next
		
		lNC := self.myNextController;
		lPC := self.myPreviousController;
		
		if lNC = null then
			return;
		endif;
		
		// break the chain
		self.myPreviousController := null;
		lNC.myPreviousController := null;
	
		// rebuild the chain, lose the tower
		lNC.myPreviousController := lPC; 
			
		return;
	else
		// ############################
		// Add a link
		// ############################
/*		if lPreviousController.myNextController = null then
			if self.myPreviousController &lt;&gt; lPreviousController then 
				self.myPreviousController := lPreviousController;
				return;
			endif;
		endif;*/

		// ############################
		// Insert a link
		// ############################
		// if I am a tower then take me out of the chain, link my previous with my next
/*		lNC := lPreviousController.myNextController;
		lPC := lPreviousController;

		// break the chain
		lNC.myPreviousController := null;
	
		// rebuild the chain, lose the tower
		lNC.myPreviousController := self; 
		self.myPreviousController := lPC; */
		
		// DVB changed 08/10/03
		// Was crashing with duplicate reference. Clear next controller before setting previous.
		// Once we get to the end of the chain all will be cool.
		lNC := lPreviousController.myNextController;
		if lNC &lt;&gt; null then
			lNC.myPreviousController := null;
		endif;
		self.myPreviousController := lPreviousController;
		return;
	endif;
end;</source>
        <Parameter name="lPreviousController" type="CM_GridController"/>
    </JadeMethod>
