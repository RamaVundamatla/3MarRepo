<Class name="CMIF_OnshipCargo" id="b8bffc8c-7e18-4a77-82db-2a7c5efeb820">
    <superclass name="CMIF_PreNote"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myBOL" id="df08876c-a6d7-4589-9ab1-941a9543a51d">
        <embedded/>
        <type name="CM_BOLIn"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myBOLDtl" id="389c2ff5-b8e9-4cd4-82f3-c4878841e442">
        <embedded/>
        <type name="CM_BOLDtl"/>
    </ImplicitInverseRef>
    <PrimAttribute name="roroX" id="7cd23b10-ea4c-40b9-a7c8-6408f7cd2086">
        <precision>12</precision>
        <scaleFactor>1</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="roroY" id="2d7e8a4b-0956-4d18-8b46-3b466f3641cd">
        <precision>12</precision>
        <scaleFactor>1</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="actionForCreate" id="8b3093e5-76c1-46e1-b214-baaccbee33e6">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;

vars
	result : Boolean;
begin
	result := inheritMethod(pProxy, _passport);
	if not result then
		return result;
	endif;

	if self.myPersistentTrackedItem &lt;&gt; null then	
		self.myPersistentTrackedItem.setMyReceivalBOL(self.myBOL);
		if self.myBOL &lt;&gt; null then
			self.myPersistentTrackedItem.setBOL(self.myBOL.number);
		endif;
		self.myPersistentTrackedItem.setBOLDtl(self.myBOLDtl);
	endif;
	
	return true;
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForUpdate" id="35363cdf-e220-4f85-b1c0-c4e9c420fdec">
        <updating/>
        <source>actionForUpdate(pProxy: CM_Object io;
				pAuditAgent: CM_UpdateTransactionAuditAgent io;
				_isCheckEdition : Boolean;
				_passport: CM_Passport input): Boolean updating;

vars
	result : Boolean;
begin
	result := inheritMethod(pProxy, pAuditAgent, _isCheckEdition, _passport);
	if not result then
		return result;
	endif;

	if self.myPersistentTrackedItem &lt;&gt; null then	
		self.myPersistentTrackedItem.setMyReceivalBOL(self.myBOL);
		if self.myBOL &lt;&gt; null then
			self.myPersistentTrackedItem.setBOL(self.myBOL.number);
		endif;
		self.myPersistentTrackedItem.setBOLDtl(self.myBOLDtl);
	endif;
	
	return true;
end;
</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="pAuditAgent" type="CM_UpdateTransactionAuditAgent" usage="io"/>
        <Parameter name="_isCheckEdition" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCoordinates" id="810d8cbc-a846-4e26-a7de-9c11728d2809">
        <source>hasCoordinates(_x : Decimal output; _y : Decimal output) : Boolean;
/*
Purpose:			
Date		Who		Reason
15 November 2011	cnwab1	Initial creation
*/

vars

begin
	_x := self.roroX;
	_y := self.roroY;
	
	return self.roroX &gt; -20;
epilog

end;</source>
        <Parameter name="_x" type="Decimal" usage="output"/>
        <Parameter name="_y" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBOLItem" id="257e2362-dc30-4b6b-bf41-14c882ef0177">
        <source>isBOLItem() : Boolean;
/*
Purpose:			
Date		Who		Reason
15 November 2011	cnwab1	Initial creation
*/

vars

begin
	return self.myBOL &lt;&gt; null or self.myBOLDtl &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
