    <JadeMethod name="getDisplayID" id="a8598507-ec76-41c3-a447-88fa21a5de87">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

