    <JadeMethod name="setForUpdateMoveItem" id="4a752217-7867-494d-ad70-b9b51fc4e504">
        <updating/>
        <source>setForUpdateMoveItem(_index : Integer; _toObject : CM_MenuUserItem input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.myParent.removeChild(self);
	if _toObject.isHeader then
		_toObject.addChild(self,0);
		self.level := _toObject.getLevel() + 1;
	else
		_toObject.myParent.addChild(self,_index);
		self.level := _toObject.myParent.getLevel() + 1;
	endif;
//	self.level := _toObject.level;

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_toObject" type="CM_MenuUserItem" usage="input"/>
    </JadeMethod>
