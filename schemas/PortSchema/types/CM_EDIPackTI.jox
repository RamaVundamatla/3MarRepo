    <JadeMethod name="assignValueSpecial" id="a5a13574-8005-457f-96c8-eb49ec32807e">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// par 26898 cnwrs1 7 Feb 2011
//
// 18/09/2012	cnwcs5	par 30316 - changed parameter usage for _processedValue
// 10 May 2013	cnwcs5	par 31626 - make method public so can be used for hook code
// 30 Jun 2016	cnwrs1	TFS 2300 Add Fonterra Pack VGM
// 13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
//4 sept 2024 	navsaa30 Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)

vars

begin
	if _propName = ETRow_NetWeight  then
		if _processedValue = null then 
			self.setPropertyValue(CM_EDIPackTI::weightNet.name, NULL_WEIGHT);
		else
			self.setPropertyValue(CM_EDIPackTI::weightNet.name, _processedValue.asDecimalJMT);			//4/9/24  navsaa30  #63853
		endif;
		return true;
	elseif _propName = ETRow_TareWeight  then
		if _processedValue = null then 
			self.setPropertyValue(CM_EDIPackTI::weightTare.name, NULL_WEIGHT);
		else
			self.setPropertyValue(CM_EDIPackTI::weightTare.name, _processedValue.asDecimalJMT);			//4/9/24  navsaa30  #63853
		endif;
		return true;
	elseif _propName = ETRow_IsCertifiedWeight then							// TFS #2033
		self.isWeightCertified := _processedValue.toUpper.asBooleanJMT;		// TFS #2033
		return true;														// TFS #2033
	// jlika1 TFS 53316 --&gt;
	elseif _propName = ETRow_Diameter then							//4/9/24  navsaa30  #63853
		self.diameter := _processedValue.asDecimalJMT;			
		return true;
	elseif _propName = ETRow_RollingLength then
		self.rollingLength := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;
	// jlika1 TFS 53316 &lt;--
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clientRefEx" id="06ec6373-1bef-4aac-b19d-593787b9f81f">
        <methodInvocation>mapping</methodInvocation>
        <source>clientRefEx(set: Boolean; _value: String io) mapping;
/*

Purpose:			
    CCMS 2081 for POL SouthPOL XML File - Delivery Reason
    This attribute is used in versions 7.8.2 and 7.9.1. The upgrade script for 
    7.9.2 upgrades clientRefEx to clientRef

Date		Who		Reason
15 July 2011	cnwgb1	Initial creation

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, ClientRef, _value);
	else
		global.getExtraData(self.allExtraData, ClientRef, _value);
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="fbe3dd36-4a0c-4249-ae60-c466e439fc05">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	cnwrs1 CCMS 1976 1 dec 2010
//----------------------------------------------------------------
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.cargoType := TI_CargoType_Container;
	self.temperature := NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY );
	self.vent := NULL_VENTILATION;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="7eaf51c1-8082-484b-a817-74fece62dfaf">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDestinationTerminal" id="c561f4fa-081d-4e4a-bfdb-fb7ab762dbec">
        <source>getDestinationTerminal() : String;
//
//05 Dec 2012	cnwrs1	ccms2215 move CM_EDIPackTI::destinationTerminal from allExtraData to data field
//
// this is only for the conversion from JMT812 to 821
//
vars
	value : String;
begin
	global.getExtraData(self.allExtraData, CM_EDIPackTI::destinationTerminal.name, value);
	return value;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="91707d10-8da9-4250-b716-54f0ea142902">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	08 Decemeber 2010 ccms 1976
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
// 30 Jun 2016	cnwrs1	TFS 2300 Add Fonterra Pack VGM
// 13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
vars
	str,
	strReturn	: String;
	strSize		: Integer;
	rowName, type	: String;						// PAR #33005
begin
	if _attrName = ETRow_Temperature then
		if self.temperature &lt;= NULL_TEMPERATURE then
			return null;
		endif;
	elseif _attrName = ETRow_Ventilation or
	       _attrName = ETRow_Vent then
		return self.vent.asNullDecimal();
	elseif _attrName = ETRow_Humidity then
		return self.getHumidity.asNullHumidity();
	elseif _attrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide();
	elseif _attrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen();
	elseif _attrName = ETRow_TareWeight then	//par 26898 cnwrs1 7 Feb 2010
		return self.weightTare.asStringWeightJMT();	
	elseif _attrName = ETRow_NetWeight then	//par 26898 cnwrs1 7 Feb 2010
		return self.weightNet.asStringWeightJMT();	
	elseif  _attrName = ETRow_Weight then										
		return self.weight.asStringWeightJMT();	
	elseif _attrName = ETRow_IsCertifiedWeight then							// TFS #2033
		return self.isWeightCertified.getYes;								// TFS #2033
	// jlika1 TFS 53316 --&gt;	
	elseif _attrName = ETRow_Grade then		
			return self.grade;
	elseif _attrName = ETRow_Grammage then
		if self.grammage &gt; 0 then
			return self.grammage.asStringJMT;
		endif;	
	elseif _attrName = ETRow_Diameter then
		return null; // will be taken over by the measurement row		
	elseif _attrName = ETRow_RollingLength then
		return null; // will be taken over by the measurement row
	// jlika1 TFS 53316 &lt;--		
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005	
	endif;
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="d2e9adde-25dd-4696-8656-20b1e5cefbe3">
        <source>getHumidity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Humidity display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.humidity &gt; 999.99 then
		return 999.99;
	endif;

	return self.humidity;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="633be595-4170-430b-87c7-845b2dc624d6">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	if _attrName = ETRow_NetWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weightNet);
	elseif _attrName = ETRow_TareWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weightTare);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
