    <JadeMethod name="doBtnAddClick" id="83bcf667-7d4e-4b09-8613-13dface52278">
        <source>doBtnAddClick();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not (app.isSpecial()) then
		self.frmNew.visible := false;
		return;
	endif;
	
	self.frmNew.centreWindow();
	self.frmNew.visible := true;
	self.txtNewCode.setFocus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAddClickOLD" id="523bf611-cad5-4870-aa48-ba9bf0f7cfee">
        <updating/>
        <source>doBtnAddClickOLD() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	 aProxyDrawingAttribute,aRealDrawingAttribute : CM_DrawingAttribute;
	 idx, theFontCharacter, theColour : Integer;
	 theCode, theFontName : String;
	 result : Boolean;
	 theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	idx := self.tblAttributes.addItem("picTI" &amp; Tab &amp; "Helvetica" &amp; Tab &amp; 65.Character &amp; Tab &amp; "65" &amp; Tab &amp; "0");
	self.tblAttributes.accessCell(idx,1).selected := true;
	self.tblAttributes.accessedCell.inputType := Table.InputType_TextNumeric;
	
	theCode := self.tblAttributes.accessCell(idx,Col_Attribute).text;
	theFontCharacter := self.tblAttributes.accessCell(idx,Col_CharacterNumber).text.Integer;
	theColour := self.tblAttributes.accessCell(idx,Col_Colour).text.Integer;
	theFontName := self.tblAttributes.accessCell(idx,Col_Font).text;
	create aProxyDrawingAttribute transient;
	aProxyDrawingAttribute.setProxy(theCode,theFontName,theFontCharacter,theColour,app.myRoot);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateDrawingAttribute(aProxyDrawingAttribute,aRealDrawingAttribute,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Drawing Attributes', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.tblAttributes.accessRow(idx).itemObject := aRealDrawingAttribute;
	global.beep;
	app.msgBox("Data Saved","Drawing Attributes",MsgBox_OK_Only);
epilog
	if aProxyDrawingAttribute &lt;&gt; null then
		delete aProxyDrawingAttribute;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="0b0c38d6-1817-4fff-9fa8-96cc4f1fba38">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	 aProxyDrawingAttribute,aRealDrawingAttribute : CM_DrawingAttribute;
	 idx, theFontCharacter, theColour : Integer;
	 theCode, theFontName : String;
	 result : Boolean;
	 loadStateSet : Boolean;
	 theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	foreach idx in self.tblAttributes.fixedRows + 1 to self.tblAttributes.rows do
	
		aRealDrawingAttribute := self.tblAttributes.accessRow(idx).itemObject.CM_DrawingAttribute;
		if aRealDrawingAttribute = null then
			continue;
		endif;
		
		theCode := aRealDrawingAttribute.code;
		theFontCharacter := self.tblAttributes.accessCell(idx,Col_CharacterNumber).text.Integer;
		theColour := self.tblAttributes.accessCell(idx,Col_Colour).backColor;
		theFontName := self.tblAttributes.accessCell(idx,Col_Font).text;
		app.cmsBeginLoad(loadStateSet);
		aProxyDrawingAttribute := aRealDrawingAttribute.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadStateSet);
		aProxyDrawingAttribute.setProxy(theCode,theFontName,theFontCharacter,theColour,aRealDrawingAttribute.myRoot);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateDrawingAttribute(aProxyDrawingAttribute,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Drawing Attributes', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
		if aProxyDrawingAttribute &lt;&gt; null then
			delete aProxyDrawingAttribute;
		endif;
		
	endforeach;
	global.beep;
	app.msgBox("Data Saved","Drawing Attributes",MsgBox_OK_Only);
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if aProxyDrawingAttribute &lt;&gt; null then
		delete aProxyDrawingAttribute;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbCharacter" id="38c55a9b-4b0c-4043-ac2c-5037639e0d9e">
        <source>doBuildCmbCharacter(_theCombo : ComboBox input; _theFont : String);
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
begin

	_theCombo.clear();
	_theCombo.sorted := false;
	_theCombo.fontName := _theFont;
	_theCombo.fontSize := 15;
	foreach idx in 1 to 255 do
		_theCombo.addItem( idx.Character);
	endforeach;

end;</source>
        <Parameter name="_theCombo" type="ComboBox" usage="input"/>
        <Parameter name="_theFont" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildCmbFont" id="2f7f68cc-815c-4648-8b93-a8056a3b4dc5">
        <updating/>
        <source>doBuildCmbFont(_theCombo : ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	_theCombo.clear();
	_theCombo.addItem("Courier");
	_theCombo.addItem("Courier New");
	_theCombo.addItem("Times New Roman");
	_theCombo.addItem("Helvetica");
	_theCombo.addItem("Arial");
	_theCombo.addItem("Verdana");
	_theCombo.addItem("Wingdings");
	_theCombo.addItem("Wingdings 2");
	_theCombo.addItem("Wingdings 3");
	_theCombo.addItem("Webdings");
	_theCombo.sorted := true;



end;</source>
        <Parameter name="_theCombo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComboCharClick" id="59f290cc-4438-4911-a272-27c19aa6ca14">
        <source>doComboCharClick(combobox : ComboBox);
// ---------------------------------------------------------------------------
