    <JadeMethod name="qryCashTransactions" id="9f5272c5-292e-4487-b59b-a97c8557fae0">
        <updating/>
        <source>qryCashTransactions(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	numSelected : Integer;
	jrwTrans : CM_JRWCashTransactions;
	cashTrxFilter : CMQF_CashTransactions;
	
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	cashTrxFilter := _filter.CMQF_CashTransactions;
	jrwTrans := self.createJRWTransient(CM_JRWCashTransactions).CM_JRWCashTransactions;
	
	_filter.filterObjects(cashTrxFilter.allCashTransactions, _passport);
	
	jrwTrans.setResults(cashTrxFilter.allCashTransactions, cashTrxFilter.allDebtors, cashTrxFilter.allTerminals);
	jrwTrans.setDateRange( cashTrxFilter.startDate, cashTrxFilter.endDate );
	jrwTrans.billOfLading	:= cashTrxFilter.billOfLading;
	jrwTrans.cargoId		:= cashTrxFilter.cargoId;
	jrwTrans.cashReceiptNumber	:= cashTrxFilter.cashReceiptNumber;
	jrwTrans.customsEntryNumber	:= cashTrxFilter.customsEntryNumber;
	jrwTrans.myVoyage		:= cashTrxFilter.getMyVoyage;
	
	numSelected := jrwTrans.allCashPayments.size; 

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryContBtwnTerms" id="a536ea2c-9992-4366-8855-3780f5de0794">
        <updating/>
        <source>qryContBtwnTerms(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//+cnwml2 22 February 2010
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_ContBtwnTerms;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_ContBtwnTerms;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	jrwTrans.allTransactions.clear();

	jrwTrans.setAllTerminals(tiFilter.allTerminals);

	jrwTrans.dateTimeFrom := tiFilter.dateTimeFrom;
	jrwTrans.dateTimeTo := tiFilter.dateTimeTo;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myFromTerminal := tiFilter.fromTerminal;
	jrwTrans.myToTerminal := tiFilter.toTerminal;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	tiFilter.filterObjects(jrwTrans.allTransactions, _passport);

	numSelected := jrwTrans.allTransactions.size;

epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryContainer" id="e4ffcb35-9626-4ce7-91c8-149819466c7f">
        <updating/>
        <source>qryContainer(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWContainer;
	tiFilter			: CMQF_Container;
	emptyFilter			: CMQF_Empty;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	tiFilter := _filter.CMQF_Container;
	jrwTrans := self.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
	jrwTrans.allTrackedItems.clear();

	if CMQF_Empty.hasInstance(tiFilter) then
		emptyFilter := tiFilter.CMQF_Empty;
	endif;
	
	if emptyFilter &lt;&gt; null
	and emptyFilter.printMTSummaryRep then
	
		//somehow need to add the CM_MTSummaryRep to the the list of report designs
		emptyFilter.filterEmptySpecial(jrwTrans, _passport);
		
	else
		_filter.filterObjects(jrwTrans.allTrackedItems, _passport);
		
	endif;

	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	
	jrwTrans.qryReceivedDT	:= tiFilter.getOnTimeStamp;
	jrwTrans.qryStartDate	:= tiFilter.startDate;
	jrwTrans.qryEndDate 	:= tiFilter.endDate;
	jrwTrans.myPort 			:= tiFilter.getMyPort;
	jrwTrans.myLoadPort 		:= tiFilter.getMyLoadPort;
	jrwTrans.myVoyage 			:= tiFilter.getMyVoyage;
	jrwTrans.myTerminalArea 	:= tiFilter.getMyTerminalArea;
	jrwTrans.myOperator 		:= tiFilter.myOperator;
	jrwTrans.myOperatorGroup	:= tiFilter.getMyOperatorGroup;
	jrwTrans.myISOTypeGroup		:= tiFilter.getMyISOTypeGroup;
	jrwTrans.qryAvaGradesStr	:= tiFilter.getQryAvaGradesStr;

	jrwTrans.sumRail 	:= tiFilter.sumRail;
	jrwTrans.sumRoad 	:= tiFilter.sumRoad;
	jrwTrans.sumWeight 	:= tiFilter.sumWeight;
	jrwTrans.sum20s 	:= tiFilter.sum20s;
	jrwTrans.sum40s 	:= tiFilter.sum40s;

	numSelected := jrwTrans.allTrackedItems.size;

epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryContainerEvents" id="6624977f-5f4e-4978-85c2-1310b097b8b9">
        <updating/>
        <source>qryContainerEvents(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_ContainerTrans;
	oid   : String;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_ContainerTrans;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	
	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.myVoyage := tiFilter.getMyVoyage;
	jrwTrans.myOperator := tiFilter.myOperator;
	jrwTrans.startDate := tiFilter.startDate;
	jrwTrans.endDate := tiFilter.endDate;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
//	jrwTrans.transTypeStr := tiFilter.allTransTypeDescriptions.asCSV(false)[1:120];	// cnwrl1 07/09/2009 PAR 20198 - what it was
	jrwTrans.transTypeStr := tiFilter.getTransTypeString(oid)[1:120];//21/07/2010 cnwdz2 24513
	numSelected := jrwTrans.allTransactions.size;
	
epilog
	
	return numSelected;
end;
</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryCraneKPI" id="15753869-5372-423d-b7cc-d552d16b818f">
        <updating/>
        <source>qryCraneKPI(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// Dec 2010 CCMS 1134
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWCraneKPI;
	filter			: CMQF_CraneKPI;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter.CMQF_CraneKPI;
	jrwTrans := self.createJRWTransient(CM_JRWCraneKPI).CM_JRWCraneKPI;

	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allVoyageKPICraneShifts, _passport);
	
	jrwTrans.dateFrom := filter.startDate;
	jrwTrans.dateTo := filter.endDate;
	jrwTrans.timeFrom := filter.startTime;
	jrwTrans.timeTo := filter.endTime;
	
