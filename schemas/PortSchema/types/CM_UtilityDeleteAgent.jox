    <JadeMethod name="utlDeleteVoyage" id="5646081d-d7bf-447f-af74-499a477ce537">
        <source>utlDeleteVoyage(_voyage:CM_Voyage io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Nov 2017	jlgkpd1		Move YA objects cleanup to erase for Garbage Collection
// ---------------------------------------------------------------------------
vars
	realVoyage : CM_Voyage;
	expectedEdition : Integer;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVoyage(_voyage, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	if _voyage.isTransient then
		 _voyage.pxyGetRealObjectAndEdition(realVoyage, expectedEdition);
	else
		realVoyage := _voyage;
	endif;

	if realVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Voyage.name, null, null);
		return;
	endif;
	
	if not _passport.noErrors() then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if expectedEdition &lt;&gt; null // If null the a real voyage was passed in
	and realVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage', null, null);
		return;
	endif;		
	
	self.exclusiveLock(realVoyage);	

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_voyage);
	endif;

	if _passport.noErrors then
		_voyage.causeEvent(_voyage.myTerminal.getTerminalEvent(Voyage_Delete_Event), false, _voyage);
		_voyage.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageAllocation" id="c6973648-2085-4485-8875-8189fa64268b">
        <source>utlDeleteVoyageAllocation(_voyAllocation : CM_VoyageAllocation io; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	tmpVoy : CM_Voyage;
	slotReq : CM_SlotRequest;
	aReq : CM_VoyageRequest;
	tiSet : CM_TISet;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValDA.valVoyageAllocation(_voyAllocation);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	tmpVoy := _voyAllocation.myVoyage;
	
	if _passport.noErrors then		
		app.myEventManager.createSingleObjInfoNoteEvt(tmpVoy,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_DELETE),_voyAllocation);
		
		create tiSet transient;	//27 Jun 2017	NDL	TFS 5148
		foreach slotReq in _voyAllocation.allSlotRequests do //+ Par 25030
			//27 Jun 2017	NDL	TFS 5148
			if slotReq.moveType = DLR_MOVETYPE or slotReq.moveType = SOB_MOVETYPE then
				foreach wle in slotReq.allWorkListEntries do
					ti := wle.myTrackedItem;
					if ti &lt;&gt; null then
						tiSet.addNoDuplicates( ti, false );
					endif;
				endforeach;
			endif;
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoy,_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),slotReq.mySlotController);
		endforeach;
		
		// PAR 28513
		foreach aReq in _voyAllocation.allRequests do
			//27 Jun 2017	NDL	TFS 5148
			if aReq.moveType = DLR_MOVETYPE or aReq.moveType = SOB_MOVETYPE then
				foreach wle in aReq.allWorkListEntries do
					ti := wle.myTrackedItem;
					if ti &lt;&gt; null then
						tiSet.addNoDuplicates( ti, false );
					endif;
				endforeach;
			endif;
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoy,_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),aReq.CM_RORORequest.myROROController);
		endforeach;
		
		//27 Jun 2017	NDL	TFS 5148
		foreach ti in tiSet do
			ti.setTransitStatus(TI_TransitStatusNull, true, _passport);
		endforeach;
		
		_voyAllocation.erase(NORMAL_ERASE);
	endif;

epilog
	
	delete tiSet;
	
end;</source>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageController" id="853bf9ed-51e5-4c18-b60b-9ea2699b7e6c">
        <source>utlDeleteVoyageController(_voyageController:CM_VoyageController io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
