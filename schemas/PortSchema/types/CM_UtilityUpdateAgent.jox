        <source>utlUpdateInvINCOTerms(_pxyInvoiceINCOTerm : CM_InvoiceINCOTerm io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars
	realINCOTerm:CM_InvoiceINCOTerm;
	expectedEdition:Integer;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	_pxyInvoiceINCOTerm.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceINCOTerm.pxyGetRealObjectAndEdition(realINCOTerm, expectedEdition);
	
	if realINCOTerm = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceContractShipTerm.name, null, null);
		return;
	endif;

	app.myValUA.valInvINCOTerm(_pxyInvoiceINCOTerm);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realINCOTerm);

	if _passport.noErrors and realINCOTerm.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'INCO Term', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realINCOTerm, true);
	endif;
	
	if _passport.noErrors then
		realINCOTerm.setForUpdate(_pxyInvoiceINCOTerm);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realINCOTerm, false);
	app.myEventManager.createSingleObjInfoNoteEvt(realINCOTerm.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvINCOTermUpdate),realINCOTerm);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoiceINCOTerm" type="CM_InvoiceINCOTerm" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
