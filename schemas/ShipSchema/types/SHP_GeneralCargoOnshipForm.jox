    <JadeMethod name="buildCargoMenu" id="de81d63d-8e51-4694-ab28-559fd23038e5">
        <updating/>
        <source>buildCargoMenu(_theTI : CM_TrackedItem input) updating, protected;
// 16/06/2010 cnwcs5	par 24342 - no context menu for stops
vars

begin

	self.mnuCargo.visible := true;
	self.mnuCargoSetGrade.visible := false;
	
	//epr par 32261 19/8/13
	self.myAssistant.menuSetGradeBuild(self.mnuCargoSetGrade,self.mnuSetGradeSub,_theTI);
	
	self.doBuildMnuTasksAdd(_theTI);	
	self.doBuildMnuTasksComplete(_theTI);	
	self.doBuildMnuTasksRemove(_theTI);	
	//self.doBuildMnuStops(_theTI);
	self.mnuStops.visible := true;
	self.mnuStops.enabled := true;
	self.mnuStops.userObject := _theTI;
	
	// 26/04/2010 cnwmh5 PAR23821
	self.mnuCargoLabelPrint.visible := true;
	self.mnuCargoLabelPrint.userObject := _theTI;
	
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
