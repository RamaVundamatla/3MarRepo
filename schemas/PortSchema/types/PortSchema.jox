        <source>finPushEventsApp() updating;
/*

Purpose:			Finalise method for Push Events Application

Parameters:			None

Return Value:		None

Date		Who		Reason
13 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	if self.myInterfaceController &lt;&gt; null then
		self.myInterfaceController.finish();
		delete self.myInterfaceController;
