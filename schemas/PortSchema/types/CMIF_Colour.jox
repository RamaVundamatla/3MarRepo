<Class name="CMIF_Colour" id="1dca3673-a031-4dfd-a936-9184af4d1e40">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="colour" id="49e7a178-5415-4da6-9920-0b765b44f63c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="inverseColour" id="d1de2863-4649-4667-9621-a6bfdefb3d31">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setColour" id="e099103a-f6fe-40fd-9c33-ff8e13fb92c4">
        <updating/>
        <source>setColour(_colour : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2017	cnwer1	Initial creation TFS 3284

*/

vars

begin
	if self.colour &lt;&gt; _colour then
		self.colour :=_colour;	
		self.inverseColour:=self.colour.getInverseColour;
		
	else
		if _colour = 0 then
			self.inverseColour := White;
		endif;
	endif;
epilog	

end;</source>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
</Class>
