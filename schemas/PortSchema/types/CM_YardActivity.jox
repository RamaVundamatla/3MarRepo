    <JadeMethod name="addReeferInfoTransaction" id="f6396f2c-a852-4d53-9ecf-93df7b74fc2c">
        <source>addReeferInfoTransaction();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation
TFS 51455 09 JUL 2021 NAVAB1 this was creating/attempting to create a monitor job for all job deletions (doAction), have re implemented on Monitor job sub class to create new monitor job.
*/

vars
	
	information : StringArray512;
	info : CM_Information;
	invalid : Boolean;

begin

	if self.myTrackedItem &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalid );
		
		create information transient;
		information.addTruncated(self.getTypeString &amp; " - Actioned");
		information.addTruncated("Reefer = " &amp; self.myTrackedItem.id);
	
		info := self.myTrackedItem.createInfomationTransaction( "Reefer Job - Actioned", information, null, app.myPassport );
		
	endif;

epilog

	delete information;

end;</source>
    </JadeMethod>
