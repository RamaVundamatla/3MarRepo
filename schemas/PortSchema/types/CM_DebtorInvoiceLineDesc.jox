    <JadeMethod name="getAuditText" id="761fc311-97d8-4328-baa4-92134044e2ec">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation
// 02 Feb 2017 TFS #3286:Issues with Invoicing Audits
*/

vars
	txt,
	tmpStr	: String;
	tmpDeb 	: CM_Debtor;
	tmpInvLineDesc : CM_InvoiceLineDesc;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	
	if self.allConsolidatingDebtor.size &gt; 0 then
		foreach tmpDeb in self.allConsolidatingDebtor do
			tmpStr := tmpStr &amp;tmpDeb.name &amp;CrLf ;
		endforeach;
		
		txt := txt &amp; 'Debtors' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allConsolidatingInvLineDesc.size &gt; 0 then
		foreach tmpInvLineDesc in self.allConsolidatingInvLineDesc do
			tmpStr := tmpStr  &amp;tmpInvLineDesc.narration&amp;CrLf ;
		endforeach;
		txt := txt &amp; 'Invoice Lines' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
		tmpStr := null;
	if self.myBankDebtor &lt;&gt; null then
		tmpStr := self.myBankDebtor.code;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
