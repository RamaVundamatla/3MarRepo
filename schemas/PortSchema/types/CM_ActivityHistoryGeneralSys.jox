<Class name="CM_ActivityHistoryGeneralSys" id="204dd244-fa50-48b4-8814-9113aad6594d">
    <superclass name="CM_ActivityHistoryGeneral"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="earliestDeleteDate" id="54386106-aeb9-41f8-8490-ac6da946a0c4">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="89cc86f5-2c13-4e62-be0d-ea7f0c3f8004">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwndl1	Initial creation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	user : CM_User;

begin

	self.earliestDeleteDate := ( app.actualTimeServer.Date + 90 );	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	user := app.getMyUser;
	if user &lt;&gt; null then
		self.userCode := user.code;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4cca9d06-3004-4ee5-a00e-b9c8b01ca2d2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_Description then
		if self.userCode &lt;&gt; null then
			return self.userCode &amp; ", " &amp; self.description;
		endif;
		return self.description;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="a03a723d-7e89-46e7-b86f-c3da349f20a2">
        <source>getTypeDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwndl1	Initial creation

*/

vars

begin

	return inheritMethod() &amp; "/" &amp; app.getErrorString(System_GC);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtraDetailFromStack" id="fbe15b75-b3ff-414e-836f-ee3966037822">
        <updating/>
        <source>setExtraDetailFromStack( _stack : HugeStringArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.allExtraDetail = null then
		if self.isTransient then
			create self.allExtraDetail transient;
		else
			create self.allExtraDetail;
		endif;
	endif;
	
	if not _stack.isEmpty then
		_stack.copy(self.allExtraDetail); 
	endif;

epilog

end;</source>
        <Parameter name="_stack" type="HugeStringArray"/>
    </JadeMethod>
</Class>
