    <JadeMethod name="trainStatusEnumToString" id="3ed6612d-8db6-4119-8a74-85adf9011b81">
        <source>trainStatusEnumToString(_statusCode : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2022	navsp1	Initial creation TFS#53619

*/

vars

begin
	if _statusCode = TrainStatus_Created then
		return app.getErrorString(TrainStatus_CreatedStr).trimBlanks;
	elseif _statusCode = TrainStatus_Inbound then
		return app.getErrorString(TrainStatus_InboundStr).trimBlanks;
	elseif _statusCode = TrainStatus_Arrived then
		return app.getErrorString(TrainStatus_ArrivedStr).trimBlanks;
	elseif _statusCode = TrainStatus_Working then
		return app.getErrorString(TrainStatus_WorkingStr).trimBlanks;
	elseif _statusCode = TrainStatus_Complete then
		return app.getErrorString(TrainStatus_CompleteStr).trimBlanks;
	elseif _statusCode = TrainStatus_Departed then
		return app.getErrorString(TrainStatus_DepartedStr).trimBlanks;
	elseif _statusCode = TrainStatus_Closed then
		 return app.getErrorString(TrainStatus_ClosedStr).trimBlanks;
	elseif	_statusCode = TrainStatus_Cancelled then	
		return app.getErrorString(TrainStatus_CancelledStr).trimBlanks;
	else
		return null;
	endif;
end;


</source>
