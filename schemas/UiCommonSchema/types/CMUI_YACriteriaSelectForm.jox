    <JadeMethod name="translateForm" id="503e0d91-b321-4d6b-bb07-1af1148f5c68">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010156, locale);
	btnCancel.translateCaption(Xlat_0010157, locale);
	btnOK.translateCaption(Xlat_0010158, locale);
	chkByDescription.translateBubbleHelp(Xlat_0010159, locale);
	chkByDescription.translateCaption(Xlat_0010160, locale);
	lblByVoyage.translateCaption(Xlat_0015088, locale);
	lblByWeight.translateCaption(Xlat_0019043, locale);
	lblFind.translateCaption(Xlat_0010161, locale);
	optAll.translateCaption(Xlat_0010162, locale);
	optSelected.translateCaption(Xlat_0010163, locale);
	optVoyage.translateCaption(Xlat_0010164, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtFind_keyDown" id="1362a445-153e-4cfe-b9d3-ee6599ced1f4">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFind_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 October 2022	navgm20	ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS

*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.Timer_TblAvailData_Filter, type, remaining) then
		self.endTimer(self.Timer_TblAvailData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_TblAvailData_Filter);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
