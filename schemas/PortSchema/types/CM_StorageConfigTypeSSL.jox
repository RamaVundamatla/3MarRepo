    <JadeMethod name="addWorkAndCompChargeDaysTo" id="25b1f7dd-e1d1-45a9-a46f-7c40bb266b5f">
        <source>addWorkAndCompChargeDaysTo( _ti : CM_TrackedItem; _storageConfig: CM_StorageConfig; _expiryDate: Date; _days: Integer): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2017	jlgndl1	Initial creation	TFS 7032 - Returns the last free day of storage.

					This is special code exclusively for Bermuda based on some weird illogical rules as explained by Steve.
					
14 Jan 2019		NDL		TFS 40503 - New rules.  disch Fri = this sat &amp; sun free, disch sat = this sun, next sat &amp; sun free, disch sun = next sat &amp; sun free.

*/

vars

	coyNoWorkDaysCal : CM_Calendar;
	count	: Integer;
	result	: Date;
	date	: Date;
//	calendarDate : CM_CalendarDate;
	eofFreePeriodDt : Date;
	receivalTrans : CM_TITransaction;
	recDate : Date;
	addCount : Boolean;
	
begin

	recDate := null;
	if _ti &lt;&gt; null then
		receivalTrans := _ti.findLastReceivalTrans();
		if receivalTrans &lt;&gt; null and receivalTrans.isKindOf( CM_ReceiveShip ) then
			recDate := receivalTrans.dateTime.Date;
		endif;
	endif;
	
	result := _expiryDate;
	if not _expiryDate.isValid then
		return null;
	endif;

	if _storageConfig &lt;&gt; null then
		coyNoWorkDaysCal := _storageConfig.getMyCompulsoryCalendar;
	endif;

	if coyNoWorkDaysCal = null then
		return null;
	endif;
	if coyNoWorkDaysCal.allCalendarDates.isEmpty or _days &lt;= 0 then
		return null;
	endif;
	
	//This is the bit that re-adjusts what weekend days will be included in the free period.
	if  recDate &lt;&gt; null and recDate = _expiryDate and recDate.dayOfWeek = 6 then
		//if it arrives on saturday then they get 2 sundays, so allow an extra day
		eofFreePeriodDt := _expiryDate + 7;
	else
		eofFreePeriodDt := _expiryDate + 6; // otherwise just the weekend it arrives before
	endif;
	
	date := _expiryDate;

	while true do
		date := date + 1;
		addCount := true;
		
		if date &lt;= eofFreePeriodDt then	// check for a weekend date in the first week (mon-sunday week)
			if date.dayOfWeek &gt; 5 then
				addCount := false;
			endif;
		endif;
		if addCount then	// not a weekend, check for compulsory days
			addCount := coyNoWorkDaysCal.getFirstCalendarDateForDay(date) = null;
		endif;
		if addCount then	// not a weekend/holiday or Compulsory day
			count := count + 1;
//write " -  this is a normal work day within the 'n' days free, counted as one of the free days " &amp; date.String;
		endif;
		
		if count &gt;= _days then // need to consider bailing now unless tomorrow is also a holiday
		
			if coyNoWorkDaysCal.getFirstCalendarDateForDay(date + 1) &lt;&gt; null then
				//while the next day is a holiday we will want to count that too, so carry on.
//write " - count &gt;= 5 next day is a stat day so continue " &amp; date.String;
				continue;
			endif;
			
			if date &lt;= eofFreePeriodDt then	// check for free weekends within the 7 or 8 days from rec date.
				if date.dayOfWeek = 5 or date.dayOfWeek = 6  then
//write " -  tomorrow is a w/e date within the date range so skip forward " &amp; date.String;
					continue;
				endif;
			endif; 
			if date &lt;= eofFreePeriodDt then
				if date.dayOfWeek = 6 then
					continue;
				endif;
			endif; 
			
//write "breaking @ " &amp; date.String;
			break;
		endif;
	endwhile;
	
//write _ti.id &amp; " " &amp; date.String;
//write " ";
	
	result := date;
	return result;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_days" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getAllExtraDayCargoTypeObjs" id="9583803c-fb2b-41f3-8974-eefd74990e0c">
        <source>getAllExtraDayCargoTypeObjs(_coll : Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2022	jlier1	Initial creation TFS 52292

*/

vars
	cargoTypeCode : Integer;
	cargoType : CM_CargoType;
begin
	if _coll = null then
		return;
	endif;
	
	
	foreach cargoTypeCode in self.allExtraDayCargoTypes discreteLock do
		cargoType:=self.myRoot.allCargoTypesById[cargoTypeCode];
		if cargoType &lt;&gt; null then
			_coll.add(cargoType);
		endif;	
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraDayCargoTypeSummary" id="3b104e5c-c633-4eac-ac14-d6bcb81f0e5b">
        <source>getExtraDayCargoTypeSummary( _delim : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//14/06/2023	navkc1	CR 58007 Defect 58623: Audit option not working on Storage Config Screen for "Cargo Types for Extra Days Storage" tab

*/

vars
	retString 		: String;
	root			: CM_Root;
	cargoTypeID 	: Integer;
begin
	root := app.myRoot;
	
	if root = null then
		return null;
	endif;
	
	foreach cargoTypeID in self.allExtraDayCargoTypes do
		if retString &lt;&gt; null then
			retString := retString &amp; _delim;
		endif;
		retString := retString &amp; root.getCargoTypeDescription(cargoTypeID);
	endforeach;
	
	return retString;
	
epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="d4d8e410-2dbd-4b4c-8c95-a332336fb537">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

begin
	return "Storage Configuration - SSL Bermuda";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumWorkAndCompChargeDays" id="bab2dd38-74d8-4db9-8287-bd8ab82758bd">
        <source>getNumWorkAndCompChargeDays(	_workCal : CM_Calendar;
								_compCal : CM_Calendar;
								_startDate : Date;
								_endDate : Date;
								_tiTrx : CM_TITransaction
								):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 January 2019	jlgndl1	Initial creation	TFS 40503		SSL Version
25 March 2022	jlier1	TFS 52292
13 Apr 	2022	jlier1	TFS 53412;
23 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	numDaysToCheck : Integer;
	testDate : Date;
	numDaysChecked : Integer;
	calendarDate : CM_CalendarDate;
	daysToCharge : Integer;
	ti : CM_TrackedItem;
	eofWeekDt : Date;
	recTrx : CM_TITransaction;
	needsExtraDay : Boolean;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();	 //27.02.2025 navah1 #34141
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " _startDate: " &amp; _startDate.String &amp; " _endDate: " &amp; _endDate.String, LogINFO.String);
	endif;
	if not _startDate.isValid or not _endDate.isValid then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning ZERO - invalid dates", LogINFO.String);
		endif;
		return 0;
	endif;
	
	numDaysToCheck :=  _endDate - _startDate;	//06 Dec 2017	NDL	TFS 7032
	if numDaysToCheck &lt;= 0 then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning Zero - Date range &lt; 1", LogINFO.String);
		endif;
		return 0;
	endif;
	
	if _workCal = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No 'Days Excluded Calendar' for storage config", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	if _compCal = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No 'Compulsory Days Calendar' for storage config", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	
	if _workCal.allCalendarDates.isEmpty and _compCal.allCalendarDates.isEmpty then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning total for date range - No Dates in Calendars", LogINFO.String);
		endif;
		return numDaysToCheck;
	endif;
	
	eofWeekDt := null;
	if _tiTrx &lt;&gt; null then
		ti := _tiTrx.myTrackedItem;
		if ti &lt;&gt; null then
			recTrx := ti.findLastReceivalTrans();
			if recTrx &lt;&gt; null then		
			//	if _workCal.getFirstCalendarDateForDay(recTrx.dateTime.Date) &lt;&gt; null then
			//		eofWeekDt := recTrx.dateTime.Date + 2;
			//	else
			//		eofWeekDt := recTrx.dateTime.Date + 7;
			//	endif;
				//15 Jan 2018	NDL	TFS 40503
				if  recTrx.dateTime.Date.dayOfWeek = 6 then
					//if it arrives on saturday then they get 2 sundays, so allow an extra day
					eofWeekDt := recTrx.dateTime.Date + 8;
				else
					eofWeekDt := recTrx.dateTime.Date + 7; // otherwise just the weekend it arrives before
				endif;
				// jlier1 TFS 52292 25/3/22 - it has arrived on a weekend check if it needs and extra day
				if (recTrx.dateTime.Date.dayOfWeek = 6 or  recTrx.dateTime.Date.dayOfWeek = 7) and self.needsExtraDay(ti) then
					needsExtraDay:=true;
					eofWeekDt:=eofWeekDt +1;
				endif;
			endif;
		endif;
	endif;
	//This is the bit that re-adjusts for when the cargo actually arrives in the weekend.
	if eofWeekDt = null then
	//	if _workCal.getFirstCalendarDateForDay(_startDate) &lt;&gt; null then
	//		eofWeekDt := _startDate + 2;
	//	else
	//		eofWeekDt := _startDate + 7;
	//	endif;
		//15 Jan 2018	NDL	TFS 40503
		if  _startDate.dayOfWeek = 6 then
			//if it arrives on saturday then they get 2 sundays, so allow an extra day
			eofWeekDt := _startDate + 8;
		else
			eofWeekDt := _startDate + 7; // otherwise just the weekend it arrives before
		endif;
	endif;
	
	//OK should be good to go now.
	//Need to return the count of the number of days between the start and end, and subtract the days that are 
	//weekends (i.e. the days declared in the days excluded calendar for the first physical week mon-sun irrespective
	//of the s=day it arrives ) and those that are in the compulsory days calendar. DO NOT double count any days
	//that occur in both.
//write ti.id &amp; " " &amp; _startDate.String &amp; " - " &amp; eofWeekDt.String;	

	testDate := _startDate;
	while true do
		testDate := testDate + 1;
		numDaysChecked := numDaysChecked + 1;
		calendarDate := null;
		if testDate &lt;= eofWeekDt then
			calendarDate := _workCal.getFirstCalendarDateForDay(testDate); // check for a weekend date in the first week (mon-sunday week)
		endif;
		if calendarDate = null then
			calendarDate := _compCal.getFirstCalendarDateForDay(testDate); // check for any compulsory day in the period
		endif;
		if calendarDate = null then	// not a weekend/holiday or compulsory day
			if testDate = eofWeekDt and needsExtraDay then 
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Excluding Date for extra days free storage- " &amp; testDate.String, LogINFO.String);
				endif;
			else
				daysToCharge := daysToCharge + 1;
			endif;
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Excluding Date - " &amp; calendarDate.date.String, LogINFO.String);
			endif;
		endif;
		if numDaysChecked = numDaysToCheck or testDate = _endDate then
			break;
		endif;
	endwhile;

	return daysToCharge;

epilog

end;</source>
        <Parameter name="_workCal" type="CM_Calendar"/>
        <Parameter name="_compCal" type="CM_Calendar"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isSSLtype" id="b8318762-c1a1-4232-9d13-85f8d2f20ad5">
        <source>isSSLtype(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

begin

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needsExtraDay" id="962bd556-34cf-4fc8-8dd9-05d146ce7fee">
        <source>needsExtraDay(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2022	jlier1	Initial creation TFS 52292

*/

vars

begin
	if _ti.isContainer and not _ti.is20 then
		return false;
	endif;
	
	return self.allExtraDayCargoTypes.includes(_ti.cargoType);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllExtraDayCargoTypes" id="d3a36601-bd2f-4a34-8f8a-33da6ccfbbd7">
        <source>setAllExtraDayCargoTypes(_allExtraDayCargoTypes : IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2022	jlier1	Initial creation TFS 52292

*/

vars

begin
	self.allExtraDayCargoTypes.clear;
	_allExtraDayCargoTypes.copy(self.allExtraDayCargoTypes);
epilog

end;</source>
        <Parameter name="_allExtraDayCargoTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
</Class>
