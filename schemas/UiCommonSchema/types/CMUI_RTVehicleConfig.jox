    <JadeMethod name="chkAllowChgSet_click" id="416f75a3-608f-4067-a573-eb98753f1561">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAllowChgSet_click(checkbox: CheckBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/07/2021	navdap1		Initial creation TFS 51409 PNL Queued Jobs in Driver Mode
//
vars

begin
	if checkbox.value then						// TFS 51409
		self.chkWarnChgSet.enabled := true;		// TFS 51409
	else										// TFS 51409
		self.chkWarnChgSet.enabled := false;	// TFS 51409
		self.chkWarnChgSet.value := false;		// TFS 51409
	endif;										// TFS 51409

epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkAllowNonRT_click" id="435e7871-1af3-4e55-a9c2-16bd0970f8b0">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAllowNonRT_click(checkbox: CheckBox input) updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
------------------------------------------------------------------------------
01/07/2021		navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
*/
vars
	obj	: Object;

begin

	self.btnTemplCritEdit.enabled := checkbox.value;
	self.chkAutoPlanDriver.enabled:=checkbox.value; //epr TFS 6846 8/9/17
	obj := self.lstObject.listObject;
	if obj.isKindOf(CM_Terminal) then
		self.displayCriteriaDesc();
	endif;
	
	if checkbox.value then						// TFS 51409
		self.chkAllowNonRTQ.enabled := true;	// TFS 51409
	else										// TFS 51409
		self.chkAllowNonRTQ.enabled := false;	// TFS 51409
		self.chkAllowNonRTQ.value := false;		// TFS 51409
	endif;										// TFS 51409

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIgnoreWarn_click" id="48f9884e-736f-4fff-8ad8-ee31f358f522">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIgnoreWarn_click(checkbox: CheckBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/08/2021	navdap1		Initial creation TFS 51409 PNL Queued Jobs in Driver Mode
//
vars

begin
	// clear and disable "Warn driver on changed Setdown" if "Ignore Warnings" is ticked
	if checkbox.value then
		self.chkWarnChgSet.value := false;
		self.chkWarnChgSet.enabled := false;
	else
		if self.chkAllowChgSet.value then 
			self.chkWarnChgSet.enabled := true;
		else
			self.chkWarnChgSet.enabled := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkTandemToDiffTargets_change" id="bd1cf615-7c5a-4cc0-a904-365fd98e6768">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkTandemToDiffTargets_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2025	navkc1 JIRA 36186 PNL | Vehicle App Swap behaviour with Release Requests - DB Changes / Jade / Form

*/

vars

begin
	if checkbox.value then
		self.chkDoSwapChangeCargo.visible := true;
	else
		self.chkDoSwapChangeCargo.visible := false;
		self.chkDoSwapChangeCargo.value := false; // If allow tandem to diff location is false, this must be false too
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkTaskGetNext_click" id="2199ac31-58e4-4159-9c99-26253287059e">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkTaskGetNext_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwer1	Initial creation

*/

vars
	bothVisible : Boolean;
begin
	if not checkbox.value then
		if not self.chkTaskList.value then
			checkbox.value:=true;
		endif;
	endif;
	
	self.setDefaultTaskModeVisibility();
	
	if bothVisible then 
		self.lblDefGetNext.caption :=  app.getErrorString(Default);
		self.lblDefList.caption:= app.getErrorString(SetDefault);
	endif;
	
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
