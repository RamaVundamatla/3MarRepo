    <JadeMethod name="mnuFileRun_click" id="f488826a-d8f9-4bec-8c76-5875a33ec2de">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileRun_click(menuItem: MenuItem input) updating;

begin
	if currentForm=null then
		global.beep;
	else
		if currentForm.oEnv.value=true then
			currentForm.setProcessLogFileName("backup");
		else
			currentForm.setProcessLogFileName("run");
		endif;
		currentForm.listBox.top:=currentForm.tCmdLine.top+currentForm.tCmdLine.height+6;
		currentForm.resize;
		currentForm.cbEnv.setFocus;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileSelectServer_click" id="438f1f7a-57c8-43d8-91b5-a0411f6d1a94">
