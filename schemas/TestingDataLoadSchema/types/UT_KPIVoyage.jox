    <JadeMethod name="setupShifts" id="0ea21fa6-1f60-4fbd-bda7-e836d1fa6f39">
        <source>setupShifts();
// ---------------------------------------------------------------------------
// Purpose:     	
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 13/12/2021		navmh5			Created
// ---------------------------------------------------------------------------
constants
	
	OpsViewCreated				: String = "OpsView Created";
	ShiftText					: String = "Shift";

vars

	shiftStd					: CM_ShiftStd;
	pxyShiftStd					: CM_ShiftStd;
	shiftEntity					: CM_ShiftEntity;
	
	shiftLength					: Integer;
	actualShiftLength			: Real;
	shiftTS						: TimeStamp;
	endTS						: TimeStamp;
	tempTime					: Time;
	pos							: Integer;
	shiftCode					: String;
	shiftDesc					: String;
	shiftDay					: Integer;
	shiftDate					: Date;
	count						: Integer;
		
begin

	shiftLength := (app.shiftLength / 60).Integer;
	actualShiftLength := shiftLength.Real;
	if actualShiftLength = 0 then
		actualShiftLength := 0.5;
	endif;
	
	shiftTS := app.actualTimeAppServer();
	tempTime.setTime(shiftTS.time.hour, 0, 0, 0);
	shiftTS.setTime(tempTime);
	endTS := shiftTS.addDays(2).addMinutes(1);
	
	
	//write "shiftLength: " &amp; shiftLength.String &amp; Tab &amp; "actualShiftLength: " &amp; actualShiftLength.String &amp; Tab &amp;
	//	"startTS: " &amp; shiftTS.String &amp; Tab &amp; "endTS: " &amp; endTS.String;
	
	// Delete any already created shifts that were OpsView Created
	foreach shiftStd in CM_ShiftStd.instances discreteLock do
		
		pos := shiftStd.description.pos(OpsViewCreated, 1);
		if pos = 0 then
			continue;
		endif;
		
		app.myTrxDA.trxDeleteShift(shiftStd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	endforeach;
	
	// create the shifts for the next 48 hours
	shiftDate := null;
	count := 0;
	while shiftTS &lt; endTS do
	
		count := count + 1;
		if count &gt; 100 then
			break;
		endif;
	
	
		// date has changed so we need to set a few variables
		//write "shiftTS.date: " &amp; shiftTS.date.String &amp; Tab &amp; "shiftDate: " &amp; shiftDate.String;
		if shiftTS.date &lt;&gt; shiftDate then
			shiftDay := shiftTS.date.dayOfWeek;
			shiftDate := shiftTS.date;
		endif;
				
		shiftCode := ShiftText &amp; shiftTS.time.hour.String.padLeadingZeros(2) &amp; shiftTS.time.minute.String.padLeadingZeros(2);
		shiftDesc := shiftCode &amp; " - " &amp; OpsViewCreated;
		//write "shiftCode: " &amp; shiftCode &amp; Tab &amp; "shiftDesc: " &amp; shiftDesc &amp; Tab &amp; "shiftDay: " &amp; shiftDay.String &amp; Tab &amp;
		//	"shiftDate: " &amp; shiftDate.String;
			
		// create the shift
		create pxyShiftStd transient;
		pxyShiftStd.setProxy(shiftDay, shiftTS.time, shiftTS.time.addMinutes((actualShiftLength * 60).Integer).Time, shiftCode, shiftDesc, self.getTerminal(), false);
		
		app.myPassport.setWarningsIgnored(true);
		app.myTrxCA.trxCreateShift(pxyShiftStd, app.myPassport, shiftEntity);
		self.assertNoTrxErrorsOrWarnings();
		app.myPassport.setWarningsIgnored(false);
				
		// update the description
		delete pxyShiftStd;
		
		beginLoad;
		pxyShiftStd := shiftEntity.pxyCreateUpdateProxy().CM_ShiftStd;
		endLoad;
		pxyShiftStd.setPropertyValue("description", shiftDesc);
		pxyShiftStd.setPropertyValue("myTerminal", shiftEntity.CM_ShiftStd.myTerminal);
		app.myTrxUA.trxUpdateShift(pxyShiftStd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
		delete pxyShiftStd;
			
		// set for next shift
		shiftTS := shiftTS.addMinutes((actualShiftLength * 60).Integer);
		
		
	endwhile;
	
	
epilog
	
		delete pxyShiftStd;
		
		app.myPassport.setWarningsIgnored(false);
	
end;
</source>
    </JadeMethod>
