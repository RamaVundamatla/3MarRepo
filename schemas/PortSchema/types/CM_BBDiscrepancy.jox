        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChargeQuantity" id="1118d764-f789-4622-8fea-6c03cc6bb4ec">
        <source>getChargeQuantity(): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37588


*/

vars

begin
	
	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.myCargoType.isBulkMulti then
			return self.weightChange;
		else
			return quantityChange;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ed82b4a9-925e-4a1b-9649-4fe684892df2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2013	cnwrd1	Initial creation

*/

vars
	oldQuantity : Integer;
	oldWeight : Decimal[14,4];
	lDetail : String;
	oldAmount,
	newAmount,
	amountChange : String;
	oldCargoWeight : Decimal[14,4];
	oldTareWeight : Decimal[14,4];
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			oldQuantity := newTotalQuantity - quantityChange;
			oldWeight := newTotalWeight - weightChange;	
			oldCargoWeight := newCargoWeight - cargoWeightChange;
			oldTareWeight := newTareWeight - tareWeightChange;

			if quantityChange &lt;&gt; null then
				lDetail := lDetail &amp; "Old Total Quantity " &amp; oldQuantity.asStringJMT &amp; ", Change " &amp; self.quantityChange.asStringJMT &amp; ", New Total Quantity " &amp; self.newTotalQuantity.asStringJMT ;
			endif;
			if weightChange &lt;&gt; null then
				if self.myTrackedItem &lt;&gt; null  and self.myTrackedItem.myCargoType.isBulkMulti then
					if lDetail &lt;&gt; null then
						lDetail := lDetail &amp; CrLf;
					endif;
					oldAmount:=self.myTrackedItem.myCargoType.getBulkTrackByDisplayForWeight(oldWeight,self.myTrackedItem.getDensity,true);
					newAmount:=self.myTrackedItem.myCargoType.getBulkTrackByDisplayForWeight(self.newTotalWeight,self.myTrackedItem.getDensity,true);
					amountChange:=self.myTrackedItem.myCargoType.getBulkTrackByDisplayForWeight(self.weightChange,self.myTrackedItem.getDensity,true);
					if self.myTrackedItem.isBulkByVolume then
						lDetail := lDetail &amp; "Old Total Volume " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Total Volume " &amp; newAmount &amp; ' ';
					else
						lDetail := lDetail &amp; "Old Total Weight " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Total Weight " &amp; newAmount &amp; ' ';
					endif;
				else
				//epr TFS 2117 11/7/16
					if lDetail &lt;&gt; null then
						lDetail := lDetail &amp; CrLf;
					endif;
					oldAmount:=app.getWeightForDefaultDisplay(oldWeight);
					newAmount:=app.getWeightForDefaultDisplay( newTotalWeight);
					amountChange:=app.getWeightForDefaultDisplay(self.weightChange);
					lDetail := lDetail &amp; "Old Total Weight " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Total Weight " &amp; newAmount;
				endif;
			endif;
			
			if cargoWeightChange &lt;&gt; null then
				if lDetail &lt;&gt; null then
					lDetail := lDetail &amp; CrLf;
				endif;
				oldAmount:=app.getWeightForDefaultDisplay(oldCargoWeight);
				newAmount:=app.getWeightForDefaultDisplay( newCargoWeight);
				amountChange:=app.getWeightForDefaultDisplay(self.cargoWeightChange);
				lDetail := lDetail &amp; "Old Cargo Weight " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Cargo Weight " &amp; newAmount;
			endif;
			
			if tareWeightChange &lt;&gt; null then
				if lDetail &lt;&gt; null then
					lDetail := lDetail &amp; CrLf;
				endif;
				oldAmount:=app.getWeightForDefaultDisplay(oldTareWeight);
				newAmount:=app.getWeightForDefaultDisplay( newTareWeight);
				amountChange:=app.getWeightForDefaultDisplay(self.tareWeightChange);
				lDetail := lDetail &amp; "Old Tare Weight " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Tare Weight " &amp; newAmount;
			endif;
			
			if self.reason &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  'Reason : ' &amp; self.reason;
			endif;
			
			return lDetail;
		endif;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="9996e978-c296-4c15-9e44-ce8532cd465f">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_BBDiscrepancyController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 37558

*/

vars

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.cargoWeightChange := _tiTransCntrl.cargoWeightChange;
	self.newCargoWeight := _tiTransCntrl.newCargoWeight;
	self.newTareWeight := _tiTransCntrl.newTareWeight;
	self.newTotalQuantity := _tiTransCntrl.newTotalQuantity;
	self.newTotalWeight := _tiTransCntrl.newTotalWeight;
	self.quantityChange := _tiTransCntrl.quantityChange;
	self.reason := _tiTransCntrl.reason;
	self.tareWeightChange := _tiTransCntrl.tareWeightChange;
	self.weightChange := _tiTransCntrl.weightChange;
	
	//13 Apr 2021	NDL	TFS 50906
	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null
	and self.myTrackedItem.myPrimaryActualLocation.isActivityTrackingLocation
	then
		self.createEventLocationActivity( self.myTrackedItem, _tiTransCntrl );
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_BBDiscrepancyController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
