<Class name="BGP_AutoUserDisableRequest" id="0ed5c18f-d458-43ec-a949-d7bbde12fa8c">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Auto Disable Users&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="6fe5aac3-fc99-4769-a1fa-ff909f61fec9">
        <updating/>
        <source>action(): Boolean updating;

// Created by cnwdvb1 on 21 November 2006

vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	
	self.processAutoDisableUser();

epilog

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		//app.getErrorString('Successfully Auto Disabled Users')
		app.createActivityHistory(ActivityHistoryGeneral, null, null, 'Successfully Auto Disabled Users', false, false);
	endif;
	inheritMethod();
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="7087a8e2-980c-4576-80f3-f30460ab0a8e">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTask) updating;

// Created by cnwdvb1 on 21 November 2006

vars

begin
	inheritMethod(_task);

end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="processAutoDisableUser" id="c874b94f-c16d-479c-bc18-416f3020acb2">
        <source>processAutoDisableUser() protected;

// Created by cnwdvb1 on 21 November 2006

vars
	
begin

	app.myTrxUA.trxAutoDisabilityUserNotify(app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		app.remoteErrorWarningToAlert('Auto Disabling Users - could not send email', null,  app.myPassport.allErrors, null, false, true);
	endif;
	  
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
