    <JadeMethod name="doResize" id="04e0fc74-e2b5-4d86-a3b4-eb8a2704f83a">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpPos	: Integer;
	
begin

	lblInstns.left 	:= WinLeftMargin;
	lblInstns.top	:= WinTopMargin;
	lblInstns.width	:= self.width - WinLeftMargin - WinRightMargin;

	
	// set the top position for all buttons at the bottom of the window
	tmpPos := (self.height - WinBottomMargin - btnSave.height).Integer;

	btnCancel.top 	:= tmpPos;
	
	if btnSave.visible then
		btnSave.top		:= tmpPos;
		
		btnCancel.left 	:= self.width - WinRightMargin - btnCancel.width;
		btnSave.left	:= btnCancel.left - HorizontalSpacing - btnSave.width;
	else
		btnCancel.caption := 'OK';
		btnCancel.left 	:= self.width - WinRightMargin - btnSave.width;
	endif;
	
	// Finally fit the table into the space left in the middle.
	tblWarnings.left  := lblInstns.left;
	tblWarnings.width := lblInstns.width;
	
	tblWarnings.top := lblInstns.top + lblInstns.height + VerticalSpacing;
	tblWarnings.height := btnCancel.top - VerticalSpacing - tblWarnings.top;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="dec6ac95-f4a1-40da-92bb-9f3780adf04f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.doSave := false;
	self.tblWarnings.optimiseRowHeight := true;
	self.tblWarnings.displayCollection(app.myPassport.allErrorWarnings, false, 0, null);
	self.btnSave.default := true;
	self.tblWarnings.cnEcResizeContents();
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tblWarnings_displayRow" id="69c849fa-03b2-4685-811e-a23ce874eef9">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWarnings_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err			: CM_Error;
	outStr		: String;
	cellHeight	: Integer;

begin

	err := obj.CM_Error;

	table.CM_BaseTable.fitTextToCell(err.text, outStr, table.width.Integer, cellHeight);
	
	return outStr;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="01695858-c424-46c4-a236-5e80856fcfa7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008386, locale);
	btnCancel.translateBubbleHelp(Xlat_0001245, locale);
	btnCancel.translateCaption(Xlat_0001247, locale);
	btnSave.translateBubbleHelp(Xlat_0001246, locale);
	btnSave.translateCaption(Xlat_0001248, locale);
	lblInstns.translateCaption(Xlat_0001249, locale);
end;</source>
    </JadeMethod>
