    <JadeMethod name="roundOnDisplay" id="cbf7daa3-f26c-4efc-8ba8-9ffe74746776">
        <source>roundOnDisplay( _value : Decimal):Decimal;
/*

Purpose:			
		No Rounding Should be done while calculating
Parameters:			

Return Value:		

Date		Who		Reason
17 October 2019	jlgma1	Initial creation

*/

vars
	rounded : Decimal[23,2];
begin
	rounded := _value.roundedTo(2);
	
	return  rounded;
epilog

end;</source>
