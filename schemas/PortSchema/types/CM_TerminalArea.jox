    <JadeMethod name="validateForDelete" id="f0b10276-5cc8-4c55-9b4c-45e929123bc5">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/04/2001   cnwdw1	    Removed check for Location Restrictions as they are now redundant,
//							and will only be opresent for really old terminals areas
// ---------------------------------------------------------------------------
vars

	lc	:	CM_LocationsController;
	tav : CM_TerminalAreaViewPosition;
	termViews : CM_TerminalAreaViewDict;
	termView : CM_TerminalAreaView;
	termViewStrs : String;
	termViewCount : Integer;
	
begin
	
	if self.allTerminalAreaViewPositions.size() &gt; 0 then
		//21 Mar 2012	NDL	Par 29313
		create termViews transient;
		foreach tav in self.allTerminalAreaViewPositions do
			termView := tav.myTerminalAreaView;
			if termView &lt;&gt; null and not termViews.includes(termView) then
				termViews.add(termView);
			endif;
		endforeach;
		foreach termView in termViews do
			if termViewStrs = null then
				termViewStrs := "'" &amp; termView.getDisplayDetails(false) &amp; "'";
			else
				termViewStrs := termViewStrs &amp; ", '" &amp; termView.getDisplayDetails(false)&amp; "'";
			endif;
			termViewCount := termViewCount + 1;
			if termViewCount = 5 and termViews.size &gt; termViewCount then
				termViewStrs := termViewStrs &amp; " ....";
				break;
			endif;
		endforeach;
		app.raiseCMException2(ERR_RemoveFromSatViewDefFirst, self.id, termViewStrs, null, null);
	endif;

	foreach lc in self.allLocationsControllers do
		if lc.hasTIs then
			app.raiseCMException2(ERR_LC_HAS_TIS,lc.getFullId, null, null, null); // PAR 20584 AKB2009SEP
			break;
		endif;
	endforeach;

	if (not self.allRestrictionsLabour.isEmpty) then
		app.raiseCMException1(ERR_HAS_RESTRICTIONS, "Terminal Area " &amp; self.id, null, null);
	endif;

	if self.swapStack &lt;&gt; null then
		swapStack.validateForDelete();
 	endif;
	
	//29 Nov 2011	NDL	Par 28727
	if self.myTerminal.allRTQueueMultiRuleTAMasters.includesRulesFor( self ) then
		app.raiseCMException1(Has_Machine_Rules, "Terminal Area " &amp; self.id, null, null);
	endif;
	
	self.checkRTQueueTaskUsage();
	
epilog

	delete termViews;
	
end;</source>
    </JadeMethod>
