    </JadeMethod>
    <JadeMethod name="getPickupTaskForCrane" id="7e27a8cf-8d3d-451d-9fb5-6d527034b2d7">
        <source>getPickupTaskForCrane(_oid: Object) : SIM_Task;
vars
	task: SIM_Task;
begin
	task := self.getTasks(_oid);

	if task.isPrevTaskACrane then
		return task.getPrev.getPrev;
	endif;
	
	if task.isNextTaskACrane then
		return task.getNext;
	endif;
	
epilog

end;</source>
        <Parameter name="_oid" type="Object"/>
        <ReturnType type="SIM_Task"/>
    </JadeMethod>
    <JadeMethod name="getTaskCount" id="9d31d0a8-5bd9-44e6-a4bd-af727f0f23be">
        <source>getTaskCount() : Integer;

vars
	count: Integer;
	task: Object;
begin
	foreach task in allTasks do
		if not task.SIM_Task.isCompleted then
			count := count + 1;
		endif;
	endforeach;
	
	return count;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTaskForMachine" id="12ad08a0-3db6-4ffd-9f64-c3ed6e04fbc2">
        <source>getTaskForMachine(_oid: Object) : SIM_Task;
vars
begin
	return self.getTasks(_oid);
epilog

end;</source>
