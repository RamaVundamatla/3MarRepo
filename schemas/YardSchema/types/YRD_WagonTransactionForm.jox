    <JadeMethod name="translateForm" id="b38b1b73-c5de-4e48-98e5-290b08b50409">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011265, locale);
	btnInvoiceLine.translateBubbleHelp(Xlat_0013854, locale);
	btnInvoiceLine.translateCaption(Xlat_0013855, locale);
	btnRefresh.translateBubbleHelp(Xlat_0011266, locale);
	btnRefresh.translateCaption(Xlat_0011267, locale);
	shtCharges.translateCaption(Xlat_0011268, locale);
	shtTrans.translateCaption(Xlat_0011269, locale);
end;</source>
    </JadeMethod>
</GUIClass>
