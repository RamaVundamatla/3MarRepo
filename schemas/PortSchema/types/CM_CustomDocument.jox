    <JadeMethod name="reverseStops" id="d7c4a4a6-e3fc-4aa5-9177-e4408d22d386">
        <updating/>
        <source>reverseStops() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 

12/02/2023	navkc1 Bug 62402: FR - 53715 - Customs status update on cancellation of first document.
*/


vars
	allPersistenTI,
	allTIs : CM_TISet;
	stop : CM_StopsTable;
	docType, cdtti : CM_CustomDocumentType;
	ti, cgti, proxyTI : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	stopsToReverse : CM_StopsTableSet;
	cd, cdti : CM_CustomDocument;
	cdd : CM_CustomDocumentDetail;

begin
	create allTIs transient; // do here so epilog is OK
	create allPersistenTI transient;	//12/02/2023	navkc1 Bug 62402
	
	cd := self;
	docType:= self.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	if docType.allStopsToApply.isEmpty
	and docType.allStopsToClear.isEmpty then
		return;
	endif;
	
	// ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
	create stopsToReverse transient;
	
	// All TIs are linked to the custom document, whether they have a custom document detail or not. 
	// So a cargo group will have a custom document detail, but its TI may not, but the cargo groups TIs are linked to the custom document.
	foreach ti in self.allTrackedItems discreteLock do
		if ti.isZombie() then
			continue;
		endif;
		if ti.isCargoGroupItem then
			continue;
		else
			proxyTI	:= app.createUpdateProxy( ti ).CM_TrackedItem;
			allTIs.add(proxyTI);
			allPersistenTI.add(ti);	//12/02/2023	navkc1 Bug 62402
		endif;

		// ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
		if cd.isOutward() then
			foreach cdd in ti.allCustomDocDetails discreteLock do
				cdti := cdd.getCustomDocumentHeader();
				// ### TFS BUG 61435 23NOV2023 NAVAB1
				if cdti.isCancelled() then
					continue;
				endif;
				
				if cdti.isInward() then
					cdtti := cdti.myCustomDocumentType;
					foreach stop in cdtti.allStopsToApply discreteLock do
						if docType.allStopsToClear.includes(stop) then
							stopsToReverse.addNoDuplicates(stop,false);
						endif;
					endforeach;
				endif;
			endforeach;
		
		endif;
		
	endforeach;

	// ### Apply proxy stops to the proxy TIs
	self.applyStops(allTIs,stopsToReverse); // ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
	// ### Cancel proxy stops for the proxy TIs
	self.cancelStops(allTIs, docType.allStopsToApply); 
	
	// ### Update the stops on the TIs
	foreach ti in allTIs do
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport); 
		if (not app.myPassport.noErrors) then
			break;
		endif;
	endforeach;
	
	//12/02/2023	navkc1 Bug 62402 - Want to apply stop based on the stop criteria in case user remove/cancel a custom document
	if app.myPassport.noErrors() then
		foreach ti in allPersistenTI do
			if ti.getImExStatus() = TI_IMEX_STATUS_TRANSHIP then
				ti.setStopsForTranship();
				elseif ti.isExport then
				ti.setStopsForExport();
				elseif ti.isImport then
				ti.setStopsForImport();
			endif;
		endforeach;
	endif;
	
epilog
	delete stopsToReverse;
	allTIs.purge();
	delete allTIs;
	delete allPersistenTI;	//12/02/2023	navkc1 Bug 62402
end;</source>
    </JadeMethod>
