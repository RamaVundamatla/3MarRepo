    <JadeMethod name="lstHazards_hasGotFocus" id="63abafbd-6963-4b2c-9253-ad3b35c0c01f">
        <controlMethod name="CMUI_FieldFrame::hasGotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstHazards_hasGotFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars
	space : Integer;
begin
	// make list box bigger, and place it over the textbox
	//+cnwml2 PAR23938
	space := self.clientHeight.Integer - self.lstHazards.top.Integer;
	if space &lt; 125 then
		self.lstHazardList.move(self.txtHazards.getFormLeft, self.txtHazards.getFormTop, 300, space);
	else
		self.lstHazardList.move(self.txtHazards.getFormLeft, self.txtHazards.getFormTop, 300, 125);
	endif;
	self.lstHazardList.adjustColumns();
	self.lstHazardList.visible := true;
	self.lstHazardList.parent := self;
	self.txtHazards.visible := false;
	self.lstHazardList.setFocus;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
