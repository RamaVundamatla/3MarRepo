    <JadeMethod name="cnEcPropertyDeletedException" id="d699203f-306d-4026-bb25-1df17d648cc0">
        <source>cnEcPropertyDeletedException(pException: Exception): Integer;

constants
	PROPERTY_NOT_DEFINED	: Integer = 1011;
	
vars
	deadFormatproperty		: Object;	
	
begin
	if pException.errorCode = PROPERTY_NOT_DEFINED then
		//app.msgBox ("The requested property is not defined for this object class", "Error", 0);	
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;      		// default dialog
	endif;
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlOutput" id="f88adfde-aeba-46bf-b170-81c2362e6d2d">
        <source>cnEcXmlOutput(	pObject:Object;
				pIsDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io) : String;

vars
	prop		: CnEcXmlFormatProperty;
	theProperty	: Property;
	xmlString	: String;
	
begin

	if not self.isShowTagData then
		return null;
	endif;

	on Exception do cnEcPropertyDeletedException(exception);

	foreach prop in self.allProperties do
		if app.name = "XMLUtility" then  // we are doing a 'Sample' or a 'Format Extract' from BaseSchema.
		
			if pObject.isKindOf(CnEcXML) then  // extracting a Format
				xmlString := xmlString &amp; prop.cnEcXmlFormatOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
			else	// we are 'Sample'ing
				theProperty := pObject.class().getProperty(prop.propertyName);
				if theProperty = null then // i.e 'oid','edition',' a literal, or other special...
					xmlString := xmlString &amp; prop.cnEcXmlOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
				else 
					if theProperty.virtual then
						xmlString := xmlString &amp; cnEcXmlTagIt(prop.propertyName, "Mapping Method, references not available to the Peer Schema.", pIsDebug);	
					else
						xmlString := xmlString &amp; prop.cnEcXmlOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
					endif;
				endif;
			endif;
					
		else
			 // we should be working from Users Schema.
    		xmlString := xmlString &amp; prop.cnEcXmlOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
    		
    	endif;
	endforeach;

	if not self.isSuppressTag then
		xmlString := cnEcXmlTagIt(self.tagName, xmlString, pIsDebug);	
	endif;

	return xmlString;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copy" id="3e2e1510-d7b7-4184-b787-fde054418854">
        <updating/>
        <source>copy(pCopyFromFormatClass : CnEcXmlFormatClass; pNewFormat : CnEcXmlFormat) updating;

vars
	propertyFormat : CnEcXmlFormatProperty;
	
begin
	initializeMe(	pCopyFromFormatClass.className,
					pCopyFromFormatClass.tagName,
					pCopyFromFormatClass.isShowTagData,
					pCopyFromFormatClass.isSuppressTag,
					pCopyFromFormatClass.noidPropertyName,
					pCopyFromFormatClass.epilogMethodName,
					pNewFormat);

	foreach propertyFormat in pCopyFromFormatClass.allProperties do
		//self.allMyProperties.add(propertyFormat.createNewCopy(self));
		propertyFormat.createNewCopy(self); //NDL otherwise ir adds in twice...	
	endforeach;	
end;</source>
        <Parameter name="pCopyFromFormatClass" type="CnEcXmlFormatClass"/>
        <Parameter name="pNewFormat" type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="getFormatProperty" id="1bf345df-36aa-4e12-8360-9e8d8f1a3e4d">
        <source>getFormatProperty(pPropertyName : String): CnEcXmlFormatProperty;

vars
	formatProperty	: CnEcXmlFormatProperty;
	
begin
	foreach formatProperty in self.allProperties do
		if formatProperty.propertyName = pPropertyName then
			return formatProperty;
		endif;
	endforeach;
	
	return null; 
end;</source>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="CnEcXmlFormatProperty"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="fc86629b-8ae1-4755-9e87-dde6fe6d4a79">
        <updating/>
        <source>initializeMe(	pClass:String;
				pTagName : String;
				pIsShowTagData:Boolean;
				pIsSuppressTag : Boolean;
				pNoidPropertyName : String;
				pEpilogMethodName : String;
				pFormat : CnEcXmlFormat) updating;

begin
	self.className 			:= pClass;
	self.tagName 			:= pTagName;
	self.noidPropertyName 	:= pNoidPropertyName;
	self.epilogMethodName	:= pEpilogMethodName;

	self.isShowTagData		:= pIsShowTagData;
	self.isSuppressTag		:= pIsSuppressTag;

	self.myFormat			:= pFormat;
end;</source>
        <Parameter name="pClass" type="String"/>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pIsShowTagData" type="Boolean"/>
        <Parameter name="pIsSuppressTag" type="Boolean"/>
        <Parameter name="pNoidPropertyName" type="String"/>
        <Parameter name="pEpilogMethodName" type="String"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ce909a81-2e5b-4a9a-a751-a1032d89eeee">
        <updating/>
        <source>updateMe(	pTagName : String;
			pIsShowTag:Boolean;
			pIsSuppressTag : Boolean;
			pNoidPropertyName : String;
			pEpilogMethodName : String) updating;

begin
	if self.tagName	&lt;&gt; pTagName then
		self.tagName	:= pTagName;
	endif;
	
	if self.noidPropertyName &lt;&gt; pNoidPropertyName then
		self.noidPropertyName 	:= pNoidPropertyName;
	endif;
	
	if self.epilogMethodName	&lt;&gt; pEpilogMethodName then
		self.epilogMethodName	:= pEpilogMethodName;
	endif;		
	
	if self.isShowTagData	&lt;&gt; pIsShowTag then
		self.isShowTagData	:= pIsShowTag;
	endif;
	
	if self.isSuppressTag	&lt;&gt; pIsSuppressTag then
		self.isSuppressTag	:= pIsSuppressTag;
	endif;
end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pIsShowTag" type="Boolean"/>
        <Parameter name="pIsSuppressTag" type="Boolean"/>
        <Parameter name="pNoidPropertyName" type="String"/>
        <Parameter name="pEpilogMethodName" type="String"/>
    </JadeMethod>
</Class>
