    <JadeMethod name="assignValueSpecial" id="00fa005a-b78d-4855-9084-d1bd1b86adf9">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	if _propName = ETRow_DriverExtId then
		self.driverExternalId := _processedValue;
		return true;
		
	elseif _propName = ETRow_ExternalReference then
		self.externalReference := _processedValue.toUpper();
		return true;
		
	elseif _propName = ETRow_RegNumber then
		self.vehicleRegNumber := _processedValue;
		return true;
		
	endif;

	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxy" id="740b6450-f56b-4cd7-9f7e-bfa8b54c8945">
        <source>createProxy() : CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars
	proxy 		: CM_VehicleBookingTimeSlot;
	real 		: CM_VehicleBookingTimeSlot; 
	terminal 	: CM_VehicleBookingTerminal;
	slotType 	: CM_VehicleBookingTimeSlotType;
	startTS 	: TimeStamp;
	endTS		: TimeStamp;
	inCheck		: Boolean;
	outCheck 	: Boolean;
	kCheck 		: Boolean;
	carrier		: CM_Carrier;
	driver		: CM_DriverDetails;
	vehicle		: CM_Vehicle;
	
begin
	terminal := self.getVBTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, app.getErrorString(Terminal), ETRow_Terminal, null);
		return null;
	endif;
	
	slotType := self.getSlotType();
	if slotType = null then
		return null;
	endif;

	startTS := self.startDate.asTimeStamp;					//14.07.2023 navma1 #59136
	startTS.setTime(slotType.startTime);
	
	/*
	//14.07.2023 navma1 #59136
	if startTS &lt; now then
		startTS := startTS.addDays(1);
	endif;
	*/
	endTS := startTS.addMinutes(slotType.duration);
	
	inCheck  := self.preGateInCheck;
	outCheck := self.preGateOutCheck;
	kCheck   := self.kioskCheck;
	
	if slotType.preGateInCheck then
		inCheck := true;
	endif;
	if slotType.preGateOutCheck then
		outCheck := true;
	endif;
	if slotType.kioskCheck then
		kCheck := true;
	endif;
	
	carrier := self.getCarrier();
	driver  := self.getDriver();
	
	if driver &lt;&gt; null then
		vehicle := self.getVehicle();
		
		if not driver.allVehicleMachines.includes(vehicle) then
			vehicle := null;
		endif;
		if not driver.allCarriers.includes(carrier) then
			driver := null;
		endif;
	endif;
	
	if self.id &lt;&gt; null then
		real := terminal.allVBTimeslotsById[self.id.toUpper()];
	else
		real := terminal.allVBTimeslotsByExtRef[self.externalReference.toUpper()];
	endif;
	
	if real = null then
		create proxy transient;
		
		proxy.setProxy(	startTS,
					endTS,
					terminal,
					carrier,
					self.getSubCarrier,
					driver,
					vehicle,
					self.remarks,
					false,
					false,
					null,
					null,
					slotType,
					self.id.toUpper(),
					null,
					null,
					null,
					inCheck,
					outCheck,
					kCheck,
					self.externalReference.toUpper(),
					null);								// 08 Aug 2024 navcs2	ChangeRequest 63928						
	else
		proxy := real.pxyCreateUpdateProxy();
		
		proxy.setProxy(	startTS,
					endTS,
					terminal,
					carrier,
					self.getSubCarrier,
					driver,
					vehicle,
					self.remarks,
					real.includesDelivery,
					real.includesPickUp,
					null,
					real.myVehicleVisitRecord,
					slotType,
					real.id,
					null,
					null,
					null,
					inCheck,
					outCheck,
					kCheck,
					self.externalReference.toUpper(),
					null);											// 08 Aug 2024 navcs2	ChangeRequest 63928 
				
	endif;
	
	proxy.setCreationMethod(CM_VehicleBookingTimeSlot.Creation_Method_EDI);

	return proxy;
	
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="findRealVehicleBooking" id="91e55467-b611-47ca-af39-17a03ceaebb1">
        <source>findRealVehicleBooking() : CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal : CM_VehicleBookingTerminal;
	
begin
	terminal := self.getVBTerminal;
	if terminal = null then
		return null;
	endif;
	
	if self.id = null then
		return terminal.allVBTimeslotsByExtRef[self.externalReference.toUpper()];
	else
		return terminal.allVBTimeslotsById[self.id.toUpper()];
	endif;
	
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="d3602cd6-ccd7-4d3a-af62-d409bd5e5418">
        <source>getCarrier() : CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	carrier : CM_Carrier;
	
begin
	
	if self.carrierCode &lt;&gt; null then									//11.08.2023 navma1 #59793
		carrier := app.myRoot.allCarriers[self.carrierCode.toUpper];		
	endif;
	
	if carrier = null then
		return null;
	endif;
	
	if not carrier.isRoad then
		return null;
	endif;
	
	if carrier.isNotAvailableForEntry then
		return null;
	endif;
	
	return carrier;
	
epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="180fae67-aa1e-4801-9214-377e4b859d6a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	if _attrName = ETRow_DriverExtId then
		return self.driverExternalId;
		
	elseif _attrName = ETRow_RegNumber then
		return self.vehicleRegNumber;
		
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriver" id="64584ae1-bdb3-44d4-9346-6886c176f290">
        <source>getDriver() : CM_DriverDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	driver : CM_DriverDetails;
	terminal : CM_Terminal;
	
begin
	if self.driverCode = null and self.driverExternalId = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;

	if self.driverCode &lt;&gt; null then
		driver := terminal.allDriversByCode[self.driverCode];
	elseif self.driverExternalId &lt;&gt; null then
		driver := terminal.allDriversByExternalID[self.driverExternalId];
	endif;

	return driver;

epilog

end;</source>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
