    <JadeMethod name="changeVehicleForVisit" id="7d2b965e-2043-469f-9ecb-cb90ddebfa6a">
        <updating/>
        <source>changeVehicleForVisit(_newVehicle : CM_Vehicle input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Feb 2010	consw1	PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit

*/

vars
	roadjob : CM_RoadJob;
begin
	self.visitRecords.last.changeVehicle(_newVehicle, _passport);

	// Place the new vehicle in the old vehicle's location
	_newVehicle.setMyPrimaryActualLocation( self.getMyPrimaryActualLocation(),true );	//21 Nov 2017	NDL	TFS 7460
	_newVehicle.setMyInTerminalJobSheet(self.myInTerminalJobSheet);
	
	//epr TFS 2685 21/9/16
	roadjob := self.getCurrentRoadJob;
	
	if roadjob &lt;&gt; null then
		roadjob.changeVehicle(_newVehicle, _passport);
	endif;
	// Clear the location setting for the old vehicle location
	self.setMyPrimaryActualLocation(null,true);
	
epilog

end;</source>
        <Parameter name="_newVehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="containsLogDocket" id="a37b23f6-6a78-407b-b0a0-1efe178e891e">
        <source>containsLogDocket() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2015	cnwmc5	Initial creation	PAR 35528

*/

vars
	job	: CM_Job;
begin
	foreach job in self.allRoadJobs do
		if job.containsLogDocket() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createVisitRecord" id="da2ce8aa-45bc-4e20-b841-e14c6e0fae82">
        <updating/>
        <source>createVisitRecord(_cmifBulkRelease : CMIF_BulkRelease; _releasedTISet : CM_TISet; _receivedTISet : CM_TISet) updating;
//------------------------------------------------
// Created: 07 April 2006 By: cnwgd1
//------------------------------------------------
constants
	MAX_DWELL = 2;
vars
    visitRecord 		: CM_VehicleVisitRecord;
    inwardsTIs, 
    outwardTIs, 
    numDays, 
    isPos 				: Integer;
    totalTime 			: Integer;
    timeIn,
    timeOut				: TimeStamp;
	gate, 
	driver, 
	pass, 
	workNum, 
	clerkCode,
	loaderCode			: String;
begin

	if _cmifBulkRelease = null then
		return;
	endif;
	
	//th2 23/01/07 deadlock on CM_Terminal::allVehicleVisitRecords
	exclusiveLock(app.myPassport.myTerminal.allVehicleVisits);
		
	create visitRecord persistent;
	timeIn := _cmifBulkRelease.dateTimeIn;
	timeOut := _cmifBulkRelease.dateTimeOut;
	
	if (not timeIn.isValid()) then
		// belts and braces
		timeIn := app.serverTimestampAtTrxStart;
	endif;
	if (not timeOut.isValid()) then
		// belts and braces
		timeOut := app.serverTimestampAtTrxStart;
	endif;	
	
	if timeOut &gt; timeIn then
		totalTime :=  timeOut.getDifferenceInMinutes(timeIn);		// PAR 16390
	endif;
	
	outwardTIs := _cmifBulkRelease.getTotalRequested();
	
	if self.carrier &lt;&gt; _cmifBulkRelease.myCarrier then
		self.carrier := _cmifBulkRelease.myCarrier;
	endif;
	
	// set from the reserve detail
	gate := _cmifBulkRelease.gate;
	driver := _cmifBulkRelease.userPickedUp;
	pass := _cmifBulkRelease.releaseNo;
	workNum := _cmifBulkRelease.deliveryReleaseNumber;
	if _cmifBulkRelease.myUser &lt;&gt; null then
		clerkCode := _cmifBulkRelease.myUser.code;
	endif;
	
	if _cmifBulkRelease.myLoadingCompany &lt;&gt; null then
		loaderCode := _cmifBulkRelease.myLoadingCompany.code;
	endif;

	visitRecord.setForCreate(totalTime, inwardsTIs, outwardTIs,
							 timeIn, timeOut, null, self,
							 self.carrierCode, gate, driver, pass,
							 workNum, clerkCode, loaderCode, null, _cmifBulkRelease.remarks, _releasedTISet, _receivedTISet, self.myTerminal);
	

end;





</source>
        <Parameter name="_cmifBulkRelease" type="CMIF_BulkRelease"/>
        <Parameter name="_releasedTISet" type="CM_TISet"/>
        <Parameter name="_receivedTISet" type="CM_TISet"/>
    </JadeMethod>
