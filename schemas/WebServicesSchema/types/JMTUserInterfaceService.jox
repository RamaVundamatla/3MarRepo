    <JadeWebServicesMethod name="getICAreasForDischarge" id="8a6971ba-e64d-413c-bf8d-02a72c52dc57">
        <source>getICAreasForDischarge(voyageOid : String)  : WS_TerminalAreaMasterResponse webService;
/*

Date		Who		Reason
08 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	response	: WS_TerminalAreaMasterResponse;
	completedOK : Boolean;
	voyage  : CM_Voyage;
	objSet : CM_ObjectSetActual;
	obj : CM_Object;
	craneTA : CM_CraneTransferArea;
	interChangeArea : CM_InterchangeArea;
	workPoint : CM_WorkPoint;
	crane : CM_Crane;
	wsTerminalArea : WS_TerminalAreaMaster;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	//epr TFS 5535 4/8/17 
	voyage :=  app.myPassport.getObjectOfTypeFromOid(voyageOid,CM_Voyage).CM_Voyage;
	if voyage = null then		
		completedOK := true;
		return response;
	endif;
	
	create objSet transient;
	voyage.findAllMyCranesAndWorkpoints( objSet );
	
	foreach obj in objSet discreteLock do
		if obj.isKindOf( CM_Crane ) then
			crane := obj.CM_Crane;
			craneTA := crane.transferArea;
			if craneTA &lt;&gt; null then
					create wsTerminalArea transient;
					wsTerminalArea.setProxyFromObject(craneTA);
					response.allTAMasters.add(wsTerminalArea);		
					if craneTA.myDefaultInterchangeArea &lt;&gt; null then
						create wsTerminalArea transient;
						wsTerminalArea.setProxyFromObject(craneTA.myDefaultInterchangeArea);
						response.allTAMasters.add(wsTerminalArea);
					endif;
			endif;
		elseif obj.isKindOf( CM_WorkPoint ) then
			workPoint := obj.CM_WorkPoint;
			if workPoint.myWorkPointInterchangeArea &lt;&gt; null then
				create wsTerminalArea transient;
				wsTerminalArea.setProxyFromObject(workPoint.myWorkPointInterchangeArea);
				response.allTAMasters.add(wsTerminalArea);
			endif;
		endif;
			
			
	endforeach;
	
	completedOK := true;
	return response;	
	
	
epilog
	delete objSet; //epr TFS 7521 10/11/17
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="voyageOid" type="String"/>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeWebServicesMethod>
