    <JadeMethod name="trxUpdateResourceTypeUsageSet" id="8463e2e7-c908-4c59-aa2b-8029f25dae80">
        <updating/>
        <source>trxUpdateResourceTypeUsageSet(	_transaction : CM_TITransaction io;
								_originalEdition : Integer input;
								_newProxyResourceTypeUsages : CM_ResourceTypeUsageSet input;
								_updProxyResourceTypeUsages : CM_ResourceTypeUsageSet input;
								_delRealResourceTypeUsages : CM_ResourceTypeUsageSet input;
								_passport : CM_Passport input
								) updating;
/*
Purpose:			Called to handle creates, updates and deletes all in one transaction state

Parameters:			Set of proxies for updating
					Set of proxies for creating
					Set of reals for deleting

Return Value:		

Date			Who		Reason
06 January 2010	conkc1	Initial creation
30 Aug 2012		cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
13 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/
vars
	proxyResourceTypeUsage : CM_ResourceTypeUsage;
	realResourceTypeUsage  : CM_ResourceTypeUsage;
	newResourceTypeUsage   : CM_ResourceTypeUsage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	exclusiveLock(_transaction);

	if _transaction.edition &lt;&gt; _originalEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Transaction', null, null);
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_transaction, true);
	endif;
	//
	// Do Creates first
	//
	foreach proxyResourceTypeUsage in _newProxyResourceTypeUsages do
		app.myUtilityCA.utlCreateResourceTypeUsage(proxyResourceTypeUsage, null, newResourceTypeUsage, _passport);				//13.12.2023 navlc30 #60748
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	//
	// Do Updates
	//
	foreach proxyResourceTypeUsage in _updProxyResourceTypeUsages do
		app.myUtilityUA.utlUpdateResourceTypeUsage(proxyResourceTypeUsage, false, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	//
	// Lastly do Deletes
	//
	foreach realResourceTypeUsage in _delRealResourceTypeUsages do
		app.myUtilityDA.utlDeleteResourceTypeUsage(realResourceTypeUsage, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_transaction, false);
	endif;

	self.updateObjectEdition (_transaction);	// par 30292

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction" usage="io"/>
        <Parameter name="_originalEdition" type="Integer" usage="input"/>
        <Parameter name="_newProxyResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_updProxyResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_delRealResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateResourceUsageToDo" id="128d3596-cbfa-4423-b1fb-8e27ca71f3a2">
        <updating/>
        <source>trxUpdateResourceUsageToDo(	_transaction            	: CM_Transaction io;
								    _originalEdition            : Integer input;
									_newProxyResourceTypeUsages : CM_ResourceTypeUsageSet input;
									_updProxyResourceTypeUsages : CM_ResourceTypeUsageSet input;
									_delRealResourceTypeUsages  : CM_ResourceTypeUsageSet input;
									_passport 					: CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2022	navcs2  ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
13 Dec 2023 		navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/

vars
	proxyResourceTypeUsage : CM_ResourceTypeUsage;
	realResourceTypeUsage  : CM_ResourceTypeUsage;
	newResourceTypeUsage   : CM_ResourceTypeUsage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	exclusiveLock(_transaction);

	if _transaction.edition &lt;&gt; _originalEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Transaction', null, null);
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_transaction, true);
	endif;
	//
	// Do Creates first
	//
	foreach proxyResourceTypeUsage in _newProxyResourceTypeUsages do
		app.myUtilityCA.utlCreateResourceTypeUsage(proxyResourceTypeUsage, null, newResourceTypeUsage, _passport);				//13.12.2023 navlc30 #60748
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	//
	// Do Updates
	//
	foreach proxyResourceTypeUsage in _updProxyResourceTypeUsages do
		app.myUtilityUA.utlUpdateResourceTypeUsage(proxyResourceTypeUsage, false, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	//
	// Lastly do Deletes
	//
	foreach realResourceTypeUsage in _delRealResourceTypeUsages do
		app.myUtilityDA.utlDeleteResourceTypeUsage(realResourceTypeUsage, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_transaction, false);
	endif;

	self.updateObjectEdition (_transaction);	// par 30292

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_transaction" type="CM_Transaction" usage="io"/>
        <Parameter name="_originalEdition" type="Integer" usage="input"/>
        <Parameter name="_newProxyResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_updProxyResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_delRealResourceTypeUsages" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRestrictionLabour" id="f0f7c228-b115-418d-a51b-17d6dd0b5a3e">
        <updating/>
        <source>trxUpdateRestrictionLabour(pProxyRestriction : CM_LabourRestriction input; 
						pRealRestriction : CM_LabourRestriction input;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/02/2011	cnwcs5		CCMS CPL 2027/par 27126 - audit location changes
//													- replace existing TA audit with TA Location audit
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
vars
	aTA 				: CM_TerminalArea;
	queueEntrySet_before,
	queueEntrySet_after	: CM_RTQueueEntrySet;
	cTA 				: CM_TerminalArea;
	cQueueEntrySet_before,
	cQueueEntrySet_after	: CM_RTQueueEntrySet;
	childRestriction : CM_LabourRestriction;
	queueEntry	: CM_RTQueueEntry;
	childrenToDelete : CM_LabourRestrictionSet;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	pProxyRestriction.raiseExceptionIfNotProxy(method); 

	if pRealRestriction = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LabourRestriction.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	beginLoad;
	app.myValUA.valRestrictionLabour(pProxyRestriction);
	endLoad;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create queueEntrySet_before transient;
	create queueEntrySet_after transient;
	create cQueueEntrySet_before transient;
	create cQueueEntrySet_after transient;
	
	exclusiveLock(pRealRestriction);
	
	pRealRestriction.getQueueEntries( queueEntrySet_before );
	//23 Apr 2014	NDL	Par 33995
	if not pRealRestriction.allChildLabourRestrictions.isEmpty then
		foreach childRestriction in pRealRestriction.allChildLabourRestrictions do
			cQueueEntrySet_before.clear();
			childRestriction.getQueueEntries( cQueueEntrySet_before );
			foreach queueEntry in cQueueEntrySet_before do
				queueEntrySet_before.addNoDuplicates( queueEntry, false );
			endforeach;
		endforeach;
	endif;
	
	beginTransaction;

	aTA := pRealRestriction.myTerminalArea;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(pRealRestriction, true);	// cnwdad1 06/08/2008 - PAR #17673 - reinstated.
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of ta with an audit that includes the changes to locations as well
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(aTA, true, null,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, AuditUpdated, null);		
	endif;
	
	if _passport.noErrors then
		pRealRestriction.setForUpdate(pProxyRestriction);
		 pRealRestriction.getQueueEntries(queueEntrySet_after);
		 
			//23 Apr 2014	NDL	Par 33995
			if not pRealRestriction.allChildLabourRestrictions.isEmpty then
				foreach childRestriction in pRealRestriction.allChildLabourRestrictions do
					cQueueEntrySet_after.clear();
					childRestriction.getQueueEntries( cQueueEntrySet_after );
					foreach queueEntry in cQueueEntrySet_after do
						queueEntrySet_after.addNoDuplicates( queueEntry, false );
					endforeach;
				endforeach;
			endif;
	
		 pRealRestriction.setQueueTasksStatus( queueEntrySet_before, queueEntrySet_after );	// ccms1573	cnwvu1
	endif;

	if _passport.noErrors then
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA); //epr par 16956 11/6/08		
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Update),false,pRealRestriction); //epr par 16956 11/6/08
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(pRealRestriction, false);	// cnwdad1 06/08/2008 - PAR #17673.
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of TA with audit that includes locations changes
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (aTA, false, pRealRestriction.allLocationControllers,
																	CM_AuditTALocations.LocnTypeUpdate_LabRestrict, 
																	AuditUpdated, pRealRestriction.getAuditTALocationDetails);
		//23 Apr 2014	NDL	Par 33995
		if not pRealRestriction.allChildLabourRestrictions.isEmpty then
			foreach childRestriction in pRealRestriction.allChildLabourRestrictions where not childRestriction.allLocationControllers.isEmpty do
				cTA := childRestriction.myTerminalArea;
				app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (cTA, false, childRestriction.allLocationControllers,
																	CM_AuditTALocations.LocnTypeUpdate_LabRestrict, 
																	AuditUpdated, childRestriction.getAuditTALocationDetails);
			endforeach;
			
		endif;
	endif;
	
	//23 Apr 2014	NDL	Par 33995
	if _passport.noErrors then
		if not pRealRestriction.allChildLabourRestrictions.isEmpty then
			create childrenToDelete transient;
			foreach childRestriction in pRealRestriction.allChildLabourRestrictions where childRestriction.allLocationControllers.isEmpty do
				childrenToDelete.addNoDuplicates(childRestriction,false);
			endforeach;
			if not childrenToDelete.isEmpty then
				foreach childRestriction in childrenToDelete do
					if _passport.noErrors then
						break;
					endif;
					app.myUtilityDA.utlDeleteRestrictionLabour(childRestriction, true, _passport);
				endforeach;
			endif;
		endif;
	endif;
	
	//23 Apr 2014	NDL	Par 33995
	if _passport.noErrors then
		if not pRealRestriction.allChildLabourRestrictions.isEmpty then
			foreach childRestriction in pRealRestriction.allChildLabourRestrictions do
				cTA := childRestriction.myTerminalArea;
				cTA.causeEvent(cTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,cTA);
				cTA.causeEvent(cTA.myTerminal.getTerminalEvent(Event_TALocation_Update),false,childRestriction);
			endforeach;
		endif;
		//navsp1 03MAY2022 TFS#53369
		if app.myPassport.isOpsViewEnabled(aTA.myTerminal) then 
			aTA.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, aTA); 
		endif;
	endif;

epilog

	endLoad;				// 08/04/2011 cnwmh5 #27347

	delete queueEntrySet_before;
	delete queueEntrySet_after;
	delete cQueueEntrySet_before;
	delete cQueueEntrySet_after;
	delete childrenToDelete;
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction" usage="input"/>
        <Parameter name="pRealRestriction" type="CM_LabourRestriction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateReticketTI" id="db90eda2-aa2e-4bca-ba70-d277c9383cef">
        <updating/>
        <source>trxUpdateReticketTI(_reticketTISet	: CMIF_TIReticketSet;
					_errorReticketSet : CMIF_TIReticketSet input;
					_cargoType		: Integer;
					_taType			: Integer;
					_newLocation	: CM_LocationsController;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateReticketTI(_reticketTISet, 
										_errorReticketSet,
										_cargoType,
										_taType,
										_newLocation,
										_passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_reticketTISet" type="CMIF_TIReticketSet"/>
        <Parameter name="_errorReticketSet" type="CMIF_TIReticketSet" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateReturnCargoToYard" id="60bb42b4-1883-4ca1-9403-dc57ca3bd205">
        <updating/>
        <source>trxUpdateReturnCargoToYard(_jobParams : CMIF_VoyageJobParams input; _tiArray : CM_TIArray; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//------------------------------------------------
vars
	str : String;
	tmpTI : CM_TrackedItem;
	theNewVoyageJob : CM_VoyageJob;
	params : CMIF_AutoplanParams;
	anLC : CM_VoyageROROController;	// PAR 29306 cnwmc5
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// add validtion here
	self.raiseExceptionIfNull(_tiArray, '_tiArray');
	self.raiseExceptionIfNull(_jobParams, '_jobParams');	
	
	
	// PAR 30406 if we get a warning, like 'auto plan failed', these are full of invalid objects
	_jobParams.allRORORequests.clear();
	_jobParams.allSlotRequests.clear();
	
	
	
	app.setContinueCMExceptions(true);
	if _jobParams.craneID = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Crane', null, null);	
		app.raiseCMException(Input_required_field_crane, null, null);	 // cnwdb2	PAR 35364
	endif;	
	if _jobParams.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Job ID', null, null);	
		app.raiseCMException(Input_required_field_jobID, null, null);	
	endif;
	if _jobParams.isExportReturn then
		// make sure all cargo are exports
		str := null;
		foreach tmpTI in _tiArray do
			if (not tmpTI.isExport and not tmpTI.isTranshipItem) then  //cnwrd1 par 28989 16.2.2012
				str := str &amp; ' ' &amp; tmpTI.id;
			endif;
		endforeach;
		if str &lt;&gt; null then
//			app.raiseCMException3(ErrCargoImexJobTypeMisMatch, str, _jobParams.id, 'Export Returned. Items must be EXPORTS.', null, null);		
			app.raiseCMException2(Imex_statu_cargo_items_does_no, str, _jobParams.id,  null, null);		// PAR 29306
		endif;
	endif;
	
	if not _jobParams.allSlotControllers.isEmpty() then
		self.doValidateSlotRequestAttribute(_jobParams.allSlotControllers, null, false, null, _jobParams.allObjectEditions, null, _passport);
	
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
		
		beginTransaction;
		
		// Create discharge colour coding for the LOLO slots
		self.doUpdateSlotRequestAttribute(_jobParams.allSlotControllers, null, false, null, null, _passport);	
	//Added in 'elseif' statement by cnwmc5 - PAR 29306
	elseif not _jobParams.allROROControllers.isEmpty() then				
		beginTransaction;
		foreach anLC in _jobParams.allROROControllers discreteLock do
			// Create discharge colour coding for the RORO slots
			app.myUtilityCA.utlCreateROROSlotDischargeCC(anLC, _passport);
			
			if _passport.hasErrorsOrWarnings() then
				return;
			endif;
			app.myEventManager.createSingleObjInfoNoteEvt(
									anLC.myVoyage,
									anLC.myVoyage.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
									anLC);
		endforeach;
	else
		return;
	endif;

	if _passport.hasErrors() then
		return;
	endif;	
	
	// Create voyage job for crane
	app.myUtilityCA.utlCreateVoyageJob(_jobParams, theNewVoyageJob, _passport);
	if _passport.hasErrors() then
		return;
	endif;	
	
	// Par 12287
	// Auto-plan cargo into the yard
	if _jobParams.isAutoplan then
		// PAR 19450
		create params transient;
		_tiArray.copy(params.allTrackedItems);
		params.moveMode := PLANNING_MODE;
		params.myTerminalArea := null;
		params.myJob := theNewVoyageJob;
		params.showWarningWhenNoPlan := true;
	
//PAR 19450		app.myUtilityUA.utlUpdateAutoplanTrackedItems(_tiArray, PLANNING_MODE, theNewVoyageJob, null, _passport);
		app.myUtilityUA.utlUpdateAutoplanTrackedItems(params, _passport);
	endif;
	if _passport.hasErrors() then
		return;
	endif;	
	
epilog
	delete params;

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRevertDirectorTask" id="2208cfe2-ab84-4fc6-88dc-ac2391ff8fb7">
        <updating/>
        <source>trxUpdateRevertDirectorTask(_rtQueueEntry : CM_RTQueueEntry input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	// Perform the operation
	app.myUtilityUA.utlUpdateRevertDirectorTask(_rtQueueEntry);

	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRoRoLaneCargo" id="27d3ebc6-b193-404e-b9f2-a5c1a329c51b">
        <updating/>
        <source>trxUpdateRoRoLaneCargo(	_rc : CM_RoRoController input;
						_ic : CM_LocationsController input;
						_tis : CM_TIArray input;
						_passport : CM_Passport input
						)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	movingOut : CM_TISet;
	movingIn : CM_TISet; 
	
	ti : CM_TrackedItem;
	control : CMIF_MoveController;
	pos : Integer;
	requiresReOrder : Boolean;
	
	stowageConfirmController : CMIF_StowageConfirmController;
	newTITransaction:CM_TITransaction;
	now : TimeStamp;
	locString : String;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create movingOut transient;
	create movingIn transient;
	foreach ti in _rc.allTrackedItems discreteLock do
		if not _tis.includes( ti ) then
			movingOut.add( ti );
		endif;
	endforeach;
	foreach ti in _tis discreteLock do
		if not _rc.allTrackedItems.includes( ti ) then
			movingIn.add( ti );
		endif;
	endforeach;
	
	now := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create control transient;
	control.setMoveMode(REAL_MODE);	
	control.isSystemMove := true;

	beginTransaction;
	
	foreach ti in movingOut discreteLock do
		control.setMyTrackedItem(ti);
		control.setMyToPrimaryLocation(_ic);
		app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	app.myUtilityUA.utlUpdateRoRoLaneFreedLength(_rc, 0, _passport);	// 19/7/17 MAP TFS4907
	
	foreach ti in movingIn discreteLock do
		control.setMyTrackedItem(ti);
		control.setMyToPrimaryLocation(_rc);
		app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	if not _rc.allTrackedItems.isEmpty then
		foreach pos in 1 to _rc.allTrackedItems.size do
			if _rc.allTrackedItems[pos] &lt;&gt; _tis[ pos ] then
				requiresReOrder := true;
				break;
			endif;
		endforeach;
	endif;
	
	if requiresReOrder then
		app.myUtilityUA.utlUpdateSlotControllerShuffle(_tis, _passport);
	endif;
	if _passport.hasErrors then
		return;
	endif;
	
	foreach ti in _rc.allTrackedItems discreteLock do
		delete stowageConfirmController;
		create stowageConfirmController transient;
		stowageConfirmController.type := TRANS_TYPE_STOWAGE_CONFIRM;
		stowageConfirmController.dateTime := now;
		stowageConfirmController.userId := _passport.myUser.code;
		stowageConfirmController.noCharge := false; //TFS 3844 changed to false
		stowageConfirmController.myTrackedItem := ti;
		locString := _rc.getFullIdTI(ti) &amp; " " &amp; _rc.allTrackedItems.indexOf(ti).String;
		stowageConfirmController.confirmedLocation := locString;
		stowageConfirmController.myTerminal := _passport.myTerminal;
		
		app.myUtilityCA.utlCreateStowageConfirmTrans(stowageConfirmController,newTITransaction,_passport);
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

epilog

	delete movingOut; 
	delete movingIn;
	delete control;
	delete stowageConfirmController;
	
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_rc" type="CM_RoRoController" usage="input"/>
        <Parameter name="_ic" type="CM_LocationsController" usage="input"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
