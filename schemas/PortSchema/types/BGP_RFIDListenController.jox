    <JadeMethod name="setCMIF" id="92f5a3bf-e2b0-4a9d-af17-d40da896a975">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_cmif);
	_cmif.myTerminal := self.myTerminal;
	self.allRFIDTagReaders.copy(_cmif.allRFIDTagReaders);
end;


</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5ad7ca5f-e0ce-4ede-ac89-787dc4504a53">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_cmif);
	self.myTerminal := _cmif.myTerminal;
	self.allRFIDTagReaders.clear();
	_cmif.allRFIDTagReaders.copy(self.allRFIDTagReaders);

end;


</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="cc5f512f-1ba9-4705-91c8-2e05d2a6886d">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		25 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	terminalEvent,
	errCode			: Integer;
	errTxt			: String;
	gateLane		: CM_LaneController;

begin

	on Exception do app.alertExceptionHandler(exception, null, method.name, errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);

	terminalEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	if terminalEvent =  Event_Raise_Boom then
		if  theObject.isKindOf(CM_LaneController) then
			//epr par 22695 11/3/10 changed to CM_LaneController 
			gateLane := theObject.CM_LaneController;
			// No valid work. Should have been picked up in Gui.
			if gateLane = null then
				return;
			endif;
			
			
			if not self.doOpenBoom(gateLane, userInfo.Integer) then
				app.remoteErrorWarningToAlert('Boom gate failure connecting to gate lane' &amp; gateLane.ident, null,  null, null, false, true);
			endif;
		endif;
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
