    <JadeMethod name="cmbSession_click" id="70ea273d-d335-4816-9df7-bf8925f57030">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSession_click(combobox:ComboBox input) updating;

begin
	myBmkControl:=cmbSession.itemObject[cmbSession.listIndex].BmkControlSession;
	setCaption;
	showSession;
	showCreatorCreators;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="compareTranStats" id="7cf31ca4-a9eb-4ace-92cf-961b1fd66576">
        <updating/>
        <source>compareTranStats() updating;

vars
	sfb:FrmServerFileBrowser;
	aa:Analysis;
begin
	if secondLastStatsFile = null then
		secondLastStatsFile:="s:\BenchMarkResults";
	endif;
	
	create sfb;
	sfb.myParentForm:=self;
	sfb.selectedItem:=secondLastStatsFile;
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select Reference Stats File", null);
	sfb.showModal;
	secondLastStatsFile:=sfb.selectedItem;
	addResults("reference file: "&amp;sfb.selectedItem);

	create sfb;
	sfb.myParentForm:=self;
	if lastStatsFile = null then
		sfb.selectedItem:=secondLastStatsFile;
	else
		sfb.selectedItem:=lastStatsFile;
	endif;
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select Second Stats File", null);
	sfb.showModal;
	lastStatsFile:=sfb.selectedItem;
	addResults("second file:    "&amp;sfb.selectedItem);

	if lastStatsFile &lt;&gt; null and secondLastStatsFile &lt;&gt; null then
		create aa;
		aa.inFile.usePresentationFileSystem:=false;
		addResults("comparison results: "&amp;aa.compareStatsFiles(secondLastStatsFile, lastStatsFile));
	endif;
	cmbAction.setFocus;
epilog
	delete sfb;
	delete aa;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmd" id="1ac4977b-54cb-4a37-9406-53ecc354d47e">
        <updating/>
        <source>doCmd(cmd,cmdLog:String) updating;

vars
	result:String;
	i,j,retCode:Integer;
begin
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime '&amp;cmdLog,null,null,true,true,retCode);
	node.createExternalProcess(null,'cmd /c echo '&amp;cmd&amp;cmdLog,null,null,true,true,retCode);
	node.createExternalProcess(null,'cmd /c '&amp;cmd&amp;cmdLog,null,null,true,false,retCode);
	result:=cmd&amp;" retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
	app.logMessage(result);
	addResults(result);
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="cmdLog" type="String"/>
    </JadeMethod>
    <JadeMethod name="doGo" id="b5feec37-22ca-432b-ac05-d29d9d56a432">
        <updating/>
        <source>doGo(action:String) updating;

begin
	if     action = Show 						then showSession;
	elseif action = Show_CreatorCreators 	then showCreatorCreators;
	elseif action = Start_Creators 			then startCreators;
	elseif action = Show_Jade_Version		then showJadeVersion;
	elseif action = Start_Rap					then startRap;
	elseif action = Start_AppServers			then startAppServers;
	elseif action = Sync_Master_Thinbin 		then syncMasterThinbin;
	elseif action = Sync_Client_Thinbins 		then syncThinbin;
	elseif action = Start_ODT				then startODT;
	elseif action = Start_ControllerApp		then startControllerApp;
	elseif action = Start_Driver_Apps 		then startDriverApps;
	elseif action = Start_Background_Monitor	then startBackgroundMonitor;
	elseif action = Start_PerfMon_Logs		then doPerfMonLogStart;
	elseif action = Stop_PerfMon_Logs		then doPerfMonLogStop;
	//elseif action = Save_Log_Files 			then saveLogFiles;
	elseif action = Save_Log_Files 			then saveLogFilesGui;
	elseif action = Post_Process_Log_Files	then postProcessLogFiles;
	elseif action = Stop_Creators 			then stopCreators;
	elseif action = Start_JadeDev 			then startJadeDev;
	elseif action = Start_UserApp				then startUserApp;
	elseif action = Start_JadeMonV2			then startJadeMon("V2");
	elseif action = Start_JadeMon			then startJadeMon("");
	elseif action = Start_DriverApp			then startDriverApp;
	elseif action = Start_SingleUser			then startSingleUser;
	elseif action = Start_SingleUser_JdbUtil	then startSingleUserJdbUtil;
	elseif action = Start_SingleUser_AppServer	then startSingleUserAppServer;
	elseif action = Start_Fat_Client			then startFatClient;
	elseif action = Start_KillerAll				then startKillerAll;
	elseif action = Start_KillerFat				then startKillerFat;
	elseif action = Stop_All_Child_Processes	then stopAllChildren;
	elseif action = Stop_All_Mine		 		then stopAllMine;
	elseif action = Stop_CreatorCreators 		then stopCreatorCreators;
	elseif action = Fix_Envid 		then fixEnvid;
	endif;
end;</source>
        <Parameter name="action" type="String"/>
    </JadeMethod>
