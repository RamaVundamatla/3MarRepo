    <JadeMethod name="createTransientSelectorLine" id="ad3c2272-151a-4809-86f5-d5d0c9a1484c">
        <source>createTransientSelectorLine( criteriaLineHolder :  CM_QueryCriteriaLineHolder input; criteria : CM_YACriteria; className : String ):String;
/*

Purpose:			

Parameters:			Tries to add a Selector Query Line to a query using
					a Yard Allocation Criteria as the source.	

Return Value:		

Date		Who		Reason
16 Jun 2015	cnwndl1	Initial creation	Par 36388
20 Sep 2023	navkc1	Bug 60595: Selector criteria built up incorrectly from release request
12 Oct 2023	navdap1	TFS 58928 EUP | Calloff Zimmer DB Load
*/

vars

	queryProp : CM_QueryProperty;
	operClass : Class;
	dataValue : Any;
	transQueryLine : CM_SelectorCriteriaLine;
	transProperty : CM_QueryProperty;
	transOperator : CM_QueryOperator;
	warningMess : String;
	intArray : IntegerArray;
	strArray : StringArray;
	obj : Object;
	int : Integer;
	str	: String;
begin

	if criteria = null then
		return "'No YA criteria!";
	endif;
	
	//warningMess := criteria.getSelectorEquivalentValues( className, queryProp, operClass, dataValue );		// TFS 58928
	warningMess := criteria.getSelectorEquivalentValues( className, true, queryProp, operClass, dataValue );	// TFS 58928
	if warningMess &lt;&gt; null then
		return warningMess;
	endif;
	
	//30 Oct 2015	NDL	Par 37094
	if queryProp.isKindOf(CM_QAvailabilityGradeProperty) and operClass = CM_QIntegerIsOneOf then
		if dataValue &lt;&gt; null and dataValue.isKindOf(CM_ObjectSet) then
			create intArray transient;
			foreach obj in dataValue.CM_ObjectSet where obj.isKindOf(CM_MTGrade) do
				int := obj.CM_MTGrade.code;
				intArray.add( int );
				dataValue := intArray;
			endforeach;
		endif;
	endif;
	
	//20/09/2023	navkc1	Bug 60595
	if queryProp.isKindOf(CM_QImExStatusProperty) and operClass = CM_QIntegerIsOneOf then
		if dataValue &lt;&gt; null and dataValue.isKindOf(CM_ObjectSet) then
			create intArray transient;
			foreach obj in dataValue.CM_ObjectSet where obj.isKindOf(CM_IMEXStatus) do
				int := obj.CM_IMEXStatus.code;
				intArray.add( int );
			endforeach;
			dataValue := intArray;
		endif;
	endif;
	
	//20/09/2023	navkc1	Bug 60595
	if queryProp.isKindOf(CM_QStrCommodityProperty) and operClass = CM_QStringIsOneOf then
		if dataValue &lt;&gt; null and dataValue.isKindOf(CM_ObjectSet) then
			create strArray transient;
			foreach obj in dataValue.CM_ObjectSet where obj.isKindOf(CM_Commodity) do
				str := obj.CM_Commodity.code;
				strArray.add( str );
			endforeach;
			dataValue := strArray;
		endif;
	endif;
	
	//20/09/2023	navkc1	Bug 60595
	if queryProp.isKindOf(CM_QStrSpecialStowCodeProperty) and operClass = CM_QStringIsOneOf then
		if dataValue &lt;&gt; null and dataValue.isKindOf(CM_ObjectSet) then
			create strArray transient;
			foreach obj in dataValue.CM_ObjectSet where obj.isKindOf(CM_SpecialStow) do
				str := obj.CM_SpecialStow.code;
				strArray.add( str );
			endforeach;
			dataValue := strArray;
		endif;
	endif;
	
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder( criteriaLineHolder );

	create transProperty as queryProp.class transient;
	transProperty.set(	queryProp.niceName,	//_niceName : String
						queryProp.propertyName,	//_propName : String
						className	//_className : String
						);
	transProperty.setPerformanceRating( queryProp.performanceRating );		
	
	create transOperator as operClass transient;
	transOperator.setSearchValue( dataValue );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
										
	return null;

epilog

	delete intArray;
	delete strArray;
end;</source>
        <Parameter name="criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="criteria" type="CM_YACriteria"/>
        <Parameter name="className" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
