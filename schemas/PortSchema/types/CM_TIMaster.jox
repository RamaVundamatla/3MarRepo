    <JadeMethod name="pxyCreateUpdateProxy" id="9fffebc9-d37d-4826-a8a4-6de35e8242c1">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
//----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	tiMaster : CM_TIMaster;
	realDamage,
	pxyDamageInstance : CM_DamageInstance;
	completedOK		: Boolean;
begin
	tiMaster :=  inheritMethod();
	
	foreach realDamage in self.allDamageInstancesByPos discreteLock do
		pxyDamageInstance := realDamage.pxyGetProxyObject();
		if pxyDamageInstance = null then
			pxyDamageInstance := realDamage.pxyCreateUpdateProxy().CM_DamageInstance;
		endif;
		pxyDamageInstance.setMySubject(tiMaster);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tiMaster;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tiMaster;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeToDoTaskForBulk" id="dfbdf8dc-2593-4a4e-b109-4ad83b1d19f2">
        <updating/>
        <source>removeToDoTaskForBulk(_toDoDesc : CM_ToDoTaskDesc; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/

vars

	task 		: CM_ToDoTaskDesc;
	tiTask 		: CM_ToDoTaskDesc;	
	found		: Boolean;
begin

	//Check that we do infact have this task assigned to us
	foreach task in self.allToDoTaskDesc where task.description.trimBlanks = _toDoDesc.description do
		found := true;
		break;
	endforeach;
	
	if not found then
		app.raiseCMWarning1(WARN_TODOTASK_REMOVE, 'Task "' &amp; _toDoDesc.description &amp; '" is not pending for "' &amp; self.id &amp; '" and so cannot be removed.', null, null, self);
		return;
	endif;
	
	self.allToDoTaskDesc.removeIfPresent(task);
		/*
	if task.toDoTaskDescTrans = REPAIR then
		self.unDamage();
	endif;
	*/
//	task.erase(NORMAL_ERASE);
	
	
	// CCMS 1285: check for event notification processing	
	//self.actionStopTaskEventRequests(app.getErrorString(AvailableForRelease), null, _passport);
	//self.actionStopTaskEventRequests(CM_EventRequestNotification.Event_Type_IsAvailable, CM_EventRequestNotification.Event_Type_IsAvailable, false, _passport);
//	self.causeEvent(Object_Update_Event, false, self);
	self.updateObjectEdition(self);
	// PAR 13005
	
end;</source>
        <Parameter name="_toDoDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
