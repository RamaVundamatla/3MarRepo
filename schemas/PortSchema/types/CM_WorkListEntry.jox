    <JadeMethod name="validateForAssignTI" id="8ed884f5-da0e-4294-9bf8-a8f1c811ae31">
        <source>validateForAssignTI(_theTI : CM_TrackedItem);
//--------------------------------------------------------------
//Created: 20 February 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 10/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 A WLE with a TBA TI is OK
// 23/03/2011 	cnwer1		PAR #25573 status assigned no longer used part complete is instead
vars
	theID : String;
	release			: CM_BulkRelease;
	reserveDetail			: CM_ReserveDetail;
	desc 	: String;
begin
	if _theTI =  null then
		app.setContinueCMExceptions(false);	
		app.raiseCMException2(ERR_INVALID_VALUE, 'Tracked Item', "A Tracked Item Was Not Specified", null, null);		
		return;
	endif;

	if         self.isCompleteForJob then     //epr par 37028 6/1/16   self.status &lt;&gt; WLE_PART_COMPLETE and  self.status &lt;&gt; WLE_UNACTIONED then //
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_INVALID_WLE_STATUS, _theTI.id, self.statusString, null, null);
		return;		
	endif;

	//if self.myTrackedItem &lt;&gt; null then									// PAR #23794
	if self.myTrackedItem &lt;&gt; null and not self.myTrackedItem.isTBAorIsRRP then		// PAR #23794
		if self.myTrackedItem &lt;&gt; _theTI then
			if self.job &lt;&gt; null then
				theID := self.job.jobId;
			else
				theID := "&lt;null&gt;"; 
			endif;
			app.raiseCMException2(ERR_WLE_HAS_TI, theID, self.myTrackedItem.id, null, null);		
		endif;
	endif;
	
	//th2 PAR 14873 - validate that the container is allowed to be attached against the associated release request. 
	//Note that here we take into account that the 
	//quantity outstanding may be larger than the number specifically assigned to 
	//the release, in which case the container only has to match the release criteria. Alternatively,
	//the quantity outstanding may be smaller or equal to the number assigned, in which case the container
	//attached here MUST BE one of the ones assigned.
	
	release := self.myRequest.myOriginatingBulkRelease;
	reserveDetail := self.myRequest.myReserveDetail.CM_ReserveDetail;
	if release &lt;&gt; null then
		//jlier1 TFS 60770 12/3/24
		if self.isAnyId then
			if reserveDetail &lt;&gt; null and reserveDetail.isFullyLoaded then
				desc := reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr();
				app.raiseCMException1(Quant_weigh_relea_will_excee_r, desc, null, self );
				return;
			endif;
		else
			if reserveDetail &lt;&gt; null then
				reserveDetail.validateCanReleaseTI(_theTI);
			else
				release.validateCanReleaseTI(_theTI);
			endif;
		endif;
	endif;
	
	_theTI.testAgainstRequest(self.myRequest);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForAutoplan" id="16d2d3d5-ef81-4308-bf69-442ac768436e">
        <source>validateForAutoplan();
//--------------------------------------------------------------
//Created: 05 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	

	//epr par 25573 6/2/2011  completed for the job raise exception
	if self.myFutureMove = null and self.isCompleteForJob   then 
		app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'complete', 'auto-planned', null, null);			
		return;
	endif;

	if self.myTrackedItem = null then
		return;		//It must be a request therefore not interested
	endif;
	
	self.myTrackedItem.validateForAutoplan;

end;</source>
    </JadeMethod>
