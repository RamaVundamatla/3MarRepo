<Class name="CMEVT_UnreconciledBooking" id="1e262af4-e5a1-4979-97ac-a0fc3aa234d9">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ImplicitInverseRef name="myBookingRef" id="e9410807-18d2-4cbf-b72f-cc5405809274">
        <embedded/>
        <type name="CM_BookingRef"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTrackedItem" id="b47ee501-d78f-42b1-95b7-dba2f79e6dea">
        <kind>child</kind>
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
        <Inverse name="CM_TrackedItem::myUnreconciledBookingEvent"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="8b1a05da-1a62-4e33-af79-41472378598c">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/05/2012	cnwdap1	Initial creation PAR #29509
*/
vars

begin
	self.type := EVT_UnreconciledBooking;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoTypeId" id="c9c173bb-40bf-49ba-8d2d-a0a8f78f2d16">
        <source>getCargoTypeId(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		    Who		Reason
14 March 2023	navmp20	ChangeRequest 56278: PRP - Financial Data Extract Additional Attributes

*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.cargoType;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="479d1bdf-0412-4621-8041-a4be61ff1a6d">
        <source>getDebtor(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2017	jlgndl1	Initial creation	TFS 5646

*/

vars

	op : CM_Operator;
	dr : CM_Debtor;

begin

	if self.myTrackedItem &lt;&gt; null then
		op := self.myTrackedItem.myOperator;
		if op &lt;&gt; null then
			dr := op.debtor;
			if dr &lt;&gt; null then
				return dr;
			endif;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="364c558b-8a8e-458a-a720-ca02f1830016">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/05/2012	cnwdap1	Initial creation PAR #29509
*/
vars

begin
	if _attrName = ETRow_ErrorText or _attrName = ETRow_Description then
		return self.myBookingRef.bookingReference &amp; " / " &amp; self.myTrackedItem.myCargoType.description &amp; " " &amp; self.myTrackedItem.id;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateDetails" id="82346371-1d4b-4f30-b0f6-070aa46d85d4">
        <updating/>
        <source>updateDetails(_booking : CM_BookingRef; _ti : CM_TrackedItem; _passport : CM_Passport) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/05/2012	cnwdap1	Initial creation PAR #29509
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	terminal : CM_Terminal;

begin
	self.myBookingRef	:= _booking;
	self.myTrackedItem	:= _ti;
	if _passport &lt;&gt; null then
		terminal 		:= _passport.myTerminal;
	else
		terminal		:= _ti.myTerminal;
	endif;
	if self.myTerminal = null then
		self.myTerminal := terminal;
	endif;
	if _passport &lt;&gt; null and _passport.myUser &lt;&gt; null then
		self.userCode 	:= _passport.getUserCode;
	endif;
	self.myEventType 	:= terminal.myRoot.allEventTypesByType[EVT_UnreconciledBooking];
	if self.dateTime = null then
		self.dateTime	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.setCAMSTimeStamp(app.actualTimeServer);	
	
	// raise a notification of an unreconciled event
	terminal.causeEvent(terminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
