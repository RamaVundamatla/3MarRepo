    </JadeMethod>
    <JadeMethod name="doesValueMatch" id="9e229b35-1923-4921-b4a1-399edb587399">
        <source>doesValueMatch(_booleanValue : Boolean) : Boolean;
// -------------------------------------------
// Created 09 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.value =  CM_YADataBoolean.VALUE_EITHER then
		return true;
	endif;
	
	if self.value = self.VALUE_FALSE then
		return not _booleanValue;
	elseif self.value = self.VALUE_TRUE then
		return _booleanValue;
	endif;
	
	return false;

end;</source>
        <Parameter name="_booleanValue" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
