    <JadeMethod name="handleSysNotify" id="cdef8d0a-1cd6-4c65-ac4f-8059d36bf8f0">
        <updating/>
        <source>handleSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 May 2008	cnwkpd1	PAR #16748 - Correct handling of deleted TI
11/03/2011	cnwmh5	PAR #27142 - if delete event ti was always null, change where ti is set.
*/

vars
	ti				: CM_TrackedItem;
	row				: Integer;
	invalidTI		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);		// PAR #16748
	
	ti := theObject.CM_TrackedItem;								// 11/03/2011 cnwmh5 #27142
	if eventType = Object_Update_Event then
		if self.myCurrentTI = ti then
			self.showDetailsForTI(ti);
		endif;
		if self.tblData.findObjectInRow(ti, row) then
			self.tblData.accessCell(row, 1).text := ti.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		endif;
	elseif eventType = Object_Delete_Event then
		if self.tblData.findObjectInRow(ti, row) then
			self.tblData.removeItem(row);
		endif;
		if self.myCurrentTI = ti then
//			self.myCurrentTI := null;		// PAR #16748
			self.setCurrentTI(null);		// PAR #16748
			app.msgBox('The container you are viewing has just been deleted', 'Info', MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="f8f75d5c-0c37-4ad6-91c9-75630b627e22">
        <source>initTblData() protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 26/05/2025	navlw1	JIRA-34824: MTN | Quick Cargo Review UI Refactor
vars
	entDef	: EntTableDef;
	
begin
	entDef := app.myController.getEntTableDef(ETDef_LlHeadings);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_LlHeadings not found');
		return;
	endif;
	
	self.tblData.setTblDataEntRowsFromDef(entDef);
	self.tblData.selectionType := Table.SelectMode_FixedRow;
	self.tblData.setGridLinesHorizontal(false);

end;</source>
        <access>protected</access>
    </JadeMethod>
