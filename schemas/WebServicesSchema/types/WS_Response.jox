<Class name="WS_Response" id="7c51fe13-a874-47e0-8be4-f4dfc2a2fc72">
    <superclass name="WS_InterfaceObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allErrors" id="5fc79a8d-04ce-4b6d-950c-549c6d19f6e1">
        <memberTypeInverse/>
        <type name="WS_ErrorMessageArray"/>
        <text>A collection of all JMT Errors that might have occured during the processing of the request.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allInfo" id="af6c56d5-db3e-487d-8cf6-b23c14469a85">
        <memberTypeInverse/>
        <type name="WS_InfoMessageArray"/>
        <text>A collection of all miscellaneous information that may occur during the processing of the request. (E.g. Returning the PIN of a successful Pre-Note).</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWarnings" id="944757f7-dd80-4187-b5ce-afbc25a1a619">
        <memberTypeInverse/>
        <type name="WS_ErrorMessageArray"/>
        <text>A collection of all JMT Warnings that might have occured during the processing of the request.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="result" id="d4049091-c2ac-4725-9c17-004c126ea3fb">
        <embedded/>
        <type name="Integer"/>
        <text>Result of web service call.

Zero - Successful.
Non-zero - Failure, need to check allErrors.</text>
    </PrimAttribute>
    <JadeMethod name="addInfo" id="200af292-e175-4be0-a949-cb44748a54d7">
        <updating/>
        <source>addInfo(text : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation 51683

*/

vars
	infoMessage			: WS_InfoMessage;
begin
	if text.trimBlanks = null then
		return;
	endif;
	create infoMessage transient;		
	infoMessage.text :=	text.trimBlanks;
	self.allInfo.add(infoMessage);

epilog

end;</source>
        <Parameter name="text" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="82a4b982-c4ea-4e65-9429-89e9df58b78d">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	self.allWarnings.purge();
	self.allErrors.purge();
	self.allInfo.purge(); //06/07/2009 cnwdz2 par 20233
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="13c5b65d-d1f0-486e-9499-8d4955d80254">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation

*/

vars

begin
	if _property = WS_Response::allErrors or _property = WS_Response::allWarnings
		or _property = WS_Response::allInfo then
		return ExportAsParent;
	endif;

	return NoExport;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getErrorsAsStringForTesting" id="4e251af7-dffe-4035-8ef7-c6a412fde119">
        <source>getErrorsAsStringForTesting():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwndl1	Initial creation

*/

vars

	error  : WS_ErrorMessage;
	str : String;

begin

	foreach error in self.allErrors do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; error.text;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResponseCode" id="6decc002-72c4-4a6d-bf67-9b1d07d53de9">
        <source>getResponseCode(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2020	jlgrr1	Initial creation

*/

vars

begin
	// If we have any errors, and no specific response error code set yet, set to Client Error
	if self.result = 1 then
		return HttpResponseClientError;
	else 
		return HttpResponseOK;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWarningsAsStringForTesting" id="cdca9606-ac9f-4b85-a73f-15c07d402436">
        <source>getWarningsAsStringForTesting():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/11/2017	jlgmp6	Initial creation

*/

vars

	warning  : WS_ErrorMessage;
	str : String;

begin

	foreach warning in self.allWarnings do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; warning.text;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasErrors" id="cc7be29d-752c-450a-abbf-cef9633e9ae7">
        <source>hasErrors():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwndl1	Initial creation

*/

vars

begin

	return not self.allErrors.isEmpty;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setErrorsFromPassport" id="0218ef0b-78aa-49bf-b672-b5a572570658">
        <updating/>
        <source>setErrorsFromPassport() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
08 Sep 2008 cnwkao1 updated to cater for warnings (?)
27 Apr 2020 cnwma1  Bug 48757: SNO - Power disconnection
*/

vars
	passport		: CM_Passport;
	error			: CM_Error;
	errorProxy		: WS_ErrorMessage;
	
begin
	passport := app.myPassport;
	if passport = null then
		return;
	endif;
	
	foreach error in passport.allErrors do
		create errorProxy transient;
		errorProxy.setProxyFromObject(error);
		self.allErrors.add(errorProxy);
	endforeach;
	
	if not passport.warningsIgnored then
		foreach error in passport.allWarnings do
			create errorProxy transient;
			errorProxy.setProxyFromObject(error);
			self.allWarnings.add(errorProxy); //KO - do we want to distinguish between errors and warnings? Currently I'm setting CM_Passport::warningsIgnored to true for some updates
		endforeach;
	endif;
	
	if not self.allErrors.isEmpty then
		self.result := 1;
		//27.03.2020 cnwma1 #48757
		if app.myPassport.allErrors.includesErrorCode(MACH_LIFT_POWER) then 
			self.result := 99;  //has Prompt 
		endif;
	endif;
	
	// KPD - added this to ensure errors are not copied twice for nested webService
	// method calls
	passport.clearErrorsWarnings();
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
