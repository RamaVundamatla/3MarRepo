    <JadeMethod name="setStartDate" id="e5aacaa1-4e66-4128-9599-ec7a727ae743">
        <updating/>
        <source>setStartDate(pDate:Date) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
