    <JadeMethod name="setProxy" id="a50af95a-dd34-4b32-8550-09653d0562a2">
        <updating/>
        <source>setProxy(_code, _description : String; _notAvailableForEntry: Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(_code, _description,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8823b383-d7e6-4a49-b86a-41facd514384">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if app.myRoot.allLabourRestictionsCodes.includesKey(self.description) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);
	endif;
	inheritMethod();
end;</source>
    </JadeMethod>
