<Class name="WS_WorkOrderDetailUpdateReq" id="dd325cd6-cee9-4732-9310-316eac67bbf6">
    <superclass name="WS_UpdateRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myWorkOrderDetail" id="2654fa8e-7f8a-4e5f-952d-28ef41c61722">
        <embedded/>
        <type name="WS_WorkOrderDetail"/>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyWorkOrder" id="d65c0aa1-39f9-49b8-997d-12ed9ebcdf24">
        <source>createProxyWorkOrder(_isCreate : Boolean) :CM_WorkOrder ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2018	jlger1	Initial creation
28/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
21/02/2019	jlgdap1	TFS 43431 PEL1 Container Services - Release Request Expiry Date
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
04 Nov 2021 navma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	pxyWorkOrder        : CM_WorkOrder;
	workOrderDetail     : CM_WorkOrderDtl;
	pxyWorkOrderDetail,
	realWorkOrderDetail : CM_WorkOrderDtl;
	voyage              : CM_Voyage;
	reqByDT             : TimeStamp;				// TFS 43431
	wsTi                : WS_WorkOrderTrackedItem;
	ti					: CM_TrackedItem;
	passport		    : CM_Passport;
begin
	if self.myWorkOrderDetail = null then 
		return null;
	endif;
	
	passport := app.myPassport;
	
	if  self.myWorkOrderDetail.isVoyageWorkOrder then
		voyage := app.myPassport.getObjectOfTypeFromOid(self.myWorkOrderDetail.voyage,CM_Voyage).CM_Voyage;
	/*
	12.01.2023 navma1 #56141 Task#56147
	else
		tiList   := self.myWorkOrderDetail.allTIs.asDelimitedString(Comma);					 	//29.09.2021 navma1 #51925
		
		if not self.myWorkOrderDetail.allTIs.isEmpty then
			wsTi 			:= self.myWorkOrderDetail.allTIs.first;
			if wsTi.cmObjectId &lt;&gt; null then
				ti := app.myPassport.getObjectOfTypeFromOid(wsTi.cmObjectId,CM_TrackedItem).CM_TrackedItem;
				if ti &lt;&gt; null and ti.myCargoType &lt;&gt; null then
					cargoType		:= ti.myCargoType;
					wsCargoTypeId	:= cargoType.id;
				endif;
			endif;
			
		endif;
	*/
	endif;
	
	/* //04.11.2021 navma1 #52248
	if not self.myWorkOrderDetail.isVoyageWorkOrder then
		
		cargoType:= app.myRoot.allCargoTypesById[self.myWorkOrderDetail.cargoTypeId];
		
		if cargoType = null and self.myWorkOrderDetail.isKindOf( WS_WorkOrderReleaseExt ) then	//19 Mar 2019	NDL	TFS 43405
			cargoType:= app.myRoot.allCargoTypesById[TI_CargoType_Container];
		endif;
	else
		voyage := app.myPassport.getObjectOfTypeFromOid(self.myWorkOrderDetail.voyage,CM_Voyage).CM_Voyage;
	endif;
	*/
	if not _isCreate then
		//realWorkOrderDetail:= self.myWorkOrderDetail.cmObjectId.asOid.CM_WorkOrderDtl;														//12.08.2022 navtnr20 52451
		realWorkOrderDetail  := passport.getObjectOfTypeFromOid(self.myWorkOrderDetail.cmObjectId,CM_WorkOrderDtl).CM_WorkOrderDtl;		//12.08.2022 navtnr20 52451
		if realWorkOrderDetail = null then
			return null;
		endif;
		
		if realWorkOrderDetail.myParent = null then
			return null;
		endif;
		pxyWorkOrder := realWorkOrderDetail.myParent.pxyGetProxyObject();						//06.03.2023 navma1 #56457:[56458]
		if pxyWorkOrder &lt;&gt; null then								
			delete pxyWorkOrder;
		endif;

		pxyWorkOrder:= app.createUpdateProxy(realWorkOrderDetail.myParent).CM_WorkOrder;		//06.03.2023 navma1 #56457:[56458]
			
		//epr TFS 42924 8/2/19
		if pxyWorkOrder.taskStatus = WO_STATUS_NOTAPPROVED then
			//update to PENDING APPROVAL so new cash receipt can be generated
			pxyWorkOrder.setTaskStatus( WO_STATUS_PENDING);
		endif;
		
		foreach workOrderDetail in pxyWorkOrder.allWoDtls discreteLock do
			if workOrderDetail.pxyGetRealObject = realWorkOrderDetail then
				pxyWorkOrderDetail := workOrderDetail;
				break;
			endif;			
		endforeach;
		
		/*
		12.01.2023 navma1 #56141 Task#56147
		if pxyWorkOrder.isKindOf(CM_WorkOrderTI) then
			pxyWorkOrder.CM_WorkOrderTI.mySource.setProxy(wsCargoTypeId,tiList);						   //04.11.2021 navma1 #52248
		endif;
		*/
	else
		if self.myWorkOrderDetail.isVoyageWorkOrder then
			create pxyWorkOrder as CM_WorkOrderVoyage transient;
		else
			create pxyWorkOrder as CM_WorkOrderTI transient;
		endif;
		
		if self.myWorkOrderDetail.requiredByDT &lt;&gt; null then									// TFS 43431
			reqByDT := self.myWorkOrderDetail.requiredByDT.asTimeStampFromWebInterface;		// TFS 43431
			reqByDT.setTime("23:59:00".Time);												// TFS 43431
		endif;																				// TFS 43431
		
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,passport.myUser,null,null,passport.myTerminal,null,reqByDT,null, WO_STATUS_PENDING);	// TFS 43431
		
		/*
		//12.01.2023 navma1 #56141 Task#56147
		//10.09.2021 navma1 #51002
		if cargoType &lt;&gt; null then
			pxyWorkOrder.setProxyWorkOrderSource(null,pxyWorkOrder,cargoType,tiList,not _isCreate);
		endif;
		*/
	endif;
	
	if voyage &lt;&gt; null then
		pxyWorkOrder.CM_WorkOrderVoyage.setMyVoyage(voyage);
	endif;
	
	//epr tfs 38947 5/6/18
	
	if pxyWorkOrderDetail = null then																//08.02.2023 navma1 #56457 Task#56458
		pxyWorkOrderDetail := self.myWorkOrderDetail.createProxyWorkOrder();
	endif;
	
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.isKindOf(CM_WorkOrderTI) then
	
		pxyWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.clear();								//08.02.2023 navma1 #56457 Task#56458
		
		foreach wsTi in self.myWorkOrderDetail.allTIs do 
			ti := passport.getObjectOfTypeFromOid(wsTi.cmObjectId,CM_TrackedItem).CM_TrackedItem;
			if ti &lt;&gt; null then
				//pxyWorkOrder.CM_WorkOrderTI.allTIs.addNoDuplicates(ti,false);						//08.02.2023 navma1 #56457 Task#56458
				pxyWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti,false);		//08.02.2023 navma1 #56457 Task#56458
			endif;
		endforeach;
		//pxyWorkOrder.CM_WorkOrderTI.setTotalRequired(self.myWorkOrderDetail.allTIs.size);    	     //29.09.2021 navma1 #51925	//08.02.2023 navma1 #56457 Task#56458
	endif;
	
	pxyWorkOrder.allWoDtls.addExclusive(pxyWorkOrderDetail);										 //08.02.2023 navma1 #56457 Task#56458

	self.myWorkOrderDetail.updateProxyWorkOrder(pxyWorkOrderDetail);
	
	return pxyWorkOrder;
	
epilog
	endLoad;
end;</source>
        <Parameter name="_isCreate" type="Boolean"/>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="delete" id="da127ac6-9df5-428b-bfb0-04c9f90a2fb7">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars

begin
	delete self.myWorkOrderDetail;
epilog

end;</source>
    </JadeMethod>
</Class>
