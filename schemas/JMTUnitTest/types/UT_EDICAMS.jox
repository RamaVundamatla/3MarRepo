	self.assertTrueMsg(camProtocol.allEWSCamsActivities.first() &lt;&gt; null, "camProtocol.allEWSCamsActivities.first() is null");	
	//self.assertTrueMsg(camProtocol.allEWSCamsActivities.first.responseCode &lt;&gt; 400 ,"The error response from the server is : "&amp;camProtocol.allEWSCamsActivities.first.response);		
	
