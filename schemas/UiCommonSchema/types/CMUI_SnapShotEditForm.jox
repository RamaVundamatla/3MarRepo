    <JadeMethod name="create" id="b6a551ca-b63b-457b-922e-1a2ef0297a75">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 Jan 2019	NDL	TFS 42729
vars

begin


	self.permissionView  := PmAdmSnapShotEditView;
	self.permissionMaint := PmAdmSnapShotEditMaint;

	self.helpFileName := HelpFile_Voyage;
end;</source>
