    <JadeMethod name="setControllerCurrent" id="d0152168-6791-4a95-82a5-6d0d48ece3a1">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
vars

	aCommMap : CM_CommodityMap;
	
begin

	inheritMethod();
	
	myTMCController.myCurrentMapServiceBroker := self.myTransServiceBroker;
	myTMCController.myCurrentMapResourceType := null;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myTransResourceServiceBroker.isKindOf(CM_TransResourceServiceBroker) then
		aCommMap := self.myTransServiceBroker.CM_TransResourceServiceBroker.commodityMap;
		
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := 	myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="c328929c-3fd0-44f2-8920-7016624230f7">
        <source>setEnableObjects(form: INV_TransactionMap io);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2010	cnwndl1	Initial creation	CCMS MES 1006
12 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions
15/05/2023		navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

begin

	inheritMethod(form);
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myGroup.isKindOf(CMIF_TMCSBGroup) then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_ResourceType;
	elseif self.myGroup.isKindOf(CMIF_TMCEventGroup) then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_EventResourceType;
	elseif self.myGroup.isKindOf(CMIF_TMCWorkOrderGroup) then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_WOResourceType;
	endif;
	form.menuSItemDelete.visible := false;
	form.menuSINewDebtor.visible := false;
	form.menuSINewTranType.visible := true;
	form.btnDelete.enabled := false;
	form.mnuCopy.visible := false; // TFS 38711 - hide resource Copy menu item
	form.btnCopy.enabled := false; // TFS 38711 - disable toolbar Copy button

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="11721f03-42ba-44dd-b72f-aa72316678b8">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwndl1	Initial creation	CCMS MES 1006
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

	aCommMap : CM_CommodityMap;
	
begin

	inheritMethod(form);
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myGroup.isKindOf(CMIF_TMCSBGroup) then
		form.myTMCSB := self.myGroup.CMIF_TMCSBGroup;
		form.myCurrentMapServiceBroker := self.myTransServiceBroker;
		form.myCurrentResourceMappingHdr := self;
		form.myCurrentMapResourceType := null;
		
		aCommMap := self.myTransServiceBroker.CM_TransServiceBroker.commodityMap;

		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := 	form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;
		form.modePropertyNew := INV_TransactionMap.ModeProperty_ResourceType;
		
	elseif self.myGroup.isKindOf(CMIF_TMCEventGroup) then // 15/05/2023	navkc1	CR 57927 Task 54268
		
		form.myTMCEG := self.myGroup.CMIF_TMCEventGroup;
		form.myCurrentMapServiceBroker := self.myTransServiceBroker;
		form.myCurrentResourceMappingHdr := self;
		form.myCurrentMapResourceType := self.myTransServiceBroker;
		form.myCurrentMapTMEvent := self.myTransServiceBroker.CM_EventServiceBroker.myTranMap;
		form.modePropertyNew := INV_TransactionMap.ModeProperty_EventResourceType;
		
	elseif self.myGroup.isKindOf(CMIF_TMCWorkOrderGroup) then // 15/05/2023	navkc1	CR 57927 Task 54268
		
		form.myTMCWO := self.myGroup.CMIF_TMCWorkOrderGroup;
		form.myCurrentMapServiceBroker := self.myTransServiceBroker;
		form.myCurrentResourceMappingHdr := self;
		form.myCurrentMapResourceType := self.myTransServiceBroker;
		form.myCurrentMapTMWorkOrder := self.myTransServiceBroker.CM_WorkOrderServiceBroker.myTransMap;
		form.modePropertyNew := INV_TransactionMap.ModeProperty_WOResourceType;
		
	endif;
epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
