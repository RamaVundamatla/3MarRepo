<Class name="CM_QuickAccess">
    <JadeMethod name="getMenuAction" id="5a997da6-b98b-431b-b47e-020451dddc92">
        <source>getMenuAction( _terminal : CM_Terminal ):CMUI_MenuAction;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

	menuAction : CMUI_MenuAction;

begin

	menuAction := app.myController.createMenuAction(self.permissionInteger, null, null, _terminal);
	
	return menuAction;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMUI_MenuAction"/>
    </JadeMethod>
