    <JadeMethod name="setFromTI" id="c944bf9d-dacb-42d6-94ee-7836bd3bbbb9">
        <updating/>
        <source>setFromTI(_ti: CM_Container; _setKeys: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	todoTask		: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	tiTA			: CM_TerminalArea;
begin
	
	self.allTrackedItems.add(_ti);
	
	if _setKeys then
		self.dischPort		:= _ti.dischargePort;
		self.loadPort		:= _ti.loadPort;
		
		self.height			:= _ti.height;
		//self.weight			:= _ti.weight;					//-cnwml2 MSL CCMS 1017
		self.weight			:= _ti.totalWeight;					//+cnwml2 MSL CCMS 1017
		self.isoType		:= _ti.isoType;
		
		self.reeferTemp 	:= _ti.getTemperature;
		
		if _ti.isReefer then
			self.liveReefer	:= "Y";
		else
			self.liveReefer	:= "N";
		endif;
		
		if _ti.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			self.fullStatus	:= "E";
		elseif _ti.contentsStatus = TI_CONTENTS_STATUS_FCL then
			self.fullStatus	:= "F";
		elseif _ti.contentsStatus = TI_CONTENTS_STATUS_LCL then
			self.fullStatus	:= "L";
		elseif _ti.contentsStatus = TI_CONTENTS_STATUS_NULL then
			self.fullStatus	:= "N";
		elseif _ti.contentsStatus = TI_CONTENTS_STATUS_MASK then
			self.fullStatus	:= "M";
		endif;
	endif;


	
	if _ti.site = TI_SITE_ONSITE then
		self.totalQuantity := self.totalQuantity + 1;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_setKeys" type="Boolean"/>
    </JadeMethod>
</Class>
