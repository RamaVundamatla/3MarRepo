    <JadeMethod name="setCurrentTableItem" id="09136ec1-7f0f-4c8b-bf0e-3408c4dd4d66">
        <updating/>
        <source>setCurrentTableItem(_tblItem: SOP_TableMaintItem) updating;
//-----------------------------------------------------------------------
//	Created:	29 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	04/06/2021	navmd1		TFS 51320 - Add filter to Sys/Terminal forms

vars
	oldMaintItem	: SOP_TableMaintItem;
	invalidItem		: Boolean;
	dataClass		: Class;
	
begin
	oldMaintItem := self.myCurrentTableItem;

	self.myCurrentTableItem := _tblItem;

	if self.myCurrentTableItem &lt;&gt; null then
		self.beginClassNotification(self.myCurrentTableItem.myDataClass, false, Object_Create_Event, Response_Continuous, 0);
	endif;
	
	on Exception do app.handleDeletedObject(exception, oldMaintItem, invalidItem);	// 26/05/2011 cnwar2 #27445
	if oldMaintItem &lt;&gt; null then
		dataClass := oldMaintItem.myDataClass;
		if not invalidItem
		and dataClass &lt;&gt; self.myCurrentTableItem.myDataClass then
			self.endClassNotification(oldMaintItem.myDataClass, false, Object_Create_Event);
			// We've actually changed 'Tables', so the old filter text is now invalid
			//25/06/2024	navkc1 CR 64823 Task 64824
			//self.txtFilterBox.text := "";										// TFS 51320
			//self.txtFilterBox.foreColor := getSystemColor(Color_WindowText);	// TFS 51320
			self.frmTableFilter.txtFilterBox.text := "";
			self.frmTableFilter.txtFilterBox.foreColor := getSystemColor(Color_WindowText); //25/06/2024	navkc1 CR 64823 Task 64824
			oldMaintItem.filteredObjects.clear();								// TFS 51320
		endif;
	endif;

	if _tblItem.isKindOf(SOPTM_Terminal) then
		btnSubTerms.visible	:=	true;
		btnITTC.visible  	:=	true;
		btnAutoId.visible := true;//	29 July 2014	NDL	Par 34660
		//btnAutoVoyageConfig.visible := true;  // ### TFS BUG 65730 22AUG2024 NAVAB1		
		// ### JIRA 33001 03OCT2024 NAVAB1
		btnAutoVoyageConfig.visible :=  app.getMyUser.canDo(null, Mod_VoyageAutoClosure);

	else
		btnSubTerms.visible	:=	false;
		btnITTC.visible  	:=	false;
		btnAutoId.visible := false;//	29 July 2014	NDL	Par 34660
		btnAutoVoyageConfig.visible := false;  // ### TFS BUG 65730 22AUG2024 NAVAB1
	endif;
	
	// TFS 47920 jlgzm1 07/01/2020
	if _tblItem.isKindOf(SOPTM_EventStreamDefinition) then
		btnReplay.visible 	:=	true;
	else
		btnReplay.visible 	:=	false;
	endif;
	
end;</source>
        <Parameter name="_tblItem" type="SOP_TableMaintItem"/>
    </JadeMethod>
