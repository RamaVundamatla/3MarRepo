    <JadeMethod name="valVolumeDiscrepancy" id="a952f23d-33b5-4ac0-bf36-9226f237dfa9">
        <source>valVolumeDiscrepancy( _validateInput : Boolean;
					_ti : CM_TrackedItem input;
					_quantity : Integer;
					_pieces : Integer;
					_width,
					_length,
					_height	: Decimal;
					_weight : Decimal;
					_volume	: Decimal;
					_reason: CM_VolumeDiscrepancyReason;
					_passport : CM_Passport input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

begin
	if _ti = null then
		app.raiseCMException(No_Cargo_selected,null,null);
		return;
	endif;
	
	if _validateInput then
		
		if _width &lt;= 0 then
			app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(Width), app.getErrorString(CM_Total_Volume),null,null);
		endif;
		
		if  _length &lt;= 0 then
			app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(Length), app.getErrorString(CM_Total_Volume),null,null);
		endif;
		
		if  _height &lt;= 0 then 
			app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(Height), app.getErrorString(CM_Total_Volume),null,null);
		endif;
		
		if  _quantity &lt;= 0 then 
			app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(CM_Total_Quantity), app.getErrorString(CM_Total_Volume),null,null);
		endif;
		
		if  _pieces &lt;= 0 then 
			app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(CM_Pieces), app.getErrorString(CM_Total_Volume),null,null);
		endif;

		if _reason = null then
			app.raiseCMException(No_reason_given, null, null);			// 3/5/19 MAP TFS41707
		endif;

		if  _ti.totalVolume = _volume  and
			_ti.totalQuantity = _quantity and 
			_ti.totalWeight = _weight then
			app.raiseCMException(NothingHasBeenChangedWQV, null, null);
		endif;

	endif;
epilog

end;</source>
        <Parameter name="_validateInput" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_pieces" type="Integer"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_reason" type="CM_VolumeDiscrepancyReason"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valVolumeDiscrepancyReason" id="e7cf74a3-5969-492c-8107-5615b0b44cb5">
