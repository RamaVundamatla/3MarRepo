//--------------------------------------------------------------
vars
begin
	if self.mnuHideTreeView.caption = HideTreeView then
		self.splOperations.setLeftToRightRatioAndResize(0);
		self.mnuHideTreeView.caption := ShowTreeView;
	else
		self.splOperations.setLeftToRightRatioAndResize(30);
		self.mnuHideTreeView.caption := HideTreeView;	
	endif;
end;</source>
