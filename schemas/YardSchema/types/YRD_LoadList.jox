    <JadeMethod name="doTblSummaryDblClick" id="16a7d379-c7af-4103-b16b-5180511b9198">
        <updating/>
        <source>doTblSummaryDblClick(_table: CM_DataTable input) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpSumObj		: CMIF_LoadListSummaryObject;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
	str				: String;
	int,
	function	: Integer;
begin
	tbl := _table;
	tmpSumObj := tbl.accessRow(tbl.row).itemObject.CMIF_LoadListSummaryObject;
	
	if tmpSumObj = null then
		//nothing to do
		return;
	endif;

//	if tbl.column = self.Column_ColourCode then
//		self.showStowageIDs(tmpSumObj);
//		return;
//	endif;
	
	if self.defaultDblClickFunction = null then
		//ask - what do you want to do?
		self.doSetFunctionPref(tmpSumObj);
		return;
	endif;
	
	create allSummariesObj transient;
	allSummariesObj.add(tmpSumObj);
	
	self.handleFunctionForObject(self.defaultDblClickFunction, allSummariesObj, tbl.column);
epilog
	delete allSummariesObj;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVoyageListBuild" id="3f5382d0-03fb-4692-86a4-a25d85cab108">
        <updating/>
        <source>doVoyageListBuild() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	theVoyages : CM_VoyageSet;
	voyage : CM_Voyage;
	
begin

	// get all current voyages for this terminal.
	create theVoyages transient;
	self.myTerminal.getAllCurrentVoyages(theVoyages, true, false, false);
	
	self.lstVoyages.rows := 0;
	self.lstVoyages.zOrder(1);
	
	foreach voyage in theVoyages do
		self.lstVoyages.addItemObject(voyage.code,voyage);
	endforeach;
	self.lstVoyages.setSelected(theVoyages);
	
epilog
	
end;</source>
    </JadeMethod>
