<Class name="CM_SerialWeightIntControllerXX" id="28afbe7f-1bff-4528-a53b-7264a7a9829c">
    <superclass name="CM_SerialWeightIntController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <PrimAttribute name="isNoteActive" id="c780107d-abb3-4ac8-8133-9931570d6b24">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="connectedState" id="dcb0bd9b-e813-467b-bb79-1412376f1a9a">
        <source>connectedState(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWeighBridgeDetails" id="bcb55306-5ae6-429a-878d-e642059cd2fe">
        <source>getWeighBridgeDetails(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	name : String;
	stateString : String;
	listeningString : String;
	details : String;
	
begin
	
	if self.hasValidConnection then
		if self.mySerialDetails.myWeighBridgeObj &lt;&gt; null then
			name := self.mySerialDetails.myWeighBridgeObj.name;
		endif;
		if self.mySerialPort &lt;&gt; null then
			stateString := "Simulation - ";
			listeningString := "Listening";
		else
			stateString := "No Serial Port Configured";
		endif;

		details := name &amp; CrLf &amp; stateString &amp; Space &amp; listeningString;
	else
		details := null;
	endif;
	
	self.diagnosticLog(method.qualifiedName &amp; " myWeighBridgeObj=|" &amp; name &amp; "| state=" &amp; stateString &amp; "| listeningState=|" &amp; listeningString &amp; "|" );	

	return details;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="openEvent" id="178db170-bc50-4960-9309-2dbef8ebc024">
        <updating/>
        <source>openEvent(_connection: Connection) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	self.listeningState := self.Listening;
	
	self.hasValidConnection := true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="readEvent" id="f1c788be-c5cf-45a6-9cfc-ce9ab05c7016">
        <updating/>
        <source>readEvent(_connection: Connection; _binaryData: Binary) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
        <Parameter name="_binaryData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="startListening" id="a809c5dd-caf4-440b-9205-545337304cfc">
        <updating/>
        <source>startListening() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " registering for process notification");
	
	self.beginNotification(process, 64999, Response_Continuous, 0);
	self.isNoteActive := true;
	self.hasValidConnection := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stopListening" id="b74a7899-4eba-43e6-95a5-b12c2579df88">
        <updating/>
        <source>stopListening() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName);
	
	if self.isNoteActive then
		self.endNotification(process, 64999);
		self.isNoteActive := false;
	endif;
	
	self.listeningState := self.PendingDelete;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="af1db51d-6525-466e-9913-bffd855a0537">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	if theObject = process and eventType = 64999 then
		// Send the received weight back
		self.myWeightCallerInterface.sendWeight(userInfo.Decimal);

		if self.listeningState &lt;&gt; self.Listening then
			if self.myWeightCallerInterface &lt;&gt; null  then					//TFS 6865 
				self.myWeightCallerInterface.openEvent(self.mySerialPort);	//TFS 6865 
			endif;															//TFS 6865 
		endif;
			
		self.latestWeight := userInfo.Decimal;											//Bug 38134
		self.latestWeightSetAt := app.actualTimeServer;									//Bug 38134
		self.latestReturnValue := ")0 "&amp; userInfo.String.padBlanks(6) &amp; "     0";	//Bug 38134
		write self.latestWeightSetAt.formatAsYYYYMMDDHHMMSSMMM &amp; " |" &amp; self.latestReturnValue &amp; "| " &amp; self.latestWeight.String;

	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
