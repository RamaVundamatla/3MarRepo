    <JadeMethod name="clearAllInfo" id="9a21e30b-abf5-4d38-b3e4-bda9000d5290">
        <updating/>
        <source>clearAllInfo(_confirm : Boolean) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _confirm then
		if app.msgBox("Clear All Details?","Confirm",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;

	self.txtVehicle.text := null;
	self.txtAltID.text := null;
	self.txtLocation.text := null;
	self.txtVoyage.text := null;
	self.txtLocation.setFocus();

	self.doClearErrors();
	
end;


</source>
        <access>protected</access>
        <Parameter name="_confirm" type="Boolean"/>
    </JadeMethod>
