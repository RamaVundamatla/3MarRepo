<Class name="CMQF_OrganisationAccess">
    <JadeMethod name="setFromAgent" id="d0eeef83-f079-43a0-9505-75631ac4dfb4">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwjre1	Initial creation

*/
vars

begin
	inheritMethod(_agent);
	
	self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_DateTimeFrom);
	self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_DateTimeTo);

	if _agent.isRowIncluded(ETRow_SiteState) then
		self.allQrySites.clear;
		_agent.getSelectedSites(self.allQrySites);
	endif;

	if _agent.isRowIncluded(ETRow_Voyage) then
		self.setMyVoyage( _agent.getSelectedCellularVoyage() );
	endif;

	if _agent.isRowIncluded(ETRow_Organisation) then
		self.setMyOrganisation( _agent.getSelectedOrganisation() );
	endif;

	if _agent.isRowIncluded(ETRow_OrganisationUsers) then
		self.allUsers.clear;
		_agent.getSelectedUsers(self.allUsers);
	endif;
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
