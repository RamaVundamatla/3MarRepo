    <DbClassMap file="_usergui"/>
    <Constant name="Display_Both" id="27f0450d-b880-4182-83ef-a90e40c75ef8">
        <source>0</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Display_BreakBulkOnly" id="21a8c09a-b0c9-497e-9574-57cbc383ef9e">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Display_BulkOnly" id="0e63d891-ba6f-49a1-80ab-b34ad9921e90">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="showBulk" id="355b46fc-a611-4e6d-bd68-3ac31fa103e0">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="ae506fbb-c045-4e42-9e53-9d775de48ec0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _cargoType: CM_CargoType; lstIndex: Integer): String updating, clientExecution;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
vars

	isBulk	: Boolean;

begin
	if inheritMethod(combobox, _cargoType, lstIndex) = null then
		return null;
	endif;
	
	if not _cargoType.id &gt; TI_CargoBOLType_Max then 
		return null;
	endif;
	
	isBulk := _cargoType.isBulkProduct;
	
	if self.showBulk = Display_Both then
		// Continue without muking around
	elseif (isBulk and self.showBulk = Display_BreakBulkOnly) then
		return null;
	elseif not (isBulk and self.showBulk = Display_BulkOnly) then
		return null;
	endif;
	
	return _cargoType.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
