    <JadeMethod name="tblWLEChange" id="5b19d1e9-564b-4a79-ad36-a00eadc8fe51">
        <updating/>
        <source>tblWLEChange(_newRow: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_newRow);
	

	if self.myCurrentWLE = null then
		self.tblInfo.clear();
		self.tblInfo.rows := 0;
		return;
	endif;
		//sort out move btn.	
	if self.myCurrentWLE.myTrackedItem &lt;&gt; null then
		if self.myCurrentWLE.status = WLE_COMPLETED or self.myCurrentWLE.isPlanOnPickupNoTarget then
			self.btnMoveIt.enabled := false;
		else
			self.btnMoveIt.enabled := true;
		endif;
	else
		self.btnMoveIt.enabled := false;
	endif;
	
	

epilog

end;</source>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLEReceiveDrop" id="e9b36496-fbb0-49a9-86ea-cd0b53dac6f5">
        <updating/>
        <source>tblWLEReceiveDrop() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2009	cnwrd1	Initial creation

*/

vars

begin

	if app.myMoveController.moveMode = PLANNING_MODE then
		app.msgBox('Planning is not allowed in Yard Operations. Only instant moving and queueing of cargo item is permitted.','Plan mode not allowed',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	if (not global.isValidObject(self.myCurrentWLE)) then
		self.tblWLEChange(null);
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;	
	
	if self.myCurrentWLE.isQueued then
		app.msgBox(app.getErrorString(Pleas_unque_task_befor_assig_c),'Director Task Already Queued', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
		
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	

	//if app.myMoveController.moveMode = REAL_MODE then
	//	self.moveTrackedItem(self.getLocationController(), self.myCurrentWLE);
	//else
//		self.assignTIToReleaseRequest(self.myCurrentWLE);
//	endif;
	
	if self.myCurrentWLE.isKindOf (CM_YardWLE) and self.myCurrentWLE.isReceipt then
		//selected wle is a receipt, they could be sending it back to the vehicle
		self.moveTrackedItem(self.getLocationController(), self.myCurrentWLE);
	else //selected wle is a release
		self.assignTIToReleaseRequest(self.myCurrentWLE);
	endif;
	
	// This get done via notifications
	//self.tblWLEUpdateWle(self.myCurrentWLE, self.Mode_Update);	
	
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblWLEUpdateWle" id="2586503b-b1a0-4de6-9615-91946e97c6e6">
        <updating/>
        <source>tblWLEUpdateWle(_wle: CM_WorkListEntry; _mode: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwrd1	Initial creation

*/


vars
	taId,
	str		: String;
	col,
	rowIdx	: Integer;
	job		: CM_Job;
	wleArray	: CM_WLEArray;
begin
	
	if _mode = self.Mode_Delete or (not global.isValidObject(_wle)) then
		self.tblWorkEntries.removeItemObject(_wle);
		if _wle.String = self.myCurrentWLE.String then
			self.tblWLEChange(null);
		endif;		
		return;
	endif;

	
	if (not CM_WorkListEntry.hasInstance(_wle)) then
		return;
	endif;
	
	if self.includeWLE(_wle) 
	and self.filterJob(_wle.job) then
		self.updateAddWle(_wle, _mode);
	endif;


epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
