    <JadeMethod name="getFunctionCode" id="04cdab2c-60bd-477b-ba87-20310afb3445">
        <source>getFunctionCode(_description: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars

begin
	if _description = self.Function_ImportReleaseStopDesc then
		return self.Function_ImportReleaseStop;
	elseif _description = self.Function_ExportReleaseStopDesc then
		return self.Function_ExportReleaseStop;
	elseif _description = self.Function_ImportBayanStopDesc then
		return self.Function_ImportBayanStop;
	elseif _description = self.Function_ExportBayanStopDesc then
		return self.Function_ExportBayanStop;
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionDescription" id="cb0d0357-b7d3-432a-b4fa-fccc3e92e2eb">
        <source>getFunctionDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars

	code : Integer;
begin

	code := self.function;
	
	if code = self.Function_ImportReleaseStop then
		return self.Function_ImportReleaseStopDesc;
	elseif code = self.Function_ExportReleaseStop then
		return self.Function_ExportReleaseStopDesc;
	elseif code = self.Function_ImportBayanStop then
		return self.Function_ImportBayanStopDesc;
	elseif code = self.Function_ExportBayanStop then
		return self.Function_ExportBayanStopDesc;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
