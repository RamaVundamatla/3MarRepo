    <JadeMethod name="setForCreate" id="93cc8c4b-ce44-464f-bf6f-b18ae1a07ed8">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	inheritMethod(_pxySB);

	self.workOrderType := _pxySB.workOrderType;
	self.myTransMap := _pxySB.myTransMap;
	
	self.initialise(_pxySB.myTransMap.myBank);
end;</source>
