    <JadeMethod name="extractFile" id="42e924d4-09a8-4b07-9daa-4ab1be48cb20">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile io; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	LF:String = #"0A";
	CR:String = #"0D";
	FD:String = #"7E"; //field delimiter
vars
	ediTI : CM_EDITrackedItem;
	xlOperator : CM_Operator;
	voyageOid : CM_Voyage;
	now : TimeStamp;
	terminal : CM_Terminal;
	fileStr	: String;
	strTime	: String;
	ediData	: CM_EDIDataBayPlan;
	str : String;
begin

	terminal := app.myPassport.myTerminal;
	ediData := _ediFile.ediData.CM_EDIDataBayPlan;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	strTime := now.date.format('yyyyMMdd') &amp; now.time.format('hhmmss');

	if (not CM_EDIDataBayPlan.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	
	if _recipient = null then
		xlOperator := app.myRoot.allOperators[ediData.operatorCode];
	else
		xlOperator := _recipient;
	endif;
	
	if xlOperator = null and _recipient &lt;&gt; null then
		xlOperator := _recipient;
	endif;

	// Header
	fileStr := 'POLMAFH100'&amp;FD&amp;'N'&amp;FD&amp;'39'&amp;FD&amp;'1'&amp;FD&amp;'39'&amp;FD&amp;now.date.format('yyyyMMdd')&amp;FD&amp;'000039'&amp;FD&amp;ediData.vesselName&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;'0'&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;ediData.voyageCode&amp;FD&amp;'PLGDN'&amp;FD&amp;'1'&amp;FD&amp;ediData.departTime.date.format('yyyyMMdd')&amp;ediData.departTime.time.format('hhmmss')&amp;FD&amp;ediData.arriveTime.date.format('yyyyMMdd')&amp;ediData.arriveTime.time.format('hhmmss')&amp;FD&amp;ediData.arriveTime.date.format('yyyyMMdd')&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;''&amp;FD&amp;'0';
	str := str &amp; fileStr &amp; CrLf;
	fileStr := 'POLMAFD150'&amp;FD&amp;'N'&amp;FD&amp;'1'&amp;FD&amp;'PL'&amp;FD&amp;ediData.toPort&amp;FD&amp;'2'&amp;FD&amp;'To';
	str := str &amp; fileStr &amp; CrLf;
	fileStr := 'POLMAFD150'&amp;FD&amp;'N'&amp;FD&amp;'1'&amp;FD&amp;'PL'&amp;FD&amp;ediData.fromPort&amp;FD&amp;'2'&amp;FD&amp;'From GDANSK';
	str := str &amp; fileStr &amp; CrLf;
	str := str &amp; self.generateMessageBody(_ediFile);

	_ediFile.setNumContainers(ediData.allEDITrackedItems.size);
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="13212db2-9f7c-43c5-9881-a1c0a46da21e">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataBayPlan;
	_dataType := EDIDataType_BayPlan;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="generateMessageBody" id="75a93d6c-5164-47d7-8580-1df8a822f5a1">
        <updating/>
        <source>generateMessageBody(_ediFile: CM_EDIFile io) : String updating, protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
vars
	str : String;
	ediTI : CM_EDIBayPlanTI;
	lastEDITI : CM_EDIBayPlanTI;
	xlOperator: CM_Operator;
	dynaDict : DynaDictionary;
	iter : Iterator;
	bolID : String;
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_EDIBayPlanTI);
	dynaDict.addMemberKey(CM_EDIBayPlanTI::bol.name, false, true);
	dynaDict.addMemberKey(CM_EDIBayPlanTI::id.name, false, true);
	dynaDict.endKeys(true);
	_ediFile.ediData.allEDITrackedItems.copy(dynaDict);
	iter := dynaDict.createIterator();
	while iter.next(ediTI) do
//	foreach ediTI in _ediFile.ediData.allEDITrackedItems do
		if bolID = null then //firstTime thru
			bolID := ediTI.bol;
		endif;
		if ediTI.bol &lt;&gt; bolID then //changeOf bol
			str := self.getBOLDetails(ediTI.CM_EDIBayPlanTI);
			str := str &amp; CrLf;
		endif;
		str := self.getCarDetails(ediTI.CM_EDIBayPlanTI);
		str := str &amp; CrLf;
		bolID := ediTI.bol;
	endwhile;
	return str;
epilog
	delete dynaDict;
	delete iter;		// PAR #26678
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOLDetails" id="abacc5bb-3987-4bda-b8cf-463b8dcb7aa0">
        <source>getBOLDetails(_ediTI : CM_EDIBayPlanTI) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
constants
	LF:String = #"0A";
	FD:String = #"7E"; //field delimiter
vars
	str, tmpStr : String;
	pos : Integer;
begin
	tmpStr := _ediTI.rawEDIData;
	if tmpStr = null then
		//      POLMAFD300  ~   N  ~   2  ~   1  ~  JP680693   ~   0  ~   WLWH  ~  ~  ~  ~  ~  ~  HONDA MOTOR CO., LTD.~KOYO KAIUN CO., LTD.~RU~HONDA MOTOR RUS LLC.~17/2 KRYLATSKAYA ST.,~121614 MOSCOW,RUSSIA~ATTN: MR.SERGEY KAMENEV~PHONE:+7-495-745-20-80~ ~ 63  ~303~JPYOK~1 ~  ~FIHKO~1 ~6 ~162785.0000~115~   0  ~115~   AUTO  ~    
		str := 'POLMAFD300'&amp;FD&amp;'N'&amp;FD&amp;'0'&amp;FD&amp;'1'&amp;FD&amp;_ediTI.bol&amp;FD&amp;'0'&amp;FD&amp;'WLWH'&amp;FD&amp;FD&amp;FD&amp;FD&amp;FD&amp;FD&amp;                     FD&amp;                  FD&amp;FD&amp;                  FD&amp;                   FD&amp;                  FD&amp;                      FD&amp;                   FD&amp;     FD&amp; FD&amp;   FD&amp;FD&amp;FD&amp;   FD&amp;FD&amp;FD&amp;         FD&amp; FD&amp;'0'&amp;FD&amp; FD&amp;'AUTO'&amp;FD;
		return str;
	endif;
	pos := 1;
	str := tmpStr.cnEcGetNextLine(pos);
	return str;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarDetails" id="97dfacdd-32f6-4d6e-aa8b-b149326a6936">
        <source>getCarDetails(_ediTI : CM_EDIBayPlanTI) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
constants
	LF:String = #"0A";
	FD:String = #"7E"; //field delimiter
vars
	str, tmpStr : String;
	pos : Integer;
begin
	tmpStr := _ediTI.rawEDIData;
	if tmpStr = null then
		//      POLMAFD350  ~   N  ~   1  ~  ~   1~     UNT  ~  ~  ~  1436.0000                    ~12.2980~   99  ~   1  ~   0  ~   1  ~  ~  HONDA AUTOMOBILES ACCORD 4 DOOR 001 INVOICE NO.2~  ~  JHMCL96808C210272~ 
		str := 'POLMAFD350'&amp;FD&amp;'N'&amp;FD&amp;'1'&amp;FD&amp;FD&amp;'1'&amp;FD&amp;'UNT'&amp;FD&amp;FD&amp;FD&amp;_ediTI.weight.asStringWeightJMT()&amp;'.0000'&amp;FD&amp;     FD&amp;'99'&amp;FD&amp;'1'&amp;FD&amp;'0'&amp;FD&amp;'1'&amp;FD&amp;FD&amp;_ediTI.remarks&amp;                                 FD&amp;FD&amp;_ediTI.id&amp;       FD;      
		return str;
	endif;
	pos := 1;
	str := tmpStr.cnEcGetNextLine(pos);
	if pos &gt; tmpStr.length then
		return null;
	endif;
	str := tmpStr.cnEcGetNextLine(pos);
	return str;
end;


</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="1e26480b-2b8a-4211-b332-a148bd92f7cd">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	info			: StringArray;
	numMsgs			: Integer;
	msgCount		: Integer;
	int				: Integer;
	message			: String;
	vehicle			: CM_EDIBayPlanTI;
	passport		: CM_Passport;
	terminal		: CM_Terminal;
	ediDataBayPlan	: CM_EDIDataBayPlan;
	bolId			: String;
	dischargePort	: String;
	loadPort		: String;
	operator		: String;
	consignee		: String;
	consignor		: String;
	description		: String;
	rawBolData		: String;
	numCar			: Integer;
	numBol			: Integer;
	newBOLId		: String; //generated bolid
	now				: Date;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	ediDataBayPlan := _ediFile.ediData.CM_EDIDataBayPlan;
	create info transient;
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		int := int + 1;
		
		self.getRecordInfo(message, info);
	
		if info[1][4:7] = "MAFH100" then
			ediDataBayPlan.vesselName := info[8];
		elseif info[1][4:7] = "MAFD150" then
			if info[3] = '1' then
				dischargePort := info[5];
			elseif info[3] = '2' then
				loadPort := info[5];
			endif;
		elseif info[1][4:7] = "MAFD300" then
			bolId := now.formatAsYYMMDD[1:2]&amp;'DS'&amp;info[5];
			newBOLId := terminal.bolInNextSeqNumber;
			newBOLId := now.formatAsYYMMDD[1:2] &amp; "DS" &amp; newBOLId.String.padZeros(8)[1:8];
			numBol := 1;
			operator := info[7];
			consignee := info[15];
			consignor := info[13];
			description := info[34];
			rawBolData := message;
		elseif info[1][4:7] = "MAFD350" then
		
			create vehicle persistent;
			numCar := numCar + 1;
			if numCar &gt; 99 then
				numCar := 1;
				numBol := numBol + 1;
				newBOLId := terminal.bolInNextSeqNumber;
				newBOLId := now.formatAsYYMMDD[1:2] &amp; "DS" &amp; newBOLId.String.padZeros(8)[1:8];
			endif;
			vehicle.setForCreateNew(ediDataBayPlan);
			vehicle.setCargoType(TI_CargoType_Car);
			vehicle.setId(info[18]);
			vehicle.bol := newBOLId;
			vehicle.remarks := info[16];
			vehicle.operatorCode := operator;
			vehicle.loadPort := loadPort;
			vehicle.dischargePort := dischargePort;
			vehicle.setDescription(description);
			vehicle.weight := info[9].Decimal; //cnwrd1 ccms 1060 12.1.09
			vehicle.rawEDIData := rawBolData&amp;CrLf&amp;message;
		endif;
	endforeach;
epilog
	delete theLines;
	delete info;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
