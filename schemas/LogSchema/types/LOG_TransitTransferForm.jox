    <JadeMethod name="loadSelectionCombos" id="c226fc60-9128-4860-a03d-bfaa2e7f1d62">
        <updating/>
        <source>loadSelectionCombos() protected, updating;

vars

	voyage		: String;


begin

	voyage			:= self.tblSelection.getValueByName(ETRow_Voyage).String;
	self.myVoyage	:= self.myTerminal.lookupVoyage(voyage, null, false).CM_Voyage;

	if self.myVoyage &lt;&gt; null and self.myVoyage.myLogVoyageStructure &lt;&gt; null  then
		self.cmbDocket.listCollection(myVoyage.allBOLOutByTypeStatusNumDT, true, 0);
		self.cmbLot.listCollection(self.myVoyage.myLogVoyageStructure.allLogLots, true, 0);
		//self.cmbToVoyage.listIndex := self.cmbVoyageOLD.listIndex;
		self.cmbToVoyage.listIndex := self.cmbVoyage.listIndex;		
		self.tblActionData.setValueByName(ETRow_ToVoyage, self.myVoyage.code);
		self.loadDestination();
	else	
		self.cmbToVoyage.listIndex := 1;
		self.tblActionData.setValueByName(ETRow_ToVoyage, null);
	endif;

end;</source>
