    <DbClassMap file="_usergui"/>
    <Constant name="DEFAULT_HEIGHT" id="c411baa5-68ba-4905-8d93-baf231966862">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="create" id="09253c45-4343-4776-8676-c7deaa013c19">
        <updating/>
        <source>create() updating;

begin
	self.borderStyle		:=	0;
	self.caption			:=	null;
	self.height				:=	self.DEFAULT_HEIGHT;
//	self.bevelColor			:=	Window.Color_3DHighlight + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
	self.bevelColor			:=	self.getSystemColor(Window.Color_3DHighlight);		// cnwdad1 28/02/2003.
	self.bevelInner			:=	0;
	self.bevelInnerWidth	:=	0;
	self.bevelOuter			:=	1;
	self.bevelOuterWidth	:=	1;
//	self.bevelShadowColor	:=	Window.Color_3DDkShadow + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
	self.bevelShadowColor	:=	self.getSystemColor(Window.Color_3DDkShadow);		// cnwdad1 28/02/2003.
	self.boundaryBrush		:=	0;
	self.boundaryWidth		:=	0;
//	self.boundaryColor		:=	Window.Color_3DFace + CNEC_SYSTEM_COLOUR;			// cnwdad1 28/02/2003.
	self.boundaryColor		:=	self.getSystemColor(Window.Color_3DFace);			// cnwdad1 28/02/2003.
	self.show3D				:=	Control.Show3D_Use3D;
end;</source>
    </JadeMethod>
    <JadeMethod name="height" id="03a6fd2d-3a84-4f71-820e-ad837c49f04f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>height(set: Boolean; value: Real io) mapping, updating;

begin
	if set then
		value	:=	self.DEFAULT_HEIGHT;
		inheritMethod(set, value);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="move" id="d325a0ff-c5c2-48a5-b899-0f1a7063d42a">
        <source>move(x : Real; y : Real; width2 : Real; height2 : Real);

begin
	inheritMethod(x, y, width2, self.DEFAULT_HEIGHT);
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width2" type="Real"/>
        <Parameter name="height2" type="Real"/>
    </JadeMethod>
