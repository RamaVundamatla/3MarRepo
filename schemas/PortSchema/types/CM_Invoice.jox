    <JadeMethod name="getCNotesCopiedFromExtStr" id="96fd9d1b-c812-4bf3-aeac-9d68ed581efc">
        <source>getCNotesCopiedFromExtStr() : String;
/*

Purpose:		//16/10/2024	navkc1	JIRA Bug MTN-12541
				It's changed to be "Target Credit Note Ext", when user select Invoice and Created a credit note from it
				E.g
				Invoice 1 - Posted
				User select Invoice 1 and create credit note 2 from it.
				Invoice 1.allCreditCredits will have reference to Credit Note 2
				Credit Note 2.allCreditInvoices will have reference to Invoice 1.	

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 65269: Jade New Columns for Data Extract

*/

vars
	str			: String;
	inv			: CM_Invoice;
	
begin
	
	/* //16/10/2024	navkc1	JIRA Bug MTN-12541
	inv := self.myOtherInvoice;
	
	if inv &lt;&gt; null and inv.isCreditNote() then
		str := inv.externalNumber;
	endif;
	*/
	
	//16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach inv in self.allCreditCredits discreteLock do
		
		if inv.externalNumber = null then
			continue;
		endif;
		
		if str = null then
			str := inv.externalNumber;
		else
			str &amp;= "," &amp; inv.externalNumber;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCNotesCopiedFromStr" id="b6529f8f-9c73-4596-a9b4-3161711a2e76">
        <source>getCNotesCopiedFromStr() : String;
/*

Purpose:			
					//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Target Credit Note", when user select Invoice and Created a credit note from it
					E.g
					Invoice 1 - Posted
					User select Invoice 1 and create credit note 2 from it.
					Invoice 1.allCreditCredits will have reference to Credit Note 2
					Credit Note 2.allCreditInvoices will have reference to Invoice 1.
Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 65269: Jade New Columns for Data Extract

*/

vars
	str		: String;
	inv		: CM_Invoice;
begin
	
	/* //16/10/2024	navkc1	JIRA Bug MTN-12541
	inv := self.myOtherInvoice;
	
	if inv &lt;&gt; null and inv.isCreditNote() then
		str := inv.sequenceNum.asStringJMT();
	endif;
	*/
	
	//16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach inv in self.allCreditCredits discreteLock do
		if str = null then
			str := inv.sequenceNum.asStringJMT();
		else
			str &amp;= ", " &amp; inv.sequenceNum.asStringJMT();
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCNotesCopiedToExtStr" id="23b9c449-fa48-449f-a7a0-9d048ca7dc98">
        <source>getCNotesCopiedToExtStr() : String;
/*

Purpose:			//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Source Invoices Ext", when user select Invoice and Created a credit note from it
					E.g
					Invoice 1 - Posted
					User select Invoice 1 and create credit note 2 from it.
					Credit Note 2.allCreditInvoices will have reference to Invoice 1.
					Invoice 1.allCreditCredits will have reference to Credit Note 2

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 64895: Jade - New Columns for Invoice List

*/

vars
	str 		: String;
	invoice		: CM_Invoice;
	
begin
	
	/* //16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach invoice in self.allOtherInvoices discreteLock where invoice.isCreditNote() do
		//21/08/2024	navkc1 Bug 65741
		if invoice.externalNumber = null then
			continue;
		endif;
		if str = null then
			str := invoice.externalNumber.asStringJMT();
		else
			str &amp;= ", " &amp; invoice.externalNumber.asStringJMT();
		endif;
	endforeach;
	*/
	
	//16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach invoice in self.allCreditInvoices discreteLock do
		if invoice.externalNumber = null then
			continue;
		endif;
		
		if str = null then
			str := invoice.externalNumber;
		else
			str &amp;= ", " &amp; invoice.externalNumber; 
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCNotesCopiedToStr" id="64f1185f-8693-44e1-b4c6-2e89c05686fe">
        <source>getCNotesCopiedToStr() : String;
/*

Purpose:			//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Source Invoices", when user select Invoice and Created a credit note from it
					E.g
					Invoice 1 - Posted
					User select Invoice 1 and create credit note 2 from it.
					Credit Note 2.allCreditInvoices will have reference to Invoice 1.
					Invoice 1.allCreditCredits will have reference to Credit Note 2
					
Parameters:			

Return Value:		

Date		Who		Reason
09/08/2024	navkc1 CR 64894 Task 64895: Jade - New Columns for Invoice List

*/

vars
	str		: String;
	invoice	: CM_Invoice;
begin
	
	/* //16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach invoice in self.allOtherInvoices discreteLock where invoice.isCreditNote() do
		if str = null then
			str := invoice.sequenceNum.asStringJMT();
		else
			str &amp;= ", " &amp; invoice.sequenceNum.asStringJMT();
		endif;
	endforeach;
	*/
	
	//16/10/2024	navkc1	JIRA Bug MTN-12541
	foreach invoice in self.allCreditInvoices discreteLock do
		if str = null then
			str := invoice.sequenceNum.asStringJMT();
		else
			str &amp;= ", " &amp; invoice.sequenceNum.asStringJMT();
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCalculatedStorageDays" id="323f7622-8fe4-4fc5-95a2-201fb21a1320">
        <source>getCalculatedStorageDays():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2018	jlgndl1	Initial creation	TFS 42557

*/

vars

	invLine : CM_InvoiceLine;
	daysStored : Integer;

begin

	foreach invLine in self.invoiceLines discreteLock do		
		if invLine.status = CM_InvoiceLine.STATUS_VOIDED then
			continue;
		endif;
		daysStored := daysStored  + invLine.calculateStorageDays();
	endforeach;
	
	return daysStored; 

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
