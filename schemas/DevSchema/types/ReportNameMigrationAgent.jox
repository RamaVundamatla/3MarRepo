<Class name="ReportNameMigrationAgent" id="9365c582-04d0-4f78-9ca2-9bfeace8ffb0">
    <superclass name="LocalisationSupportAgents"/>
    <transient/>
    <subclassTransientAllowed/>
    <subschemaFinal/>
    <transientAllowed/>
    <DbClassMap file="translation"/>
    <JadeMethod name="createGlobalConstantsScm" id="44bfae06-0461-474e-a889-cece995e477f">
        <source>createGlobalConstantsScm();

vars
	root		: CM_Root;
	reportRoot	: CM_MenuRootReportForRoot;
	menuEntity	: CM_MenuEntity;
	menuItem	: CM_MenuItem;
begin
	root := CM_Root.firstInstance;
	reportRoot := root.myReportMenuRoot;
	foreach menuEntity in reportRoot.allMenuUserItemsWithAMenuItem do	// CM_MenuUserItemDictByMenuItem
		menuItem  := menuEntity.CM_MenuItem;
		
		// PENDING
app.writeStatement( menuItem.String);
	endforeach;
end;
</source>
    </JadeMethod>
</Class>
