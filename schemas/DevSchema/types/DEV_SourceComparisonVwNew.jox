        <source>refreshToolbar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2022	navpw1	Initial creation

*/

vars
	toolbar : CMUI_Toolbar;
	
begin
	toolbar := self.frmToolbar;
	
	toolbar.isPositionsCalculated := false;
