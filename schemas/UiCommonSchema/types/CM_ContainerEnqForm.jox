    <JadeMethod name="validateForm" id="2dd726d6-4bea-44ea-a08d-193adf0d9a5f">
        <source>validateForm():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2024	navsp1	Initial creation JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
31 Mar 2025		navah1  Bug 34351: CUX - Cargo Enquiry Selector Query
*/

vars
	clientRef	: String;
	state, site	: Integer;
	critLine    : CM_SelectorCriteriaLine;
	sites		: IntegerArray;			 // 31.03.2025 navah1 #34351
	myQueryOperator : CM_QueryOperator;  // 31.03.2025 navah1 #34351
begin
	create sites transient; 			 // 31.03.2025 navah1 #34351
	
	critLine  	:= self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
	if critLine &lt;&gt; null then
		state		:= critLine.myQueryOperator.getSearchValue.Integer;
	endif;
	
	critLine  	:= self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
	if critLine &lt;&gt; null then 
		myQueryOperator := critLine.myQueryOperator;         // 31.03.2025 navah1 #34351
		if myQueryOperator.isKindOf(CM_QIntegerIsOneOf) then // 31.03.2025 navah1 #34351
			sites.tryCopyFrom(myQueryOperator.getSearchValue.IntegerArray);
		elseif myQueryOperator.isKindOf(CM_QIntegerLookupEqual) then
			site := myQueryOperator.getSearchValue.Integer; 
			sites.tryAdd(site);
		endif;
	endif;
	
	critLine  	:= self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::clientRef.name);
	if critLine &lt;&gt; null then
		clientRef 	:= critLine.myQueryOperator.getSearchValue.String;
	endif;
	
	//if clientRef &lt;&gt; null and (state = TI_STATE_UNDEFINED or state = null or state = TI_STATE_OFFSITE or site = TI_SITE_OFFSITE or site = TI_SITE_UNDEFINED) then // 31.03.2025 navah1 #34351
	if clientRef &lt;&gt; null and (state = TI_STATE_UNDEFINED or state = null or state = TI_STATE_OFFSITE or sites.includes(TI_SITE_OFFSITE) or sites.includes(TI_SITE_UNDEFINED)) then // 31.03.2025 navah1 #34351
		if app.msgBox("The search may take a considerable time to finish. Would you like to continue?", "Warning!", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No	then
			return false;
		endif;
	endif;
	return true;
	
epilog 
	delete sites;  // 31.03.2025 navah1 #34351
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zAutomationDoEnquiry" id="aea67a7d-bc8a-4db1-82d8-97c560abcc05">
        <updating/>
        <source>zAutomationDoEnquiry(_queryKey: String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	crit : CM_SelectorCriteriaLine;
	ct, filterCT : CM_CargoType;

begin
	inheritMethod(_queryKey);

	// set up the data key - check whether we have a cargo type
	foreach ct in app.myRoot.allCargoTypesById discreteLock do
		if ct.description = _queryKey then
			filterCT := ct;
			break;
		endif;
	endforeach;
	// we found a cargo type
	if filterCT &lt;&gt; null then
		self.filterCargoTypeId := filterCT.id;
		self.zAutomationSetSearchTable(_queryKey, "Cargo Type");
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
		if crit &lt;&gt; null then
			crit.myQueryOperator.setSearchValue(_queryKey);
		endif;
	else
		// assume we have a cargo id
		self.filterId := _queryKey;
		self.zAutomationSetSearchTable(_queryKey, "Cargo ID");
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		if crit &lt;&gt; null then
			crit.myQueryOperator.setSearchValue(_queryKey);
		endif;
		// don't default to any particular cargo type
		self.filterCargoTypeId := null;
		self.zAutomationSetSearchTable(null, "Cargo Type");
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
		if crit &lt;&gt; null then
			crit.myQueryOperator.setSearchValue(null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_queryKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="zAutomationShowData" id="9f9064ab-de82-4307-ae7d-68461c01a7ea">
        <updating/>
        <source>zAutomationShowData(_cntrl : Control io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars

begin
	inheritMethod(_cntrl);
	
	if _cntrl.isKindOf(CM_EntryTable) and _cntrl.parent.isKindOf(CMUI_Sheet) then
		self.showThumbnailDataForSheet(_cntrl.parent.CMUI_Sheet, false);
	endif;

epilog

end;</source>
        <Parameter name="_cntrl" type="Control" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zDoSave" id="9765ac18-3aa7-489d-96e0-f835e15cd15b">
        <updating/>
        <source>zDoSave(): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2022	navsrk20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11/07/2023	navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
01/08/2023	navcs2	ChangeRequest 59569: EUP - Damage | Cargo Saving and Discrepancy order
*/

vars
	dosave : Boolean;
	pxyCount,
	realCount : Integer;
	damage	: CM_DamageInstance;
	pxyTrackedItem	: CM_TrackedItem;
begin
	pxyTrackedItem := self.myProxyObject.CM_TrackedItem;
	
	// 11/07/2023 navcs2 Bug 59045
	// Changed the order of the if statement and the inherit method
	// to make the user flow make more sense and fix transaction order
	foreach damage in pxyTrackedItem.allDamageInstancesByPos do
		if damage.status = DamageStatusRepaired then
			pxyCount += 1;
		endif;
	endforeach;
	
	foreach damage in self.myCurrentObject.CM_TrackedItem.allDamageInstancesByPos do
		if damage.status = DamageStatusRepaired then
			realCount += 1;
		endif;
	endforeach;
	/*
	if self.isDamageChanged then
		if pxyTrackedItem.canGetRepairedDetails() and (pxyCount &gt; realCount) then
			self.doShowRepairDetailsForm();
		endif;
	endif;
	*/
	dosave := inheritMethod();	
	return dosave;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoThumbnailContextMenu" id="97be823f-0c33-4130-9caf-4044b92674d3">
        <updating/>
        <source>zDoThumbnailContextMenu(x: Integer; y: Integer; mouse: Boolean): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then 
		return inheritMethod(x, y, mouse);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="mouse" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zShowSearcher" id="2f6e8a55-4362-4fd3-9996-e66c13e769dd">
        <updating/>
        <source>zShowSearcher() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row			: Integer;
	tbl			: CM_EntryTable;
begin
	inheritMethod();
	//PAR 6284 - automatically select the ID filed if it is populated
	
	
	tbl := self.tblSearch;

	if tbl.getValueByName(ETRow_FilterId) &lt;&gt; null then
		tbl.goToRowByName(ETRow_FilterId);
	endif;
	
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyDelete" id="fb8e003d-ab96-4633-a04e-7f89e063f6b6">
        <updating/>
        <source>zTblDataSysNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(eventType, theObject, eventTag);
	if (not self.useTblData) then
		if self.mode = Mode_View and theObject = self.myCurrentObject then
			app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only + MsgBox_Information_Icon);
			self.myCurrentObject := null;
			self.zClearThumbnailData();
		endif;
		return;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyUpdate" id="bfcfeecd-fc66-4ae7-bb59-62f8525415da">
        <updating/>
        <source>zTblDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
//--------------------------------------------------
// Created:	11 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if CM_BOL.hasInstance(self.myCurrentObject)
	and CM_TrackedItem.hasInstance(theObject) then
		// check an item on the BOL may have been upated
		if theObject.CM_TrackedItem.myReceivalBOL = self.myCurrentObject then
			inheritMethod(eventType, self.myCurrentObject, eventTag);		
		endif;
	else
		inheritMethod(eventType, theObject, eventTag);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
