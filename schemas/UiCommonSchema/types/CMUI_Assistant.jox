    <JadeMethod name="setAllPortCodes" id="d1053639-0dd4-41fd-aebb-cd99f37a90e6">
        <executionLocation>server</executionLocation>
        <source>setAllPortCodes(_voyage: CM_Voyage) serverExecution;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	port			: Any;
	loadStateSet	: Boolean;
	portColl		: Collection;
begin

	// Using new port display collections assistant.
	return;
	if self.allPortCodes.isEmpty then
		if _voyage = null then
			portColl := app.myRoot.allPorts;
		else
			portColl := _voyage.allPorts;
		endif;
		app.cmsBeginLoad(loadStateSet);
		foreach port in portColl do
			self.allPortCodes.add(self.displayEntryPort(port.CM_Port));
		endforeach;
	endif;

epilog
	app.cmsEndLoad(loadStateSet);
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setAllVoyageCodes" id="9616a924-c478-49bf-9222-db12d338058f">
        <source>setAllVoyageCodes(reset, _includeArchived : Boolean) protected;
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	//voyageCol	: CM_VoyageByCodeDict;
	voyageCol	: CM_VoyageByCodeArrivalDTDict;
	iter 		: Iterator;
	voy 		: CM_Voyage;
	keyStr		: String;
	ls			: Boolean;
	date		: Date;
	arriveDate	: TimeStamp;
begin

	//Reset allows you to dump current collection and start again
	//if desired. Otherwise we only build the collection once
	if self.allVoyageCodes.size &gt; 0 then
		if reset then
			self.allVoyageCodes.clear;
		    self.allVoyages.clear;
		else
			return;
		endif;
	endif;
	
	voyageCol := self.myTerminal.allVoyagesNew;
	date := app.actualTimeServer().date;

	app.cmsBeginLoad(ls);	
	iter := voyageCol.createIterator;
	while iter.next(voy) do
	    if (not _includeArchived) and (voy.myTerminalArchived &lt;&gt; null) then
	    	continue;
	    endif;
		iter.getCurrentKeys(keyStr, arriveDate);  //MTN-35226
		// include voyages where the departure is today and/or beyond
		if (not voy.departedDT.isValid) 
		or voy.departedDT.date &gt;= date 
		or _includeArchived then
		   	keyStr :=  keyStr.trimBlanks &amp; Tab &amp; voy.description.trimBlanks;
		   	if (not self.allVoyageCodes.includes(keyStr)) then
		    	self.allVoyageCodes.add(keyStr);
			    self.allVoyages.add(voy);	    	
			endif;			  
	  	endif;
	endwhile;

epilog
	app.cmsEndLoad(ls);
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="reset" type="Boolean"/>
        <Parameter name="_includeArchived" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCarrierTransportMode" id="18b77457-d57b-46f0-840c-2f7c146eccc6">
        <source>setCarrierTransportMode(_cmbCarrier : CMUI_ComboCarrier; _transportMode : String);
/*
Date		Who		Reason
08/06/2010	cnwas3	24344
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
*/

vars
	cmbCarrier : CMUI_ComboCarrier;
begin
	cmbCarrier := _cmbCarrier;
	
	if _transportMode = BR_TYPE_ROAD_STR then									// PAR #27972
		cmbCarrier.setTransportMode(BR_TYPE_ROAD);

	elseif _transportMode = BR_TYPE_RAIL_STR  then								// PAR #27972
		cmbCarrier.setTransportMode(BR_TYPE_RAIL);
	
	elseif _transportMode = BR_TYPE_PACKING_STR then							// PAR #27972
		cmbCarrier.setTransportMode(BR_TYPE_PACKING);
	
	elseif _transportMode = BR_TYPE_SHIP_STR then								// PAR #27972
		cmbCarrier.setTransportMode(BR_TYPE_SHIP);
	
	else
		cmbCarrier.setTransportMode(BR_TYPE_INVALID);
	endif;
epilog

end;</source>
        <Parameter name="_cmbCarrier" type="CMUI_ComboCarrier"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setColourDetails" id="9efabfad-bb77-4908-b912-66a4c4f30c95">
        <source>setColourDetails(_colours : String; _lstTable : CMUI_ListTableColour input; _textbox : CMUI_TextBox input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	colours	: StringArray;
	col		: String;
	colour 	: CM_VehicleColour;
	colDict	: CM_VehicleColourByColour;

begin
	if self.myTerminal.getConfig(ValidateColour).Boolean then
		create colours transient;
		create colDict transient;
		colours := _colours.getTokens();
		
		foreach col in colours do
			col := col.toUpper;
			colour := app.myDutyDocRoot.allVehicleColours[col];
			if colour &lt;&gt; null then
				colDict.add(colour);
			endif;
		endforeach;
		
		_lstTable.setSelected(colDict);
		if app.myCurrentUserCan(self.myTerminal, PmAdmVehicleColourMaint) then
			_lstTable.accessCell(1,1).inputType := null;
			_lstTable.accessedCell.text := null;
		endif;
		_lstTable.lostFocus(_lstTable);
	else
		if _textbox &lt;&gt; null then
			_textbox.text := _colours;
		endif;
	endif;
epilog
	delete colours;
	delete colDict;
end;</source>
        <Parameter name="_colours" type="String"/>
        <Parameter name="_lstTable" type="CMUI_ListTableColour" usage="input"/>
        <Parameter name="_textbox" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCurrentVoyageCodes" id="0bcd2850-5ff9-458f-bbec-17d3389348cd">
        <updating/>
        <source>setCurrentVoyageCodes(	_reset,
						_includeNonPlannedWorked,
						_includeArchived,
						_includeDeparted,
						_includeNullVoyage,
						_includeLogVoyage,
						_includeGCVoyage,
						_excludeInward : Boolean) updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 28 October 2003
//********************************************************************
//17 Jun 2025	jlier1	JIRA MTN-35088 - do the check of user access at the end this caused performance issues
vars
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	checkDT		: TimeStamp;
	gracePeriod	: Integer;
	str			: String;
	iter		: Iterator;
	failedDAC 	: CM_DataAccessController;
	
begin
	// DOES NOT INCLUDE NON CELLULAR VOYAGES e.g. Log and HMS voyages
	thePassport := app.myPassport;
//********************	
	if _reset then
		self.allVoyageCodes.clear;
		self.allVoyages.clear;		
	endif;
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	 // 11.02.2019 cnwma1 #43466

	
	// lorcan change to reflect new arrivaldate jey in dict - no other changes 
	if _includeArchived then
		iter := self.myTerminal.allVoyagesSet.createIterator();
	else
		iter := self.myTerminal.allVoyagesNew.createIterator();		
	endif;
	
	while iter.next(aVoyage) do
		if (not _includeNullVoyage and aVoyage.isNullVoyage()) then
			continue;
		endif;
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
		if aVoyage.myCellularVoyageStructure = null then
			if (_includeLogVoyage and aVoyage.myLogVoyageStructure &lt;&gt; null)
			or (_includeNonPlannedWorked and aVoyage.isHOLDSorSHIP()) // PAR 34866
			or (_includeGCVoyage and aVoyage.myGeneralCargoVoyage &lt;&gt; null) 
			//PAR16254 - Need to still include null voyage for non containerised voyages
			or (_includeNullVoyage and aVoyage.isNullVoyage)// then
			or aVoyage.myHMSVoyageData &lt;&gt; null 
			or aVoyage.isKindOf(CM_VoyageInlandTerminal) then
			//changed by cnwyl1 for par 15713
			//the inland termianl voyage should be displayed in the comboxVoyageCurrent.
			// carry on
			else
				continue;
			endif;
		endif;
		
		if (not _includeArchived) then
			if (aVoyage.archived) or (aVoyage.myTerminalArchived) &lt;&gt; null then
				continue;
			endif;
			
			if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue; 
			endif;
			
		endif;
		
		if (not _includeNonPlannedWorked) then
		/* PAR 33644 WAS
			if (aVoyage.isNonPlannedVoyage or aVoyage.isNonWorkedVoyage) then
				// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
				if aVoyage.isNonPlannedOrNotCellularRORO then
					continue;
				endif;
			endif;
			NOW */
			
			if aVoyage.isHOLDSorSHIP() then
				continue;
			endif;
		endif;

		if (not _includeDeparted) then
			 // CCMS 1423
			if (not aVoyage.isActiveDisplay(checkDT)) then
				continue;
			endif;
		endif;
		
		if (not aVoyage.canUserAccessSelf(null, failedDAC, thePassport)) then
			continue;
		endif;
		
		
		// PAR11740
		str :=  aVoyage.code &amp; Tab &amp; aVoyage.description; 		
		if self.allVoyageCodes.includes(str) then
			//Already add, use inward code instead		
			if _excludeInward then
				// don't include inward code
				str := null;					
			else
				str := aVoyage.inwardCode &amp; Tab &amp; aVoyage.description;
			endif;
		endif;
		
		if str &lt;&gt; null then
		    self.allVoyageCodes.add(str); 
		    self.allVoyages.add(aVoyage);
	   endif;
	    str := null;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_includeNonPlannedWorked" type="Boolean"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_includeDeparted" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
        <Parameter name="_includeLogVoyage" type="Boolean"/>
        <Parameter name="_includeGCVoyage" type="Boolean"/>
        <Parameter name="_excludeInward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setListTableHazards" id="597ac62c-e059-4c90-a892-1bebdcb68655">
        <source>setListTableHazards(pLstHazard : CMUI_HazardsListTable input; pHazards : StringArray);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	hazCode		: String;
	hazard		: CM_HazardClass;
	objArray	: ObjectArray;

begin

	create objArray transient;
	
	if pHazards &lt;&gt; null then
		foreach hazCode in pHazards do
			hazard := app.myRoot.allHazardClasses[hazCode];
			if hazard &lt;&gt; null then
				objArray.add(hazard);
			endif;
		endforeach;
	endif;
	
	
	pLstHazard.setSelected(objArray);

epilog
	if objArray &lt;&gt; null then
		delete objArray;
	endif;
end;</source>
        <Parameter name="pLstHazard" type="CMUI_HazardsListTable" usage="input"/>
        <Parameter name="pHazards" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setListTableMTGrade" id="d69ccefe-36a9-4372-bd68-0d0e1cff4c81">
        <source>setListTableMTGrade(pLstMTGrade : CMUI_ListTable io; pMTGrades : IntegerArray);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mtGrade		: CM_MTGrade;
	code		: Integer;
	objArray	: ObjectArray;
	tmpRoot		: CM_Root;
begin

	create objArray transient;
	
	tmpRoot := app.myRoot;
	
	if pMTGrades &lt;&gt; null then
		foreach code in pMTGrades do
			mtGrade := tmpRoot.allAvailableAvailabilityGrades[code];
			if mtGrade &lt;&gt; null then
				if (not objArray.includes(mtGrade)) then
					objArray.add(mtGrade);
				endif;
			else
				// CCMS 1235
				mtGrade := tmpRoot.allAvailabilityGrades[code];
				if mtGrade &lt;&gt; null then
					pLstMTGrade.addItemObject(self.displayEntryMTGrade(mtGrade),mtGrade);
					if (not objArray.includes(mtGrade)) then
						objArray.add(mtGrade);
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	pLstMTGrade.setSelected(objArray);

epilog
	if objArray &lt;&gt; null then
		delete objArray;
	endif;
end;</source>
        <Parameter name="pLstMTGrade" type="CMUI_ListTable" usage="io"/>
        <Parameter name="pMTGrades" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setListTablePorts" id="983b95d4-b99b-4cfe-9582-0ef1e5b5b4e1">
        <source>setListTablePorts(_list : CMUI_ListTable input; _coll : StringArray);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2012	cnwcs5		Minor tweaks
// ---------------------------------------------------------------------------
vars
	portCode	: String;
	port		: CM_Port;
	array		: ObjectArray;
	portColl	: CM_PortByCodeDict;
begin

	create array transient;
	
	if _coll &lt;&gt; null then
		portColl := app.myRoot.allActivePorts;
		
		foreach portCode in _coll do 
			port := portColl[portCode];
			
			if port &lt;&gt; null then
				array.add(port);
			endif;
		endforeach;
	endif;
	
	_list.setSelected(array);

epilog
	delete array;
end;</source>
        <Parameter name="_list" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_coll" type="StringArray"/>
    </JadeMethod>
