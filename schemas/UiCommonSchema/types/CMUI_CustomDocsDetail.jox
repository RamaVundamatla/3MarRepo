    <JadeMethod name="setProxyForCargoReview" id="c9853f55-17a5-4526-8594-674a2f46de6d">
        <updating/>
        <source>setProxyForCargoReview(_pxy : CM_CustomDocumentDetail) updating;
/*
Purpose:			

Date		Who		Reason
25 August 2023	navab1	CR 59942 TASK 59943 
*/

vars

begin
	if _pxy = null then
		return;
	endif;
	
	self.myProxyDetail := _pxy;
	self.myCustDocDetail := _pxy;
	
	self.allCustomDetails.clear();
	_pxy.allSubDetails.copy(self.allCustomDetails);
	self.mode := CMUI_CustomDocsMaint.Cargo_Review_Mode;
epilog

end;</source>
        <Parameter name="_pxy" type="CM_CustomDocumentDetail"/>
    </JadeMethod>
