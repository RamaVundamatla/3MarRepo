    <PrimAttribute name="timestampClient" id="f7a63541-aacb-4c79-b2cd-9befdf926a73">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timestampServer" id="a95984e0-1a1e-4131-88b0-eb0262eda576">
