    <JadeMethod name="cloneMySelf" id="7668d3c5-5e7b-47bd-9b53-1244d2f99d34">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
// ---------------------------------------------------------------------------
// Created:     14 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	newMoveResource : HMS_ResourceTypeForMovement;
	resourceType :  HMS_ResourceType;
begin
	
	newMoveResource := self.cloneSelf(_transient);
	newMoveResource.myHarbour := self.myHarbour;
	
	foreach resourceType in self.allResourceTypes do
		newMoveResource.allResourceTypes.add(resourceType);
	endforeach;
	
	
	return newMoveResource;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="49b62a13-4f94-42ac-90df-9ddcf3721b61">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = HMS_ResourceTypeForMovement::myHarbour then	
		return HMS_Harbour::code;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="2b0093e8-af22-4499-95a8-e0f4add4e58f">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = HMS_ResourceTypeForMovement::allResourceTypes then
		return ExportAsChild;
	elseif _property = HMS_ResourceTypeForMovement::myHarbour then
		return ExportAsChild;
	endif;
	
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="d9c14f83-0ae8-4625-956e-8cde8f1306e3">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     16 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.myHarbour.description &amp; ' - ' &amp; self.movementType;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3ea0de83-ad30-48d0-8801-1aba3a2d820f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str 	: String;
	resourceType : HMS_ResourceType;

begin	

	if _attrName = ETRow_MyHarbourResource then
		return (self.myHarbour.description);
	elseif _attrName = ETRow_MoveType then
		return (self.movementType);
	elseif _attrName = ETRow_ResourceTypes then
		foreach resourceType in self.allResourceTypes do
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; resourceType.code; 
		endforeach;	
		return (str);
	elseif _attrName = ETRow_NumTugsForMovement then
		return (self.numTugsForMovement.String);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTypeString" id="cce86282-8456-4c13-b045-73ede44cd46b">
        <source>getDisplayTypeString(): String;
// ---------------------------------------------------------------------------
// Created:     16 February 2005	cnwhjg1
//
