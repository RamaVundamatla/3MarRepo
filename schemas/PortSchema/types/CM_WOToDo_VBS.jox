<Class name="CM_WOToDo_VBS" id="d8a95787-9029-430e-aaba-d4aa882e36c0">
    <superclass name="CM_WOTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getVBSCode" id="8badc5a7-fc98-4a3a-b6c3-6bf13da7d2ae">
        <source>getVBSCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Queryy
04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodToDoVBS.allVBSSlots.isEmpty() then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodToDoVBS.allVBSSlots.listStringNoDuplicate(Comma, CM_VehicleBookingTimeSlot::id.name); // 04.08.2023 navlw1 tfs #59284:#59660
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
