    <JadeMethod name="setForCreate" id="91dd6f6e-6d64-43a1-91fb-53f4f727598a">
        <updating/>
        <source>setForCreate(_bol : CM_BOL; _type : Integer) updating;

// cnwdvb1 12 June 2003 

vars

	voyage : CM_Voyage;

begin

	self.dateTime	:= app.serverTimestampAtTrxStart;
	self.type		:= _type;
	self.myBOL 		:= _bol;
	
	//18 Nov 2019	NDL	TFS 47100
	if self.myBOL &lt;&gt; null then
		if self.myBOL.myOperator &lt;&gt; null then
			self.operatorCode := self.myBOL.myOperator.code;
		endif;
		voyage := self.myBOL.getMyVoyage;
		if voyage &lt;&gt; null then
			if voyage.myOperator &lt;&gt; null then
				self.operatorShipCode := voyage.myOperator.code;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="a41a625a-0ec5-431e-b107-7f109d476516">
        <updating/>
        <source>setForUpdateResync(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
18 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars
	bu : CM_Bank;
begin
	
	bu := self.getMyBank();
	
	if bu = null then
		app.invLog("No business unit, no charge", LogINFO.String);
		return;
	endif;
	
	 // ### JIRA 35228 11JUL2025 NAVAB1
	if self.myTerminal &lt;&gt; null
	and not self.myTerminal.getConfig(FinancialsEnabled).Boolean then
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  
		return;
	endif;
	
	bu.createChargeBOLResync(self);
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="dcc024ac-aa26-41e9-98d8-e52dbeaf307a">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_cmifCntrl : CMIF_TITransactionController; _passport : CM_Passport) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 October 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	bol : CM_BOL;
begin
	bol := _cmifCntrl.myBOL;
	if bol &lt;&gt; null then	//04 Nov 2019	NDL	TFS 47100
		self.myTerminal := bol.getMyTerminal();
	endif;
	self.userId := _passport.getUserCode;
	self.setForCreate(bol, global.getTiTxnTypeForClass(self.class));
epilog
end;</source>
        <Parameter name="_cmifCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
