    <JadeMethod name="loadMissingMethods" id="f6b7696a-2470-4a4b-8c85-43aca1c3bb37">
        <source>loadMissingMethods(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	devMethod 		: DEV_Method;
	addedSchema,
	addedClass 		: Boolean;
	showResolved	: Boolean;
	classCount,					//30.07.2025 navah1 #34749
	methodCount,    			//30.07.2025 navah1 #34749
	classIndex,					//30.07.2025 navah1 #34749
	schemaIndex		: Integer;  //30.07.2025 navah1 #34749
begin
	showResolved := self.chkShowResolved.value;
	
	foreach schema in _report.allSchemas do
		addedSchema := false;
		classCount := 0; //30.07.2025 navah1 #34749
		foreach class in schema.allClasses where class.reason = DEV_SourceCompareReportAgent.Object_Link do
			addedClass := false;
			methodCount := 0; //30.07.2025 navah1 #34749
			foreach devMethod in class.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if (_userCode &lt;&gt; null and devMethod.modifiedBy &lt;&gt; _userCode) or (devMethod.resolvedBy &lt;&gt; null and not showResolved) then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbMissingMethods.addItem(schema.name);
					self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := schema;
					self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 1;
					self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
					else
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbMissingMethods.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbMissingMethods.addItem(class.name);
					self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := class;
					self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 2;
					self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
					if class.resolvedBy &lt;&gt; null then
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
					else
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedClass := true;
					classIndex := self.qlbMissingMethods.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				self.qlbMissingMethods.addItem(devMethod.name);
				self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := devMethod;
				self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 3;
				self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
				if devMethod.resolvedBy &lt;&gt; null then
					self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
				else
					self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
				endif;
				methodCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			 
			if methodCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbMissingMethods.itemText[classIndex] := app.getErrorString2(LabelWithValue, class.name, methodCount.String);
				classCount += methodCount; 
			endif; 
		endforeach;
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbMissingMethods.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;

end;</source>
