    <JadeMethod name="getSelectedHMSDate" id="29470722-d862-4f74-a7a2-dccbc9cdcaf5">
        <source>getSelectedHMSDate(_attribute : String) : Date;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// 19 July 2018	jlgrh7 TFS #39280 LNX - Cannot select default value for ETA and ETD in Report Maintenance
// -------------------------------------------
vars

begin

	if _attribute = ETRow_ArrivalsDateFrom or 
	   _attribute = ETRow_MovementDateFrom then
		return self.arriveDFrom;
	elseif _attribute = ETRow_ArrivalsDateTo or 
	   _attribute = ETRow_MovementDateTo then
		return self.arriveDTo;
	elseif _attribute = ETRow_DepartedDateFrom then
		return self.departDFrom;
	elseif _attribute = ETRow_DepartedDateTo then
		return self.departDTo;
	elseif _attribute = ETRow_InPortDateFrom then
		return self.inPortDFrom;
	elseif _attribute = ETRow_InPortDateTo then
		return self.inPortDTo;
	elseif _attribute =ETRow_ExpectedArrivalDateFrom then				//+TFS39280
		return self.estimatedArrivalDFrom;
	elseif _attribute= ETRow_ExpectedArrivalDateTo then
		return self.estimatedArrivalDTo;
	elseif	_attribute=ETRow_ExpectedDepartDateFrom then
		return self.estimatedDepartDFrom;
	elseif _attribute=ETRow_ExpectedDepartDateTo then
		return self.estimatedDepartDTo;
		
	endif;
end;</source>
        <Parameter name="_attribute" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getSelectedHMSTime" id="e04cd07f-b834-4813-9468-f1f7dfdd077f">
