    <JadeMethod name="getDelimitedRecord" id="915fd893-3dcf-4887-b236-89df08df4bf7">
        <source>getDelimitedRecord(pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Method:		getTabDelimitedRecord
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------

vars
	fieldObj		: CnEcFileField;
	record			: String;
	fieldDelimiter	: String;

begin
	fieldDelimiter	:=	pDelimiter;

	if (fieldDelimiter = null) then
		fieldDelimiter	:=	Tab;
	endif;

	foreach fieldObj in self.allFields do
		if (record = null) then
			record	:=	fieldObj.fieldValue;
		else
			record	:=	record &amp; fieldDelimiter &amp; fieldObj.fieldValue;
		endif;
	endforeach;
epilog
	return record;
end;</source>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDelimitedRecordWithNames" id="5d763e97-9091-4645-829d-b831c5c71259">
        <source>getDelimitedRecordWithNames(pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Method:		getDelimitedRecordWithNames
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
vars
	fieldObj		: CnEcFileField;
	record			: String;
	fieldDelimiter	: String;

begin
	fieldDelimiter	:=	pDelimiter;

	if (fieldDelimiter = null) then
		fieldDelimiter	:=	Tab;
	endif;

	foreach fieldObj in self.allFields do
		if (record = null) then
			record	:=	fieldObj.fieldName &amp; "=" &amp; fieldObj.fieldValue;
		else
			record	:=	record &amp; fieldDelimiter &amp; fieldObj.fieldName &amp; "=" &amp; fieldObj.fieldValue;
		endif;
	endforeach;
epilog
	return record;
end;</source>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="361ee958-4994-4fe0-b00e-ce985b4ac701">
        <updating/>
        <source>set(pDefinitionObj:CnEcFileDefinition;
	pRecordNo:Integer;
	pRecordType:String;
	pIsValid:Boolean;
	pIsHeader:Boolean;
	pIsTrailer:Boolean) updating;
// --------------------------------------------------------------------------------
// Method:		set
//
// Purpose:		Public interface to set the Record properties.
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
begin
	if (self.recordNo &lt;&gt; pRecordNo) then
		self.recordNo := pRecordNo;
	endif;

	self.recordType	:=	pRecordType;
	self.isValid	:=	pIsValid;
	self.isHeader	:=	pIsHeader;
	self.isTrailer	:=	pIsTrailer;

	self.myFileDefinition := pDefinitionObj;
end;</source>
        <Parameter name="pDefinitionObj" type="CnEcFileDefinition"/>
        <Parameter name="pRecordNo" type="Integer"/>
        <Parameter name="pRecordType" type="String"/>
        <Parameter name="pIsValid" type="Boolean"/>
        <Parameter name="pIsHeader" type="Boolean"/>
        <Parameter name="pIsTrailer" type="Boolean"/>
    </JadeMethod>
