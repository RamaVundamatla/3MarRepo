    <JadeMethod name="addControlsForStockOrderLine" id="dbcac0d6-c1ec-4bb4-ac09-f7c2e492f488">
        <updating/>
        <source>addControlsForStockOrderLine(_stockOrderProductLine : CM_StockOrderProductLine; _row : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowIdx : Integer;
	tblDetail  : CM_DataTable;
	orderLine	: CM_StockOrderProductLine;
	newCombo 			: CMUI_ComboBox;
	newText		: CMUI_TextBox;
	cargoType : CM_CargoType;
	product	: CM_Product;

begin

	rowIdx := _row;
	orderLine := _stockOrderProductLine;
	tblDetail := self.tblDataDetail;
	self.newIndex := self.newIndex + 1;

	// call this here as backcolour for linetype cell is reset below. (for when editing)
	self.setTblDataDetailCells(rowIdx);			

	newCombo := self.addControlCmbLineType(rowIdx, newIndex).CMUI_ComboBox;
	self.myAssistant.comboBoxOrderLineType(newCombo, StockOrderLine_Product_Descr);	
	
	// dont want users to be able to edit Line type. 
	tblDetail.accessCell(rowIdx, self.colLineType).enabled := false;
	tblDetail.accessCell(rowIdx, self.colLineType).backColor := Grey;

	newCombo := self.addControlCmbCargoType(rowIdx, newIndex).CMUI_ComboBoxCargoTypeForTerm;
	product := orderLine.myProduct;
	if product  &lt;&gt; null then 
		cargoType := orderLine.myProduct.myCargoType;
	endif;
	newCombo.CMUI_ComboBoxCargoTypeForTerm.setObject(cargoType);

	//Load product control
	newCombo := self.addControlCmbProduct(rowIdx, self.newIndex).CMUI_ComboProduct;
	newCombo.CMUI_ComboProduct.myCargoType := cargoType;
	newCombo.CMUI_ComboProduct.setObject(product);
	
	newText := self.addControlTxtQuantity(rowIdx, newIndex).CMUI_TextBox;
	newText.text := orderLine.reqdQuantity.cnEcWholeValue.String;
	
	tblDetail.selected := false;
	tblDetail.row := tblDetail.rows;

end;</source>
        <Parameter name="_stockOrderProductLine" type="CM_StockOrderProductLine"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addControlsForStockOrderTI" id="2960bae0-c0cc-4c67-be03-409efb9a284f">
        <updating/>
        <source>addControlsForStockOrderTI(_stockOrderTi : CM_StockOrderTILine; _row : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowIdx 		: Integer;
	tblDetail  	: CM_DataTable;
	orderLine	: CM_StockOrderTILine;
	newCombo 	: CMUI_ComboBox;
	product		: CM_Product;
	cargoType	: CM_CargoType;
	
begin

	orderLine	 := 	_stockOrderTi;
	rowIdx := _row;
	tblDetail := self.tblDataDetail;
	self.newIndex := self.newIndex + 1;

	// call this here as backcolour for linetype cell is reset below. (for when editing)
	self.setTblDataDetailCells(rowIdx);	
	
	newCombo := self.addControlCmbLineType(rowIdx, self.newIndex);
	self.myAssistant.comboBoxOrderLineType(newCombo, StockOrderLine_TI_Descr);
	
	tblDetail.accessCell(rowIdx, self.colLineType).enabled := false;
	tblDetail.accessCell(rowIdx, self.colLineType).backColor := Grey;

	newCombo := self.addControlCmbCargoType(rowIdx, newIndex).CMUI_ComboBoxCargoTypeForTerm;
	cargoType := orderLine.myTrackedItem.myCargoType;
	newCombo.CMUI_ComboBoxCargoTypeForTerm.setObject(cargoType);

	newCombo := self.addControlCmbProduct(rowIdx, self.newIndex).CMUI_ComboProduct;
	newCombo.CMUI_ComboProduct.myCargoType := cargoType;
	newCombo.CMUI_ComboProduct.setObject(orderLine.myTrackedItem.myProduct); 
	
	newCombo := self.addControlCmbTI(rowIdx, self.newIndex).CMUI_ComboBox;
	self.myAssistant.comboBoxTIsByProduct(newCombo, orderLine.myTrackedItem.myProduct, orderLine.myTrackedItem.id);
	
	tblDetail.selected := false;
	tblDetail.row := tblDetail.rows;

end;</source>
        <Parameter name="_stockOrderTi" type="CM_StockOrderTILine"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addObjectToDetailTable" id="4a087959-0488-45d0-88db-c73a6b7ca090">
        <updating/>
        <source>addObjectToDetailTable(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowIdx : Integer;
	tblDetail  : CM_DataTable;
	orderLine	: CM_StockOrderLine;
	row			: Integer;
begin
	inheritMethod(_obj);

	if self.mode &lt;&gt; self.Mode_Edit then 
		// only add these controls on an edit. dont need them otherwise. will add diff ones on add. 
		return;
	endif;
	
	tblDetail := self.tblDataDetail;
	row := tblDetail.accessedRow.row;
	
	orderLine := _obj.CM_StockOrderLine;

	if orderLine.isKindOf(CM_StockOrderTILine) then 		
		self.addControlsForStockOrderTI(orderLine.CM_StockOrderTILine, row);
	elseif	orderLine.isKindOf(CM_StockOrderProductLine) then 
		self.addControlsForStockOrderLine(orderLine.CM_StockOrderProductLine, row);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="14dc8f79-67cf-4be9-8602-eb0bbc47a337">
        <source>addObjectsToTable(_cmifMonitor: CMIF_Monitor input);
// ---------------------------------------------------------------------------
// Created:     28 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_StkOrdByProcessFulfillStat;
	iter				: Iterator;
	stkOrd				: CM_StockOrderHeader;
	stockOrderGen		: CM_StockOrderHeaderGeneric;
	numSearched,
	numFound,
	processVal,
	fulfillVal,
	processKey,
	fulfillKey			: Integer;
	
	orderNoVal,
	orderNoKey			: String;
	tbl					: CM_DataTable;
	breakOut			: Boolean;

begin

	tbl := self.tblDataMaster;
	processVal := self.filtProcessOption;
	fulfillVal := self.filtFulfillStatus;
	orderNoVal := self.filtOrderNo;
	if self.myFiltOperator &lt;&gt; null then
		if self.filtOrderNo &lt;&gt; null then
			stkOrd := self.myFiltOperator.allStockOrderHeaders[self.filtOrderNo];
			if CM_StockOrderHeaderGeneric.hasInstance(stkOrd) and self.includesObject(stkOrd) then
				self.addObjectToMasterTable(tbl, stkOrd, null, null, breakOut);
				return;
			endif;	
		endif;
		
		dict := self.myFiltOperator.allStkOrdByProcessFulfillStat;
	else
		dict := self.myTerminal.allStkOrdByProcessFulfillStat;
	endif;
	
	iter := dict.createIterator();
	dict.startKeyGeq(processVal, fulfillVal, orderNoVal, iter);

	while iter.next(stockOrderGen) do
		dict.getIteratorKeys(processKey, fulfillKey, orderNoKey, iter);
		
		if processVal &lt;&gt; null then
			if processVal &lt;&gt; processKey then
				break;
			endif;
			//if we have a first and second key doesn't match, we can bail out. If we don't have first key,
			//the key still needs to be compared in the includesObject method
			if fulfillVal &lt;&gt; null and
			   fulfillVal &lt;&gt; fulfillKey then
				break;
			endif;
		endif;
		
		numSearched := numSearched + 1;
		
		if self.includesObject(stockOrderGen) then
			numFound := numFound + 1;
			self.addObjectToMasterTable(tbl, stockOrderGen, numSearched, numFound, breakOut);
		endif;
		
		if breakOut then
			break;
		endif;		
	endwhile;
	
	self.tblDataMaster.colourRows(self.colorRow1, self.colorRow2);
epilog
	delete iter;
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="armNotifications" id="54c6f61a-922c-4e4a-adcf-1f87d27ddf92">
        <updating/>
        <source>armNotifications() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.endNotificationForSubscriber(self);
	
	self.beginNotification(self.myTerminal, Event_StockOrderHdr_Create, Response_Continuous, 0);
	self.beginNotification(self.myTerminal, Event_StockOrderHdr_Update, Response_Continuous, 0);
	self.beginNotification(self.myTerminal, Event_StockOrderHdr_Delete, Response_Continuous, 0);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_click" id="02e49193-3ff1-4617-b48a-e3f4721c3582">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	beforeTxt		: String;
	tmpCargoType	: CM_CargoType;
	theRow			: Integer;
begin

	theRow  := self.tblDataDetail.row;
	
	//find out what table text is to see if combo has changed.  
	beforeTxt := self.tblDataDetailSaveText;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		tmpCargoType := combobox.listObject.CM_CargoType;
		self.setupTblDtlRowForCargoType(theRow, self.getTblDataDetailRowLineType(theRow), tmpCargoType);
		// reset this in case change again
		self.tblDataDetailSaveText := combobox.text;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
