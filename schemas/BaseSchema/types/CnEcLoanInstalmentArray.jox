    <DbClassMap file="basedvfn"/>
    <JadeMethod name="addInstalment" id="40267c8f-5e1b-48ca-8bc4-8bb647684376">
        <lockReceiver/>
        <updating/>
        <source>addInstalment(	pOpeningBalance:Decimal;
				pPrincipalAmount:Decimal;
				pInterestAmount:Decimal):Decimal updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2001 by cnwdad1
//
// Purpose:		Creates a loan instalment object and adds it to the receiver.
//
// Parameters:	pOpeningBalance - The opening loan balance.
//				pPrincipalAmount - The principal amount of the loan.
//				pInterestAmount - The interest amount of the loan.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentObj	: CnEcLoanInstalment;
	
begin
	instalmentObj	:=	self.createEntry();
	instalmentObj.initializeMe(pOpeningBalance, pPrincipalAmount, pInterestAmount);
	self.add(instalmentObj);

	return instalmentObj.closingBalance;
end;</source>
        <Parameter name="pOpeningBalance" type="Decimal"/>
        <Parameter name="pPrincipalAmount" type="Decimal"/>
        <Parameter name="pInterestAmount" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="createEntry" id="f8bc0bca-402a-4897-ac85-e2f3b511d88c">
        <source>createEntry():CnEcLoanInstalment protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2001 by cnwdad1
//
// Purpose:		Creates a loan instalment object and returns it.
//
// Parameters:	None
//
// Returns:		The loan instalment object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentObj	: CnEcLoanInstalment;

begin
	if self.isTransient() then
		create instalmentObj transient;
	else
		create instalmentObj;
	endif;
epilog
	return instalmentObj;
end;</source>
        <access>protected</access>
        <ReturnType type="CnEcLoanInstalment"/>
    </JadeMethod>
</CollClass>
