    <JadeMethod name="updateCriteriaValue" id="6b4d5db9-a590-4552-9b75-570a94aee8c0">
        <updating/>
        <source>updateCriteriaValue() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
16 December 2008	consw1	Initial creation
12/07/2011			cnwmh5	#27772 - Add saving of oids
13/08/2013			cnwdap1	PAR #32123 Colours MUST be in alphabetical order, not just selection order
23/10/2014			cnwdap1	PAR #34996 Save selected voyages back to maint form
28/06/2023 			navtnr20 CR 58224 	Task 58226: UI - COO Query
*/

vars
	obj : Object;
	val : String;
	voyages	: CM_VoyageSet;							// PAR #34996
	form	: CM_BaseForm;							// PAR #34996
	idx		: Integer;								// PAR #34996
	ctrl 	: CMUI_YACriteriaCntl;					// PAR #34996
begin
	create voyages transient;											// PAR #34996
	
	if self.myCriteriaType.isKindOf(CM_YATypeColour) then					// PAR #32123
		val := self.myAssistant.getColourString(self.tblAvailable, null);	// PAR #32123
	else																	// PAR #32123
		foreach obj in self.tblAvailable.allSelectedObjects do
			if val &lt;&gt; null then
				val := val &amp; ", ";
			endif;
			val := val &amp; self.getValue(obj);
			if obj.isKindOf(CM_Voyage) then								// PAR #34996
				voyages.add(obj.CM_Voyage);								// PAR #34996
			endif;														// PAR #34996
		endforeach;
	endif;																	// PAR #32123
	
	//epr TFS 1822 28/4/16

	self.criteriaValue := val;
	
	if not voyages.isEmpty then											// PAR #34996
		if self.myParentForm.isKindOf(CMUI_YACriteriaMaintForm) then	// PAR #34996
			form := self.myParentForm.CMUI_YACriteriaMaintForm;			// PAR #34996
		elseif self.myParentForm.isKindOf(CMUI_YAMaintForm) then		// PAR #34996
			form := self.myParentForm.CMUI_YAMaintForm;					// PAR #34996
		endif;															// PAR #34996
		if form &lt;&gt; null then											// PAR #34996
			foreach idx in 1 to form.controlCount do					// PAR #34996
				if form.controls(idx).isKindOf(CMUI_YACriteriaCntl) then// PAR #34996
					ctrl := form.controls(idx).CMUI_YACriteriaCntl;		// PAR #34996
					ctrl.setVoyagesReference(voyages);					// PAR #34996
				endif;													// PAR #34996
			endforeach;													// PAR #34996
		endif;															// PAR #34996
	endif;																// PAR #34996
	
	// ### TFS 51515 13JUL2021 NAVAB1
	if self.myParentForm.isKindOf(CMUI_LocationActivityEnquiry) then
		if self.myCriteriaType.isKindOf(CM_YATypeInventoryType) then
			self.myParentForm.CMUI_LocationActivityEnquiry.handleYAInventoryTypeOK(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeLocnEventMoveDir) then
			self.myParentForm.CMUI_LocationActivityEnquiry.handleYAMoveDirectionOK(val);
		endif;
	endif;

	// 20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
	if self.myParentForm.isKindOf(CMUI_OwnershipChangeEnquiry) then
		if self.myCriteriaType.isKindOf(CM_YATypeCargoType) then
			self.myParentForm.CMUI_OwnershipChangeEnquiry.handleYACargoType(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeCommodity) then
			self.myParentForm.CMUI_OwnershipChangeEnquiry.handleYACommodity(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeOperatorItem) then
			self.myParentForm.CMUI_OwnershipChangeEnquiry.handleYAOperatorNew(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeOperatorItem) then
			self.myParentForm.CMUI_OwnershipChangeEnquiry.handleYAOperatorOld(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeProduct) then
			self.myParentForm.CMUI_OwnershipChangeEnquiry.handleYASubType(val);
		endif;
	endif;
	// ### TFS CR 56094 TASK 59618 08AUG2023 NAVAB1
	if self.myParentForm.isKindOf(CMUI_CustomDocsEnquiry) then
		if self.myCriteriaType.isKindOf(CM_YATypeCargoType) then
			self.myParentForm.CMUI_CustomDocsEnquiry.handleYACargoType(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeCommodity) then
			self.myParentForm.CMUI_CustomDocsEnquiry.handleYACommodity(val);
		endif;
		if self.myCriteriaType.isKindOf(CM_YATypeProduct) then
			self.myParentForm.CMUI_CustomDocsEnquiry.handleYASubType(val);
		endif;
	endif;
epilog
	
end;</source>
    </JadeMethod>
</GUIClass>
