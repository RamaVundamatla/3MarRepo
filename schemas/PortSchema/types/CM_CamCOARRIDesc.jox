    <JadeMethod name="outputHeader_UNB" id="7f0972c9-8470-467d-8325-b5a9afb426c9">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	msg :String;
begin
	if _protocol.camGroup.code.trimBlanks = "COL" and _protocol.terminal.getConfig(PortDestCode).String = "POE" then
		msg := self.makeUNBSegment (_protocol, "UNOA", 2, 'POTOTAGO', 'ZZ', _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, true, _camTaskHistory.runDateTime);
		
	else
		msg := self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), null, _protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, _camTaskHistory.runDateTime);
	endif;

	return self.outputFileMessage(_camTaskHistory, msg, _coll);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="19ac2d40-7fdd-4a1c-87a2-6c8c8363dcbc">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile :CM_CamFile input; _camTaskHistory :CM_CamTaskHistory input; _activity :Integer; 
					_unhSeq, _segmentCount :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
constants
	COARRI = "COARRI";
	LOAD = "46";
	DISCHARGE = "44";
	//cnwmc5 - 10 Feb 2016 - PAR 37503
	LOAD_STD = "270";
	DISCHARGE_STD = "98";
vars
	strLine : String;
	load, discharge : String;
begin
	if _activity = COARRI_SHIPLOAD then
		//cnwmc5 - 10 Feb 2016 - PAR 37503
		load := LOAD;
		if _camTaskHistory.camProtocol.changeCOARRIBGM then
			load := LOAD_STD;
		endif;
		
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, load, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
		
	elseif _activity = COARRI_SHIPDISCHARGE then
		//cnwmc5 - 10 Feb 2016 - PAR 37503
		discharge := DISCHARGE;
		if _camTaskHistory.camProtocol.changeCOARRIBGM then
			discharge := DISCHARGE_STD;
		endif;
		
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, discharge, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="cff23c82-4737-4c6a-ae74-793cfcd343cf">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
//
//06 Jun 2017	cnwrs1	TFS 4470 Coarri Event driven
//12 Mar 2020	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
//
vars
	camMessage : CM_CamMessage;
	transaction : CM_TITransaction;
	voyage : CM_Voyage;
	transArray : CM_TransactionArray;
	startTS : TimeStamp;
	endTS : TimeStamp;
	camGroup : CM_CamGroup;
	logExcludedTransaction : Boolean;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
	camGroup := _camProtocol.camGroup;
	startTS := _camAgent.startDateTime;
	endTS := _camAgent.endDateTime;
	logExcludedTransaction := _camAgent.logExcludedTransactions;
	create transArray transient;
	if _transaction.type = EVT_VoyageDeparture then
		voyage := _transaction.getVoyage();
		if voyage = null then
			return;
		endif;
		if voyage.allTITransactionsByTypeTIIdDT.size &lt;&gt; 0 then
			foreach transaction in voyage.allTITransactionsByTypeTIIdDT do
			if self.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
										_camProtocol, camGroup, _camAgent, logExcludedTransaction, _transaction) then	// par 29601 June 2012	// TFS 48785
				if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 
					transArray.add(transaction);
				endif;
			endif;
			endforeach;
		endif;
	endif;
	foreach transaction in transArray do
		self.processTransaction(transaction, _camProtocol, _camAgent, _camFile);
	endforeach;
epilog
	delete transArray;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="a61beaa7-096e-43c7-af10-db61c15bea68">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
// 14/07/2010	cnwdap1	PAR 25021 - review use of isImport/isExport for tranships
// 12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 13/12/2012	cnwcs5	CCMS 1294 / par 30855 - remove trx to create CAMS info transaction
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
//12 July 2017	jlgrs1	TFS 4470 SNO standard Codedo/Coarri
//02 May 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
vars
	camMessage			: CM_CamMessage;
	xlVoyageId, fCode, code,
	vesselName			: String;
	ti					: CM_TrackedItem;
	voyage				: CM_Voyage;
	pos3, pos4, pos5	: Integer;
begin
	_camAgent.writeDebugLog(class.name &amp; '::' &amp; method.name &amp; " process " &amp; _transaction.getCamsDisplayDetails);
	
	ti 	:= _transaction.myTrackedItem;
	
	if not self.includeRehandles(_camProtocol) then
		if ti.isRehandle or ti.isSOB then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, "Transaction is for a rehandle or SOB and they are not set to be included.");
			endif;
			return;
		endif;
	endif;
	
	voyage := self.getVoyage(_transaction, ti);
	
	if voyage = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for no voyage so is excluded.");
		endif;
		return;
	endif;
	
	//get the voyage code
	code 		:= self.getCodeForVoyage (ti, voyage, _camProtocol);	// par 30855 Dec 2012
	vesselName 	:= voyage.vesselName; 									// par18987 cnwrs1 Mar 2009
	
	//translate the voyage Code	
	if _camProtocol.getIsCustomsProtocol() and voyage.customsManifest &lt;&gt; null then		
		fCode := voyage.customsManifest;		
	else
		fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
	endif;		

	if fCode.trimRight = "HOLD" or fCode.trimRight = "********" then
		app.writeLog("Error : Container " &amp; ti.id.trimRight &amp; " has an invalid voyage " &amp; fCode &amp; ".", LogINFO);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for invalid voyages which are ignored.");
		endif;
		camMessage := null;
	// is this is set for Coarri then ignore unplanned voyages.
// PAR 33644	elseif not _camProtocol.includeNonPlannedVoyage and voyage.isNonPlannedVoyage then
// PAR 33644	elseif not _camProtocol.includeNonPlannedVoyage and voyage.isHOLDSorSHIP() then
	elseif voyage.isHOLDSorSHIP() then
		app.writeLog("NonPlannedVoyages are ignored for this protocol.", LogWARN);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction for NonPlannedVoyages which are ignored for this protocol.");
		endif;
		camMessage := null;
	else
		if _transaction.isCamsShipReleaseType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, COARRI_SHIPLOAD, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
		
		elseif _transaction.isCamsShipReceiveType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, COARRI_SHIPDISCHARGE, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
		
		else
			//do nothing
			app.writeLog("No message. Not a ship receive/release.", LogWARN);
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, "Transaction not a ship receive/release.");
			endif;
			camMessage := null;
		endif;
	endif;

	if camMessage = null then
		app.writeLog("CAM Message is null " &amp; _transaction.String &amp; ", " &amp; ti.id &amp; " for " &amp; fCode &amp; ".", LogERROR);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ", " &amp; ti.id &amp; " for " &amp; fCode &amp; ".");
		endif;
		return;
	endif;

	camMessage.camVoyage.voyageOid := voyage;
	
	//create all of the group 3 message now
	pos3 := camMessage.group3.size;
	
	self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);

	camMessage.setupCAMSInfoDetails(_camProtocol, pos3, pos4, pos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
epilog
	
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
