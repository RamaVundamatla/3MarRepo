    <JadeMethod name="shouldAuditProperty" id="26420a0a-cae0-4179-a6aa-91028165f2ed">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 Dec 2022		navvt20	TFS CR 55621 Task 55807: Jade - UOM Audits

*/

vars
	propName	: String;
begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_InvoiceUnitOfMeasure::type.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
