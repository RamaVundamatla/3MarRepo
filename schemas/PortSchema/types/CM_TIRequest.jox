    <JadeMethod name="getQuantityOnRequest" id="1a7c840b-e86d-4b98-b71e-9132c67902c3">
        <source>getQuantityOnRequest(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2013	cnwer1	Initial creation CCMS DPH 2274
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	ti : CM_TrackedItem;
begin
	
	ti := self.trackedItem;									//31.03.2025 navma1 #MTN-34387
	if ti &lt;&gt; null then
		if ti.myCargoType.isBreakBulkMulti() then
			if self.allWorkListEntries.isNotEmpty then		//31.03.2025 navma1 #MTN-34387
				return self.getWLEQuantity();
			endif;
		endif;
		
		return ti.totalQuantity.max(1);
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
