    <JadeMethod name="unitTestAfterClass" id="918ab4bd-0316-4e00-bca5-6545b087f7d5">
        <updating/>
        <source>unitTestAfterClass() updating, protected;
//	clear cash only terminal after running
vars

begin
	// TFS 45953 PEL voyage process means no road exit cash validation and not moving invoice lines to cash invoice
	beginTransaction;
	self.myTerminal.setConfig(DefaultVoyageProcess, self.previousProcessCode);
	commitTransaction;

	inheritMethod();
	self.enableCashOnlyTerminal( self.myTerminal, false );
	// delete any cash receipts with invalid invoice lines or cargo
	self.zCashReceiptCleanup();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="fa488fd8-0b7f-4f17-9c6a-31a724ef2e31">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
//	establish entities used in the tests - customs agents and matching cash-only debtors
vars
	root	: CM_Root;
	terminal	: CM_Terminal;
	invType		: CM_InvoiceDesc;
	ca		: CM_CustomsAgent;
	rootDebtor,
	debtor1,
	debtor2,
	debtor3,
	debtor4	: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	defaultVoyageProcess : CM_VoyageProcess;
begin
	inheritMethod();
	root := CM_Root.firstInstance;
	terminal := self.getTerminal();
	self.myTerminal := terminal;

	// TFS 45953 PEL voyage process means no road exit cash validation and not moving invoice lines to cash invoice
	defaultVoyageProcess := CM_VoyageProcessDefault.firstInstance;
	beginTransaction;
	self.myTerminal.setConfig(DefaultVoyageProcess, defaultVoyageProcess.code);
	commitTransaction;
	self.previousProcessCode := defaultVoyageProcess.code;
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	
	// don't want RDT a cash debtor so can use it for non-cash charges then resynch them back
	rootDebtor := app.myRoot.myRootCompany.rootDebtor;
	debtorTerminal := rootDebtor.allDebtorTerminals[terminal];
	if debtorTerminal &lt;&gt; null and
	   debtorTerminal.isCashOnly then
		beginTransaction;
		debtorTerminal.setCashOnly(false);
		commitTransaction;
	endif;
	self.enableCashOnlyTerminal( self.myTerminal, true );

	// set cash invoice type
	self.deleteInvoiceType("UT_CashInvType");
	invType := self.createInvoiceType("UT_CashInvType", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_CashInvType not created");
	self.setDefaultBankCashInvoiceType(invType);
		
	// cash-only debtors - create or clear out existing balances
	//  also set them to zero-tax
	debtor1 := root.myRootCompany.debtors["UT_Cash1"];
	if debtor1 = null then
		debtor1 := self.addCashDebtor("UT_Cash1", "1 Cash Debtor St", "Cash Debtor 1", terminal).CM_Debtor;
	else
		debtorTerminal := debtor1.allDebtorTerminals[terminal];
		self.zPurgeCashDebtor(debtorTerminal);
	endif;
	if not debtor1.isZeroRatedTax then
		beginTransaction;
		debtor1.setIsZeroRatedTax(true);
		commitTransaction;
	endif;
	debtor2 := root.myRootCompany.debtors["UT_Cash2"];
	if debtor2 = null then
		debtor2 := self.addCashDebtor("UT_Cash2", "2 Cash Debtor St", "Cash Debtor 2", terminal).CM_Debtor;
	else
		debtorTerminal := debtor2.allDebtorTerminals[terminal];
		self.zPurgeCashDebtor(debtorTerminal);
	endif;
	if not debtor2.isZeroRatedTax then
		beginTransaction;
		debtor2.setIsZeroRatedTax(true);
		commitTransaction;
	endif;
	debtor3 := root.myRootCompany.debtors["UT_Cash3"];
	if debtor3 = null then
		debtor3 := self.addCashDebtor("UT_Cash3", "3 Cash Debtor St", "Cash Debtor 3", terminal).CM_Debtor;
	else
		debtorTerminal := debtor3.allDebtorTerminals[terminal];
		self.zPurgeCashDebtor(debtorTerminal);
	endif;
	if not debtor3.isZeroRatedTax then
		beginTransaction;
		debtor3.setIsZeroRatedTax(true);
		commitTransaction;
	endif;

	debtor4 := root.myRootCompany.debtors["UT_Cash4"];
	if debtor4 = null then
		debtor4 := self.addCashDebtor("UT_Cash4", "4 Cash Debtor St", "Cash Debtor 4", terminal).CM_Debtor;
	endif;
	if not debtor4.isZeroRatedTax then
		beginTransaction;
		debtor4.setIsZeroRatedTax(true);
		commitTransaction;
	endif;
	
	// make sure that there are three unit test customs agents with matching cash-only debtors
	ca := root.allCustomsAgents["UTCA1"];
	if ca = null then
		ca := self.addCustomsAgent("UTCA1", "Cash customs agent 1");
	endif;
	if ca.myDebtor &lt;&gt; debtor1 then
		beginTransaction;
		ca.setDebtor(debtor1);
		commitTransaction;
	endif;

	ca := root.allCustomsAgents["UTCA2"];
	if ca = null then
		ca := self.addCustomsAgent("UTCA2", "Cash customs agent 2");
	endif;
	if ca.myDebtor &lt;&gt; debtor2 then
		beginTransaction;
		ca.setDebtor(debtor2);
		commitTransaction;
	endif;

	ca := root.allCustomsAgents["UTCA3"];
	if ca = null then
		ca := self.addCustomsAgent("UTCA3", "Cash customs agent 3");
	endif;
	if ca.myDebtor &lt;&gt; debtor3 then
		beginTransaction;
		ca.setDebtor(debtor3);
		commitTransaction;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateBulkSplitMergeA" id="15c1adda-9620-4733-b9c9-6ddb903d22f3">
        <source>validateBulkSplitMergeA(_cargo, _splitCargo : CM_TrackedItem);
// tPayBulkSplitMerge validate lines and payments after the first split
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 4000.Decimal, "First original cargo payment after first split");	// 21/12/17 MAP	4000 was 1000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Second original cargo payment after first split");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 4000.Decimal, "Third original cargo payment after first split");	// 21/12/17 MAP	4000 was 1000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
			self.assertEqualMsg(payment.myProformaDetail.quantity, 40000.Real, "Third original cargo proforma quantity after first split");	// 21/12/17 MAP	40000 was 10000.  Coal gets split 40:10, payment gets split 40000:10000 accordingly
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 4000.Decimal, "Third original cargo proforma value after first split");	// 21/12/17 MAP	4000 was 1000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Original cargo payments after first split");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 4000.Decimal, "First original invoice line after first split");	// 21/12/17 MAP	4000 was 1000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after first split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Original invoice lines after first split");

	count := 0;
	foreach payment in splitCargo.allCashPayments where payment.myCashPaymentForInvoice = null do	// 21/12/17 MAP skip the tax payments
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "First split cargo payment after first split");	// 21/12/17 MAP	1000 was 4000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Second split cargo payment after first split");	// 21/12/17 MAP	1000 was 4000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
			self.assertEqualMsg(payment.myProformaDetail.quantity, 10000.Real, "Second split cargo proforma quantity after first split");	// 21/12/17 MAP	10000 was 40000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 1000.Decimal, "Second split cargo proforma value after first split");	// 21/12/17 MAP	1000 was 4000.  Coal gets split 40:10, payment gets split 4000:1000 accordingly
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Split cargo payments after first split");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(line.lineTotal, 1000.Decimal, "First Split invoice line after first split");	// 21/12/17 MAP	1000 was 4000.  Coal gets split 40:10, invoice line gets split 4000:1000 accordingly
	endforeach;
	self.assertEqualMsg(count, 1, "Split invoice lines after first split");

end;
</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_splitCargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateCashReceipt" id="29f042ae-af5a-413b-a307-7e0dc4637f8e">
        <source>validateCashReceipt(_cashReceipt : CM_CashReceipt; _occurance : Integer) protected;
// after cash payment before releasing the cargo
vars
	ti	: CM_TrackedItem;
	invLine	: CM_InvoiceLine;
	proformaDetails	: CM_ProformaDetails;
	count	: Integer;
begin
	count := 0;
	// 2 items per cash receipt
	foreach ti in _cashReceipt.allTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " tracked items");
	
	count := 0;
	// 1 charged wash per cargo item, $20 each
	foreach invLine in _cashReceipt.allInvoiceLines do
		count := count + 1;
		self.assertEqualMsg(invLine.lineTotal, 20.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " inv line value " &amp; count.String);
	endforeach;
	self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " invoice lines");

	count := 0;
	// one estimated storage per item, $60 each
	foreach proformaDetails in _cashReceipt.allProformaDetails do
		count := count + 1;
		self.assertEqualMsg(proformaDetails.lineTotal, 60.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " proforma line value " &amp; count.String);
	endforeach;
	self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " proforma lines");
	
	self.assertEqualMsg(_cashReceipt.cashValue, 160.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " cashValue");
end;
</source>
        <access>protected</access>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_occurance" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCashReceiptRelease" id="37a1acf8-b8ab-49d1-8374-18c06bf1fd55">
        <source>validateCashReceiptRelease(_cashReceipt : CM_CashReceipt; _occurance : Integer) protected;
// after releasing the cargo
vars
	ti	: CM_TrackedItem;
	invLine	: CM_InvoiceLine;
	proformaDetails	: CM_ProformaDetails;
	payment	: CM_CashPayment;
	count	: Integer;
	count20,
	count60	: Integer;
begin

	count := 0;
	// 2 items per cash receipt
	foreach ti in _cashReceipt.allTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " tracked items");
	
	// each TI has 2 cash payments, $20 and $60
	foreach ti in _cashReceipt.allTrackedItems do
		count := 0;
		count20 := 0;
		count60 := 0;
		foreach payment in ti.allCashPayments do 
			if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
				continue;
			endif;
			count := count + 1;
			if payment.cashValue = 20.00 then
				count20 := count20 + 1;
			elseif payment.cashValue = 60.00 then
				count60 := count60 + 1;
			endif;
		endforeach;
		self.assertEqualMsg(count20, 1, "Cash receipt " &amp; _occurance.String &amp; " " &amp; ti.id &amp; " $20 cash payments");
		self.assertEqualMsg(count60, 1, "Cash receipt " &amp; _occurance.String &amp; " " &amp; ti.id &amp; " $60 cash payments");
		self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " " &amp; ti.id &amp; " cash payments");
	endforeach;

	count := 0;
	// 1 charged wash per cargo item, $20 each plus the storage lines added from DD code
	count20 := 0;
	count60 := 0;
	foreach invLine in _cashReceipt.allInvoiceLines do
		count := count + 1;
		if count = 1 or count = 2 then
			self.assertEqualMsg(invLine.lineTotal, 20.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " inv line value " &amp; count.String);
		else
			self.assertEqualMsg(invLine.lineTotal, 60.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " inv line value " &amp; count.String);
		endif;
	endforeach;
	// 2 or 4 lines depending on the isDD option
	//self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " invoice lines`");

	count := 0;
	// one estimated storage per item, $60 each
	foreach proformaDetails in _cashReceipt.allProformaDetails do
		count := count + 1;
		self.assertEqualMsg(proformaDetails.lineTotal, 60.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " proforma line value " &amp; count.String);
	endforeach;
	self.assertEqualMsg(count, 2, "Cash receipt " &amp; _occurance.String &amp; " proforma lines");
	
	count := 0;
	count20 := 0;
	count60 := 0;
	foreach payment in _cashReceipt.allCashPayments do
		count := count + 1;
		if payment.cashValue = 20.00 then
			count20 := count20 + 1;
		elseif payment.cashValue = 60.00 then
			count60 := count60 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count20, 2, "Cash receipt " &amp; _occurance.String &amp; " $20 cash payments");
	self.assertEqualMsg(count60, 2, "Cash receipt " &amp; _occurance.String &amp; " $60 cash payments");
	self.assertEqualMsg(count, 4, "Cash receipt " &amp; _occurance.String &amp; " payment lines");

	self.assertEqualMsg(_cashReceipt.cashValue, 160.00.Decimal, "Cash receipt " &amp; _occurance.String &amp; " cashValue");
end;
</source>
        <access>protected</access>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_occurance" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateSplitMerge2A" id="0f0fcc64-f1ed-4580-a032-3e4f9cca1add">
        <source>validateSplitMerge2A(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after the first release
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "First original cargo payment after first release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Second original cargo payment after first release");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "Third original cargo payment after first split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 30000.Real, "Third original cargo proforma quantity after first release");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 3000.Decimal, "Third original cargo proforma value after first release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Original cargo payments after first release");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 3000.Decimal, "First original invoice line after first release");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after first release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Original invoice lines after first release");

	count := 0;
	foreach payment in splitCargo.allCashPayments do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "First split cargo payment after first release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Second split cargo payment after first release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Split cargo payments after first release");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First Split invoice line after first release");
	endforeach;
	self.assertEqualMsg(count, 2, "Split invoice lines after first release");

end;
</source>
