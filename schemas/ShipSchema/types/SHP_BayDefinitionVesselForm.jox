    <JadeMethod name="setControlsForMACS3" id="991f39cb-53e7-4026-8a62-9d32bc619177">
        <source>setControlsForMACS3();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	webService 	: CM_NavisMACS3Service;
	parameters 	: HugeStringArray;
	result 		: String;
	
	vessel		: CM_Vessel;
begin
	// Only do the API check if the user has Edit/Maint permission
	if not app.myCurrentUserCan(self.myTerminal, PmShipBayDefMaint) then
		return;
	endif;
	
	// Check we even have an external web service set up
	webService := app.myRoot.allExternalWebServices[ExternalWebServiceNavisMACS3].CM_NavisMACS3Service;
	if webService = null then
		self.grpMACS3.enabled := false;
		self.lblMACS3IMOStatus.caption := "";
		self.lblMACS3Dets.caption := app.getErrorString(MACS3_NO_WEBSERVICE);
		return;
	endif;
	
	if self.myCurrentCellularVessel &lt;&gt; null then
		// Does the voyage have an IMO number currently entered ?
		if self.myCurrentCellularVessel.myVessel.lloydsNumber &lt;&gt; null then
			self.btnMACS3.enabled := true;
			self.lblMACS3IMOStatus.caption := app.getErrorString(MACS3_IMO_STATUS) &amp; " " &amp; app.getErrorString(MACS3_IMO_NOT_CHECKED);
			self.lblMACS3Dets.caption := app.getErrorString(MACS3_CONNECT_VPS);
		
			// Have we already checked before, and found nothing?
			if self.myCurrentCellularVessel.definitionSource &lt;&gt; null then
				if self.myCurrentCellularVessel.definitionSource = CM_CellularVesselStructure.DefinitionType_MACS3
				and self.myCurrentCellularVessel.definitionVersion &gt; 0 then
					self.lblMACS3IMOStatus.caption := app.getErrorString(MACS3_IMO_STATUS) &amp; " " &amp; app.getErrorString(MACS3_KNOWN_IMO);
					self.lblMACS3Dets.caption := app.getErrorString(MACS3_DOWNLOAD_DATA);
				else
					self.lblMACS3IMOStatus.caption := app.getErrorString(MACS3_IMO_STATUS) &amp; " " &amp; app.getErrorString(MACS3_UNKNOWN_IMO);
					//self.lblMACS3Dets.caption := "";
				endif;
			endif;
		endif;
	endif;

epilog
	delete parameters;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForUpdate" id="a2c915f0-f7e0-4ea2-81a4-1acaf6821410">
        <updating/>
        <source>setControlsForUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mode &lt;&gt; Mode_Update
	or self.viewModeOnly then
		return;
	endif;
	
	self.btnDefnWizard.enabled := false; // PAR 18214
	
	if self.myCurrentCellularVessel.allBaysByOrdinal.isEmpty() then
		self.txtBayOrder.readOnly := false;
	else
		self.txtBayOrder.readOnly := true;
	endif;
	self.btnImport.enabled:=false;
	self.cmbBridgeAftBay.enabled := true;
	self.txtNumHolds.readOnly := false;		
	self.txtTEUTotal.readOnly := false;		// PAR 32286
	self.ckbISOHalfHeight.readOnly := false;
	self.ckb40BayIds.readOnly := false;		
	self.cmbStowageNumber.enabled := true;	

	self.cmbVessel.enabled := false;
	self.btnEditTV.enabled := false;
	self.btnSaveBase.enabled := true;
	self.btnCancelBase.enabled := true;			

	self.btnDirDefaults.enabled := true;
				
	//self.frmToolBarLayout.enabled := true;
	self.setEnableBayLayout(true);
	
	self.btn40BaySlots40.enabled := true;
	self.btnBayApplyBay.enabled := true;
	self.btnBayPrintBay.enabled := true;
	self.btnBayCancelbay.enabled := true;
	self.btnBayRemoveBay.enabled := true;
	self.btnBayEditBay.enabled := true;
	self.btnBayEditBay.visible := true;	
	self.btnBayNewBay.enabled := true;
	self.cmbBayLayout.enabled := true;

	self.btnBayTempBay.enabled := true;
	self.btnBayEditBay.enabled := true;
	self.btnBayCancelbay.enabled := true;

	if not self.initWithBay then
		self.btnBaySeqBay.caption := self.CAPTION_BTN_ATTRIBUTES;
		self.btnBaySeqBay.bubbleHelp := self.BUBBLE_ATTRIBUTE;
		self.btnBaySeqBay.click(self.btnBaySeqBay);
		self.frmToolBarBay.positionToolbarControls();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="dce3c292-771f-4db2-85ca-684d751df7f4">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2020	jlgdap1		TFS 49003 MTN API Inline Agent
// 01/02/2021	jlgmd1		TFS 49052 MTN - MACS3 Vessel Library API
// 03/11/2022   navds21  ChangeRequest 55184: MTN - Hide MACS3 and NSD Vessel Definition imports
// ---------------------------------------------------------------------------
vars

begin
	self.setEnableBayObjects(false);	
	self.btnImport.enabled:=true;
	self.btnDefnWizard.enabled := true; // PAR 18214

	self.txtBayOrder.readOnly := true;
	self.ckb40BayIds.readOnly := true;
	self.ckbISOHalfHeight.readOnly := true;
	self.txtNumHolds.readOnly := true;			
	self.txtTEUTotal.readOnly := true;		// PAR 32286

	self.cmbStowageNumber.enabled := false;
	self.cmbBridgeAftBay.enabled := false;			
		
	self.btnSaveBase.enabled := false;
	self.cmbVessel.enabled := true;
	self.cmbBayList.enabled := true;		

	self.btnDirDefaults.enabled := false;
	//self.frmToolBarLayout.enabled := false;
	self.setEnableBayLayout(false);	
	self.btn40BaySlots40.enabled := false;
	self.btnBayApplyBay.enabled := false;
	self.btnBayPrintBay.enabled := true;
	self.btnBayCancelbay.enabled := false;
	self.btnBayRemoveBay.enabled := false;
	self.btnBayEditBay.enabled := false;
	self.btnBayNewBay.enabled := false;	
	
	self.initSDF(self.mySDF);
	self.btnBayTempBay.enabled := false;
	self.btnBayTempBay.userObject := null;
	self.btnBayTempBay.caption := app.getErrorString(Template);
	self.myTemplateBay := null;

	self.cmbBayLayout.enabled := false;
	
	self.btnBayNewBay.enabled := false;
	self.btnBayEditBay.enabled := false;
	self.btnBayCancelbay.enabled := false;

	if self.myCurrentBay &lt;&gt; null then
		if global.isValidObject(self.myCurrentBay) then
			if self.myCurrentBay.isTransient then
				delete self.myCurrentBay;
			endif;
		endif;
	endif;

	self.cmbBayList.listIndex := -1;
	self.displayBayDetails(null);
	self.initWithBay := false;

	self.frmToolBarBay.repositionAfterResize();
	
	// Disabled until this does something ;)
	self.grpNSD.enabled := false;
	
	// TFS 49003 see if MACS3 knows about this vessel via the IMO (Lloyd's Number)
	self.grpMACS3.enabled := true;
	self.btnMACS3.enabled := false;
	
	self.setControlsForMACS3();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnImport.enabled:= false;
		self.btnDefnWizard.enabled:= false;
		self.grpWizard.enabled := false;
		self.grpMACS3.enabled := false;
		self.grpNSD.enabled := false;
	endif;
	// Start 03.11.2022 navds21 TFS 55184
	if not (app.isSpecial or app.myPassport.myUser.isSuperUser) then
	 self.grpMACS3.visible :=false;
	 self.grpNSD.visible:=false;
	 endif;
	//End 03.11.2022 navds21 TFS 55184
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="9ab1980e-3639-431a-91aa-230bae6ac7af">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbBayLayout.style := 2;
	self.cmbBayList.style := 2;
	self.cmbBayType.style := 2;
	self.cmbBridgeAftBay.style := 2;
	self.cmbDirOn.style := 2;
	self.cmbDirOn40.style := 2;
	self.cmbDirUnder.style := 2;
	self.cmbDirUnder40.style := 2;
	self.cmbgetBayIDBays.style := 2;
	self.cmbHolds.style := 2;
	self.cmbLashFrom.style := 2;
	self.cmbOnShipCrane.style := 2;
	self.cmbStowageNumber.style := 2;
	self.cmbUnlashFrom.style := 2;


epilog

end;</source>
