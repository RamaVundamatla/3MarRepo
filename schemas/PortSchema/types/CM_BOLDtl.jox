    <JadeMethod name="myCargoType" id="7e3253b2-8992-4814-b132-d3463a383cd7">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set : Boolean; _value : CM_CargoType io) mapping;
/* ---------------------------------------------------------------------------
Created:     11 January 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if set then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to set virtual property myCargoType');
		return;
	endif;
	
	_value := app.myRoot.allCargoTypesById[self.cargoType];
epilog

end;</source>
