    <JadeMethod name="doConnectionClose" id="09aefcb8-9b15-4b4e-b9fa-5eec2cb48a38">
        <source>doConnectionClose();
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
