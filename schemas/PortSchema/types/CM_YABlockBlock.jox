<Class name="CM_YABlockBlock" id="9614320a-b85b-4c76-af05-95d1e3471a40">
    <superclass name="CM_YABlock"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="buildLocationStatistics" id="2b02d6d9-505f-4881-84b6-27a19dd8b06d">
        <updating/>
        <source>buildLocationStatistics() updating;
/*

Purpose:			Build Location Statistics

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2009	cnwjk3	PAR 19327

*/

vars
	locationStatistics  : CM_LocationStatistics;
	plocationStatistics : CM_LocationStatistics;
	blockStack          : CM_BlockStack;
	blockController     : CM_BlockController;
	terminal            : CM_Terminal;
	theTI				: CM_TrackedItem;
	container			: CM_Container;
	invalidContainer	: Boolean;
begin
	if self.myLocationStatistics = null then
		create plocationStatistics transient;
		plocationStatistics.setParent(self);
		create locationStatistics  persistent;
		locationStatistics.setupForCreate(plocationStatistics);
	endif;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts;

	if self.myTerminalArea.isKindOf(CM_BlockStack) then

		blockStack := self.myTerminalArea.CM_BlockStack;
		
		// Total		
		self.myLocationStatistics.c20Total := blockStack.maxCapacity;
		self.myLocationStatistics.c30Total := blockStack.maxCapacity;
		self.myLocationStatistics.c40Total := blockStack.maxCapacity;
		self.myLocationStatistics.c45Total := blockStack.maxCapacity;
		self.myLocationStatistics.c53Total := blockStack.maxCapacity;
		
		// Init free
		self.myLocationStatistics.c20Free := blockStack.maxCapacity;
		self.myLocationStatistics.c30Free := blockStack.maxCapacity;
		self.myLocationStatistics.c40Free := blockStack.maxCapacity;
		self.myLocationStatistics.c45Free := blockStack.maxCapacity;
		self.myLocationStatistics.c53Free := blockStack.maxCapacity;
				
		blockController := self.myTerminalArea.CM_BlockStack.myLocationsController;
		
		on Exception do app.handleDeletedObject(exception, container, invalidContainer); //+ cnwmd1 Par 26125
		
		// Used &amp; Free
		foreach theTI in blockController.allTrackedItems do
			if theTI.isKindOf(CM_Container) then
				container := theTI.CM_Container;
				if container.is20 then
					self.myLocationStatistics.c20Used := self.myLocationStatistics.c20Used + 1;
				elseif container.is30 then
					self.myLocationStatistics.c30Used := self.myLocationStatistics.c30Used + 1;
				elseif container.is40 then
					self.myLocationStatistics.c40Used := self.myLocationStatistics.c40Used + 1;
				elseif container.is45 then
					self.myLocationStatistics.c45Used := self.myLocationStatistics.c45Used + 1;
				elseif container.is53 then
					self.myLocationStatistics.c53Used := self.myLocationStatistics.c53Used + 1;				
				endif;
				self.myLocationStatistics.c20Free := (self.myLocationStatistics.c20Free-1);
				if self.myLocationStatistics.c20Free &lt; 0 then
					self.myLocationStatistics.c20Free := 0;	
				endif;
				self.myLocationStatistics.c30Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c45Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c53Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c40Free := self.myLocationStatistics.c20Free;
			endif;
		endforeach;
		
		// Calculate future queued/planned (unchanged from original code)
		self.myLocationStatistics.processALocationController(blockController, 1, 1);
		
		//cnwjo3 par 21189
		self.myLocationStatistics.free := self.myLocationStatistics.c20Free;
	//	self.myLocationStatistics.used := self.allYardControllers.first.getTrackedItemCount;	//cnwrd1 31736 break bulk counting	
		//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
		self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used
										+ self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used
										+ self.myLocationStatistics.c53Used;
		self.myLocationStatistics.total := self.myLocationStatistics.c20Total;
		
		
		self.myLocationStatistics.setUpdateTimestamp;
		terminal := self.myTerminalArea.myTerminal;
		terminal.causeEvent(terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, self.myLocationStatistics);
	endif;
epilog
	delete plocationStatistics;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildLocationStatisticsOLD" id="d8d790d5-c687-435e-a1e1-6b83cfb0f76d">
        <updating/>
        <source>buildLocationStatisticsOLD() updating;
/*

Purpose:			Build Location Statistics

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	conkc1	Initial creation

*/

vars

	locationStatistics  : CM_LocationStatistics;
	plocationStatistics : CM_LocationStatistics;
	blockStack          : CM_BlockStack;
	blockController     : CM_BlockController;
	terminal            : CM_Terminal;

begin

	if self.myLocationStatistics = null then
		create plocationStatistics transient;
		plocationStatistics.setParent(self);
		create locationStatistics  persistent;
		locationStatistics.setupForCreate(plocationStatistics);
	endif;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts;

	if self.myTerminalArea.isKindOf(CM_BlockStack) then

		blockStack := self.myTerminalArea.CM_BlockStack;
		self.myLocationStatistics.c20Total := blockStack.maxCapacity;
		self.myLocationStatistics.c30Total := blockStack.maxCapacity;
		self.myLocationStatistics.c40Total := blockStack.maxCapacity;
		self.myLocationStatistics.c45Total := blockStack.maxCapacity;
		self.myLocationStatistics.c53Total := blockStack.maxCapacity;
		blockController := blockStack.allLocationsControllers.first.CM_BlockController;
		if blockController &lt;&gt; null then
			self.myLocationStatistics.c20Used := blockController.allTrackedItems.size;
			self.myLocationStatistics.c20Free := self.myLocationStatistics.c20Total - blockController.allTrackedItems.size;
			// PAR 19264
			if self.myLocationStatistics.c20Free &lt; 0 then 
				self.myLocationStatistics.c20Free := 0;
			endif;
			self.myLocationStatistics.c30Used := self.myLocationStatistics.c20Used;
			self.myLocationStatistics.c30Free := self.myLocationStatistics.c20Free;
			self.myLocationStatistics.c40Used := self.myLocationStatistics.c20Used;
			self.myLocationStatistics.c40Free := self.myLocationStatistics.c20Free;
			self.myLocationStatistics.c45Used := self.myLocationStatistics.c20Used;
			self.myLocationStatistics.c45Free := self.myLocationStatistics.c20Free;
			self.myLocationStatistics.c53Used := self.myLocationStatistics.c20Used;
			self.myLocationStatistics.c53Free := self.myLocationStatistics.c20Free;
		else
			self.myLocationStatistics.c20Used := 0;
			self.myLocationStatistics.c20Free := self.myLocationStatistics.c20Total;
			self.myLocationStatistics.c30Used := 0;
			self.myLocationStatistics.c30Free := self.myLocationStatistics.c30Total;
			self.myLocationStatistics.c40Used := 0;
			self.myLocationStatistics.c40Free := self.myLocationStatistics.c40Total;
			self.myLocationStatistics.c45Used := 0;
			self.myLocationStatistics.c45Free := self.myLocationStatistics.c45Total;
			self.myLocationStatistics.c53Used := 0;
			self.myLocationStatistics.c53Free := self.myLocationStatistics.c53Total;
		endif;
		self.myLocationStatistics.setUpdateTimestamp;
		terminal := self.myTerminalArea.myTerminal;
		terminal.causeEvent(terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, self.myLocationStatistics);
	endif;
epilog
	delete plocationStatistics;
end;</source>
    </JadeMethod>
    <JadeMethod name="getFifo" id="c37eb6f5-bdfc-44ed-8d67-5311c58c8e19">
        <source>getFifo(_isIn: Boolean): Date;
// -------------------------------------------
// Created 11 May 2005 by cnwdvb1
// -------------------------------------------
//21 Jun 25	jlier1 JIRA-13860 
vars
	fifoDate	: Date;
	termArea	: CM_TerminalArea;
begin
	fifoDate:=null;
	termArea := self.myTerminalArea;
	
	if termArea &lt;&gt; null and termArea.isKindOf( CM_BlockStack ) then	//one of the issues found testing TFS 3723
		fifoDate := termArea.CM_BlockStack.effectiveFIFODate;
	endif;
	
	return fifoDate;
end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getUsageStats" id="1ddfa2cb-a20f-4b18-9ee4-65b09e45b5b7">
        <source>getUsageStats(_usedMatching, _userNotMatching, _empty, _positionCount : Integer output; _cmifAutoPlan : CMIF_YAAutoPlanNormal input);
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpYC				: CM_YardController;
	tmpTI				: CM_TrackedItem;

begin

	// Run through all locations for this block.
	foreach tmpYC in self.allYardControllers discreteLock do
		
		foreach tmpTI in tmpYC.allTrackedItems discreteLock  do
			_cmifAutoPlan.attachTI(tmpTI);
			if self.myYardAllocationIn.compareCriteriaToCMIF(null, _cmifAutoPlan) then
				_usedMatching := _usedMatching + 1;
			else
				_userNotMatching := _userNotMatching + 1;
			endif;
		endforeach;
		
	endforeach;
	
	_positionCount := self.myTerminalArea.CM_BlockStack.maxCapacity;
	
	_empty	:= (_positionCount - (_usedMatching + _userNotMatching).max(0));
	
end;</source>
        <Parameter name="_usedMatching" type="Integer" usage="output"/>
        <Parameter name="_userNotMatching" type="Integer" usage="output"/>
        <Parameter name="_empty" type="Integer" usage="output"/>
        <Parameter name="_positionCount" type="Integer" usage="output"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlanNormal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialiseForDecking" id="985a712a-b70d-4aa6-b4bc-2e483da3a61e">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsBlock input);
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locn	: CM_YardController;
begin

	foreach locn in self.allYardControllers do
		locn.setupForDeckingInBlock(1, 1, _pxyDeckingOptions);
	endforeach;

	//do default out - reverse of in?
	_pxyDeckingOptions.setOutDeckingReverseOfIn();
	
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsBlock" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchForLocationIn" id="2d4e613b-6f97-425a-a1af-4a117986acd1">
        <source>searchForLocationIn(_yaAgent: CM_YAAutoplanAgent input): Boolean;

// Created by cnwdvb1 on 23 January 2007

vars
	termArea	: CM_TerminalArea;
	termAreaId  : String;
	ti 			: CM_TrackedItem;
begin

	// CCMS1505 23/1/2007 Mohammad
	
	termArea := self.myTerminalArea;
	if termArea &lt;&gt; null then
		termAreaId := termArea.id;
	endif;
	
	ti := _yaAgent.getMyCurrentTrackedItem();
	if (ti &lt;&gt; null and ti.isContainer()) and termArea &lt;&gt; null then
		if ti.CM_Container.offsitePreTrip and termArea.myType.type = TA_TYPE_PTI then
			// Don't want to process this block stack any further.
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " &amp; termAreaId, false);																// 22/01/2013 cnwmh5 #30999
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Suitable location not found - Is offsite for a Pre Trip Inspection in area - " &amp; termAreaId, false);	// 22/01/2013 cnwmh5 #30999
			return false;
		endif;
	endif;
	
	//epr par 18831
	if self.getMaxCapacity &lt;&gt; 0 then
		if termArea.CM_BlockStack.getAvailableCapacity = 0 then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " 				&amp; termAreaId, false);								// 22/01/2013 cnwmh5 #30999
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Suitable location not found - " &amp; termAreaId &amp; " is at maximum capacity", false);	// 22/01/2013 cnwmh5 #30999
			return false;
		endif;
	endif;
	
	return inheritMethod(_yaAgent);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
