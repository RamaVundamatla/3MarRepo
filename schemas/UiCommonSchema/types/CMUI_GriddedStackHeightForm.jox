    <JadeMethod name="moveControlsForSetup" id="225770b2-6408-4d17-a1f9-fc3c98e70083">
        <updating/>
        <source>moveControlsForSetup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984
28/11/2023			navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

begin

	//hide the crap we aren't using
	self.shtLocation.visible := false;
	self.shtOptions.visible := false;
	self.shtRemarks.visible := false;
	self.lblHeader.visible := false;
	self.cmbIMEX.visible := false;
	self.btnFindImex.visible := false;
	self.lblGroupName.visible := false;
	self.txtGroupName.visible := false;
	self.lblYAColour.visible := false;
	self.clrYAColour.visible := false;
	self.grpTemplate.visible := false;
	self.btnNext.visible := false;
	self.txtImex.visible := false;
	
	// move the name field
	self.lblYACode.parent := self.frmHeader;		// Name: Label
	self.lblYACode.top := 1;
	self.lblYACode.transparent := true;
	
	self.txtYACode.parent := self.frmHeader;		// Name textbox
	self.txtYACode.top := 1;
	
	self.lblProjected20.parent := self.frmHeader;	// Priority Label
	self.lblProjected20.top := 35;
	self.lblProjected20.left := self.lblYACode.left;
	self.lblProjected20.width := self.lblYACode.width;
	self.lblProjected20.transparent := true;
	self.lblProjected20.alignment := Label.Alignment_Right_Middle;
	lblProjected20.caption := app.getErrorString(Priority) &amp; ":";
	
	self.txtProjected20.parent := self.frmHeader;	//Priority Textbox
	self.txtProjected20.left := self.txtYACode.left;
	self.txtProjected20.top := self.lblProjected20.top;
	self.txtProjected20.width := 45;
	self.txtProjected20.alignment := TextBox.Alignment_Right;
	
	self.lblProjected30.parent := self.frmHeader;	// Max Stack Height Label
	self.lblProjected30.top := self.lblProjected20.top;
	self.lblProjected30.left := self.txtProjected20.left + self.txtProjected20.width + 20;
	self.lblProjected30.width := self.lblYACode.width + 80;
	self.lblProjected30.transparent := true;
	self.lblProjected30.alignment := Label.Alignment_Right_Middle;
	lblProjected30.caption := app.getErrorString(Gridded_stack_height) &amp; ":";
	
	self.txtProjected30.parent := self.frmHeader;	//Max Stack Height Textbox
	self.txtProjected30.left := self.lblProjected30.left + self.lblProjected30.width + 10;
	self.txtProjected30.top := self.txtProjected20.top;
	self.txtProjected30.width := self.txtProjected20.width;
	self.txtProjected30.alignment := TextBox.Alignment_Right;
	
	self.chkDisableYA.parent := self.frmHeader;
	self.chkDisableYA.left := self.txtProjected20.left;
	self.chkDisableYA.top := self.txtProjected20.top + self.txtProjected20.height + 10;
	self.chkDisableYA.width := self.txtYACode.width;
	self.chkDisableYA.caption := app.getErrorString(NeverMix);
	
	//move criteria down
	self.picCriteria.parentAspect := Control.ParentAspect_StretchBoth;	// 28/11/2023	navkc1 Bug 60782
	self.shtCriteria.parentAspect := Control.ParentAspect_StretchBoth;	// 28/11/2023	navkc1 Bug 60782
	self.fldYardAlloc.parentAspect := Control.ParentAspect_StretchBoth;	// 28/11/2023	navkc1 Bug 60782
	self.frmHeader.height := 95;
	//self.fldYardAlloc.parentAspect := 0;	// 28/11/2023	navkc1 Bug 60782
	self.fldYardAlloc.height := picCriteria.height + 50;
	self.fldYardAlloc.top := 110;
	
	self.height := self.fldYardAlloc.top + self.fldYardAlloc.height + 50;
	
	self.btnSave.left := self.btnNext.left;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="007e8210-52f0-4887-847c-75184b10ca8f">
        <updating/>
        <source>populateCriteriaFrames(_autoSetFocus: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984
28/11/2023			navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	i: Integer;
	criteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	cmifObject: CMIF_Object;
	tabIndex: Integer;
	adjustment: Real;
	new: Boolean;
	defaultNumCriteria : Integer;
begin

	tabIndex := self.frmCriteria.tabIndex;					

	self.hideAllOpCriteriaFrames();
	
	//defaultNumCriteria := 9;
	defaultNumCriteria := self.getNumCriteriaToDisplay(); // 28/11/2023	navkc1 Bug 60782
	
	while i &lt; defaultNumCriteria do
		i := i + 1;
		criteria := null;
		if myObjectMatchCriteria &lt;&gt; null and not myObjectMatchCriteria.allCriteria.isEmpty and myObjectMatchCriteria.allCriteria.size &gt;= i then
			criteria := myObjectMatchCriteria.allCriteria[i];
		endif;
		if criteria = null then
			criteriaFrame := self.addCriteriaFrame(i, null, tabIndex);
		else
			criteriaFrame := self.addCriteriaFrame(i, criteria.myYACriteriaType, tabIndex);
		endif;
		saveChangeMethod := criteriaFrame.formCriteriaChangeMethodName;
		criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
		criteriaFrame.setCriteria( criteria );
		criteriaFrame.setMasterControl(self.frmCriteria);	
		criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
		
		if _autoSetFocus and i = 1 then
			criteriaFrame.CMUI_YACriteriaCntl.txtCriteriaValue.setFocus();
		endif;
	endwhile;
		
epilog

end;</source>
        <Parameter name="_autoSetFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="ecdad7e0-deb4-4631-802f-efab432a3677">
        <updating/>
        <source>populateForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	nullTimeStamp : TimeStamp;
	varTimeStamp : TimeStamp;
	selectedTimes : CM_StringDict;
	stringTime : CM_String;
	time : Time;
	
begin
	
	defaultYACodeChanged	:= false;
	create selectedTimes transient;
	
	if self.myObjectMatchCriteria &lt;&gt; null then
		self.txtYACode.text := self.myObjectMatchCriteria.name;
		self.txtProjected20.text := self.myObjectMatchCriteria.priority.asStringJMT;
		self.txtProjected30.text := self.myObjectMatchCriteria.maxStackHeight.asStringJMT;
		self.chkDisableYA.value := self.myObjectMatchCriteria.neverMix;
				
	else
		self.txtYACode.text := null;
		self.txtProjected20.text := null;
		self.txtProjected30.text := null;
		self.chkDisableYA.value := false;
				
	endif;

	self.doSetupCriteriaFrames();
	
epilog

	delete self.myAssistant;
	delete selectedTimes;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="c45460a2-6ede-4904-aecd-0f8ab49f7b31">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	priority : Integer;
	allTransientCriteriaObj	: CMIF_Array;
	pxyObjMatch : CM_ObjectMatchCriteria;
	loadState : Boolean;
	result : Integer;
	real : CM_ObjectMatchCriteria;
	name : String;
	neverMix : Boolean;
	maxStackHeight : Integer;
	msg : String;
	deleteProxy : Boolean;
	new : Boolean;

begin

	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	if self.myObjectMatchCriteria &lt;&gt; null then
		// let the real updating occur on the source form
		pxyObjMatch := self.myObjectMatchCriteria;
		
	else
		create pxyObjMatch as CM_GriddedTAStackHeight transient;
		new := true;
	endif;
	
	priority := self.txtProjected20.text.asIntegerJMT;	
	name := self.txtYACode.text;
	neverMix := self.chkDisableYA.value;
	maxStackHeight := self.txtProjected30.text.asIntegerJMT;
	
	if allTransientCriteriaObj.isEmpty then
		msg := app.getErrorString( No_Criteria_values_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		deleteProxy := true;
		return false;
	elseif name.trimBlanks = null then
		msg := app.getErrorString( Input_required_field_fileName );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.txtYACode.setFocus;
		deleteProxy := true;
		return false;
	elseif priority &lt;= 0 then
		msg := app.getErrorString( No_Priority_entered );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.txtProjected20.setFocus;
		deleteProxy := true;
		return false;
	elseif maxStackHeight &lt;= 0 then
		msg := app.getErrorString2(Invali_value_must_greate_than, app.getErrorString(Max_Number_in_stack), "1" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.txtProjected30.setFocus;
		deleteProxy := true;
		return false;
	elseif new and self.myTerminalAreaMaster.allGriddedTAStackHeights.getAtKey( priority ) &lt;&gt; null then
		msg := app.getErrorString1(Priorit_value_already_used, priority.String );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.txtProjected20.setFocus;
		deleteProxy := true;
		return false;
	endif; 
	
	pxyObjMatch.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
							priority	//_priority : Integer
							);
							
	pxyObjMatch.CM_GriddedTAStackHeight.setProxyBaseData(	maxStackHeight, //_maxStackHeight : Integer;
															name, //_name : String;
															neverMix,	//_neverMix : Boolean;
															self.myTerminalAreaMaster //_termAreaMaster : CM_TerminalAreaMaster
															);
	

	pxyObjMatch.CM_GriddedTAStackHeight.validateMe();
	if app.myPassport.hasErrors then
		app.msgBox( app.myPassport.getAllErrorsWarningsAsString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		deleteProxy := true;
		return false;
	endif;
	
	self.unloadForm;
	
	return true;
	
epilog

	if deleteProxy then
		delete pxyObjMatch;
		if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then	//23 Jan 2018	NDL	TFS 43045
			allTransientCriteriaObj.purge();
		endif;
	endif;
	
	delete allTransientCriteriaObj;
	app.cmsEndLoad(loadState);
		
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="dea49987-dbe9-4388-b26e-71b888e412a8">
        <updating/>
        <source>setBaseData(	_myObjectMatchCriteria : CM_GriddedTAStackHeight;
				_myCallingForm : CM_TableViewForm
				)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin

	self.myObjectMatchCriteria := _myObjectMatchCriteria;
	self.myCallingForm := _myCallingForm;
	if self.myCallingForm &lt;&gt; null then
		self.setMyTerminal( self.myCallingForm.myTerminal );
		self.myTerminalAreaMaster := self.myCallingForm.myProxyObject.CM_TerminalAreaMaster;
	endif;

epilog

end;</source>
        <Parameter name="_myObjectMatchCriteria" type="CM_GriddedTAStackHeight"/>
        <Parameter name="_myCallingForm" type="CM_TableViewForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b960dd80-5065-4017-a2ab-770c1fd3c4f3">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation
28/11/2023			navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

begin

	self.initialSheetIndex := 1; 
	self.handleMenusForModalDisplay();
	self.moveControlsForSetup();
	
	inheritMethod();
	
	// 28/11/2023	navkc1 Bug 60782
	self.picCriteria.height := self.shtCriteria.height - 10;
	self.fldYardAlloc.height := self.btnSave.top - self.fldYardAlloc.top - 10 ;
	
	if self.myParentForm &lt;&gt; null then
		self.centreOverParent( 0 );
	endif;
	
	self.txtYACode.setFocus();
	
	self.btnSave.enabled := app.myCurrentUserCan(self.myTerminal, PmAdmTermareadefMaint);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="723d9bc1-2719-4777-8773-2e237730b58d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 September 2020 08:34:33.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024034, locale);
end;</source>
    </JadeMethod>
</GUIClass>
