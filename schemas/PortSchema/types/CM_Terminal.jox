    <JadeMethod name="isUsingAutoBookingId" id="8b0b09a8-d3d4-4e8b-a509-03f3278ded20">
        <source>isUsingAutoBookingId():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation

*/

vars

	bookingIdGen : CM_AutoBookingIdGen;

begin

	bookingIdGen := self.getMyAutoIdGenerator( CM_AutoBookingIdGen ).CM_AutoBookingIdGen;
	if bookingIdGen = null or not bookingIdGen.isEnabled then
