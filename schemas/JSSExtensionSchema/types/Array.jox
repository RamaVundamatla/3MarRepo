<CollClass name="Array">
    <JadeMethod name="jssDoSort" id="26a9f658-9b46-4d96-b6f4-fcf99c1da781">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter:JSSSorter) updating, protected, abstract;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the JSSSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
// --------------------------------------------------------------------------------
// Parameters:	pTheSorter - A reference to the transient JSSSorter object.
//
// Returns:		Nothing
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
    <JadeMethod name="jssRandomSelect" id="c964c142-afb1-4cca-8575-fdbdcc619463">
        <lockReceiver/>
        <updating/>
        <source>jssRandomSelect(pMaxSelect:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2003 by cnwdad1
//
// Purpose:		Randomly selects a maximum number of candidate elements from receiver,
//				and discards the remaining elements.
//
// Parameters:	pMaxSelect - The maximum number of candidates to randomly select.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryName		: String;
	arraySize		: Integer;
	loopCount		: Integer;
	arrayPointer	: Integer;
	allCandidates	: Array;
	
begin
	if self.isEmpty() then
		return;
	endif;
	
	arraySize	:=	self.size();
	
	if pMaxSelect = arraySize then
		return;
	elseif pMaxSelect &gt; arraySize then
		JSSException.raise_(JSS_X_03011, "The maximum number of selections (" &amp; pMaxSelect.String &amp; ") cannot exceed the number of candidates (" &amp; arraySize.String &amp; ").");
		return;
	endif;
	
	if pMaxSelect &gt; (arraySize div 2) then
		// The number of elements to select is more than half of the candidates,
		// so it'll be more efficient to randomly select elements to discard.
		
		loopCount	:=	arraySize - pMaxSelect;
		
		while loopCount &gt; 0 do
			arrayPointer	:=	app.random(self.size());
			
			if arrayPointer &gt; 0 then
				self.removeAt(arrayPointer);
				loopCount	:=	loopCount - 1;
			endif;
		endwhile;
	else
		// The number of elements to select is less than half of the candidates,
		// so it'll be more efficient to randomly select elements to keep.
		
		create allCandidates as self.class() transient;
		loopCount	:=	pMaxSelect;
		
		while loopCount &gt; 0 do
			arrayPointer	:=	app.random(self.size());
			
			if arrayPointer &gt; 0 then
				allCandidates.add(self[arrayPointer]);
				self.removeAt(arrayPointer);
				loopCount	:=	loopCount - 1;
			endif;
		endwhile;
		
		self.clear();
		allCandidates.copy(self);
	endif;
epilog
	delete allCandidates;
end;</source>
        <Parameter name="pMaxSelect" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssScramble" id="591f7bbd-6f7f-4a32-b5c6-7490d359a1f4">
        <lockReceiver/>
        <updating/>
        <source>jssScramble() updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2003 by cnwdad1
//
// Purpose:		Randomly scrambles the order of the receiver's elements.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allElements		: Array;
	loopCount		: Integer;
	arrayPointer	: Integer;
	
begin
	if self.isEmpty() then
		return;
	endif;
	
	create allElements as self.class() transient;
	loopCount	:=	self.size();
	
	while loopCount &gt; 0 do
		arrayPointer	:=	app.random(self.size());
		
		if arrayPointer &gt; 0 then
			allElements.add(self[arrayPointer]);
			self.removeAt(arrayPointer);
			loopCount	:=	loopCount - 1;
		endif;
	endwhile;
	
	allElements.copy(self);
epilog
	delete allElements;
end;</source>
    </JadeMethod>
    <JadeMethod name="jssSort" id="72d663ca-f6fc-4261-be7a-4bad3b529033">
        <lockReceiver/>
        <updating/>
        <source>jssSort(pIsDescending:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the CnEcSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
//
// Parameters:	pIsDescending - If True, the array will be sorted in descending
//					order, otherwise ascending order will be assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSorter		: JSSSorter;
	
begin
	create theSorter transient;
	theSorter.setSortType(self.jssGetMemberType.name, pIsDescending);
	self.jssDoSort(theSorter);
epilog
	delete theSorter;
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</CollClass>
