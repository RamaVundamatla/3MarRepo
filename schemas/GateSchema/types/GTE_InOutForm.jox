    <JadeMethod name="getTblMainMaxHeight" id="b3b9ee48-975b-42ba-8b01-d8e6e0638879">
        <source>getTblMainMaxHeight() : Integer protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	extra	: CM_EntryTable;

begin

	extra := topSheet.myTblExtra;
	
	if extra &lt;&gt; null and extra.visible then
		return (extra.top - 20 - 2).rounded;
	else
		return (topSheet.height - 5 - 5).rounded;
	endif;

end;</source>
