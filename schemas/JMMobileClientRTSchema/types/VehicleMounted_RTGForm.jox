    <JadeMethod name="loadTaskTable" id="8bf5f892-779f-431e-840e-d2862389c55f">
        <updating/>
        <source>loadTaskTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
	row : Integer;
begin

	theTable:=tblJobs;
	
	row:=theTable.fixedRows + 1;
	while row &lt;= theTable.rows do
		theTable.deleteRow(row);
	endwhile;
	
	app.myVehicleMountedRTGGuiAgent.loadTable(theTable);
	
	//this just updates the colors
	self.updateTableElapsedTimes(false);
	
	if theTable.rows &gt; theTable.fixedRows then
		if (not self.timerRefreshActive) then
			self.beginTimerForRefresh();
		endif;
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshTableEntry" id="a9e6137b-9aa9-4495-9b31-327d80b6650d">
        <updating/>
        <source>refreshTableEntry(_entry: CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwer1	Initial creation

*/

vars

begin
	app.myVehicleMountedRTGGuiAgent.refreshTableEntry(self.tblJobs,_entry);

	//this just updates the colors
	self.updateTableElapsedTimes(false);
	
	if self.tblJobs.rows &gt; self.tblJobs.fixedRows then
		if (not self.timerRefreshActive) then
			self.beginTimerForRefresh();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_entry" type="MobileHandHeldThin::CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3d18b4bf-a1c0-4c46-9c54-3aafd58245b8">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	errorStr : String;
begin
	inheritMethod();
	
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, EVENT_TWISTLOCK_OPENED, Response_Continuous , null);
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, EVENT_TWISTLOCK_CLOSED, Response_Continuous , null);
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj,EVENT_RFIDINFO,Response_Continuous , null);
	if not app.isRunningOnCE then
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'RTG Dev mode (has control box)';
		self.height := self.height + 25;
	endif;
	
	self.setupTable;
	self.setupTaskCaption;
	self.loadTaskTable();
	self.loadReasonCombo;
	configElapsedTime:=app.myHandHeldGuiAgent.getTerminalConfig(HandHeldAgent.ConfigElapsedTimeExceeded).Integer;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
	self.btnJobOrder.visible := false;			//+cnwml2 PAR25751 DCT CCMS 2017
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMsgFrameNew" id="4056b8d8-186a-4ac3-b553-91400e9beb89">
        <updating/>
        <source>setupMsgFrameNew(	_type : String;
					_containerId,
					_fromLoc, 
					_toLoc : String io;
					_ostow : Boolean;
					_canEditTo,
					_toIsVehicle:Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants
	Complete = "Complete";
	Overstow = "Overstow";
	MoveLabel = " move of ";
	From = " from ";
	To = " to ";
	Unknown = "...";
vars
	moveString : String;
	idx : Integer;
begin
	//initalise 
	lblRow.caption:="Location";	
	lblRow.visible:=true;
	txtRow.visible:=_canEditTo;
	lblRow.visible:=_canEditTo;
	frmAccept.centreWindow();	
	
	fromLocationId:=_fromLoc;
	toLocationId:=_toLoc;
	toLocationId := toLocationId.trimBlanks();
	
	// ### if there is a space it will be the stack height, so remove it
	idx :=  toLocationId.pos(" ",1);
	if idx &gt; 0 then
		toLocationId := toLocationId[1:idx];
	endif;
	if _ostow then	
		moveString:=Overstow;
	else
		moveString:=Complete;
	endif;
	if _canEditTo then
		txtRow.text:=toLocationId;
		if _toIsVehicle then
			lblRow.caption:="Vehicle";
		endif;
	endif;
	self.clearErrors;
	currentContainerId :=_containerId;
	self.lblMsg.caption:=moveString &amp; MoveLabel &amp; _containerId &amp; From  &amp; _fromLoc &amp; To &amp; _toLoc;

	self.frmAccept.visible:=true;
	self.changeDefaultButtons(btnAccept,btnMsgOK);
	self.changeCancelButtons(btnLogoff,btnMsgCancel);
	self.txtRow.setFocus();
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_containerId" type="String" usage="io"/>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_ostow" type="Boolean"/>
        <Parameter name="_canEditTo" type="Boolean"/>
        <Parameter name="_toIsVehicle" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupTable" id="f9ec6fa6-3218-42fb-a25d-91f8665c4def">
        <source>setupTable() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
begin
	
	theTable := self.tblJobs;
