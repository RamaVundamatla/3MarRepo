<Class name="CM_CAMSAudit" id="11a84f07-ab29-4839-b533-629955c0c73a">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="camsAudit"/>
    <PrimAttribute name="auditType" id="f6e6c087-e711-4008-944b-6c3854369b00">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myRelatedTransaction" id="9d1e824f-09b1-4aa6-9b9a-a2ea52bb0048">
        <embedded/>
        <type name="CM_TITransaction"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="e51da03d-9294-42af-9185-3af075c29897">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
05 February 2013	cnwcs5	Initial creation -  CCMS SFW 1294 /par 30855 
*/
vars
	trx				:CM_TITransaction;
	gotException	:Boolean;
	str				:String;
begin
	if _attrName = ETRow_Details then
		on Exception do app.handleDeletedObject (exception, trx, gotException);
		
		trx := self.myRelatedTransaction;
		
		if trx &lt;&gt; null and 
			trx.class &lt;&gt; null then	// always true
			
			str := trx.getTypeString;
		endif;
		
		if trx = null or gotException then
			str := 'Unknown' ;
		endif;
		
		if self.isDelete then
			return str &amp; ' - transaction deleted';
		else
			return str &amp; ' - transaction updated';
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyRelatedTransaction" id="dfe1cc72-5aee-4c04-8816-8c562d178b6a">
        <source>getMyRelatedTransaction():CM_TITransaction;
/*
Date		Who		Reason
07 Feb 2013	cnwcs5	Initial creation - CCMS SFW 1294 / par 30855 
*/
//05 Nov 2014	cnwrs1	par 35184 Messina Cams failing with code 4
vars
	trx				:CM_TITransaction;
	getException	:Boolean;
	trxEdition : Integer;
begin
	trx := self.myRelatedTransaction;
	
	on Exception do app.handleDeletedObject(exception, trx, getException);
	if trx &lt;&gt; null then 
		trxEdition := trx.edition;
		if getException then
			return null;	// must be invalid
		endif;
		return trx;
	endif;
	
	// must be invalid
	return null;
epilog

end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="isDelete" id="7ac851e4-b77c-4714-ab0f-c9be4f536995">
        <source>isDelete():Boolean;
/*
Date		Who		Reason
17 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars

begin
	return self.auditType = AuditDeleted;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUpdate" id="e1a94987-a48a-4389-85ae-d5cb1d93d7b7">
        <source>isUpdate():Boolean;
/*
Date		Who		Reason
17 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars

begin
	return self.auditType = AuditUpdated;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditType" id="bf15b304-5ca5-4fcc-b5cb-1cfb4842a3d9">
        <updating/>
        <source>setAuditType(_value :Integer) updating;
/*
Date		Who		Reason
18 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars

begin
	if _value &lt;&gt; AuditUpdated and _value &lt;&gt; AuditDeleted then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Invalid audit type passed to method");
	endif;
	
	self.auditType	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyRelatedTransaction" id="97d0315b-bf57-4f86-82d0-564824bab8b4">
        <updating/>
        <source>setMyRelatedTransaction(_value :CM_TITransaction)updating;
/*
Date		Who		Reason
04 Feb 2013	cnwcs5	Initial Creation - CCMS SFW 1294 /par 30855
*/
vars

begin
	self.myRelatedTransaction := _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
