    <JadeMethod name="auditId" id="b67b37b2-bd6b-45d5-a4c6-900b06930a51">
        <source>auditId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	str : String;

begin

	str := getDisplayStringForAttribute(ETRow_Priority,false);
	str := str &amp; " " &amp; myTerminal.code;
	str := str &amp; " " &amp; getDisplayStringForAttribute(ETRow_MyOperator,false);
	str := str &amp; " " &amp; getDisplayStringForAttribute(ETRow_MyISOGroup,false);
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
