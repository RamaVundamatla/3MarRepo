    <JadeMethod name="isVoyageCalcTypeForProforma" id="9f0078af-bd71-42b7-8d77-cea31b732f45">
        <source>isVoyageCalcTypeForProforma() : Boolean;
/*

Purpose:			TFS 37454

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2018	jlgab1	Initial creation

*/

vars
	aCT : CM_CalculationType;

begin
	aCT := self.getCalcType();
	
	if aCT = null then
		return false;
	endif;
	
	if aCT.isEventCalcType then
		if self.invoiceType &lt;&gt; null and self.invoiceType.isVoyageSpecific() then
			return true;
		endif;
	else
		return aCT.isVoyageCalcType;
	endif;

	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
