    <JadeMethod name="loadCombos" id="bbbf56b4-0548-416f-a466-a8673adb7fa1">
        <source>loadCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2017	cnwns1	Initial creation

*/

vars
	iter : Iterator;
	mt : CM_MeasurementType;
	index : Integer;
begin
	self.myForm.cmbMeasureUnit.clear;
	
	
	iter := app.myRoot.allMeasurementTypesByShortName.createIterator;
	
	while iter.next( mt ) do
		if mt.measurementType &lt;&gt; Type_Weight then
			continue;
		endif;
		
		if not mt.isAvailableForEntry then
			continue;
		endif;
		self.myForm.cmbMeasureUnit.itemObject[ self.myForm.cmbMeasureUnit.addItem( mt.name ) ] := mt;	
	endwhile;
	
	
	self.myForm.cmbUpdatedAfter.clear();
	self.myForm.cmbUpdatedAfter.itemData[ self.myForm.cmbUpdatedAfter.addItem( CM_WeighBridgeObj.SingleReadingStr ) ] := CM_WeighBridgeObj.SingleReading;
	self.myForm.cmbUpdatedAfter.itemData[ self.myForm.cmbUpdatedAfter.addItem( CM_WeighBridgeObj.TwoReadingsStr ) ] := CM_WeighBridgeObj.TwoReadings;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="e16e8dff-e519-4618-91e9-c90f1b82d23b">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := false;
			
	self.loadCombos();		
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		
		theForm.loadCmbWBridgeType();
		theForm.loadCmbGateLane();
		
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_IpAddress);
		theForm.tblInput1.enableRowByName(ETRow_WeighBridgeType);
		theForm.tblInput1.enableRowByName(ETRow_PortNumber);
		theForm.tblInput1.enableRowByName(ETRow_TimeOutSeconds);
		theForm.tblInput1.enableRowByName(ETRow_CargoUpdateMode);
		theForm.tblInput1.enableRowByName(ETRow_CanUpdateRTS);	//11 May 2020	NDL	TFS 49296
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		self.changeViews(null);
		
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		
		
	else

		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_WeighBridgeObj);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Name);
		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="b5e26f53-8726-462b-9c80-fef568610113">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

