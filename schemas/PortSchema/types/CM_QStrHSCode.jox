<Class name="CM_QStrHSCode" id="ddfb85ba-dc65-475f-9872-3266d72b91b3">
    <superclass name="CM_QStringLookupProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="bc7ed564-e31c-48c3-85c3-4f57627caad4">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="3b27b9cb-61fe-4d49-a49e-79084a7e3f41">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 55585
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	hsCode			: CM_HarmonizedSystem;
	hsCodeDict		: CM_HarmonizedSysByCodeDict;
	byName			: Boolean;				

begin
	
	_combo.clear();
	hsCodeDict := app.myRoot.allHSCodesActive;	

	foreach hsCode in hsCodeDict do
		_combo.itemObject[_combo.addItem(hsCode.getDisplayString())] := hsCode;		
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := hsCodeDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := hsCodeDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a9ee8194-37e9-4176-8a1f-f654a710120a">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 55585
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode 			: CM_HarmonizedSystem;
	hsCodeDict     	: CM_HarmonizedSysByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	
	hsCodeDict := app.myRoot.allHSCodesActive;
	
	_tbl.rows := _tbl.fixedRows;
	
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach hsCode in hsCodeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(hsCode.id) then
			selectionValue := 1;
			array.add(hsCode);
		endif;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; hsCode.getDisplayString());
		_tbl.accessRow(idx).itemObject := hsCode;
	endforeach;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="700908b7-bf22-4f9d-bc55-c0c0124ddbee">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 55585
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode 		: CM_HarmonizedSystem;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			hsCode := _tbl.accessRow(idx).itemObject.CM_HarmonizedSystem;
			sa.add(hsCode.id);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="de00becb-77bf-4a08-a4de-6eb6330d63ac">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	
	if _value.isKindOf(CM_HarmonizedSystem) then
		if _value &lt;&gt; null then
			return _value.CM_HarmonizedSystem.id;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="736ac2e8-c7bd-402c-a34d-5575daa53b40">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 November 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: CM_HarmonizedSystem;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_HarmonizedSystem) then
			object := _value.CM_HarmonizedSystem;
		endif;
		
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.id;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
