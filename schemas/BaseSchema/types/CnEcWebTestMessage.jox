<Class name="CnEcWebTestMessage" id="9b9ecb7b-2c31-4c66-aa22-69624c1d414a">
    <superclass name="CnEcWebTestEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

