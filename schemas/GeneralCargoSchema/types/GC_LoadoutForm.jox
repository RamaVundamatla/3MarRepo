    <JadeMethod name="getTblDataDetailCargoType" id="64ebd750-4953-4e8e-9559-e6c68f1b3605">
        <source>getTblDataDetailCargoType(_row : Integer) : CM_CargoType;
// ---------------------------------------------------------------------------
// Created:     29 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	lineType,
	currentRow,
	row,
	numRows			: Integer;
	tmpCell 		: JadeTableCell;
	tmpCmb 			: CMUI_ComboBoxCargoTypeForTerm;
	cargoType		: CM_CargoType;
begin
	
	row := _row;
	tbl	:= self.tblDataDetail;	
	
	if row &lt;= tbl.fixedRows or row &gt; tbl.rows then 
		return null;
	endif;
	
	tmpCell := tbl.accessCell(row, self.colCargoType);
	tmpCmb := tmpCell.cellControl.CMUI_ComboBoxCargoTypeForTerm;
	 
	if tmpCmb.listIndex = -1 then // none selected
		return null;
	endif;
	
	cargoType := tmpCmb.myObject.CM_CargoType;
	
	return cargoType;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
