    <JadeMethod name="setupForm" id="134fe63f-102e-497d-883b-accaf097a19c">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();


	if not self.myTerminal.getConfig(GateAllowDualGate).Boolean then
		app.msgBox("To use Machine Rules with RDT queue jobs you must set the 'Use Multiple Machine Queuing' terminal configuration flag, on the Gate tab.","Note",MsgBox_Information_Icon); // PAR 17890, made message clearer
//		self.unloadForm();
//		return;
	endif;
	
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.setNavigatorHeading(self.caption);
	self.dkcMain.width:=self.clientWidth;
	self.dkcMain.parentAspect:=Control.ParentAspect_StretchBoth;
	
	self.initTblData();	
	
	self.beginClassNotification(CM_RTQueueMultiRule, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_RTQueueMultiRule, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_RTQueueMultiRule, false, Object_Update_Event, Response_Continuous, 0);
	
	

end;</source>
    </JadeMethod>
