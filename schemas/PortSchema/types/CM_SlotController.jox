    <JadeMethod name="getSequence" id="6579f6f8-1429-45bb-bcea-e7f901103e30">
        <source>getSequence(_isDischarge : Boolean; _isStarboard : Boolean) : Integer;
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Given 2 booleans, determine the appropiate seq num.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if _isDischarge then
		if _isStarboard then
			return self.mySlotDefnVoyage.sequenceNumStarDis;
		endif;
		return self.mySlotDefnVoyage.sequenceNumPortDis;
	else
		if _isStarboard then
			return self.mySlotDefnVoyage.sequenceNumStarLoad;
		endif;
		return self.mySlotDefnVoyage.sequenceNumPortLoad;
	endif;
end;</source>
        <Parameter name="_isDischarge" type="Boolean"/>
        <Parameter name="_isStarboard" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTasks" id="46a92d8b-70e9-47b3-be18-971453680871">
        <source>getSetdownTasks(_arbiter: CM_RTQueueArbiter input; _isOverstowMove : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     method that returns the work required to set TI to this controller
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	task	: CM_RTQueueTask;
begin
	create task;
	task.setDetails(	_arbiter.ti.getPrimaryLocation(REAL_MODE),
						self,
						TASK_UNACTIONED,
						TASK_SETDOWN,
						_arbiter.ti);
	task.isOverstowTask := _isOverstowMove;
	
	_arbiter.entry.addTask(task);

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSpannedToLCs" id="b13bd6e8-277f-4601-b4bc-bbdf30176311">
        <source>getSpannedToLCs(_control: CMIF_MoveController input): Boolean;
// ---------------------------------------------------------------------------
// Created:     28 February 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	units : Real;
	tArray : CM_LCArray;
	lc : CM_SlotController;
	count : Integer;
begin
	// if we have already set multiple locations for this TI then get out, break bulk can take up more than one slot
	if _control.allToLocations.size &gt; 1 then
		if _control.myTrackedItem &lt;&gt; null then
			if _control.myTrackedItem.isKindOf(CM_Cargo) then
				return true;
			endif;
		endif;
	endif;

	inheritMethod(_control);		//Clears toSecondaryLocations coll (no return)

	 // PAR 16415 CCMS 1029
	if _control.myTrackedItem.isAttributeTrue(TI_Attrib_IsThirty) then
		if not self.is30ft then
			return false;
		endif;
	endif;
	if _control.myTrackedItem.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		if not self.is53ft then
			return false;
		endif;
	endif;
	// PAR 18682 CCMS 1055
	if _control.myTrackedItem.isAttributeTrue(TI_Attrib_IsFortyFive) then
		if not self.is45ft then
			return false;
		endif;
	endif;
	
	// PAR 17841
	if _control.myTrackedItem.isAttributeTrue(TI_Attrib_IsForty) then
		if not self.isFortyFront then
			return false;
		endif;
	
	endif;

	//Determine the # of spaces this TI will take up
	units := _control.myTrackedItem.getLengthInUnits();
	if units &lt;= 2 then
		//---------------
		//This controller will carry it off (2 * 10' units = my size. i.e. 1 * 20' unit)
		//---------------
		return true;
	endif;
	//---------------
	//Convert to 20' scale
	//---------------
	units := units div 2;
	//---------------
	//Because each of me is a 20' unit, I need 1 for each 2 units returned from the call
	//as they are 10' units as well
	//---------------
	if self.myAftSlotInHold() = null then //self.myAftSlot = null then AKB2003MAY
		//There is NO next LC (slot)!

		return false;
	endif;
/* PAR 17841 moved up for 40s only
	if not self.isFortyFront then
		return false;
	endif;

*/
	create tArray transient;
	lc := self.myAftSlot;
	count := 1;
	while true do
		if lc = null then
			break;
		endif;
		count := count +1;
		tArray.add(lc);
		if count = units then
			break;
		endif;	
		lc := lc.myAftSlot;
	endwhile;	
	//--------------------
	//Return whether there are enough positions
	//--------------------
	if (tArray.size + 1) &lt;&gt; units then
		//Subtract 1 for the current lc where we started from (its NOT in the array returned)
		return false;
	endif;
	//Set the array
	_control.setMyToSecondaryLocations(tArray);
	return true;
epilog
	delete tArray;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStateForTIHere" id="0e781710-8b9d-44ae-ac63-3d96ce7f748a">
        <source>getStateForTIHere(_ti : CM_TrackedItem): Integer;
// ---------------------------------------------------------------------------
// Created:     09 January 2002 by cnwdwq1
//
// Purpose:     See superclass
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if self.allTrackedItems.includes(_ti) then
		//-------------
		//Is here.
		//-------------
		return TI_STATE_ONSHIP;
	endif;
	if self.getFutureMoveOfTypeForTI(PLANNING_MODE, TI_FutureMovePlannedOrDLR, _ti) &lt;&gt; null then
		//-------------
		//Is planned here
		//-------------
		return TI_STATE_ONSHIP;
	endif;
	if self.getFutureMoveOfTypeForTI(QUEUE_MODE, TI_FutureMoveQueued, _ti) &lt;&gt; null then
		//-------------
		//Is queued here
		//-------------
		return TI_STATE_ONSHIP;
	endif;
	if self.getFutureMoveOfTypeForTI(PLANNING_MODE, TI_FutureMoveEDI, _ti) &lt;&gt; null then
		//-------------
		//Check for EDI.
		//-------------
		return TI_STATE_EDI;
	endif;
	return TI_STATE_UNDEFINED;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStowageId" id="1e1f3d6a-a4a6-4a54-9ab9-8a9e423c6a7c">
        <source>getStowageId(_ti:CM_TrackedItem):String;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     Converted from C++. Returns the 40' corrected stowageid of the slot defn.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	structure 		: CM_CellularVoyageStructure;
	lStowageId		: String;
	is40			: Boolean;
	slotDefnVoyage	: CM_SlotDefnVoyage;
begin
	
	if self.myVoyage = null then
		return null;
	endif;
	
	structure := self.myVoyage.myCellularVoyageStructure;
	
	if structure.use40Id then
		if _ti &lt;&gt; null then
			if _ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isOverSizedContainer() then // PAR 16415 CCMS 1029
				is40 := self.myBayVoyage.canHandle4045();
			endif;
		endif;
	endif;
	
	slotDefnVoyage := self.mySlotDefnVoyage;
	
	if slotDefnVoyage = null then
		return null;
	endif;

	lStowageId := slotDefnVoyage.getStowageId(is40, structure.useBayCellTierNumbering);
	
	return lStowageId;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIForDisplayMode" id="afae482e-57b6-4613-935b-6905cae7347b">
        <source>getTIForDisplayMode(_mode : Integer; _theEDIIndex : Integer; _numTIs : Integer output) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     Returns the TI for the display mode and also the numTIs
// ---------------------------------------------------------------------------
vars
	theMode	: Integer;
	theTI	: CM_TrackedItem;
	tmpStr	: String;

begin

	theMode := _mode;

	if theMode = ShpDisplayMode_Actual or
	   theMode = ShpDisplayMode_ColCodeDisch then
		_numTIs := self.allTrackedItems.size;
		if _numTIs &gt; 0 then
			theTI := self.allTrackedItems.first;
		endif;

	elseif theMode = ShpDisplayMode_ColCodeLoad then
		theTI:= self.getTIAtIndex(PLANNING_MODE, 1);
		if theTI &lt;&gt; null then
			_numTIs := 1;
		endif;

	elseif theMode = ShpDisplayMode_EDI then
		_numTIs := 0;

		if _theEDIIndex &gt; 0 then
			theTI := self.getTheEDITrackedItemsForIndex(_theEDIIndex);
			if theTI &lt;&gt; null then
				_numTIs := 1;
			endif;
		endif;

	elseif theMode = ShpDisplayMode_Proposed then
		self.getProposedCargo(theTI, _numTIs);
	endif;


	return theTI;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_theEDIIndex" type="Integer"/>
        <Parameter name="_numTIs" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIsForOtherVoyage" id="3f8ef9e4-16ed-47c1-80a4-72285403a9f4">
        <source>getTIsForOtherVoyage(_proposed: Boolean; _otherVoyage: CM_Voyage; _tmpTIs: CM_TIArray input; _otherSlot: CM_SlotController output);
//----------------------------------------------------------------
//	Created:	04 August 2004	by Jason Chapman  (cnwjc2)
//
//	This will get TI's for the equivalent sc on the passed in voyage.
//	Used for multi-terminal inter-terminal voyage transfer.
//
//----------------------------------------------------------------
vars
	matchingSlot 	: CM_SlotController;	//slot on otherVoyage
begin
	if _otherVoyage = null then
		return;
	endif;
	
	matchingSlot := _otherVoyage.getMatchingSlot(self);
	
	if matchingSlot = null then
		return;
	endif;
	
	if _proposed then 
		matchingSlot.getProposedTIs(_tmpTIs);
	else
		matchingSlot.allTrackedItems.copy(_tmpTIs);
	endif;

epilog
	_otherSlot := matchingSlot;
end;</source>
        <Parameter name="_proposed" type="Boolean"/>
        <Parameter name="_otherVoyage" type="CM_Voyage"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_otherSlot" type="CM_SlotController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTheEDITrackedItemsForIndex" id="204f45ad-f9fc-47f2-8d56-44ea7ea600b7">
        <source>getTheEDITrackedItemsForIndex(_ediBayPlanIndex : Integer) : CM_TrackedItem;
/*
------------------------------------------------------------------------
Created:			18 March 2003 by cnwdwq1
Purpose:			Returns all TI's in a me for this edibayplan index (could be multiple)
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tMove : CM_FutureMove;
	move : CM_FutureMovePlannedEDI;
	//coll : CM_FutureMoveArray;
	controller : CM_VoyageEDIBayPlanController; 
	iter01 : Iterator;
	theTI : CM_TrackedItem;
begin
	if (_ediBayPlanIndex &lt; 1) or (_ediBayPlanIndex &gt; self.myVoyage.allEDIBayPlans.size) then
		app.raiseCMException(Err_EDIMoveNotValid, null, null);	
		return null;
	endif;
	controller := self.myVoyage.allEDIBayPlans[_ediBayPlanIndex];
	if controller = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI BayPlan controller not found on Voyage');
		return null;	
	endif;
	
//	iter01 := self.allPlannedFutureMoves.createIterator(); // AKB2003MAR
	
//	while iter01.next(tMove) do
	foreach tMove in self.allPlannedFutureMoves where tMove.moveType = TI_FutureMoveEDI do
//		if tMove.moveType = TIFutureMoveEDI then
			move := tMove.CM_FutureMovePlannedEDI;
			if move.myVoyageEDIBayPlanController &lt;&gt; controller then
				//This is basically the index to the EDI bayplan.
				continue;
			endif;
			if move.myTrackedItem = null then
				continue;
			endif;
			theTI := move.myTrackedItem;
			break;
//		endif;
//	endwhile;
	endforeach;

	return theTI;
epilog
	delete iter01;
end;</source>
        <Parameter name="_ediBayPlanIndex" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTransferType" id="8662f436-7fed-403c-949f-ad5c13ae6a0a">
        <source>getTransferType(): Integer;
/*

Date			Who		Reason
27 March 2018	jlgmd1	TFS #37788 - Fix code mismatch between DMAST and WMAST from TFS #4435

*/

vars

begin
	return VESSEL_TYPE_LOLO;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVMRTMoveExtraDetails" id="ea98b398-e5ce-433b-87b6-9af5de527e3f">
        <source>getVMRTMoveExtraDetails(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     23 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpString : String;
	twinTI : CM_TrackedItem;
begin
	tmpString := inheritMethod(_ti);

	if self.myBayVoyage &lt;&gt; null then
		if _ti = null or (_ti &lt;&gt; null and _ti.is20()) then
			tmpString := tmpString &amp; "BAY : "&amp; self.myBayVoyage.id &amp; CrLf;
		else
			tmpString := tmpString &amp; "BAY : "&amp; self.myBayVoyage.idBay40 &amp; CrLf;
		endif;
	endif;

	if _ti &lt;&gt; null then
		twinTI:=_ti.getTwinVoyageLoadTI();
	// PAR 26013
		if twinTI &lt;&gt; null then
			tmpString := tmpString &amp; "MATCH WITH CONTAINER: "  &amp;  twinTI.id &amp; CrLf;
		endif;
	endif;
	
	return tmpString;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWLEForTI" id="88727a13-e822-4c34-b02e-dfcce16cd111">
        <source>getWLEForTI(_ti: CM_TrackedItem): CM_WorkListEntry;
/*
Purpose:			

Date		Who		Reason
10 February 2022	navab1	TFS 51855
*/

vars
	req : CM_Request;
	wle : CM_WorkListEntry;
begin

	foreach req in self.allSlotRequestsDischarge discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;
	foreach req in self.allSlotRequestsLoad discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;

	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWeightRounded" id="f27bc788-f053-4597-89fa-444a635b49fc">
        <source>getWeightRounded(	_mode : Integer; 
					_interTermVoyage: CM_Voyage;					
					_splitWeight : Integer output) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
04 Jun 2010	cnwkpd1	PAR #24281 - Move isBulkRelease() check up for performance

*/

vars
	ti			: CM_TrackedItem;
	theWeight,
	tiWeight	: Decimal[14,4];
	tmpTIs		: CM_TIArray;
	is40TI,
	is40Back	: Boolean;
	aSC			: CM_SlotController;
	lengthInUnits : Real;
	isOtherSize : Boolean;

begin
//	if self.isBulkRelease() then			// PAR #24281 - moved up	//06 Aug 2010 NDL Par 25127 wrong place
//		theWeight := self.mySlotRequestLoad.getWeight();		
//	else 
	
		if _mode = ShpDisplayMode_Defn then	//12 Oct 2010	NDL Par 26002
			return 0;
		elseif _mode = ShpDisplayMode_Actual or
		   _mode = ShpDisplayMode_ColCodeDisch then
			tmpTIs := self.allTrackedItems;
		elseif _mode = ShpDisplayMode_Proposed or
			   _mode = ShpDisplayMode_ColCodeLoad or
			   _mode = ShpDisplayMode_EDI then
			create tmpTIs transient;
			self.getProposedTIs(tmpTIs);
			if tmpTIs.isEmpty() then
				if self.isBulkRelease() then	//06 Aug 2010 NDL Par 25127 
					theWeight := self.mySlotRequestLoad.getWeight();		
					return theWeight.Integer;
				endif;
			endif;
		elseif _mode = ShpDisplayMode_VoyGlobActual or
			   _mode = ShpDisplayMode_VoyGlobProposed then
			if _interTermVoyage &lt;&gt; null then
				create tmpTIs transient;
				self.getTIsForOtherVoyage((_mode = ShpDisplayMode_VoyGlobProposed), _interTermVoyage, tmpTIs, aSC);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'inter-terminal voyage required for this view mode');
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; _mode.String &amp; ')');
		endif;
		
		is40Back := self.isFortyBack;

		foreach ti in tmpTIs discreteLock do
			lengthInUnits := ti.getLengthInUnits;
			isOtherSize := lengthInUnits &gt; 2;
			tiWeight := ti.totalWeight;		
			if isOtherSize and 
			   is40Back then
				// do not include the back end of containers longer than 20 foot			
			else
				theWeight := theWeight + (tiWeight / 1000).rounded;
			endif;
			if isOtherSize then
				_splitWeight := _splitWeight + (tiWeight / 2 / 1000).rounded;
			else
				_splitWeight := _splitWeight + (tiWeight / 1000).rounded;
			endif;
		endforeach;
//	endif;
	
	return theWeight.Integer;

epilog
	if tmpTIs &lt;&gt; null and tmpTIs.isTransient then
		delete tmpTIs;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_interTermVoyage" type="CM_Voyage"/>
        <Parameter name="_splitWeight" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionSlotRequest" id="b85ecf8b-1db4-460c-ac03-fbd7e2930fe7">
        <source>handleExceptionSlotRequest(exObj : Exception; _slotRequest : CM_SlotRequest io) : Integer protected;
//--------------------------------------------------
// Created:	18 March 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_slotRequest := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTIBeingErased" id="230dc1a8-3266-440f-a406-a92a0f6520bb">
        <updating/>
        <source>handleTIBeingErased(_ti : CM_TrackedItem) updating;
/*
Purpose:			
Date		Who		Reason
29 August 2011	cnwab1	Initial creation
*/

vars
	tmpWLE : CM_VoyageWLE;
	req : CM_SlotRequest;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, req, invalidObj);

	req := self.mySlotRequestDischarge;
	
	if req &lt;&gt; null then
		req.removeWLE(tmpWLE,_ti);
		if invalidObj then
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="has20FTInBackend" id="5b11c9d1-24d3-4238-bf58-5a142429ac67">
        <source>has20FTInBackend(_trackedItem : CM_TrackedItem) : Boolean;
/*
Purpose:		Checks to see if is a back end and there is currently a 20Ft container in it
				if there is then return error message
Parameters:			

Return Value:		

Date			Who		Reason
12/07/2010	cnwmh5	Initial creation #24827
30/11/2010	cnwdap1	PAR #26426 CCMS MES 1102 added new parameter to createPlanningTrackedItem method
*/
vars
	dischargeTI,
	ti					: CM_TrackedItem;
	obj					: Object;
	slotRequest			: CM_SlotRequest;
	slotController		: CM_SlotController;
	
	tiArray				: CM_TIArray;
	
	has20FTInBackend 	: Boolean;
	isoGroup : CM_ISOTypeGroup;
begin

	has20FTInBackend := false;

	// no tracked item then everything is fine
	if _trackedItem = null then
		return false;
	endif;
	
	// check to see it tracked item is 20Ft is so then don't do anything
	if _trackedItem.is20() then
		return false;
	endif;
	
	
	
	// get the relevant ti's depending on whether fortyFront or fortyBack
	create tiArray transient;
	if self.isFortyBack then
		self.allTrackedItems.copy(tiArray);
		self.getAllPlannedQueuedFutMoves(tiArray, true, true);
		slotController := self;
	elseif self.isFortyFront then
		slotController := self.myAftSlot;
		if slotController &lt;&gt; null then
			if slotController.mySlotRequestLoad &lt;&gt; null then
				slotRequest := slotController.mySlotRequestLoad;
				if slotRequest &lt;&gt; null then
					if slotRequest.myBulkReleaseReserveDetail &lt;&gt; null then
						tiArray.add(slotRequest.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self, true));
					endif;
				endif;
				if tiArray.size = 0 then
					if slotRequest.getVoyageLoadController() &lt;&gt; null then
						slotRequest.getVoyageLoadController().getAllPlannedQueuedFutMoves(tiArray, true, true);
					endif;
				endif;
			//else
			//	slotController.allTrackedItems.copy(tiArray);			// 15/07/2010 cnwmh5 #25057
			//	slotController.getAllPlannedQueuedFutMoves(tiArray, true, true);
			endif;
			slotController.allTrackedItems.copy(tiArray);				// 15/07/2010 cnwmh5 #25057
			slotController.getAllPlannedQueuedFutMoves(tiArray, true, true);
		endif;
	endif;
	
	//20/08/2010 cnwdz2 25464
	if slotController &lt;&gt; null then
		slotRequest := slotController.mySlotRequestDischarge;
		if	slotRequest &lt;&gt; null then
			dischargeTI := slotRequest.getTrackedItem();
		endif;
	endif;
	
	
	// read through the ti's got and see if there are any 20FT's there already
	foreach obj in tiArray do
		ti := obj.CM_TrackedItem;
		///if ti.is20() and dischargeTI &lt;&gt; null and ti &lt;&gt; dischargeTI then 			// 20/08/2010 cnwdz2 25464
		if ti.is20() then
			if (dischargeTI &lt;&gt; null and ti &lt;&gt; dischargeTI) or (dischargeTI = null and ti &lt;&gt; _trackedItem) then // 28/09/2010 cnwmh5 #25882
				//app.raiseCMException5(Error_Cant_Move_TI_In_Backend, _trackedItem.id, _trackedItem.myVoyage.code, // 04/10/2010 cnwmh5 #25936
				app.raiseCMWarning5(Error_Cant_Move_TI_In_Backend, _trackedItem.id, _trackedItem.myVoyage.code, 
					self.getStowageId(_trackedItem), ti.id, slotController.getStowageId(ti), null, null, null);
				has20FTInBackend := true;
				break;
			endif;
		endif;
	endforeach;	
	
	return has20FTInBackend;
	
epilog
	
	delete tiArray;
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIsOfMode" id="a6bbad83-f013-43ff-9113-a6c283f9e0dc">
        <source>hasTIsOfMode(_mode: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	hasPlannedTIs : Boolean;
	move : CM_FutureMove;
begin

	if _mode = PLANNING_MODE then
		
		if self.isCompletedBulkRelease() then
			return true;
		endif;
			
		if self.allPlannedFutureMoves.isEmpty then
			return false;
		endif;
		hasPlannedTIs := false;
		foreach move in self.allPlannedFutureMoves do
			// not EDI future moves - see self.getAllFutureMovesOfType or similar
			if move.moveType = TI_FutureMovePlanned 
			or move.moveType = TI_FutureMoveSOB 
			or move.moveType = TI_FutureMoveDLRDischarge 
			or move.moveType = TI_FutureMoveDLRLoad then
				hasPlannedTIs := true;
				break;
			endif;
		endforeach;
		return hasPlannedTIs;
	else
		return inheritMethod(_mode);
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTI" id="fe5c4154-c838-4093-b00f-3aa2a7f46ede">
        <source>includesTI(_ti: CM_TrackedItem; _mode : Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 06 Mar 2025  navma1  	MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------

vars

begin
	if _ti = null then
		return false;
	endif;
	
	// CCMS 1011
	if _mode = REAL_MODE and _ti.isTranshipExport()   then						//06.03.2025 navma1 #MTN-34179
		if _ti.myImportVoyage = self.myVoyage then								// PAR #23645 CCMS 1116
			return true;
		endif;
	endif;
	return inheritMethod(_ti, _mode);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
