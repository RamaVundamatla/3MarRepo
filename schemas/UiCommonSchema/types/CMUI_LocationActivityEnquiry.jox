    <JadeMethod name="displaySelectorResults" id="e22e5ed7-fdbe-495f-8ecf-5f759387c7f6">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	user : CM_User;
	iter : Iterator;
	invalidObject : Boolean;
	obj : Object;
	thisObjTerminal : CM_Terminal;
	locActivity : CMEVT_LocationActivity;
	atLimit : Boolean;

begin

	self.tblLocActivity.rows := self.tblLocActivity.fixedRows;
	self.allLocActivityByDate.clear();
	self.allLocationActivitySet.clear();
	self.numItemsShown := 0;
	user := app.getMyUser();
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	iter := _resultCollection.createIterator;
	while iter.next(obj) do
		invalidObject := false;
		if not obj.isKindOf(CMEVT_LocationActivity) then
			continue;
		endif;
		
		locActivity := obj.CMEVT_LocationActivity;
		
		thisObjTerminal := locActivity.myTerminal;
		
		// Skip any invalid objects
		if invalidObject then
			continue;
		endif;
		
		// Skip any from other than the first terminal
		if self.myTerminal &lt;&gt; null and thisObjTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		
		// Otherwise, add it to the table
		atLimit := self.addObjectToCollection(locActivity, user);
		if atLimit then
			break;
		endif;

	endwhile;
	
	// set up transaction table and display transactions
	if not self.tableInitialised then
		self.initTblLocActivity();
	endif;
	
	
	self.populateLocActivityTable();
	self.showNumRowsShown();

epilog

	delete iter;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
