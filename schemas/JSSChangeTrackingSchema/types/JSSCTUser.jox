<Class name="JSSCTUser" id="758f10a4-c3c8-4f0c-a43e-9a307a50e292">
    <superclass name="JSSPersistent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_changes"/>
    <PrimAttribute name="index" id="38000032-f40a-4df2-95aa-d69f5bba2528">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="95b449cd-f508-4baf-82fb-0c07817e09fb">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="JSSCTChangeTrackingRoot"/>
        <access>readonly</access>
        <Inverse name="JSSCTChangeTrackingRoot::allUsersByIndex"/>
        <Inverse name="JSSCTChangeTrackingRoot::allUsersByTranID"/>
    </ExplicitInverseRef>
    <PrimAttribute name="tranID" id="55388ecb-0263-4ee5-9713-35eb4a642953">
        <precision>12</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userCode" id="395bb714-c677-4c73-94e8-44e160ba3d75">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setTranID" id="b6dbeb39-0868-443b-8f14-5719064e45e1">
        <updating/>
        <source>setTranID( _tranID : Decimal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2014	cnwrd1	Initial creation

*/

vars

begin

	self.tranID := _tranID;
	
epilog

end;</source>
        <Parameter name="_tranID" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="update" id="81ba4149-9fd6-4bdb-b2a4-cf17596b91e8">
        <updating/>
        <source>update(_userIndex : Integer; _userName : String; _root : JSSCTChangeTrackingRoot) updating;

vars
	jssCtUser : JSSCTUser;
begin
	self.index := _userIndex;
	if _userName &lt;&gt; null then
		self.userCode  := _userName;
	endif;
	self.myRoot := _root;
end;
</source>
        <Parameter name="_userIndex" type="Integer"/>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_root" type="JSSCTChangeTrackingRoot"/>
    </JadeMethod>
</Class>
