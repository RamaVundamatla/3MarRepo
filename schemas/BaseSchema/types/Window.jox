<GUIClass name="Window">
    <JadeMethod name="cnEcBrowseForFile" id="f491d906-a0a2-47a6-9b20-0b3d83a15d1d">
        <source>cnEcBrowseForFile(pFilter:String):String protected;
// --------------------------------------------------------------------------------
// Created:		29 May 2006 by cnwdad1
//
// Purpose:		Browses for a file name.
//
// Parameters:	pFilter - The file type filter string.
//
// Returns:		The name of the selected file/path, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	
	if fileObj.cnEcSetOpenName(false, false, pFilter) then
		return fileObj.fileName;
	endif;
epilog
	delete fileObj;
end;</source>
        <access>protected</access>
        <Parameter name="pFilter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllChildControls" id="7d9b3e1c-7b1f-4255-bc25-844d33b3f479">
        <source>cnEcGetAllChildControls(pAllChildControls:CnEcControlArray io; pIsGetTheirChildren:Boolean) abstract;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad2
//
// Purpose:		Populates the array parameter with the receiver's child controls.
//
// Parameters:	pAllChildControls - The control array to populate.
//				pIsGetTheirChildren - True if the children's children should also
//					be included.
//
// Returns:		The control array parameter.
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <Parameter name="pAllChildControls" type="CnEcControlArray" usage="io"/>
        <Parameter name="pIsGetTheirChildren" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDescription" id="ca7fb391-2600-4ee9-874d-2684336e6539">
        <source>cnEcGetDescription():String;
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Purpose:		Returns a description of the receiver.
//
// Parameters:	None
//
// Returns:		A string containing the description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	self.class.schema.name &amp; "::" &amp; self.class.name;
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDetails" id="7ed09e04-0605-4f89-bb30-cf19423d6dbb">
        <source>cnEcGetDetails(pAllDetailsObj:CnEcDualStringArray input);
// --------------------------------------------------------------------------------
// Created:		06 February 2006 by cnwdad1
//
// Purpose:		Populates an array with the property names and values of the receiver.
//
// Parameters:	pAllDetailsObj - A reference to the BaseSchema array object.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj		: Property;
	allProperties	: PropertyColl;
	propName		: String;
	propValue		: String;
	
begin
	allProperties	:=	self.class.allProperties();	// This method creates a new instance of the property collection.
	
	foreach propertyObj in allProperties do
		propName	:=	propertyObj.name;
		propValue	:=	self.getPropertyValue(propertyObj.name).String;
		pAllDetailsObj.cnEcAdd(propName, propValue);
	endforeach;
epilog
	delete allProperties;
end;</source>
        <Parameter name="pAllDetailsObj" type="CnEcDualStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetRelativePosition" id="449b4385-8e3d-4469-af1d-a932b8430ff3">
        <updating/>
        <source>cnEcGetRelativePosition(pWindowObj:Window input; pXposition:Real io; pYposition:Real io) updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Updates the X-Y coordinates of a window relative to the screen.
//
// Parameters:	pWindowObj - The window whose coordinates to set.
//				pXposition - The X coordinate of the window.
//				pYposition - The Y coordinate of the window.
//
// Returns:		The X-Y coordinates after being converted to screen coordinates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pWindowObj.windowToScreen(pXposition, pYposition);
	self.screenToWindow(pXposition, pYposition);
end;</source>
        <Parameter name="pWindowObj" type="Window" usage="input"/>
        <Parameter name="pXposition" type="Real" usage="io"/>
        <Parameter name="pYposition" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetUserInput" id="0838c36a-09bc-4d60-8b7e-b61a992c6d3f">
        <source>cnEcGetUserInput(pTitle:String; pInstruction:String; pDefaultValue:String):String;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Purpose:		Display a pop-up dialog form, with the specified prompt, for the
//				user to enter text.
//
// Parameters:	pTitle - The title (caption) of the dialog.
//				pInstruction - The prompt telling the user what to enter.
//				pDefaultValue - The value to pre-fill.
//
// Returns:		The text entered by the user.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputFormObj	: CnEcUserInputForm;
	inputValue		: String;

begin
	create inputFormObj;
	inputFormObj.setProperties(pTitle, pInstruction, pDefaultValue);

	if inputFormObj.showModal() = Form.CNEC_MODAL_UPDATE then
		inputValue	:=	inputFormObj.getValue();
	endif;
epilog
	return inputValue;
end;</source>
        <Parameter name="pTitle" type="String"/>
        <Parameter name="pInstruction" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIgnoreSkinAll" id="d1a8027c-986f-4664-b0ff-f8e30d16fdd8">
        <updating/>
        <source>cnEcIgnoreSkinAll(pIsIgnore:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 May 2007 by cnwdad1
//
// Purpose:		Sets the receiver's "ignoreSkin" flag, and then does the same for
//				all of the receiver's children.
//
// Parameters:	pIsIgnore - True or false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allControlsObj	: CnEcControlArray;
	controlObj		: Control;
	
begin
	self.ignoreSkin	:=	pIsIgnore;
	
	create allControlsObj transient;
	self.cnEcGetAllChildControls(allControlsObj, true);
	
	foreach controlObj in allControlsObj do
		controlObj.ignoreSkin	:=	pIsIgnore;
	endforeach;
epilog
	delete allControlsObj;
end;</source>
        <Parameter name="pIsIgnore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGUI" id="10077052-cbec-4bdb-93e3-08f205100d4b">
        <source>cnEcIsGUI(): Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI object.
//
// Parameters:	None
//
// Returns:		True if he receiver is a GUI object, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcPrintMe" id="5735a6c9-aefd-4c2d-bbe5-9e6eeb228d00">
        <updating/>
        <source>cnEcPrintMe(pIsLandscape:Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Prints the receiver form or control, in landscape.
//
// Parameters:	pIsLandscape - True if the receiver should be printed in landscape,
//					otherwise it will be printed in portrait.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if pIsLandscape then
		app.printer.setMargins(Print_Landscape, 1, 1, 1, 1);
	else
		app.printer.setMargins(Print_Portrait, 1, 1, 1, 1);
	endif;
	
	app.printer.printActive(self);
	app.printer.close();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pIsLandscape" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEc_MouseUp" id="372ed438-b62f-40de-b1a4-d408eb069075">
        <updating/>
        <source>cnEc_MouseUp(wndw:Window input; button:Integer; shift:Integer; x:Real; y:Real) protected, updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Used to send a 'mouseUp' message to a subclass of the Window class
//				(this method should be reimplemented on the intended target class).
//
// Parameters:	Same as the standard JADE mouseUp method signature, except that the
//				'wndw' parameter may be any subclass of the Window class.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEc_MoveWindow" id="f862c306-4085-41b7-9ecc-2f421656a22e">
        <source>cnEc_MoveWindow(hwnd:Integer);
// This method allows for the movement of a form by directly accessing windows - the same as would happen
// if you clicked and dragged the standard windows caption bar at the top of each form. This method gives
// the ability to suppress the windows blue toolbar and use your own layout instead. If you turn off the 
// PC's control panel setting to 'show windows while dragging', the movement will show a phantom rectangle
// being moved around the screen.

// To set up the external function do the following:
// 1) Go to External Function browser
// 2) Add library - user32
// 3) Add external function - name 			= sendMessage
//							  entry point 	= SendMessageA
//							  library 		= user32
// 4) Define the sendMessage signature as follows:
// 	  sendMessage(hwnd:Integer; msg:Integer; lParam:Integer; wParam:Integer):Integer is SendMessageA in user32
constants
	WM_SYSCOMMAND	: Integer = #112;
	WM_LBUTTONUP	: Integer = #202;
	MOUSE_MOVE		: Integer = #f012;
	SC_MOVE			: Integer = #f010;

begin
	call cnEc_SendMessage(hwnd, WM_LBUTTONUP, 0, 0);
	call cnEc_SendMessage(hwnd, WM_SYSCOMMAND, MOUSE_MOVE, 0);
end;</source>
        <Parameter name="hwnd" type="Integer"/>
    </JadeMethod>
</GUIClass>
