    <JadeMethod name="selectEventTypes" id="349c5cec-1101-4946-9185-7f3274ca93aa">
        <source>selectEventTypes(_allEventTypes	: IntegerArray) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lstTbl			: CMUI_ListTable;

	eventTypeInt	: Integer;
	eventType		: CM_EventType;
	str			: String;
begin
	lstTbl := self.lstTblEventTypes;
	lstTbl.clearSelected();
	
	foreach eventTypeInt in _allEventTypes do
		eventType := app.myRoot.allEventTypesByType [eventTypeInt];
		if eventType = null then
			continue;
		endif;
		
		lstTbl.allSelectedObjects.add(eventType);
		str := str &amp; eventType.name &amp; ',';
	endforeach;

	return str;
	
	

end;


</source>
        <access>protected</access>
        <Parameter name="_allEventTypes" type="IntegerArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="0836b0dc-41fa-4aca-a4f7-4ad2f4a94566">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	theBackColour	: Integer;

begin
	
	inheritMethod(_colorControl);
	
	self.setColorsForTable(self.tblSchedules);
	self.setColorsForEntryTable(self.tblTaskCreation);
	self.setColorsForTable(self.tblTaskDisplay);
	self.setColorsForMultiSelectGrpBox(self.multiSelectTasks);
		
	theBackColour := self.backColor;
	self.schedula.setColor(self.colorControlBack, theBackColour);

//	self.fldSchedules.backColor		:= theBackColour;
//	self.shtSchedule.backColor		:= theBackColour;
//	self.shtTasks.backColor			:= theBackColour;
	self.splitter1.backColor		:= theBackColour;
	self.splitter2.backColor		:= theBackColour;
	self.splitter3.backColor		:= theBackColour;
	self.splitter4.backColor		:= theBackColour;

	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1227ffd0-53c8-44a9-8ccc-785c7d997800">
        <updating/>
        <source>setupForm() updating;

// cnwdvb1 14 January 2003 
//
// 27 May 2015	cnwrs1	Par 36285 Make the BGP Auto Schedule Form multiselect
// 25 Jul 2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars

	entTableDef 	: EntTableDef;
	theClass		: Class;
	dyna			: DynaDictionary;
	cmif			: CMIF_ClassSorter;
	obj				: Object;
	subs			: ClassColl;

begin

	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.typeOfSheet := self.Sheet_Schedule;
	self.splitter2.setLeftToRightRatioAndResize(55);	
	self.splitter1.setLeftToRightRatioAndResize(65);
	self.splitter1.setDistanceFromRight(5);
	self.splitter3.setLeftToRightRatioAndResize(100);

	self.splitter2.cnEcResizeContents();	//05 Apr 2019	NDL	TFS 44149
	
	self.tblSchedules.setColumnHeadingsFromDef(ETDef_BgpAutoSchedules, false);
	self.tblSchedules.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblSchedules.autoSize := Table.AutoSize_Column;
	self.tblSchedules.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblSchedules.cnEcResizeContents();	//05 Apr 2019	NDL	TFS 44149

	self.tblTaskDisplay.setColumnHeadingsFromDef(ETDef_BgpAutoTaskDisplay, false);
	self.tblTaskDisplay.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblTaskDisplay.autoSize := Table.AutoSize_Column;

	self.multiSelectTasks.formDisplayEntryMethodName := 'displayDetail'; 
	self.multiSelectTasks.availableHeading := 'Available Tasks';
	self.multiSelectTasks.selectedHeading := 'Selected Tasks';
	self.multiSelectTasks.myBaseForm	:= self;
	self.multiSelectTasks.mySelectedListBox.sorted := false;
	self.multiSelectTasks.displayOrderBtns(true, true);
	self.multiSelectTasks.multiSelect	:= ListBox.MultiSelect_Extended;
	
	self.myAssistant.listTableEventTypes(self.lstTblEventTypes);

	entTableDef := app.myController.getEntTableDef(ETDef_BgpAutoTasks);
	self.tblTaskCreation.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblTaskCreation.optimiseHeadingColumn();
	self.tblTaskCreation.showHideRowsByViewName('bgpAutoViewDefault', CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
	self.tblTaskCreation.userInputEnabled := false;
	self.tblTaskCreation.autoSize := Table.AutoSize_Column;

	create dyna transient;
	create subs transient;
	dyna.setMembership(CMIF_ClassSorter);
	dyna.addMemberKey('key', false,false);
	dyna.endKeys(true);
	CM_AutoTask.allSubclasses(subs);
	
	foreach theClass in subs do
		//+cnwml2 PAR25320
		if theClass.name = "CM_AutoTaskWOSchedule" then
			continue;
		endif;
		if theClass.name = "CM_AutoTaskSapPerformance" then
			continue;
		endif;
		if theClass.name = "CM_AutoTaskSapTPP" then
			continue;
		endif;
		create cmif transient;
		cmif.myClass := theClass;
		cmif.description := theClass.text.cnEcGetTagValueOfName('display');
		cmif.key := cmif.description[1:30];
		dyna.add(cmif);
	endforeach;

	foreach obj in dyna do
		cmif := obj.CMIF_ClassSorter;
		self.cmbTaskTypes.itemObject[self.cmbTaskTypes.addItem(cmif.description)] := cmif.myClass;
	endforeach;

	self.setupTabIndexes();
		
	if app.myRoot.allAutoTasks.size &gt; 0 then
		self.selectedTaskRow := 2;
	endif;

	self.changeButtonStates();
	self.setNavigatorHeading('Scheduler');

	self.fldSchedules.useSheetBackColors := true;
	self.fldSchedules.setDefaultSheetBackColors();
 	self.fldSchedules.initSheetBackColors();
 	
 	// Need this to overcome case sensitive sorting.
 	self.allTemplates.setMembership(CM_ReportTemplate);
 	self.allTemplates.addMemberKey('name', false, true);
 	self.allTemplates.endKeys(true);
 	
 	self.cmbPackages.listCollection(app.myRoot.allPackages, true, 0);
	
	self.frmTableFilter.setupControl(self.tblSchedules, null);
	self.frmTableFilter.setCallbackMethod(CMUI_AutoSchedulerForm::doFilterTable.name);
	
	//self.cmbPackageType.addItem(EventDataVVR);
 	
	self.resize();
	
epilog
	if dyna &lt;&gt; null then
		dyna.purge();
	endif;
	delete dyna;
	delete subs;
	delete dyna;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTabIndexes" id="561aa2fd-dc6e-4aad-a423-5dad7cbfc4f1">
        <updating/>
        <source>setupTabIndexes() protected, updating;

// cnwdvb1 05 March 2003 

vars

begin

	self.shtSchedule.tabIndex			:= 98;
	self.shtTasks.tabIndex				:= 99;
	self.tblSchedules.tabIndex			:= 100;
	self.schedula.tabIndex				:= 101;
	self.schedula.optT.tabIndex			:= 102;
	self.schedula.optD.tabIndex			:= 103;
	self.schedula.optM.tabIndex			:= 104;
	self.schedula.tblT.tabIndex			:= 105;
	self.schedula.tblD.tabIndex			:= 106;
	self.schedula.tblM.tabIndex			:= 107;
	self.schedula.tblE.tabIndex			:= 108;
	self.schedula.txtTimeCopy.tabIndex	:= 109;
	self.schedula.btnAdd.tabIndex		:= 110;
	self.schedula.btnRemove.tabIndex	:= 111;
	self.schedula.tblStartTimes.tabIndex:= 112;
	self.multiSelectTasks.myAvailableListBox.tabIndex	:= 113;
	self.multiSelectTasks.myAddSelectedBtn.tabIndex		:= 114;
	self.multiSelectTasks.myRemoveSelectedBtn.tabIndex	:= 115;
	self.multiSelectTasks.myAddAllBtn.tabIndex			:= 116;
	self.multiSelectTasks.myRemoveAllBtn.tabIndex		:= 117;
	self.multiSelectTasks.myUpSelectedBtn.tabIndex		:= 118;
	self.multiSelectTasks.myDownSelectedBtn.tabIndex	:= 119;
	self.multiSelectTasks.mySelectedListBox.tabIndex 	:= 120;
	self.multiSelectTasks.myTopSelectedBtn.tabIndex 	:= 121;
	self.multiSelectTasks.myBottomSelectedBtn.tabIndex 	:= 122;
	self.tblTaskDisplay.tabIndex	:= 126;
	self.tblTaskCreation.tabIndex	:= 127;
	
	self.btnSaveBase.tabStop := false;
	self.btnCancelBase.tabStop := false;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showForTask" id="700cc7b0-60d4-45fa-8efa-ef553b775dc7">
        <updating/>
        <source>showForTask(_task : CM_AutoTask) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars

begin

	self.myInitialTask := _task;

end;
</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="showInitialTask" id="deb99ff2-1495-4543-9c3f-81a99d88f8c7">
        <updating/>
        <source>showInitialTask() updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	row	: Integer;
begin

	if self.myInitialTask &lt;&gt; null then
		self.mySelectedAutoTask := self.myInitialTask;
		self.tblTaskCreation.userInputEnabled := false;
		self.fldSchedules.topSheet := self.shtTasks;
		foreach row in self.tblTaskDisplay.fixedRows to self.tblTaskDisplay.rows do
			if self.tblTaskDisplay.accessRow(row).itemObject = self.myInitialTask then
				self.tblTaskDisplay.row := row;
				self.tblTaskDisplay.selectRow(row, true);
				break;
			endif;
		endforeach;
		self.doLoadTaskTable(self.mySelectedAutoTask);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showMnuInspectObject" id="726893eb-43ee-4792-b4fa-10ff89cf1ca9">
        <source>showMnuInspectObject();
// ---------------------------------------------------------------------------
// Created:     18 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	addMnuInspect :	Boolean;
begin
		addMnuInspect := app.isAllowedToInspect();
		self.mnuInspectSchedule.visible	:= addMnuInspect;
		self.mnuInspectTask.visible		:= addMnuInspect;
end;</source>
    </JadeMethod>
    <JadeMethod name="showSSDefinitionForm" id="03eb3d99-428c-4b5d-a576-72bb2d279e1b">
        <source>showSSDefinitionForm();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwas3	Initial creation

*/

vars
	
	terminal: CM_Terminal;
	format	: CM_OutputFormat_SS;
	snap	: CM_AutoTaskSummarySnapShot;
	idx		: Integer;
	obj		: Object;
	
begin
	
	/* comented by #24990 15/07/2010
	terminal := self.mySelectedAutoTask.myTerminal;
	if terminal = null then
		terminal := self.myTerminal;
	endif;*/
	// Getting Terminal from combobox - this is the last terminal info. #24990 15/07/2010
	idx := self.cmbTerminal.listIndex;
	if idx &lt; 1 then	// there is no terminal in combobox
		app.msgBox(app.getErrorString(Select_Terminal), null, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	else	// something selected in terminal combobox
		obj		:= self.cmbTerminal.itemObject[idx];
		terminal := obj.CM_Terminal;
	endif;
	
	/* comented by #24990 15/07/2010
	if self.mySelectedAutoTask.isA(CM_AutoTaskSummarySnapShot) then
		format := self.mySelectedAutoTask.CM_AutoTaskSummarySnapShot.mySSDefinition;
	endif;*/
	idx := self.cmbSSDef.listIndex;	// getting format from combobox #24990 15/07/2010
	if idx &gt;= 1 then	// something selectyed in combobox
		obj		:= self.cmbSSDef.itemObject[idx];
		format := obj.CM_OutputFormat_SS;
	endif;
	
	
	//if format &lt;&gt; null then	// comented by #24990. We can show this form with no format selected.
		self.myAssistant.showSSDefinitionMaintForm( terminal, format );
	//endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelector" id="67110fee-f8f1-4536-84f1-a330e33a54e0">
        <updating/>
        <source>showSelector() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwas3	Initial creation

*/
vars
	frm				: CMUI_Selector;
	idx				: Integer;
	query 			: CM_MenuUserQuery;
	obj				: Object;
	
begin
	
	//commented by #24990 14/07/2010
	/*if self.myTerminal = null or self.myTerminal &lt;&gt; self.mySelectedAutoTask.myTerminal then
		self.myTerminal := self.mySelectedAutoTask.myTerminal;
	endif;*/

	// Getting Terminal from combobox - this is the last terminal info. #24990 14/07/2010
	idx := self.cmbTerminal.listIndex;
	if idx &lt; 1 then	// there is no terminal in combobox
		app.msgBox(app.getErrorString(Select_Terminal), null, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	else	// something selected in terminal combobox
		obj		:= self.cmbTerminal.itemObject[idx];
		self.myTerminal := obj.CM_Terminal;
	endif;
	
	
	frm := app.getSelectorForm(self, self.myMasterMenuAction);
	
	if frm = null then
		return;
	endif; 
	
	//frm.myTerminal := self.mySelectedAutoTask.CM_AutoTaskSummarySnapShot.myTerminal; //commented by 13/07/2010 cnwdz2 24992
	//frm.myTerminal := self.mySelectedAutoTask.myTerminal;	//13/07/2010 cnwdz2 24992 //and this is commented by #24990 14/07/2010
	
	frm.myEnquiryCollectionClass := CM_ObjectSet;
	frm.defaultSiteStr := TI_SITE_ONSITE_str;
	
	
	//Getting Query from combobox  #24990 14/07/2010
	idx := self.cmbSelectorQuery.listIndex;
	if idx &gt;= 1 then	// somethiong selected in query combobox
		obj		:= self.cmbSelectorQuery.itemObject[idx];
		query	:= obj.CM_MenuUserQuery;
	endif;
	
	
	frm.disableMnuEnquiry := false;							
	frm.show();
	if query &lt;&gt; null then	//#24990 14/07/2010
		frm.showQuery(query);		
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
