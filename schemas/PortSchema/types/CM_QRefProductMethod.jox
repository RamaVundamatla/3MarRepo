    <JadeMethod name="setComboValues" id="035da277-c935-4d8c-aeb3-3ce4e57fdc54">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	crit			: CM_SelectorCriteriaLine;
	idx				: Integer;
	os				: ObjectSet;
	value			: Any;
	obj				: Object;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	qrl				: CM_QReferenceLookup;
	terminal 		: CM_Terminal;
begin
	_combo.clear;
	
	if _params = null then
		 terminal := app.myPassport.myTerminal;
		foreach cargoType in app.myRoot.allCargoTypesById do
		
			if terminal &lt;&gt; null then
				if not terminal.allCargoBOLTypes.includes(cargoType) then
					continue;
				endif;
			endif;
			
			foreach product in cargoType.allProducts do
				idx := _combo.addItem(cargoType.abbreviation &amp; " - " &amp; product.code);
				_combo.itemObject[idx] := product;
			endforeach;
		endforeach;
		
		
		// Select the chosen one
		if CM_QReferenceLookup.hasInstance(_queryOperator) then
			qrl := _queryOperator.CM_QReferenceLookup;
			if global.isValidObject(qrl.mySelectionValue) then
				_combo.listObject := qrl.mySelectionValue;
			endif;
		endif;
	
		
		return;
	endif;
	
	//07/10/2025	navkc1 JIRA 36147 - Do Contents Cargo Type first if there's one;
	crit := _params.allCriteriaByPropertyName[CM_TrackedItem::getCargoTypeIdForContents.name, CM_TrackedItem.name]; // 19/10/2025	navkc1 MTN JIRA 36352
	
	//07/10/2025	navkc1 JIRA 36147
	if crit = null then
		crit := _params.allCriteriaByPropertyName[CM_TrackedItem::cargoType.name, CM_TrackedItem.name]; // 19/10/2025	navkc1 MTN JIRA 36352
	endif;

	create os transient;
	
	if crit &lt;&gt; null then
		if CM_QReferenceIsOneOf.hasInstance(crit.myQueryOperator) then
			crit.myQueryOperator.getSearchValueAsObjectSet(os);
		elseif	CM_QIntegerLookupNotEqual.hasInstance(crit.myQueryOperator) or 
				CM_QIntegerLookupEqual.hasInstance(crit.myQueryOperator) then
			cargoType := app.myRoot.allCargoTypesById[crit.myQueryOperator.getSearchValue().Integer];	
			if cargoType = null then
				app.msgBox(app.getString(CouldNotFindCargoType), 'Warning', 0);
				return;
			endif;
			os.add(cargoType);
		endif;
		
	else
		app.msgBox(app.getString(SpecifyCargoType), 'Warning', 0);				//+cnwml2 PAR24397
		return;
	endif;
	
	foreach obj in os do
		cargoType := obj.CM_CargoType;
		foreach product  in cargoType.allProducts do
			idx := _combo.addItem(product.code);
			_combo.itemObject[idx] := product;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		
		obj := qrl.mySelectionValue; // 19/10/2025	navkc1 MTN JIRA 36352
		
		if global.isValidObject(obj) then
			idx := _combo.findObject(obj);  // 19/10/2025	navkc1 MTN JIRA 36352
			
			// 19/10/2025	navkc1 MTN JIRA 36352
			if idx &gt; null then
				//_combo.listObject := qrl.mySelectionValue;
				_combo.listIndex := idx; // 19/10/2025	navkc1 MTN JIRA 36352
			endif;
		endif;
	endif;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="3e4f70c6-189d-45ea-b826-4b0ab2cdb5f9">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	prod		: CM_Product;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	cargoType	: CM_CargoType;
	dict		: CM_ProductByOpCodeProCodeDict;
	tmpValue	: String;
begin

	if _value.isKindOf( CM_Product ) then
		return _value;
	endif;

	tmpValue := _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['cargoType', CM_TrackedItem.name];
	cargoType := app.myRoot.allCargoTypesById[ critLine.myQueryOperator.getSearchValue().Integer ];
	
	dict	:= cargoType.allProducts;
	
	foreach prod in dict discreteLock do
		if prod.code.toUpper() = tmpValue then
			return prod;
		endif;
	endforeach;

	inheritMethod( _value, _criteriaLine );
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b68b1e42-3ed9-4aaf-8eb0-b64ee9052d1a">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.String;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b7bacee1-eadc-4ca6-85fc-ebdff254806c">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	returnVal		: CM_Product;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_Product) then
			returnVal := _value.CM_Product;
		endif;
	endif;
	
	return returnVal;

epilog

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
