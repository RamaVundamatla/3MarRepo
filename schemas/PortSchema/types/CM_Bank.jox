vars
	days:  Real;
begin
	//days := terminal.myCalendar.getBusinessDaysBetween(_startTimeStamp, _endTimeStamp);
	days := (endTimeStamp.date - startTimeStamp.date);

	if startTimeStamp.time &lt; onsiteStorageChargeTime then
		days := days + 1;
	endif;

	if endTimeStamp.time &lt; onsiteStorageChargeTime then
		days := days - 1;
	endif;

	days := days + 1;

	return days;
end;</source>
        <Parameter name="startTimeStamp" type="TimeStamp"/>
        <Parameter name="endTimeStamp" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
