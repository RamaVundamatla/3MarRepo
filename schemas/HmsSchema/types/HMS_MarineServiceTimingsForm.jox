    <JadeMethod name="btnRecalc_click" id="b2338800-6f3a-4a38-8cc7-2ed50a0fae5a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRecalc_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars

begin
	self.checkNotReadySurcharge( false );
	self.checkTooSoonSurcharge( false );
epilog

end;</source>
