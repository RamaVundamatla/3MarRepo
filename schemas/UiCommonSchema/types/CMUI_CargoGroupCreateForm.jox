    <JadeMethod name="doResize" id="3ae582d6-3814-4559-8428-08eeb3238df1">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation

*/

vars

begin

	self.width := self.grpMain.width + 16;
	self.height := self.grpMain.height + 38;
	
	self.grpMain.left := 0;
	self.grpMain.top := 0;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="70a62acf-5720-47f9-8629-48ae317531c5">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 June 2015		cnwndl1	Initial creation	Par 36338
05 December 2022	navmd1	TFS 55379 - Fixed blank error dialog when only errors were returned by the trx

*/

vars

	cargoType : CM_CargoType;
	msg : String;
	oper : CM_Operator;
	tmpID : String;
	pxyTI : CM_TrackedItem;
	realTI : CM_TrackedItem;
	subT : CM_SubTerminal;
	remarks : String;
	invalidObj : Boolean;
	terminal : CM_Terminal;
	existingTI : CM_TrackedItem;
	minWeight : Decimal [14,4];
	maxWeight : Decimal [14,4];

begin

	terminal := self.myTerminal;
	if terminal = null then
		msg := app.getErrorString(Select_Terminal);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	cargoType := self.cmbCGType.listObject.CM_CargoType;
	if cargoType = null then
		msg := app.getErrorString(Unspecified_Cargo_Type);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	tmpID := self.txtCGId.text;
	if tmpID = null then
		msg := app.getErrorString(ERR_INVALID_TI_ID);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	existingTI := terminal.allCargoGroupsByCargoTypeId.getAtKey( cargoType.id, tmpID );
	if existingTI &lt;&gt; null then
		msg := app.getErrorString1(Cargo_group_already_used, tmpID);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	oper := self.cmbGCOper.listObject.CM_Operator;
	if oper = null then
		msg := app.getErrorString(Please_select_operator);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	minWeight := self.tblMinWeight.getConvertedValue;
	maxWeight := self.tblMaxWeight.getConvertedValue;
	
	remarks := self.txtCGRems.text;
	
	pxyTI := terminal.createTI(cargoType, true);
	pxyTI.zSetPxyTerminal(self.myTerminal);
	pxyTI.setCargoType(cargoType.id);

	pxyTI.setMyOperator(oper);
			
	pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);

	pxyTI.zSetPxyCompany(terminal.getDefaultCompanyBank);
		
	if app.isSubTerminalsOn(terminal) then
		subT := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	pxyTI.zSetPxyId( tmpID );
	pxyTI.setRemarks( remarks, false );
	pxyTI.CM_CargoGroup.setPxyMinMaxWeights( minWeight, maxWeight );
	
	while true do
	
		app.myTrxCA.trxCreateCargoGroup(pxyTI, realTI, app.myPassport);
		
		msg := app.myPassport.getErrorsAndWarningsAsString;		// TFS 55379 navmd1 moved up from below to always make sure we have *something* in msg if we're going to show the dialog
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		elseif app.myPassport.noErrors then
			//msg := app.myPassport.getErrorsAndWarningsAsString;
			
			app.myPassport.warningsAcknowledged	:=	true;
			continue;
		endif;
		
		break;
	
	endwhile;
	
	on Exception do app.handleDeletedObject( exception, pxyTI, invalidObj );
	
	if realTI &lt;&gt; null then
		//jlier1 TFS 53515 30/5/22
		if self.isModal then	
			self.modalResult := IDOK;
			self.userObject:=realTI;
		endif;
		return true;
	endif;
	
	app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		
	return false;

epilog

	if pxyTI &lt;&gt; null then
		delete pxyTI;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbCGType" id="1946918e-9fac-48cc-87bd-8888cf45da29">
        <source>populateCmbCGType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	cargoType : CM_CargoType;
	index : Integer;

begin

	self.cmbCGType.clear();
	
	iter := app.myRoot.allCargoTypesById.createIterator;
	while iter.next( cargoType ) do
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		if cargoType.productType &lt;&gt; ProductType_CargoGroup then
			continue;
		endif;
		if not cargoType.allTerminals.includes( self.myTerminal ) then
			continue;
		endif;
		index := self.cmbCGType.addItem( cargoType.displayForXlation(false) );
		self.cmbCGType.itemObject[index] := cargoType;
	endwhile;
	
	if self.cmbCGType.listCount = 1 then
		self.cmbCGType.listIndex := 1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="08529956-1774-407d-900f-dcac01e6d3aa">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	self.populateCmbCGType();
	
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);
	
	self.tblMinWeight.setup(Type_Weight, self.backColor);
	self.tblMinWeight.tabKey := J_key_Tab;
	self.tblMinWeight.visible := true;
	
	self.tblMaxWeight.setup(Type_Weight, self.backColor);
	self.tblMaxWeight.tabKey := J_key_Tab;
	self.tblMaxWeight.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2f397c08-363c-4fa5-93c1-d80e63b111d6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 July 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020700, locale);
	btnCancel.translateCaption(Xlat_0020701, locale);
	btnSave.translateCaption(Xlat_0020702, locale);
	lblCGId.translateCaption(Xlat_0020703, locale);
	lblCGOper.translateCaption(Xlat_0020704, locale);
	lblCGRems.translateCaption(Xlat_0020705, locale);
	lblCGType.translateCaption(Xlat_0020706, locale);
	lblMaxWeight.translateCaption(Xlat_0020748, locale);
	lblMinWeight.translateCaption(Xlat_0020749, locale);
end;</source>
    </JadeMethod>
</GUIClass>
