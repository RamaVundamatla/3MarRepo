    <JadeMethod name="resetQueueNotes" id="9f4da0b9-fb1f-48f0-9b2c-155b76455471">
        <source>resetQueueNotes();
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	eventRemove	: Integer;
	teminal : CM_Terminal;
	rtQ :  CM_RadioTelemetryQueue;
begin
	self.endNotificationForSubscriber(self);
	teminal:=getTerminal;
	if teminal = null then
		return;
	endif;
	eventRemove	:= teminal.getTerminalEvent(Event_Delete_Queue_Entry);
	
	rtQ:=self.getRTQueue;
	if  rtQ &lt;&gt; null then
		self.beginNotification(rtQ, eventRemove, Response_Continuous, 0);	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c602c5a3-48c8-4ed3-822a-8f457605a2a1">
        <source>setupForm();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	root : CM_Root;
	terminal : CM_Terminal;
	ia : IntegerArray;
	//allTerminals
begin
	self.myAssistant.comboSerialDataBits(self.cmbDataBits);
	self.myAssistant.comboSerialFlowControl(self.cmbFlowControl);
	self.myAssistant.comboSerialParity(self.cmbParity);
	self.myAssistant.comboSerialStopBits(self.cmbStopBits);
	self.cmbLen.addItem(LENGTH_20FOOT.String);
	self.cmbLen.addItem(LENGTH_40FOOT.String);
	self.cmbLen.addItem(LENGTH_45FOOT.String);
	
	foreach terminal in app.myRoot.allTerminals do
		self.cmbTerminal.itemObject[self.cmbTerminal.addItem(terminal.name)] := terminal;
	endforeach;
	self.shtTLDetails.enabled:=true;
	self.shtXMLDetails.enabled:=true;
//	self.myAssistant.comboBoxTerminal(self.cmbTerminal,null);
create ia transient;
	ia.add(CMUI_Key_F11);
	self.registerFormKeys(ia);
	
epilog
	delete ia;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="cf0dc468-559a-4658-aaef-85755dcfb6c7">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQ : CM_RadioTelemetryQueue;
begin
	rtQ:=self.getRTQueue;
	if theObject = rtQ then
		self.doSelectRTQueue;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
