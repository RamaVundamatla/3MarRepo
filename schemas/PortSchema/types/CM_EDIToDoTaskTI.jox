    <JadeMethod name="setForUpdate" id="a4e11879-7d63-455c-a015-c34833f82723">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1
// Purpose:	PAR 22022 Messina CCMS 1069 CR 6
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_proxyEDITI);
	self.isComplete := _proxyEDITI.isComplete;
	self.taskCode := _proxyEDITI.taskCode;
	self.toDoRemarks := _proxyEDITI.toDoRemarks;	//07 Oct 2015	NDL	Par 37011
epilog
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setValuesForTest" id="537445e7-6465-4770-835c-868db610144e">
        <updating/>
        <source>setValuesForTest( _action : String; _id : String; _cargoType : Integer; _taskCode : String; _isComplete : Boolean; _toDoRemarks : String) updating;
// ---------------------------------------------------------------------------
// Created:	21 February 2010 By Graeme Black cnwgb1
// Purpose:	Used in Unit tests to set up the values of a ToDoTaskTI
// ---------------------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars
begin
	self.messageMode := _action;
	self.setId(_id);
	self.cargoType := _cargoType;
	self.taskCode := _taskCode;
	self.isComplete := _isComplete;
	self.toDoRemarks := _toDoRemarks;	//07 Oct 2015	NDL	Par 37011
epilog
end;</source>
        <Parameter name="_action" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_taskCode" type="String"/>
        <Parameter name="_isComplete" type="Boolean"/>
        <Parameter name="_toDoRemarks" type="String"/>
    </JadeMethod>
</Class>
