    <JadeMethod name="cmbCranes_click" id="9d139281-7c06-4f36-ad01-314078c60c46">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCranes_click(combobox: ComboBox input) updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
// Edited: 10 July 2012 By: cnwmc5 - par 29306
//------------------------------------------------
vars

begin
	if self.isRORO = true then
		self.txtJobId.text := self.myVoyage.getNextJobNumber(null, combobox.listObject.CM_WorkPoint.IF_VoyageWorkPoint).String;
	else
		self.txtJobId.text := self.myVoyage.getNextJobNumber(null, combobox.listObject.CM_Crane.IF_VoyageWorkPoint).String;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCranes_displayEntry" id="e74fee26-b2dd-498f-8761-c5090a9b793f">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCranes_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
// Edited: 10 July 2012 By: cnwmc5 - par 29306
//------------------------------------------------
vars

begin
	if obj.isKindOf(CM_Crane) then
		return obj.CM_Crane.description;
	endif;
	if obj.isKindOf(CM_WorkPoint) then
		//return obj.CM_WorkPoint.description; // description can be null....
		return obj.CM_WorkPoint.getID;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
