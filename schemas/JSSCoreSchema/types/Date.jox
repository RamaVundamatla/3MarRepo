<PrimType name="Date">
    <JadeMethod name="jssAddDays" id="5e3aabb8-6aeb-4f6a-acc5-eb4a521ede0f">
        <source>jssAddDays(pDays:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver date.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + pDays;
end;</source>
        <text>___________________________________________________________________________

