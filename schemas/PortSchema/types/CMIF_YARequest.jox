    <JadeMethod name="checkIsAvailable" id="6f9631b3-a142-4907-bc27-50bc641668de">
        <source>checkIsAvailable() : Boolean;
/*
Purpose:			

Date		Who		Reason
15 November 2022	navab1	TFS 52721
*/

vars

begin
	if self.myDeliveryRequest = null then
		return false;
	endif;
	
	return self.myDeliveryRequest.checkIsAvailable();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clear" id="31016484-3556-4fc1-a8aa-16c7ccfc5765">
        <updating/>
        <source>clear() updating;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// 07 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 
// -------------------------------------------
vars

begin
	
	inheritMethod;
	self.allAvailabilityGrades.clear();
	self.bulkReleaseCode := null;
	self.clean := false;
	self.consigneeCode := null;
	self.consignorVoyageCode := null;
	self.deliveryNumber := null;
	self.doorsDirection := 0;
	self.doorsForward := false;
	self.eirNumber := null;
	self.hasRemarks := false;
	self.heavyRated := false;
	self.ids.clear();
	self.imexStatus := 0;
	self.imexStatusArray.clear();		// 10/09/2010 cnwmh5 #25696
	self.isReceipt := false;
	self.isoType := null;
	self.myCargoType := null;
	self.myCommodity := null;
	self.myOperatorGroup := null;
	self.mySubTerminal	:=	null;
	self.needCOU := false;
	self.needGenerator := false;
	self.numberWlesQueued := 0;
	self.operatorCode := null;
	self.reasonCode := null;
	self.totalRequested := 0;
	self.voyageCode := null;
	
	// 17/08/2010 cnwmh5 #25453 - Start
	self.bestPick := false;
	self.isoGroup := null;
	self.myBookingRef := null;
	self.myDeliveryRequest := null;	
	self.myProduct := null;
	// 17/08/2010 cnwmh5 #25453 - End
	
	self.myReserveSelection := null;	//16 Jun 2015	NDL	Par 36338
	self.myBookingRefItem	:= null;	//07.02.2023 navhl20 #61960
	self.myCargoTypeForContents := null; //07/10/2025	navkc1 JIRA 36148
	
end;</source>
    </JadeMethod>
    <JadeMethod name="display" id="dcb0cf0a-4e94-41d9-ac19-0b11809dfa17">
        <source>display(): String;
//13 August 2010	cnwdw1	
//
vars
	d: String;
begin
	d := "VoyageCode: " &amp; self.voyageCode &amp; " isoGroup: " &amp; self.isoGroup &amp; " isoType: " &amp; self.isoType &amp; " isRequestForMTs: " &amp; self.isRequestForMTs.String;
	if self.myCargoType &lt;&gt; null then
		d := d &amp; " " &amp;self.myCargoType.abbreviation;
	endif;
	return d;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getID" id="250d1bb6-6d6f-4d0d-b12c-9b99af258131">
        <source>getID(): String;
// -------------------------------------------
// Created 01 June 2005 by cnwdvb1
// -------------------------------------------
vars
	deliveryRequest : CM_DeliveryRequest;
	bulkRelease		: CM_BulkRelease;
begin

	deliveryRequest := self.myDeliveryRequest;
	
	
	if deliveryRequest = null then
		return null;
	endif;
	
	bulkRelease := deliveryRequest.myOriginatingBulkRelease;
	
	if  bulkRelease &lt;&gt; null then
		return bulkRelease.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ' ' &amp; deliveryRequest.isoType;
	else
		return deliveryRequest.operatorCode &amp; ' ' &amp;	deliveryRequest.isoType;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeFromRequest" id="f427e634-f984-460a-b167-4870963446a9">
        <source>getISOTypeFromRequest() : CM_ISOType protected;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return 	app.myRoot.allISOTypes[self.isoType];

end;</source>
        <access>protected</access>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
