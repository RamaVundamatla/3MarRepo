    <JadeMethod name="txtBooking_lostFocus" id="018001a4-d4ee-4cbd-9e9e-2cf28357af2b">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBooking_lostFocus(textbox: TextBox input) updating;
//15 March 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 22/09/2016	cnwdap1		TFS 2651 New parameter for getBookingRefFromCode method
vars
	txtStr				: String;
	tmpBookingRefItem	: CM_BookingRefItem;

begin
	txtStr := self.txtBooking.text;	

	//added to show this when no br item selected
	if (self.cmbBookingItem.listIndex &lt; 0 or txtStr &lt;&gt; self.cmbBookingItem.listObject.CM_BookingRefItem.myBookingReference.bookingReference) and txtStr &lt;&gt; null then
		// need to set values from booking ref if it exists
		//tmpBookingRefItem := self.myAssistant.getBookingRefFromCode(txtStr);							// TFS 2651
		tmpBookingRefItem := self.myAssistant.getBookingRefFromCode(txtStr, false).CM_BookingRefItem;	// TFS 2651
		
		if tmpBookingRefItem &lt;&gt; null then									
			self.setDefaultsFromBooking(tmpBookingRefItem.myBookingReference);
			self.loadBookingItems(tmpBookingRefItem.myBookingReference, tmpBookingRefItem);	
		else
			self.cmbBookingItem.clear;
			self.cmbBookingItem.lostFocus(self.cmbBookingItem);
		endif;
	endif;

	
	self.tblContainer.setValueByControlName(self.txtBooking.name, self.txtBooking.text);
	self.doLoadCmbOperator(self.cmbOperatorRight);					//+cnwml2 PAR22785
	self.doLoadCmbDisPort();										//+cnwml2 PAR22785
	self.doLoadCmbDestPort();										//+cnwml2 PAR24740
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
