    <JadeMethod name="setSealNumVent" id="7d41bb74-6806-4ccd-8193-a7fc203c6ed6">
        <updating/>
        <source>setSealNumVent(_value : String) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 January 2010
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// CCMS1909 	cnwsh3		Add soft Vent Seal for 7.7.3 only.
// 							An upgrade script in 7.8.1 will migrate any data in this field to
//							CM_Container.sealNumVent so this method should be removed from 7.8.2 onwards.
//----------------------------------------------------------------------
vars
	
begin
//	self.sealNumVent := _value;
	/* Was as below for 7.7.3 but changed for 7.8.1.  Moved from virtual to real attribute.
	global.setExtraData(self.allExtraData, self, SealNumVent , _value);
	*/
	
	//16 Sep 2010	NDL	Par 25608 - Use/update new seals data structure
	inheritMethod(_value);
	
	
epilog

end;</source>
