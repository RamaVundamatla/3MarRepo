    <JadeMethod name="zzGenerateMethods" id="0e5a8510-2fa3-442f-86ba-4a0c1574605a">
        <source>zzGenerateMethods();
/* ---------------------------------------------------------------------------
Created:     06 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	newMethod,
	methodName	: String;
	moveTypeNames,
	moveTypeKeys,
	transhipNames,
	transhipKeys,
	contentsNames,
	contentsKeys		: StringArray;
	lengths				: IntegerArray;
	moveStr,
	contStr,
	tsStr		: String;
	len			: Integer;
	moveInt,
	methodIdx,
	contInt,
	tsInt		: Integer;
	methodNames : StringArray;
	
	
	
	
begin

	create moveTypeNames transient;
	create moveTypeKeys transient;
	create transhipNames transient;
	create transhipKeys transient;
	create contentsNames transient;
	create contentsKeys transient;
	create lengths transient;
	create methodNames transient;
	
	moveTypeNames.add("Disch");
	moveTypeNames.add("Load");
	moveTypeNames.add("SOB");
	moveTypeNames.add("DLR");
	
	moveTypeKeys.add('VoyageMoveType_Discharge');
	moveTypeKeys.add('VoyageMoveType_Load');
	moveTypeKeys.add('VoyageMoveType_SOB');
	moveTypeKeys.add('VoyageMoveType_DLR');
	
	lengths.add(20);
	lengths.add(30);
	lengths.add(40);
	lengths.add(45);
	lengths.add(53);
	
	transhipNames.add("TS");
	transhipNames.add("NonTS");

	transhipKeys.add('true');
	transhipKeys.add('false');

	
	contentsNames.add("FCL");
	contentsNames.add("LCL");
	contentsNames.add("MT");
	contentsNames.add("Unknown");
	
	contentsKeys.add('TI_CONTENTS_STATUS_FCL');
	contentsKeys.add('TI_CONTENTS_STATUS_LCL');
	contentsKeys.add('TI_CONTENTS_STATUS_EMPTY');
	contentsKeys.add('TI_CONTENTS_STATUS_NULL');
	
	write "START";
	write "";

	write '
jadeVersionNumber "6.3.06";
schemaDefinition
PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=7, patchVersioningEnabled = true;
		setModifiedTimeStamp "&lt;unknown&gt;" "" 2010:02:27:11:45:42;
localeDefinitions
libraryDefinitions
typeHeaders
 
interfaceDefs
 
membershipDefinitions
 
typeDefinitions
CM_KPIVoyageEntity(
		jadeMethodDefinitions' &amp; CrLf;



	
	foreach moveInt in 1 to 4 do
		foreach len in lengths do
			foreach tsInt in 1 to 2 do
				foreach contInt in 1 to 4 do
				
					methodName := 'get' &amp; moveTypeNames[moveInt] &amp; len.String &amp; transhipNames[tsInt] &amp; contentsNames[contInt]; 
					
					//write methodName &amp; '(): Integer;' &amp; CrLf;
					
					methodNames.add(methodName);
					
					write methodName &amp; 'Reef' &amp; '(): Integer;' &amp; CrLf;
					write methodName &amp; 'Items' &amp; '(): Integer;' &amp; CrLf;
					write methodName &amp; 'TEU' &amp; '(): Integer;' &amp; CrLf;
					write methodName &amp; 'OverDim' &amp; '(): Integer;' &amp; CrLf;
					//self.zzGenerateMethodOutput1(methodName &amp; 'Reef', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numReefer.name);
					//self.zzGenerateMethodOutput1(methodName &amp; 'Items', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numTIs.name);
					//self.zzGenerateMethodOutput1(methodName &amp; 'TEU', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numTEU.name);
					//self.zzGenerateMethodOutput1(methodName &amp; 'OverDim', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numOverdimension.name);
				endforeach;
			endforeach;
			
			methodName := 'get' &amp; moveTypeNames[moveInt] &amp; len.String &amp; 'All'; 
			
			write methodName &amp; 'Reef' &amp; '(): Integer;' &amp; CrLf;
			write methodName &amp; 'Items' &amp; '(): Integer;' &amp; CrLf;
			write methodName &amp; 'TEU' &amp; '(): Integer;' &amp; CrLf;
			write methodName &amp; 'OverDim' &amp; '(): Integer;' &amp; CrLf;
			
			methodNames.add(methodName);
			
			//self.zzGenerateMethodOutputLen(methodName &amp; 'Reef', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numReefer.name);
			//self.zzGenerateMethodOutputLen(methodName &amp; 'Items', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numTIs.name);
			//self.zzGenerateMethodOutputLen(methodName &amp; 'TEU', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numTEU.name);
			//self.zzGenerateMethodOutputLen(methodName &amp; 'OverDim', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numOverdimension.name);
		
		endforeach;
	endforeach;
	
	//getDisch20NonTSUnkownOverDim
	//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
		
	write ')' &amp; CrLf;
	
	
write 'inverseDefinitions
exportedPackageDefinitions
externalFunctionSources
typeSources' &amp; CrLf;

foreach moveInt in 1 to 4 do
		foreach len in lengths do
			foreach tsInt in 1 to 2 do
				foreach contInt in 1 to 4 do
					methodIdx := methodIdx + 1;
					
					write 'CM_KPIVoyageEntity (
					jadeMethodSources' &amp; CrLf &amp;
					methodNames[methodIdx] &amp; 'Reef' &amp; CrLf &amp; '{' &amp; CrLf;
		
					self.zzGenerateMethodOutput1(methodNames[methodIdx] &amp; 'Reef', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numReefer.name);
		
					write CrLf &amp; '}' &amp; CrLf &amp; ')';
	
					write 'CM_KPIVoyageEntity (
					jadeMethodSources' &amp; CrLf &amp;
					methodNames[methodIdx] &amp; 'Items' &amp; CrLf &amp; '{' &amp; CrLf;
		
					self.zzGenerateMethodOutput1(methodNames[methodIdx] &amp; 'Items', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl::numTIs.name);
					write CrLf &amp; '}' &amp; CrLf &amp; ')';
				
					write 'CM_KPIVoyageEntity (
					jadeMethodSources' &amp; CrLf &amp;
					methodNames[methodIdx] &amp; 'TEU' &amp; CrLf &amp; '{' &amp; CrLf;
					
					self.zzGenerateMethodOutput1(methodNames[methodIdx] &amp; 'TEU', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl_Container::numTEU.name);
					
					write CrLf &amp; '}' &amp; CrLf &amp; ')';
				
					write 'CM_KPIVoyageEntity (
					jadeMethodSources' &amp; CrLf &amp;
					methodNames[methodIdx] &amp; 'OverDim' &amp; CrLf &amp; '{' &amp; CrLf;
					
					self.zzGenerateMethodOutput1(methodNames[methodIdx] &amp; 'OverDim', moveTypeKeys[moveInt], len, transhipKeys[tsInt], contentsKeys[contInt], CM_KPIVoyageMoveDtl_Container::numOverdimension.name);
					
					write CrLf &amp; '}' &amp; CrLf &amp; ')';
				endforeach;
			endforeach;
			
			methodIdx := methodIdx + 1;
			
			write 'CM_KPIVoyageEntity (
			jadeMethodSources' &amp; CrLf &amp;
			methodNames[methodIdx] &amp; 'Reef' &amp; CrLf &amp; '{' &amp; CrLf;
			
			self.zzGenerateMethodOutputLen(methodNames[methodIdx] &amp; 'Reef', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numReefer.name);
			write CrLf &amp; '}' &amp; CrLf &amp; ')';
		
			write 'CM_KPIVoyageEntity (
			jadeMethodSources' &amp; CrLf &amp;
			methodNames[methodIdx] &amp; 'Items' &amp; CrLf &amp; '{' &amp; CrLf ;
			
			self.zzGenerateMethodOutputLen(methodNames[methodIdx] &amp; 'Items', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl::numTIs.name);
			write CrLf &amp; '}' &amp; CrLf &amp; ')';
		
			write 'CM_KPIVoyageEntity (
			jadeMethodSources' &amp; CrLf &amp;
			methodNames[methodIdx] &amp; 'TEU' &amp; CrLf &amp; '{' &amp; CrLf;
			
			self.zzGenerateMethodOutputLen(methodNames[methodIdx] &amp; 'TEU', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl_Container::numTEU.name);
			write CrLf &amp; '}' &amp; CrLf &amp; ')';
		
			write 'CM_KPIVoyageEntity (
			jadeMethodSources' &amp; CrLf &amp;
			methodNames[methodIdx] &amp; 'OverDim' &amp; CrLf &amp; '{' &amp; CrLf;
			
			self.zzGenerateMethodOutputLen(methodNames[methodIdx] &amp; 'OverDim', moveTypeKeys[moveInt], len, CM_KPIVoyageMoveDtl_Container::numOverdimension.name);
			write CrLf &amp; '}' &amp; CrLf &amp; ')';
		endforeach;
endforeach;





epilog
	delete moveTypeNames;
	delete moveTypeKeys ;
	delete transhipNames;
	delete transhipKeys ;
	delete contentsNames;
