    <JadeMethod name="verifyEDIDataTIs" id="de21fb0d-5369-4f4a-80c7-3183667363e8">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Verify the Train Consist by calling the Train Consist in validation mode.
//
// Parameters:	_passport - A reference to the current User's Passport object.
//
// Returns:		The number of errors that were found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
//24/07/2025	naviv1	MTN-34763 : MTN - Deferred Updates Required For Train Consist EDI
// --------------------------------------------------------------------------------
vars
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	app.myTrxUA.trxProcessEDITrainConsist(self, true, _passport);
	
	return _passport.allErrors.size();
epilog
	app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_NONE);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
