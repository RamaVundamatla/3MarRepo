    <JadeMethod name="getDescription" id="355d6699-0eb6-4a4c-a250-4e10d2aa01d2">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if  self.myGroup &lt;&gt; null then
		return self.myGroup.getDescription() &amp; Cr &amp; "&gt; " &amp; self.itemName;
	else
		return self.itemName;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
