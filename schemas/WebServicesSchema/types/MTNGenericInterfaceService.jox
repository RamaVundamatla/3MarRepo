    <JadeMethod name="createActivityHistory" id="5082f780-436b-4fac-b553-3f2723bc9ac4">
        <updating/>
        <source>createActivityHistory(_requestData : String; _pathIn : String; _methodType : String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

//TODO: Modify the content of the constants to fit better with what they should be

vars
	terminal 	: CM_Terminal;
	description : String;
	dataAction	: Character;
	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	terminal := app.myPassport.myTerminal;
	
	if _pathIn.startsWith(Path_GateScanData) then
		if _methodType = self.MethodType_POST then
			description := CM_EWSActivityGenericScan.Description_POST; //"GenericScan - POST (C)";
			dataAction 	:= CM_ExternalWebServiceActivity.DataAction_Create; //"C";
			
		elseif _methodType = self.MethodType_PUT then
			description := CM_EWSActivityGenericScan.Description_PUT; //"GenericScan - PUT (U)";
			dataAction 	:= CM_ExternalWebServiceActivity.DataAction_Update; //"U";
			
		elseif _methodType = self.MethodType_GET then
			description := CM_EWSActivityGenericScan.Description_GET; //"GenericScan - GET (R)";
			dataAction 	:= CM_ExternalWebServiceActivity.DataAction_Retrieve; //"R";
			
		endif;
		
		create self.myCurrentActivityHistory as CM_EWSActivityGenericScan transient;
		self.myCurrentActivityHistory.initialiseActivity(description, 
										CM_EWSActivityGenericScan.InterfaceName, //"Generic Scan"
										terminal, 
										null,
										dataAction,
										CM_EWSActivityGenericScan.DataType,	//"Scan Record"
										false,
										null);
		self.myCurrentActivityHistory.setRequest(_requestData);
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_requestData" type="String"/>
        <Parameter name="_pathIn" type="String"/>
        <Parameter name="_methodType" type="String"/>
    </JadeMethod>
    <JadeMethod name="finaliseResponse" id="c7fe6035-b58b-45b5-abe3-1c12978e8cc3">
        <updating/>
        <source>finaliseResponse(_response: WS_InterfaceObject input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	hadError 		: Boolean;
	jsonHelper 		: JadeJson;
	jsonResponse	: String;
	
begin
	inheritMethod(_response);
	
	on Exception do self.handleJSONException(exception, hadError);
	
	create jsonHelper transient;
	jsonResponse := jsonHelper.generateJson(_response, JadeJson.Format_Json_Microsoft).String;
	
	self.finalizeActivityHistory(jsonResponse);
	
epilog
	delete jsonHelper;
	
end;</source>
        <access>protected</access>
        <Parameter name="_response" type="WS_InterfaceObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="finaliseResponseGeneric" id="906902ef-197d-453a-8395-e83c44102443">
        <updating/>
        <source>finaliseResponseGeneric(_response : WS_GAPIResponse input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	hadError 		: Boolean;
	jsonHelper 		: JadeJson;
	jsonResponse	: String;
	
begin
	//New Error handling code
	if _response &lt;&gt; null and app.myPassport.hasErrors and _response.isKindOf(WS_GAPIErrorResponse) then
		self.httpStatusCode := HttpResponseClientError;
		_response.WS_GAPIErrorResponse.setErrorFromPassport();
		
	elseif _response &lt;&gt; null and app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseClientError;
		
	endif;
	
	// this will avoid the annoying 100010 exception 
	if self.startCnTrx &lt;&gt; null then
		self.cnEndTransactionEx(self.startCnTrx);
	endif;
	
	on Exception do self.handleJSONException(exception, hadError);
	
	create jsonHelper transient;
	jsonResponse := jsonHelper.generateJson(_response, JadeJson.Format_Json_Microsoft).String;
	
	self.finalizeActivityHistory(jsonResponse);
	
epilog
	delete jsonHelper;

end;</source>
        <access>protected</access>
        <Parameter name="_response" type="WS_GAPIResponse" usage="input"/>
    </JadeMethod>
    <JadeMethod name="finalizeActivityHistory" id="1460aaaf-d427-44ff-b0d9-d911192d3320">
        <updating/>
        <source>finalizeActivityHistory(_response : String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	if self.myCurrentActivityHistory &lt;&gt; null then
		if self.myCurrentActivityHistory.isKindOf(CM_EWSActivityGenericScan) then
			self.myCurrentActivityHistory.setResponse(_response);
			self.myCurrentActivityHistory.setResponseCode(self.httpStatusCode);
			app.myTrxCA.trxCreateEWSActivityHistory(self.myCurrentActivityHistory, app.myPassport);
		endif;
	endif;
	
epilog
	if self.myCurrentActivityHistory &lt;&gt; null then
		delete self.myCurrentActivityHistory;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_response" type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateScanData" id="d46d00b2-725d-4f4c-9615-6377ae9e1b7f">
        <updating/>
        <source>getGateScanData(_deviceId : String) : WS_GAPIResponse  updating;
/*

Purpose:			Returns a list of unassigned Gate Scan Reports that match the requested devideId

Parameters:			

Return Value:		

Date			Who		Reason
02 May 2022		navhl20	Initial creation	TFS 52777
16 July 2022	navmd1	TFS 52777 Tidy up/review code
28 Jult 2022	navmd1	TFS 54321 MTN - Generic API - GET GateScanData doesn't un-urlencode parameters
18 Jan 2023		navak20 Task 55758: EUP - INT - Generic API: GET /GateScanData Changes
*/

vars
	scanRecord 				: CM_GenericGateScanRecord;
	terminal 				: CM_Terminal;
	badResponse 			: WS_GAPIErrorResponse;
	goodResponse			: WS_GAPIGateScanDataRes;
	wsScanRecord			: WS_GAPIGenericGateScanRecord;
	genericIfaceAPIDevice	: CM_Object;
	iter					: Iterator;
	completedOk				: Boolean;
	deviceId				: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create badResponse transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK or app.myPassport.hasErrors then		
		self.httpStatusCode := HttpResponseUnauthorized;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return badResponse;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	if not app.getMyUser.canDo(terminal, PmWebGenericScanRecord) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return badResponse;
	endif;
	
	// Un URL Encode the parameter
	deviceId := _deviceId.asStringRESTFUL;
	
	//Do we have a GenericIfaceAPIDevice (CM_WeighBridgeObj or CM_ScanReaderObj) to match the Generic Scan Record to
    genericIfaceAPIDevice := app.myAlternateDict.getGnrcIfaceDvcById(deviceId, terminal.code);
    if genericIfaceAPIDevice = null then //If we have no GenericIfaceAPIDevice then raise and exception
        app.raiseCMException2(WB_not_matched, deviceId, terminal.code, null, null);
		self.httpStatusCode := HttpResponseClientError;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return badResponse;
    endif;
	
	
	create goodResponse transient;
	
	iter := terminal.allGenericScanRecsUnassigned.createIterator();
	terminal.allGenericScanRecsUnassigned.startKeyGeq(deviceId, null, iter);
	
	while iter.next(scanRecord) do
		if scanRecord.deviceId &lt;&gt; deviceId then
			break;
		endif;
		
		create wsScanRecord transient;
		wsScanRecord.setProxyFromObject(scanRecord);
		goodResponse.allScanData.add(wsScanRecord);
	endwhile;
	
	if app.myPassport.hasErrors or wsScanRecord = null then
		self.httpStatusCode := HttpResponseClientError;
		return badResponse;
	endif;
	
	completedOk := true;
	return goodResponse;
epilog
	if not completedOk then
		delete goodResponse;
		self.finaliseResponseGeneric(badResponse);
	else
		delete badResponse;
		self.finaliseResponseGeneric(goodResponse);
	endif;
	delete iter;	// 18.01.2023 navak20 TFS 55758
end;</source>
        <Parameter name="_deviceId" type="String"/>
        <ReturnType type="WS_GAPIResponse"/>
    </JadeMethod>
    <JadeMethod name="getJsonFormatError" id="de3f6c46-1cb7-424d-a855-07f15b259960">
        <updating/>
        <source>getJsonFormatError(_errorCode: Integer; _errorItem: String): WS_GAPIErrorResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2022	navpw1	Initial creation TFS: 53883
04/07/2023	navcs2	Bug 58575: MTN - MasterTerminalAPI processRequest not clearing passport
*/

vars
	response : WS_GAPIErrorResponse;
	
begin
	self.initialisePassport(); //Used for activity history
	response := inheritMethod(_errorCode, _errorItem);
	return response;
	
epilog
	self.finaliseResponseGeneric(response);
	
	response.setErrorFromPassport();			// 04/07/2023	navcs2	Bug 58575
	app.myPassport.clearErrorsWarnings();		// 04/07/2023	navcs2	Bug 58575
end;</source>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_errorItem" type="String"/>
        <ReturnType type="WS_GAPIErrorResponse"/>
    </JadeMethod>
    <JadeMethod name="postGateScanData" id="b5cbf203-4c19-4a76-a67c-471872c1404f">
        <updating/>
        <source>postGateScanData(_request : WS_GAPIGateScanDataReq) : WS_GAPIResponse updating;
/*

Purpose:	This is a Rest api post call for Generic Api Scan Records		

Parameters:		DeviceId and Timestamp are mandatory params.
				Optional params are: Weight,Truck,Cargo,Driver,Chassis

Return Value:		

Date			Who		Reason
15 March 2022	navgm20	Initial creation  TFS 52777
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	terminal 				: CM_Terminal;
	pxyGateScanRecord,
	realGateScanRecord 		: CM_GenericGateScanRecord;
	batNumber, chassisId,
	carrierCode, driverId,
	driverName, truckId 	: String;
	weight 					: Decimal[23,6];
	cargoItem  				: CM_CargoScanRecordData;
	cargoScanRecords 		: WS_GAPICargoArray;
	cargoRec 				: WS_GAPICargo;
	response 				: WS_GAPIResponse;
	genericIfaceAPIDevice 	: CM_Object;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	create response as WS_GAPIErrorResponse transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK or app.myPassport.hasErrors then
		//user has not validated
		self.httpStatusCode := HttpResponseUnauthorized;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if not app.getMyUser.canDo(terminal, PmWebGenericScanRecord) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	//Do we have a GenericIfaceAPIDevice (CM_WeighBridgeObj or CM_ScanReaderObj) to match the Generic Scan Record to
    genericIfaceAPIDevice := app.myAlternateDict.getGnrcIfaceDvcById(_request.deviceId, terminal.code);
    if genericIfaceAPIDevice = null then
		//If we have no GenericIfaceAPIDevice then raise and exception
        app.raiseCMException2(WB_not_matched, _request.deviceId, terminal.code, null, null);
		self.httpStatusCode := HttpResponseClientError;
		return response;
    endif;
	
	if _request.truck &lt;&gt; null then
			batNumber := _request.truck.batNumber;
			carrierCode := _request.truck.carrierCode;
			truckId := _request.truck.id;
	endif;
	if _request.driver &lt;&gt; null then
			driverId := _request.driver.id;
			driverName := _request.driver.name;
	endif;
	if _request.weight &lt;&gt; null then
			weight := _request.weight.value;
	endif;
	if _request.chassis &lt;&gt; null then
			chassisId := _request.chassis.id;
	endif;
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(_request.deviceId, batNumber,carrierCode, chassisId,
										 driverId, driverName, truckId, weight,
										 _request.timestamp, terminal);
	
	cargoScanRecords := _request.cargo;
	foreach cargoRec in cargoScanRecords do
		create cargoItem transient;
		cargoItem.setProxyForCreate(cargoRec.id, cargoRec.alternateId, cargoRec.type, null, null);
		cargoRec.populateSealCollections(cargoItem.sealTypes, cargoItem.sealValues);
		
		pxyGateScanRecord.allCargoItems.add(cargoItem);
	endforeach;
	
	app.myPassport.warningsAcknowledged := true;
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	if app.myPassport.hasErrors or realGateScanRecord = null then
		self.httpStatusCode := HttpResponseClientError;
		return response;
	endif;
	
	// All good so far, so delete the 'bad' response and return a 'good' one instead
	delete response;
	
	create response as WS_GAPIEmptyResponse transient;
	return response;
epilog	
	if pxyGateScanRecord &lt;&gt; null then
		pxyGateScanRecord.allCargoItems.purge();
	endif;
	
	delete pxyGateScanRecord;
	
	self.finaliseResponseGeneric(response);
end;</source>
        <Parameter name="_request" type="WS_GAPIGateScanDataReq"/>
        <ReturnType type="WS_GAPIResponse"/>
    </JadeMethod>
    <JadeMethod name="processRequest" id="0a38a0ac-b9b0-42ca-a962-ff5f99f93839">
        <updating/>
        <source>processRequest(httpIn: String; queryStr: String; pathIn: String; methodType: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2022	navhl20	Initial creation   TFS 52777

*/

begin
	self.createActivityHistory(httpIn, pathIn, methodType);
	inheritMethod(httpIn, queryStr, pathIn, methodType);

end;</source>
