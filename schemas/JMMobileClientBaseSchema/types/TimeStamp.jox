<PrimType name="TimeStamp">
    <JadeMethod name="mbAddDays" id="705e9fdf-0a68-4272-8c8a-2c98743ffbb9">
        <source>mbAddDays(_days:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver timestamp.
//
// Parameters:	_days (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.mbAddDays(_days));
	
	return currentTimestamp;
end;</source>
        <Parameter name="_days" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAddHours" id="a25e38b6-a734-498a-b03d-ce734b4249df">
        <source>mbAddHours(_hours:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver timestamp.
//
// Parameters:	_hours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if _hours &gt; 0 then
		adjustTime.setTime(_hours, 0, 0, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(-_hours, 0, 0, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="_hours" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAddMinutes" id="4d2dc29b-8203-4c03-aa6b-805ad6ed9414">
        <source>mbAddMinutes(_minutes:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver timestamp.
//
// Parameters:	_minutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if _minutes &gt; 0 then
		adjustTime.setTime(0, _minutes, 0, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(0, -_minutes, 0, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="_minutes" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAddMonths" id="c82835cb-4501-4d4b-84d7-ff1813b82e3d">
        <source>mbAddMonths(_months:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver timestamp.
//
// Parameters:	pMonth (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.mbAddMonths(_months));
	
	return currentTimestamp;
end;</source>
        <Parameter name="_months" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAddSeconds" id="90758a4f-77e0-4283-b412-159762a8eaf2">
        <source>mbAddSeconds(_seconds:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver timestamp.
//
// Parameters:	_seconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if _seconds &gt; 0 then
		adjustTime.setTime(0, 0, _seconds, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(0, 0, -_seconds, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="_seconds" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAddYears" id="9e3c8925-e5dc-41c7-bae4-46dcb4a4ad5b">
        <source>mbAddYears(_years:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				receiver timestamp.
//
// Parameters:	_years (Integer) - The number of years to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.mbAddYears(_years));
	
	return currentTimestamp;
end;</source>
        <Parameter name="_years" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbAge" id="a2c8579b-d05f-4159-9375-80c1c4c3086d">
        <source>mbAge():Decimal;
// Determines the age - i.e. the time between the TimeStamp and now.
// Returns the age in milliseconds.
vars
	now	: TimeStamp;
	age	: Decimal[23,1];

begin
	if now &gt;= self then
		age := now.mbDiff(self);
	else
		age := self.mbDiff(now);
	endif;

	return age;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="mbAgeInDays" id="90977dc2-a285-42b7-8915-5df747f68af1">
        <source>mbAgeInDays():Integer;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MILLISECONDS_IN_DAY	: Integer = 86400000;
	
begin
	return (self.mbAge() div MILLISECONDS_IN_DAY).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mbDiff" id="37ccc690-cb7c-411e-8a97-52520d9b0f96">
        <source>mbDiff(_timeStamp:TimeStamp):Decimal;
// Calculates the difference between two timestamp values and returns "days" and
// time difference in milliseconds.  The value returned will be positive (always
// taking the smaller value from larger value).
constants
	MILLISECONDS_IN_DAY	: Integer = 86400000;
	
vars
	dateFrom		: Date;
	dateTo			: Date;
	timeFrom		: Time;
	timeTo			: Time;
	daysDifference	: Integer;

begin
	// Make sure we take the smaller value from the larger.

    if self &gt; _timeStamp then
 		dateFrom	:=	self.Date;
		dateTo		:=	_timeStamp.Date;

	   	timeFrom	:=	self.Time;
		timeTo		:=	_timeStamp.Time;
	else
		dateTo		:=	self.Date;
		dateFrom	:=	_timeStamp.Date;

	   	timeTo		:=	self.Time;
		timeFrom	:=	_timeStamp.Time;
	endif;

	daysDifference	:=	dateFrom - dateTo;         						// Get the difference in dates.

	// [DvA19990127] added .Decimal to be able to calculate with differences larger than 24 days.....
	// .... also changed the returned datatype from Integer to Decimal.
	// cnwdad1 03/12/2001 - Changed to cast the Milliseconds_In_Day to a decimal.
//	return  (Milliseconds_In_Day * daysDifference).Decimal + 			// days component
//			(timeFrom - timeTo).Decimal;								// and time
	return  (MILLISECONDS_IN_DAY.Decimal * daysDifference.Decimal) + 	// days component
			(timeFrom - timeTo).Decimal;								// and time
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="mbEstimatedEndTime" id="0933f2ac-fe6e-4634-97ac-fb03bb8fe10b">
        <source>mbEstimatedEndTime(_startTime:TimeStamp; _totalParts:Integer; _partsDone:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		27 February 2003 by cnwdad1
//
// Purpose:		Estimates the completion time of a number of job parts, based upon
//				the total number of parts to do, and the number of parts that are
//				already done.
//
// Parameters:	_startTime - The time that the processing began.
//				
//
// Returns:		The estimated timestamp for when the job will be completed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elapsedMilliSeconds	: Decimal[23,0];
	estTotalElapsed		: Decimal[23,0];
	returnTime			: Time;
	returnTimestamp		: TimeStamp;
	plusDays			: Integer;
	plusHours			: Integer;
	plusMins			: Integer;
	plusSecs			: Integer;
	
begin
	elapsedMilliSeconds	:=	self.mbMillisecondsSince(_startTime);
	estTotalElapsed		:=	(elapsedMilliSeconds / _partsDone) * _totalParts;
	
	if estTotalElapsed &gt;= 86400000 then
		plusDays		:=	(estTotalElapsed / 86400000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 86400000;
	endif;
	
	if estTotalElapsed &gt;= 3600000 then
		plusHours		:=	(estTotalElapsed / 3600000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 3600000;
	endif;
	
	if estTotalElapsed &gt;= 60000 then
		plusMins		:=	(estTotalElapsed / 60000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 60000;
	endif;
	
	if estTotalElapsed &gt;= 1000 then
		plusSecs		:=	(estTotalElapsed / 1000).Integer;
		estTotalElapsed	:=	estTotalElapsed mod 1000;
	endif;
	
	returnTime.setTime(	_startTime.Time.hour,
						_startTime.Time.minute,
						_startTime.Time.second,
						00);
	
	if plusSecs &gt; 0 then
		if plusSecs + returnTime.second &gt; 60 then
			plusMins	:=	plusMins + 1;
			plusSecs	:=	(plusSecs + returnTime.second) - 60;
		endif;
	endif;  
	
	if plusMins &gt; 0 then
		if plusMins + returnTime.minute &gt; 60 then
			plusHours	:=	plusHours + 1;
			plusMins	:=	(plusMins + returnTime.minute) - 60;
		endif;
	endif;
	
	returnTime.setTime(	returnTime.Time.hour,
						plusMins + returnTime.Time.minute,
						plusSecs + returnTime.Time.second,
						00);
	
	returnTimestamp.setTime(returnTime);
	returnTimestamp.setDate(_startTime.Date); 
	
	if plusHours &gt; 0 then
		returnTimestamp	:=	returnTimestamp.mbAddHours(plusHours);
	endif;
	
	if plusDays &gt; 0 then
		returnTimestamp	:=	returnTimestamp.mbAddDays(plusDays);
	endif;
	
	return returnTimestamp;
end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_totalParts" type="Integer"/>
        <Parameter name="_partsDone" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="mbIsLessThanOrEqual" id="4b8a8a81-0e47-4195-9482-cedb74a636e0">
        <source>mbIsLessThanOrEqual(_timeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is less-
//				than or equal-to the specified timestamp.
//
// Parameters:	_timeStamp - The tmestamp to compare the receiver to.
//
// Returns:		True if the receiver is less-than or equal-to the specified timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt; _timeStamp.date then
		return true;
	elseif self.date = _timeStamp.date and self.time &lt;= _timeStamp.time then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbMillisecondsSince" id="2b3bc3bd-4a57-4f9b-8d6e-6f894ecd1c6f">
        <source>mbMillisecondsSince(_start:TimeStamp):Decimal;
// --------------------------------------------------------------------------------
// Created:		27 February 2003 by cnwdad1
//
// Purpose:		Returns the number of milliseconds since the specified timestamp.
//
// Parameters:	_start - The timestamp from which to measure the milliseconds.
//
// Returns:		The number of milliseconds.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	HOURS_IN_DAY			: Integer = 24;
	MINUTES_IN_HOUR			: Integer = 60;
	SECONDS_IN_MINUTE		: Integer = 60;
	MILLISECONDS_IN_SECOND	: Integer = 1000;
	
vars
	difference  : Decimal[23,0];
	
begin
	difference	:=	(self.Date - _start.Date) * HOURS_IN_DAY * MINUTES_IN_HOUR * SECONDS_IN_MINUTE * MILLISECONDS_IN_SECOND;
	difference	:=	difference + (self.Time - _start.Time);
	
	return difference;
end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="mbSetDateAndTime" id="6e4d8204-e2e4-4c1e-a0c9-3726efdd07bf">
        <updating/>
        <source>mbSetDateAndTime(_date:Date; _time:Time) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Updates the Date and Time properties of the TimeStamp.
//
// Parameters:	_date (Date) - The new date value.
//				_time (Time) - The new time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt;&gt; _date then
		self.setDate(_date);
	endif;
	
	if self.time &lt;&gt; _time then
		self.setTime(_time);
	endif;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="shortCurrentLocaleFormat" id="23f0bc50-704b-4cdf-ab3e-c83ecf66963b">
        <source>shortCurrentLocaleFormat(_isSplit:Boolean) : String;
// if format changes then you may have to change primitiveType String.convertToTimeStamp() as well
begin
	//Make sure self is valid as time.currentLocaleFormat returns 12:00:00am (midnight) if not set	
	//if date is set and time is 00:00:00 then timeStamp is valid and therefore must be midnight
	//if Date is not set then self is invalid.
	
	if self.isValid() then
		// Par 9488
		// DVB changed this to cast time as a string because time.currentLocaleFormat screws up sorting. Date is still using locale.
		if _isSplit then
			return date.shortFormatJMT() &amp; CrLf &amp; time.currentLocaleFormatJMT();
		else
			return date.shortFormatJMT() &amp; ' ' &amp; time.currentLocaleFormatJMT();
		endif;
		
//		return date.shortFormat &amp; ' ' &amp; time.String;//time.currentLocaleFormat;
//		return date.shortFormat &amp; ' ' &amp; time.currentLocaleFormat;
	endif;
	
	return null;
		   
//    return time.currentLocaleFormat &amp; " " &amp; date.shortFormat;
end;</source>
        <Parameter name="_isSplit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
