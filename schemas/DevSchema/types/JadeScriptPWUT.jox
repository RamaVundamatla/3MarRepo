    <JadeMethod name="pwUnitTestsGetSubClassesCnt" id="28a9cba1-1c86-443c-9773-a3d8bf51f66f">
        <source>pwUnitTestsGetSubClassesCnt(_klass : Class input; _classNames : StringArray input; _methodCounts : IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2024	navpw1	Initial creation

*/
constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars
	class : Class;
	classCol : ClassColl;
	meth : Method;
	methNDict : MethodNDict;
	currentCountMethods : Integer;
	countMethods,
	indexOf: Integer;
	classStr : String;
	parentClass : Class;
	scm : Schema;
	utDsl : Class;
	
begin
	scm := rootSchema.getSchema("JMTUnitTest");
	utDsl := scm.getClass("UT_DSL");
	
	create classCol transient;
	create methNDict transient;
	_klass.getSubclasses(classCol);
	foreach class in classCol do
		methNDict.clear();
		class.getMethods(methNDict);
		
		parentClass := class;
		
		while parentClass.getSuperclass &lt;&gt; utDsl do
			parentClass := parentClass.getSuperclass;
		endwhile;
		
		currentCountMethods := 0;
		foreach meth in methNDict do
			if self.isRunnableUnitTestMethod(meth) then
				currentCountMethods += 1;
			endif;
		endforeach;
		
		//currentCountMethods := methNDict.size;
		indexOf := _classNames.indexOf(parentClass.name);
		if indexOf &gt; 0 then
			countMethods := _methodCounts[indexOf].Integer;
			countMethods += currentCountMethods;
			_methodCounts[indexOf] := countMethods;
		else
			_classNames.add(parentClass.name);
			_methodCounts.add(currentCountMethods);
		endif;
		
		if class.hasSubclasses then
			self.pwUnitTestsGetSubClassesCnt(class, _classNames, _methodCounts);
		endif;
		
	endforeach;
	
epilog
	delete classCol;
	delete methNDict;
	
end;</source>
        <access>protected</access>
        <Parameter name="_klass" type="Class" usage="input"/>
        <Parameter name="_classNames" type="StringArray" usage="input"/>
        <Parameter name="_methodCounts" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pwUnitTestsGetSubClassesCntObj" id="9fb6146e-dbdd-43b3-9b03-a753078e035f">
        <source>pwUnitTestsGetSubClassesCntObj(_dict : DynaDictionary input; _cls : Class) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024	navpw1	Initial creation

*/

constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars
	class : Class;
	classCol : ClassColl;
	meth : Method;
	methNDict : MethodNDict;
	currentCountMethods : Integer;
	countMethods,
	indexOf: Integer;
	classStr : String;
	parentClass : Class;
	scm : Schema;
	utDsl : Class;
	unitTestClassTotal : CMIF_UnitTestClassTotal;
	unitTestDetail : CMIF_UnitTestDetail;
	
begin
	scm := rootSchema.getSchema("JMTUnitTest");
	utDsl := scm.getClass("UT_DSL");
	
	create classCol transient;
	create methNDict transient;
	_cls.getSubclasses(classCol);
	foreach class in classCol do
		methNDict.clear();
		class.getMethods(methNDict);
		
		parentClass := class;
		
		while parentClass.getSuperclass &lt;&gt; utDsl do
			parentClass := parentClass.getSuperclass;
		endwhile;
		
		unitTestClassTotal := _dict[parentClass.name].CMIF_UnitTestClassTotal;
		if unitTestClassTotal = null then
			app.raiseCMException1(Err_Is_Null, "unitTestClassTotal", null, null);
		endif;
		
		foreach meth in methNDict do
			create unitTestDetail transient;
			unitTestDetail.className := class.name;
			unitTestDetail.methodName := meth.name;
			unitTestDetail.isRunnable := self.isRunnableUnitTestMethod(meth);
			unitTestDetail.isIgnored := self.isIgnoredUnitTestMethod(meth);
			unitTestDetail.isUtility := self.isUtilityUnitTestMethod(meth);
			unitTestDetail.isVerification := self.isVerificationUnitTestMethod(meth);
			unitTestClassTotal.allMethods.add(unitTestDetail);
		endforeach;
		
		if class.hasSubclasses then
			self.pwUnitTestsGetSubClassesCntObj(_dict, class);
		endif;
		
	endforeach;
	
epilog
	delete classCol;
	delete methNDict;
	
end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="DynaDictionary" usage="input"/>
        <Parameter name="_cls" type="Class"/>
    </JadeMethod>
</Class>
