    <JadeMethod name="initForShow" id="fa9cb46a-41b6-4e69-b09f-48e7a60512fe">
        <updating/>
        <source>initForShow(_voyage : CM_Voyage; _source : CM_LocationsController; _target : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	self.myVoyage := _voyage;
	self.myLocationSource := _source;
	self.myLocationTarget := _target;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_source" type="CM_LocationsController"/>
        <Parameter name="_target" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="initTableEntry" id="fa9855b8-80fc-4c35-b028-0222ed51001f">
        <source>initTableEntry();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	theHeight : Integer;
begin

	theTable := self.tblEntry;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
		
	entTableDef := app.myController.getEntTableDef(ETDef_TbaEntry);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.adjustHeight(200);

	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	if self.myLocationSource &lt;&gt; null then
		theTable.setValueByName(ETRow_TbaYardLocation,self.myLocationSource.getFullId());
		theTable.disableRowByName(ETRow_TbaYardLocation);
	endif;
	if self.myLocationTarget &lt;&gt; null then
		theTable.setValueByName(ETRow_TbaPlanTo,self.myLocationTarget.getFullId());
		theTable.disableRowByName(ETRow_TbaPlanTo);
		self.chkPlan.value := true;
	endif;
	
	theRow := theTable.getRowByName(ETRow_TbaHazards);					// TFS 2842
	theTable.accessCell(theRow, theTable.ColumnValue).inputType := 0;	// TFS 2842
	theTable.accessedCell.cellControl := null;							// TFS 2842
	self.lstHazardList.enabled := false;								// TFS 2842
	self.lstHazardList.visible := false;								// TFS 2842
	self.lstHazardList.userInputEnabled := false;						// TFS 2842
	
	
	theRow := theTable.getRowByName(ETRow_TbaReefer);					// TFS 45590
	theTable.accessCell(theRow, theTable.ColumnValue).inputType := 0;	// TFS 45590
	theTable.accessedCell.cellControl := null;							// TFS 45590

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="dfd15f30-1bb0-4daa-a814-47a8b627beaf">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/09/2014	cnwdap1		Initial creation PAR #33872 Measurement types for TBAs
//
vars

begin
	if self.doCheckKeyDownSpecial(keyCode, CMUI_AttachBreakBulk::doTblItemCellInputReady.name) then
		keyCode := 0;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="7b2f6dbc-17d7-4692-9b5d-5987391c186b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPort		: CM_Port;
	aVoyage 	: CM_Voyage;
	tmpInt		: Integer;
	llti		: CM_EDILoadListTI;
	isoGroup	: CM_ISOTypeGroup;
	isoType		: CM_ISOType;
	commodity	: CM_Commodity;
	operator	: CM_Operator;
	terminal	: CM_Terminal;
	defTBALoc	: String;

begin
	inheritMethod();
	
	delete app.myMoveController;
	
	aVoyage := self.myVoyage;
	aPort := self.myTerminal.getDefaultPort();
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then // TFS 45590
		defTBALoc := terminal.getConfig(DefaultTBAYardLocation).String; // TFS 45590
		self.tblEntry.setValueByName(ETRow_TbaYardLocation, defTBALoc); // TFS 45590
	endif; // TFS 45590

	self.cmbCommodity.setObject(commodity);
	self.cmbCommodity.lostFocus(self.cmbCommodity);

	self.myAssistant.comboBoxISOTypeByGroup(self.cmbISOType, isoGroup, isoType);
	self.cmbISOType.lostFocus(self.cmbISOType);
	self.doBuildComboPort();
	self.doBuildComboVoyage();
	if self.myLocationTarget = null then
		self.doBuildComboLocations();
	endif;
	if aPort &lt;&gt; null then
		//self.cmbDischPort.listObject := aPort;
		self.cmbDischPort.listIndex := self.cmbDischPort.findObject(aPort);	//06 Jul 2012	NDL Par 29935
		self.cmbDischPort.lostFocus(self.cmbDischPort);
	endif;
	if aVoyage &lt;&gt; null then
		tmpInt := self.cmbVoyage.findObject(aVoyage);
		if tmpInt &gt; 0 then
			self.cmbVoyage.listIndex := tmpInt;
		endif;
		self.cmbVoyage.lostFocus(self.cmbVoyage);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		self.cmbSubTerminal.automaticCellControl	:=	true;
		self.myAssistant.comboBoxSubTerminal(self.cmbSubTerminal, null, self.myTerminal);
	else
		self.tblEntry.hideRowByName(ETRow_MySubTerminal, false);
	endif;
	
	self.myAssistant.resetHazardListTable(lstHazardList);
	self.doBuildComboReceive();
end;</source>
        <access>protected</access>
    </JadeMethod>
