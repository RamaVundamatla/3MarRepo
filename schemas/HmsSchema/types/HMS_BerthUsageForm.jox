    <JadeMethod name="doResize" id="6a9ae708-0e57-4b84-9c6e-2fc66835a7b6">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

	tmpTop : Real;
	
begin

	inheritMethod();
	tmpTop := self.frmToolbar.height;
	self.fldMain.move(0, tmpTop, self.clientWidth, self.clientHeight-tmpTop+7);
	
	//15 Feb 2012	NDL	Par 29120
	self.doResizeGraphs();
	self.doResizePies();

	
//	self.pieGraph.redrawGraph();
//	self.barGraph.redrawGraph();
	
