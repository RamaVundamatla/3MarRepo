    <JadeMethod name="initialize" id="0a75ac2a-857a-436d-8912-0fe847ff47cc">
        <updating/>
        <source>initialize() updating;
// --------------------------------------------------------------------------------
// Created:		20 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj	: Schema;
	
begin
	inheritMethod();
	
	schemaObj	:=	rootSchema.getSchema(JSSCoreSchema.name);
	self.loadErrorMessages(schemaObj);
	self.loadErrorMessages(currentSchema);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadErrorMessages" id="bbe92132-eb99-4280-a9d1-96fd449f984a">
        <updating/>
        <source>loadErrorMessages(pTheSchema:Schema) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Locates all of the peer schema's error (global) constants, and
//				creates transient error objects for use when an error occurs at
//				run-time.
//
// Parameters:	pTheSchema - The schema in which the error codes constant category
//				is located.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCategories	: ConstCategoryNDict;
	theCategory		: ConstantCategory;
	theConstant		: Constant;
	errorObj		: JSSErrorMessage;
	categoryName	: String;
	prefixLength	: Integer;
	
begin
	self.baseErrorNumber	:=	JSS_EX_00001;
	prefixLength			:=	JSS_EXCEPTION_NAME_PREFIX.length;
	allCategories			:=	pTheSchema.jssGetLocalConstantCategories();
	
	foreach theCategory in allCategories do
		categoryName	:=	theCategory.name;
		
		if categoryName.length &lt; prefixLength
		or categoryName[1:prefixLength] &lt;&gt; JSS_EXCEPTION_NAME_PREFIX
		then
			continue;
		else
			// Create an error object for each constant in this category.
			
			foreach theConstant in theCategory.getConstants do
				create errorObj transient;
				errorObj.initializeGlobalConstant(self, theConstant.GlobalConstant);
				
				if errorObj.errorCode &lt; self.baseErrorNumber then
					self.baseErrorNumber	:=	errorObj.errorCode;
				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="raiseException" id="9f8ef431-5c59-4e61-94c5-d4642294ddcc">
        <updating/>
        <source>raiseException(pExceptionObj:JSSException input; pErrorCode:Integer; pErrorText:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Raises a JSSException.
//
// Parameters:	pExceptionObj - The exception object.
//				pErrorCode - The error code to report.
//				pErrorText - A description of the error.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lastErrorCode	:=	pExceptionObj.errorCode;
	self.lastErrorText	:=	pExceptionObj.extendedErrorText;
	
	pExceptionObj.errorCode			:=	pErrorCode;
	pExceptionObj.errorItem			:=	"Error " &amp; pErrorCode.String;
	pExceptionObj.extendedErrorText	:=	pErrorText;
	
	raise pExceptionObj;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="JSSException" usage="input"/>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pErrorText" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseJSSException" id="9134f94a-0511-4adf-9c5a-fea6b5614035">
        <updating/>
        <source>raiseJSSException(pErrorCode:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Raises an exception for the specified error code.
//
// Parameters:	pErrorCode
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	exceptionObj	: JSSException;
	errorText		: String;
	
begin
	create exceptionObj transient;
	
	errorText	:=	self.getErrorString(pErrorCode);
	self.raiseException(exceptionObj, pErrorCode, errorText);
end;</source>
        <Parameter name="pErrorCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="raiseJSSException1" id="c71cef1e-e67b-46da-855d-1fa76bf53ef1">
        <updating/>
        <source>raiseJSSException1(	pErrorCode:Integer;
					pParameter1:String) updating;
