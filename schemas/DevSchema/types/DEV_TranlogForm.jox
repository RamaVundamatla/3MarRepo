    <JadeMethod name="tblDetailsSetup" id="230039c2-d38b-4f73-b3fd-99ec05b2162f">
        <source>tblDetailsSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	if not self.allTranLogs.isEmpty then
		self.allTranLogs.purge();
	endif;

	self.tblDetails.columns := 6;
	self.tblDetails.rows := 1;
	self.tblDetails.fixedRows := 1;
	
	self.tblDetails.setCellText( 1, 1, DEV_TranLogObj@getHeaderLine );
	

epilog

end;</source>
    </JadeMethod>
