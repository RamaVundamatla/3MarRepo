<Class name="UT_WorkOrders" id="7d7998fa-4cf0-4b25-981a-d969e42402da">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <ImplicitInverseRef name="myVoyage" id="d3d5be56-ae54-4c1b-b0bc-49f18c04a3f3">
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="assignedTeam" id="d354ea5a-606b-4f14-b263-f071f091a6eb">
        <options>4</options>
        <source>assignedTeam(): String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2025	navsp1	Initial creation JIRA-34202

*/

vars

begin
	return UT_UnitTest.Team_Mohamed;

epilog

end;</source>
