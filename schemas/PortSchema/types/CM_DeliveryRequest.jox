        <source>getSourceTermArea() : CM_TerminalArea;
// from 27911 to display the source terminal area, if only one just show it otherwise do the full getNominatedTA processing
// cnwjre1 Nov 2011, only used in form display not queue processing etc
vars
	ta	: CM_TerminalArea;
begin
	if self.allTerminalAreas.size = 1 then
