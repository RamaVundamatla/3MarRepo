<Class name="CMQF_TransVoyageCargoChanges" id="23721330-cc2e-4b9b-95d3-14e431963482">
    <superclass name="CMQF_Transactions"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allSites" id="2db4e5db-5a6a-41b8-ba30-aa95e94ba394">
        <embedded/>
        <type name="IntegerArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="cd43411b-337b-45c0-bcdf-dd2f4010f01b">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29118
//04 May 2016	cnwrs1	Par 37842	when createing as persistant then the allSites should be persistant as well
*/

vars

begin
	if self.isTransient then
		create self.allSites transient;
	else
		create self.allSites persistent;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="9cb1d5b2-a737-4a91-9f98-26a625469ba7">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars

begin

	if self.allSites &lt;&gt; null then
		delete self.allSites;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="d3283503-3100-4ca7-ba9a-285220170189">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars

	voyage 		: CM_Voyage;
	txnType 	: Integer;
	startTS,
	endTS		: TimeStamp;
	terminal 	: CM_Terminal;
	cargoType 	: Integer;
	isOnShip : Boolean;
	isOnSite : Boolean;
	isOffSite : Boolean;
	
begin
	if self.getMyCargoType &lt;&gt; null then
		cargoType := self.getMyCargoType.id;
	endif;
	
	//Add edit txns as search option.
	self.initFields();
	
	//Set the time/date range.
	self.setDefaultStartEndDates(startTS, endTS);
	
	isOnShip := ( self.allSites = null or self.allSites.isEmpty or self.allSites.includes( TI_SITE_ONSHIP ) );
	isOnSite := ( self.allSites = null or self.allSites.isEmpty or self.allSites.includes( TI_SITE_ONSITE ) );
	isOffSite := ( self.allSites = null or self.allSites.isEmpty or self.allSites.includes( TI_SITE_OFFSITE ) );
	
	if self.getMyVoyage &lt;&gt; null then
		voyage := self.getMyVoyage;
		if not voyage.archived then
			foreach txnType in self.allTxnTypes do 
				voyage.getTITxnsByTypeFromTIs(txnType, 
											  isOnShip,
											  isOnSite,
											  false,
											  isOffSite,
											  startTS, 
											  endTS, 
											  CMQF_FilterReports::checkStatusIncludesObject.name, 
											  self, 
											  _collection);	
			endforeach;
		endif;
		
	else
		foreach terminal in self.allTerminals do : terminalLoop
			foreach txnType in self.allTxnTypes do
				terminal.getTITxnsForTypeAll(txnType, startTS, endTS, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
			endforeach;
		endforeach;
		
	endif;
		
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="60d8070b-733d-42af-8133-298fdc520546">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars

	rtnValue : Boolean;
	
begin

	rtnValue :=  inheritMethod(_trx, _passport, _breakOut);

	if rtnValue = false then
		return false;
	endif;
	
	if _trx.myTrackedItem = null then
		return false;
	endif;

	if self.getMyCargoType &lt;&gt; null and 
	   self.getMyCargoType &lt;&gt; _trx.myTrackedItem.myCargoType then
		return false;
	endif;
	
	if self.myOperator &lt;&gt; null and 
	   self.myOperator &lt;&gt; _trx.myTrackedItem.myOperator then
		return false;
	endif;
	
	if self.allSites &lt;&gt; null and not self.allSites.isEmpty then
		if not self.allSites.includes( _trx.myTrackedItem.site ) then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="b34512da-df5d-49c8-915f-3f21716ee295">
        <updating/>
        <source>initFields() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars

begin
	inheritMethod();
	self.allTxnTypes.add(TRANS_TYPE_EDIT);

epilog

end;</source>
    </JadeMethod>
</Class>
