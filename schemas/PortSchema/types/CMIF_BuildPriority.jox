    <JadeMethod name="action" id="aed8bd91-6558-4b2a-9564-0266bb20d631">
        <updating/>
        <source>action() updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.mode = Mode_Add then
		self.actionCMIFRequests();
	endif;
	
	if self.mode = Mode_Update then
		self.actionForUpdate();
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="actionCMIFRequests" id="c5769fa9-3af2-4528-bacb-6f432bf70ed9">
        <updating/>
        <source>actionCMIFRequests() updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	intFaceObj	: CMIF_Request;
	newRequest : CM_Request;
begin

	foreach intFaceObj in self.allCMIFRequests do
		if intFaceObj.quantityTxt = 0
		and intFaceObj.weight = 0 //03 Feb 2016	NDL	Par 37492
		and not intFaceObj.isAnyAmount // 19/10/2022 jlizm1 TFS 54118
		then
			continue;
		endif;
		intFaceObj.userCode := self.myPassport.userCode;
		newRequest := intFaceObj.action(self.myPassport);
		
		if newRequest &lt;&gt; null then
			if self.myReserveHeader &lt;&gt; null then
				newRequest.setBulkRelease(self.myReserveHeader);
				if (intFaceObj.myTrackedItem &lt;&gt; null and intFaceObj.myTrackedItem.canMergeBreakBulk) or intFaceObj.isAnyAmount then	//16 Sep 2013	NDL	Par 32479
					// leave it set for rail multi release from 
				else
					newRequest.setMyOriginatingBulkRelease(null);
				endif;
			else
				self.myReserveHeader := newRequest.bulkRelease;
			endif;
		endif;
		if self.myPassport.hasErrors() then
			break;
		endif;		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="actionForUpdate" id="c22494e9-462e-4f7f-8eb8-f9f77fb1eeb9">
        <updating/>
        <source>actionForUpdate() updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	edition		: Integer;
	intFaceObj	: CMIF_Request;
	realJob		: CM_Job;
begin

	self.myProxyRailJob.pxyGetRealObjectAndEdition(realJob, edition);
	
	if realJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.myProxyRailJob.class.name, null, null);
		return;
	endif;
	
	exclusiveLock(realJob);

	if self.myPassport.noErrors and realJob.edition &lt;&gt; self.expectedJobEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Rail Job', null, null);
		return;
	endif;
	
	realJob.setForUpdate(self.myProxyRailJob, self.myPassport.myTerminal);
	
	self.actionCMIFRequests();

	realJob.causeTerminalEvent(realJob.Event_Mode_Update);			

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="c67ae49d-7b10-49c8-91ff-2a04017aaad2">
        <source>validate();
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	intFaceObj	: CMIF_Request;
begin

	if self.allCMIFRequests.isEmpty then
		app.raiseCMException(NoCargoSelected, null, null);
	endif;
	
	if self.mode &lt; Mode_Add and self.mode &gt; Mode_Update then
		app.raiseUnexpectedProgramError(class.name,method.name, 'Invalid Mode ' &amp; self.mode.String);
	endif;				

	if self.myProxyRailJob = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Proxy Rail Job', null, null);
		app.raiseCMException(Input_required_field_proxyRail, null, null); // cnwdb2	PAR 35364
	endif;				
			
	if self.myPassport = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, 'Passport', null, null);
		app.raiseCMException(Input_required_field_passport, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myPassport.hasErrors() then
		return;
	endif;

	foreach intFaceObj in self.allCMIFRequests do
		intFaceObj.validate();
	endforeach;

end;</source>
    </JadeMethod>
</Class>
