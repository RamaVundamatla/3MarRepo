    <JadeMethod name="doBtnNewDateClick" id="6b9fc47c-6870-4592-ac5f-81abab05d5b2">
        <updating/>
        <source>doBtnNewDateClick()updating;
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myCurrentCalendar = null or self.lstData.listIndex &lt; 0 then
		global.beep;
		app.msgBox("Please select a Calendar to add a date to.","New Date Error",MsgBox_OK_Only);
		return;
	endif;

	if self.myCurrentYear = null then
		global.beep;
		app.msgBox("Please select a Year to add a date to.","New Date Error",MsgBox_OK_Only);
		return;
	endif;
	
	self.setUpdateMode(self.UpdateMode_New);
	self.modePropertyNew := self.MODEPROPERTY_DATE;
	self.modePropertyUpdate := null;
	self.myCurrentDate := null;

	self.showPropertyFrame('DateEntry', null,PROPHEIGHT);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNewYearClick" id="1a1fdb56-effc-4cb4-9602-cf9996d349cd">
