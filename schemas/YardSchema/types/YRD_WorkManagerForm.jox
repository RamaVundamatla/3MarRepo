    <JadeMethod name="doResetSearch" id="2e65d0df-5ba2-43e1-9fa4-795197a32c09">
        <source>doResetSearch();
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	today : Date;
	
begin
	today := self.systemToLocalTime(app.actualTimeServer()).date;

	self.mskDateFrom.setDate( today );
	self.mskDateTo.setDate( today );
	
	self.txtWorkOrderId.text := null;
	self.cmbOrganisation.listObject := null;

	self.mltTasks.setSelected(self.allTaskTypes);
	
epilog

end;</source>
