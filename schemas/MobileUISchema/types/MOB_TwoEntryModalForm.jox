    <JadeMethod name="handleF3Key" id="43dce728-0c64-41a6-b3c7-777bcf8ef4a8">
        <updating/>
        <source>handleF3Key() updating;

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		app.myMobileGUIAgent.loadRecordDamageForm(myTrackedItem);
	else
		app.msgBox(app.getErrorString(Damage_Nothing_Selected), "", MsgBox_OK_Only);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleF5Key" id="31998893-6fe3-41b1-90cb-b2aa94430bbd">
        <updating/>
        <source>handleF5Key() updating;

vars

begin
	if app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobCargoEnquiry) then
		app.myMobileGUIAgent.loadCargoEnquiryForm(myTrackedItem);
	else
		app.msgBox(app.getErrorString1(NoPermission, 'view cargo items.'), '', MsgBox_OK_Only);
		return;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleOK" id="433773d4-47b4-4b2a-82b1-d2b64a02673a">
        <updating/>
        <source>handleOK()updating;
/*
	Created on 14 May 2008
	
	by Debby Hutchison
	
	Purpose:
	
	Changed On	By			Reason
	----------	--------	----------------------------------------------
	28/05/2010	cnwdap1		CCMS 1116 Tranship changes
	19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	ti 		: CM_TrackedItem;
	pxyTI	: CM_TrackedItem;
	result	: Integer;
	seal,
	cmdtStr,
	id		: String;
	cmdt 	: CM_Commodity; 
	timeStamp : TimeStamp;
	terminal : CM_Terminal;
	marine : CM_SubTerminal;
begin
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'current cargo item is null');
		return;
	endif;
	if ti.isKindOf(CM_Container) then
		seal := self.txt_Input3.text.trimBlanks;
		if seal = null then
			app.msgBox("Please enter a Seal Number","", MsgBox_OK_Only);
			return;
		endif;
	else
		id := self.txt_Input3.text.trimBlanks;
		if id = null then
			app.msgBox("Please enter a Pack ID","", MsgBox_OK_Only);
			return;
		endif;		
	endif;

	cmdt := self.cmb_Commodity.listObject.CM_Commodity;
	if cmdt = null then
		app.msgBox("Please select a commodity","", MsgBox_OK_Only);
			return;
	endif;
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	// PAR #23645 CCMS 1116 don't change IMEX status if it's a tranship
	if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT); //+ dh 31/7/2008 par 17655
	endif;
	if pxyTI.isKindOf(CM_Container) then
		timeStamp := app.actualTimeServer();	// 8/6/16 cnwmp6 TFS 488 - Multi timezone support
		pxyTI.CM_Container.setSealDetails(seal, timeStamp, false);
	else
		pxyTI.zSetPxyId(id);
	endif;
	pxyTI.setCommodity(cmdt.code);
	
	//epr TFS 2332 14/7/16
	terminal:= ti.myTerminal;
	if terminal &lt;&gt; null and terminal.isSubTerminalsOn then
		marine := terminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal;
		pxyTI.setSubTerminal(marine,null);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIPackComplete(pxyTI, null, null, app.myPassport);	//19.03.2024 navhl20 #62863
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
	endwhile;
	if app.myPassport.noErrors then			
		self.modalResult := ModalResultOK;
		self.unloadForm;
	endif;
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="hasUnsavedChanges" id="04a3af10-adc1-46f7-b7ec-0bbebeb9c62c">
        <source>hasUnsavedChanges(): Boolean;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if txt_GrossWeight.text &lt;&gt; null 
	or txt_Input3.text &lt;&gt; null 
	or cmb_Commodity.text &lt;&gt; null then
		return true;
	else
		return inheritMethod();
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e7c5b589-8d33-449f-9b6c-4fdb5310159c">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 14 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	commodity   : String;
	reserve 	: CM_ReserveDetail;
	bulkRel 	: CM_BulkRelease;
	bookingRefStock : CM_BookingRef;
begin
	inheritMethod();
	if myMainObject &lt;&gt; null and myMainObject.isKindOf(CM_TrackedItem) then
		self.myTrackedItem := myMainObject.CM_TrackedItem;
	else
		app.msgBox("Form incorrectly loaded, please inform developer.", "Error", MsgBox_OK_Only);
		unloadForm;
	endif;
	self.loadComboBoxCommodity(self.cmb_Commodity,null);
	reserve := self.myTrackedItem.allReserveDetailsReleased.first;
	if  reserve &lt;&gt; null then
		bulkRel :=reserve.myReserveHeader;
		if bulkRel &lt;&gt; null then
			if bulkRel.myBookingRefStock &lt;&gt; null then
				bookingRefStock := bulkRel.myBookingRefStock;
				commodity :=  bookingRefStock.commodity;
				if commodity &lt;&gt; null then
					self.cmb_Commodity.listIndex := self.cmb_Commodity.findObject(app.myRoot.allCommodities[commodity]);
				elseif bookingRefStock.allBookingRefItems.size &lt;&gt; 0 then
					// AER 03/07/2008 Par 17250
					// if no commodity on the Booking Ref then grab the first comodity form a Booking ref Item, --(Debby)
					commodity := bookingRefStock.allBookingRefItems.first.commodity;
					self.cmb_Commodity.listIndex := self.cmb_Commodity.findObject(app.myRoot.allCommodities[commodity]);
				endif;
			endif;
		endif;
	endif;
	self.txt_GrossWeight.dataType := txt_GrossWeight.DataType_Numeric;
	self.txt_GrossWeight.maxLength := 5;
	self.txt_GrossWeight.text := self.myTrackedItem.totalWeight.asStringWeightJMT;
	self.txt_Input3.setFocus;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dac50c79-8fa9-4f02-a207-f336d2dcaa30">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017620, locale);
	btn_ButtonLeft.translateCaption(Xlat_0013234, locale);
	btn_ButtonRight.translateCaption(Xlat_0013235, locale);
	lbl_Commodity.translateCaption(Xlat_0013236, locale);
	lbl_GrossWeight.translateCaption(Xlat_0013237, locale);
	lbl_Input3.translateCaption(Xlat_0013238, locale);
	lbl_Title.translateCaption(Xlat_0013239, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
