    <JadeMethod name="isFromVessel" id="758a1abc-3705-4274-ae71-196d54242707">
        <source>isFromVessel(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	return self.modeInt.isOneOf( LocnActMoveDir_VesselToYard, LocnActMoveDir_VesselToBarge, LocnActMoveDir_VesselToRail );

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
