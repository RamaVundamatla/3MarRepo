    <JadeMethod name="processStatusWorking" id="2e215fe3-f0e8-4f5c-beb6-83bd57d4e644">
        <source>processStatusWorking(_voyage : CM_Voyage; _confirmation : Boolean);
/*
Purpose:	Just been changed to 'working' status, this is a different status depending on the voyage process		

Date		Who		Reason
27 Mar 2023	navab1	TFS CR 57138 TASK 57310
07 Dec 2023	jlika1	TFS 61189 61441 RTL - Remove existing Queue Export Config
24 Jun 2024	jlika1	TFS 64737 CUX | Config for queuing LOLO on start of operations
04 Jul 2024		jlier1  TFS 65046
15 Aug 2024		jlier1 TFS 65578
*/

vars
	voyage 			: CM_Voyage;
	term 			: CM_Terminal;
	params 			: CMIF_AutoplanParams;
	tiset 			: CM_TISet;
	str				: String;
	workingStatus 	: Integer;
	cargo			: CM_TrackedItem;
	job				: CM_Job;
	wle				: CM_WorkListEntry;
	voyageJob		: CM_VoyageJob;
	moveController	: CMIF_MoveController;
begin
	workingStatus := self.myProcess.getWorkingStatus(); // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1


	if _voyage = null then
		return;
	endif;
	
	voyage := _voyage;
	
	if voyage.status &lt;&gt; workingStatus then
		return;
	endif;
	
	term := voyage.myTerminal;
	
	if term = null then
		return;
	endif;
	
	if voyage.hasGroundPlacedExpROROCont() then
		create tiset transient;
		create params transient;  // ### CUX BUG 57417 30MAR2023 NAVAB1
		
		params.moveMode := QUEUE_MODE;
		params.showWarningWhenNoPlan := true;
		voyage.getGroundPlacedExpROROConts(tiset);
		tiset.copy(params.allTrackedItems);
		app.myUtilityUA.utlUpdateAutoplanTrackedItems(params, app.myPassport);
	endif;
	
	if term.getConfig(ShipExchIfStatusLoading).Boolean then // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
		voyage.setShipExchangeDate(app.actualTimeAppServer); // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1	
	endif;
	
	/*if term.getConfig(QueuePlanExpLoloContVOPS).Boolean and not term.getConfig(AutoQueueReadyToLoad).Boolean then
		create moveController transient;
		moveController.setMoveMode(QUEUE_MODE);
			
		foreach job in voyage.allVoyageJobs  do
			voyageJob:=job.CM_VoyageJob;
			if voyageJob.isDischargeOrSOB then
				continue;
			endif;
			foreach wle in voyageJob.workListEntries where not wle.isCompleted do	
				if wle.myRequest = null or not wle.myRequest.isKindOf(CM_SlotRequest) then
					continue;
				endif;		
				if wle.myTrackedItem = null then
					continue;
				endif;
				if wle.getTargetLocation = null then
					continue;
				endif;
				if wle.isQueued then
					continue;
				endif;
				moveController.setMyTrackedItem(wle.myTrackedItem);
				moveController.setMyToPrimaryLocation(null);
				moveController.setMyToPrimaryLocation(wle.getTargetLocation);
				wle.doMoveToLocn(moveController, app.myPassport);
				if app.myPassport.hasErrors then
					return;
				endif;
			endforeach;
		
		endforeach;
		
	endif;*/
	//jlier1 TFS 65578 only cause event if no Errors or warnings or there are warnings but they are acknowledged
	if not app.myPassport.hasErrors and (app.myPassport.warningsAcknowledged or not app.myPassport.hasWarnings)  then
		voyage.causeEvent(term.getTerminalEvent(ROROExportAutoQueue), false, voyage);
	
	endif;
	
epilog
	delete tiset;
	delete params;
	delete moveController;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_confirmation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processVoyageWorkOrders" id="0e54d69b-1911-46f4-abba-bc0eb61f7318">
        <source>processVoyageWorkOrders(_voyage : CM_Voyage) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 June 2018		jlger1	Initial creation 39166
11 Oct 2021			jlier1 TFS 51963
31 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
*/

vars
	workOrderDtl : CM_WorkOrderDtl;
	workOrder : CM_WorkOrder;
	beforeAuditText, 
	afterAuditText: String;
	newStatus : Integer;
begin
	if _voyage = null then
		return;
	endif;

	if self.id.isOneOf(Voyage_Status_VoyReqRejected) then
		//find voyage request and set to not approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_NEWVOYAGE);
		if workOrderDtl &lt;&gt; null then
			newStatus:=WO_STATUS_NOTAPPROVED;		
		endif;
	elseif self.id.isOneOf(Voyage_Status_CargoReqPending) then
		// find voyage request work order set to approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_NEWVOYAGE);
		if workOrderDtl &lt;&gt; null  then
			newStatus:=WO_STATUS_APPROVED;
		endif;
	elseif self.id.isOneOf(Voyage_Status_CargoReqRejected) then
		// find voyage cargo request work order set to not approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
		if workOrderDtl &lt;&gt; null then
			newStatus:=WO_STATUS_NOTAPPROVED;
		endif;
	elseif self.isInitialMarineService then
		//find voyage cargo request and set to approved	
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
		if workOrderDtl &lt;&gt; null then
// TFS 41539			workOrderDtl.myParent.setTaskStatus(WO_STATUS_APPROVED);
		endif;
	elseif self.id.isOneOf(Voyage_Status_ApprovalRejected) then	
		//find voyage initial marine request and set to not approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
		if workOrderDtl &lt;&gt; null then
			newStatus:=WO_STATUS_NOTAPPROVED;
		endif;
	elseif self.id.isOneOf(Voyage_Status_VoyageApproved) then	
		//find voyage initial marine request and set to approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
		if workOrderDtl &lt;&gt; null  then
			newStatus:=WO_STATUS_APPROVED;
		endif;
	elseif self.id.isOneOf(Voyage_Status_DepServApproved) then		
		//find voyage depart marine request and set to approved
		workOrderDtl:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);
		if workOrderDtl &lt;&gt; null  then
			newStatus:=WO_STATUS_APPROVED;
		endif;
	
	//02 Aug 2018	NDL	TFS 39924
	elseif self.id.isOneOf(Voyage_Status_VoyCancelled) then
		foreach workOrder in _voyage.allWorkOrders do
			if workOrder.taskStatus = WO_STATUS_COMPLETE then
				continue;
			endif;
			beforeAuditText:=workOrder.getAuditText;
			workOrder.setTaskStatus(WO_STATUS_CANCELLED);
			afterAuditText:=workOrder.getAuditText();
			app.myAA.auditUpdateTrx(workOrder, beforeAuditText, afterAuditText);
		endforeach;
		return;
	
	// TFS 54298
	elseif self.id.isOneOf(Voyage_Status_EUP_Departed) then
		workOrderDtl:= _voyage.getWorkOrderForVoyageRequest;
		if workOrderDtl &lt;&gt; null and workOrderDtl.isKindOf(CM_WorkOrderVoyageDtl) then
			workOrderDtl.CM_WorkOrderVoyageDtl.setIsComplete();
		endif;
		
	endif;
	
	//epr TFS 43778 13/3/19 if work order has been Complete don't set it back to approved.
	if newStatus &lt;&gt; null and workOrderDtl &lt;&gt; null then
		workOrder:=workOrderDtl.myParent;
		if newStatus = WO_STATUS_APPROVED and workOrder.taskStatus = WO_STATUS_COMPLETE then
			return;
		endif;
		//epr TFS 43778 also added auditing
		beforeAuditText:=workOrder.getAuditText;
		workOrder.setTaskStatus(newStatus);
		afterAuditText:=workOrder.getAuditText();
		app.myAA.auditUpdateTrx(workOrder, beforeAuditText, afterAuditText);
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e2f67889-f03b-4bb7-a52f-415458cda3a6">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	pxyStatus : CM_VoyageStatus;
	pxyEmailTemplate : CM_EmailTemplate;
	completedOK : Boolean;

begin
	pxyStatus := inheritMethod();
	
	if self.myEmailTemplate &lt;&gt; null then
		pxyEmailTemplate := self.myEmailTemplate.pxyCreateUpdateProxy();
		pxyEmailTemplate.setMyParent(pxyStatus);
	endif;
	self.allEventsToCreate.copy(pxyStatus.allEventsToCreate);
	self.allHMSResourcesAllowed.copy(pxyStatus.allHMSResourcesAllowed);
	self.allHMSResourcesApproval.copy(pxyStatus.allHMSResourcesApproval);	//01 Aug 2018	NDL	TFS 39900
	pxyStatus.myProcess := self.myProcess;
	pxyStatus.myRoot := self.myRoot;
	
	completedOK := true;
	return pxyStatus;

epilog
	if not completedOK then
		delete pxyStatus;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="runStatusReportFor" id="8c9abe1b-601d-4031-9f6c-125c135b1351">
        <source>runStatusReportFor( _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38905

*/

vars

	filterObject : CMQF_HMSVoyages;
	jrwTransient : CM_JRWVoyages;
	jrwReport : JadeReportWriterReport;
	jrwManager : JadeReportWriterManager;
	jadeReport : JadeReport;

begin

	if _voyage = null or _voyage.getMyTerminal = null then
		return;
	endif;
	if self.reportToRun.trimBlanks = null then
		return;
	endif;
	
	create jrwManager transient;
	create jadeReport transient;
	create filterObject transient;
	filterObject.allTerminals.add( _voyage.getMyTerminal );
	filterObject.setMyVoyage( _voyage );
	
	app.myQAFilter.qryHMSVoyages(filterObject, app.myPassport);
	
	jrwTransient := app.myQAFilter.allJRWTransients.first.CM_JRWVoyages;
	
	app.printer.printPreview := true;
	
	jrwReport := jrwManager.getReport( self.reportToRun );
	
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Design not found:' &amp; self.reportToRun);
		return;
	endif;
	
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();

epilog

	delete filterObject;
	delete jrwManager;
	delete jadeReport;
	abortTransaction;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
