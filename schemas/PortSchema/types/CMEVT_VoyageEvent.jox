    <JadeMethod name="setDetailsFromCMIF" id="1c8d026a-87ac-4d11-bd95-a54502b489df">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_VoyageEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	eventTransaction		: CM_EventTransaction;
	resourceUsages			: CM_ResourceTypeUsageSet; 
	wod						: CM_WorkOrderToDoDtl;
begin
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Prepopulate this
	self.type := _cmifEventTrx.type;
	
	self.setMyBol(_cmifEventTrx.myBOL);	
	self.setMyVoyage(_cmifEventTrx.myVoyage);
	
	if _cmifEventTrx.allResourceUsages.isNotEmpty() then
		create resourceUsages transient;
		_cmifEventTrx.allResourceUsages.copy(resourceUsages);
		
		self.addResourcesFromProxys(resourceUsages);
	endif;

	self.setToDoTask(_cmifEventTrx.myToDoTask);
	
	wod := _cmifEventTrx.myWorkOrderDetail;
	
	if wod = null then
		wod := self.getWorkOrderDetail().CM_WorkOrderToDoDtl;
	endif;
	
	if wod &lt;&gt; null then
		self.setFromWOD(wod);
	endif;
	
	self.setGeneralLandingDate(_cmifEventTrx.prevGenLandingDate, _cmifEventTrx.generalLandingDate);
	self.setAmount(_cmifEventTrx.amount);
	
	inheritMethod(_eventType, _cmifEventTrx);
epilog
	delete resourceUsages;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_VoyageEventCtrl"/>
    </JadeMethod>
    <JadeMethod name="setEndDataTime" id="ccd45ca1-0bb0-459a-b032-4bdbe651ef14">
