    <JadeMethod name="delete" id="f6eec772-e217-4681-b0c3-b8982bd9b70a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	self.allStopTableIds.purge();	//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findReleaseImportTI" id="50e3ccae-83f2-43cf-9d4f-5f8d03ec73d3">
        <source>findReleaseImportTI() : CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwkao1	Initial creation

*/

vars	
	ti : CM_TrackedItem;
begin
	ti := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.lookupTIUsingIdCargoType(self.idTextBox.toUpper(), self.cargoType);
	if ti &lt;&gt; null and ti.isOnSite() then
		return ti;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="stops" id="30d13eb7-2530-45ef-bab5-ddff9036e212">
        <methodInvocation>mapping</methodInvocation>
        <source>stops(set : Boolean; _value : String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2008	cnwdz2	Initial creation

*/
vars
	stopTableIdsArray	: StringArray;
	stopTableId			: String;
begin
	if set then
		create stopTableIdsArray transient;
		_value.getTokensForDelimiter("|", stopTableIdsArray);
		foreach stopTableId in stopTableIdsArray do
			if not self.allStopTableIds.includes(stopTableId.Integer) then
				self.allStopTableIds.add(stopTableId.Integer);				
			endif;
		endforeach;	
	endif;	
epilog
	delete stopTableIdsArray;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
