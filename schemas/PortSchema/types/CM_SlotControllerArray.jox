<CollClass name="CM_SlotControllerArray" id="c0224228-1fef-4143-ba05-73bafdb459e8">
    <memberType name="CM_SlotController"/>
    <superclass name="CM_ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="slotctrl"/>
    <JadeMethod name="getHeightOfSlots" id="7b3880c9-dfd3-4d46-a934-0be39ec2fec1">
        <source>getHeightOfSlots(_currentSlot : CM_SlotController; _countExistingOnes : Boolean):Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwas3	Initial creation

*/

vars
	slot : CM_SlotController;
	height : Real;
begin
	if _countExistingOnes then			//when switching the hi-cube pen for the selected cells in the colour coding screen 
		foreach slot in self where (slot.ordinalCell = _currentSlot.ordinalCell and slot.ordinalDeck = _currentSlot.ordinalDeck) do  ///only the cells from underneath the current one, on the same cell-column and deck
			
			if slot.mySlotRequestLoad = null then
				height := height + HEIGHT_FULL_HIGH_CUBE;
			else
				if slot.mySlotRequestLoad.getAttrHiCubed() then
					height := height + HEIGHT_FULL_NORMAL - HEIGHT_FULL_HIGH_CUBE;
				else
					height := height + HEIGHT_FULL_HIGH_CUBE - HEIGHT_FULL_NORMAL;
				endif;
			endif;
		endforeach;
	else								//asigning a colour code to selected cells
		foreach slot in self where (slot.ordinalCell = _currentSlot.ordinalCell and slot.ordinalDeck = _currentSlot.ordinalDeck) do
			if slot.mySlotRequestLoad = null then 
				height := height + HEIGHT_FULL_NORMAL;
			endif;		
		endforeach;
	endif;
	return height;
epilog

end;</source>
        <Parameter name="_currentSlot" type="CM_SlotController"/>
        <Parameter name="_countExistingOnes" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</CollClass>
