    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="671aa68d-cbc7-4a57-a2e7-9aa0964cab05">
        <updating/>
        <source>repositionAfterResize() updating;

vars
	newLeft		: Real;
	newTop		: Real;
	newWidth	: Real;
	newHeight	: Real;
   	parentWidth,
   	parentHeight	: Real;
	
begin

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	newLeft		:=	self.left;
	newTop		:=	self.top;
	newWidth	:=	self.width;
	newHeight	:=	self.height;

	if self.lockRight then
		newLeft	:=	(parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	
	if self.lockBottom then
		newTop	:=	(parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	
	if self.stretchWidth then
		newWidth	:=	(parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	
	if self.stretchHeight then
		newHeight	:=	(parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;
	
	if newLeft &lt;&gt; self.left
	or newTop &lt;&gt; self.top
	or newWidth &lt;&gt; self.width
	or newHeight &lt;&gt; self.height
	then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.cnEcResizeContents();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeChildren" id="96b70ada-41a3-4adc-9903-3d1b33816424">
        <source>resizeChildren(pParent : Window) protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Resizes the receiver's child controls, typically after the
//				receiver itself has been resized.
//
// Parameters:  pParent - The receiver's parent window.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	controlIndex	: Integer;
	theControl		: Control;
	
begin
	foreach controlIndex in 1 to self.form.controlCount() do
		theControl	:=	self.form.controls(controlIndex);
		
		if theControl.parent = pParent then
//			theControl.cnEcResizeContents();
//			theControl.repositionAfterResize();
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pParent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="resizeChildrenAndSplitter" id="9a8b9f60-d012-4663-93fa-4d8c914df81c">
        <updating/>
        <source>resizeChildrenAndSplitter() updating, protected;
//Purpose:		Positions and sizes the left and right controls, and the vertical splitter
//				on the control
//
//14 Nov 00	cnwrs2	Add code to set seperation to 0 if splitter is not visible.
//Oct 02 cnwrs2 - Changes to cater for splitType
vars
	separation	: Integer;
	leftSize	: Real;
	rightSize	: Real;
	
begin

	self.resizeSplitterGetNewSizes(leftSize, rightSize, separation);

	if self.isSplitHorizontal then
	 	// Handle horizontal split

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, self.clientWidth, leftSize);
			self.myLeftControl.cnEcResizeContents();

			// removed special treatment of a Frame - not sure why this is done (rjs 4Jul03) - also below
			//if self.myLeftControl.isKindOf(Frame) then
			//	self.resizeChildren(self.myLeftControl);
			//endif;
		endif;

		if self.myRightControl &lt;&gt; null then
			self.myRightControl.move(0, leftSize + separation, self.clientWidth, rightSize);
			self.myRightControl.cnEcResizeContents();
			
			//if self.myRightControl.isKindOf(Frame) then
			//	self.resizeChildren(self.myRightControl);
			//endif;
		endif;

		if self.myHorizontalSplitter &lt;&gt; null then
			self.myHorizontalSplitter.move(0, leftSize, self.clientWidth, self.myHorizontalSplitter.height);
			self.myHorizontalSplitter.zOrder(1);
		endif;
	else
		// Handle vertical split

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, leftSize, self.clientHeight);
			self.myLeftControl.cnEcResizeContents();

			//if self.myLeftControl.isKindOf(Frame) then
			//	self.resizeChildren(self.myLeftControl);
			//endif;
		endif;

		if self.myRightControl &lt;&gt; null then
			self.myRightControl.move(	leftSize + separation,
										0,
										rightSize,
										self.clientHeight);

			self.myRightControl.cnEcResizeContents();
			
			//if self.myRightControl.isKindOf(Frame) then
			//	self.resizeChildren(self.myRightControl);
			//endif;
		endif;

		if self.myVerticalSplitter &lt;&gt; null then
			self.myVerticalSplitter.move(leftSize, 0, self.myVerticalSplitter.width, self.clientHeight);
			self.myVerticalSplitter.zOrder(1);
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeChildrenAndSplitterOLD" id="59b9b2c3-99e1-43aa-b9b8-23fdafabf532">
        <updating/>
        <source>resizeChildrenAndSplitterOLD(_fromResize : Boolean) updating, protected;
//Purpose:		Positions and sizes the left and right controls, and the vertical splitter
//				on the control
//
//14 Nov 00	cnwrs2	Add code to set seperation to 0 if splitter is not visible.
//Oct 02 cnwrs2 - old method kept in case need to refer to after change to add splitType.
vars
	ratio		: Decimal[4,2];
	separation	: Integer;

begin

	ratio	:=	self.leftToRightRatio / 100;

	if self.isSplitHorizontal then
	 	// Handle horizontal split

		if self.myHorizontalSplitter = null or (not self.myHorizontalSplitter.visible) then
			separation	:=	0;
		else
			separation	:=	self.myHorizontalSplitter.height.Integer;
		endif;

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, self.clientWidth, (self.clientHeight * ratio) - (separation div 2));
			self.myLeftControl.cnEcResizeContents();
			
			if self.myLeftControl.isKindOf(Frame) then
				self.resizeChildren(self.myLeftControl);
			endif;
		endif;

		if (self.myRightControl &lt;&gt; null) and (self.myLeftControl &lt;&gt; null) then
			self.myRightControl.move(self.myLeftControl.left, self.myLeftControl.height + separation, self.myLeftControl.width, self.clientHeight - self.myLeftControl.height - separation);
			self.myRightControl.cnEcResizeContents();
			
			if self.myRightControl.isKindOf(Frame) then
				self.resizeChildren(self.myRightControl);
			endif;
		endif;

		if (self.myHorizontalSplitter &lt;&gt; null) and (self.myLeftControl &lt;&gt; null) then
			self.myHorizontalSplitter.move(self.myLeftControl.left, self.myLeftControl.top + self.myLeftControl.height, self.myLeftControl.width, self.myHorizontalSplitter.height);
			self.myHorizontalSplitter.zOrder(1);
		endif;

	else
		// Handle vertical split

		if self.myVerticalSplitter = null or (not self.myVerticalSplitter.visible) then
			separation	:=	0;
		else
			separation	:=	self.myVerticalSplitter.width.Integer;
		endif;

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, (self.clientWidth * ratio) - (separation div 2), self.clientHeight);
			self.myLeftControl.cnEcResizeContents();
			
			if self.myLeftControl.isKindOf(Frame) then
				self.resizeChildren(self.myLeftControl);
			endif;
		endif;

		if (self.myRightControl &lt;&gt; null) and (self.myLeftControl &lt;&gt; null) then
			self.myRightControl.move(self.myLeftControl.width + separation, self.myLeftControl.top, self.clientWidth - self.myLeftControl.width - separation, self.myLeftControl.height);
			self.myRightControl.cnEcResizeContents();
			
			if self.myRightControl.isKindOf(Frame) then
				self.resizeChildren(self.myRightControl);
			endif;
		endif;

		if (self.myVerticalSplitter &lt;&gt; null) and (self.myLeftControl &lt;&gt; null) then
			self.myVerticalSplitter.move(self.myLeftControl.left + self.myLeftControl.width, self.myLeftControl.top, self.myVerticalSplitter.width, self.myLeftControl.height.min(self.myRightControl.height));
			self.myVerticalSplitter.zOrder(1);
		endif;

	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_fromResize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resizeSplitterGetNewSizes" id="3356ded7-2c66-4319-a6da-d8befa731695">
        <updating/>
        <source>resizeSplitterGetNewSizes(pLeftSize: Real output;
						pRightSize : Real output;
						pSeparation : Integer output) updating, protected;
//Purpose:		Positions and sizes the left and right controls, and the vertical splitter
//				on the control
//
constants
	MIN_SIZE	: Integer = 20;
	
vars
	ratio				: Decimal[4,2];
	leftControlSize		: Real;
	rightControlSize	: Real;
	clientSize			: Real;

begin

	ratio	:=	self.leftToRightRatio / 100;

	if self.isSplitHorizontal then
	 	// Handle horizontal split

		if self.myHorizontalSplitter = null or (not self.myHorizontalSplitter.visible) then
			pSeparation	:=	0;
		else
			pSeparation	:= self.myHorizontalSplitter.height.Integer;
		endif;
		
		clientSize := self.clientHeight;
		
//		if self.myLeftControl &lt;&gt; null then
		if self.myLeftControl &lt;&gt; null and
		   self.myLeftControl.visible then
			leftControlSize		:= self.myLeftControl.height;
		else
			// possibly need to do some calculations here
			leftControlSize		:= 0;
		endif;

//		if self.myRightControl &lt;&gt; null then
		if self.myRightControl &lt;&gt; null and
		   self.myRightControl.visible then
			rightControlSize	:= self.myRightControl.height;
		else
			rightControlSize	:= 0;
		endif;
	else
		if self.myVerticalSplitter = null or (not self.myVerticalSplitter.visible) then
			pSeparation	:=	0;
		else
			pSeparation	:=	self.myVerticalSplitter.width.Integer;
		endif;

		clientSize := self.clientWidth;

//		if self.myLeftControl &lt;&gt; null then
		if self.myLeftControl &lt;&gt; null and
		   self.myLeftControl.visible then
			leftControlSize		:= self.myLeftControl.width;
		else
			// possibly need to do some calculations here
			leftControlSize		:= 0;
		endif;

//		if self.myRightControl &lt;&gt; null then
		if self.myRightControl &lt;&gt; null and
		   self.myRightControl.visible then
			rightControlSize	:= self.myRightControl.width;
		else
			rightControlSize	:= 0;
		endif;
	endif;

	// Calculate new sizes for left and right controls;
	
	if (not self.useRatio) and self.splitType = self.SPLITTYPE_LOCKLEFT then
		if self.pinnedPosition &lt;&gt; 0 and rightControlSize &gt; 0 then
			// Always attempt to reset control to pinned size
			leftControlSize		:=	self.pinnedPosition;
			self.pinnedPosition	:=	0;
		endif;
		
		if leftControlSize + MIN_SIZE &gt; clientSize and
		   rightControlSize &gt; 0 then
			if self.pinnedPosition = 0 then
				self.pinnedPosition	:=	leftControlSize;
			endif;
			pLeftSize	:=	(clientSize - MIN_SIZE) - (pSeparation div 2);
		elseif rightControlSize = 0 then
			pLeftSize	:=	clientSize - pSeparation;
		else
			pLeftSize	:=	leftControlSize;
		endif;
		
		pRightSize	:=	clientSize - pLeftSize - pSeparation;

	elseif (not self.useRatio) and self.splitType = self.SPLITTYPE_LOCKRIGHT then
		if self.pinnedPosition &lt;&gt; 0 and leftControlSize &gt; 0 then
			// Always attempt to reset control to pinned size
			rightControlSize	:=	self.pinnedPosition;
			self.pinnedPosition	:=	0;
		endif;
		
		if rightControlSize + MIN_SIZE &gt; clientSize and
		   leftControlSize &gt; 0 then
			if self.pinnedPosition = 0 then
				self.pinnedPosition := rightControlSize;
			endif;
			
			pRightSize	:=	(clientSize - MIN_SIZE) - (pSeparation div 2);
		elseif leftControlSize = 0 then
			pRightSize	:=	clientSize - pSeparation;
		else
			pRightSize	:=	rightControlSize;
		endif;
		
		pLeftSize	:=	clientSize - pRightSize - pSeparation;
	else
		pLeftSize	:=	(clientSize * ratio) - (pSeparation div 2);
		pRightSize	:=	clientSize - pLeftSize - pSeparation;
	endif;
	
	self.useRatio := false;

end;</source>
        <access>protected</access>
        <Parameter name="pLeftSize" type="Real" usage="output"/>
        <Parameter name="pRightSize" type="Real" usage="output"/>
        <Parameter name="pSeparation" type="Integer" usage="output"/>
    </JadeMethod>
