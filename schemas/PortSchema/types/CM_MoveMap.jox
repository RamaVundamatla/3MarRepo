end;</source>
        <Parameter name="_theProxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMovePlan" id="42a08306-9174-491e-940c-4acc19e817f4">
        <updating/>
        <source>setMovePlan(source : String input; target : String input; attribPlans : CM_AttributePlansArray input) updating;
//Takes the values required to create a move plan, also creates one if 
//required to do so.

vars
	movePlan: CM_MovePlan;
begin
	movePlan := self.movePlans[source, target];
	if movePlan = null then
		self.createMovePlan(source, target, movePlan);
	endif;
	movePlan.setAttributePlans(attribPlans);
end;</source>
        <Parameter name="source" type="String" usage="input"/>
        <Parameter name="target" type="String" usage="input"/>
        <Parameter name="attribPlans" type="CM_AttributePlansArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b44441a7-ba49-4bea-9b39-5fbe97ba5fe1">
        <updating/>
        <source>setProxy(_id, _clonedFromId, _remarks : String; _myTerminal : CM_Terminal ) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id 			:= _id;
	self.clonedFromId 	:= _clonedFromId;
	self.remarks 		:= _remarks.trimBlanks;
	self.terminal 		:= _myTerminal;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_clonedFromId" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="dcfaaf7d-0fc4-4293-b462-797771275421">
        <source>shouldAuditProperty(_rootClass : Class; _property : Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     03 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _property.name = CM_MoveMap::allAttributePlans.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
