    <JadeMethod name="selectBlockOfObjectsFromXYs" id="8a67dc97-724f-451f-9b7f-4b31ca5a3ce7">
        <updating/>
        <source>selectBlockOfObjectsFromXYs( _class : Class; _x1,_y1,_x2,_y2 : Integer) updating;
/*
Purpose:			 // PAR 32308
Date				Who			Reason
SEPTEMBER 2013		CNWAB1		Initial creation
*/

vars

	objs : ObjectArray ;
	startObj, anObj : Object;
	selectTI : Boolean;
	cdc : SelfType;
	realX1,realX2,realY1,realY2 : Integer;
	frmX1,frmX2,frmY1,frmY2 : Integer;
	objX1,objX2,objY1,objY2 : Integer;

	tmpFrame : CMUI_BlockAreaDrawingFrame;
begin
	create objs transient;

	cdc := self;

	realX1 := _x1;
	realY1 := _y1;
	realX2 := _x2;
	realY2 := _y2;

	if _x1 &gt; _x2 then
		realX1 := _x2;
		realX2 := _x1;
	endif;
	
	if _y1 &gt; _y2 then
		realY1 := _y2;
		realY2 := _y1;
	endif;
	
	tmpFrame := self.myDrawingFrame;
	
	objs.clear;
	self.allDrawnObjects.findObjectsInDict(realX1,realY1,realX2,realY2, objs, _class,true,false);
	foreach anObj in objs do
		self.selectObject(anObj,tmpFrame,true);	
	endforeach;
epilog
	delete objs;


end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectCell" id="f3a460da-0157-48af-a813-e0033d21ebdf">
        <source>selectCell(cell: Point) protected;
// Select the cell
begin
	self.getCell(cell.x, cell.y).setIsSelected(true);
	self.drawCell(cell.x, cell.y);
end;
</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
    </JadeMethod>
