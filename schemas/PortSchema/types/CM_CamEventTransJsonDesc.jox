    <JadeMethod name="outputFile" id="0fe38c2c-02fc-441f-9cce-f4b19931643c">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj: Object; _transactions: CM_TITransactionSet) updating;
/*

Purpose:			Save all of our generated JSON strings to the CAMS Task history

Parameters:			

Return Value:		

Date			Who		Reason
27 Jan 2023		navra1	Initial creation for TFS - 55859
18 Mar 2023		navmd1	TFS 57092 Refactor and move sending of JSON message to sendAction phase of CAMS
03 Jul 2023		navcs2	Bug 58947: FR | 54536 - 1035 UHE logs Occurring processing Damage CAMs Message + Refactor
25 Sep 2023		navdap1	TFS 60365 EUP | FR 53853 - Goods Receipt Message Grouping
							Changed _contextObj from CM_Object to Object
18 Dec 2024 	navhn30 Bug MTN-12511: MTN - Reverse Changes made for 61182 for handling large JSON messages
*/
vars
	camVoyage 		: CM_CamVoyage;
	camMessage 		: CM_CamMessage;
	str,
	delim,
	msg,
	rawData			: String;
	
begin	
	delim := CM_CamProtocol.JSON_Output_Delimeter.unicodeToString;
	
	if _camFile.camVoyages.size &gt; 0 then			
		foreach camVoyage in _camFile.camVoyages do
			app.writeLog(method.qualifiedName &amp; " cam messages: " &amp; camVoyage.camMessages.size.String, LogTRACE);
			foreach camMessage in camVoyage.camMessages do
				app.writeLog(method.qualifiedName &amp; " group3 messages: " &amp; camMessage.group3.size.String, LogTRACE);
				msg := null;
				foreach str in camMessage.group3 do
					// Combine any split messages
					if str.startsWith(delim) then
						rawData &amp;= str[delim.length+1:end];			// 18.12.24		navhn30		 MTN-12511
						continue;
					else
						msg := str;									// 18.12.24 	navhn30 	 MTN-12511
					endif;
					
					_camFile.incrementMessageCount();
					
					if rawData = null then
						rawData := msg;
					else
						rawData &amp;= Cr &amp; msg;
					endif;
					
					//msg := null;									// 18.12.24 	navhn30 	 MTN-12511
				endforeach;
				// If the last message line starts with a delim, then make sure we actually add the message!
				if msg &lt;&gt; null then
					if rawData = null then
						_camFile.incrementMessageCount();
					endif;
					//rawData &amp;= msg;		// 18.12.24 	navhn30 	 MTN-12511
				endif;
			endforeach;
		endforeach;		
	endif;		
	
	app.writeLog(method.qualifiedName &amp; " _camTaskHistory = " &amp; _camTaskHistory.getOidAsString &amp;  " raw data string:" &amp; CrLf &amp; rawData, LogTRACE);
	
	//write the messages to the history		
	_camTaskHistory.setRawDataString(rawData);
	
epilog	
	
end;</source>
