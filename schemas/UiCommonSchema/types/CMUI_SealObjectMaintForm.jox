    <JadeMethod name="setupForm" id="7d2a8633-d259-4723-9cfa-2e32496f2b02">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	self.width := 430;
	self.height := 402;
	self.minimumWidth := 430;
	self.minimumHeight := 402;
	
	self.grpMain.top := 1;
	self.grpMain.left := 1;
	
	self.tblValues.inputType := Table.InputType_TextBox;
	self.tblValues.userInputEnabled := true;
	
	self.setForMultiSealValues( false );	//30 Jul 2015	NDL	Par 36658
	
	inheritMethod();
	
	populateForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblSeals_click" id="4fee2fb8-4d72-4f1e-9a6b-f4ba05cc8278">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSeals_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;

begin

	rowIndex := self.tblSeals.row;
	
	if rowIndex &lt;= self.tblSeals.fixedRows
	or rowIndex &gt; self.tblSeals.rows
	then
		rowIndex := 0;
	endif;

	self.selectItem( rowIndex );

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0b061266-942e-44ae-a688-f967ffb8d752">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020277, locale);
	btnClose.translateCaption(Xlat_0020278, locale);
	btnSave.translateCaption(Xlat_0020279, locale);
	btnSaveAndClose.translateCaption(Xlat_0020280, locale);
	lblAction.translateCaption(Xlat_0020281, locale);
	lblDateTime.translateCaption(Xlat_0020282, locale);
	lblMainObj.translateCaption(Xlat_0020283, locale);
	lblPrevValue.translateCaption(Xlat_0020315, locale);
	lblSealType.translateCaption(Xlat_0020284, locale);
	lblSealValues.translateCaption(Xlat_0020285, locale);
	txtPrevValue.translateBubbleHelp(Xlat_0020316, locale);
	txtValues.translateBubbleHelp(Xlat_0020286, locale);
end;</source>
    </JadeMethod>
</GUIClass>
