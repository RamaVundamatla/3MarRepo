    <JadeMethod name="eraseForVoyage" id="325a1811-dfdc-471e-b319-afe33009f612">
        <updating/>
        <source>eraseForVoyage(eraseLevel: Integer) updating;
// -------------------------------------------
// Created 14 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	// because these do NOT have a myTrackedItem reference (as the no-number log
	// that they are associated with has already been deleted when it is
	// swapped)
	self.erase(eraseLevel);
end;</source>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="e1d127cf-f6c8-46a4-bceb-9311802267fe">
        <source>getDisplayString(): String;
//--------------------------------------------------------------
//Created: 25 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return 'With ticket ' &amp; self.getOtherTrackedItem().id;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="2f0b36b9-48f9-4e79-9da9-64e2f46e40a4">
        <source>getOtherTrackedItem(): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	mar 2006	cnwrs1		can be expected to be invalid 
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	otherTrackedItem : CM_TrackedItem;
begin
	otherTrackedItem := self.myOtherTrackedItem;
	if otherTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, otherTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := otherTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return otherTrackedItem;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setResidualLogDetails" id="fd50e2e7-5ed9-48c2-9306-06a61ce3597d">
        <updating/>
        <source>setResidualLogDetails(_log : CM_Log) updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myOtherTrackedItem := _log;
	
	self.otherTrackedItemId			:= _log.id;
	self.otherTrackedItemSEDMean	:= _log.sedMean;
	self.otherTrackedItemVolume		:= _log.getMyTotalVolume;
	//self.otherTrackedItemWeight		:= _log.weight;					//-cnwml2 MSL CCMS 1017
	self.otherTrackedItemWeight		:= _log.totalWeight;				//+cnwml2 MSL CCMS 1017

end;</source>
        <Parameter name="_log" type="CM_Log"/>
    </JadeMethod>
</Class>
