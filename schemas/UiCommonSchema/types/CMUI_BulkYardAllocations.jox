    <JadeMethod name="translateForm" id="fae4bea7-7a53-4b36-9bc8-2857db2177f8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2025 10:26:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027113, locale);
	btnAdd.translateCaption(Xlat_0027114, locale);
	btnAddAll.translateCaption(Xlat_0027115, locale);
	btnCalculate.translateCaption(Xlat_0027116, locale);
	btnClose.translateCaption(Xlat_0027117, locale);
	btnConfigure.translateCaption(Xlat_0027118, locale);
	btnCreate.translateCaption(Xlat_0027119, locale);
	btnRemove.translateCaption(Xlat_0027120, locale);
	btnRemoveAll.translateCaption(Xlat_0027121, locale);
	lblBGPProgress.translateCaption(Xlat_0027122, locale);
	lblMatches.translateCaption(Xlat_0027123, locale);
	lblProposed.translateCaption(Xlat_0027124, locale);
	lblSelectedCargo.translateCaption(Xlat_0027125, locale);
	lblVoyage.translateCaption(Xlat_0027126, locale);
	lblVoyageDetails.translateCaption(Xlat_0027127, locale);
	mnuRemoveSelected.translateCaption(Xlat_0027128, locale);
	mnuSelectedContext.translateCaption(Xlat_0027129, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="93fba65a-3b26-4d51-82f7-a28d89bed3d0">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	if self.myBulkYACandidateResults &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkYACandidateResult(self.myBulkYACandidateResults, app.myPassport);
	endif;
	self.endNotificationForSubscriber(self);
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="4f7ef994-76a2-4a51-8a5a-ea0c90fcdf03">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars

begin
	if self.myBulkYACandidateResults &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkYACandidateResult(self.myBulkYACandidateResults, app.myPassport);
	endif;
	self.endNotificationForSubscriber(self);
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ea739a59-a4a6-445f-a86c-a422cfcd664c">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	event : Integer;
	terminal : CM_Terminal;
	progress : Integer;

begin
	terminal := self.myTerminal;
	
	event := terminal.getEventFromTerminalEvent(eventType);
	
	if event = Event_BulkYAProgress then
		progress := userInfo.Integer * 100;
		self.lblBGPProgress.caption := app.getErrorString1(Background_process_progress, progress.String);
		
	elseif event = Event_BulkYAFailed then
		self.lblBGPProgress.caption := app.getErrorString(Background_process_failed);
		
	elseif event = Event_BulkYAComplete then
		self.myBulkYACandidateResults := userInfo.CM_BulkYACandidateResults;
		self.lblBGPProgress.caption := app.getErrorString(Background_process_complete);
		self.displayResults();
		
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
