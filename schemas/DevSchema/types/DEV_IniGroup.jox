<Class name="DEV_IniGroup" id="898f1598-cf1a-4b55-9eca-10de60b205d4">
    <superclass name="DEV_IniObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allIniItems" id="66f191ee-e356-4108-8a4a-3cc3b598f1c4">
        <updateMode>automatic</updateMode>
        <type name="DEV_IniObjectDict"/>
        <access>readonly</access>
        <Inverse name="DEV_IniItem::myIniGroup"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myIniFile" id="d61c4334-85a0-4d18-9885-95926532a1d3">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_IniFile"/>
        <access>readonly</access>
