    <JadeMethod name="cancelWSInterruptTimer" id="054ccfa9-a70a-448f-9b54-f27098f09711">
        <source>cancelWSInterruptTimer(_userInfo: Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

vars
	proc		: Process;
	tracker		: CMIF_WSTrackingObj;
	message		: String;
	option,
	remaining	: Integer;
begin
	if _userInfo = null or not _userInfo.isKindOf(Process) then
		return;
	endif;

	proc := _userInfo.Process;
	tracker := self.allWSTrackingObjects[proc];
	
	// This shouldn't happen... but you never know
	if tracker = null then
		return;
	endif;

	// Check timer status ... do we even have one ?
	if not tracker.getTimerStatus(CMIF_WSTrackingObj.Timer_Interrupt_Event, option, remaining) then
			app.writeLog(method.qualifiedName &amp; " Timer not active - ignoring cancellation request", LogTRACE);
		return;
	endif;
	
	message := method.qualifiedName &amp; " " &amp; getOidStringForObject(tracker) &amp; " Cancelling Interrupt Timer (" &amp; CMIF_WSTrackingObj.Timer_Interrupt_Event.String &amp; ")" &amp;
				" for " &amp; proc.String &amp; " " &amp; proc.userInfo;

	app.writeLog(message, LogDEBUG);
	
	tracker.endTimer(CMIF_WSTrackingObj.Timer_Interrupt_Event);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="create" id="29f0b528-3a0f-4528-a45a-710977d363db">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Mar 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
07 Apr 2021 navmd1	TFS 42010 MTN - Early Termination of web services

*/

vars

begin
	self.beginNotification(self, self.Terminate_Application_Note, Response_Cancel, null);
	self.beginNotification(self, self.WS_Start_Interrupt_Note, Response_Continuous, null);
	self.beginNotification(self, self.WS_Start_Long_Interrupt_Note, Response_Continuous, null);
	self.beginNotification(self, self.WS_Cancel_Interrupt_Note, Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="52129430-c381-49d4-b91d-2f9ecce765f2">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2021	navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

vars

begin
	self.endNotification(self, self.WS_Start_Interrupt_Note);
	self.endNotification(self, self.WS_Start_Long_Interrupt_Note);
	self.endNotification(self, self.WS_Cancel_Interrupt_Note);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFileCleanup" id="199d89db-25d3-4ba8-898f-0597bb0897f0">
        <source>doFileCleanup() protected;

/*

Purpose:			Clean up any temporary files in the download directory that are
					older than the specified number of minutes

Parameters:			None

Return Value:		None


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	fileFolder		: FileFolder;
	file			: FileNode;
	timeout,
	filesChecked,
	filesDeleted,
	fileErrors		: Integer;
	earliestCreate	: TimeStamp;
	msg				: String;
	
begin
	timeout := app.downloadFileTimeout;
	earliestCreate := app.actualTimeServer.cnEcAddMinutes(-1 * timeout);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	app.writeLog("Deleting files created before " &amp; earliestCreate.asStringJMT, LogINFO);	
	
	create fileFolder transient;
	fileFolder.fileName := app.downloadFileDirectoryPath;
	fileFolder.mask := WebService_ReportAgent.OUTPUT_FILE_PREFIX &amp; "*.*";
	
	foreach file in fileFolder.files do
		if file.isKindOf(File) then
			filesChecked := filesChecked + 1;
			if file.isAvailable() and file.createdTime &lt; earliestCreate then
				// Delete this file
				app.writeLog("Deleting file " &amp; file.fileName, LogINFO);
				if app.removeFile(file.fileName, false) then
					filesDeleted := filesDeleted + 1;
				else
					fileErrors := fileErrors + 1;
				endif;
			endif;
		endif;
	endforeach;	
	
	// Log completion message
	msg := "Delete files complete, " &amp; 
			filesChecked.String &amp; " files checked, " &amp;
			filesDeleted.String &amp; " files deleted";
			
	if fileErrors &gt; 0 then
		msg := msg &amp; ", " &amp; fileErrors.String &amp; " not deleted due to errors";
	endif;
	
	app.writeLog(msg, LogINFO);	
	
	
epilog
	delete fileFolder;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRestAuthTokenDelete" id="ff2f297d-3640-486d-bef1-b9eb43be31a7">
        <source>doRestAuthTokenDelete() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/04/2021	navdap1		Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
//
vars
	authToken : CM_RestAuthToken;
	tokensByCreateTime : DynaDictionary;
	iter : Iterator;
	aWeekOld : TimeStamp;
	tokensToDelete : ObjectArray;
	tokenCount : Integer;

begin
	create tokensToDelete transient;
	create tokensByCreateTime transient;
	tokensByCreateTime.setMembership(CM_RestAuthToken);
	tokensByCreateTime.addMemberKey(CM_RestAuthToken::createdTime.name, false, false);
	tokensByCreateTime.endKeys(true);
	aWeekOld := app.actualTimeServer.addDays(-7);
	
	app.writeLog("Deleting Auth tokens created before " &amp; aWeekOld.asStringJMT, LogINFO);	
	
	app.myRoot.allRestAuthTokensByGuid.copy(tokensByCreateTime);
	iter := tokensByCreateTime.createIterator;
	while iter.next(authToken) do
		if authToken.creationTime &gt; aWeekOld then
			break;
		endif;
		
		tokensToDelete.add(authToken);
	endwhile;
	tokenCount := tokensToDelete.size;
	
	app.myTrxDA.trxDeleteRestAuthTokens(tokensToDelete, app.myPassport);
	
	app.writeLog("Finished deleting " &amp; tokenCount.String &amp; " Auth Tokens", LogINFO);
	if app.myPassport.hasErrors then
		app.writeLog("Deletion process had errors: " &amp; app.myPassport.getErrorsAsString, LogERROR);
	endif;
	
epilog
	delete iter;
	delete tokensToDelete;
	delete tokensByCreateTime;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jadeHTTPMessageTimeout" id="01764298-4dea-4ae7-b51f-c36a073ab54f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>jadeHTTPMessageTimeout(_set : Boolean; _value : Integer io) mapping, updating;
/*

Purpose:			Only read the jadehttp.ini value once (in theory)

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial creation TFS 42010 MTN - Early termination of Webservice responses

*/

vars
	iniFile		: File;
	timeoutStr	: String;
begin
	if not _set and _value = 0 then
		// We cant have attempted to read this value before, so lets try
		create iniFile transient;
		iniFile.usePresentationFileSystem := false;
		iniFile.mode := File.Mode_Input;
		iniFile.fileName := app.cnGetServerMiscPath &amp; "\bin_public_jadehttp\ini\jadehttp.ini";
		if not iniFile.isAvailable then
			return;
		endif;
		
		timeoutStr := app.getProfileStringAppServer(iniFile.fileName, JMTWebService_Section, "MessageTimeout", "300");
		_value := timeoutStr.Integer;
		self.jadeHTTPMessageTimeout := _value;
	endif;
epilog
	delete iniFile;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="start" id="2142b163-2793-4dd1-a1f9-7c7f953298fd">
        <source>start();

/*

Purpose:			Startup method for this agent

Parameters:			None

Return Value:		None


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
27 Apr 2021	navdap1	Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
*/

vars

begin
	self.startFileCleanupTimer();
	
	// Do initial cleanup at startup
	self.doFileCleanup();
	
	// do rest auth token cleanup at start			// TFS 50491
	self.doRestAuthTokenDelete();					// TFS 50491
	// then start the timer							// TFS 50491
	self.startRestAuthTokenDeleteTimer();			// TFS 50491
	
	// Just go idle waiting for timer to fire
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startFileCleanupTimer" id="5ddce76e-6fd0-4cc7-8af1-c445b8e0be8a">
        <source>startFileCleanupTimer() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	timerDelay		: Integer;
	
begin
	timerDelay := 5 * 60 * 1000;		// Check every 5 minutes
	
	self.beginTimer(timerDelay, Timer_Continuous, self.File_Cleanup_Timer_Event);
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startRestAuthTokenDeleteTimer" id="73c58412-8810-4f83-97af-f44da0d4fe6b">
        <source>startRestAuthTokenDeleteTimer() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/04/2021	navdap1		Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
//
vars
	timerDelay : Integer;
	now : TimeStamp;
	
begin
	timerDelay := 24 * 60 * 60 * 1000;		// Check every day
	now := app.actualTimeServer.cnEcAddSeconds((timerDelay / 1000).Integer);
	app.writeLog("Setting Rest Auth Token Delete Timer to fire at " &amp; now.asStringJMT, LogINFO);
	self.beginTimer(timerDelay, Timer_Continuous, self.Token_Delete_Timer_Event);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startWSInterruptTimer" id="907f02ef-978f-4a52-9158-efd98ee7b19c">
        <source>startWSInterruptTimer(_userInfo: Any; _long: Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2021	navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

vars
	tracker	: CMIF_WSTrackingObj;
	proc	: Process;
begin
	if _userInfo = null or not _userInfo.isKindOf(Process) then
		return;
	endif;
	
	proc := _userInfo.Process;
	tracker := self.allWSTrackingObjects[proc];
		
	beginTransientTransaction;
	if tracker = null then
		create tracker sharedTransient;
	endif;
	
	tracker.startInterruptTimer(proc, self, _long);
	commitTransientTransaction;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_userInfo" type="Any"/>
        <Parameter name="_long" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="6491c47d-d4d5-4872-aa26-7bc46636ef7e">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			Handle timer event for file cleanup

Parameters:			

Return Value:		


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
27 Apr 2021	navdap1	Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
*/

vars

begin
	if eventTag = self.File_Cleanup_Timer_Event then
		self.doFileCleanup();
		
	elseif eventTag = self.Token_Delete_Timer_Event then		// TFS 50491
		self.doRestAuthTokenDelete();						// TFS 50491
		
	endif;

	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="2dec3b3d-f3aa-42d6-bdf9-61ef74f8ae4f">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Mar 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
07 Apr 2021	navmd1	TFS 42010 MTN - Early Termination of web services

*/

vars

begin
	if eventType = self.Terminate_Application_Note then
		app.writeLog("Closedown notification received, terminating application", LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		terminate;
	elseif eventType = self.WS_Start_Interrupt_Note then
		self.startWSInterruptTimer(userInfo, false);
	elseif eventType = self.WS_Start_Long_Interrupt_Note then
		self.startWSInterruptTimer(userInfo, true);
	elseif eventType = self.WS_Cancel_Interrupt_Note then
		self.cancelWSInterruptTimer(userInfo);
	endif;
	

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
