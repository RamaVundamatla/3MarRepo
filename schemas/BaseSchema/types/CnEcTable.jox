    <JadeMethod name="create" id="9cf00d58-4a87-4975-9d5e-831ce6c6e931">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollection" id="942d715e-b98e-48d9-8b1e-2bcaa7beb0bd">
        <updating/>
        <source>displayCollection(c: Collection; update: Boolean; showHow: Integer; startObj: Object) updating;

begin
	inheritMethod(c, update, showHow, startObj);
end;</source>
