    <JadeMethod name="initTableData" id="587661f1-f17c-41a0-aa14-47883e3e9efd">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2017	jlgab1	Initial creation

*/

vars
	col : Integer;
begin
	inheritMethod(_theEntDef);

	self.tblData.multiSelect := CM_BaseTable.MultiSelect_None;
	self.tblData.fixedColumns := 0;
	
	self.tblData.getEntRowColumnByRowName(ETRow_Priority,col);
	
	if col &lt;= 0 then
		col := 1;
	endif;
	
	self.tblData.sortAsc[1] := false;
	self.tblData.sortColumn[1] := col;
	self.tblData.resort();
	
epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
