    <JadeMethod name="addAllCargo" id="3ee29d1f-72eb-4195-991d-dccb89d64fcf">
        <source>addAllCargo(	_washTA : CM_TerminalAreaMaster;
				_repairTA : CM_TerminalAreaMaster;
				_pretripTA : CM_TerminalAreaMaster;
				_washToDo : CM_ToDoTaskDesc;
				_repairToDo : CM_ToDoTaskDesc;
				_pretripToDo : CM_ToDoTaskDesc;
				_ptiRepairToDo : CM_ToDoTaskDesc;
				_surveyToDo : CM_ToDoTaskDesc;
				_mTGrade : CM_MTGrade;
				_operator : CM_Operator
