/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmh5	Initial creation

*/

vars
	isoTypeGroup	: CM_ISOTypeGroup;
begin

	self.tblEntry.setValueByControlName(combobox.name, combobox.text);
	
	if combobox.listObject &lt;&gt; null then
		isoTypeGroup := combobox.listObject.CM_ISOType.myISOTypeGroup;	
		if isoTypeGroup &lt;&gt; null then				// 21/09/2010 cnwmh5 #25688
			self.myAssistant.comboBoxISOTypeGroupFilter(cmbISOGroup, isoTypeGroup);
		else
			cmbISOGroup.clear();
		endif;
	else
		self.myAssistant.comboBoxISOTypeGroupFilter(cmbISOGroup, null);		// 21/09/2010 cnwmh5 #25688
	endif;
	
epilog

end;</source>
