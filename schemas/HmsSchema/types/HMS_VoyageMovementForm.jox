    <JadeMethod name="calcClosestTidalWindow" id="c0cab2b1-022f-4d25-b0e0-90619d3c3a34">
        <source>calcClosestTidalWindow() protected;

/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16289 - Change Drafts to Decimal[8,2]

*/

vars
	regionToCheck:		HMS_HarbourRegion;
	earliestTime:		TimeStamp;
	latestTime:			TimeStamp;
	currentLimitPosv:	Decimal[5,1];
	currentLimitNegv:	Decimal[5,1];
	draftLimit:			Decimal[8,2];			// PAR #16289
	offsetTime:			Integer;
	offsetAsTime:		Time;
	enterLeaveStatus:	String;
	moveTidalClass:		HMS_TidalClass;
	moveDT:				TimeStamp;
	current:			Real;
	draft:				Real;
begin
	// This method calculates the closest tidal window to the current movement time
	if self.myCurrentMovement = null then
		return;
	endif;

	offsetTime:=0;
	enterLeaveStatus:=null;

	regionToCheck := self.myCurrentMovement.getFirstRegionWithChkPts(offsetTime, enterLeaveStatus, self.myCurrentMovement.getVoyageMovementPrevious());

	if regionToCheck = null then 
		// No checkpoints to check - set tidal textboxes to 'N/A'
		tbxPredictCurrent.text:=app.getErrorString(NotApplicable);
		tbxPredictDirect.text:=app.getErrorString(NotApplicable);
		tbxPredictDepth.text:=app.getErrorString(NotApplicable);
		tbxMoveEarliest.text:=app.getErrorString(NotApplicable);
		tbxMoveLatest.text:=app.getErrorString(NotApplicable);
		tbxTidalActTime.text:=app.getErrorString(NotApplicable);
		tbxTidalRelative.text:=app.getErrorString(NotApplicable);
		tbxRegionName.text:=app.getErrorString(NotApplicable);
	else	
   		// Display details for first checkpoint reached for the movement
		// Get current and draft limits
		moveTidalClass := self.cmbTidalClass.listObject.HMS_TidalClass;
		
		if moveTidalClass = null then
			moveTidalClass := self.myCurrentMovement.myTidalClass;
		endif;
		
		if moveTidalClass &lt;&gt; null then
			if enterLeaveStatus = HMSMovementTypeEntering then
				currentLimitPosv := moveTidalClass.allMaximumCurrents[1];
				currentLimitNegv := (moveTidalClass.allMaximumCurrents[2])*-1;
			else
				currentLimitPosv := moveTidalClass.allMaximumCurrents[3];
				currentLimitNegv := (moveTidalClass.allMaximumCurrents[4])*-1;
			endif;
		endif;
		
		if myCurrentMovement.myHMSVoyageData.dim_DraftFore&lt;myCurrentMovement.myHMSVoyageData.dim_DraftAft then
			draftLimit:=myCurrentMovement.myHMSVoyageData.dim_DraftFore;
		else
			draftLimit:=myCurrentMovement.myHMSVoyageData.dim_DraftAft;
		endif;

		// Get moveDT 
		moveDT:=myCurrentMovement.occursOnDTNEW;

		if app.myHMSRvTide.getClosestWindow(earliestTime,latestTime,regionToCheck,moveDT,currentLimitPosv,currentLimitNegv,draftLimit,offsetTime,current,draft)=app.getErrorString(MoveUnrestricted) then
        	tbxMoveEarliest.text:=app.getErrorString(MoveUnrestricted);
			tbxMoveLatest.text:=app.getErrorString(MoveUnrestricted);
		else
			if offsetTime&lt;0 then
				offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
				earliestTime:=earliestTime+offsetAsTime;
				latestTime:=latestTime+offsetAsTime;
				tbxMoveEarliest.text := self.systemToLocalTime(earliestTime).date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.userFormat($CM_HMS_Time24Hour);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
				tbxMoveLatest.text := self.systemToLocalTime(latestTime).date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.userFormat($CM_HMS_Time24Hour);
			else
				offsetAsTime.setTime(0,offsetTime,0,0);
				earliestTime:=earliestTime-offsetAsTime;
				latestTime:=latestTime-offsetAsTime;
				tbxMoveEarliest.text := self.systemToLocalTime(earliestTime).date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.userFormat($CM_HMS_Time24Hour);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
				tbxMoveLatest.text := self.systemToLocalTime(latestTime).date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.userFormat($CM_HMS_Time24Hour);
			endif;
		endif;

		tbxTidalRelative.text:=offsetTime.String;

		if offsetTime&lt;0 then
			offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
			tbxTidalActTime.text := self.systemToLocalTime(moveDT - offsetAsTime).Time.userFormat($CM_HMS_Time24Hour);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
		else
			offsetAsTime.setTime(0,offsetTime,0,0);
			tbxTidalActTime.text := self.systemToLocalTime(moveDT+offsetAsTime).Time.userFormat($CM_HMS_Time24Hour);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
		endif;

		if current&lt;0 then
			tbxPredictCurrent.text:=(current*-1).roundedTo(1).String;
			tbxPredictDirect.text:=app.getErrorString(Ebb);
		else
			tbxPredictCurrent.text:=current.roundedTo(1).String;
			tbxPredictDirect.text:=app.getErrorString(Flood);
		endif;

		tbxPredictDepth.text:=draft.roundedTo(2).String;
		tbxRegionName.text:=regionToCheck.description;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
