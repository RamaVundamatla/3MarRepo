    <JadeMethod name="getStateData" id="14fb9de1-5e6e-475e-9470-b3559d40950d">
        <source>getStateData(pGroup : Integer; pKey : String) : Any protected;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	if pGroup &lt; 1 then
		return null;
	endif;
	
	if pGroup &lt;= self.allStateObjects.size then
		stateObj := self.allStateObjects[pGroup];
	endif;
	
	if stateObj = null then
		return null;
	endif;
	
	return stateObj.getStateData(pKey);

end;</source>
        <access>protected</access>
        <Parameter name="pGroup" type="Integer"/>
        <Parameter name="pKey" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
