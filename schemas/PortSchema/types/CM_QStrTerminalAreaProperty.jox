    <JadeMethod name="getValueForObject" id="0345627c-4eb4-4ed3-921b-024ed25c6b09">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2019	jlger1	Initial creation TFS 47132

*/

vars
	propValue : String; 
begin
	if self.propertyName = CM_TrackedItem::getQueuedTermAreaId.name then
		propValue := _obj.sendMsg(self.propertyName).String;
	
		if self.needToUpperCase then
			propValue := propValue.toUpper;
		endif;
		return propValue;
	else
	
		return inheritMethod(_obj, _op);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
