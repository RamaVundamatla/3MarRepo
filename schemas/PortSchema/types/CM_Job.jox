    <JadeMethod name="setForUpdate" id="672e9d6d-0162-4431-8342-47ef5041cb4b">
        <updating/>
        <source>setForUpdate(proxyJob : CM_Job;_theTerminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Feb 2024 	navhl20 	ChangeRequest 61869: EUP | FR | 53891 - Mobile App changes for Delivery Dispatch - Source Location
// ---------------------------------------------------------------------------

vars

begin

	proxyJob.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.id := proxyJob.id;
	self.jobType := proxyJob.jobType;
	self.status := proxyJob.status;
	self.priority := proxyJob.priority; //cnwrd1 24.8.09
	self.myWODtl := proxyJob.myWODtl; //cnwrd1
	//self.setJobPlannedLocation();			//26.02.2024 navhl20 #61869
	self.setJobPlannedLocation(true);	 //26/08/2024	navkc1 CR 63588 Task 63589
	
	//jlier1 MTN-34200 11/3/24
	if self.myJobSheetForWorkOrder &lt;&gt; null and not self.isTransient then
		app.myEventManager.createSingleObjInfoNoteEvt(self, self.myJobSheetForWorkOrder.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event),  self);
	endif;
	
	
end;</source>
        <Parameter name="proxyJob" type="CM_Job"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
