    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="01c5eb79-417d-4a6c-a859-b2e4b175ac0e">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _locale: CM_Locale; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _locale = null then
		return null;
	endif;
	
	// 26733 show locales with no description
	if _locale.localeDescription &lt;&gt; null then
		return _locale.localeDescription;
	else
		return _locale.localeId;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="c843200b-2208-43f5-aa59-888091fb73d8">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allLocales;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
