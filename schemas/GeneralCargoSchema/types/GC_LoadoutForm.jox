    <JadeMethod name="doModalMessageDisplay" id="999a0a4e-8a43-4a18-82f2-6be379af9419">
        <updating/>
        <source>doModalMessageDisplay(_container : CM_Container) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2005	cnwhjg1
//
// Purpose:     If a container is selected that has ToDo tasks then display message 
//				and make it not possible to pack items into it. 
// ----------   ----------  --------------------------------------------------
vars
	noPackMsg : String;
	container : CM_Container;
begin
	container := _container;
	if (not self.chkIgnoreWarning.value) then
		if container.hasToDoTasks then
			if noPackMsg = null then
				noPackMsg := app.getErrorString(HasToDoTasks);
			else
				noPackMsg := noPackMsg &amp;  CrLf &amp; " &amp; " &amp; app.getErrorString(HasToDoTasks);
			endif;
		endif;
		
		if noPackMsg &lt;&gt; null then
			app.msgBox(app.getErrorString(CannotPack) &amp; " " &amp; container.id &amp; ". " &amp; noPackMsg &amp; ". " &amp; app.getErrorString(TheseMustBeRemovedFirst),
			app.getErrorString(Pack_) &amp; container.id, MsgBox_OK_Only);
			
			if self.frmDetailEnt.visible then
//				self.zShowHideDetailEnt(false);
			endif;
			
			self.setState(STATE_DISABLED);
		else
			self.setState(STATE_ENABLED);	
		endif;
	else
		self.setState(STATE_ENABLED);	
	endif;
	//even if they are ignoring warnings, we need to tell them about this one:
	if container.contentsStatus = TI_CONTENTS_STATUS_FCL then
		app.msgBox(app.getErrorString1(TheContentsStatusOfContainer, container.id), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
	endif;
	

end;</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="e2e870df-8996-4c69-9b32-a3e57e43c27d">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     re-populates all comboboxes - should also re-select any items to their original value etc.
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	tmpOperator			: CM_Operator;
	tmpProduct			: CM_Product;
	tmpCargoType		: CM_CargoType;
	tmpImex,
	tmpTransMode,
	tmpProcessOpt,
	tmpStatus			: Integer;
	tmpId				: String;
	ls					: Boolean;
	tmpTAType			: CM_TerminalAreaType;
	terminalArea		: CM_TerminalArea;
begin

	app.mousePointer := Busy;
	inheritMethod();
	app.cmsBeginLoad(ls);
	tmpTAType := app.myRoot.allTerminalAreaTypes[TA_TYPE_IRREGULAR_BLOCK_AREA];		// was TA_TYPE_GENERAL_CARGO_AREA
	terminalArea := tmpTAType.allTerminalAreasByTerminal.getAtKeyGeq(self.myTerminal, null).CM_TerminalArea;
	if terminalArea &lt;&gt; null then
		self.myAssistant.comboBoxTAType(self.cmbTAType, tmpTAType, true);
		self.myAssistant.comboBoxTerminalArea(self.cmbTerminalArea, tmpTAType.type, terminalArea);
		self.myAssistant.comboBoxLocationControllers(self.cmbLocation, terminalArea.allLocationsControllers, false);
	endif;
	//combobs on the filter frame
//	self.myAssistant.comboBoxOperator(self.cmbFiltOperator, self.cmbFiltOperator.listObject.CM_Operator, null);
	self.cmbFiltOperator.setObject(cmbFiltOperator.listObject);
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
											self.cmbFiltVoyage.listObject.CM_Voyage,
											true,
											false,
											false,
											false,
											false,
											false,
											true,
											false,
											false);
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
											self.cmbVoyage.listObject.CM_Voyage,
											true,
											true,
											false,
											false,
											false,
											false,
											true,
											false,
											false);										
	
	if self.cmbFiltStatus.listIndex &gt; 0 and self.cmbFiltStatus.text &lt;&gt; Any_String then
		tmpStatus := self.cmbFiltStatus.itemData[self.cmbFiltStatus.listIndex];
	endif;
	self.myAssistant.comboBoxBOLStatus(self.cmbFiltStatus, tmpStatus);
	
	//combobs on the master entry frame
	if self.cmbStockOrder.listObject &lt;&gt; null then
		tmpId := self.cmbStockOrder.listObject.CM_StockOrderHeaderGeneric.orderNo;
	endif;
	
	self.myAssistant.comboBoxStockOrderGeneric(self.cmbStockOrder, self.myTerminal, null, null, OrderStatus_Unfulfilled, tmpId);
	
//	tmpOperator := self.cmbOperator.listObject.CM_Operator;
//	self.myAssistant.comboBoxOperator(self.cmbOperator, tmpOperator, null);
	self.cmbOperator.setObject(self.cmbOperator.myObject);
//	self.myAssistant.comboBoxOperator(self.cmbContOp, self.cmbContOp.listObject.CM_Operator, null);
	self.cmbContOp.setObject(self.cmbContOp.myObject);
//	HG CCMS1235 09/12/04
//	self.myAssistant.comboBoxConsignor(self.cmbConsignee, self.C.listObject.CM_ConsigneeConsignor);
//	self.myAssistant.comboBoxConsignor(self.cmbConsignor, self.cmbConsignor.listObject.CM_ConsigneeConsignor);
	self.cmbConsignee.setObject(self.cmbConsignee.myObject);
	self.cmbConsignor.setObject(self.cmbConsignor.myObject);
	
	//container packed related combos
	self.myAssistant.comboBoxCommodity(self.cmbCommodity, self.cmbCommodity.listObject.CM_Commodity);
	
	// lorcan - replacing port combobox - 11/4/2006
	self.cmbDisPort.myTerminal := self.myTerminal;// so text for port is displayed in correct order from config
	self.cmbDisPort.myAssistant := self.myAssistant;
	self.cmbDisPort.showAllDestinations := true;
	if self.cmbVoyage.listObject.CM_Voyage = null then
		self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), null);
	else
		self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), self.cmbVoyage.listObject.CM_Voyage);
	endif;
	//self.myAssistant.comboBoxDischarge(self.cmbDisPort, self.cmbVoyage.listObject.CM_Voyage, self.cmbDisPort.listObject.CM_Port);

	self.myAssistant.comboBoxISOType(self.cmbISOType, self.cmbISOType.listObject.CM_ISOType);
	
	if self.cmbIMEX.listObject &lt;&gt; null then
		tmpImex := self.cmbIMEX.listObject.CM_IMEXStatus.code;
	endif;
	
	self.myAssistant.comboBoxIMEXStatus(self.cmbIMEX, tmpImex);
	
	self.myAssistant.comboBoxContentsStatus(self.cmbContents, self.cmbContents.listObject.CM_ContentsStatus);
	
	// DVB changed 15/09/04
	//self.myAssistant.comboBoxCarrier(self.cmbCarrier, self.cmbCarrier.listObject.CM_Carrier);
	
	self.myAssistant.comboBoxVehicleTable(self.tblMasterEnt, ETRow_VehicleId, self.cmbCarrier.myObject.CM_Carrier);
	
	if self.cmbProcessOpt.listIndex &gt; 0 then
		tmpProcessOpt := self.cmbProcessOpt.itemData[self.cmbProcessOpt.listIndex];
	endif;	
	self.myAssistant.comboBoxProcessOption(self.cmbProcessOpt, tmpProcessOpt);
	
	if self.cmbFiltProOpt.listIndex &gt; 0 then
		tmpProcessOpt := self.cmbFiltProOpt.itemData[self.cmbFiltProOpt.listIndex];
	endif;
	self.myAssistant.comboBoxProcessOption(self.cmbFiltProOpt, tmpProcessOpt);
	
	if self.cmbTransportMode.listIndex &gt; 0 then
		tmpTransMode := self.cmbTransportMode.itemData[self.cmbTransportMode.listIndex];
	endif;
	self.myAssistant.comboBoxTransportModesLoadout(self.cmbTransportMode, tmpTransMode);
	
	tmpCargoType := self.cmbTypeToPack.listObject.CM_CargoType;
	self.myAssistant.comboBoxCargoTypesForPacking (self.cmbTypeToPack, tmpCargoType);

	if self.cmbTypeToPack.itemObject.size &gt; 0 then	//Par17435	11/07/2008
		// at moment only 1 type to pack (containers) so set that as default.
		if self.cmbTypeToPack.itemObject[1] &lt;&gt; null then 	// + dh par 15594 25/1/2008
			self.cmbTypeToPack.listObject := self.cmbTypeToPack.itemObject[1];
			tmpCargoType := self.cmbTypeToPack.listObject.CM_CargoType;
		endif;
	endif;	
	self.cmbTypeToPack.lostFocus(self.cmbTypeToPack);
	
	if tmpCargoType &lt;&gt; null then
		tmpId := cmbPackInto.text;
		self.myAssistant.comboBoxTrackedItemToPack(self.cmbPackInto, 
											tmpCargoType.id,
											TI_STATE_NORMAL,
											tmpId);
	
	endif;
	
	/* detail entry frame no longer used
	//combos on the detail entry frame
	if self.cmbCargoType.listObject &lt;&gt; null then
		self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, self.cmbCargoType.listObject.CM_CargoType);
	else
		self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, null);
	endif;
	tmpProduct := self.cmbProduct.listObject.CM_Product;
	self.myAssistant.comboBoxProduct(self.cmbProduct, 
									self.cmbCargoType.listObject.CM_CargoType, 
									null, 
									tmpProduct);
	tmpId := self.cmbItem.text;
	self.myAssistant.comboBoxTIsByProduct(self.cmbItem, tmpProduct, tmpId);
	*/
	
epilog
	endLoad;
	app.mousePointer := Idle;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveDetailLine" id="2f4c5de7-0326-45a7-83b8-7187e318d0e8">
        <updating/>
        <source>doRemoveDetailLine() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj			: Object;
	row,
	numRows		: Integer;
	tbl			: CM_DataTable;
	objSet		: CM_ObjectSet;
begin
	create objSet transient;
	tbl := self.tblDataDetail;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if (not tbl.accessRow(row).selected) then
			continue;
		endif;
		
		objSet.add(tbl.accessedRow.itemObject);
	endforeach;
	
	foreach obj in objSet do
		self.tblDataDetail.removeItemObject(obj);
		self.allDetailObjects.remove(obj);
	endforeach;
	
	self.doAssignLineNos();
	self.maintainIDCombos(null);
epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="d0d6e830-e168-4301-8127-68fc7b562f76">
        <updating/>
        <source>doResetSearch() updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	nullDate	: Date;
begin

	nullDate := null;
	tbl := self.tblSearch;
	tbl.clearValues();
//	self.cmbFiltOperator.text := null;
	self.cmbFiltOperator.setObject(null);
	self.cmbFiltStatus.text := Any_String;
	tbl.setValueByName(ETRow_FiltStatus, self.cmbFiltStatus.text);
	
	self.cmbFiltVoyage.text := null;
	
//	self.txtFiltDateFrom.setTextFromDate(nullDate);
//	self.txtFiltDateTo.setTextFromDate(nullDate);
	
	tbl.setValueByName(ETRow_FiltDateFrom, null);
	tbl.setValueByName(ETRow_FiltDateTo, null);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="bcaf8f57-51e4-4335-9f5e-2fde272500f0">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifBOLOut			: CMIF_BOLOut;
	rtnValue			: Boolean;
	
begin

//	self.setCMIFDetails();
	
	create cmifBOLOut transient;

	if self.mode = self.Mode_New then
		if (not self.setCMIFBOLOutForNew(cmifBOLOut)) then
			return false;
		endif;
		if cmifBOLOut.processOption = Process_Pack then
			return self.doSaveForPack(cmifBOLOut);
		elseif cmifBOLOut.processOption = Process_Direct_Loadout then
			return self.doSaveForDirectLoadout(cmifBOLOut);
		endif;
		// if go this far must have nothing selected. 
		app.msgBox('Please select a Process Option to continue',
		'Process Option', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
		
	elseif self.mode = self.Mode_Edit then
		self.setCMIFBOLOutForUpdate(cmifBOLOut);
		return self.doSaveForHeaderUpdate(cmifBOLOut);
	endif;
epilog
	delete cmifBOLOut;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveForDirectLoadout" id="a07252a1-c305-4fb5-b7be-b5770640514c">
        <updating/>
        <source>doSaveForDirectLoadout(_cmifBOLOut : CMIF_BOLOut input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	result	: Integer;
begin
	while true do
		app.myTrxCA.trxCreateBOLOut(_cmifBOLOut, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.myCurrentMasterObject := _cmifBOLOut.myPersistentBOL;
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Create Pack docket', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveForHeaderUpdate" id="499f48b0-f7ab-4ec0-9707-687842d4b069">
        <updating/>
        <source>doSaveForHeaderUpdate(_cmifBOLOut : CMIF_BOLOut input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	result			: Integer;
begin

	while true do
		app.myTrxUA.trxUpdateBOLHeader(_cmifBOLOut, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.myCurrentMasterObject := _cmifBOLOut.myPersistentBOL;
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Update docket', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveForPack" id="a74d64cb-4681-41cc-89b7-5ee3e866b72c">
        <updating/>
        <source>doSaveForPack(_cmifBOLOut : CMIF_BOLOut input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	result			: Integer;
begin

	while true do
		app.myTrxCA.trxCreateBOLOutPacked(_cmifBOLOut, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.myCurrentMasterObject := _cmifBOLOut.myPersistentBOL;
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Create Pack docket', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;
	

end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectStockOrder" id="cacde8a7-e4b8-4087-9fbb-5486e31cd214">
        <updating/>
        <source>doSelectStockOrder(_stockOrder : CM_StockOrderHeaderGeneric) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	orderLine		: CM_StockOrderLine;
	tbl				: CM_DataTable;
	bolOutLine		: CMIF_BOLOutLine;
	idx,
	reqdQuantity	: Integer;
	tmpOperator		: CM_Operator;
	tmpConsign		: CM_ConsigneeConsignor;
	processDescr,
	transDescr		: String;
	numLinesToAdd,
	numFulfilled,
	transMode		: Integer;
	orderNo			: String;
	isPartialLoadout	: Boolean;
	ti					: CM_TrackedItem;
	msg,
	msgHdr				: String;
begin

	if _stockOrder = null then
		return; 
	endif;
	tbl := self.tblDataDetail;
	orderNo := self.tblMasterEnt.getValueByName(ETRow_MyStockOrder).String;
	
	if tbl.rows &gt; tbl.fixedRows then
		if app.msgBox('Any loadout lines that have been added will now be cleared with the selection of this stock order.' &amp; CrLf &amp;
						'Are you sure you with to continue?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			self.cmbStockOrder.text := orderNo;
			return;
		endif;
	endif;
	
	self.tblMasterEnt.setValueByControlName(self.cmbStockOrder.name, self.cmbStockOrder.text);
	///////////////////////////////////////////////////
	//pre-populate entry table based on the stock order info
	tmpOperator := _stockOrder.myOperator;
//	ccms 1235 - combo does check for not available
//	if tmpOperator &lt;&gt; null and (not tmpOperator.isNotAvailableForEntry) then
//		self.tblMasterEnt.setValueByName(ETRow_MyOperator, tmpOperator.code);
//		self.cmbOperator.listObject := (_stockOrder.myOperator);
		self.cmbOperator.setObject(tmpOperator);
//	endif;
	
	tmpConsign := app.myRoot.allConsigneeConsignors[_stockOrder.consigneeCode];
	if tmpConsign &lt;&gt; null then
		self.tblMasterEnt.setValueByName(ETRow_MyConsignee, tmpConsign.code);
//		self.cmbConsignee.listObject := tmpConsign; HG CCMS1235 09/12/04
		self.cmbConsignee.setObject(tmpConsign);
	endif;
	
	processDescr := app.processOptionEnumToString(_stockOrder.processOption);
	self.tblMasterEnt.setValueByName(ETRow_ProcessOpt, processDescr);
	self.cmbProcessOpt.text := processDescr;
	
	transMode := _stockOrder.transportMode;
	transDescr := app.transModeToString(transMode);
	self.tblMasterEnt.setValueByName(ETRow_TransportMode, transDescr);
	self.cmbTransportMode.text := transDescr;

	self.doChangeEntryView();

	if transMode = TI_TRANSMODE_SHIP then
		//look for the voyage - may have specified CM_NullVoyage, or may have sailed/been archived etc. etc.
		idx := self.cmbVoyage.findObject(_stockOrder.myVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listIndex := idx;
		endif;
		
		self.tblMasterEnt.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
	endif;

	/////////////////////////////////////////////
	//add bolOut lines for the stock order	
	tbl.rows := tbl.fixedRows;
	self.allClonedControls.purge();
	self.allDetailObjects.purge();
	
	foreach orderLine in _stockOrder.allStockOrderLines do
		numFulfilled := orderLine.getNumberFulfilled();
		//create single line for a pre-assigned item, otherwise create lines to make up the required quantity
		if CM_StockOrderTILine.hasInstance(orderLine) then
			if numFulfilled = 1 then //line already fulfilled
				isPartialLoadout := true;
				continue;
			endif;
			
			create bolOutLine transient;
			bolOutLine.setFromStockOrderLine(orderLine);
			self.allDetailObjects.add(bolOutLine);
			self.addProxyObjectToDetailTable(tbl, bolOutLine);
			
			ti := orderLine.CM_StockOrderTILine.myTrackedItem;
			if ti &lt;&gt; null 
			and (ti.isChild or ti.site = TI_SITE_OFFSITE) then
				//could be packed into another or sent offsite
				tbl.accessRow(tbl.rows).backColor := self.ColorRedWarning;
			endif;
		elseif CM_StockOrderProductLine.hasInstance(orderLine) then
			reqdQuantity := orderLine.CM_StockOrderProductLine.reqdQuantity.Integer;
			numLinesToAdd := reqdQuantity - numFulfilled;
			
			if numLinesToAdd &lt; reqdQuantity then
				isPartialLoadout := true;
			endif;
			
			foreach idx in 1 to numLinesToAdd do
				create bolOutLine transient;
				bolOutLine.setFromStockOrderLine(orderLine);
				self.allDetailObjects.add(bolOutLine);
				self.addObjectToDetailTable(bolOutLine);
			endforeach;
		endif;	
	endforeach;
	
	self.doAssignLineNos();
	/////////////////////////////////////////
	
	if isPartialLoadout then //give advisory
		msg := 'Some of the lines from stock order ' &amp; _stockOrder.orderNo &amp; ' have already been fulfilled' &amp; CrLf &amp;
				'Only the unfulfilled lines have been displayed.';
		msgHdr := 'Partial loadout advisory';
		
		app.msgBox(msg, msgHdr, MsgBox_Exclamation_Mark_Icon);
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_stockOrder" type="CM_StockOrderHeaderGeneric"/>
    </JadeMethod>
    <JadeMethod name="doTblDetailDataDblClick" id="c3454165-275a-4eaa-9687-3d9f3262db29">
        <updating/>
        <source>doTblDetailDataDblClick(_tbl: CM_DataTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	itemObj			: Object;
	ti				: CM_TrackedItem;
begin
	itemObj := _tbl.accessRow(_tbl.row).itemObject;
	
	if CM_TrackedItem.hasInstance(itemObj) then
		ti := itemObj.CM_TrackedItem;
	elseif CM_BOLOutStockOrderLineTI.hasInstance(itemObj) then
		ti := itemObj.CM_BOLOutStockOrderLineTI.myTrackedItem;
	endif;

	if ti = null then
		return;
	endif;
		
	self.doEnquiryTI(ti);

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDtlDataContext" id="53560200-d85e-4394-b748-cc2784999c06">
        <updating/>
        <source>doTblDtlDataContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	ti					: CM_TrackedItem;
begin


	if not app.myCurrentUserCan(self.myTerminal,PmGCLoadoutMaint).Boolean then
		return false;
	endif;

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if CM_TrackedItem.hasInstance(self.myCurrentDetailObject) then
		ti := self.myCurrentDetailObject.CM_TrackedItem;
	elseif CM_BOLOutStockOrderLineTI.hasInstance(self.myCurrentDetailObject) then
		ti := self.myCurrentDetailObject.CM_BOLOutStockOrderLineTI.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		self.mnuDetailEnquire.caption := 'Enquire ' &amp; ti.id &amp; '...';
		self.mnuDetailEnquire.visible := true;
	else
		self.mnuDetailEnquire.visible := false;
	endif;

	if self.mode = self.Mode_New then
		self.mnuDetailNew.visible := true;
		self.mnuDetailNew.caption := 'Add Detail';

		self.mnuDetailEdit.visible := false;
	//	self.mnuMastEdit.caption := 'Edit Detail';
	
		self.mnuDetailRemove.visible := true;
		self.mnuDetailRemove.caption := 'Remove Detail';
		
	else 

		self.mnuDetailNew.visible := true;
		self.mnuDetailNew.caption := 'New Loadout';

		self.mnuDetailRemove.visible := false;
		
		if self.tblDataMaster.rows &gt; self.tblDataMaster.fixedRows then 
			self.mnuDetailEdit.visible := true;
			self.mnuDetailEdit.caption := 'Edit Loadout';
		else
			self.mnuDetailEdit.visible := false;
		endif;
		
	endif;	

	
	self.doMnuContextDetailBuild();
	
	//Can't at this stage organize the table as several of the fields are dependent on the input of others
	//CMUI_column Organiser will need to be reworked to allow sorting of some items but not the removal of them.
	self.mnuDetailOrganiser.visible := false;
	
	self.popupMenu(self.mnuDetailContext, x1.Integer, y1.Integer);
//	self.popupMenu(self.mnuTblDtlDataContext, x1.Integer, y1.Integer);
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblMasterDataContext" id="a82a84ee-3bac-4b69-91be-7d76b0d8a0d3">
        <updating/>
        <source>doTblMasterDataContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	bolOut				: CM_BOLOut;
begin
	if not app.myCurrentUserCan(self.myTerminal,PmGCLoadoutMaint).Boolean then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
		
	if app.isAllowedToInspect() then
		self.mnuInspectObject.visible := true;
		self.mnuInspectObject.enabled := true;
	else
		self.mnuInspectObject.visible := false;
	endif;
	
	bolOut := self.myCurrentMasterObject.CM_BOLOut;
	if bolOut = null then
		return false;
	endif;
	
	if bolOut.status = BOL_STATUS_ARCHIVED then
		self.mnuArchiveAllPrevious.enabled 	:= false;
		self.mnuArchiveSelected.enabled 	:= false;
		self.mnuUnarchiveAllFuture.enabled	:= true;
		self.mnuUnarchiveSelected.enabled	:= true;
		
	elseif bolOut.status = BOL_STATUS_NORMAL then
		self.mnuArchiveAllPrevious.enabled 	:= true;
		self.mnuArchiveSelected.enabled 	:= true;
		self.mnuUnarchiveAllFuture.enabled	:= false;
		self.mnuUnarchiveSelected.enabled	:= false;
	endif;
	
	self.popupMenu(self.mnuTblMstDataContext, x1.Integer, y1.Integer);
	
	return false;


end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblMasterEntContext" id="ae1eb663-975f-495a-a6e9-685daf9b3725">
        <updating/>
        <source>doTblMasterEntContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	bolOut				: CM_BOLOut;
begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
		
	bolOut := self.myCurrentMasterObject.CM_BOLOut;
	if bolOut &lt;&gt; null and 
	   bolOut.processOption = Process_Pack and 
	   bolOut.myMasterTI &lt;&gt; null then
		self.mnuEnquireParent.caption := 'Enquire ' &amp; bolOut.myMasterTI.id &amp; '...';
		self.mnuEnquireParent.visible := true;
	else
		self.mnuEnquireParent.visible := false;
	endif;
	
	self.popupMenu(self.mnuTblMstEntContext, x1.Integer, y1.Integer);
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
