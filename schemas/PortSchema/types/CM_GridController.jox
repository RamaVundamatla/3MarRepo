    <JadeMethod name="isAvailForMultiMove" id="a1607598-d341-4b87-9987-b6b63f435a51">
        <source>isAvailForMultiMove(): Boolean;

/*

Purpose:			

Parameters:			determine if this location is available for
					a move during a multi cargo move ?

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	array : CM_TIArray;

begin

	create array transient;
	
	self.getTIs(array,  PLANNING_MODE, true);
	self.getTIs(array,  QUEUE_MODE, false);
	self.getTIs(array,  REAL_MODE, false);

	return array.size &lt; self.allYAYardLocationCells.size;

epilog

	delete array;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
