    <JadeMethod name="showCargoTransactionsForm" id="f6dcc68f-8299-43bd-ba64-813629ce59a8">
        <source>showCargoTransactionsForm(_obj : Object; _masterMenuAction : CMUI_MenuAction);
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
// Feb 2012 CCMS 1262 transaction enquuiry use new fform
//--------------------------------------------------
vars
	transForm : CMUI_TransactionEnquiry;
begin

	if _obj = null then
		return;
	endif;
	
	transForm := app.loadForm(CMUI_TransactionEnquiry, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							_masterMenuAction).CMUI_TransactionEnquiry;	

	if transForm = null then
		return;
	endif;

	if _obj.isKindOf(CM_TrackedItem) then
		transForm.myTrackedItem := _obj.CM_TrackedItem;
	endif;
	
	if _obj.isKindOf(CM_BOL) then
		transForm.myBOL:=_obj.CM_BOL;
	endif;
	
	// ### JIRA 33348 22NOV2024 NAVAB1
	if _obj.isKindOf(CM_InvoiceContractAccumulate) then
		transForm.myAccumulation :=_obj.CM_InvoiceContractAccumulate;
	endif;
	
	
	transForm.show;		
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showCargoTypeForm" id="fda63674-ccd9-49e7-81c1-db2cc9a67493">
        <source>showCargoTypeForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction; _thumbnailOnly, _doEdit : Boolean);
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/
vars
	cargoEnqForm : CMUI_CargoTypeForm;
	menuAction : CMUI_MenuAction;
	failedDAC	: CM_DataAccessController;
	
begin

	menuAction := app.myController.createMenuAction(PmAdmCargoTypeView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	if _object &lt;&gt; null and (not _object.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			app.raiseCMException(Autho_view_full_detai_this_car, null, null);
	endif;
	
	cargoEnqForm := menuAction.goToObject(null, null, false, null).CMUI_CargoTypeForm;
	if cargoEnqForm = null then
		return;
	endif;
	
	if _object &lt;&gt; null then
		cargoEnqForm.showWithObject(_object, _thumbnailOnly, _doEdit);
	else
		cargoEnqForm.show();
	endif;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCarrierEmailOptions" id="d4f9fef8-7683-4f35-b1d6-9a09acd3760f">
        <source>showCarrierEmailOptions(_carrier: CM_Carrier; _emailDefault: CM_PINObjectDefaultEmail; _sending: Boolean; _warningText : String): Integer;
//----------------------------------------------------------------
//	Created:	22 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	form			: CMUI_CarrierEmailForm;
	canUpdate		: Boolean;
	canMaintain		: Boolean;
	limitedUpdate	: Boolean;
begin

	canUpdate := app.myPassport.myUser.canDo(self.myTerminal, PmAdmPINEmailDefUpdate);
	canMaintain := app.myPassport.myUser.canDo(self.myTerminal, PmAdmPINEmailDefMaint);
	
	if not (canUpdate or canMaintain) then
		//app.raiseCMWarning1(NoPermission, 'change any of the e-mail details', null, null, null);
		//just return OK - send default email
		app.msgBox("You do not have the permissions required for modifying the email defaults.","E-mail Options",null);
		return IDOK;
	endif;

	if _emailDefault = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults is null from form');
		return IDCANCEL;
	endif;
	
	if not _emailDefault.enabled then
		app.msgBox("Carrier emails have not been enabled for this type of item.", "E-mail Options", MsgBox_OK_Only);
		return IDCANCEL;
	endif;
	
	if canMaintain then
		limitedUpdate := false;
	else
		limitedUpdate := true;
	endif;
	
	if _warningText = null then
		create form;
	else
		create form as CMUI_CarrierEmailWarningForm;	//Special case, when the carrier is changed - need to populate form with a warning. Par 19427 April 2009 cnwvu1
		form.CMUI_CarrierEmailWarningForm.setWarning(_warningText);
	endif;
	
	form.setAssistantAndTerminalRefs(self, self.myTerminal);
	form.setCaption(form.caption &amp; ' Options - ' &amp; _emailDefault.name);
	form.setup(_carrier, _emailDefault, limitedUpdate, _sending);
	form.centreWindow;
	form.showModal();
	
	return form.modalResult;
	
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_emailDefault" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_sending" type="Boolean"/>
        <Parameter name="_warningText" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showColourStackHeights" id="d4640cf7-20ef-4b3f-ad92-48265e726383">
        <source>showColourStackHeights(): Integer;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
