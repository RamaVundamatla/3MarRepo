    <JadeMethod name="canSourcesBeAdded" id="80768e9c-3fbe-43bd-9fcf-f0a7a3d926f2">
        <source>canSourcesBeAdded() : Boolean;
// -----------------------------------------------------------------------------
// Created:		06 August 2009 by consw1
//
// Purpose:		Can containers/sources be added to this work order?
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.taskStatus = WO_STATUS_USERENTRY
	or self.taskStatus = WO_STATUS_PENDING 
	or self.taskStatus = WO_STATUS_NOTAPPROVED
	then
		return true;
	endif;

	if self.taskStatus = WO_STATUS_APPROVED	
	or self.taskStatus = WO_STATUS_PARTCOMPLETE 
	or self.taskStatus = WO_STATUS_PENDING_HOLD   //assume can add source when held/pending.
	or self.taskStatus = WO_STATUS_HELD 
	then
		return not app.myPassport.myUser.myOrganisation.isExternal;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSourcesBeRemoved" id="e5974f42-ad61-4d2c-a9b3-192b70d3a3ea">
        <source>canSourcesBeRemoved() : Boolean;
// -----------------------------------------------------------------------------
// Created:		06 August 2009 by consw1
//
// Purpose:		Can containers/sources be removed from this work order?
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.taskStatus = WO_STATUS_USERENTRY
	or self.taskStatus = WO_STATUS_PENDING 
	or self.taskStatus = WO_STATUS_NOTAPPROVED then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeTerminalEvent" id="ad77eefe-e817-46ad-9268-1d2139cda431">
        <source>causeTerminalEvent(_mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	jlier1	Initial creation  MTN-34591

*/

vars
	evt : CM_SingleObjectUserInfoNoteEvt;
	terminal : CM_Terminal;
	woDtl	: CM_WorkOrderDtl; 
begin
	if self.isTransient then
		return;
	endif;
	
	if app.isInProformaMode then
		return;
	endif;
	
	terminal:= self.getMyTerminal;
	
	if terminal = null then
		return;
	endif;
	
	if _mode =Event_WorkOrder_Update then
		//if we are doing an update and there is already an create then we don't need to do a an update event
		evt := app.myEventManager.allSingleObjInfoNotes[self, Event_WorkOrder_Create, self];
		if evt = null then
			app.myEventManager.createSingleObjInfoNoteEvt(self, terminal.getTerminalEvent(Event_WorkOrder_Update),  self);
		endif;
	elseif _mode = Event_WorkOrder_Create then
		app.myEventManager.createSingleObjInfoNoteEvt(self, terminal.getTerminalEvent(Event_WorkOrder_Create),  self);
	elseif _mode = 	Event_WorkOrder_Delete then
		
		//07/05/2025	navkc1 JIRA MTN-34592 - When deleting a work order, also send notification to work order details
		foreach woDtl in self.allWoDtls discreteLock do
			woDtl.causeEvent( terminal.getTerminalEvent(Event_WODtl_Delete),false,woDtl);
		endforeach;
		
		self.causeEvent( terminal.getTerminalEvent(Event_WorkOrder_Delete),false,self);
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearPin" id="f763ee76-c63c-466d-9d13-3a86fb1d8455">
        <source>clearPin(_isDelete : Boolean);
//
// Purpose:			
