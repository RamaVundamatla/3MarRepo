    <JadeMethod name="addEntry" id="d30d4ef8-0322-4e01-9ebf-a5b231ee8a80">
        <source>addEntry(pObj : Object; pPos, pLevel : Integer; _expanded : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 May 2009	cnwkpd1		PAR #18769 - Use exception handler rather than
//							isValidObject for performance
//17 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
// ---------------------------------------------------------------------------
vars
	str		: String;
	idx		: Integer;
	pic		: Binary;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, pObj, invalid);		// PAR #18769
	str := pObj.asStringJMT;	//PAR 37738
	if invalid then
		return null;
	endif;
	str := null;
	if pObj.isKindOf(CM_RadioTelemetryQueue) then
		str := pObj.CM_RadioTelemetryQueue.id;
		idx := pObj.CM_RadioTelemetryQueue.allEntries.size;
		if idx &gt; 0 then
			str := str &amp; ' (' &amp; idx.String &amp; ' entries)';
		endif;
		if pObj.isKindOf(CM_MasterQueue) then
		else
			if pObj.isKindOf(CM_VoyageQueue) then
				if pObj.isKindOf(CM_VoyageCraneQueue) then
					if pObj.CM_RadioTelemetryQueue.status = QSTATUS_HELD then
						pic := form.YRD_QueueForm.picCraneOff.picture;
					else
						pic := form.YRD_QueueForm.picCrane.picture;
					endif;
				else
					if pObj.CM_RadioTelemetryQueue.status = QSTATUS_HELD then
						pic := form.YRD_QueueForm.picVoyQueueHeld.picture;
					else
						pic := form.YRD_QueueForm.picVoyQueue.picture;
					endif;
				endif;
			else
				if pObj.CM_RadioTelemetryQueue.status = QSTATUS_HELD then
					pic := form.YRD_QueueForm.picQueueHeld.picture;
				else
					pic := form.YRD_QueueForm.picQueue.picture;
				endif;
			endif;
		endif;
		
	elseif pObj.isKindOf(CM_RTQueueEntry) then
		str := pObj.CM_RTQueueEntry.idFullDisplay;	// Par 25418
		if pObj.CM_RTQueueEntry.status = ENTRY_USER_HELD  or pObj.CM_RTQueueEntry.status = ENTRY_SYSTEM_HELD then
			pic := form.YRD_QueueForm.picQueueEntHeld.picture;
		else
			pic := form.YRD_QueueForm.picQueueEntry.picture;
		endif;

	else
		str := 'Unknown object type (' &amp; pObj.String &amp; ')';
	endif;

	// PAR #18769
	if invalid then
		return null;
	endif;
	
	if pPos &lt;= 0 or pPos &gt; self.listCount then
		idx := self.addItem(str);
	else
		idx := pPos;
		self.addItemAt(str, idx);
	endif;
	self.itemObject[idx] := pObj;
	self.itemLevel[idx] := pLevel;
	self.itemPicture[idx] := pic;
	if pObj.isKindOf(CM_RTQueueEntry) then
		if pObj.CM_RTQueueEntry.status = ENTRY_WORKING then
			self.itemBackColor[idx] := LightGreen;
		else
			self.itemBackColor[idx] := self.backColor;//White;
		endif;
	endif;
	self.itemExpanded[idx] := _expanded;

	return idx;

end;</source>
        <Parameter name="pObj" type="Object"/>
        <Parameter name="pPos" type="Integer"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBelowLevel" id="b64dfac6-d618-47e5-b239-7cf5715d7eca">
        <source>clearBelowLevel(pIndex : Integer);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lListCount : Integer;
	lLevel : Integer;
begin

	lListCount := self.listCount;
	lLevel := self.itemLevel[pIndex];
	
	if pIndex &lt;= lListCount then
		while true do
			// Something with the same level as us or above us, so stop
			if self.itemLevel[pIndex + 1] &lt;= lLevel then
				break;
			endif;
			self.removeItem(pIndex + 1);
			lListCount := lListCount - 1;
			// check that we have not just got rid of the bottom item
			if pIndex + 1 &gt; lListCount then 
				break;
			endif;
		endwhile;
	endif;



end;</source>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
