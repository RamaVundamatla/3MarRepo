    <JadeMethod name="pxyCreateUpdateProxy" id="09761d1e-172b-468c-bd07-ce9fccfad9d9">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars

	pxy : SelfType;
	completedOK : Boolean;
	
	pxyMarineService : CM_WodMarineServiceDetail;
	marineService : CM_WodMarineServiceDetail;

begin

	pxy := inheritMethod();
	
	pxy.myCargoSubType := self.myCargoSubType;
	pxy.myCargoType := self.myCargoType;
	pxy.myCommodity := self.myCommodity;
	pxy.myConsignee := self.myConsignee;
	pxy.myConsignor := self.myConsignor;
	pxy.myFreightForwarder := self.myFreightForwarder;
	pxy.myLocationsController := self.myLocationsController;
	pxy.myOperator := self.myOperator;
	pxy.setMyWorkPoint( self.getMyWorkPoint );
//	pxy.myBerth 	:= self.myBerth;
	
	//17 Aug 2018	NDL	TFS 40127
	foreach marineService in self.allMarineServiceDetails discreteLock do
		pxyMarineService:= marineService.pxyCreateUpdateProxy;
		if pxyMarineService &lt;&gt; null then
			pxy.allMarineServiceDetails.add(pxyMarineService);
		endif;
	endforeach; 
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
