<Class name="GlobalConstant">
    <JadeMethod name="cnEcGetCategory" id="9ee39e3f-be3f-4872-900a-6468d8f321d8">
        <source>cnEcGetCategory():ConstantCategory;
// --------------------------------------------------------------------------------
// Created:		08 July 2001 by cnwdad1
//
// Purpose:		Returns the receivers global constant category.
//
// Parameters:	None
//
// Returns:		The ConstantCategory object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.category;
end;</source>
        <ReturnType type="ConstantCategory"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGlobal" id="ebc4bf94-d095-4867-ab46-cc47745abd55">
        <source>cnEcIsGlobal():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 April 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
