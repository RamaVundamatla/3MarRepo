    <JadeMethod name="populateCombo" id="cb5e04a9-9ade-4d1d-8dca-764c3ef6d6c5">
        <source>populateCombo() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin

	self.cmbDoubleClick.clear();
	
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickCargoEnqArea );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickCargoEnqBayRow );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickReportArea );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickReportBayRow );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickSumArea );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickSumBayRow );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickYardEnqArea );
	self.cmbDoubleClick.addItem( YRD_SatelliteViewForm.DblClickYardEnqBayRow );

	self.cmbHeightRest.clear();
	self.cmbHeightRest.addItemWithData(app.getErrorString(Show_unavailabl_from), YRD_GridOViewDrawingController.UNAVAILABLE_FROM);
	self.cmbHeightRest.addItemWithData(app.getErrorString(Show_number_slots_availab),YRD_GridOViewDrawingController.UNAVAILABLE_NUMBER_AVAIL);
	self.cmbHeightRest.addItemWithData(app.getErrorString(Show_number_slots_unavail),YRD_GridOViewDrawingController.UNAVAILABLE_NUMBER_UNAVAIL);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateDataValues" id="c90e556e-f552-4798-b9ab-5969a4d5ecbf">
        <source>populateDataValues(	_dblClickAction : String; 
					_showColour : Boolean;
					_showFail : Boolean;
					_showRTG : Boolean;
					_showSelPanel : Boolean;
					_showYAMTable : Boolean;
					_heightRestrictOption : Integer;
					_showDirections: Boolean
					);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin

	self.populateCombo();

	if _dblClickAction &lt;&gt; null then
		self.cmbDoubleClick.listIndex := self.cmbDoubleClick.findStringExact( 1, _dblClickAction );
	endif;
	
	self.cmbHeightRest.setIndexForItemData(_heightRestrictOption);
		
	self.chkShowColour.value := _showColour;
	self.chkShowFail.value := _showFail;
	self.chkShowRTG.value := _showRTG;
	self.chkShowSelPanel.value := _showSelPanel;
	self.chkShowYAMTable.value := _showYAMTable;
	self.chkShowDirections.value := _showDirections;		// 2/10/17 MAP TFS7084
		
	
	if self.cmbDoubleClick.listIndex = -1 then
		self.cmbDoubleClick.listIndex := self.cmbDoubleClick.findStringExact( 1, YRD_SatelliteViewForm.DblClickYardEnqArea );	// default setting.
	endif;
		

epilog

end;</source>
        <Parameter name="_dblClickAction" type="String"/>
        <Parameter name="_showColour" type="Boolean"/>
        <Parameter name="_showFail" type="Boolean"/>
        <Parameter name="_showRTG" type="Boolean"/>
        <Parameter name="_showSelPanel" type="Boolean"/>
        <Parameter name="_showYAMTable" type="Boolean"/>
        <Parameter name="_heightRestrictOption" type="Integer"/>
        <Parameter name="_showDirections" type="Boolean"/>
    </JadeMethod>
