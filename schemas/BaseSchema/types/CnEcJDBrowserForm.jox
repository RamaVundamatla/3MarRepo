    <JadeMethod name="isEditingAllowed" id="f4b74997-f905-4f37-bf89-723876634ffa">
        <source>isEditingAllowed():Boolean;
// --------------------------------------------------------------------------------
// Created:		28 January 1999 by cnwdad1
//
// Purpose:		Gets the "AllowUpdates" value from the INI file and returns it.
//
// Parameters:	None
// Returns:		Boolean
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allowUpdates	: Boolean;

begin
	allowUpdates	:=	app.getProfileString(app.getIniFileName(), "JDBrowser", "AllowUpdates", "true").Boolean;
epilog
	return allowUpdates;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isManualCollection" id="b053c52d-83a5-47d7-a747-373b6a3eac36">
        <source>isManualCollection(pProperty:Property):Boolean;
// --------------------------------------------------------------------------------
// Created:		18 July 1999 by cnwdad1
//
// Purpose:		Identifies whether or not a Collection property is manual (ie.
//				it has no auto inverses).
//
// Parameters:	pProperty (Property) - The (Collection) Property to be examined.
// Returns:		Boolean - True if the collection has no auto inverses.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isManual	: Boolean;

begin
	if (pProperty = null) then
		isManual	:=	false;

	elseif (not pProperty.getType.isCollection) then
		isManual	:=	false;

	elseif (pProperty.isKindOf(ExplicitInverseRef)) then
		if (pProperty.ExplicitInverseRef.updateMode.Integer = 0) then
			isManual	:=	true;
		endif;

	elseif (pProperty.isKindOf(ImplicitInverseRef)) then
/*
		if (pProperty.ImplicitInverseRef.memberTypeInverse) then
			// This will be true if, where the reference is defined, 'Exclusive' is checked.
		else
			// This will be false if, where the reference is defined, 'Exclusive' is NOT checked.
		endif;
*/
		isManual	:=	true;

	endif;
epilog
	return isManual;
end;</source>
        <Parameter name="pProperty" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="35de5e49-e7ba-4a5b-addb-3f4d5627b45b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod(keyCode, shift);
	self.cnEcKeyDown(keyCode, shift);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="objectBrowse" id="50283ef7-0d4c-49f4-96bc-23447d45c7b4">
        <source>objectBrowse(pListbox:ListBox; pTable:Table input);
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Purpose:		Gets a selected object from a list or table control and loads it
//				into a Browser form.  Only one of the parameters can have a value,
//				not both.
//
// Parameters:	pListBox (ListBox) - The listbox from which to get the object.
//				pTable (Table) - The table from which to get the object.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theObject		: Object;
	browseOnly		: Boolean;
	updateForm		: CnEcObjectUpdateForm;
	browserForm		: CnEcObjectBrowserForm;
	collectionForm	: CnEcCollectionBrowserForm;

begin
	browseOnly	:=	false;

	if pListbox &lt;&gt; null and pListbox.listIndex &lt;&gt; CNEC_NULL_INDEX then
		theObject	:=	pListbox.listObject;
		browseOnly	:=	true;

	elseif pTable &lt;&gt; null then
		if pTable.row &gt; 1 and pTable.row &lt;= pTable.rows then
			if pTable.column &gt; 0 and pTable.column &lt;= pTable.columns then
				theObject	:=	pTable.cnEcGetCellObject(pTable.row, pTable.column);

				if theObject = null then
					theObject	:=	pTable.cnEcGetCellObject(pTable.row, 1);
				endif;
			endif;
		endif;
	endif;

	if theObject &lt;&gt; null then
		if theObject.isKindOf(Collection) or browseOnly then
			if (pListbox = null) then
				create collectionForm;
				collectionForm.setMyClass(currentSchema.getClass(theObject.class().name));
				collectionForm.setMyObject(null);
				collectionForm.setMyCollection(theObject.Collection);
				collectionForm.setIsCollection(true);
				collectionForm.setIsReference(false);
				collectionForm.setIsBrowseOnly(true);
				collectionForm.setIsManual(false);
				collectionForm.show();
			else
				create browserForm;
				browserForm.setMyClass(theObject.Class);
				browserForm.setIsBrowseOnly(true);
				browserForm.show();
			endif;
		else
			create updateForm;
			updateForm.setMyObject(theObject);
			updateForm.setMyClass(theObject.class());
			updateForm.setIsNewObject(false);
			updateForm.setIsBrowseOnly(true);
			updateForm.show();
		endif;
	endif;
end;</source>
        <Parameter name="pListbox" type="ListBox"/>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="objectInspect" id="d5ef46a4-44cc-4684-95c9-a2daff29d4b6">
        <source>objectInspect(pListbox:ListBox; pTable:Table input);
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Purpose:		Gets a selected object from a list or table control and inspects
//				it with the JADE Inspector.  Only one of the parameters can have a
//				value, not both.
//
// Parameters:	pListBox (ListBox) - The listbox from which to get the object.
//				pTable (Table) - The table from which to get the object.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theObject	: Object;

begin
	if pListbox &lt;&gt; null and pListbox.listIndex &lt;&gt; CNEC_NULL_INDEX then
		theObject	:=	pListbox.listObject;

	elseif pTable &lt;&gt; null then
		if pTable.row &gt; 1 and pTable.row &lt;= pTable.rows then
			if pTable.column &gt; 0 and pTable.column &lt;= pTable.columns then
				theObject	:=	pTable.cnEcGetCellObject(pTable.row, pTable.column);

				if theObject = null then
					theObject	:=	pTable.cnEcGetCellObject(pTable.row, 1);
				endif;
			endif;
		endif;
	endif;

	if theObject &lt;&gt; null then
		theObject.cnEcInspect();
	endif;
end;</source>
        <Parameter name="pListbox" type="ListBox"/>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCanUpdate" id="3bf8384f-f03e-48cc-a2d6-c79e7776811c">
        <updating/>
        <source>setCanUpdate(value: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if canUpdate &lt;&gt; value then 
		canUpdate := value;
	endif;
end;</source>
        <Parameter name="value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statusMsg" id="87312600-2c2a-4150-9785-0649456e211b">
        <source>statusMsg(pMessage:String);
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Displays a message on the status bar, and sets/resets the cursor (Busy/Idle).
//
// Parameters:	String - The message to be displayed.
// Returns:		nothing	
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	mdiForm	: CnEcJDBrowserMdi;

begin
	mdiForm	:=	self.getMdiForm();

	if (pMessage.trimBlanks.length = 0) then
		mdiForm.picBusy.visible		:=	false;
		mdiForm.picReady.visible	:=	true;
		mdiForm.picReady.zOrder(1);
		mdiForm.statusLine.caption	:=	"Ready.";
		app.mousePointer			:=	Idle;
	else
		app.mousePointer			:=	Busy;
		mdiForm.picReady.visible	:=	false;
		mdiForm.picBusy.visible		:=	true;
		mdiForm.picBusy.zOrder(1);
		mdiForm.statusLine.caption	:=	pMessage;
	endif;
epilog
	mdiForm.statusLine.refreshNow();
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</GUIClass>
