    <JadeMethod name="validateForUpdate" id="4f490f4b-bc56-4f9b-a943-c4ba43664b44">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			 Reason
07 October 2022	navvt20	 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	if self.context = null then
		app.raiseCMException(Input_required_context, ETRow_Context, self);
	endif;

	if self.text = null then
		app.raiseCMException(Input_required_text,ETRow_Text, self); 
	endif;
end;</source>
    </JadeMethod>
