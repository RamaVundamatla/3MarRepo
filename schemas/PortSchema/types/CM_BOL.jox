    <JadeMethod name="getNumItemsForSite" id="801e4e0d-4dff-4ad3-9b06-9cb0dc53db6a">
        <source>getNumItemsForSite(_site : Integer) : Integer;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	cnt : Integer;
begin

	foreach tmpTI in self.allTrackedItems do
		if tmpTI.site &lt;&gt; _site then
			continue;
		endif;
		cnt := cnt + tmpTI.quantity;
	endforeach;

	return cnt;
end;</source>
        <Parameter name="_site" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumReceived" id="50f6c48f-fc74-4710-a7cc-b9ff638a4fda">
        <source>getNumReceived() : Integer;
/*

Purpose:		items not on ship	

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2013	cnwer1	Initial creation 31274

*/

vars
	ti : CM_TrackedItem;
	num : Integer;
begin

	foreach ti in self.allTrackedItems do 
		if ti.site &lt;&gt; TI_SITE_ONSHIP then
			num:=num + 1;
		endif;
	endforeach;
	
	return num;
	
epilog

end;</source>
