<CollClass name="CMIF_RefsDict" id="68aff2fc-7275-4980-a01f-627b00298a35">
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_Refs"/>
    <superclass name="CMIF_Dicts"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CMIF_Refs::referenceOne"/>
    </MemberKey>
    <JadeMethod name="addObjects" id="b7f6008e-5bab-4622-8593-55b0d76ae852">
        <lockReceiver/>
        <updating/>
        <source>addObjects(_obj1, _obj2 : Object) updating;

// Created by cnwdvb1 on 16 January 2007

vars

	refs				: CMIF_Refs;
begin

	if _obj1 = null or _obj2 = null then
		return;
	endif;
	
	create refs transient;
	refs.referenceOne := _obj1;
	refs.referenceTwo := _obj2;
	
	self.add(refs);

end;</source>
        <Parameter name="_obj1" type="Object"/>
        <Parameter name="_obj2" type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c45bae6e-aa58-4423-8f74-9ed73b8737e6">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;

// Created by cnwdvb1 on 10 January 2007

vars

begin

	self.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSecondaryObject" id="c4da66b2-3cb9-483a-be64-70fac7454d2b">
        <source>getSecondaryObject(_primaryObj : Object) : Object;

// Created by cnwdvb1 on 10 January 2007

vars

	cmif : CMIF_Refs;

begin

	if _primaryObj = null then
		return null;
	endif;
	
	cmif := self[_primaryObj];
	
	if cmif = null then
		return null;
	endif;
	
	return cmif.referenceTwo;

end;</source>
        <Parameter name="_primaryObj" type="Object"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</CollClass>
