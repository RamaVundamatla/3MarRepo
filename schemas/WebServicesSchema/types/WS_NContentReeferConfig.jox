    <JadeMethod name="create" id="7ffbc010-982a-4231-a567-bde89a7ab21c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2020	jlgrr1	Initial creation TFS 49227

*/

vars
	configPriv : WS_NReeferConfigPrivilege;

begin
	self.blockNameDelimiter := "\";
	self.blockLabel := "Walk Path";
	self.sortType := "WALKPATH";
	self.actionSortConfig := "A,M,C,D";
	
	create configPriv transient;
	configPriv.setDetails("mobile_apps_management", "ms_rm_base_priv");
	self.requiredPrivileges := configPriv;
	
	self.sessionIdleTime := 120;
	self.displayListAfterSave := true;
	self.notesBehaviour := "APPEND";
epilog

end;</source>
    </JadeMethod>
</Class>
