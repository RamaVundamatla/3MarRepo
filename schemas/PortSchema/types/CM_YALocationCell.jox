    <JadeMethod name="getRowCoordinate" id="c05e8c1c-c58a-413a-a51f-50fefeda2de8">
        <source>getRowCoordinate():Point;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//	
//	Returns the column and height position in the row
//----------------------------------------------------------------
vars
	pt				: Point;
	row				: CM_GridRow;
	gridController	: CM_GridController;
begin

	if not CM_GridController.hasInstance(self.myYardController) then
		return null;
	endif;
	
	gridController := self.myYardController.CM_GridController;
	
	row := gridController.myGridRow;
	
	pt.set(row.allControllersByColumn.indexOf(gridController), self.height);

	return pt;


end;</source>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="isAvailForMultiMove" id="19445dd7-a811-4eac-8900-617ba53fc31d">
        <source>isAvailForMultiMove():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	tot : Integer;

begin

	if not self.isAvailable then
		return false;
	endif;
	
	if myYardController = null then
		return false;
	endif;
	
	if myYardController.isGridLocation then
	
		tot := tot + myYardController.allPlannedFutureMoves.size;
		tot := tot + myYardController.allQueuedFutureMoves.size;
		tot := tot + myYardController.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
		tot := tot + myYardController.allTrackedItemOSBackEnds.size;
		tot := tot + myYardController.allTrackedItemOSBackEndsPd.size;
		tot := tot + myYardController.allTrackedItemOSBackEndsQd.size;
	
		return tot &lt; height;
		
	else
		return myYardController.isAvailForMultiMove;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailable" id="35238f72-105c-4b1b-a66b-abd3024eaf02">
        <methodInvocation>mapping</methodInvocation>
        <source>isAvailable(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	unAvailHeight	: Integer;
begin
	if set then
		return;
	else
		unAvailHeight := self.myYardController.getFirstUnavailableHeight();
		
		if unAvailHeight = 0 then	//available at all heights
			_value := true;
		else						//available up to the unAvailHeight					
			_value := (self.height &lt; unAvailHeight);
		endif;
	endif;



epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="row" id="f4e319f6-14bd-406e-9499-92d07f6e91d2">
