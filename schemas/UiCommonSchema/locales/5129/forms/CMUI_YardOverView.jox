        <caption>&amp;Refresh Display</caption>
        <enabled/>
        <level>2</level>
        <name>mnuRefresh</name>
        <shortCutKey>F5</shortCutKey>
        <visible/>
    </MenuItem>
    <MenuItem>
        <caption>&amp;Hide Colour Legend</caption>
