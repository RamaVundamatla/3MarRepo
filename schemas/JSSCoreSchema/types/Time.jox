<PrimType name="Time">
    <JadeMethod name="jssAddHours" id="fe5e9b02-c8d2-449c-80ab-5d0fb376d384">
        <source>jssAddHours(pHours:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver time.
//
// Parameters:	pHours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (((pHours * 60) * 60) * 1000);
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

