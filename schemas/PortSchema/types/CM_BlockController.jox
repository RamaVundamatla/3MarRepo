    <JadeMethod name="getID" id="b8f67264-916a-424b-a899-81912733e466">
        <source>getID(): String;

// 23/06/2009	concms1	ccms 1061 - gate config changes
vars
	laneIndex :	Integer;
	tmpTA	: CM_TerminalArea;

begin
// ccms 1061 - start
	if self.myTerminalArea &lt;&gt; null then 
		if self.isInTransitTo then
			return In_Transit_To &amp; ' ' &amp; self.myTerminalArea.id;
		endif;
		if self.isInTransitFrom then
			return In_Transit_From &amp; ' ' &amp; self.myTerminalArea.id;
		endif;
	endif;
// ccms 1061 - end
	if self.myPreGateVTA &lt;&gt; null then
		return PreGate;
	elseif self.myPostGateVTA &lt;&gt; null then
		return PostGate;
	elseif self.myRoadJobSheet &lt;&gt; null then
		return InTerminalUnknown;
	endif;


	tmpTA := self.myTerminalArea;

	
	if tmpTA = null then
		return self.String;
	endif;
	
	if CM_CraneTransferArea.hasInstance(tmpTA) then
		laneIndex := tmpTA.CM_CraneTransferArea.lanes.indexOf(self);
		return tmpTA.id.trimBlanks &amp; " " &amp; laneIndex.String;
	else	
		return tmpTA.id.trimBlanks;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
