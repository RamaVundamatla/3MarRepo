<Class name="UT_COPARN_GATEDOC" id="68ebc405-9495-4476-a3b5-cf0b92622fdd">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="doCoparnSNOBookPrenoteVGM" id="2362873a-4854-4ad9-98b7-42e8deafebd0">
        <source>doCoparnSNOBookPrenoteVGM(_ediUseOldCoparn : Boolean);
//
// 13 Feb 2018	jlgrs1	TFS 36945 CTA+RP not working in COPARN
//
constants
	HSDExample : String = "HSDExample";
	KKKExample : String = "KKKExample";
	GBExample : String = "GBExample";
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "0530215931";
	Prenote1 : String = "GSLM2012170";
	VehicleId : String = "UTTRUCK1";
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
//	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	vgmDetails : CM_VGMDetails;
begin
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiUseOldCoparn, _ediUseOldCoparn);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "TOFU", operator);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFileSNO;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, false);
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNull(vgmDetails);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	
	// gate in the container with no carrier
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote1).isOnSite);
	beginTransaction;
	ediParty.allEDIPartyRules.first.setPropertyValue(CM_EDIPartyCoparnRules::updateVGMForOnsiteCargo.name, true);
	commitTransaction;
	coparnInput := self.zCoparnFileSNO3;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
//		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, true);
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNotNull(vgmDetails);
	self.assertEqual(vgmDetails.vgmAuthSignature, "NORMIS BATES");
	self.assertEqual(vgmDetails.weightCertifiedName, "JOHN P. SMITH");
	self.assertEqual(vgmDetails.weightCertifiedReference, "UT_CL_VOY1");
epilog

end;</source>
        <Parameter name="_ediUseOldCoparn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tCoparnInvalidConsignorError" id="f71a5a82-8770-4aa9-bd9f-a858b495982b">
        <source>tCoparnInvalidConsignorError();
/*
Purpose:  Test the behavior of the system when it encounter INVALID Consignor in the EDI FILE.
		  The behaviour of JMT must be guided by the Terminal Configuration -&gt; EdiGateDocInvConsignor
		  
Case When: Invalid consignor is treated as an ERROR
		  
Date		Who		Reason
05 Aug 2019	jlgdi1	45733	Initial creation
*/

constants
	BOOKING_NO : String = "TEST7733";
	VESSEL_CODE : String = "TESTVL";
	VOYAGE_CODE : String = "TESTVY";
	EDI_PARTY_NAME : String = "TST";
	SENDER : String = "TST";
	USER_DEF_NAME : String = "SNO_COPARN";
	PRENOTE1 : String = "TEST2724458";
	PRENOTE2 : String = "TEST1838669";
	INV_CONSIGNOR_CODE : String = "11800019545";
	CONSIGNOR_CODE : String = "QWERT";
	CONSIGNOR_DESC : String = "UNIT TEST CONSIGNOR";
	FIVE_ITEMS : Integer = 5;
	
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	booking : CM_BookingRef;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	subTerminal : CM_SubTerminal;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	coparnInput : String;
	errorMsg : String;
	prenote : CM_TrackedItem;
	result : Boolean;
	validConsignor : CM_ConsigneeConsignor;
	consigneeConsignor : CM_ConsigneeConsignor;
	fileName : String;
	prevEdiUseOldCoparn : Boolean;
	prevEdiGateDocInvConsignor : Boolean;
	controllerAgent : CM_EDIControllerAgent;
	
begin
	// Arrange
	prevEdiUseOldCoparn := self.getTerminalConfig(EdiUseOldCoparn).Boolean;
	prevEdiGateDocInvConsignor := self.getTerminalConfig(EdiGateDocInvConsignor).Boolean;
	
	fileName := USER_DEF_NAME&amp;"1"&amp;method.name;
	
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// delete test data if still exist
	zInvConsignorDataCleanUp(CONSIGNOR_CODE,
							 PRENOTE1,
							 PRENOTE2,
							 BOOKING_NO,
							 VESSEL_CODE,
							 VOYAGE_CODE,
							 EDI_PARTY_NAME,
							 "EDI_LOAD_" &amp; fileName &amp; ".edi");

	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	
	
	// Create the party rules.
	self.deleteEDIParty(EDI_PARTY_NAME);
	ediParty := self.createEDIParty(EDI_PARTY_NAME, EDI_PARTY_NAME, SENDER, operator);

	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;	
	
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;
	
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'BN', CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;	
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, '12', CM_EDIEDIFactRule.Fnct_RFF_1_1_Release);
	
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;
	
	coparnInput := self.zInvConsignorCoparnFile(SENDER,
												EDI_PARTY_NAME, 
												BOOKING_NO, 
												VOYAGE_CODE, 
												VESSEL_CODE,
												PRENOTE1,
												PRENOTE2,
												INV_CONSIGNOR_CODE);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", fileName);
	
	self.assertNotNull(ediFile);
	
	create controllerAgent transient;
	
	// -------------------- Test Case No# 1 ---------------------------------
	// When : Invalid consignor is treated as an ERROR
	// Given : Invalid Consignor
	// Expected Results
	// i.   verification = EDI_STATUS_VERIFIED_ERRORS
	// ii.  db load = EDI_STATUS_DBLOADED_ERRORS
	
	self.setTerminalConfig(EdiGateDocInvConsignor, true);
	// Act
	self.ediVerify(ediFile);
	result := (ediFile.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	// Assert
	self.assertTrueMsg(result, "Test Case #1 Status must be VERIFIED WITH ERRORS");
	
	self.ediDBLoad(ediFile);
	result := (ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS);
	self.assertTrueMsg(result, "Test Case #1 Status must be db loaded with ERRORS");
	// End of Test Case No# 1 ------------------------------------------------
	
epilog
	// data clean up
	zInvConsignorDataCleanUp(CONSIGNOR_CODE,
							 PRENOTE1,
							 PRENOTE2,
							 BOOKING_NO,
							 VESSEL_CODE,
							 VOYAGE_CODE,
							 EDI_PARTY_NAME,
							 "EDI_LOAD_" &amp; fileName &amp; ".edi");
							 
	self.setTerminalConfig(EdiUseOldCoparn, prevEdiUseOldCoparn);
	self.setTerminalConfig(EdiUseOldCoparn, prevEdiGateDocInvConsignor);
	
	delete controllerAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoparnInvalidConsignorWarning" id="869081b8-7269-4aa1-a61a-dc34a2e6363a">
        <source>tCoparnInvalidConsignorWarning();
/*
Purpose:  Test the behavior of the system when it encounter INVALID Consignor in the EDI FILE.
		  The behaviour of JMT must be guided by the Terminal Configuration -&gt; EdiGateDocInvConsignor

Case When: Invalid consignor is treated as a WARNING

Date		Who		Reason
05 Aug 2019	jlgdi1	45733	Initial creation
*/

constants
	BOOKING_NO : String = "TEST7733";
	VESSEL_CODE : String = "TESTVL";
	VOYAGE_CODE : String = "TESTVY";
	EDI_PARTY_NAME : String = "TST";
	SENDER : String = "TST";
	USER_DEF_NAME : String = "SNO_COPARN";
	PRENOTE1 : String = "TEST2724458";
	PRENOTE2 : String = "TEST1838669";
	INV_CONSIGNOR_CODE : String = "11800019545";
	CONSIGNOR_CODE : String = "QWERT";
	CONSIGNOR_DESC : String = "UNIT TEST CONSIGNOR";
	FIVE_ITEMS : Integer = 5;
	
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	booking : CM_BookingRef;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	subTerminal : CM_SubTerminal;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	coparnInput : String;
	errorMsg : String;
	prenote : CM_TrackedItem;
	result : Boolean;
	validConsignor : CM_ConsigneeConsignor;
	consigneeConsignor : CM_ConsigneeConsignor;
	fileName : String;
	prevEdiUseOldCoparn : Boolean;
	prevEdiGateDocInvConsignor : Boolean;
	controllerAgent : CM_EDIControllerAgent;
	pnUniqueBooking : Boolean;
	
begin
	// Arrange
	pnUniqueBooking := self.setTerminalConfig(PrenoteUniqBooking, false).Boolean;
	prevEdiUseOldCoparn := self.getTerminalConfig(EdiUseOldCoparn).Boolean;
	prevEdiGateDocInvConsignor := self.getTerminalConfig(EdiGateDocInvConsignor).Boolean;
	
	fileName := USER_DEF_NAME&amp;"1"&amp;method.name;
	
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// delete test data if still exist
	zInvConsignorDataCleanUp(CONSIGNOR_CODE,
							 PRENOTE1,
							 PRENOTE2,
							 BOOKING_NO,
							 VESSEL_CODE,
							 VOYAGE_CODE,
							 EDI_PARTY_NAME,
							 "EDI_LOAD_" &amp; fileName &amp; ".edi");

	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	
	
	// Create the party rules.
	self.deleteEDIParty(EDI_PARTY_NAME);
	ediParty := self.createEDIParty(EDI_PARTY_NAME, EDI_PARTY_NAME, SENDER, operator);

	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;	
	
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;
	
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'BN', CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;	
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, '12', CM_EDIEDIFactRule.Fnct_RFF_1_1_Release);
	
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;
	
	coparnInput := self.zInvConsignorCoparnFile(SENDER,
												EDI_PARTY_NAME, 
												BOOKING_NO, 
												VOYAGE_CODE, 
												VESSEL_CODE,
												PRENOTE1,
												PRENOTE2,
												INV_CONSIGNOR_CODE);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", fileName);
	
	self.assertNotNull(ediFile);
	
	create controllerAgent transient;
	
	// -------------------- Test Case No# 2 ---------------------------------
	// - When : INVALID consignor
	// - expected results
	//   i.   verification = EDI_STATUS_VERIFIED_WARNINGS
	//   ii.  db load = EDI_STATUS_DBLOADED_ERRORS
	//   iii. EDI Track Items = 5 {Book Header, 2 Book Items, 2 PreNotes}
	//   iv.  Consignor in PreNote must be blank
	self.setTerminalConfig(EdiGateDocInvConsignor, false);
	
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", fileName);
	
	// Act
	self.ediVerify(ediFile);
	
	result := (ediFile.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	// Assert
	self.assertTrueMsg(result, "Test Case #2 Returns " &amp; controllerAgent.displayStatus(ediFile.fileStatus) &amp; ", expected to be 'VERIFIED WITH WARNINGS'");
	
	self.ediDBLoad(ediFile);
	result := (ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED);
	self.assertTrueMsg(result, "Test Case #2 Status must be loaded");
	
	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, FIVE_ITEMS);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(PRENOTE1);
	self.assertNotNull(prenote);
	self.assertNull(prenote.consignor);
	
	prenote := self.getTrackedItem(PRENOTE2);
	self.assertNotNull(prenote);
	self.assertNull(prenote.consignor);
	// End of Test Case No# 2 ------------------------------------------------
	
	// -------------------- Test Case No# 3 ---------------------------------
	// - When : VALID consignor
	// - expected results
	//   i.   verification = no Error (may have warnings)
	//   ii.  db load = EDI_STATUS_DBLOADED
	//   iii. EDI Track Items = 5 {Book Header, 2 Book Items, 2 PreNotes}
	//   iv.  Consignor in PreNote is not blank

	validConsignor := app.myRoot.allConsigneeConsignors.getAtKey(CONSIGNOR_CODE);
	if validConsignor = null then
		validConsignor := self.addConsigneeConsignor(CONSIGNOR_CODE, CONSIGNOR_DESC, false, true, false);
	endif;
	
	coparnInput := self.zInvConsignorCoparnFile(SENDER,
												EDI_PARTY_NAME, 
												BOOKING_NO, 
												VOYAGE_CODE, 
												VESSEL_CODE,
												PRENOTE1,
												PRENOTE2,
												CONSIGNOR_CODE);
												
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", fileName);
	
	self.assertNotNull(ediFile);
	
	self.setTerminalConfig(EdiGateDocInvConsignor, false);
	// Act
	self.ediVerify(ediFile);
	errorMsg :=	"Test Case #3 - Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	
	// Assert
	self.assertIsOneOf(ediFile.fileStatus,
					   errorMsg,
					   CM_EDIFile.EDI_STATUS_VERIFIED,
					   CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
		
	self.ediDBLoad(ediFile);
	result := (ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED);
	self.assertTrueMsg(result, "Test Case #3 Status must be loaded");
	
	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, FIVE_ITEMS);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(PRENOTE1);
	self.assertNotNull(prenote);
	self.assertNotNull(prenote.consignor);
	prenote := self.getTrackedItem(PRENOTE2);
	self.assertNotNull(prenote);
	self.assertNotNull(prenote.consignor);
	// End of Test Case No# 3 ------------------------------------------------
	
epilog
	// data clean up
	zInvConsignorDataCleanUp(CONSIGNOR_CODE,
							 PRENOTE1,
							 PRENOTE2,
							 BOOKING_NO,
							 VESSEL_CODE,
							 VOYAGE_CODE,
							 EDI_PARTY_NAME,
							 "EDI_LOAD_" &amp; fileName &amp; ".edi");
							 
	self.setTerminalConfig(EdiUseOldCoparn, prevEdiUseOldCoparn);
	self.setTerminalConfig(EdiGateDocInvConsignor, prevEdiGateDocInvConsignor);
	self.setTerminalConfig(PrenoteUniqBooking, pnUniqueBooking);
	
	delete controllerAgent;
end;</source>
