    <JadeMethod name="lstColour_hasLostFocus" id="8b3ee815-1ae0-468d-99f1-30aacbf652f7">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars
	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstColourList.getSelectedString(CM_VehicleColour::colour.name);
	if str.length &gt; 30 then
		self.txtColourList.text := str[1:29]&amp; '...';
	else
		self.txtColourList.text := str;
	endif;
	self.txtColourList.visible := true;
	self.lstColourList.visible := false;
	self.lstColourList.parent := _fieldFrame;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
