<Class name="CMEVT_DelayStart" id="1977a4e3-3c8b-4a0f-af6e-e816d3085fb9">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ExplicitInverseRef name="myDelay" id="2c18fc17-2a0c-4686-81ed-cffcbf2969be">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Delay"/>
        <access>readonly</access>
        <Inverse name="CM_Delay::myEventStart"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myMachineHistory" id="cfba2b99-94b7-4b18-ac8b-1275056e6b97">
        <embedded/>
        <type name="CM_MachineDelayHistory"/>
        <access>readonly</access>
        <Inverse name="CM_MachineDelayHistory::myDelayStartEvent"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="3533cc0c-c935-4f14-8c81-09229efc5908">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.type	:= EVT_DelayStart;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="80c3b517-f6b7-4e44-a26b-f8f693afc43c">
        <updating/>
        <source>delete() updating;
/*
Purpose:	Remove any machine history for the delay event

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	history	:CM_MachineDelayHistory;
begin
	history := self.myMachineHistory;
	
	if history &lt;&gt; null then
		history.erase (NORMAL_ERASE);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBank" id="3ffb6771-224e-4cae-961b-692f2f62263d">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aVoy : CM_Voyage;
begin
	aVoy := self.getVoyage();
	if aVoy &lt;&gt; null then
		if aVoy.myDischargeCompany &lt;&gt; null then
			return aVoy.myDischargeCompany;
		endif;
	endif;
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="fc82e29f-a0ef-478e-b8de-9377f44bab46">
        <source>getDebtor() : CM_Debtor;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aVoy : CM_Voyage;
begin
	aVoy := self.getVoyage();
	if aVoy &lt;&gt; null then
		if aVoy.myDebtor &lt;&gt; null then
			return aVoy.myDebtor.CM_Debtor; // &lt;&lt;&lt; this is virtual
		endif;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getName" id="a8dd65c1-f830-4745-abd7-115bdcd8bc30">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.getDescription(false);
	else
		return inheritMethod();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="5a509921-7147-457a-8585-bf097ba9a516">
        <source>getVoyage() : CM_Voyage;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.myVoyage;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="29065bbc-f6f6-4bf6-8c71-3bfe046533af">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_DelayEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	delay		: CM_Delay;
	machine		: CM_Machine;
begin
	
	delay := _cmifEventTrx.myDelay;
	
	if delay &lt;&gt; null then
		delay.setMyEventStart(self);
		machine := delay.myMachine;
		
		if machine &lt;&gt; null then
			machine.addDelayStartHistory(self);
		endif;
	endif;
	
	// Keep this at the bottom so it calculate the charges after all details are entered
	inheritMethod(_eventType, _cmifEventTrx);
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_DelayEventCtrl"/>
    </JadeMethod>
</Class>
