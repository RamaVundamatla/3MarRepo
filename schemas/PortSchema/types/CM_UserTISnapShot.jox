    <JadeMethod name="setProxyValueFromCargoProperty" id="493fd0ae-6724-44c1-8ac3-3c8603f6f430">
        <updating/>
        <source>setProxyValueFromCargoProperty(_entTableRow : EntTableRow; _ti : CM_TrackedItem) updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	tivaluestr : String;
	snapprop : String;
begin
	
	snapprop := _entTableRow.name;
	tivaluestr := _ti.getDisplayStringForAttribute(_entTableRow.name,false);
	
	if _entTableRow.name = ETRow_TotalQuantity then
		self.setPropertyValue(snapprop,tivaluestr.Integer);
		
	elseif _entTableRow.name = ETRow_CargoType 
	or _entTableRow.name = ETRow_TransitStatus	then
		self.setPropertyValue(snapprop,_ti.getPropertyValue(snapprop));		
		
	elseif _entTableRow.name = ETRow_ContentsStatus then
		if _ti.isContainer() then
		self.setPropertyValue(snapprop,_ti.getPropertyValue(snapprop));		
		endif;
	elseif _entTableRow.name = ETRow_ImExStatus then		
		self.setPropertyValue(snapprop,_ti.getImExStatus());
	elseif _entTableRow.name = ETRow_IsOverDimensions then
		self.setPropertyValue("isOD",tivaluestr.Boolean);
	elseif _entTableRow.name = ETRow_IsTranship then
		self.setPropertyValue("isTransship",tivaluestr.Boolean);
	elseif _entTableRow.name = ETRow_TotalVolume then
		self.setPropertyValue(snapprop,_ti.totalVolume);
	elseif _entTableRow.name = ETRow_TotalWeight then
		self.setPropertyValue(snapprop,_ti.totalWeight);
	elseif _entTableRow.name = ETRow_DischargePortDescr then
		self.setPropertyValue("dischargePortDescription",tivaluestr);
	elseif _entTableRow.name = ETRow_DestinationPortDescr then
		self.setPropertyValue("destinationPortDescription",tivaluestr);
	elseif _entTableRow.name = ETRow_DestinationPortDescr then
		self.setPropertyValue("destinationPortDescription",tivaluestr);
	elseif _entTableRow.name = ETRow_CargoSubtypeDescr then
		self.setPropertyValue("cargoSubtypeDescription",tivaluestr);
	else // all the strings
		self.setPropertyValue(snapprop,tivaluestr);
	endif;
	
epilog

end;</source>
        <Parameter name="_entTableRow" type="EntTableRow"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
