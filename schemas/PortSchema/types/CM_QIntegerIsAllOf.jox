    <JadeMethod name="validateForRT" id="2866ba12-04d0-4f37-8c7e-7be2785f4a43">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars

begin

	//26 Jul 2011	NDL	Par 27890
	//app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;'"', null, null);
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;'"', null, null, null);
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
