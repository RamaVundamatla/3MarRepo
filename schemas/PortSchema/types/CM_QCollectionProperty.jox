<Class name="CM_QCollectionProperty" id="525d0b09-199b-4b3f-b04a-c3c425d7507c">
    <superclass name="CM_QueryProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="fa7b0928-5328-4277-9156-6ee48c174521">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwpjs1	Initial creation  PAR # 31327

*/

vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QCollIncludesOneOf persistent;
	self.allAllowedOperators.add(oper);
	create oper as CM_QCollIncludesNoneOf persistent;
	self.allAllowedOperators.add(oper);
	create oper as CM_QCollIncludesAllOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="b2d0111f-30b9-442e-aaaf-2a96d713a91b">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwpjs1	Initial creation  PAr # 31327

*/

vars

begin
	
	if _op.isKindOf(CM_QCollIncludesOneOf) then
		return QueryControl_MultiSelect;
	elseif  _op.isKindOf(CM_QCollIncludesAllOf) then
		return QueryControl_MultiSelect;
	elseif  _op.isKindOf(CM_QCollIncludesNoneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);

epilog

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultOperator" id="23f2d461-b13e-4197-83ff-3c5d20d706dd">
        <source>getDefaultOperator(): CM_QueryOperator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAR # 31237
*/

vars

begin
	return self.allAllowedOperators[CM_QueryOperator.Operator_IncludesOneOf];


epilog

end;</source>
        <ReturnType type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="e3b71a46-10b5-4152-916a-5bbae198fb5c">
