begin
	delete self.myCargo;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="b56f9c3b-d104-45d5-a990-7cd28834b12d">
        <updating/>
        <source>setProxyFromObject(_object: CM_LocationsController) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Feb 2009	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	inheritMethod(_object);

	self.description := _object.displayEntry();
	self.id := _object.getFullId; //epr TFS 1487
	
	//cnwmc5 - 31 August 2015 - CCMS 1142
	self.terminalAreaId	:= _object.terminalAreaId;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
