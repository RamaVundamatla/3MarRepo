<CollClass name="CM_TISet" id="5a034830-8a59-4bf6-a5fb-ee54182953eb">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="trakitem"/>
    <JadeMethod name="asCSV" id="5c243cfd-fcb4-402b-8131-a53478ae79ca">
        <source>asCSV() : String;

// cnwdvb1 21 November 2002 

vars

	ti		: CM_TrackedItem;
	output	: String;
	
begin

	foreach ti in self do
		output := output &amp; ',' &amp; '"' &amp; ti.id &amp; '"';
	endforeach;	
	if output.length &gt; 0 then
		return output[2:end];
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asDelimitedString" id="3163c2e4-772a-48a9-9185-1a87301e4b72">
        <source>asDelimitedString(_delimiter :Character):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	ti		: CM_TrackedItem;
	output	: String;
begin

	foreach ti in self do
		if output = null then
			output := ti.id ;
		else
			output := output &amp; _delimiter &amp;  ti.id ;
		endif;
		
	endforeach;	
	
	return output;
epilog

end;</source>
        <Parameter name="_delimiter" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstNonEquipmentBooking" id="f6327159-b7f7-4fcc-abcc-15205fcf89c0">
        <source>getFirstNonEquipmentBooking():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwndl1	Initial creation	Par 36111

*/

vars

	ti : CM_TrackedItem;

begin

	ti := self.getFirstNonEquipmentTI;

	if ti = null then
		return null;
		
	else
		return ti.bookingReference;
		
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
