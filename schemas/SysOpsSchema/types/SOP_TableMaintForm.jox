    <JadeMethod name="tblData5_keyDown" id="4a20003b-831f-47a8-9e66-572a936fcf38">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData5_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;

/*
Date		Who		Reason
11 June 2009	cnwar2	Initial creation

*/
constants
	FirstCol = 2;
	LastCol	 = 4;
vars
	row, col : Integer;
	lastCol	: Integer;
begin
	lastCol := table.columns; //20/03/2025	navkc1 JIRA Story MTN-34232 make it dynamic?
	
	if keyCode = J_key_Tab then	
		row	:= table.row;
		col	:= table.column;
			
		if shift = 0 then	// moving forward
			//if col = LastCol and row &lt;&gt; table.rows then
			if col = lastCol and row &lt;&gt; table.rows then //20/03/2025	navkc1 JIRA Story MTN-34232
				table.row 	 := row + 1;
				table.column := FirstCol - 1;
			endif;
		elseif shift = 1 then	// moving back
			if col = FirstCol then
				table.column := 1;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
