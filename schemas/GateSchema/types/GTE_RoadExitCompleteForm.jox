    <JadeMethod name="tblWorkEntryColor" id="e8808415-cb1f-420e-8a1b-d08b81ff033e">
        <updating/>
        <source>tblWorkEntryColor(_tbl : CM_DataTable io; _wle : CM_WorkListEntry; _row : Integer) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 June 2007
//
//----------------------------------------------------------------------
vars
	isSelected,
	isReceipt 	: Boolean;
	foreColour,
	backColour 	: Integer;	
	tbl 		: CM_DataTable;
begin
	tbl := _tbl;
	
	foreColour := Black;
	backColour := White;

	if _wle = null then
		return;
	endif;

	if _wle.job &lt;&gt; null and _wle.job.jobType = BOLType_Log then
		foreColour := Black;
		if _row mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
	else
		_wle.getRowColour(foreColour, backColour);	
	endif;	

	tbl.accessRow(_row).backColor := backColour;
	tbl.accessRow(_row).foreColor := foreColour;	
	
	if backColour = Red then
		tbl.accessRow(_row).fontBold := true;	
	else		
		tbl.accessRow(_row).fontBold := false;		
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntryDrop" id="5268d699-47c2-451a-a071-3944d26b0e98">
        <updating/>
        <source>tblWorkEntryDrop(_table : Table; win : Window; x, y : Real)protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars

begin
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	if (not global.isValidObject(self.myCurrentWLE)) then
		//self.tblWLEChange(null);
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;	
	
	app.mousePointer := MousePointer_HourGlass;
	
	if self.myCurrentWLE.isReceipt then
		//selected wle is a receipt, they could be sending it back to the vehicle
		self.doMoveTrackedItem(self.getLocationController(self.myCurrentWLE), self.myCurrentWLE);
	else //selected wle is a release
		self.assignTIToReleaseRequest(app.myMoveController.myTrackedItem, self.myCurrentWLE);
	endif;
	
	// This get done via notifications
	//self.tblWLEUpdateWle(self.myCurrentWLE, self.Mode_Update);	
epilog
	app.mousePointer := MousePointer_Default;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table"/>
        <Parameter name="win" type="Window"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntryUpdateWle" id="987a1622-0544-4096-b857-5da2077c41a2">
        <updating/>
        <source>tblWorkEntryUpdateWle(_wle : CM_WorkListEntry; _mode : Integer) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	taId,
	str		: String;
	col,
	rowIdx	: Integer;
	job		: CM_Job;
begin

	if _mode = self.Mode_Delete or (not global.isValidObject(_wle)) then
		self.tblReceivals.removeItemObject(_wle);
		if _wle.String = self.myCurrentWLE.String then
			//self.tbWorkEntryChange(null);
		endif;		
		return;
	endif;

	if (not CM_YardWLE.hasInstance(_wle)) then
		return;
	endif;
	
	job := _wle.job;
	
	if (not CM_RoadJob.hasInstance(job)) then
		return;
	endif;
	
//	self.myTerminal.lookupTrackedItem( lookupAllTIsOfIdCargoType(
//	self.myTerminal.lookupTerminalArea
	
/*	if self.myCurrentTransferArea &lt;&gt; null then
		taId := self.myCurrentTransferArea.id;
	else
		self.doRefresh();
		return;
	endif;
	
	if job.CM_RoadJob.roadTransAreaId &lt;&gt; taId then
		self.tblWorkEntries.removeItemObject(_wle);
		self.doNotableRemove(_wle.myTrackedItem);
		return;	
	endif;
	
	self.updateAddWle(_wle, _mode);			
	*/										
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f250289d-3daf-4836-b1aa-61007ee07fa4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005480, locale);
	chkPrintPreview.translateCaption(Xlat_0005481, locale);
	chkPrintReceipt.translateCaption(Xlat_0005482, locale);
	grpJobDetails.translateCaption(Xlat_0005483, locale);
	grpPrint.translateCaption(Xlat_0005484, locale);
	grpVehicleDetail.translateCaption(Xlat_0005485, locale);
	lblChassis.translateCaption(Xlat_0005486, locale);
	lblDateOut.translateCaption(Xlat_0005487, locale);
	lblNumCopies.translateCaption(Xlat_0005488, locale);
	lblReceivals.translateCaption(Xlat_0005489, locale);
	lblReleases.translateCaption(Xlat_0005490, locale);
	lblTimeOut.translateCaption(Xlat_0005491, locale);
	lblVehicle.translateCaption(Xlat_0005492, locale);
	mnuColorLegend.translateCaption(Xlat_0014362, locale);
	mnuContextTable.translateCaption(Xlat_0005494, locale);
	mnuDeleteCurrentEntry.translateCaption(Xlat_0005495, locale);
	mnuTurnaroundReceival.translateCaption(Xlat_0005496, locale);
	mnuUnassignTI.translateCaption(Xlat_0005497, locale);
end;</source>
    </JadeMethod>
</GUIClass>
