        <ReturnType type="Boolean"/>
    </Function>
    <Function name="internetConnect" id="6e4b7889-743a-4fe9-87db-f58d57490a29">
        <entrypoint>InternetConnectA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>internetConnect(pInternetHandle	: Integer; 
				pServerName		: String; 
				pServerPort		: Integer; 
				pUsername		: String; 
				pPassword		: String; 
				pService		: Integer; 
				pFlags			: Integer; 
				pContext		: Integer): Integer is "InternetConnectA" in "wininet";</source>
        <Parameter name="pInternetHandle" type="Integer"/>
        <Parameter name="pServerName" type="String"/>
        <Parameter name="pServerPort" type="Integer"/>
        <Parameter name="pUsername" type="String"/>
        <Parameter name="pPassword" type="String"/>
        <Parameter name="pService" type="Integer"/>
        <Parameter name="pFlags" type="Integer"/>
        <Parameter name="pContext" type="Integer"/>
        <ReturnType type="Integer"/>
    </Function>
    <Function name="internetGetLastResponseInfo" id="5d778462-1f1a-4d35-994d-d592c0b18ca9">
