    <JadeMethod name="doTblDataClick" id="95cdd247-0052-49ca-a940-ebdc1be16bbc">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl			: CM_DataTable;
	objSet 		: ObjectSet;
	objSetSize	: Integer;
begin
	// The object set will be populated with the objects selected if they are not null
	tbl := self.tblData;
	create objSet transient;
	tbl.getSelectedCellObjects(objSet);
	objSetSize := objSet.size;
	if objSetSize &lt; 1 then
		// the menus are visible only if there is data on the table or if the selected cells have any objects behind them.
		self.mnuContextTIEnquire.visible := false;
		self.mnuSendToReport.visible := false;
	else
		// otherwise the menus will be hidden
		self.mnuContextTIEnquire.visible := true;
		self.mnuSendToReport.visible := true;
	endif;
epilog 
	delete objSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
