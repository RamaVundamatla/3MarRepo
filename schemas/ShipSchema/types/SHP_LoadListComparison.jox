    <JadeMethod name="colourDiscreps" id="cf3ef18c-ee98-4770-a97a-d4dd6ae466c0">
        <updating/>
        <source>colourDiscreps(_tableRow: Integer; _ediLLTI: CM_EDITrackedItem) protected, updating;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
// 09/12/2014 cnwma1 PAR #35358 Load List Comparison - Weight
//----------------------------------------------------------------
vars
	intCol			: Integer;
	attrName	: String;
	aLLCTI		: CM_EDILoadListComparisonTI;
	newAttrName,measureType  : String;
begin
	
	aLLCTI := _ediLLTI.CM_EDILoadListComparisonTI;

	foreach attrName in self.tblData.allTblDataColPropertyNames do
	//foreach attrName in aLLCTI.allDiscrepancyAttributes do
	if not attrName.isMeasurementType  then							    	//09/12/2014 cnwma1 PAR #35358
		newAttrName :=attrName;
	else
		attrName.getRowNameMeasureType(newAttrName,measureType);
	endif;
	
		intCol := self.tblData.getColumnByRowName(attrName);
		if aLLCTI.allDiscrepancyAttributes.includes(newAttrName) then		//09/12/2014 cnwma1 PAR #35358
			self.tblData.accessCell(_tableRow, intCol).foreColor := Red;
			self.tblData.accessedCell.fontBold := true;
			self.tblData.accessedCell.fontUnderline := true;
			self.tblData.accessedCell.fontItalic := true;
			if self.tblData.accessedCell.text.trimBlanks = "" then
				self.tblData.accessedCell.text := "???";
			endif;
		else
			self.tblData.accessCell(_tableRow, intCol).foreColor := 0;
			self.tblData.accessedCell.fontBold := false;
			self.tblData.accessedCell.fontUnderline := false;
			self.tblData.accessedCell.fontItalic := false;
		endif; 
	endforeach;	
	
	//26 Apr 2010	NDL	Par 23912
	if not aLLCTI.allDiscrepancyAttributes.isEmpty and aLLCTI.allDiscrepancyAttributes.includes(ETRow_VoyageCode) then
		self.hasVoyageDiscreps := true;
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_tableRow" type="Integer"/>
        <Parameter name="_ediLLTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="create" id="513ff682-4572-4f88-bad4-46b63d405c8c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmLoadListCompView;
	self.permissionMaint := PmAdmLoadListCompMaint;
	
	create self.myLLCAgent transient;
	self.helpFileName := HelpFile_Voyage;	
	self.height := 550; //cnwrs1 CCMS1137 8 July 2010
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f2e45aac-237d-4cfe-a660-98590f8ab384">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 16/03/2015	cnwmh5	Transient Leaks
vars

begin
	
	//need to purge a few collections of proxies here
	self.myLLCAgent.allUnmatchedDBTIs.purge;
	self.myLLCAgent.allDiscrepancyTIs.purge;
	self.myLLCAgent.allMatchingTIs.purge;
	//don't do the unmatched list tis - these are persistent;
	delete self.myLLCAgent;
	self.allIgnoreFieldsObjects.purge; //cnwrs1 CCMS 1137 15 June 2010
	self.allUpdateFieldsObjects.purge; //cnwrs1 CCMS 1137 15 June 2010
	self.allTranshipFieldsObjects.purge();			// 16/03/2015 cnwmh5
end;</source>
    </JadeMethod>
    <JadeMethod name="displayEDITIs" id="1922f726-89c5-4d37-95a4-6760f515c8cf">
        <updating/>
        <source>displayEDITIs(_ediTIs: Collection; _isRefresh : Boolean; _viewMode : String) updating;				//navra1 - MTN-36125 - 24th Sep 2025
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isInvalid	: Boolean;								// cnwrl1 10/08/2010 PAR 24337
	iEdition	: Integer;								// cnwrl1 10/08/2010 PAR 24337
	object		: Object;								// cnwrl1 11/08/2010 PAR 24337
	aLLTI	: CM_EDILoadListTI;
	ediLLComparison	: CM_EDILoadListComparisonTI;		// cnwrl1 10/08/2010 PAR 24337
	aDisTI	: CM_EDITrackedItem;
	idx		: Integer;
	ediTI	: Any;
	ti : CM_TrackedItem;
	count : Integer; //fix up counts cnwrs1 June 2007
	column: Integer;
	duplicateCondition,
	foundIt	: Boolean;
	cellText : String;	//19 May 2010	NDL	Par 24243
	exportString : String;	//19 May 2010	NDL	Par 24243
	intransitString : String;	//19 May 2010	NDL	Par 24243
	imexStr : String;			//navra1 - MTN-36125 - 24th Sep 2025
	currPortDestCode : String;	//navra1 - MTN-36125 - 24th Sep 2025
	comparisonMode : Integer;	//navra1 - MTN-36125 - 24th Sep 2025
	startRow : Integer;			//navra1 - MTN-36126 - 24th Sep 2025
	endRow : Integer;			//navra1 - MTN-36126 - 24th Sep 2025
	rowIndex : Integer;			//navra1 - MTN-36126 - 24th Sep 2025
	visibleCount : Integer;		//navra1 - MTN-36126 - 24th Sep 2025
	
begin
	on Exception do app.handleDeletedObject( exception, object, isInvalid );	// cnwrl1 11/08/2010 PAR 24337
	
	if _isRefresh then
		self.reColourRows();
	else
		self.tblData.rows := 1;
	endif;				//ccms 1069
	
	//19 May 2010	NDL	Par 24243
	intransitString := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_REMAINONBOARD);
	exportString := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_EXPORT);
	
	foreach ediTI in _ediTIs do
		// cnwrl1 10/08/2010 PAR 24337 - start of coding
		// Check availability by doing a de-reference
		object		:= ediTI.Object;
		iEdition	:= object.edition();
		if isInvalid then
			self.myLLCAgent.validateAgentReferences( object );
			isInvalid	:= false;	// allow the next one to be OK!
			continue;				// skip this one and continue around loop
		endif;
		// cnwrl1 10/08/2010 PAR 24337 - end of coding
		
		if CM_EDILoadListTI.hasInstance(ediTI.Object) then
			aLLTI := ediTI.CM_EDILoadListTI;
			
			//navra1 - MTN-36125 - 24th Sep 2025 - start
			if self.context = "AUTO" then
				//Do you want to show it or not when opening from the AutoVoyageProgress screen?
				currPortDestCode := self.myLLCAgent.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();
				imexStr := aLLTI.getDisplayStringForAttribute(ETRow_ImexStatus, true);				
				comparisonMode := self.myLLCAgent.comparisonMode;
				
				if _viewMode = self.VIEW_NOT_IN_LIST then													//Not in load list view
					if comparisonMode = TI_IMEX_STATUS_IMPORT then											//ie.DISCHARGE_COMPARISON					
						if imexStr &lt;&gt; "Import" and imexStr &lt;&gt; "Tranship" then								//skip anything other than that
							continue;
						else
							if aLLTI.dischargePort &lt;&gt; currPortDestCode then									//skip import and tranship if dischargeport is not current port
								continue;
							endif;
						endif;					
					else																					//ie.LOAD_COMPARISON					
						if imexStr &lt;&gt; "Export" and imexStr &lt;&gt; "Tranship" then								//skip anything other than that
							continue;
						else
							if aLLTI.loadPort &lt;&gt; currPortDestCode then										//skip export and tranship if loadport is not current port
								continue;
							endif;
						endif;												
					endif;
				endif;
			endif;				
			//navra1 - MTN-36125 - 24th Sep 2025 - end
			
			idx := 0;
			
			if self.tblData.findStringInColumn(aLLTI.getid,self.tblData.getColumnByRowName(ETRow_Id),idx) = null then 
				
				// cnwrl1 10/08/2010 PAR 24337 - start of coding
				if aLLTI.isKindOf( CM_EDILoadListComparisonTI ) then
					ediLLComparison	:= aLLTI.CM_EDILoadListComparisonTI;
					if ediLLComparison.myTrackedItem &lt;&gt; null then
						// Check availability by doing a de-reference
						object		:= ediLLComparison.myTrackedItem;
						iEdition	:= object.edition();
						if isInvalid then
							self.myLLCAgent.validateAgentReferences( object );
							isInvalid	:= false;	// allow the next one to be OK!
							continue;				// skip this one and continue around loop
						endif;
					endif;
				endif;
				// cnwrl1 10/08/2010 PAR 24337 - end of coding
				
				idx := self.tblData.addItem(aLLTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
				if (not self.myLLCAgent.allDuplicateTIsOnTerminal.includesKey(aLLTI.id)) then
					self.tblData.accessRow(idx).backColor := aLLTI.getRowColour();
				else
					self.tblData.accessRow(idx).backColor := LightRed;
				endif;
			
			// CCMS 1654 Highlight prenotified lines
				column := self.tblData.getColumnByRowName(ETRow_State);
				if column &gt; 0 then
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_NOTIFIED) then
						self.tblData.accessCell(idx, column).backColor := Yellow;
					endif;
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_TBA) then // TFS 45590
						self.tblData.accessCell(idx, column).backColor := Yellow; // TFS 45590
					endif;
				endif;
				
				//18 May 2010	NDL	Par 24243
				column := self.tblData.getColumnByRowName(ETRow_ImexStatus);
				if column &gt; 0 then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; null then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
				//
				column := self.tblData.getColumnByRowName(ETRow_VoyageCode);
				if column &gt; 0 and self.myLLCAgent.myVoyage &lt;&gt; null then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; self.myLLCAgent.myVoyage.code then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;

				self.tblData.accessRow(idx).itemObject := aLLTI;
				count := count + 1;
				aDisTI := aLLTI.getDiscrepTI();
			//added by cnwyl1 for par 12204
				if CM_EDILoadListTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	//this is correct
					idx := self.tblData.addItem(aDisTI.CM_EDILoadListTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDILoadListTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				elseif CM_EDICargoTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	//this is correct
					idx := self.tblData.addItem(aDisTI.CM_EDICargoTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDICargoTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				endif;
			else
				///////////////
				if (not self.myLLCAgent.allDuplicateTIsOnTerminal.includesKey(aLLTI.id)) then
					self.tblData.accessRow(idx).backColor := aLLTI.getRowColour();
				else
					self.tblData.accessRow(idx).backColor := LightRed;
				endif;
				
			
				column := self.tblData.getColumnByRowName(ETRow_State);
				if column &gt; 0 then
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_NOTIFIED) then
						self.tblData.accessCell(idx, column).backColor := Yellow;
					endif;
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_TBA) then // TFS 45590
						self.tblData.accessCell(idx, column).backColor := Yellow; // TFS 45590
					endif;
				endif;
				
				//19 May 2010	NDL	Par 24243
				column := self.tblData.getColumnByRowName(ETRow_ImexStatus);
				if column &gt; 0 then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; null then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
				
				column := self.tblData.getColumnByRowName(ETRow_VoyageCode);
				if column &gt; 0 and self.myLLCAgent.myVoyage &lt;&gt; null then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; self.myLLCAgent.myVoyage.code then
						//if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then //Voyage code would never match exportString or intransitString so have removed it.
						self.tblData.accessCell(idx, column).backColor := Yellow;
						//endif;
					endif;
				endif;

				self.tblData.accessRow(idx).itemObject := aLLTI;
				//count := count + 1;
				aDisTI := aLLTI.getDiscrepTI();
			
				if CM_EDILoadListTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	//this is correct
					idx := 0;
					self.tblData.findStringInColumn(aDisTI.CM_EDILoadListTI.getid,self.tblData.getColumnByRowName(ETRow_Id),idx);
					//self.tblData.removeItem(idx);
					//idx := self.tblData.addItem(aDisTI.CM_EDILoadListTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDILoadListTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				elseif CM_EDICargoTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	//this is correct
					idx := 0;
					//self.tblData.findStringInColumn(aDisTI.CM_EDIUserDefinedTI.getid,self.tblData.getColumnByRowName(ETRow_Id),idx);
					//self.tblData.removeItem(idx);
					idx := self.tblData.addItem(aDisTI.CM_EDICargoTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDICargoTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				endif;
				///////////////
			endif;
		// feb 2006 duplicates are tis not EDITis
		elseif ediTI.isKindOf(CM_TrackedItem) then
			ti := ediTI.CM_TrackedItem;
			foundIt := self.tblData.findStringInColumn(ti.id,self.tblData.getColumnByRowName(ETRow_Id),idx);
			if foundIt = null  or (foundIt and not _isRefresh) then					
				idx := self.tblData.addItem(self.getTIDisplayString(ti, self.tblData.allTblDataColPropertyNames));
			endif;
			
			if self.cmbView.text = self.VIEW_DUPLICATES then
				duplicateCondition := true;
				while duplicateCondition and idx &lt; self.tblData.rows do
					if self.tblData.accessRow(idx).backColor &lt;&gt; LightRed then
						duplicateCondition := false;
					else
						idx:=idx+1;
					endif;
				endwhile;
			endif;
			self.tblData.accessRow(idx).backColor := LightRed;
			self.tblData.accessRow(idx).itemObject := ti;
			count := count + 1;			
		endif;
	endforeach;
	
	//navra1 - MTN-36126 - 24th Sep 2025 - start
	if self.context = "AUTO" then
		if self.tblData.allowsColumnFilters then
			self.tblData.applyColumnFilter(self.allColumnFilters);
		endif;		
		endRow := self.tblData.rows;
		foreach rowIndex in (self.tblData.fixedRows + 1)  to endRow where self.tblData.rowVisible[rowIndex] do
			visibleCount := visibleCount + 1;			
		endforeach;
		self.staStatusBar.caption := app.getErrorString2(Total_Comparisons,count.String,self.cmbView.text.toLower)&amp; ". " &amp; (visibleCount).String &amp; " rows displayed";		//navra1 - MTN-36424 - 30th Oct 2025

	else
		self.staStatusBar.caption := app.getErrorString2(Total_Comparisons,count.String,self.cmbView.text.toLower);
	endif;
	//navra1 - MTN-36126 - 24th Sep 2025 - end
	
end;
</source>
        <Parameter name="_ediTIs" type="Collection"/>
        <Parameter name="_isRefresh" type="Boolean"/>
        <Parameter name="_viewMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEDITIsVoyagePorts" id="bb00590c-348b-4107-9577-88b7118b54d1">
        <updating/>
        <source>displayEDITIsVoyagePorts(_ediTIs: Collection; _isPort : Boolean; _isRefresh : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwas3	Initial creation

*/


vars

	aLLTI	: CM_EDILoadListTI;
	aDisTI	: CM_EDITrackedItem;
	idx		: Integer;	
	ediTI	: Any;
	ti : CM_TrackedItem;	
	column: Integer;
	cellText : String;	//18 May 2010	NDL	Par 24243
	exportString : String;	//18 May 2010	NDL	Par 24243
	intransitString : String;	//18 May 2010	NDL	Par 24243
begin
	if _isPort then
		if not _isRefresh then
			self.tblData.rows := 1;
		else
			self.reColourRows();
		endif;		
	endif;
	
	//18 May 2010	NDL	Par 24243
	intransitString := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_REMAINONBOARD);
	exportString := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_EXPORT);
	
	foreach ediTI in _ediTIs do
		if CM_EDILoadListTI.hasInstance(ediTI.Object) then
			aLLTI := ediTI.CM_EDILoadListTI;
			
			idx := 0;
			
			if self.tblData.findStringInColumn(aLLTI.getid,self.tblData.getColumnByRowName(ETRow_Id),idx) = null then 
				
			
				idx := self.tblData.addItem(aLLTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
				if (not self.myLLCAgent.allDuplicateTIsOnTerminal.includesKey(aLLTI.id)) then
					self.tblData.accessRow(idx).backColor := aLLTI.getRowColour();
				else
					self.tblData.accessRow(idx).backColor := LightRed;
				endif;
			
			
				column := self.tblData.getColumnByRowName(ETRow_State);
				if column &gt; 0 then
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_NOTIFIED) then
						self.tblData.accessCell(idx, column).backColor := Yellow;
					endif;
				endif;
				
				//18 May 2010	NDL	Par 24243
				column := self.tblData.getColumnByRowName(ETRow_ImexStatus);
				if column &gt; 0 then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; null then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
				column := self.tblData.getColumnByRowName(ETRow_VoyageCode);
				if column &gt; 0 and self.myLLCAgent.myVoyage &lt;&gt; null then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; self.myLLCAgent.myVoyage.code then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
			
				if _isPort then
					column := self.tblData.getColumnByRowName(ETRow_DischargePort);
				else
					column := self.tblData.getColumnByRowName(ETRow_MyTranshipToPort);
				endif;
			
				if column &gt; 0 then
					self.tblData.accessCell(idx, column).fontItalic := true;
					self.tblData.accessCell(idx, column).foreColor := Red;				
				endif;

				self.tblData.accessRow(idx).itemObject := aLLTI;
				
				aDisTI := aLLTI.getDiscrepTI();
			
				if CM_EDILoadListTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	
					idx := self.tblData.addItem(aDisTI.CM_EDILoadListTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDILoadListTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				elseif CM_EDICargoTI.hasInstance(aDisTI) then
					self.numOfDiscrepTI := self.numOfDiscrepTI + 1;
					self.colourDiscreps(idx, aLLTI);	
					idx := self.tblData.addItem(aDisTI.CM_EDICargoTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.CM_EDICargoTI.getRowColour();
					self.tblData.accessRow(idx).itemObject := aDisTI;
				endif;
			else
				//////////////
				if (not self.myLLCAgent.allDuplicateTIsOnTerminal.includesKey(aLLTI.id)) then
					self.tblData.accessRow(idx).backColor := aLLTI.getRowColour();
				else
					self.tblData.accessRow(idx).backColor := LightRed;
				endif;
			
			
				column := self.tblData.getColumnByRowName(ETRow_State);
				if column &gt; 0 then
					if self.tblData.accessCell(idx, column).text = app.stateEnumToString(TI_STATE_NOTIFIED) then
						self.tblData.accessCell(idx, column).backColor := Yellow;
					endif;
				endif;
				//////////////
				
				//18 May 2010	NDL	Par 24243
				column := self.tblData.getColumnByRowName(ETRow_ImexStatus);
				if column &gt; 0 then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; null then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
				column := self.tblData.getColumnByRowName(ETRow_VoyageCode);
				if column &gt; 0 and self.myLLCAgent.myVoyage &lt;&gt; null then
					cellText := self.tblData.accessCell(idx, column).text;
					if cellText &lt;&gt; self.myLLCAgent.myVoyage.code then
						if cellText &lt;&gt; exportString and cellText &lt;&gt; intransitString then
							self.tblData.accessCell(idx, column).backColor := Yellow;
						endif;
					endif;
				endif;
				
				if _isPort then
						column := self.tblData.getColumnByRowName(ETRow_DischargePort);
						if column &gt; 0 then
							self.tblData.accessCell(idx, column).fontItalic := true;
							self.tblData.accessCell(idx, column).foreColor := Red;			
						endif;
				else
						column := self.tblData.getColumnByRowName(ETRow_MyTranshipToPort);
						if column &gt; 0 then
							self.tblData.accessCell(idx, column).fontItalic := true;
							self.tblData.accessCell(idx, column).foreColor := Red;			
						endif;
				endif;
				///////////
				
				
			endif;
		
		elseif ediTI.isKindOf(CM_TrackedItem) then
			ti := ediTI.CM_TrackedItem;
			idx := self.tblData.addItem(self.getTIDisplayString(ti, self.tblData.allTblDataColPropertyNames));
			self.tblData.accessRow(idx).backColor := LightRed;
			self.tblData.accessRow(idx).itemObject := ti;
			
		endif;
	endforeach;

	//self.staStatusBar.caption := "Total " &amp; self.tblData.rows.String &amp; " " &amp; "voyage details discrepancies";
	self.staStatusBar.caption := app.getErrorString1(Total_voyage_details_discrep,(self.tblData.rows - 1).String);
	

end;</source>
        <Parameter name="_ediTIs" type="Collection"/>
        <Parameter name="_isPort" type="Boolean"/>
        <Parameter name="_isRefresh" type="Boolean"/>
    </JadeMethod>
