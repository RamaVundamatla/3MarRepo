<Class name="XLAT_TranslatableText" id="6caa0858-fdd1-4df6-9557-c14a5977961e">
    <superclass name="XLAT_TranslationEnties"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Equivalent of Jade's TranslatableString class, stores translations in allTextByLocale
Loaded from global constants from category (see myConstantCategoryName)

Text on the global constant is in the following format
&lt;?xml version="1.0"?&gt;
&lt;ErrorMsg&gt;
&lt;LocaleMsg name="0000"&gt;
	&lt;Msg&gt;This is the message for the default locale&lt;/Msg&gt;
	&lt;ShortMsg&gt;This is the default locale short message&lt;/ShortMsg&gt;   ---- XLAT_ErrorMessage only
&lt;/LocaleMsg&gt;
&lt;/ErrorMsg&gt;</text>
    <DbClassMap file="translation"/>
