    <JadeMethod name="btnClose_click" id="1af2acc4-62b6-4232-847a-869587ce0212">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Steverdore Data Access
//
vars

begin
	self.unloadForm;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="8fe79558-57b3-4f23-aa06-0c018d13674a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 
vars
	warningButton: Integer;
	warningMsg: String;
	form : CMUI_TxnResyncWarning;
begin
	// navsj20 TFS 53522
	if self.doResyncWarning and self.myTerminal.getConfig(AllowTransResyncForAmt).Boolean and (self.chkRPvolume.value or self.chkRPweight.value or self.chkRPquantity.value)then
		form := app.loadForm(CMUI_TxnResyncWarning, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_TxnResyncWarning;
		if form = null then
			return;
		endif;
		form.showModal();
		
		if form.modalResult = IDOK then
			self.doBtnSaveClick();
		endif;
	else
		self.doBtnSaveClick();
	endif;
	// navsj20 TFS 53522
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSelectAll_click" id="3c773e1b-7435-4902-8a30-68ee7e2c8b1b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectAll_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 04/04/2023	navmk20 	Task 57433: Country of Origin - Transactions Resync
// 20/06/2023	navkc1		CR 55653 Task 58724: EUP - Re evaluate Contract Id
//
vars
	torf : Boolean;

begin
	torf := not self.chkRPbusUnit.value;
	if torf then
		self.btnSelectAll.bubbleHelp := "Unselect All";
	else
		self.btnSelectAll.bubbleHelp := "Select All";
	endif;

	self.chkRPbusUnit.value := torf;
	self.chkRPdestPort.value := torf;
	self.chkRPcomm.value := torf;
	self.chkRPcon.value := torf;
	self.chkRPconor.value := torf;
	self.chkRPcontents.value := torf;
	self.chkRPcustAg.value := torf;
	self.chkRPdischPort.value := torf;
	self.chkRPimex.value := torf;
	self.chkRPoperator.value := torf;
	self.chkRPLength.value := torf;
	self.chkRPfreightForwarder.value := torf;
	self.chkRPstevedore.value := torf;
	self.chkRPtrailerType.value := torf;	//29 Oct 2020	NDL	TFS 50113
	self.chkRPshippingLine.value := torf; // ### TFS BUG 56663 23FEB2023 NAVAB1
	self.chkRPCountryOfOrigin.value := torf;	//4.4.2023 navmk20 TFS 57433
	self.chkRPContractId.value := torf;	//20/06/2023	navkc1	CR 55653 Task 58724
	self.chkRPHSCode.value := torf; //04/10/2024	navkc1	JIRA 32999
	
	// for quantity, weight and volume check whether they're enabled before setting
	if self.chkRPquantity.enabled then
		self.chkRPquantity.value := torf;
	endif;
	if self.chkRPvolume.enabled then
		self.chkRPvolume.value := torf;
	endif;
	if self.chkRPweight.enabled then
		self.chkRPweight.value := torf;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkRPLog_change" id="c09bb5e4-2c6e-47af-ba5c-424f63a6f05b">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkRPLog_change(checkbox: CheckBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	self.chkReadOnly.enabled := self.chkRPLog.value;
	self.chkReadOnly.value := self.chkRPLog.value;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="f2744389-6477-40b8-a470-7d0cc373e797">
