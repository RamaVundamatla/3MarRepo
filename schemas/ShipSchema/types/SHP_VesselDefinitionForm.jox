    <JadeMethod name="resetLstResourceTables" id="e016e87b-1cab-49c5-b11d-e7c2d3c3d82a">
        <source>resetLstResourceTables();
// ---------------------------------------------------------------------------
// Created:     29 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	assistant : CMUI_Assistant;
begin

	assistant := self.myAssistant;

	self.lstResTypeArriva.clearAllSelected();
	self.lstResTypeShift.clearAllSelected();
	self.lstResTypeDepart.clearAllSelected();
	
	self.lstResTypeArriva.rows := self.lstResTypeArriva.fixedRows;
	self.lstResTypeDepart.rows := self.lstResTypeDepart.fixedRows;
	self.lstResTypeShift.rows := self.lstResTypeShift.fixedRows;
	
	assistant.listTableResouceType(self.lstResTypeArriva);
	assistant.listTableResouceType(self.lstResTypeShift);
	assistant.listTableResouceType(self.lstResTypeDepart);	
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeMsgVesselAllocs" id="619caf3c-7234-48f1-8d55-3055be8987a0">
        <source>resizeMsgVesselAllocs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/06/2025	navkc1 JIRA MTN 34963 MTN | Missing Text Filter Box in Vessel Definition Form

*/

vars

begin
	self.grpVesselAllocsNew.left := 0;
	self.grpVesselAllocsNew.width := self.shtVesselAlloc.width;
	self.grpVesselAllocsNew.top := 0;
	self.grpVesselAllocsNew.height := self.shtVesselAlloc.height;
	self.msgVesselAlloc.width := self.grpVesselAllocsNew.width - 10;
	self.msgVesselAlloc.height := self.grpVesselAllocsNew.height - 50;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAddEditDelBtnState" id="fa906e94-ff2f-491e-98fb-94c6ee4ca7d8">
        <updating/>
        <source>setAddEditDelBtnState() updating;

vars

begin

 	// This method sets the Add and Delete button states according to 
 	// selectedShip&lt;&gt;null and a selected row in the tblBerthPref
 	if self.mode = self.Mode_View then
 		// Ship not yet saved in DB - Set Add, Edit, Delete to disabled
 		self.btnAddBerthPref.enabled := false;
 		self.btnDeleteBerthPr.enabled := false;
 	else
 		// Ship is saved in DB
 		self.tblPrefBerth.column := 1;
		if self.mode = self.Mode_Add
		or self.mode = self.Mode_Update then 		
			if self.tblPrefBerth.row &gt; 1 then
	 			self.btnAddBerthPref.enabled := true;
	 			self.btnDeleteBerthPr.enabled := true;	
	 		else
	 			self.btnAddBerthPref.enabled := true;
	 			self.btnDeleteBerthPr.enabled := false;
	 		endif;
	 	endif;
 	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaptionsForHarbour" id="47a90337-f326-45ff-915e-267588763368">
        <updating/>
        <source>setCaptionsForHarbour(_harbour : HMS_Harbour)protected, updating;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpStr : String;
	
begin
	if (not self.shtHMSHarbour.visible)  then
		return;
	endif;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	self.shtHMSBerthage.caption		:=app.getErrorString(Berthage);
	self.shtHMSMoveRes.caption		:=app.getErrorString(Resource_types);		
	self.shtHMSHarbour.caption		:=app.getErrorString(Harbour);
	self.lblPilotRemarks.caption	:=app.getErrorString(Pilot_remarks);
	
	if _harbour &lt;&gt; null then
		tmpStr	:=	' (' &amp; _harbour.code &amp; ')';
		self.shtHMSBerthage.caption		:=	self.shtHMSBerthage.caption &amp;  tmpStr;
		self.shtHMSMoveRes.caption		:=	self.shtHMSMoveRes.caption &amp; tmpStr;
		self.shtHMSHarbour.caption		:=	self.shtHMSHarbour.caption &amp; tmpStr;
		self.lblPilotRemarks.caption	:=	self.lblPilotRemarks.caption &amp; tmpStr;	
	endif;
	
	
// cnwdad1 25/06/2007 - PAR #14320: This method gets called frequently, and some weird shit was happening
// causing the _harbour parameter to be null, hence all of the Harbour details were being ignored for the
// display and when saving the Vessel Definition.
	if _harbour = null and cmbHarbourVD.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.myCurrentHarbour	:=	cmbHarbourVD.listObject.HMS_Harbour;
	else
		self.myCurrentHarbour	:=	_harbour;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="90a332f3-40be-42f6-837b-24becad581c3">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	20 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.tblDimensions.accessRow(1).backColor := self.colorHeadingColumn;	

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="c050c39d-de1a-4134-9308-9ba031c38892">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 26 Mar 2013	PJS			PAR # 31232
// ---------------------------------------------------------------------------
begin
	self.setEnableObjects(true);	
	self.ckbCreateHMSData.value	:=	(self.shtHMSHarbour.visible );
	
	if self.mode = Mode_Add then
		self.tblPrefBerth.rows := self.tblPrefBerth.fixedRows;		
		// set defaults
		self.cmbAccessType.listIndex := 2;
		
			// PAr # 31232
	//	self.myAssistant.comboBoxVesselStructureType(self.cmbStructureType, null);
		
		self.setCaption(app.getErrorString(Vessel_Definition));
		self.setNavigatorHeading(self.caption);	

		self.btnExtractImage.enabled := false;
		
	elseif self.mode = Mode_Update then
		
		// PAR # 31232
	
	//	if self.cmbStructureType.text = CellularStructureStr or
	//	   self.cmbStructureType.text = CellularStructureROROStr then	// PAR 21745 CCMS MES 1031
		  
		//PAr #31232 - allow changes 
	//	if tblCargoStruct.getValueByName(ETRow_IncludesLOLO).Boolean or
	//		tblCargoStruct.getValueByName(ETRow_IncludesRORO).Boolean then   
		   
	//		self.cmbStructureType.enabled := false;
	//	endif;
				
// PAR 36959		self.ckbCreateHMSData.enabled := self.myCurrentVessel.myHMSVesselData = null;
		self.ckbCreateHMSData.enabled := not self.myCurrentVessel.hasHarbourDetails();
		self.ckbCreateHMSData.value		:=	self.myCurrentVessel.hasHarbourDetails();
	endif;

	self.btnEdit.enabled := false;
	self.btnNew.enabled := false;	
	self.cmbVessel.enabled := false;
	self.btnDelete.enabled := false;
	self.btnSaveBase.enabled := true;

	self.btnImport.enabled := false;
	self.btnExport.enabled := false;
	self.btnCopy.enabled := false;	
	self.btnCancelBase.enabled := true;	
	self.btnBayDefinition.enabled := false;		
	self.btnEventAlloc.enabled := false;		//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	self.btnRoRoDeckDef.enabled := false;		// PAR 27458
	self.btnHoldDef.enabled := false;

	self.setEnableHMSData(self.ckbCreateHMSData.value);

end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentVesselTerminal" id="ac2c147c-e368-4517-b1a5-a56253d99eb9">
        <source>setCurrentVesselTerminal() protected;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Sets up the form for the Vessel's currently selected Terminal.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalDataObj	: CM_VesselTerminalData;
	cloneTDObj		: CM_VesselTerminalData;
	
begin
	self.aAllTerminalDatas.purge();
	
	if self.myCurrentVessel &lt;&gt; null then
		foreach terminalDataObj in self.myCurrentVessel.allTerminalDatas do
			cloneTDObj	:=	terminalDataObj.cloneMe(true);	
			self.aAllTerminalDatas.add(cloneTDObj);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnableHMSData" id="fc094b3b-90ea-491d-87fe-de95b0625abc">
        <source>setEnableHMSData(_enable : Boolean);
//--------------------------------------------------
// Created:	06 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.shtHMSBerthage.enabled		:=	_enable;
	self.shtHMSHarbour.enabled		:=	_enable;
	self.shtHMSMoveRes.enabled		:=	_enable;

	if self.mode = self.Mode_View then
		self.txtRemarkGeneral.readOnly	:=	true;		
		self.txtRemarksPilot.readOnly	:=	true;	
	else
		self.txtRemarkGeneral.readOnly	:=	(not _enable);		
		self.txtRemarksPilot.readOnly	:=	(not _enable);	
	endif;
	
	self.grpPropellorType.enabled	:=	_enable;
	self.ckbBowThrusters.enabled	:=	_enable;	
	self.ckbHasRamps.enabled		:=	_enable;	
	self.ckbHoldTanks.enabled		:=	_enable;	
	self.ckbSternThruster.enabled	:=	_enable;							

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="1647bec3-77e5-4b0b-aef5-5f52e8e4b27c">
        <updating/>
        <source>setEnableObjects(_enable : Boolean)updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//
// 26 Mar 2013	PJS		PAR # 31232
//-----------------------------------------
vars

	
begin
	self.enableAllControls(_enable);
	
	
	//31232
	tblVesselStruct.enabled := (_enable);
	
	
	self.cmbHarbourVD.enabled	:=	true;

	
	if self.shtHMSHarbour.visible  then
		// Licensed for Harbour module
// cnwdad1 24/03/2006 - PAR #11479.
		self.txtPreviousNames.readOnly	:=	(not _enable);
		
		if (not app.myCurrentUserCan(self.myTerminal, PmHMSPilotView)) then
			self.txtRemarksPilot.visible	:=	false;
			self.lblPilotSecurity.visible	:=	true;
		else
			self.lblPilotSecurity.visible	:=	false;
		endif;
		
	endif;

	self.txtClonedVessel.enabled			:=	false;
	
	//epr TFS 3614 10/4/17 removed waiting costs -old Voyage Commodity planning
	
	//epr ccms 1031 - 19/4/2011
	self.btnExtRampAdd.enabled:=true;
	self.btnExtRampDelete.enabled:=true;
	self.btnExtRampUpdate.enabled:=true;
	
	self.btnTankAdd.enabled:=true;
	self.btnTankDelete.enabled:=true;
	self.btnTankUpdate.enabled:=true;
	
	self.btnSectionsAdd.enabled:=true;
	self.btnSectUpdate.enabled:=true;
	self.btnSectDelete.enabled:=true;
	
	self.msgVesselAlloc.userInputEnabled := _enable; //13/06/2025	navkc1 JIRA MTN 34963
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMeterMarks" id="3bbf1916-6678-4649-861f-5f25ef350ac5">
        <updating/>
        <source>setMeterMarks(bowMark : Decimal io; _rowIdx : Integer; _berthChange : Boolean)updating;
//-----------------------------------------
// Created: December 2004 By: cnwgd1
//-----------------------------------------
vars
	sideTo,
	colBerth	: Integer;
	loa 		: Decimal[6,2];
	bridgeToBow,
	sternMark,
	bridgeMark	: Decimal[12,2];
	tmpStr		: String;
	berthForMarks,
	tmpBerth	: HMS_Berth;
	tmpTable : Table;
	tmpCombo : ComboBox;
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	if _rowIdx &lt; 2 then
		return;
	endif;

	tmpTable := self.tblPrefBerth;
	
	colBerth := self.tblPrefBerth.getColumnByRowName(ETRow_MyBerth);
	tmpCombo := tmpTable.accessCell(_rowIdx, colBerth).cellControl.ComboBox;	
	tmpBerth := tmpCombo.listObject.HMS_Berth;
	if tmpBerth = null then
		return;
	endif;	
	loa := self.getDimensionValue(ETRow_LengthOverall).Decimal;		
	
	if loa &lt; 1 then
		app.msgBox(app.getErrorString3(VesselData_Dimension, app.getErrorString(Length_overall), LOA_LowerLimit.String, LOA_UpperLimit.String), app.getErrorString(Error_no_loa), MsgBox_OK_Only+MsgBox_Stop_Icon);
		self.lastValidRow := 0;
		self.fldVessel.topSheet := self.shtVesselDetails;
		self.tblDimensions.setFocus();
		return;
	endif;			
	// Bridge to Bow
	bridgeToBow := self.getDimensionValue(ETRow_BridgeToBow).Integer;	
	
	tmpStr := tmpTable.accessCell(_rowIdx, 2).text;
	if tmpStr = app.getErrorString(StarboardSideToBerth) then
		sideTo := OrientStarboardSideTo;
	else
		sideTo := OrientPortSideTo;		
	endif;
	
	if _berthChange then
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);	
	else		
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	endif;

	tmpTable.accessCell(_rowIdx, 5).text := sternMark.asStringJMT;
	tmpTable.accessCell(_rowIdx, 4).text := bridgeMark.asStringJMT;
	tmpTable.accessCell(_rowIdx, 3).text := bowMark.asStringJMT;
	tmpTable.accessedCell.cellControl.TextBox.text := bowMark.asStringJMT;
	
	if tmpBerth &lt;&gt; berthForMarks then
		// reselect berth for marks	
		tmpCombo.listIndex := tmpCombo.findObject(berthForMarks);
		tmpTable.accessCell(_rowIdx, colBerth).text := tmpCombo.text;		
	endif;

end;</source>
        <Parameter name="bowMark" type="Decimal" usage="io"/>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_berthChange" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVessel" id="d8295191-705b-4c1e-bfcc-5422cb4e97be">
        <updating/>
        <source>setMyCurrentVessel(_vessel : CM_Vessel)updating;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//
// 26 Mar 2013	PJS		PAR # 31232
//--------------------------------------------------
//Used for both the persistant and transient object
vars
	unavailabilityObj	: CM_VesselUnavailability;
	clonedObj			: CM_VesselUnavailability;
	
begin
	self.myCurrentVesselData		:=	null;
	self.myCurrentCellularVessel	:=	null;
	
	self.endVesselStructureNotes();
	
	self.myCurrentVessel			:=	_vessel;
	
	
	if self.myCurrentVessel &lt;&gt; null and global.isValidObject(self.myCurrentVessel) then
		self.myCurrentVesselData	:=	self.myCurrentVessel.myHMSVesselData;
		//epr TFS 3614 10/4/17 removed waiting costs -old Voyage Commodity planning
	else
		self.setToViewMode(); 
	endif;
	
	self.displayVesselDetails(); //&lt;-- data cleared here if the current vessel is null
	
	self.startVesselStructureNotes();
	
	self.btnShippingAgent.enabled	:=	self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled	:=	self.cmbShippingLine.listObject &lt;&gt; null;			

	if self.myCurrentVessel &lt;&gt; null then
		self.btnBayDefinition.enabled	:=	self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null and not self.myCurrentVessel.myCellularVesselStructure.isTransient;
		// PAR # 31232
		//self.btnRoRoDeckDef.enabled:= (self.myCurrentVessel.structureType = CellularStructureRORO);
		self.btnRoRoDeckDef.enabled:= (self.myCurrentVessel.structureIncludesRORO);
		//09 Jul 2013	NDL	Par 31965
		self.btnHoldDef.enabled := self.myCurrentVessel.myGeneralCargoVesselStructure &lt;&gt; null and not self.myCurrentVessel.myGeneralCargoVesselStructure.isTransient;
		
	else
		self.btnBayDefinition.enabled	:=	false;
		self.btnRoRoDeckDef.enabled:= false;
		self.btnHoldDef.enabled := false;
	endif;
	
	self.setCurrentVesselTerminal();
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	self.doResizeTopSheet();
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageAllocationConfig" id="ac68f53b-bb4c-4028-bdf7-4cea5674912a">
        <source>setProxyVoyageAllocationConfig(_pxyVessel : CM_Vessel input) protected;
/*
Date		    Who			Reason
05 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	opCriteriaColl : CM_YACriteriaTypeArray;
	groupLabelCriteriaColl : CM_YACriteriaTypeArray;
	pxyVoyageAllocationConfig : CM_VoyageAllocationConfig;
	ct :  CM_YACriteriaType;
	ret : Integer;
begin
	
	
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	//self.getOpCriteriaColl(opCriteriaColl);
	self.msgVesselAlloc.parentCollectionRight.copy(opCriteriaColl); //13/06/2025	navkc1 JIRA MTN 34963
	
	if self.myVoyageAllocConfig &lt;&gt; null  then
		if self.myVoyageAllocConfig.isTransient then
			pxyVoyageAllocationConfig:=self.myVoyageAllocConfig;
		else
			pxyVoyageAllocationConfig := app.createUpdateProxy(self.myVoyageAllocConfig).CM_VoyageAllocationConfig;
		endif;
	else
		create pxyVoyageAllocationConfig transient;
	endif;
	
	//ct := self.getYACriteriaTypeByDescription(self.cmbDefaultColour.text);
	ct := self.cmbDefaultColour.listObject.CM_YACriteriaType; //13/06/2025	navkc1 JIRA MTN 34963

	pxyVoyageAllocationConfig.setProxyVoyage(opCriteriaColl,groupLabelCriteriaColl,Red,ct,null, null);	
	
	_pxyVessel.setVoyageAllocationConfig(pxyVoyageAllocationConfig);
	
	self.allProxies.add(pxyVoyageAllocationConfig);  //add to allProxies so they get cleared on doSave epilog
	
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVessel" type="CM_Vessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyBerthPrefOrder" id="9b15b64c-5e42-42f2-bc12-791cfc4a9b99">
        <source>setPxyBerthPrefOrder(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;

vars
	orientation,
	row,
	numRows,
	colBerth,
	colBowMark,
	colBridgeMark,
	colSternMark,
	colOrientation : Integer;
	loa : Decimal[6,2];
	bridgeToBow,	
	bowMark,
	bridgeMark,
	sternMark : Decimal[12,2];
	berthForMarks,
	berth : HMS_Berth;	
	tmpTbl : CM_DataTable;
	str : String;
	pxyBerthPref,
	berthPref : HMS_BerthPreferenceVesselData;
begin
 	// This method updates the berth preference order for the selectedShip
 	if self.mode = self.Mode_View then
 		return;
 	endif;
 	
 	if _pxyVesselDataHarbour = null then
 		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy');
 		return;
 	endif;
 	
	if not self.shtHMSBerthage.visible then
		return;
	endif;
	
 	tmpTbl := self.tblPrefBerth;
 	numRows := tmpTbl.rows;
	tmpTbl.column := 1;
	_pxyVesselDataHarbour.allBerthPrefByOrder.clear;

	colBerth := tmpTbl.getColumnByRowName(ETRow_MyBerth);
	colBowMark := tmpTbl.getColumnByRowName(ETRow_DefaultBowMark);
	colBridgeMark := tmpTbl.getColumnByRowName(ETRow_DefaultBridgeMark);
	colOrientation := tmpTbl.getColumnByRowName(ETRow_Orientation);

	//epr CCMS 1116 20/6/11 changes to the key distances table
	//LOA
	loa := self.getDimensionValue(ETRow_LengthOverall).Decimal;	
	// Bridge to Bow
	bridgeToBow := self.getDimensionValue(ETRow_BridgeToBow).Integer;	

	foreach row in 2 to numRows do
		
		berthPref := tmpTbl.accessRow(row).itemObject.HMS_BerthPreferenceVesselData;
		
		if berthPref = null then
			create pxyBerthPref transient;
		elseif berthPref.isTransient then
			pxyBerthPref := berthPref;
		else
			pxyBerthPref := berthPref.cloneMySelf(true);
		endif;

		if (not global.isValidObject(pxyBerthPref)) then
			continue;
		endif;				
		
		//bowMark := tmpTbl.accessCell(row, colBowMark).text.Decimal;
		bowMark := tmpTbl.accessCell(row, colBowMark).text.asDecimalJMT();	//01 APR 2010	NDL	Par 23556
		
		str := tmpTbl.accessCell(row, colOrientation).text;
		if str = app.getErrorString(StarboardSideToBerth) then
			orientation := OrientStarboardSideTo;
		else
			orientation := OrientPortSideTo;			
		endif;
		
		berth := tmpTbl.accessCell(row, colBerth).cellControl.ComboBox.listObject.HMS_Berth;

		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, orientation, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
		
		pxyBerthPref.setProxy(bowMark,	bridgeMark,	sternMark, orientation, berthForMarks, app.myPassport);

		if (not _pxyVesselDataHarbour.allBerthPrefByOrder.includes(pxyBerthPref)) then
			_pxyVesselDataHarbour.allBerthPrefByOrder.add(pxyBerthPref);
		endif;

	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyDefaultResources" id="ed08b3b9-f1e0-4bbe-a4b5-f2dcc911dbb0">
        <source>setPxyDefaultResources(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars

begin
	
	// Update resources set as default for a vessel
	if self.mode = self.Mode_View then
		return;
	endif;
	
	if _pxyVesselDataHarbour = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy');
		return;
	endif;

	if self.shtHMSMoveRes.visible then
		// They have the invoice system for harbour
		self.setPxyMovementResources(_pxyVesselDataHarbour);
  	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyHMSVessel" id="6437c2ba-2d7e-428f-a934-94914fb1ac19">
        <updating/>
        <source>setPxyHMSVessel(_theProxy : CM_Vessel input) updating, protected;
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpVDH,
	pxyVDH : HMS_VesselDataHarbour;
	pxyHMSVesselData : HMS_VesselData;
	
begin
	if (not self.shtHMSHarbour.visible)  then
		//Can't be Licensed for HMS
		return;
	endif;

	//Note: they can't change this field if the HMSVesselData already exists	
	if (not self.ckbCreateHMSData.value) then
		setPxyVesselDimensions( _theProxy ); //PAR 16596 cnwgb 9 May 2008
		return;
	endif;
	
	pxyHMSVesselData := _theProxy.myHMSVesselData;
	
	if pxyHMSVesselData = null then
		create pxyHMSVesselData transient;
		_theProxy.setHMSVesselData(pxyHMSVesselData);
	endif;

	pxyHMSVesselData.setPxyMyRoot(app.myRoot);

	self.setPxyVesselDataForHarbour();
	self.setPxyVesselData(pxyHMSVesselData);
	
	foreach pxyVDH in self.allProxyVessDataHarbour do
		tmpVDH := pxyHMSVesselData.allVesselDataForHarbour[pxyVDH.myHarbour];
		
		if tmpVDH = null then
			create tmpVDH transient;
			self.allProxies.add(tmpVDH);			
			pxyHMSVesselData.allVesselDataForHarbour.add(tmpVDH);						
		endif;
		
		// update system proxy from interface item
		if tmpVDH &lt;&gt; pxyVDH then
			tmpVDH.setProxyFromProxy(pxyVDH, app.myPassport);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_theProxy" type="CM_Vessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyMovementResources" id="e0840118-ee50-491c-a9b8-e02c4cf13169">
        <source>setPxyMovementResources(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;

vars
	numTugs : Integer;
	moveType : String;
	coll : ObjectArray;
	tmpHarbour : HMS_Harbour;
  	moveResource : HMS_ResourceTypeForMovement;
begin
  
	// This method updates invoice resources set as default for a vessel
	if (not self.shtHMSMoveRes.visible) then
		return;
	endif;
	
	if self.mode = self.Mode_View then
		return;
	endif;
	
	if _pxyVesselDataHarbour = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy');
		return;
	endif;
	
	create coll transient;
	tmpHarbour := _pxyVesselDataHarbour.myHarbour;
	
	// set default resources for the arrival movement
	moveType := HMSMovementTypeArrival;
	numTugs := self.txtTugsMArrival.text.Integer;
	if self.lstResTypeArriva.allSelectedObjects &lt;&gt; null then
		self.lstResTypeArriva.allSelectedObjects.copy(coll);
	endif;

	moveResource := _pxyVesselDataHarbour.allMovementResourcesByMovement[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyVesselDataHarbour.allMovementResourcesByMovement.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);
	
	// set default resources for the shift movement
	coll.clear();
	moveType := HMSMovementTypeShift;
	numTugs := self.txtTugsMShift.text.Integer;
	if self.lstResTypeShift.allSelectedObjects &lt;&gt; null then
		self.lstResTypeShift.allSelectedObjects.copy(coll);
	endif;
	
	moveResource := _pxyVesselDataHarbour.allMovementResourcesByMovement[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyVesselDataHarbour.allMovementResourcesByMovement.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);

	// set default resources for the departure movement
	coll.clear();
	moveType := HMSMovementTypeDeparture;
	numTugs := self.txtTugsMDepart.text.Integer;
	if self.lstResTypeDepart.allSelectedObjects &lt;&gt; null then
		self.lstResTypeDepart.allSelectedObjects.copy(coll);
	endif;
	
	moveResource := _pxyVesselDataHarbour.allMovementResourcesByMovement[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyVesselDataHarbour.allMovementResourcesByMovement.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);

epilog
	delete coll;  	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVessel" id="8477f40c-de5a-4b81-ab80-dcb25f920be7">
        <updating/>
        <source>setPxyVessel(_theProxy : CM_Vessel input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/* Changes

Date		Name	TFS#			Description
============================================================================
26 Mar 2013	PJS		PAR 3 31232
13 Jul 2017	cnwma1	TFS #4708		DQM - JMT GUI Glitch - PDC#399
04/03/2019	jlgka1	37102			STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyGCVessel				: CM_GeneralCargoVesselStructure;
	pxyROROVessel			: CM_ROROVesselStructure;
	realVessel				: CM_Vessel;
	proxyTerminalDataObj	: CM_VesselTerminalData;
	pxyStructElement		: CM_VesselStructuralElements;
	theLloydsNumber			: String;
	theClassLabel			: String;
	theRemarks				: String;
	theClonedFromVessel		: String;
	theCode					: String;
	theName					: String;
	theCallSign				: String;

	theOperator				: CM_Operator;
	theStructureType		: Integer;
	theCraneClearance		: Integer;
	theVesselType			: Integer;
	theCreateVoyages		: Boolean;
	yearOfBuild             : Integer; //ccms 1031
	theTrade				: CM_Trade;
	
	includesLOLO			: Boolean;  // 31232
	includesRORO			: Boolean;  // 31232
	includesHolds			: Boolean;  // 31232
	
	dim_loaWithRampsDown	: Decimal[6,2]; //ccms 1031
	dim_airDraft,
	dim_maxVesselBeam,
	dim_draftBow,
	dim_draftStern,
	dim_draftMid,
	dim_buildingLine		: Decimal[6,2];
	isBarge					: Boolean; // jlgka1 TFS 37102
begin
	theCode				:= self.txtVesselCode.text.removeTabCrLfs; //13/07/2017 cnwma1 TFS #4708
	theName				:= self.txtVesselName.text.removeTabCrLfs; //13/07/2017 cnwma1 TFS #4708
	theCallSign			:= self.txtCallSign.text.removeTabCrLfs;   //13/07/2017 cnwma1 TFS #4708
	theOperator			:= self.cmbOperatorNew.myObject.CM_Operator;
	theClassLabel		:= self.txtClass.text;
	theRemarks			:= self.txtRemarksVessel.text;
	theClonedFromVessel	:= _theProxy.clonedFromVessel;
	theCraneClearance	:= self.txtCraneClearanc.text.Integer;
	theLloydsNumber		:= self.txtLloydsNum.text;
//	theStructureType	:=	app.vesselStructureTypeStrToENum(self.cmbStructureType.text);  // 31232
	theVesselType		:= app.vesselAccessTypeStrToEnum(self.cmbAccessType.text);		
	theTrade			:= self.cmbTrade.myObject.CM_Trade; //epr 27/4 CCMS 1058
	theCreateVoyages	:= self.ckbCreateVoyages.value;
	isBarge				:= self.chkIsBarge.value; // jlgka1 TFS 37102
	
	////////cnwas3 ccms 1031
	yearOfBuild			:= self.txtYearOfBuild.text.Integer;	
	dim_loaWithRampsDown := self.getDimensionValue(ETRow_LoaWithRampsDown).Decimal;	
	dim_airDraft := self.getDimensionValue(ETRow_AirDraft).Decimal;
	dim_maxVesselBeam := self.getDimensionValue(ETRow_MaxVoyageBeam).Decimal;
	dim_draftBow := self.getDimensionValue(ETRow_DraftBow).Decimal;
	dim_draftStern := self.getDimensionValue(ETRow_DraftStern).Decimal;
	dim_draftMid := self.getDimensionValue(ETRow_DraftMid).Decimal;
	dim_buildingLine := self.getDimensionValue(ETRow_BuildingLine).Decimal;
	
	
	////////
	
	// PAR # 31232
	
	includesLOLO := tblVesselStruct.getValueByName(ETRow_IncludesLOLO).Boolean;
	includesRORO:= tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean;
	includesHolds := tblVesselStruct.getValueByName(ETRow_IncludesHolds).Boolean;
	
	
	////////

	_theProxy.setProxyForVessel(self.picVesselBitmap.picture,
								theCode,
								theName,
								theCallSign,
								theClassLabel,
								theRemarks,	
								theClonedFromVessel,
								theLloydsNumber,
								null,
								null,
								theCraneClearance,
								theVesselType,
								yearOfBuild,								
								dim_loaWithRampsDown,
								dim_airDraft,
								dim_maxVesselBeam,
								dim_draftBow,
								dim_draftStern,
								dim_draftMid,
								dim_buildingLine,
								theCreateVoyages,
								false,
								theOperator,
								theTrade,
								isBarge);
// General Cargo Structure - create proxy if needed
	pxyGCVessel	:=	_theProxy.myGeneralCargoVesselStructure;
	
	if pxyGCVessel = null then
		// 3132
		//if theStructureType = GeneralCargoStructure 
		if includesHolds 
		then
			create pxyGCVessel transient;
		endif;
	endif;
	
	//cnwrd1 31874
	pxyStructElement := _theProxy.myStructuralElements;
	
	if pxyStructElement = null then
		create pxyStructElement transient;
	endif;	
	
	
	// 31232
	if not includesHolds and pxyGCVessel &lt;&gt; null then
		delete pxyGCVessel;
	endif;
	
	if pxyGCVessel &lt;&gt; null then
		pxyGCVessel.setProxyGCVessel(app.myRoot, 0);
	endif;	
// Cellular Structure - create proxy if needed	
	// 31232 - change to specifically  check for LOLO only
//	if theStructureType = CellularStructure   or 
//		theStructureType = CellularStructureRORO then // PAR 21745 CCMS MES 1031

	// 31232 from here downwards
	pxyCellVessel := _theProxy.myCellularVesselStructure; //&lt;&lt;-- could be a JTV file load

	if includesLOLO then
	
		if pxyCellVessel = null then
			realVessel := _theProxy.pxyGetRealObject();
			
			if realVessel = null then
				create pxyCellVessel transient;
			elseif realVessel.myCellularVesselStructure = null then
				create pxyCellVessel transient;
			endif;
		endif;
		
		
	else
		if pxyCellVessel &lt;&gt; null then
			delete pxyCellVessel;
		endif;
		
		
		
	endif;


	// epr CCMS MES 1031 23/3/2011 par 27267 
	// PAR # 3132
	//if theStructureType = CellularStructureRORO then
	
	pxyROROVessel := _theProxy.myROROVesselStructure;
	
	if includesRORO then
		if pxyROROVessel = null then
			create pxyROROVessel transient;
			_theProxy.setMyROROVesselStructure(pxyROROVessel);
		endif;
	else
		if pxyROROVessel &lt;&gt; null then
			delete pxyROROVessel;
		endif;
	endif;
	
	// set references to the structures		
	_theProxy.setProxyVesselStructures(pxyGCVessel, pxyCellVessel, pxyStructElement);
	
	self.setProxyVoyageAllocationConfig(_theProxy);

	if self.shtHMSHarbour.visible  then
		//Save HMSVesselData
		self.setPxyHMSVessel(_theProxy);				
	else	
		self.setPxyVesselDimensions(_theProxy);
	endif;
	
	// Save Vessel Terminal data settings.
	foreach proxyTerminalDataObj in _theProxy.allTerminalDatas do
		if not self.aAllTerminalDatas.includes(proxyTerminalDataObj) then
			delete proxyTerminalDataObj;
		endif;
	endforeach;
	
	foreach proxyTerminalDataObj in self.aAllTerminalDatas do
		proxyTerminalDataObj.setVessel(_theProxy);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_theProxy" type="CM_Vessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVesselData" id="4de7fe6e-ecc1-4abb-b2ae-5fdaeb543f17">
        <source>setPxyVesselData(_pxyVesselData : HMS_VesselData input)protected;

vars
	countryCode : String;
	dim_Beam,
	dim_DraftAft,
	dim_DraftFore : Decimal[5,1];
 	dim_LengthOverall : Decimal[12,2];
	dim_DeadWeight,
 	dim_GrossRegTonnes,
	dim_NetRegTonnes,
 	dist_BowToFwdContainer,
 	dist_BridgeToBow,
 	dist_BridgeToStern,
 	dist_SternToAftContainer,
 	dist_SternToBunker : Integer;
	
begin
	if self.cmbCountryFlag.listObject &lt;&gt; null then
		countryCode := self.cmbCountryFlag.listObject.CM_Country.code;
	endif;

	dim_LengthOverall :=self.getDimensionValue(ETRow_LengthOverall).Decimal;	
	dim_GrossRegTonnes :=  self.getDimensionValue(ETRow_GrossRegTonnes).Integer; 
	dim_NetRegTonnes := self.getDimensionValue(ETRow_NetRegTonnes).Integer;
	dim_DeadWeight :=self.getDimensionValue(ETRow_DeadWeight).Integer;
	dim_Beam := self.getDimensionValue(ETRow_Beam).Decimal; 
	dim_DraftFore := self.getDimensionValue(ETRow_DraftFore).Decimal; 
	dim_DraftAft := self.getDimensionValue(ETRow_DraftAft).Decimal; 
	dist_BridgeToBow := self.getDimensionValue(ETRow_BridgeToBow).Integer;
	dist_BridgeToStern := self.getDimensionValue(ETRow_BridgeToStern).Integer;
	dist_BowToFwdContainer := self.getDimensionValue(ETRow_BowToFwdBay).Integer;
	dist_SternToAftContainer := self.getDimensionValue(ETRow_SternToAftBay).Integer;
	dist_SternToBunker := self.getDimensionValue(ETRow_SternToBunker).Integer;
		
	_pxyVesselData.setProxy(app.myRoot,
							self.ckbCoastalVessel.value,
							self.ckbIsTramper.value,	//_isTramper : Boolean;		//11 Sep 2018	NDL	TFS 40778
							self.ckbRequiresTow.value,	//21 Aug 2018	NDL	TFS 40347
							self.ckbBowThrusters.value,
							self.optPropFixed.value,
							self.ckbHoldTanks.value,
							self.ckbHasRamps.value,
							self.ckbSternThruster.value,
							self.txtRemarkGeneral.text,
							self.txtPreviousNames.text,
							countryCode,
							dim_Beam,
							dim_DraftAft,
							dim_DraftFore,
							dim_LengthOverall,
							dim_DeadWeight,
							dim_GrossRegTonnes,
							dim_NetRegTonnes,
							dist_BowToFwdContainer,
							dist_BridgeToBow,
							dist_BridgeToStern,
							dist_SternToAftContainer,
							dist_SternToBunker,
							self.cmbShippingLine.listObject.CM_ShippingLine,
							self.cmbShipType.listObject.HMS_VesselType);

end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselData" type="HMS_VesselData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVesselDataForHarbour" id="e69e4280-9ee8-4452-a965-bf670e478b75">
        <source>setPxyVesselDataForHarbour() protected;
//--------------------------------------------------
// Created:	22 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVDH : HMS_VesselDataHarbour;
	
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	if self.myCurrentHarbour = null then
		return;
	endif;

	tmpVDH := self.getPxyVesselDataHarbour();

	if tmpVDH = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy');
		return;
	endif;
	
	self.setPxyVesselDataHarbour(tmpVDH);
	self.setPxyDefaultResources(tmpVDH);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPxyVesselDataHarbour" id="0eeca09e-5e8e-4e8a-88e1-e671c21de8c7">
        <source>setPxyVesselDataHarbour(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;
//-----------------------------------------
// Created: 1 April 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpHarbour : HMS_Harbour;
	
begin
	if (not self.shtHMSBerthage.visible)  then
		return;
	endif;
	
	tmpHarbour := self.myCurrentHarbour;
	
	if tmpHarbour = null then
		self.cmbHarbourVD.setFocus();
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', null, null);
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _pxyVesselDataHarbour = null then
		return;
	endif;
	
	_pxyVesselDataHarbour.setProxy(	self.txtRemarksPilot.text,
									self.ckbVisitConfiden.value,
									self.ckbPilotExempt.value,
									self.txtEstTieUpTime.text.Integer,
									self.txtCrewLetGo.text.Integer,
									self.txtCrewTieUp.text.Integer,
									self.txtTugsArrive.text.Integer,
									self.txtTugsDepart.text.Integer,
									self.cmbBerthPriority.listIndex,
									self.txtNumVisits.text.Integer,
									tmpHarbour,
									self.cmbLineCompany.listObject.HMS_LineCompany,
									self.cmbShippingAgent.listObject.CM_ShippingAgent,
									self.cmbCatArrive.listObject.HMS_VesselCategory,
									self.cmbCatDepart.listObject.HMS_VesselCategory,
									self.cmbTidalClassAr.listObject.HMS_TidalClass,
									self.cmbTidalClassDpt.listObject.HMS_TidalClass);

	// Update the collection of berthPref order
 	self.setPxyBerthPrefOrder(_pxyVesselDataHarbour);
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVesselDimensions" id="7b903d50-b84b-4bbb-ae01-304b73c7e369">
        <source>setPxyVesselDimensions(_theProxy : CM_Vessel input);
// ---------------------------------------------------------------------------
// Created:		19 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyHMSVesselData : HMS_VesselData;
begin
	pxyHMSVesselData := _theProxy.myHMSVesselData;
	
	if pxyHMSVesselData = null then
		create pxyHMSVesselData transient;
		_theProxy.setHMSVesselData(pxyHMSVesselData);
	endif;
	self.setPxyVesselData(pxyHMSVesselData);
end;</source>
        <Parameter name="_theProxy" type="CM_Vessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRowTblPrefBerth" id="de4db0b9-9fb1-425a-b878-e50e281dddd0">
        <updating/>
        <source>setRowTblPrefBerth() updating;

vars

begin
	// Sets the selected row on tblPrefBerth
 	// Select first row if there are entries in the table
 	if self.tblPrefBerth.rows &gt; 1 then 
 		self.tblPrefBerth.row := 2;
 	endif;

 	// Set table button states
 	self.setAddEditDelBtnState();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="5fb74e94-7cf8-4f99-b557-16fabaae3ec0">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	_theTable.clearAllData;
	if _theTable = self.tblExtRamps then
		self.loadExternalRampTable;
	elseif _theTable = self.tblSections then
		self.loadSectionsTable();
	elseif _theTable = self.tblTanks then
		self.loadTankTable();
	else

		inheritMethod(_theTable);
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setToViewMode" id="c8f43612-4db9-44bf-b63c-a7b4c7f01625">
        <updating/>
        <source>setToViewMode() updating, protected;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
// 06 Mar 13	cnwpjs1		PAR # 31232
//--------------------------------------------------
begin
	if self.isFirstActivateComplete
	and self.mode = self.Mode_View
	then
		return;
	endif;
	
	self.mode := self.Mode_View;
	
	self.setEnableObjects(false);

	if (not self.viewModeOnly) then
		//epr 19/3/2008 par 16198 re-enabled par 16379
		self.btnDelete.enabled	:=	true ;
		self.btnEdit.enabled	:=	true;
		self.btnNew.enabled		:=	true;
		self.btnCopy.enabled	:=	true;
		self.btnImport.enabled	:=	true;
		self.btnExport.enabled	:=	true;	
	else
		self.btnDelete.enabled	:=	false;
		self.btnEdit.enabled	:=	false;
		self.btnNew.enabled		:=	false;
		self.btnCopy.enabled	:=	false;
		self.btnImport.enabled	:=	false;
		self.btnExport.enabled	:=	false;
		
		self.btnTankAdd.enabled:= false; // TFS 2198
		self.btnTankDelete.enabled:= false; // TFS 2198
		self.btnTankUpdate.enabled:= false; // TFS 2198
		self.btnSectDelete.enabled:= false; // TFS 2198
		self.btnSectUpdate.enabled:= false; // TFS 2198
		self.btnSectionsAdd.enabled:= false; // TFS 2198
		self.btnExtRampAdd.enabled:= false; // TFS 2198
		self.btnExtRampUpdate.enabled:= false; // TFS 2198
		self.btnExtRampDelete.enabled:= false; // TFS 2198
	endif;

	self.ckbCreateHMSData.enabled	:=	true;
	self.cmbVessel.enabled			:=	true;
	self.btnSaveBase.enabled		:=	false;
	self.btnCancelBase.enabled		:=	false;
	self.btnExtractImage.enabled	:=	self.picVesselBitmap.picture &lt;&gt; null;
	

	if self.myCurrentVessel &lt;&gt; null then
		self.btnBayDefinition.enabled	:=	self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null;
		// PAR # 31232
		//self.btnRoRoDeckDef.enabled:= (self.myCurrentVessel.structureType = CellularStructureRORO);
		self.btnRoRoDeckDef.enabled:= (self.myCurrentVessel.structureIncludesRORO);
		//09 Jul 2013	NDL	Par 31965
		self.btnHoldDef.enabled := self.myCurrentVessel.myGeneralCargoVesselStructure &lt;&gt; null;
		
		self.ckbCreateHMSData.enabled	:=	false; // PR 36959
		self.ckbCreateHMSData.value		:=	self.myCurrentVessel.hasHarbourDetails(); // PR 36959
		
	else
		self.ckbCreateHMSData.enabled	:=	true; // PR 36959
		self.btnBayDefinition.enabled	:=	false;
		self.btnRoRoDeckDef.enabled:= false;
		self.btnHoldDef.enabled := false;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="be70edce-16db-4f89-9d0d-4931bc59fd0d">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpIntArray	: IntegerArray;
	
begin
	inheritMethod();
	
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	

	create tmpIntArray transient;
	tmpIntArray.add(J_key_Tab);
	self.tblDimensions.registerKeys(tmpIntArray);
	self.tblDimensions.readOnly := false; //22/12/2010 cnwdz2 22327

	// show hide sheets before calling initForm();
//	self.viewModeOnly := (not app.myCurrentUserCan(null, PmShipDefinView));	
	self.viewModeOnly := (not app.myCurrentUserCan(null, PmShipDefinMaint));	//01 Jun 2016	NDL	TFS 2082	
	self.showHideSheetsForView();
	self.initForm();
	
epilog
	delete tmpIntArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideSheetsForView" id="75d3a61b-597b-4e69-a42e-64a136cfa592">
        <source>showHideSheetsForView();
//--------------------------------------------------
// Created:	09 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser : CM_User;
	
begin
	tmpUser := app.getMyUser();
	
	if tmpUser.canDo(self.myTerminal, Mod_Harbour) then 
		self.shtHMSBerthage.visible		:=	true;				
		self.shtHMSHarbour.visible		:=	true;
		self.shtHMSMoveRes.visible		:=	true;				
		self.grpDimensions.visible		:=	true;	
		
		
		self.txtPreviousNames.visible	:=	true;		
		self.txtRemarkGeneral.visible	:=	true;		
		self.txtRemarksPilot.visible	:=	true;		

		self.lblPilotSecurity.visible	:=	true;		
		self.lblPreviousNames.visible	:= true;
		self.lblGeneralRemark.visible	:= true;
		self.lblPilotRemarks.visible	:= true;		
	else
		self.shtHMSBerthage.visible		:=	false;		
		self.shtHMSMoveRes.visible		:=	false;		
		self.shtHMSHarbour.visible		:=	false;
		self.grpDimensions.visible		:=	true;
		self.txtPreviousNames.visible	:=	false;		
		self.txtRemarkGeneral.visible	:=	false;		
		self.txtRemarksPilot.visible	:=	false;		
		self.lblPilotRemarks.visible	:=	false;
		self.lblPilotSecurity.visible	:=	false;		
		self.lblGeneralRemark.visible	:=	false;		
		self.lblPreviousNames.visible	:=	false;	
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="showShipGraphicForm" id="4b7649de-4ac9-46ab-ada8-856b6216e2d1">
        <source>showShipGraphicForm();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		This form stores the polygons, used for drawing the side profile of a Vessel, into a graphic on the NULL voyage.
//
// ---------------------------------------------------------------------------

vars

begin
	if not app.isDevelopmentSystem then
		if not app.isSpecial() then
			return;
		endif;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	self.myAssistant.showGraphicCommandForm(self.myMasterMenuAction,0);

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="3b62d3dc-bfc4-4b9a-aacc-b35d41f0ddc5">
        <updating/>
        <source>showWithObjectMode(_object: CM_Object; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_object, _doMode);
	if CM_Vessel.hasInstance(_object) then
		self.myCurrentVessel := _object.CM_Vessel;
		self.startVesselStructureNotes;
	endif;

	if self.myCurrentVessel &lt;&gt; null then
		self.myCurrentVesselData := self.myCurrentVessel.myHMSVesselData;
		if _doMode then
			// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected vessel
			self.mode := self.Mode_Update;
		endif;
	elseif _doMode then
		// set to add mode. self.loadDataForFirstTime() will init form in add mode
		self.mode := self.Mode_Add;			
	endif;
	
	self.show();
		
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startVesselStructureNotes" id="25720ce0-94c2-4d4c-8791-f21b77266138">
        <updating/>
        <source>startVesselStructureNotes() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVesselStructure;
	//cellularStructure : CM_CellularVesselStructure;
	vesselStruct : CM_VesselStructuralElements;
begin
	if self.myCurrentVessel = null then
		return;
	endif;
	
	vesselStruct := self.myCurrentVessel.myStructuralElements;
	
	if vesselStruct &lt;&gt; null then
		self.beginNotification(vesselStruct,EVENT_TANK_CREATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_TANK_UPDATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_TANK_DELETE,Response_Continuous,null);
		
		self.beginNotification(vesselStruct,EVENT_SECTION_CREATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_SECTION_UPDATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_SECTION_DELETE,Response_Continuous,null);

		self.beginNotification(vesselStruct,EVENT_DECK_ITEM_CREATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_DECK_ITEM_UPDATE,Response_Continuous,null);
		self.beginNotification(vesselStruct,EVENT_DECK_ITEM_DELETE,Response_Continuous,null);
		
		
		self.notesRoRo := true;	//30 May 2012	NDL	Par 29645
		
	endif;
	
	roroStructure:=self.myCurrentVessel.myROROVesselStructure ;
	if roroStructure &lt;&gt; null then
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_CREATE,Response_Continuous,null);
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_UPDATE,Response_Continuous,null);
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_DELETE,Response_Continuous,null);
		
		self.notesRoRo := true;	//30 May 2012	NDL	Par 29645
		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
