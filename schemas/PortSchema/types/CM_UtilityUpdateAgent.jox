    <JadeMethod name="utlUpdateEDITIStatus" id="16e60c78-bfa6-4e9f-a0b2-1800d55a1273">
        <updating/>
        <source>utlUpdateEDITIStatus(_ediTI: CM_EDITrackedItem input; _status: Integer; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 04/09/2012	cnwcs5		par 30064 - no need to audit changes made by setStatus. Removed auit calls as performace tweak
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
vars

begin

	self.exclusiveLock(_ediTI);
	if not tryLock(_ediTI.myEDIData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediTI.myEDIData.ediConfig.allEDITrackedItemsByIdStatus);
	endif;
	
	_ediTI.setStatus(_status);
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIVGMTI" id="e691a553-5352-474a-aee2-7d90e714a009">
        <updating/>
        <source>utlUpdateEDIVGMTI(_ediTI : CM_EDIVGMTI io; _proxyTI : CM_TrackedItem input; _passport: CM_Passport input) updating;
//
//19 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	newStatus : Integer;
begin
	//update the container  //epr TFS 1947 passed in the ediTI as the updateController linked object
	app.myUtilityUA.utlUpdateTrackedItem(_proxyTI, null, TI_UPDMODE_NORMAL, null, null, _ediTI, _passport);
	if _passport.hasErrors() then
		newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS; 
	else
		newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED; 
	endif;
	if newStatus &lt;&gt; _ediTI.status then
		self.utlUpdateEDITIStatus(_ediTI, newStatus, _passport);
	endif;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDIVGMTI" usage="io"/>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEWSActivity" id="32f4bf9c-72ab-48ea-903f-9aacdc950dcf">
        <updating/>
        <source>utlUpdateEWSActivity(_pxyObject :  CM_ExternalWebServiceActivity; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
26JUL2021	NAVAB1	TFS 50669
*/

vars
	realObject		:  CM_ExternalWebServiceActivity;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'External Web Service Activity');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valEWSActivity(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Test Object', _passport).CM_ExternalWebServiceActivity;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_ExternalWebServiceActivity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
