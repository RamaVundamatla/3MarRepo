    <JadeMethod name="th1OpenGridArea" id="7a4d1c62-7eec-4662-84e5-dca0d8e87a4b">
        <updating/>
        <source>th1OpenGridArea() updating;

vars
	gridAreaForm			: CM_BaseForm;
	msgSelectAreas			: CMUI_MultiSelectGroupBox;
	allGridAreas			: ObjectArray;
begin
	gridAreaForm := self.loadForm(PmYardAreaView, false);
	self.allGridAreaForms.add(gridAreaForm);
	
	msgSelectAreas 		:= gridAreaForm.getPropertyValue('msgSelectAreas').CMUI_MultiSelectGroupBox;
	create allGridAreas transient;
	allGridAreas.add(app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'D']);
	allGridAreas.add(app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'A']);
	
	msgSelectAreas.setSelected(allGridAreas);
	gridAreaForm.getPropertyValue('btnSelectAreasSh').Button.click(null);
	
	
epilog
	delete allGridAreas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="th2OpenGridOverview" id="a06b28c8-3bee-45e1-9117-acd984923895">
        <updating/>
        <source>th2OpenGridOverview() updating;

vars
	gridOverviewForm			: CM_BaseForm;
	msgSelectAreas				: CMUI_MultiSelectGroupBox;
	allRTGLanes					: ObjectArray;
begin
	gridOverviewForm := self.loadForm(PmAdmRTGSTackView, false);
	self.allGridOverviewForms.add(gridOverviewForm);
	
	msgSelectAreas 		:= gridOverviewForm.getPropertyValue('msgSelectAreas').CMUI_MultiSelectGroupBox;
	create allRTGLanes transient;
	allRTGLanes.add(app.myPassport.myTerminal.allTerminalAreaGroups['1']);
	allRTGLanes.add(app.myPassport.myTerminal.allTerminalAreaGroups['10']);
	
	msgSelectAreas.setSelected(allRTGLanes);
	gridOverviewForm.getPropertyValue('btnSelectAreasSh').Button.click(null);

epilog
	delete allRTGLanes;
end;
</source>
    </JadeMethod>
    <JadeMethod name="th3EditContainer" id="d1947e87-6169-42d5-beb0-f3401360727f">
        <updating/>
        <source>th3EditContainer() updating;

vars
	idTxt				: TextBox;
	randomTI			: CM_TrackedItem;//i.e. seemingly random, but not random - JP any ideas
	tiPrefix			: String;
begin
	self.myContainerEnqForm := self.loadForm(PmAdmCargoEnquiryView, false).CM_ContainerEnqForm;
	
	if loopCount mod 3 = 0 then
		tiPrefix := 'ANNU';
	elseif loopCount mod 3 = 1 then
		tiPrefix := 'PONU';
	elseif loopCount mod 3 = 2 then
		tiPrefix := 'SUDU';
	endif;
	
	self.myContainerEnqForm.txtID.text := tiPrefix;
	self.myContainerEnqForm.tblSearch.setValueByName(ETRow_FilterId, tiPrefix);

	self.myContainerEnqForm.btnSearchTV.click(null);
	
end;
</source>
    </JadeMethod>
