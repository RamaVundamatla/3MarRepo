    <JadeMethod name="tbBinaryBackPath_change" id="b3d1a9f8-5b88-4457-9c31-c5ca71b004a8">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tbBinaryBackPath_change(_textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	secBackupPathChanged: Boolean; //set if the path on sec db is changed 
begin
	self.myCurrentCntrl := _textbox;
	secBackupPathChanged := false;
	beginTransaction;
	if app.isSDSSecondaryBackup then
		app.myServerAppObject.setBinarySecBackupPath(_textbox.text);
		secBackupPathChanged := true;
	else
		app.myServerAppObject.setBinaryBackupPath(_textbox.text);
	endif;
	commitTransaction;
	if secBackupPathChanged then
		//force the change to be transferred to the secondary.
		app.myDBA.closeCurrentJournal;
	endif;
end;</source>
        <Parameter name="_textbox" type="TextBox" usage="input"/>
    </JadeMethod>
