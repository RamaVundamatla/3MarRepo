    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myWorkPoint" id="c131e1ea-0cc9-438d-8018-7586ed77d439">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_WorkPoint"/>
        <access>readonly</access>
        <Inverse name="CM_WorkPoint::myWorkPointInterchangeArea"/>
    </ExplicitInverseRef>
    <JadeMethod name="canBeDesigned" id="c0c08456-74fe-44a4-918b-5a9c2ebb5e68">
        <source>canBeDesigned(): Boolean;
// Return true if this Terminal area can be designed during definition
// 28603 Nov 2011 these can't be
begin
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="bf30f516-64f7-4745-b05d-7a70f64561e7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	
	if _attrName = ETRow_WorkPoint then
		if self.myWorkPoint &lt;&gt; null then
			return self.myWorkPoint.code;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLanes" id="bdc388bb-46ee-4cdb-ab69-4640351e48d0">
        <source>getLanes( _wpLanes : CM_LCArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29745

*/

vars

	row : CM_GridRow;
	lc : CM_LocationsController;
	laneC : CM_YardICAreaLaneController;

begin

	foreach row in self.allGridRows do
		foreach lc in row.allControllersByColumn do
			if not lc.isKindOf(CM_YardICAreaLaneController) then
				continue;
			endif;
			laneC := lc.CM_YardICAreaLaneController;
			if laneC.isUnavailable then
				continue;
			endif;
			_wpLanes.addExclusive( laneC );
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_wpLanes" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="f458eacd-1650-4cff-9b1c-11108e1bc01c">
        <source>getQueues(queueSet: CM_RTQueueSet io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 December 2012	cnwrd1	Initial creation
	2/9/14  		cnwer1 also get any queues associated with the CTA 
*/

vars
	cq : CM_VoyageWorkPointQueue;
	 q : CM_RadioTelemetryQueue;
begin

	if self.myWorkPoint &lt;&gt; null then
		foreach cq in self.myWorkPoint.allVoyageWorkPointQueues discreteLock do // PAR 20474
			queueSet.add(cq);
		endforeach;
	endif;
	
	foreach q in self.allSubRTQueues discreteLock do
		queueSet.addNoDuplicates(q,false);
	endforeach;
	
	if queueSet.size = 0 then
		inheritMethod(queueSet);
	endif;
	
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateDefaultLanes" id="2e06ab63-d9ce-437b-89a0-4815446175c7">
        <updating/>
        <source>pxyCreateDefaultLanes() updating, protected;
// ---------------------------------------------------------------------------
// Created:     Nov 2011 cnwjre1, copy of method in CM_YardInterchangeArea
// Purpose:     from 28603 Work Point Interchange definition testing
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	: CM_LaneController;
begin

	self.raiseExceptionIfNotTransient (method);
	
	lc := self.pxyCreateNewLane (true);
	lc.setLockDirection (true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3c02c3f3-6c1d-4e0b-b553-940dd00f6a3a">
        <source>pxyCreateUpdateProxy(): SelfType;
// from 28604 Nov 2011 set work point for display in edit
vars
	proxy		: SelfType;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	proxy.myWorkPoint := self.myWorkPoint;
	completedOK := true;
	return proxy;
epilog
	if not completedOK then
		delete proxy;
	endif;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="3cadba7d-9c33-4042-9973-297dc02dfabd">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_WorkPointInterchangeArea; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	inheritMethod(_proxy, _passport);
	//hard code Work Point Interchange Areas to only be accessed by machines
	self.vehicleMachineAccessRules:=self.Access_Machines;
	self.setMyWorkPoint(_proxy.myWorkPoint);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_WorkPointInterchangeArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkPoint" id="2d605104-2716-4fc4-9e0c-f166b7742dba">
        <updating/>
        <source>setMyWorkPoint(_workPoint : CM_WorkPoint) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.myWorkPoint:=_workPoint;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6166e2f4-390e-4967-8cac-6e41ce44205c">
        <updating/>
        <source>setProxy(	_id :String; _comment :String; _terminal :CM_Terminal; 
			_workPoint : CM_WorkPoint;
			_releasePoint, _hideFromOverview :Boolean; 	
			_selectedTAs : CM_TerminalAreaSet input;
			_laneCount : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.myWorkPoint:=_workPoint;
	self.setProxyInterchangeArea (_id, _comment, _terminal, TA_TYPE_WORKPOINT_INTERCHANGE, _laneCount, _releasePoint, _hideFromOverview, self.Access_Machines, null,  _selectedTAs);
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_releasePoint" type="Boolean"/>
        <Parameter name="_hideFromOverview" type="Boolean"/>
        <Parameter name="_selectedTAs" type="CM_TerminalAreaSet" usage="input"/>
        <Parameter name="_laneCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3f9b5145-c695-4820-ab70-9de964187431">
        <source>validateForCreate();
// 28604 Nov 2011 give an error if work point is in use by another interchange area
vars

begin
	if self.myWorkPoint &lt;&gt; null then
		if self.myWorkPoint.myWorkPointInterchangeArea &lt;&gt; null then
			app.raiseCMException1(Work_point_in_use, self.myWorkPoint.myWorkPointInterchangeArea.id, null, null);
		endif;
	endif;

	inheritMethod();
end;

</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdateInUse" id="4ddb5f62-1274-4fed-a1c4-53848a4417df">
        <source>validateForUpdateInUse(pRealGridArea: CM_GridArea);
// 28604 Nov 2011 give an error if work point is in use by another interchange area
vars

begin
	if self.myWorkPoint &lt;&gt; null then
		if self.myWorkPoint.myWorkPointInterchangeArea &lt;&gt; null and
		   self.myWorkPoint.myWorkPointInterchangeArea &lt;&gt; pRealGridArea then
			app.raiseCMException1(Work_point_in_use, self.myWorkPoint.myWorkPointInterchangeArea.id, null, null);
		endif;
	endif;

	inheritMethod(pRealGridArea);
end;
</source>
        <Parameter name="pRealGridArea" type="CM_GridArea"/>
    </JadeMethod>
</Class>
