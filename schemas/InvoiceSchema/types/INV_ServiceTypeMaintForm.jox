    <JadeMethod name="addObjectsToTable" id="aacfcd0f-5b4e-4e94-9fbc-aa09e341942c">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	serviceType		: CM_ServiceType;
	breakOut		: Boolean;
	tmpPassprot		: CM_Passport;
	bank			: CM_Bank;
begin
	
	self.setMyDataClass();
	
	if self.allowSearch then
		bank := self.cmbBank.listObject.CM_Bank;
		
		if bank = null then
			return;
		endif;
		
		self.setMyCurrentBank(bank);	
	else
		bank := myCurrentBank;
	endif;
	
	
	tmpPassprot := app.myPassport;
	
	foreach serviceType in self.myCurrentBank.allServiceTypes do
		if self.includeObject(serviceType, tmpPassprot) then
			self.addObjectToTable(serviceType, _numItems, breakOut);
		endif;
		
		if breakOut then
			break;
		endif;
	endforeach;
	
	initGLCombo();
	setServiceAvailable();
epilog

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
