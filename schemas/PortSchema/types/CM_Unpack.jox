    <JadeMethod name="canEditAmount" id="5b8eb529-5fc8-40b1-ac43-785a13e40978">
        <source>canEditAmount(): Boolean;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	subType : CM_Product;
begin
	
	self.getCargoTypeAndSubType(ct,subType);
	
	if ct = null or not ct.allowDuplicates then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
