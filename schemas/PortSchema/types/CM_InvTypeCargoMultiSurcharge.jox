    <JadeMethod name="getCargoSurchargeInvLineType" id="d2f4ab73-99d3-44e1-a9ac-2c2c92cd99bc">
        <source>getCargoSurchargeInvLineType() : CM_InvoiceLineDesc;
/*

Purpose:			Gets the selected invoice line type on the cargo surcharge that is the invoice line type used when creating a surcharge line

Parameters:			NONE

Return Value:		CM_InvoiceLineDesc	Represents the selected Invoice Line Type

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.myCargoSurchargeInvLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;
	
end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8089bad2-096b-47f4-8b09-5346110be17e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2022	navpw1	Initial creation

*/

vars
	pxy : SelfType;
	
begin
	pxy := inheritMethod();
	
	pxy.allCargoTypes.clear();
	if self.allCargoTypes &lt;&gt; null and not self.allCargoTypes.isEmpty then
		self.allCargoTypes.copy( pxy.allCargoTypes );
	endif;
	
	pxy.allCargoSubTypes.clear();
	if self.allCargoSubTypes &lt;&gt; null and not self.allCargoSubTypes.isEmpty then
		self.allCargoSubTypes.copy( pxy.allCargoSubTypes );
	endif;
	
	pxy.allCommodities.clear();
	if self.allCommodities &lt;&gt; null and not self.allCommodities.isEmpty then
		self.allCommodities.copy( pxy.allCommodities );
	endif;
	
	pxy.allDebtors.clear();
	if self.allDebtors &lt;&gt; null and not self.allDebtors.isEmpty then
		self.allDebtors.copy( pxy.allDebtors );
	endif;
	
	pxy.allSelectedInvLineTypes.clear();
	if self.allSelectedInvLineTypes &lt;&gt; null and not self.allSelectedInvLineTypes.isEmpty then
		self.allSelectedInvLineTypes.copy( pxy.allSelectedInvLineTypes );
	endif;
	
	pxy.myCargoSurchargeInvLineType := self.myCargoSurchargeInvLineType;
	pxy.mySurchargesAndExemptions 	:= self.mySurchargesAndExemptions;
	
	return pxy;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="405ddeb3-3290-4cbd-9f8e-988d8fb1a00d">
        <updating/>
        <source>setForCreate(_proxy : CM_InvTypeCargoMultiSurcharge) updating;
/*

Purpose:			Sets the current object for creating a persistent object

Parameters:			_proxy	CM_InvTypeCargoMultiSurcharge	The proxy transient object to set our persistent object from

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

begin
	self.setForUpdate( _proxy );
	
end;</source>
        <Parameter name="_proxy" type="CM_InvTypeCargoMultiSurcharge"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d2a257bb-2c61-4d5f-8e1c-9b2e210bd3ea">
        <updating/>
        <source>setForUpdate(_proxy : CM_InvTypeCargoMultiSurcharge) updating;
/*

Purpose:			Sets the current object for updating a persistent object

Parameters:			_proxy	CM_InvTypeCargoMultiSurcharge	The proxy transient object to set our persistent object from

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

begin
	self.allCargoTypes.clear();
	if _proxy.allCargoTypes &lt;&gt; null and not _proxy.allCargoTypes.isEmpty then
		_proxy.allCargoTypes.copy( self.allCargoTypes );
	endif;
	
	self.allCargoSubTypes.clear();
	if _proxy.allCargoSubTypes &lt;&gt; null and not _proxy.allCargoSubTypes.isEmpty then
		_proxy.allCargoSubTypes.copy( self.allCargoSubTypes );
	endif;
	
	self.allCommodities.clear();
	if _proxy.allCommodities &lt;&gt; null and not _proxy.allCommodities.isEmpty then
		_proxy.allCommodities.copy( self.allCommodities );
	endif;
	
	self.allDebtors.clear();
	if _proxy.allDebtors &lt;&gt; null and not _proxy.allDebtors.isEmpty then
		_proxy.allDebtors.copy( self.allDebtors );
	endif;
	
	self.allSelectedInvLineTypes.clear();
	if _proxy.allSelectedInvLineTypes &lt;&gt; null and not _proxy.allSelectedInvLineTypes.isEmpty then
		_proxy.allSelectedInvLineTypes.copy( self.allSelectedInvLineTypes );
	endif;
	
	self.applyGreaterThanAmount := _proxy.applyGreaterThanAmount;
	self.applyGreaterThanLineTotal := _proxy.applyGreaterThanLineTotal;
	self.surchargeAmount := _proxy.surchargeAmount;
	self.surchargeRate := _proxy.surchargeRate;
	self.validFrom := _proxy.validFrom;
	self.validTo := _proxy.validTo;
	
	self.myCargoSurchargeInvLineType := _proxy.myCargoSurchargeInvLineType;
	self.mySurchargesAndExemptions := _proxy.mySurchargesAndExemptions;
	
end;</source>
        <Parameter name="_proxy" type="CM_InvTypeCargoMultiSurcharge"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a20186b9-9c27-4883-a8d2-f6c1f8e59593">
        <updating/>
        <source>setProxy(_allCargoTypes					: CM_CargoTypeSet;
			_allCargoSubTypes			: CM_ProductSet;
			_allCommodities				: CM_CommoditySet;
			_debtors					: CM_DebtorSet;
			_allSelectedInvLineDescs	: CM_InvoiceLineDescSet;
			_applyGreaterThanAmount		: Decimal;
			_applyGreaterThanLineTotal	: Boolean;
			_surchargeAmount			: Decimal;
			_surchargeRate				: Decimal;
			_validFrom					: TimeStamp;
			_validTo					: TimeStamp;
			_mySurAndExempt				: CM_InvoiceTypeSurchargeExempt;
			_mySurInvLineType			: CM_InvoiceLineDesc
			) updating;
/*

Purpose:			Sets our proxy transient object with the values passed in

Parameters:			_allCargoTypes				CM_CargoTypeSet					All the cargo types the surcharge applies to
					_allCargoSubTypes			CM_ProductSet					All the cargo sub types the surcharge applies to
					_allCommodities				CM_CommoditySet					All the commodities the surcharge applies to
					_debtors					CM_DebtorSet					All the debtors the surcharge applies to
					_allSelectedInvLineDescs	CM_InvoiceLineDescSet			All the invoice line types the surcharge applies to
					_applyGreaterThanAmount		Decimal							The amount we need to apply greater than when doing a surcharge
					_applyGreaterThanLineTotal	Boolean							Whether or not we are going to be applying greater than a line total or greater than quantity
					_surchargeAmount			Decimal							The fixed amount we are going to be surcharging
					_surchargeRate				Decimal							The rate/percentage of the line total we are going to be surcharging
					_validFrom					TimeStamp						The date/time that this is valid from
					_validTo					TimeStamp						The date/time that this is valid to
					_mySurAndExempt				CM_InvoiceTypeSurchargeExempt	The Surcharge and Exemption parent object this refers to
					_mySurInvLineType			CM_InvoiceLineDesc				The Invoice Line Type to use for the surcharge invoice line

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

begin
	self.allCargoTypes.clear();
	if _allCargoTypes &lt;&gt; null and not _allCargoTypes.isEmpty then
		_allCargoTypes.copy( self.allCargoTypes );
	endif;
	
	self.allCargoSubTypes.clear();
	if _allCargoSubTypes &lt;&gt; null and not _allCargoSubTypes.isEmpty then
		_allCargoSubTypes.copy( self.allCargoSubTypes );
	endif;
	
	self.allCommodities.clear();
	if _allCommodities &lt;&gt; null and not _allCommodities.isEmpty then
		_allCommodities.copy( self.allCommodities );
	endif;
	
	self.allDebtors.clear();
	if _debtors &lt;&gt; null and not _debtors.isEmpty then
		_debtors.copy( self.allDebtors );
	endif;
	
	self.allSelectedInvLineTypes.clear();
	if _allSelectedInvLineDescs &lt;&gt; null and not _allSelectedInvLineDescs.isEmpty then
		_allSelectedInvLineDescs.copy( self.allSelectedInvLineTypes );
	endif;
	
	self.applyGreaterThanAmount := _applyGreaterThanAmount;
	self.applyGreaterThanLineTotal := _applyGreaterThanLineTotal;
	self.surchargeAmount := _surchargeAmount;
	self.surchargeRate := _surchargeRate;
	self.validFrom := _validFrom;
	self.validTo := _validTo;
	
	self.myCargoSurchargeInvLineType := _mySurInvLineType;
	self.mySurchargesAndExemptions := _mySurAndExempt;
	
end;</source>
        <Parameter name="_allCargoTypes" type="CM_CargoTypeSet"/>
        <Parameter name="_allCargoSubTypes" type="CM_ProductSet"/>
        <Parameter name="_allCommodities" type="CM_CommoditySet"/>
        <Parameter name="_debtors" type="CM_DebtorSet"/>
        <Parameter name="_allSelectedInvLineDescs" type="CM_InvoiceLineDescSet"/>
        <Parameter name="_applyGreaterThanAmount" type="Decimal"/>
        <Parameter name="_applyGreaterThanLineTotal" type="Boolean"/>
        <Parameter name="_surchargeAmount" type="Decimal"/>
        <Parameter name="_surchargeRate" type="Decimal"/>
        <Parameter name="_validFrom" type="TimeStamp"/>
        <Parameter name="_validTo" type="TimeStamp"/>
        <Parameter name="_mySurAndExempt" type="CM_InvoiceTypeSurchargeExempt"/>
        <Parameter name="_mySurInvLineType" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="149296ea-40e7-4c30-8c1d-de6df08b174b">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			Validates the Cargo Surcharge for create

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

begin
	self.validateMe();
	
end;</source>
