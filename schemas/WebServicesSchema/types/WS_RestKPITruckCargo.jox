<Class name="WS_RestKPITruckCargo" id="cb7e4d2f-4e5e-4344-b7e4-f56b34f34c47">
    <superclass name="WS_RestKPITruckCarrier"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="cargo" id="8d8082f2-575c-4958-9d74-1c7889b3e993">
        <memberTypeInverse/>
        <type name="WS_RestCargoArray"/>
    </ImplicitInverseRef>
