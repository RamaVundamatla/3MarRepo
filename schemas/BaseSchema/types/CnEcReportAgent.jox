    <JadeMethod name="trxReportParameterUpdate" id="5a6bd2c8-eba0-4ac4-a38c-af0b767ab1c6">
        <updating/>
        <source>trxReportParameterUpdate(	pReportParameterObj:CnEcReportParameter input;
							pRequiredEdition:Integer;
							pReportDefinitionObj:CnEcReportDefinition;
							pParameterName:String;
							pDisplayValue:String;
