    <JadeMethod name="doRemove" id="37cfc6de-c024-439d-82c7-ac26bd20e47b">
        <updating/>
        <source>doRemove()updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	theReturn : Integer;
	custDoc	: CM_CustomDocument;

begin
	// ### TFS BUG 59640 03AUG2023 NAVAB1 - check is selected
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		custDoc := self.tblData.accessedRow.itemObject.CM_CustomDocument;
	endif;

// ### TFS BUG 59640 03AUG2023 NAVAB1	ownership := _obj.CM_CustomDocument;
	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox("Confirm Deletion", 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
 	app.myTrxDA.trxDeleteCustDocHeader(custDoc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog("Cust Doc Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
