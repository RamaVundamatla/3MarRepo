    <JadeMethod name="calculateDisplayValue" id="79f8ff88-0254-4c75-94f0-d0a9f3257c89">
        <source>calculateDisplayValue();
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:     This will display the result of the value field * anyMultiplier entered
//				
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	prodAttr			: CM_ProductAttr;
	validationType,
	valueStr			: String;
	valueInt			: Integer;
	valueDec,
	displayVal,
	multi				: Decimal[20,3];
	table				: CM_DataTable;
	row					: Integer;
begin
	
	table := self.tblAttributes;
	
	foreach row in table.fixedRows + 1 to table.rows do
		prodAttr := table.accessRow(row).itemObject.CM_ProductAttr;
		//multi := table.getCellText(row, table.getColumnByRowName(ETRow_Multiplier)).Decimal;					// PAR #31155
			
		if prodAttr.isKindOf(CM_ProdAttrString) then
			validationType := table.getCellText(row, table.getColumnByRowName(ETRow_ValidationType)).String;
			if validationType = CM_ProductAttr.ValidationType_Codes then
				valueStr := table.getCellText(row, table.getColumnByRowName(ETRow_ColumnCode)).String;
			else
				valueStr := table.getCellText(row, table.getColumnByRowName(ETRow_Value)).String;
			endif;
		elseif prodAttr.isKindOf(CM_ProdAttrInteger) then
			valueInt := table.getCellText(row, table.getColumnByRowName(ETRow_Value)).Integer;
			
			valueDec := (valueInt * multi);
			//
			if valueDec mod 1 = 0 then
				valueStr := (valueDec.Integer).String;
			else
				valueStr := (valueDec).String;			
			endif;
			
		elseif prodAttr.isKindOf(CM_ProdAttrDecimal) then
			valueDec := (table.getCellText(row, table.getColumnByRowName(ETRow_Value)).Decimal) * multi;
			valueStr := (valueDec).String;
		endif;
		
		table.setCellText(row, table.getColumnByRowName(ETRow_DisplayValue), valueStr.String);
	endforeach;
	
end;</source>
    </JadeMethod>
