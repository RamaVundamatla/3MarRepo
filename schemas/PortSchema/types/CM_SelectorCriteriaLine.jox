epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="e1c6aba3-b8aa-4f84-959b-cef09e7df6c5">
        <source>showCriteria(lineHolder : CM_QueryCriteriaLineHolder input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars
	
begin
	if self.myQueryProperty = null then
		return true;
	endif;
	
	return self.myQueryProperty.showCriteria(lineHolder);
	
epilog

end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="0b5f56d5-e649-4f8c-8449-8ff3e654e01c">
        <source>validateForRT( _queryName : String );
// -----------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
// -----------------------------------------------------------------

vars

begin
	
	self.myQueryOperator.validateForRT( _queryName, self.propName );

end;
</source>
        <Parameter name="_queryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="112ba320-f49b-4630-9eb4-38260a867797">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myQueryProperty = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Query line property name', 'name', null);
		app.raiseCMException(Input_required_field_qryLnePro, 'name', null); // cnwdb2	PAR 35364
	endif;
	
	if self.myQueryOperator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Query line operation description', 'operatorDescription', null);
		app.raiseCMException(Input_required_field_qryLneOp, 'operatorDescription', null); // cnwdb2	PAR 35364
	endif;
	
	//PAR24894 - cnwsh3 06/07/2010 - Need to pass a terminal in now selector permissions are terminal based.
	if (self.isUnavailableAtRunTime and not app.getMyUser.canDo(app.myPassport.myTerminal, PmAdmSelectorMaint)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'A user without full selector maint permission became ' &amp; CrLf &amp;
										'able to specify a criteria line as being unavailable at run-time');
	endif;
end;</source>
    </JadeMethod>
</Class>
