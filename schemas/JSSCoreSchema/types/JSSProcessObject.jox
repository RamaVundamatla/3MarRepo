    <JadeMethod name="create" id="85a54d0b-f21a-4756-aa79-cd80ee86afef">
        <updating/>
        <source>create() updating;
/*
*/
begin
	processOidAsString := process.getOidString();
end;</source>
    </JadeMethod>
    <JadeMethod name="setApplicationOidAsString" id="5944ae75-6e82-4d9d-93ce-9dc0d4ef9fb3">
        <updating/>
        <source>setApplicationOidAsString(value: String) updating;
/*
*/
begin
	if applicationOidAsString &lt;&gt; value then 
		applicationOidAsString := value;
	endif;
end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
