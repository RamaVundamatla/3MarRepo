<Class name="CM_ConsigneeConsignor">
    <JadeMethod name="importPLXMLReference" id="24c413d1-365b-4e18-ab7b-8a0e8ffd17c1">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ConsigneeConsignor::myRoot.name then
		return app.myRoot;
	elseif _name = CM_ConsigneeConsignor::myConsignGroup.name then
		return app.myRoot.allConsignGroups[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
