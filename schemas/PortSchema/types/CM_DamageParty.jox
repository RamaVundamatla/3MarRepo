    <JadeMethod name="cnEcGetDuplicate" id="bb1928af-d94b-4883-be0b-268b0109f237">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	code : String;
	damage : CM_DamageParty;
begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		damage := self.myTerminal.allDamageParties.getAtKey( code );
	endif;

epilog

	return damage;
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
