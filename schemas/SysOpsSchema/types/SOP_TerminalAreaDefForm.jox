    <JadeMethod name="loadDataForFirstTime" id="ba1be89f-f76d-4d02-9c1e-96b6dcca18be">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLanesForCTA" id="89d9bb99-c8a7-49a2-bb36-5cdeb69588aa">
        <source>loadLanesForCTA(_craneTransfer : CM_CraneTransferArea ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwer1	Initial creation 

*/

vars
	lc : CM_LocationsController;
begin
	self.shtGateLanes.caption:=app.getErrorString(Crane_lanes);
	self.tblGateLanes.rows := self.tblGateLanes.fixedRows;
	
	foreach lc in _craneTransfer.lanes do
		self.tblGateLanes.updateItemObject(lc, White, White, app.myPassport);		
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_craneTransfer" type="CM_CraneTransferArea"/>
    </JadeMethod>
    <JadeMethod name="loadLanesForInterchange" id="79349d80-6a01-430d-8b2e-8542780fec0e">
        <source>loadLanesForInterchange(_area :CM_AreaWithLanes)protected;
/*
Purpose:		create all the lanes for a CM_YardInterchangeArea, remove if necessary

Date		Who			Reason
28/8/2009	cnwjo3		Initial creation - PAR#20582 ccms 1061
11/09/2009	cnwcs5		Take out code that updates lanecount so we can call this method
						whenever we load the lanes.SIMPLIFY
*/

vars
	laneColl	: CM_ObjectArray;
	obj			: Object;
begin 
	self.shtGateLanes.caption:=app.getErrorString(Interchange_lanes);
	self.tblGateLanes.rows := self.tblGateLanes.fixedRows;
	
	create laneColl transient;
	_area.getAllLaneControllers (laneColl);
	
	foreach obj in laneColl do
		self.tblGateLanes.updateItemObject(obj.CM_YardICAreaLaneController, White, White, app.myPassport);
	endforeach;
epilog
	delete laneColl;
end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_AreaWithLanes"/>
    </JadeMethod>
    <JadeMethod name="loadLanesForRoRoLaneArea" id="e749729b-fe98-46b5-9fd9-ac62789b4c9a">
        <source>loadLanesForRoRoLaneArea(_area : CM_RoRoLaneArea)protected;
/*

Date		Who			Reason
18/11/2009	cnwjk3		Initial creation - ccms 1018
*/

vars
	laneColl	: CM_ObjectArray;
	obj			: Object;
begin 
	self.tblGateLanes.rows := self.tblGateLanes.fixedRows;	
	self.tblGateLanes.sortColumn[1] := 0;	// cnwjk3 PAR 23760 16/04/2010
	foreach obj in _area.allLanesByLaneNumber do
		self.tblGateLanes.updateItemObject(obj.CM_RoRoController, White, White, app.myPassport);
	endforeach;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_RoRoLaneArea"/>
    </JadeMethod>
    <JadeMethod name="loadRoRoCombos" id="56bc8b13-a601-4529-98bb-30a9ffe49047">
        <source>loadRoRoCombos() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwjk3	Initial creation

*/

vars
	leftLabel,
	rightLabel	: String;
begin
	// Get the value of the left and right lane labels
	leftLabel := self.tblMain.getValueByName(ETRow_LeftLabel).String;
	rightLabel := self.tblMain.getValueByName(ETRow_RightLabel).String;

	// Numbering direction
	self.cmbNumDir.clear();
	self.cmbNumDir.addItem(self.myProxyObject.CM_RoRoLaneArea.getLeftToRightString(leftLabel, rightLabel));
	self.cmbNumDir.addItem(self.myProxyObject.CM_RoRoLaneArea.getRightToLeftString(leftLabel, rightLabel));
	
	// Parking direction
	self.cmbParkDir.clear();
	self.cmbParkDir.addItem(self.myProxyObject.CM_RoRoLaneArea.getLeftToRightString(leftLabel, rightLabel));
	self.cmbParkDir.addItem(self.myProxyObject.CM_RoRoLaneArea.getRightToLeftString(leftLabel, rightLabel));

	// Access direction
	self.cmbAccessDir.clear();
	self.cmbAccessDir.addItem(leftLabel);
	self.cmbAccessDir.addItem(rightLabel);
	self.cmbAccessDir.addItem(self.myProxyObject.CM_RoRoLaneArea.getLeftAndRightString(leftLabel, rightLabel));

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
