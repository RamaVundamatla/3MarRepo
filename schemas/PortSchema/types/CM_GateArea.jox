    <JadeMethod name="getTypeAsString" id="e166f8f3-32ca-45e2-b2c9-ede17a45a31f">
        <source>getTypeAsString():String;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	if self.isAGate then
		return app.getErrorString (XLAT_AGATE_TYPE);
	elseif self.isPGate then
		return app.getErrorString (XLAT_PGATE_TYPE);
	elseif self.isTrouble then
		return app.getErrorString (XLAT_TROUBLE_TYPE);
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
