// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	col		:Integer;
begin
	table := self.tblGateAreas;
	
	table.setTblDataEntRowsFromDef(app.myController.getEntTableDef (ETDef_GateAreasTable));

	table.selectMode 			:= Table.SelectMode_CurrentRow;
	table.disallowColumnSorter	:= true;
	
	// id column gets set depending on whether it is a new or exitsing gate area
	col := table.getColumnByRowName (ETRow_Area_comment);
	
	if col &gt; 0 then
		table.accessColumn (col).inputType	:= Table.InputType_TextBox;
		table.accessedColumn.maxLength	:= 30;
	endif;
	
	col := table.getColumnByRowName (ETRow_Area_laneCount);
	
	if col &gt; 0 then
		table.accessColumn (col).inputType := Table.InputType_TextNumeric;
		table.accessedColumn.maxLength	:= 2;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
