C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D2042,,,,'&amp;ContainerId12&amp;',1,2200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName1&amp;'
