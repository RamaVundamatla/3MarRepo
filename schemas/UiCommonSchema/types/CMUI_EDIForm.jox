    <JadeMethod name="doUpdateEDITI" id="76a5e8f7-60d2-43ed-8fd6-dce802de71a1">
        <source>doUpdateEDITI(_ediTI: CM_EDITrackedItem ; _eventType: Integer);
// ----------------------------------------------------------------
//	Created:	17 June 2004	by Jason Chapman  (cnwjc2)
// 
// ----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - parameter change in siForLocal method
// 22/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2) - make it work for any EDI TI
// 30/11/2022 	navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	table			: CM_DataTable;
	idx				: Integer;
	gotException	: Boolean;
	ediData			: CM_EDIData;
begin
	on Exception do app.handleDeletedObject (exception, _ediTI, gotException);

	ediData := _ediTI.myEDIData;
	
	if self.myDisplayedEDIData &lt;&gt; ediData then					//30.11.2022 navma1 #52499
		return;
	endif;
	
	if gotException then
		return;
	endif;
	
	// find the table for the EDI TI
	table 	:= self.tblEDITI;
	
	while table &lt;&gt; null do
		if table.myDynaDict.includes (_ediTI) then
			break;
		endif;
		
		if table.visible then
			// look in the next table
			idx		:= idx + 1;
			table 	:= self.tblEDITI.getControl(idx);
			
			continue;
		endif;
		
		// we are out of tables
		table := null;
	endwhile;
	
	if table = null then
		return;
	endif;
	
	idx 	:= 1;
	
	if table.findObjectInRow(_ediTI, idx) then
		//30.11.2022 navma1 #52499
		if _eventType = EVENT_EDI_EDITI_UPDATE then
			table.setCellText(idx, 1, _ediTI.getAttributeStringForDefArray(table.allTblDataEntRows));
		endif;
		table.accessRow(idx);
		
		_ediTI.getColoursForEDITrackedItem (ediData, null, table.accessedRow.foreColor, table.accessedRow.backColor);	//30.11.2022 navma1 #52499
	endif;
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doVerifyEDITIs" id="426784e0-8c2e-4f05-87d7-72f650c10f03">
        <updating/>
        <source>doVerifyEDITIs() updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07/08/2012	cnwcs5	par 30136 
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
vars

	ediData		: CM_EDIData;
	passport	: CM_Passport;
	cmifMonitor	: CMIF_Monitor;
	prof		: JadeProfiler;
	startTM 	: Decimal[19,0];
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	app.mousePointer	:= MP_HOURGLASS;
	passport			:= app.myPassport;
	ediData 			:= self.myCurrentObject.CM_EDIData;
	
	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	
	passport.clearErrorsWarnings();
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption 	:= Cr &amp; app.getErrorString (XLAT_Verifying_EDIData);	// par 30136 Aug 2012
	self.frmModalDialog.visible 	:= true;
	
	app.doWindowEvents(0);	

	self.myEDIAgent.verifyEdiData(ediData);

	if self.hasVerifyErrorsToShow (ediData) then		// par 30136 Aug 2012, par 27392 13 Apr 2011
		self.showVerifyErrors(ediData);					// par 27392 13 Apr 2011
	else
		self.tblEDITIError.rows := self.tblEDITIError.fixedRows;
		self.mode 				:= self.Mode_View;
		
		self.setControls();	
		
		self.clearErrorWarnings();
		self.staMain.caption 	:= app.getErrorString (Verify_sucessful);	// par 30136 Aug 2012
	endif;
	
// cnwdad1 09/06/2010 - PAR #24302
//	self.updateTblData(ediData);
	ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
epilog
	self.closeModalDialog();
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
	app.myRoot.stopJadeProfiler(prof,startTM);
end;</source>
    </JadeMethod>
    <JadeMethod name="doViewInternalXML" id="77b75141-4598-4647-8dca-df99ef24f0ee">
        <updating/>
        <source>doViewInternalXML() updating;
/*

Purpose:			Open a viewing form to show the Internal XML interim transformation
					if there is one for the selected EDI File

Parameters:			None

Return Value:		None

Date		Who		Reason
16 Dec 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
09 Jul 2018 cnwma1	Bug 39483: JMT - EDI Operations View Raw Data and Internal XML
21 Aug 2023	navmd1	TFS 59024 Handle JSON messages
24 Aug 2023 navmd1	TFS 59451 Refactor EDI Ops/EDI Web Service viewer to call one method
*/
vars
	ediData			: CM_EDIData;
	invalidObj		: Boolean;
begin
	if self.myCurrentObject &lt;&gt; null and CM_EDIData.hasInstance(self.myCurrentObject) then
		ediData := self.myCurrentObject.CM_EDIData;
		
		on Exception do app.handleDeletedObject( exception, ediData, invalidObj );
		ediData.edition;
		
		if invalidObj then
			app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return;
		endif;
		
		self.myEDIUIAgent.doEDIViewInternalXML(ediData, self);
	endif;
		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="enableMnuEditFile" id="654c707c-1396-445a-813e-ae6b3a9a2934">
        <updating/>
        <source>enableMnuEditFile( isTblEDITI : Boolean ) updating, protected;
// -----------------------------------------------------------------------------------------------
// Created:		18 October 2007  by cnwvu1
//
// Parameters:	a) isTblEDITI = true  (mouse click on the right pane on the sheet EDI Data for...)
//				b) isTblEDITI = false (mouse click on the other panes of the form) 
// -----------------------------------------------------------------------------------------------
/*

Date		Who		Reason
16 Dec 2014	cnwkpd1	PAR #34713 - Changes for .NET EDI Integration
10.07.2018	cnwma1	Bug 39483: JMT - EDI Operations View Raw Data and Internal XML
21 Aug 2023	navmd1	TFS 59024 Handle JSON messages
*/

vars
	ediData		: CM_EDIData;
	ediFile		: CM_EDIFile;

begin
	if not ( self.myCurrentObject &lt;&gt; null and CM_EDIData.hasInstance(self.myCurrentObject) ) then
		self.mnuEditFile.enabled := false;
		self.mnuEdiXML.enabled := false;
		self.mnuEdiJSON.enabled := false;
		return;
	endif;
	
	ediData := self.myCurrentObject.CM_EDIData;
	ediFile := ediData.myEDIFile;
	
	self.mnuEditFile.visible := true;
	self.mnuEdiXML.visible := true;
	
	if ediFile &lt;&gt; null then
		if ediFile.getRawDataLength &lt;&gt; 0 then
			self.mnuEditFile.enabled := true;
		else
			self.mnuEditFile.enabled := false;
		endif;

		if ediFile.originalFileData &lt;&gt; null then
			if not ediFile.originalFileData.isEmpty then
				self.mnuEdiXML.enabled := true;
				self.mnuEdiJSON.enabled := true;
			else
				self.mnuEdiXML.enabled := false;
				self.mnuEdiJSON.enabled := false;
			endif;
		endif;
		
		if ediFile.myEDIFileType &lt;&gt; null then
			if ediFile.myEDIFileType.isJSON() then
				self.mnuEdiXML.visible := false;
				self.mnuEdiJSON.visible := true;
			endif;
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="isTblEDITI" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldDetail_sheetChg" id="7080c663-8407-4017-9ee4-a201881a118b">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldDetail_sheetChg(folder: Folder input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2025	jlier1	Initial creation 35416

*/

vars
	index : Integer;
begin

	if	self.isDataSheetDisplayed(index) //cnwgb1 MES 1011 29.9.09 PAR 20320
	   and (self.myDisplayedEDIData &lt;&gt; self.myCurrentObject) then
		self.showDataForCurrentObject(false);
	else
		if self.tblEDITIError.rows &gt; 1 then
			self.sptData.showRightControl(35, true);	//par 27392 cnwrs1 14 Apr 2011
		endif;
	endif;

	self.setControls();

epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
