    <JadeMethod name="calculateMoveLCs" id="1986e47e-e32a-420f-adb3-6c24f78fc5b2">
        <source>calculateMoveLCs(_ti: CM_TrackedItem): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

begin

	if _ti = null then
		return 1;
	elseif _ti.isContainer then
		return self.myWagon.getLengthInUnitsForWagon( _ti ) / 2;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="canPlanOverstow" id="3176963f-d136-48b1-badc-693d23986e73">
        <source>canPlanOverstow( _moveItem: CM_Object; _otherLoc: CM_LocationsController input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	wellId : String;
	maxNumInStack : Integer;
	count : Integer;
	nextWc : CM_WellcarWagonController;
	firstItemActualLength : Real;
	firstItem : CM_Object;
	firstItemLengthInUnits : Integer;
	moveItemActualLength : Real;
	moveItemLengthInUnits : Integer;
	foundA20: Boolean;
	obj : CM_Object;
	wle : CM_WorkListEntry;
	dummyWle : CM_WorkListEntry;
	index : Integer;
	stackHeight : Real;
	nextWcStackHeight : Real;

begin

	maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
	if maxNumInStack = 1 then
		// can't multi stack
		return false;
	endif;
	
	moveItemActualLength := self.myWagon.getActualLengthFor( _moveItem );
	moveItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( _moveItem ).Integer;
	firstItem := self.getFirstExistingItem( null, wle );
	if firstItem &lt;&gt; null then
		firstItemActualLength := self.myWagon.getActualLengthFor( firstItem );
	endif;

	if _otherLoc = null then
		// checking primary location
		count := moveItemLengthInUnits - 1;
		stackHeight := self.getStackHeight();
	
		nextWc := self;
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController.CM_WellcarWagonController;
			if nextWc = null or nextWc.CM_WellcarWagonController.myWellcarWellVisit &lt;&gt; self.myWellcarWellVisit then 
				// not enough controllers...  
				// would be astride the articulation point 
				return false;
			elseif ( nextWc.allTrackedItems.size + nextWc.allRailWLELoad.size ) &lt;&gt; ( self.allTrackedItems.size + self.allRailWLELoad.size ) then
				// stacked to different heights, not enough room  
				return false;
			endif;
			nextWcStackHeight := nextWc.getStackHeight; 
			if stackHeight &lt;&gt; nextWcStackHeight then
				// stacked to different heights
				return false;
			endif;
			
		endwhile;
	endif;

	
	if firstItem &lt;&gt; null then
		// we are on the top stack
		if moveItemActualLength &lt; firstItemActualLength then
			// not allowed to stack small on large
			return false;
	
		elseif _otherLoc = null then  // _otherLoc = null when this is the first controller
									// that the cargo  or release item is being placed in.
			
			//primary pos should be a twenty foot position for well wagons...
			index := self.myWagon.allLocationsControllersArray.indexOf(self);
			if not index.isOdd then
				return false;
			endif;
		
			firstItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( firstItem ).Integer;
			if firstItem.isKindOf(CM_TrackedItem) and not firstItem.CM_TrackedItem.isRRP and firstItem.CM_TrackedItem.myPrimaryActualLocation &lt;&gt; self then
				// trying to stagger stack the containers  
				return false;
			
			elseif wle &lt;&gt; null and self.myWagon.getFirstLocationFor(wle) &lt;&gt; self then
				// trying to stagger stack the iso type / isogroup  
				return false;
				
			elseif firstItemLengthInUnits = 2  // bottom one is a 20
			and moveItemLengthInUnits &lt;&gt; 2  // top one is bigger
			then
				// another way of trying to stagger stack the containers  i.e. a 40(or larger) over a 20 then a 40..
				// But 40 over 2 x 20s is allowed.
				nextWc := self;
				while true do
					nextWc := nextWc.myNextController.CM_WellcarWagonController;
					if nextWc = null or nextWc.CM_WellcarWagonController.myWellcarWellVisit &lt;&gt; self.myWellcarWellVisit then
						break;
					endif;
					obj := nextWc.getFirstExistingItem( null, dummyWle );
					if obj &lt;&gt; firstItem then
						if obj &lt;&gt; null and self.myWagon.getLengthInUnitsForWagon( obj ) = 2 then
							foundA20 := true;
							break;
						else
							return false;  // second item is not a 20
						endif;
					endif;
				endwhile;
				if not foundA20 then
					// stacking over a gap
					return false;
				endif;
			endif;
		endif;
		
	endif;
	
		
	return true;

epilog

end;
</source>
        <Parameter name="_moveItem" type="CM_Object"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColIdForJMT" id="a6adeba4-ad28-4de2-98bd-e9ba778f070f">
        <source>getColIdForJMT( _ti : CM_TrackedItem ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346

