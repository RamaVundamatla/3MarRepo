    <JadeMethod name="setControlsForAddEdit" id="805f4d90-9091-4e32-9d8e-4c0c2048a055">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.tblInput1.hideRowByName(ETRow_DefineRates,false);
	theForm.tblInput1.hideRowByName(ETRow_NumWorkPointRates,false);						// ### TFS 53105 23JUN2022 NAVAB1
	theForm.tblInput1.clearValues;														//26.4.2023 navhl20 #57712[54552]
	theForm.loadCmbWPTData(null);														//26.4.2023 navhl20 #57712[54552]
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_ExternalRef); 							 //02.10.2018 cnwma1 TFS #41234
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_WorkPoint);
		
		// cannot update code		

		theForm.tblInput1.disableRowByName(ETRow_Code);									//24 Nov 2017	NDL	TFS 7792
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_ExternalRef);  							//02.10.2018 cnwma1 TFS #41234
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="7f98902c-0718-4554-a446-8217f35ce9d1">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars


	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	
	theForm.tblInput1.showRowByName(ETRow_DefineRates,false);
	theForm.tblInput1.showRowByName(ETRow_NumWorkPointRates,false); // ### TFS 53105 23JUN2022 NAVAB1
 // ### TFS 53105 23JUN2022 NAVAB1	theForm.tblInput1.setValueByName(ETRow_DefineRates, app.getErrorString( Dbl_Click_Edit_View ));	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="b2d90e84-a03a-443e-b48d-c54ca92e16f7">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	theForm : SOP_TableMaintForm;
	tmpMenu1 : MenuItem;
	tmpMenu2 : MenuItem;
	tmpMenu3 : MenuItem;
	workPoint : CM_WorkPoint;

begin

	inheritMethod( conwin );
	theForm := self.myForm;
	
	theForm.mnuContext1.enabled := false;
	theForm.mnuContext1.visible := true;
	theForm.mnuContext1.caption := "Propogate Rates Configuration...";
	
	theForm.mnuContext2.enabled := false;
	theForm.mnuContext2.visible := true;
	theForm.mnuContext2.caption := "Extract Rates Configuration...";
	
	theForm.mnuContext3.enabled := false;
	theForm.mnuContext3.visible := true;
	theForm.mnuContext3.caption := "Import Rates Configuration...";
	
	if theForm.mode = theForm.Mode_View then
		workPoint := theForm.myCurrentObject.CM_WorkPoint;
		if workPoint &lt;&gt; null and not workPoint.allWorkPointRates.isEmpty then
			theForm.mnuContext1.enabled := true;
		endif;
		if workPoint &lt;&gt; null and not workPoint.allWorkPointRates.isEmpty then
			theForm.mnuContext2.enabled := true;
		endif;
		if workPoint &lt;&gt; null then
			theForm.mnuContext3.enabled := true;
		endif;
	endif;
	
	tmpMenu1 := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false ); 	
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		tmpMenu1.enabled:= false;
	endif;
	
	tmpMenu2 := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext2, false ); 	
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		tmpMenu2.enabled:= false;
	endif;
	
	tmpMenu3 := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext3, false ); 	
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		tmpMenu3.enabled:= false;
	endif;

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="d4a151c7-74d9-4795-a0b8-954148681a19">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WorkPointMaint);
	theForm.tblData.hideColumnByColName(ETRow_DefineRates);	//07 Mar 2018	NDL	TFS 37437

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_WorkPointMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="443c188b-afb5-40bf-b460-925bce495108">
        <updating/>
        <source>showThumbnail(_workPoint: CM_WorkPoint) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars

begin
	inheritMethod(_workPoint);
	self.myForm.loadCmbWPTData(_workPoint.myWorkPointType);
	
	if _workPoint.myWorkPointType &lt;&gt; null then
		self.myForm.tblInput1.setValueByName(ETRow_WorkPointType, _workPoint.myWorkPointType.code);
	endif;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
</Class>
