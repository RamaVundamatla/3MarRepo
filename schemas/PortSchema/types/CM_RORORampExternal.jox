<Class name="CM_RORORampExternal" id="356d1eb3-bbb2-4f9d-91cd-d7a2ef91e75c">
    <superclass name="CM_RORORamp"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myRampPosition" id="df0440e9-de8e-40b7-8b9f-ba39c779446d">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VesselRampPositionType"/>
        <access>readonly</access>
        <Inverse name="CM_VesselRampPositionType::allRamps"/>
    </ExplicitInverseRef>
    <JadeMethod name="exportAsXMLInverseRef" id="a04526b4-d1b8-4c76-afc1-538c6bfeba80">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _property = CM_RORORampExternal::myRampPosition then
		return ExportAsParent;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="de9c7264-05ca-4a5b-bb65-1aa1b3f41618">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _attrName = ETRow_ExternalPosition then
		if self.myRampPosition &lt;&gt; null then
			return self.myRampPosition.code;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1b9f113b-cc06-4092-8761-b88e43c5fdaf">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyRampExternal : CM_RORORampExternal;
	completedOK		: Boolean;
begin
	pxyRampExternal:= inheritMethod();

	pxyRampExternal.myRampPosition:=self.myRampPosition;	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRampExternal;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRampExternal;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b5a5c70a-ff25-4ada-810f-ddb5aeced348">
        <updating/>
        <source>setForUpdate(_proxyRORORamp: SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_proxyRORORamp, _passport);

	self.myRampPosition:=_proxyRORORamp.myRampPosition;
epilog

end;</source>
        <Parameter name="_proxyRORORamp" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyRampPosition" id="36ae6827-593c-4e88-88df-84b7ff2451fe">
        <updating/>
        <source>setMyRampPosition(_value : CM_VesselRampPositionType) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.myRampPosition:=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_VesselRampPositionType"/>
    </JadeMethod>
    <JadeMethod name="typeInteger" id="f0d7ceef-1a16-4e77-866d-713c88dcceb7">
        <source>typeInteger(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return DeckItem_External_Ramp;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="typeName" id="515461cb-1c48-4f2f-90e3-977af304d07c">
        <source>typeName(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return app.getErrorString(DeckItem_External_Ramp).toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
