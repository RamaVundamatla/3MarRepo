    <JadeMethod name="makeDepCarrVesselSubSectXML" id="c7ed960e-c2d2-4f66-95b1-94aee8deb19e">
        <source>makeDepCarrVesselSubSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	foundMatch : Boolean;

begin

	rootElem := _parentElem.addElement('DepartCarrierVessel');
	
	if _ti = null then
		return;
	endif;
	voyage := _ti.myExportVoyage;
	if voyage = null then
		return;
	endif;
	vessel := voyage.getMyVessel();
	if vessel = null then
		return;
	endif;
	
	xmlElem := rootElem.addElement('CTO_Reference');
	xmlElem.setText( vessel.getOidString );
	
	xmlElem := rootElem.addElement('LloydsNumber');
	xmlElem.setText( vessel.lloydsNumber );
	
	xmlElem := rootElem.addElement('CallSign');
	xmlElem.setText(  vessel.callSign  );
	
	xmlElem := rootElem.addElement('Name');
	xmlElem.setText( vessel.name );
	
	xmlElem := rootElem.addElement('Acos_Code');
	xmlElem.setText( vessel.code );
/*	
	xmlElem := rootElem.addElement('SOP_VoyageInBound');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('SOP_VoyageOutBound');
//	xmlElem.setText( voyage.code );
	xmlElem.setText( _ti.myOperator.getXlationForeignCode( voyage.code, XLATION_TYPE_VOYAGETERMINAL, foundMatch) );	//13 Mar 2017	NDL	TFS 3710
/*	
	xmlElem := rootElem.addElement('LOP_VoyageInBound');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('LOP_VoyageOutBound');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ScheduledDeparture');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ScheduledArrival');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('IsVesselChanged');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('IsVoyageChanged');
	xmlElem.setText( null );
*/	

epilog

end;</source>
