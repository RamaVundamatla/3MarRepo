    <JadeMethod name="actionCargoUpdateRequest" id="745717f9-4477-44e5-ba30-bcaaafb44849">
        <updating/>
        <source>actionCargoUpdateRequest(_ti : CM_TrackedItem input; _ignorePermissionValidation: Boolean; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	tiUpdateCntrl 	: CMIF_TIUpdateController;

begin

	if self.type = EventRequestTypeToDo then
		self.actionTiUpdateToDoTask( _ti, _passport );
		
	elseif self.type = EventRequestTypeRemarks then
		tiUpdateCntrl := app.createTIUpdateControl( TI_UPDMODE_NORMAL, _passport.userCode, null );
		_ti.setRemarksTrans( self.cargoRemarks, true, tiUpdateCntrl, _passport );
		
	elseif self.type = EventRequestTypeGrade then
		tiUpdateCntrl := app.createTIUpdateControl( TI_UPDMODE_NORMAL, _passport.userCode, null );
		_ti.setAvailabilityGrade( self.myGrade.code, tiUpdateCntrl ,_passport );
		
	elseif self.type = EventRequestTypeWeight then
		self.actionTiUpdateWeight( _ti, _passport );
		
	endif;
	
	if self.isNotify then
		self.sendEmail(_passport);
	endif;

epilog

	delete tiUpdateCntrl;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ignorePermissionValidation" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionTiUpdateToDoTask" id="5b254a17-8343-42cf-b6e4-9803b6a9f83e">
        <source>actionTiUpdateToDoTask(	_ti : CM_TrackedItem input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	toDoTask : CM_ToDoTask;
	task : CM_ToDoTask;
	tiTask : CM_TiToDoTask;	
	trans : CM_TITransaction;

begin

	if self.isClear then
		_ti.removeToDoTask(self.myToDoTaskDesc.description,_passport);
		
	else	
		if (not self.myToDoTaskDesc.isAvailableForCargoType(_ti.cargoType)) then
			self.raiseAlert( _ti, app.getErrorString2(ERR_NotAvailableForCargoType,  self.myToDoTaskDesc.description, _ti.id) );
			return;
		endif;
		
		if self.myToDoTaskDesc.isForGenSetAttachDetach() and _ti.isKindOf(CM_Container) and (not _ti.CM_Container.isReefer) then
			 self.raiseAlert( _ti, app.getErrorString2(ERR_NotValidForReefer, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, _ti.id) );
			return;
		endif;
		
		if _ti.isKindOf(CM_Container) or _ti.isKindOf(CM_TILC) then
			if not self.myToDoTaskDesc.isValidForGenSet(self)then
				if _ti.hasGeneratorSetAttached then
					self.raiseAlert( _ti, app.getErrorString2(ERR_IsNotValid, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, app.getErrorString(CM_GenSetAttached) &amp; " to " &amp;  self.myTrackedItem.id) );
				else
					self.raiseAlert( _ti, app.getErrorString2(ERR_IsNotValid, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, app.getErrorString(CM_NoGenSetAttached) &amp; " to " &amp;  self.myTrackedItem.id) );
				endif;
				return;
			endif;
		
		endif;
		
		if  self.myToDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_CHILL_TEST and (not _ti.isIntegral)then
			 self.raiseAlert( _ti, app.getErrorString3(ERR_INVALID_ISOTYPE, "Not an Integral Container", 'the todo task', self.myToDoTaskDesc.description ) );
			return;
		endif;
		
		if not _ti.hasToDoTaskToDoWithCode(self.myToDoTaskDesc.code) then
			create tiTask persistent;
			trans := tiTask.setForCreate(STATUS_TODO,self.myToDoTaskDesc, self.toDoRemarks, _passport, _ti); 
			if trans &lt;&gt; null then
				trans.setExtraData(TrnsExtraDataContext, "Added from Cargo Update Request");
			endif;
			self.updateObjectEdition(_ti);
		else	
			tiTask := _ti.getToDoTaskToDoWithCode(self.myToDoTaskDesc.code).CM_TiToDoTask;
			if tiTask &lt;&gt; null then
				tiTask.setRemarks( self.toDoRemarks );
			endif;
		endif;	
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionTiUpdateWeight" id="55cf4db9-3d9a-44cd-b400-54c340a31985">
        <source>actionTiUpdateWeight(	_ti : CM_TrackedItem input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	tiUpdateCntrl 	: CMIF_TIUpdateController;
	vgmDetails : CM_VGMDetails;						
	authSig, commsType, docDetails, ediTrans, email,
	mail, phone, fax, telephone : String;
	docsIssued, determination : TimeStamp;
	isCertified :Boolean;
	
begin
	
	tiUpdateCntrl := app.createTIUpdateControl( TI_UPDMODE_NORMAL, _passport.userCode, null );
	
	isCertified:=self.isWeightCertified;
	if not _ti.myCargoType.canWeightBeCertified then
		isCertified:=false;
	endif;
	_ti.setTotalWeightAndCertified( self.totalWeight, _ti.weightCargo, _ti.weightTare, isCertified, tiUpdateCntrl, _passport );
	
	if isCertified then
		vgmDetails := _ti.getMyVGMDetails();																	
		if vgmDetails &lt;&gt; null then																							
			authSig := vgmDetails.vgmAuthSignature;																			
			commsType := vgmDetails.vgmCommsType;																			
			docDetails := vgmDetails.vgmDocumentDetails;																	
			ediTrans := vgmDetails.vgmEDITransmission;																		
			email := vgmDetails.vgmElectronicMail;																			
			mail := vgmDetails.vgmMail;																						
			phone := vgmDetails.vgmPhone;																					
			fax := vgmDetails.vgmTelefax;																					
			telephone := vgmDetails.vgmTelephone;																				
			docsIssued := vgmDetails.vgmDocsIssuedDT;																		
			determination := vgmDetails.vgmDeterminationDT;																	
		endif;	
		
		_ti.setMyVGMDetails( self.reference, self.weightCertifiedName, 										
							 authSig, commsType, docDetails, ediTrans, email, mail, 							
							 phone, fax, telephone, docsIssued, determination, tiUpdateCntrl );				
		
		_ti.checkVGMDetails( _passport );
		
	endif;
	
epilog

	delete tiUpdateCntrl;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="differsFrom" id="6e4f241f-d21d-4155-bb91-75e1aa623384">
        <source>differsFrom( pxyEventRequest : CM_EventRequestForStop ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

begin

	//check all attributes we care about.... (per type)
	if self.type = EventRequestTypeToDo then
		if pxyEventRequest.myToDoTaskDesc &lt;&gt; self.myToDoTaskDesc then
			return true;
		endif;
		if pxyEventRequest.toDoRemarks &lt;&gt; self.toDoRemarks then
			return true;
		endif;
		if pxyEventRequest.isClear &lt;&gt; self.isClear then
			return true;
		endif;
		
	elseif self.type = EventRequestTypeRemarks then	
		if pxyEventRequest.cargoRemarks &lt;&gt; self.cargoRemarks then
			return true;
		endif;
		
	elseif self.type = EventRequestTypeGrade then
		if pxyEventRequest.myGrade &lt;&gt; self.myGrade then
			return true;
		endif;
		
	elseif self.type = EventRequestTypeWeight then
		if pxyEventRequest.totalWeight &lt;&gt; self.totalWeight then
			return true;
		endif;
		if pxyEventRequest.reference &lt;&gt; self.reference then
			return true;
		endif;
		if pxyEventRequest.weightCertifiedName &lt;&gt; self.weightCertifiedName then
			return true;
		endif;
		if pxyEventRequest.isWeightCertified &lt;&gt; self.isWeightCertified then
			return true;
		endif; 
		
	endif;
	
	if pxyEventRequest.isNotify &lt;&gt; self.isNotify then
		return true;
	endif;
	
	if pxyEventRequest.allEmailAddresses.differsFrom( self.allEmailAddresses ) then
		return true;
	endif;
	

	return false;

epilog

end;</source>
        <Parameter name="pxyEventRequest" type="CM_EventRequestForStop"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSendSubject" id="25adada7-c658-43f3-a4f1-0e58fe022b51">
        <source>getSendSubject(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars
	str, strCargoType, strId, strStop, strUnknown : String;
begin
	strId			:= self.getMyTrackedItemId;	
// 14/12/2010	cnwcs5	ccms mes 1112/par 24464 - start
	if self.status = EventRequestCargoDeleted then
		
		strCargoType	:= self.getMyCargoTypeDescription;			
		
		strStop			:= self.getStopDescription;
		
		str := app.getErrorString3 (Prenote_stop_deleted, strCargoType, strId, strStop);
		
		return str;
	endif;
// 14/12/2010	cnwcs5	ccms mes 1112/par 24464 - end
	if self.isClear then
		return app.getErrorString4(Cargo_Update_Request_Cleared, self.myStopTableTemplate.myTerminal.name,self.typeString,null, strId);	
	else
		return app.getErrorString4(Cargo_Update_Request_Added,self.myStopTableTemplate.myTerminal.name,self.typeString,null, strId);
		
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
