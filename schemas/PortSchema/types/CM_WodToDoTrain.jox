    <JadeMethod name="updateStatusWoWLE" id="eeb2e7f6-0cab-403b-838f-b9e447000a15">
        <source>updateStatusWoWLE(_status : Integer;
				  _train     : CM_Train);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	woJob	:	CM_Job;
	wle		:	CM_WorkListEntry;
begin
	foreach woJob in self.allJobs do
		if woJob &lt;&gt; null then
			foreach wle in woJob.workListEntries do
					if wle.CM_WOTrainToDoWLE.myTrain &lt;&gt; _train then
						continue;
					endif;
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="validate" id="7cb58867-c16f-4524-8e27-c30de8f195b2">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2022	navcs2  ChangeRequest 54344: EUP - VAS Work Orders - Jobs
28 Dec 2022		navhl20	Task 56057(54344): WodToDoDetail validation
*/

vars

begin
	//Start 28.12.2022 navhl20 TFS 56057(54344)
	inheritMethod();
	if self.allTrains.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Train), null, null); 
	endif;
	//End 28.12.2022 navhl20 TFS 56057(54344)
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
