    <JadeMethod name="setTransactionStateFlag" id="78d41635-2118-44c4-8fc6-bea27a4c33bd">
        <updating/>
        <source>setTransactionStateFlag(pIsDoTransactionState:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 April 2003 by cnwdad1
//
// Purpose:		Sets a flag to tell the peer schema whether to handle database
//				transaction state.  If false, it will be assumed that the application
//				schema will handle the transaction state.
//
//				The flag will default to true.
//
// Parameters:	pIsDoTransactionState - True if the peer schema will handle the
//					transaction state, or false if the application schema will
//					handle the transaction state.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isDoTransactionState &lt;&gt; pIsDoTransactionState then
		self.isDoTransactionState	:=	pIsDoTransactionState;
	endif;
end;</source>
        <Parameter name="pIsDoTransactionState" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showLicenseMaintenance" id="f9e9b083-d280-4fca-ac64-b78510760118">
        <source>showLicenseMaintenance();
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Shows a form with which to maintain a list of license registration keys.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMaintenanceForm	: JSSLKLicenseMaintenanceForm;
	
begin
	create theMaintenanceForm;
	theMaintenanceForm.setReferences(self.getManager, self, self.myRoot);
	
	theMaintenanceForm.showModal();
end;</source>
    </JadeMethod>
</Class>
