//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// --------------------------------------------------------------------------------
begin
	if set then
		// Do nothing.
	else

	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
