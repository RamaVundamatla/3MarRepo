    </JadeMethod>
    <JadeMethod name="setupForm" id="b295e4df-239c-4fd7-91d6-bbf4d43d2724">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 30 June 2004 by cnwdvb1
// 05 Oct 2018	jlgrh7 TFS #41253 SNO - Voyage Schedule error
// -------------------------------------------
vars

begin
	inheritMethod();
	
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle		:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:= true;
	self.frmSchedule.left	:= 0;
	self.frmSchedule.width	:= self.clientWidth;
	//self.lstSchedules.displayCollection(self.allAutoSchedules, false, 0, null);			// 4/10/18 MAP TFS41260 //+TFS41253  put itback
	self.fillTable(); //TFS41408 jlgzm1 replaces displayCollection to display sorted set
	
	self.frmSchedule.top := self.topMargin + self.frmToolbar.height;
	
	self.cmbPorts.myAssistant := self.myAssistant;
	
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Voyage) then
		self.cmbPorts.setObjectAndVoyage(null, self.myCurrentObject.CM_Voyage);	
	endif;
	// CPL CCMS 2120 Nov 2011 use this form for invoice packages as well as voyages
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Invoice) then
		self.setCaption("Invoice Package Selector");
		self.cmbPorts.visible := false;
		self.lblPort.visible := false;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRun.enabled:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupSelector" id="fbe27476-3d5c-4420-bcdc-fd0d173473a2">
        <updating/>
        <source>setupSelector(	_type			: Integer;
				_allSchedules	: CM_AutoSchedulesByStartTsDict input;
				_caption		: String;
				_object			: CM_Object;
				_strArray		: StringArray input) updating;
// -------------------------------------------
// Created 30 June 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.theCaption := _caption[1:30];
	self.caption := self.caption &amp; ' ' &amp; _caption;
	self.allSelectedSchedules := _allSchedules;
	app.myRoot.allAutoSchedulesByStartTs.getEventSchedulesOfType(_type, self.allAutoSchedules);
	self.myCurrentObject := _object;
	self.allExtraStrings := _strArray;


end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_allSchedules" type="CM_AutoSchedulesByStartTsDict" usage="input"/>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="46da5717-d7c0-4d82-8f9a-ef31259216f1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007438, locale);
	btnRun.translateBubbleHelp(Xlat_0000421, locale);
	btnRun.translateCaption(Xlat_0000422, locale);
	lblPort.translateCaption(Xlat_0000420, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="79fe5ac7-ec6e-4a41-96d5-f2ae8e1ba7f8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

// Created by cnwdvb1 on 28 June 2006

vars

begin

	self.addToExtraStrings();
end;</source>
    </JadeMethod>
