    <JadeMethod name="cmbTruck1Wle_click" id="fe64b26c-3716-44b8-9714-ea210e85f13e">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTruck1Wle_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	obj : Object;
	ti : CM_TrackedItem;
	desc1 : String;
	desc2 : String;

begin

	obj := self.cmbTruck1Wle.listObject;
	
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkListEntry) and obj.CM_WorkListEntry.myTrackedItem &lt;&gt; null then
		ti := obj.CM_WorkListEntry.myTrackedItem;
		ti.getShortDescriptions( desc1, desc2 );
		self.lblCargo1Type.caption := desc1;
	else
		self.lblCargo1Type.caption := null;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTruck2Wle_click" id="3ffe172c-d639-434a-baac-86767bc9d0a5">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTruck2Wle_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	obj : Object;
	ti : CM_TrackedItem;
	desc1 : String;
	desc2 : String;
	truck2 : CM_Vehicle;

begin

	obj := self.cmbTruck2Wle.listObject;
	
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkListEntry) and obj.CM_WorkListEntry.myTrackedItem &lt;&gt; null then
		ti := obj.CM_WorkListEntry.myTrackedItem;
		ti.getShortDescriptions( desc1, desc2 );
		self.lblCargo2Type.caption := desc1;
		
		truck2 := obj.CM_WorkListEntry.job.CM_RoadJob.myVehicle;
		self.cmbTruck2.listIndex := self.cmbTruck2.findObject( truck2 );
	else
		self.lblCargo2Type.caption := null;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTruck2_click" id="fcd5d16e-4fea-48df-abc2-d9e7b6572ee0">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTruck2_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	truck2 : CM_Vehicle;

begin

	truck2 := self.cmbTruck2.listObject.CM_Vehicle;
	if truck2 = null then
		self.txtState2.text := null;
	else
		self.txtState2.text := truck2.state;
	endif;
	
	self.populateCmbTruckWles( self.cmbTruck2Wle, truck2 );

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="25a36d06-b142-4f3b-8df1-0f0370563b09">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	stdHeight : Real;
	stdWidth : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	tabIndex := 4000;
	
	top := self.resizedMargin;
	if _initialSetup then
		self.txtTruck1.visible := true;
		self.txtTruck1.enabled := false;
		self.txtTruck1.setAndIncrementTabIndex( tabIndex );
	endif;
	self.txtTruck1.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );						
							 
	top := top + self.txtTruck1.height + self.resizedMargin;
	if self.myMobileGenericAgent.showState then
		if _initialSetup then
			self.txtState1.visible := true;
			self.txtState1.enabled := false;
			self.txtState1.setAndIncrementTabIndex( tabIndex );
		endif;
		self.txtState1.move(	self.resizedMargin,
								top,
								stdWidth,
								stdHeight );						
		top := top + self.txtState1.height + self.resizedMargin;
	else
		if _initialSetup then
			self.txtState1.visible := false;
		endif;
	endif;
	
	if _initialSetup then
		self.cmbTruck1Wle.visible := true;
		self.cmbTruck1Wle.setAndIncrementTabIndex( tabIndex );
	endif;
	self.cmbTruck1Wle.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
							
	top := top + self.cmbTruck1Wle.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargo1Type.visible := true;
		self.lblCargo1Type.enabled := false;
		self.lblCargo1Type.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargo1Type.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
							
	top := top + self.lblCargo1Type.height + self.lblCargo1Type.height;
	if _initialSetup then
		self.cmbTruck2.visible := true;
		self.cmbTruck2.setAndIncrementTabIndex( tabIndex );
	endif;
	self.cmbTruck2.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
							 
	top := top + self.cmbTruck2.height + self.resizedMargin;
	
	if self.myMobileGenericAgent.showState then
		if _initialSetup then
			self.txtState2.visible := true;
			self.txtState2.enabled := false;
			self.txtState2.setAndIncrementTabIndex( tabIndex );
		endif;
		self.txtState2.move(	self.resizedMargin,
								top,
								stdWidth,
								stdHeight );
								
		top := top + self.txtState2.height + self.resizedMargin;
	else
		if _initialSetup then
			self.txtState2.visible := false;
		endif;
	endif;
	
	if _initialSetup then
		self.cmbTruck2Wle.visible := true;
		self.cmbTruck2Wle.setAndIncrementTabIndex( tabIndex );
	endif;
	self.cmbTruck2Wle.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
							
	top := top + self.cmbTruck2Wle.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargo2Type.visible := true;
		self.lblCargo2Type.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargo2Type.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSwapCargo" id="279d967f-23a9-44e0-9ed1-869c627aba2c">
        <source>doSwapCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	wleTruck1 : CM_WorkListEntry;
	wleTruck2 : CM_WorkListEntry;
	result : Integer;
	msg : String;

begin

	wleTruck1 := self.cmbTruck1Wle.listObject.CM_WorkListEntry;
	wleTruck2 := self.cmbTruck2Wle.listObject.CM_WorkListEntry;

	if wleTruck1 = null or wleTruck2 = null then
		msg := app.getErrorString(Two_Items_Required);
		self.msgBox( msg, app.getErrorString(Error),MsgBox_OK_Only, false);
		return false;
	endif;
	
	while true do
		app.myTrxUA.trxSwapTruckTasks( wleTruck1, wleTruck2, app.myPassport );

		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog( app.getErrorString( Cargo_swap ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentTrucks" id="cbfb0168-ab86-44d8-9023-3d2c3088f899">
        <source>getAllCurrentTrucks( _allTrucks : CM_VehicleSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	iter : Iterator;
	roadJob : CM_RoadJob;
	truck : CM_Vehicle;

begin

	term := self.myMobileGenericAgent.getTerminal();

	if term = null or term.myRoadJobSheet = null then
		return;
	endif;
	
	iter := term.myRoadJobSheet.allJobsByOrder.createIterator;
	while iter.next( roadJob ) do
		if roadJob.status = JOB_COMPLETE
		or (roadJob.status = JOB_UNVERIFIED
		or roadJob.status = JOB_TROUBLE)
		then
			continue;
		endif;
		truck := roadJob.myVehicle;
		if truck = self.myPrimaryTruck then
			continue;
		endif;
		
		_allTrucks.addNoDuplicates( truck, false );
		
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_allTrucks" type="CM_VehicleSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="0ebad716-dc3d-4d83-af36-edf73c7beb76">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

begin

	if self.doSwapCargo() then
		self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
