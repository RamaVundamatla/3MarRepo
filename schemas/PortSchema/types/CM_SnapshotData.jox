    <JadeMethod name="getNumItems" id="889edb63-11d0-49e4-be78-94e9bd3bb158">
        <source>getNumItems():Integer protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
11 December 2009	cnwndl1	Initial creation	CCMS 1023
17/12/2009			cnwcs5	Change coll used from array to set for performance reasons
							Not sensible to use array.includes for coll of unknown size
							as we have to go through every entry in the collection and check
17/02/2010			cnwcs5	Made method protected as numberOfItems now stored on the object
*/
vars
	retValue 		: Integer;
	iter 			: Iterator;
	dynObj 			: CM_DynamicObject_Snapshot;
	obj 			: Object;
	coll		 	: CM_ObjectSet;				// cnwcs5 17/12/2009
begin
	create coll transient;
	iter := self.allSnapshotData.createIterator;
	
	while iter.next( dynObj ) do
		foreach obj in dynObj.allObjects do
			coll.addNoDuplicates (obj, false);	// cnwcs5 17/12/2009	
			//if not objectArray.includes(obj) then
			//	objectArray.add( obj );
			//endif;
		endforeach;
	endwhile;
	
	return coll.size;
epilog
	delete coll;
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryDefinition" id="ff0b8053-820e-4526-8e8b-067441f6a2f5">
