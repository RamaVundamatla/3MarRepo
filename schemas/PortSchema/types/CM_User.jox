    <JadeMethod name="isRecentlyUsedPassword" id="161b9404-64df-4d9a-8ed3-576056e6967b">
        <source>isRecentlyUsedPassword(pw : String) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	password	: Binary;
	pwBin		: Binary;
	l, count, index			: Integer;
	passwordsToCheck : BinaryArray;
begin
	pwBin	:=	app.encryptPassword(self.code, pw, self.isNewEncryptionImplemented);
	
	// PAR 12373 - change to validly check recent passwords
	// - need to check length
	l := pwBin.length;
	
	count := app.myRoot.getConfig(NumberOfPrevPasswords).Integer; // Par 15460 - AER 17/07/07
	foreach password in self.recentPasswords where count &gt; 0 do
		if password[1:l] = pwBin then
			return true;
		endif;
		count := count -1;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pw" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
