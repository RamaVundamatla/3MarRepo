    <JadeMethod name="loadLstWODtlType" id="737a3315-0c80-4602-bd88-9b8767f6bf87">
        <source>loadLstWODtlType(_allDetailTypes : CM_WorkOrderDetailTypeArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	detailType 	: CM_WorkOrderDetailType;
	str			: String;
	select,
	idx 		: Integer;
begin
	self.lstWODtlType.rows 	:= self.lstWODtlType.fixedRows;
	self.lstWODtlType.clearSelected();
	
	foreach detailType in app.myRoot.allWorkOrderTaskTypes do
		if detailType.description.cnContains("Receive Cargo") or detailType.description.cnContains("Release Cargo") then
			select := 0;
			str := detailType.description &amp; " - Ship";
			if _allDetailTypes &lt;&gt; null and _allDetailTypes.includes(detailType) &lt;&gt; null then
				select := 1;
				self.lstWODtlType.allSelectedObjects.add(detailType);	
			endif;
			
			idx := self.lstWODtlType.addItem(select.String &amp; Tab &amp; str); 
			self.lstWODtlType.accessRow(idx).itemObject := detailType;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allDetailTypes" type="CM_WorkOrderDetailTypeArray"/>
    </JadeMethod>
    <JadeMethod name="loadTimeSlotAction" id="c57ca836-bf27-4c3e-ac2b-c0942d62a347">
        <source>loadTimeSlotAction(value : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	vbts : CM_VehicleBookingTimeSlotType;
begin
	self.cmbTimeslotAction.clear;
	
	self.cmbTimeslotAction.addItemAt( app.vbsEnumToString(CM_VehicleBookingTimeSlotType.VBS_ENTRY_NOACTION) ,1 );
	self.cmbTimeslotAction.addItemAt( app.vbsEnumToString(CM_VehicleBookingTimeSlotType.VBS_ENTRY_WARN), 2 );
	self.cmbTimeslotAction.addItemAt( app.vbsEnumToString(CM_VehicleBookingTimeSlotType.VBS_ENTRY_ERROR), 3 );
	
	if value &gt;= 0 then
		self.cmbTimeslotAction.listIndex := value + 1;
	endif;
epilog

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
