    <JadeMethod name="setSecondaryObject" id="ade1c55a-bb01-48aa-aa36-1da86c907039">
        <updating/>
        <source>setSecondaryObject(_obj: CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation

*/

vars

begin

	self.myCrane := null;
	self.myWorkPoint := null;
	
	if _obj &lt;&gt; null then
		if _obj.isKindOf( CM_Crane ) then
			self.myCrane := _obj.CM_Crane;
		elseif _obj.isKindOf( CM_WorkPoint ) then
			self.myWorkPoint := _obj.CM_WorkPoint;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="a9b7646d-7f9e-4f04-99a3-bbb60c3c1a29">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	opHrs : CM_WorkPointOperatingHours;

begin

	if obj &lt;&gt; null and obj.isKindOf(CM_WorkPointOperatingHours) then
		opHrs := obj.CM_WorkPointOperatingHours;
	endif;
	
	self.populateFields( opHrs, false );

epilog

end;</source>
