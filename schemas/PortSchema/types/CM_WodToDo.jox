    <JadeMethod name="getExtraInfo" id="e5b32969-1bec-4ec5-93ac-f7086ea2ea3a">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	addStr   : String;	
	ti 		 : CM_TrackedItem;
	tis 	 : CM_TISet;
	block    : CM_DataContainerBlock;
	invalid  : Boolean;
begin
	inheritMethod(_dataContainer);

epilog
	
	if self.allToDoTasksDescs.isNotEmpty() then														//15.3.2023 navhl20	#56614[56615]
		addStr := self.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name);		//15.3.2023 navhl20	#56614[56615]
	endif;
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Todo_task), DC_Label, 1, ti);
		block.addNewItem(addStr, DC_Data, 1, ti);
	endif;	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="ff146cc7-6750-4c1f-9960-51c367144c41">
        <source>getInstructionsForContext(_instructions   : CM_InstructionsIssuedSet io;
						  _passingObject  : Object;
						  _context		  : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	dynaDict	: DynaDictionary;
	object		: Object;
	inst		: CM_InstructionsIssued;
	toDoTask	: CM_TiToDoTask;
begin
	inheritMethod(_instructions, _passingObject, _context);
	create dynaDict transient;
	dynaDict.setMembership(CM_TiToDoTask);
	dynaDict.addMemberKey(CM_TiToDoTask::myInstructions.name, true, true);
	dynaDict.endKeys(true);
	
	self.allToDoTasks.copy(dynaDict);
	
	
	foreach object in dynaDict do
		toDoTask := object.CM_TiToDoTask;
		inst := toDoTask.getInstructions();
		_instructions.tryAddIfNotNull(inst);
		
		if inst = null then
			break;
		endif;
	endforeach;

epilog
	delete dynaDict;
end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
