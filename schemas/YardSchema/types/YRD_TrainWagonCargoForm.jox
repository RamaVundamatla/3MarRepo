    <JadeMethod name="cmbCargoType_click" id="164e4f81-5618-4fd3-b0b7-afc7dbb1e1e0">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwmd1	Initial creation

*/

vars
	cargoType : CM_CargoType;
begin
	cargoType := combobox.listObject.CM_CargoType;
	
	if cargoType &lt;&gt; null then
		self.buildComboCargo(cargoType.id, self.cmbCargoID);
	else
		self.cmbCargoID.clear();
	endif;
epilog

end;</source>
