    <JadeMethod name="getUnderDeckOffSet" id="af24393f-2165-48cc-819b-d3251d889c54">
        <source>getUnderDeckOffSet(_bayDrawingController : SHP_BayDrawingController) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     06 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	num : Integer;
begin
	num := self.myBay.getNumTiersTotallyAvailable(false);
	return _bayDrawingController.yUnderDeckPos + (num* _bayDrawingController.rowHeight).Integer;
//	return _bayDrawingController.yUnderDeckPos + (self.myBay.allTiersUnderDeck.size * _bayDrawingController.rowHeight).Integer;
end;</source>
        <access>protected</access>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleBulkSelectForPlanMove" id="f11af8b9-05fd-4b82-850e-350ad9b40d75">
        <source>handleBulkSelectForPlanMove(tmpController : SHP_BayDrawingController);
// ---------------------------------------------------------------------------
// Created:     25 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theLCs : CM_LCArray;
	theObj : Object;
begin
	//### PAR 22496 added this block of code , same as at the bottom of the method to handle de selects.
		// ### CCMS 1368 SHIP ROAD MAP MULTI LOAD PLANNING
		// ## LOAD PLANNING BULK PLAN
		if tmpController &lt;&gt; null 
		and tmpController.displayMode = ShpDisplayMode_ColCodeLoad
		and tmpController.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan
		and app.myMoveController &lt;&gt; null
		and tmpController.allSelectedObjects.size &gt; 1 then
	
			create theLCs transient;
			foreach theObj in tmpController.allSelectedObjects do
				if theObj.isKindOf(CM_SlotController) then
					theLCs.add(theObj.CM_SlotController);
				endif;
			endforeach;
			app.myMoveController.updateAllToLocations(theLCs);
		endif;
	
	//###

epilog
	delete theLCs;
end;</source>
        <Parameter name="tmpController" type="SHP_BayDrawingController"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUp" id="3216375c-1425-421f-914b-1db4bb130f21">
        <updating/>
        <source>handleMouseUp(_obj : Object; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theLCs : CM_LCArray;
	theObj			: Object;
	tmpController	: SHP_BayDrawingController;
	tmpObject		: Object;
	isOnDeck,
	isSelect,
	isSelectAlt,
	isLPAlt,
	isSlotController,
	isControlKey,
	isBlock			: Boolean;
	tmpSlotController	: CM_SlotController;
begin

	if _obj = null then
		return;
	endif;


	tmpController := self.myBayDrawingController;
	if tmpController = null then
		app.raiseCMException1(MethodWithNullParam, 'bayDrawingController', null, null);
		return;
	endif;

	if (not tmpController.isSelectObjectsEnabled) then
		return;
	endif;
	
	if (not shift.isShiftKeyPressed) and  
	   (not shift.isControlKeyPressed) and 
	   (not shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL

		if button = Button.MouseButton_Left then
			// clear existing selection
			tmpController.clearAllSelectedObjects();
			self.myStartObject := null;
			self.myStartObjectHatch := null;
			self.myStartObjectOnDeck := null;
			self.myStartObjectUnderDeck := null;
			isSelect := true;
		endif;

	elseif shift.isShiftKeyPressed then // SHIFT
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
			isBlock := true;
		else
			isSelect := true;
			isBlock := true;
		endif;

	elseif shift.isControlKeyPressed then // CONTROL
		isControlKey := true;
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
		else
			isSelect := true;
		endif;

	elseif shift.isAltKeyPressed then // ALT
		if button = Button.MouseButton_Left then
			tmpController.clearAllSelectedObjectsAlt();
			isSelectAlt := true;
		elseif button = Button.MouseButton_Right then
			self.myStartObjectAlt := null;
			self.myStartObjectAltHatch := null;
			self.myStartObjectAltOnDeck := null;
			self.myStartObjectAltUnderDeck := null;
		endif;
	endif;

	if (not (isSelect or isSelectAlt)) then
		return;
	endif;
	
	if tmpController.isLoadPlanning and isSelectAlt then
		isSelectAlt := false;
		isSelect := true;
		isControlKey := true;
		isLPAlt := true;
			// clear existing selection
			tmpController.clearAllSelectedObjects();
			self.myStartObject := null;
			self.myStartObjectHatch := null;
			self.myStartObjectOnDeck := null;
			self.myStartObjectUnderDeck := null;
			isSelect := true;
	endif;
	
	if isSelect and tmpController.allSelectedObjects.includes(_obj) then
		tmpController.allSelectedObjects.remove(_obj);
		self.drawObject(_obj, tmpController);
		
		//par 18740.  If an item is deselected then set the currently
		//selected item to the first item in the forms selected objects.
		if tmpController.allSelectedObjects.size &gt; 0 then
			if tmpController.allSelectedObjects.first.CM_SlotController.allSlotRequestsLoad.size &gt; 0 then
				if app.myMoveController &lt;&gt; null then
					app.myMoveController.mySlotRequest := tmpController.allSelectedObjects.first.CM_SlotController.allSlotRequestsLoad.first; 
				else
					//not in planning mode.  Doing nothing actually.  Most likely testing.
				endif;
			else
				//possible a discharge planning mode??
				//currently do nothing since there are no pars for this area
				//at this time
			endif;
		else
			//all selected objects on the form have been deselected
			//set to NULL so other forms don't attempt to plan
			if app.myMoveController &lt;&gt; null then
				app.myMoveController.mySlotRequest := null;
			else
				//not in planning mode.  Doing nothing actually.  Most likely testing.
			endif;
		endif;
		
		//### PAR 22496 added this block of code , same as at the bottom of the method to handle de selects.
		self.handleBulkSelectForPlanMove(tmpController);
			
		return;
	elseif isSelectAlt and tmpController.allSelectedObjectsAlt.includes(_obj) then
		tmpController.allSelectedObjectsAlt.remove(_obj);
		self.drawObject(_obj, tmpController);
		return;
	endif;

	isSlotController := CM_SlotController.hasInstance(_obj);

	if _obj.isKindOf(CM_HatchLid) then
		if isSelect then
			if isBlock then
				self.selectBlockOfHatchLids(_obj.CM_HatchLid, self.myStartObjectHatch, false);
			else
				self.selectHatchLid(_obj.CM_HatchLid, self.myStartObjectHatch, false);
			endif;
		elseif isSelectAlt then
			if isBlock then
				self.selectBlockOfHatchLids(_obj.CM_HatchLid, self.myStartObjectAltHatch, true);
			else
				self.selectHatchLid(_obj.CM_HatchLid, self.myStartObjectAltHatch, true);
			endif;
		endif;
		
	elseif isSlotController or 
		   CM_SlotDefn.hasInstance(_obj) then
		if isSlotController then
			tmpSlotController := _obj.CM_SlotController;
			isOnDeck := tmpSlotController.mySlotDefnVoyage.isOnDeck;
		else
			isOnDeck := _obj.CM_SlotDefn.isOnDeck;
		endif;
		if isOnDeck then
			if isSelect then
				if isBlock then
					self.selectBlockOfSlots(_obj, self.myStartObjectOnDeck, false);
				else
					self.selectObject(_obj, self.myStartObjectOnDeck, false);
				endif;
			elseif isSelectAlt then
				if isBlock then
					self.selectBlockOfSlots(_obj, self.myStartObjectAltOnDeck, true);
				else
					self.selectObject(_obj, self.myStartObjectAltOnDeck, true);
				endif;
			endif;
		else
			if isSelect then
				if isBlock then
					self.selectBlockOfSlots(_obj, self.myStartObjectUnderDeck, false);
				else
					self.selectObject(_obj, self.myStartObjectUnderDeck, false);
				endif;
			elseif isSelectAlt then
				if isBlock then
					self.selectBlockOfSlots(_obj, self.myStartObjectAltUnderDeck, true);
				else
					self.selectObject(_obj, self.myStartObjectAltUnderDeck, true);
				endif;
			endif;
		endif;
		
		if isSlotController and
		   tmpController.workingMode = SHP_VoyageAreaForm2.WorkMode_Job then
			tmpController.selectSlotsForJob(tmpSlotController);
		endif;
	endif;
	//### PAR 22496 added this block of code , same as at the bottom of the method to handle de selects.
	// ### CCMS 1368 SHIP ROAD MAP MULTI LOAD PLANNING
	// ## LOAD PLANNING BULK PLAN
	self.handleBulkSelectForPlanMove(tmpController);

	/*
	if tmpController &lt;&gt; null 
	and tmpController.displayMode = ShpDisplayMode_ColCodeLoad
	and tmpController.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan
	and app.myMoveController &lt;&gt; null
	and tmpController.allSelectedObjects.size &gt; 1 then
		create theLCs transient;
		foreach theObj in tmpController.allSelectedObjects do
			if theObj.isKindOf(CM_SlotController) then
				theLCs.add(theObj.CM_SlotController);
			endif;
		endforeach;
		app.myMoveController.updateAllToLocations(theLCs);
	endif;
	*/
epilog
	delete theLCs;
	self.enableEvent("mouseMove", false);
	app.isDragging := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="init" id="5db072a4-79a7-4597-ab5b-c63ab2c41ec7">
        <updating/>
        <source>init(_bay : CM_Bay; _x, _y, _width, _height : Real; _colour : Integer; _controller : SHP_BayDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.clearGraphics;
	
	if _bay = null then
		return;
	endif;

	self.myBay := _bay;
	self.move(_x, _y, _width, _height);

	self.backColor	:= _colour;
	self.id := _bay.id;
	self.ignoreSkin := true;
	
	self.myBayDrawingController := _controller;

	self.myLeftCellDefnOD 	:= _bay.allCellsOnDeckByOrdinal.first;
	self.myRightCellDefnOD	:= _bay.allCellsOnDeckByOrdinal.last;

	self.myLeftCellDefnUD 	:= _bay.allCellsUnderDeckByOrdinal.first;
	self.myRightCellDefnUD	:= _bay.allCellsUnderDeckByOrdinal.last;

	self.myStartObject			:= null;
	self.myStartObjectAlt		:= null;
	self.myStartObjectAltHatch	:= null;
	self.myStartObjectAltOnDeck	:= null;
	self.myStartObjectAltUnderDeck	:= null;
	self.myStartObjectHatch		:= null;
	self.myStartObjectOnDeck	:= null;
	self.myStartObjectUnderDeck	:= null;
	
	self.setDrawingPositions(_controller);

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_controller" type="SHP_BayDrawingController"/>
    </JadeMethod>
