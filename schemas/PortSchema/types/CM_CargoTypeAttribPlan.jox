    <JadeMethod name="clone" id="3124788a-9ceb-4b6e-9b55-1a90cc8689f8">
        <source>clone(toMovePlan : CM_MovePlan io; toMoveMap : CM_MoveMap io);
//Clones this instance, and attaches it to the passed in movePlan
vars
	ap : CM_CargoTypeAttribPlan;
	aa	:	CM_AttributeArea;
	newAA	:	CM_AttributeArea;
begin
	//--- NOTE -----
	//It is QUITE OK to have a NULL MovePlan, this attrib plan exists as a "global"
	//resource available to ALL Movemaps later, its just not selected for any.
	//------------------
	if toMoveMap = null then
		app.raiseCMException1(ERR_NO_OBJECT, "toMoveMap ref missing", null, null);
		return;
	endif;
	//Does the object exist at the moveMap level? If so, we have already added
	//it, if not, create it and bind in as required.
	ap := toMoveMap.allAttributePlans[self.myCargoType, imexStatus, isoTypeGroup, commodityGroup];
	if ap &lt;&gt; null then
		//------------------
		//Add to our new MovePlans collection of attributeplans (auto update)
		//------------------
		if toMovePlan &lt;&gt; null then
			ap.movePlans.add(toMovePlan);
		endif;
		//The attribute plan has already been cloned, return
		return;
	endif;

	ap := cloneSelf(false);
	//----------------	
	//Set my properties
	//----------------	
	ap.commodityGroup := self.commodityGroup;
	ap.isoTypeGroup := self.isoTypeGroup;
	ap.myCargoType := self.myCargoType;
	//-------------
	//Set the moveMap ref to add to dict on the moveMap
	//-------------
	ap.myMoveMap := toMoveMap;
	//------------------
	//Add to our new MovePlans collection of attributeplans (auto update)
	//------------------
	if toMovePlan &lt;&gt; null then
		ap.movePlans.add(toMovePlan);
	endif;
	//------------------
	//Clone the attribute areas..
	//------------------
	foreach aa in self.attributeAreas do
		newAA := aa.clone();
		ap.attributeAreaAdd(newAA);
	endforeach;

end;</source>
        <Parameter name="toMovePlan" type="CM_MovePlan" usage="io"/>
        <Parameter name="toMoveMap" type="CM_MoveMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="commodityGrpStr" id="2251fd2a-720e-4551-a01e-f66021eef076">
        <methodInvocation>mapping</methodInvocation>
        <source>commodityGrpStr(set: Boolean; value: String io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.commodityGroup = null then
		value := null;
		return;
	endif;		
	value := self.commodityGroup.code.trimRight;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="description" id="6e36b222-3286-44e8-b2dd-2e128b0d674f">
        <methodInvocation>mapping</methodInvocation>
        <source>description(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(set, _value);

	_value := self.myCargoType.description &amp; ' / ' &amp; _value &amp; " / " &amp; self.commodityGrpStr &amp; " / " &amp; self.isoTypeGrpStr;
		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
