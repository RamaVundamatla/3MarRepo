    <JadeMethod name="hasStockMovements" id="ccdcc4a4-b5f8-4c50-813d-e18a183b4e21">
        <source>hasStockMovements(): Boolean;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myStockMovementIn &lt;&gt; null or
	   self.myStockMovementOut &lt;&gt; null then
	   	return true;
	endif;
	
	return inheritMethod();

end;</source>
