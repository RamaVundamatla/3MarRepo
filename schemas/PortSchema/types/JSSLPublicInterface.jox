end;</source>
    </JadeMethod>
    <JadeMethod name="deleteLicenseKey" id="420c8b9a-c982-4c72-9d2a-09fdbaf4a868">
        <source>deleteLicenseKey(pCustomerName:String; pProductCode:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Removes a previously registered license key
//
// Parameters:	pCustomerName - The name of the customer who's license to delete.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		True if the license key was deleted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/09/04		cnwgd1		JSSLicenseKeyService::deleteLicenseKey() does not require the license key
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode).Boolean;	
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="editLicenseKey" id="82ba9992-fb4f-4dc5-a2bf-6d3868a57eb0">
        <source>editLicenseKey(pCustomerName:String; pProductCode:String):String;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Shows a form on which to enter a (new) license registration key.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode).String;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enterLicenseKey" id="0280bbd8-d19b-48c9-809e-1215ee402974">
        <source>enterLicenseKey(pCompanyName:String; pLicenseKey:String):String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Accepts a (new) license key, causing the registration bit mask to
//				be rebuilt.  If the key is not valid (i.e. checksum fails) or if
//				any other errors are detected, an exception will be raised (of type
//				JSSException) - refer to the isJSSException method for determining
//				whether an exception was raised by a JSS peer schema.
//
// Parameters:	pCustomerName - The name of the customer to whom the product is
//					registered.
//				pLicenceKey - A string containing the customer's product key.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCompanyName, pLicenseKey).String;
end;</source>
        <Parameter name="pCompanyName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
