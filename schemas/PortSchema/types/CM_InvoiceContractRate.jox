    <JadeMethod name="auditId" id="1a1c226a-c032-4e6d-a518-18ff1ac57e84">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	auditIdStr : String;
begin

	auditIdStr := self.myInvoiceContractDetail.auditId();
	
	if self.myService &lt;&gt; null then
		auditIdStr := auditIdStr &amp; "/" &amp; self.myService.name;
	endif;
	
	return auditIdStr;

epilog

end;</source>
