    <JadeMethod name="convertOldInvoiceStauses" id="301d81fe-b14d-4d21-a0dc-aff102af4aaf">
        <source>convertOldInvoiceStauses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2019	jlgndl1	Initial creation	TFS 39618

*/

vars

	invProcess : CM_InvoiceProcess;
	invStatsToAdd : CM_InvoiceStatusById;
	invStat : CM_InvoiceStatus;

begin

	create invStatsToAdd transient;

	if CM_Root.firstInstance.licenseName.toUpper.pos("PELINDO",1) &gt; 0 then 
	
		invProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessPelindo];
		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_OPEN] );
		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_SUSPENSE] );
	
		if self.permissions.size &gt;= PmAdmInvoiceStatusDisputed and self.permissions[PmAdmInvoiceStatusDisputed] then  //  Invoice Status To Disputed
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_DISPUTED] );
		endif;
		if self.permissions.size &gt;= PmAdmInvListStatusClose and self.permissions[PmAdmInvListStatusClose] then  //  Invoice Status To Pending
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_PENDING] );
		endif;
		if self.permissions.size &gt;= PmAdmInvoiceStatusPost and self.permissions[PmAdmInvoiceStatusPost] then  //  Invoice Status To Post
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_POSTED] );
		endif;
		if self.permissions.size &gt;= PmAdmInvoiceStatusPrepend and self.permissions[PmAdmInvoiceStatusPrepend] then  //  Invoice Status To Prepend
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_PREPEND] );
		endif;
		if self.permissions.size &gt;= PmAdmInvListStatusReturn and self.permissions[PmAdmInvListStatusReturn] then  //  Invoice Status To Return
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE] );
		endif;
		if self.permissions.size &gt;= PmAdmInvoiceStatusVoid and self.permissions[PmAdmInvoiceStatusVoid] then  //  Invoice Status To Void
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_VOID] );
		endif;
	
	else
	
		invProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];
		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_OPEN] );
		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_SUSPENSE] );
	
	//	if self.permissions.size &gt;= PmAdmInvoiceStatusDisputed and self.permissions[PmAdmInvoiceStatusDisputed] then  //  Invoice Status To Disputed
	//		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_DISPUTED] );
	//	endif;
		if self.permissions.size &gt;= PmAdmInvListStatusClose and self.permissions[PmAdmInvListStatusClose] then  //  Invoice Status To Pending
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_PENDING] );
		endif;
		if self.permissions.size &gt;= PmAdmInvoiceStatusPost and self.permissions[PmAdmInvoiceStatusPost] then  //  Invoice Status To Post
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_POSTED] );
		endif;
	//	if self.permissions.size &gt;= PmAdmInvoiceStatusPrepend and self.permissions[PmAdmInvoiceStatusPrepend] then  //  Invoice Status To Prepend
	//		invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_PREPEND] );
	//	endif;
		if self.permissions.size &gt;= PmAdmInvListStatusReturn and self.permissions[PmAdmInvListStatusReturn] then  //  Invoice Status To Return
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE] );
		endif;
		if self.permissions.size &gt;= PmAdmInvoiceStatusVoid and self.permissions[PmAdmInvoiceStatusVoid] then  //  Invoice Status To Void
			invStatsToAdd.add( invProcess.allStatuses[CM_Invoice.INVOICE_VOID] );
		endif;
	
	endif;
	
	foreach invStat in invStatsToAdd do
		self.allInvoiceStatusesMaint.addNoDuplicates( invStat, false );
	endforeach;

epilog

	delete invStatsToAdd;

end;</source>
    </JadeMethod>
