<Class name="CM_VentilationReading" id="1c9c870c-8b51-4735-bfd1-d3a99421fe39">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <ExplicitInverseRef name="myVentReading" id="3113ed84-fe68-4718-a4fa-c7197fe4c8bc">
        <embedded/>
        <type name="CM_VentReading"/>
        <access>readonly</access>
        <Inverse name="CM_VentReading::myVentilationReading"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneForTrackedItemRefs" id="b50dced5-56ff-4a74-9075-cf146788e116">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_VentilationReading) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	self.myVentReading := _orginalTransaction.myVentReading.cloneSelf(self.isTransient);
	self.myVentReading.cloneForTrackedItemRefs(_ti);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_VentilationReading"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a0dc363e-c6a4-4089-bf14-3d19d443bb3a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	detail	: String;
	vent	: CM_VentReading;

begin
	if _attrName = ETRow_Details or _attrName = ETRow_Humidity then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			vent := self.myVentReading;
			if vent &lt;&gt; null then
				detail := vent.getDisplayVentilation();
			endif;
			return detail;
		endif;
	
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="f050434c-0468-4d57-9454-adcadb22f2ed">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18 March 2015	cnwdap1		Initial creation PAR #
//
vars

begin
	self.setVentReading(_tiTransCntrl.CMIF_VentTransController.myVentReading);
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVentReading" id="2d9d4277-e5dc-440f-8ffa-f1a16fe26403">
        <updating/>
        <source>setVentReading(_ventReading : CM_VentReading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	self.myVentReading := _ventReading;
epilog

end;</source>
        <Parameter name="_ventReading" type="CM_VentReading"/>
    </JadeMethod>
</Class>
