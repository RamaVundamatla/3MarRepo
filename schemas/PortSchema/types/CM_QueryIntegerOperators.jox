        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="f8924518-b54b-4bd6-a352-a57346f15364">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 15 Oct 2008	cnwkpd1		PAR #18123 - Protect against non integer values
// -----------------------------------------------------------------------------
vars
	stringValue		: String;
	integerValue	: Integer;
	
begin
	if _value &lt;&gt; null then    // par 18123
		stringValue := _value.String;
		if stringValue.isInteger then
			integerValue := stringValue.Integer;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := integerValue;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
