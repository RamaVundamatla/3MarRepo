    <JadeMethod name="postAllCharges" id="e79bd11a-0bbc-4d39-878f-5a6d7ae3f649">
        <updating/>
        <source>postAllCharges() updating;
// set all mapped properties to themselves to invoke the mapping code
// 23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	charge : CM_Charge;
	isPaymentPostPreOrAuto : Boolean;
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	//epr TFS 44359 15/4/19
	if self.invoice &lt;&gt; null then
		isPaymentPostPreOrAuto:=self.invoice.paymentType = PaymentType_AutoCollection or
								self.invoice.paymentType = PaymentType_PrePay or
								self.invoice.paymentType = PaymentType_PostPay;
	endif;
	// Apr 2012 CCMS 1262 quantity is no longer dynamic
	if not isPaymentPostPreOrAuto then
		self.calculateQuantity();
	endif;
	foreach charge in charges do
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		if not isPaymentPostPreOrAuto then
			charge.evaluateRate();
		endif;
		charge.total := charge.total;
		charge.units := charge.units;
		charge.glCode := charge.glCode;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6a4f61f6-9edb-4ca9-965f-e3e0b91a88ac">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();
	
	pxyMe.invoiceLineDesc := self.invoiceLineDesc;
	pxyMe.bank := self.bank;
	pxyMe.invoice := self.invoice;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="qetQty1Qty2" id="b4b1e1c5-ab71-49ee-9ce6-faffd9835b5b">
        <updating/>
        <source>qetQty1Qty2(quantity1, quantity2 : Decimal output;	uom1, uom2 : String output) updating;
/*
Purpose:			

Date		Who		Reason
09 January 2024	navab1	CR 58085 TASK 61342
*/

vars

begin
	if self.myTransactionTI &lt;&gt; null then
		self.getQty1Qty2CARGO(quantity1, quantity2, uom1, uom2);
	elseif self.myTransactionEvent &lt;&gt; null then
		self.getQty1Qty2EVENT(quantity1, quantity2, uom1, uom2);
	elseif self.myTransactionWO &lt;&gt; null then
		self.getQty1Qty2WORKORDER(quantity1, quantity2, uom1, uom2);
	endif;
epilog

end;</source>
        <Parameter name="quantity1" type="Decimal" usage="output"/>
        <Parameter name="quantity2" type="Decimal" usage="output"/>
        <Parameter name="uom1" type="String" usage="output"/>
        <Parameter name="uom2" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="qrySelectorCriteria" id="97b664ef-e552-44a4-85ac-fdefbf32a2b1">
        <source>qrySelectorCriteria(_criteria: CM_SelectorCriteriaLine): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	allValues	: StringArray;
	operator	: CM_QueryOperator;
	propValue,
	searchVal	: String;
	retVal		: Boolean;
	
begin
	
	if _criteria.myQueryProperty.class = CM_QStrServiceTypeMethod then
		// 24/08/2022	navkc1	#54570 --&gt;
		create allValues transient;
		
		operator := _criteria.myQueryOperator;
		propValue := _criteria.myQueryProperty.getValueForObject(self, operator).String;
		
		propValue.csvToStringArray(allValues,",");
		
		foreach searchVal in allValues do
			retVal := _criteria.myQueryOperator.doMatch(searchVal);
			
			if retVal then
				return true;
			endif;
		endforeach;
		// 24/08/2022	navkc1	#54570 &lt;--
	else
		return inheritMethod(_criteria);
	endif;

epilog
	delete allValues;
end;</source>
        <Parameter name="_criteria" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="quantity" id="13c89352-f914-4945-8908-2c463aadb872">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>quantity(set: Boolean; value: Real io) mapping, updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

begin

	if invoice = null then		// or (not global.isValidObject(invoice)) then	//AKB July 2001 PAR 1104 - inversed, so can't be invalid
		return;
	endif;
	if set then
		if invoice &lt;&gt; null then
		//	if invoice.status = CM_Invoice.INVOICE_POSTED then
			if invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
				if app.activeForm &lt;&gt; null and app.activeForm.class.name = "INV_CashConsolidation" then		//12 Aug 2019	NDL	TFS 44261
					// special case for TFS 44261
				else
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_CHANGE_POSTED_NOTALLOWED, null, null);
					return;
				endif;
			endif;
		endif;
		self.quantity := value;
	else
		// CCMS 1262 May 2012 quantity is no longer dynamic - see calculateQuantity called explicitly as required to set this
		value := self.quantity;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="quantityBOL" id="a89cab75-349d-4e37-be83-a4f61b70ac9a">
        <source>quantityBOL()  : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	value : Real;
	calcType : CM_CalculationType;
	cmifHook : CMIF_CalcTypeQuantityHook;
	valueOut : Real;

begin

	value := 0;
	
	if self.myTransactionBOL &lt;&gt; null then
		calcType := self.invoiceLineDesc.myCalculationType;
		if calcType &lt;&gt; null then
			value := self.myTransactionBOL.getQuantityForCalcType( calcType );	
		endif;
	
	endif;
	
	if calcType &lt;&gt; null and calcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := self.myTransactionBOL;
		cmifHook.origQty := value;
		cmifHook.myResourceTypeUsage := self.myResourceTypeUsage;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, calcType, calcType, cmifHook).Real;
		value := valueOut;
	endif;
	
	return value;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityCARGO" id="c4f3c7fc-bca1-48dc-9c3f-44fd9a2f87be">
        <source>quantityCARGO()  : Real; 
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_QuantityMap::getQuantityForTransaction and getQuantityForTransactionCargo
//	Oct 2012	cnwjre1	CCMS 1295 free storage days, refactor for storage configuration processing
// ---------------------------------------------------------------------------

vars
	value, valueOut	: Real;
	chargeByUnits	: Integer;
	calcType : CM_CalculationType;
	ti	:CM_TITransaction;
	blockUnit : Integer;
	
	cmifHook	: CMIF_CalcTypeQuantityHook;		// cnwmc5 - 8 Oct 2015 - PAR 36920
begin

	if self.myTransactionTI &lt;&gt; null then // if it has a transaction it is not  a manual invoice line.
		ti := self.myTransactionTI;
		chargeByUnits := self.invoiceLineDesc.getChargeByUnits();
		
		if chargeByUnits = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
			calcType := self.invoiceLineDesc.myCalculationType;
			if calcType &lt;&gt; null then
				blockUnit := calcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			value := self.quantityCARGObyType(blockUnit, true);
		elseif (chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT  // PAR 31615
			or chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT  // PAR 31615
			or chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT) then // PAR 31615
			value := self.quantityCARGObyMeasurement(chargeByUnits); // PAR 31615
		else
			value := self.quantityCARGObyType(chargeByUnits, false);
		endif;
		
	endif;
	
	calcType := self.invoiceLineDesc.myCalculationType;
	// 35365 handle escalating charging properly, don't do this for the weight/length convert calc types
	if calcType &lt;&gt; null and 
	   (calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT or
	   calcType.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT or
	   calcType.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT) then
	 // skip
	else
		if (calcType &lt;&gt; null)  then // TFS 3844
			if calcType.calculationType = INV_CALC_TYPE_UNITY then // TFS 2901
			else
				value := self.adjustQuantityForRange(value);
			endif;
		endif;
	endif;
	// 24024 CCMS 1151 Aug 2010 cnwjre1 run the user hook code for invoice quantity
	if calcType &lt;&gt; null and calcType.myHookCodeQuantity &lt;&gt; null then
		// cnwmc5 - 8 Oct 2015 - PAR 36920
		create cmifHook transient;
		cmifHook.myTransaction := ti;
		cmifHook.origQty := value;
		cmifHook.myResourceTypeUsage := self.myResourceTypeUsage;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, calcType, calcType, cmifHook).Real;
		value := valueOut;
	endif;
	return value;
epilog
	delete cmifHook;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityCARGOPreFSD" id="69931663-c8f6-4462-a5d0-e342fd253b7e">
        <source>quantityCARGOPreFSD() : Real;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_QuantityMap::getQuantityForTransaction
//	Aug 2010	cnwjre1	par 24024 use getChargeByUnits, call quantity hook method
// ---------------------------------------------------------------------------




vars
	value, valueOut, numTEU : Real;
	chargeByUnits	: Integer;
	chargedDaysWorking	: Boolean;
	endTime	: TimeStamp;
	calcType : CM_CalculationType;
	ti	:CM_TITransaction;
	
	cmifHook	: CMIF_CalcTypeQuantityHook;		// cnwmc5 - 8 Oct 2015 - PAR 36920
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
begin

	if self.myTransactionTI &lt;&gt; null then // if it has a transaction it is not  a manual invoice line.
		chargedDaysWorking := self.myTransactionTI.getChargedDaysWorking();
		chargedDaysWorkingAndComp := self.myTransactionTI.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		chargeByUnits := invoiceLineDesc.getChargeByUnits;
		if chargeByUnits = INV_CALC_TYPE_UNITY then
			value := 1.0;
		elseif chargeByUnits = INV_CALC_TYPE_QUANTITY then
			value := self.trackedItemQuantity;
		elseif chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
			if self.myResourceTypeUsage &lt;&gt; null then	//13 Jan 2010	NDL	CCMS MES 1006
				value := self.myResourceTypeUsage.quantity;
			else
				value := self.myTransactionTI.getChargeQuantity();
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT then
			value := self.trackedItemWeight;
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
			value := self.trackedItemWeight/1000;
		elseif chargeByUnits = INV_CALC_TYPE_VOLUME then
			value := self.trackedItemVolume;
			if value = 0 then
				value := self.myTransactionTI.getChargeVolume();
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
			/*if self.trackedItemVolume &gt; self.trackedItemWeight / 1000 then
				value := self.trackedItemVolume;
			else
				value := self.trackedItemWeight / 1000;
			endif; */
			value := self.myTransactionTI.getRTvalue(); //08 May 2019	NDL	TFS 38525
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL then
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then // PAR 11255
				value := 0;
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then 
				value := 0;
			endif;
			
		//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
		elseif chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
			endTime := self.myTransactionTI.getEndDateTime(chargeByUnits);
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), endTime, chargedDaysWorking, false, self.myTransactionTI);
			if value &lt; 0 then
				value := 0;
			endif;
		// PAR 24015
		elseif chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU then
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then
				value := 0;
			endif;
			numTEU := self.myTransactionTI.myTrackedItem.getNumTEU();
			if numTEU &gt; 0 then
				value := (value * numTEU);
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then
				value := 0;
			else
				value := value * self.myTransactionTI.getRTvalue;
			endif;
			
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
			value := self.bank.evaluateDaysOnsite(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime);
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
			value := self.myTransactionTI.getChargeQuantity();
			
		elseif chargeByUnits = INV_CALC_TYPE_DISCREPANCYVALUE then	//19 Mar 2018	NDL	TFS 37558
			value := self.myTransactionTI.getChargeQuantity();
			
		elseif chargeByUnits = INV_CALC_TYPE_DISCREPANCYABS then	//21 Jun 2018	NDL	TFS 39217
			value := self.myTransactionTI.getChargeQuantity().abs;
			
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then
				value := 0;
			endif;
			value := value * self.trackedItemWeight;
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
			value := self.bank.evaluateDaysCalendar(self.myTransactionTI.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI);
			if value &lt; 0 then
				value := 0;
			endif;
			value := value * self.trackedItemVolume;
		elseif chargeByUnits = INV_CALC_TYPE_QUANTITY_ONBOARD then //jlier1 TFS 63956 20/5/24
			value:= self.myTransactionTI.onboardQuantity;
		endif;
	endif;
	
	value := self.adjustQuantityForRange(value);
	// 24024 CCMS 1151 Aug 2010 cnwjre1 run the user hook code for invoice quantity
	calcType := self.invoiceLineDesc.myCalculationType;
	if calcType &lt;&gt; null and calcType.myHookCodeQuantity &lt;&gt; null then
		// cnwmc5 - 8 Oct 2015 - PAR 36920
		create cmifHook transient;
		cmifHook.myTransaction := self.myTransactionTI;
		cmifHook.origQty := value;
		cmifHook.myResourceTypeUsage := self.myResourceTypeUsage;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, calcType, calcType, cmifHook).Real;
		value := valueOut;
	endif;
	return value;
epilog
	delete cmifHook;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityCARGObyMeasurement" id="d5bd6316-e257-405f-b09f-6fe4f50b11d7">
        <source>quantityCARGObyMeasurement(chargeByUnits : Integer) : Real;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	blockUnit : Integer;
	amount : Real;
	value : Real;
	calcType : CM_CalculationType;
	convRate : Real;
begin
	// ### CALCULATION TYPE
	calcType := self.invoiceLineDesc.myCalculationType;
	if calcType &lt;&gt; null then
		blockUnit := calcType.theCalcTypeUnit;
	else
		blockUnit := INV_CALC_TYPE_UNITY; // value of 1
	endif;
	
	// ### MEASUREMENT TYPE
	if calcType.myMeasurementType &lt;&gt; null then
		convRate := calcType.myMeasurementType.conversionRate;
	else
		convRate := 1;
	endif;
			
	// ### AMOUNT
	if chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT then // PAR 31615
		if calcType.isUseCargoWeight() and self.trackedItem &lt;&gt; null then
			amount := self.trackedItem.weightCargo; //02/10/2025	navkc1 JIRA 36149
		else
			amount := self.trackedItemWeight;
		endif;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT then // PAR 31615
		amount := self.trackedItemVolume;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT then // PAR 31615
		amount := self.trackedItemLength;
	else
		amount := 1;
	endif;

	// ### CONVERT
	value := self.quantityCARGObyType(blockUnit, true) * (amount / convRate);
	app.invLog(method.qualifiedName &amp; " blockUnit=" &amp; blockUnit.String &amp; " amount=" &amp; amount.String &amp; " convRate=" &amp; convRate.String &amp; ", value=" &amp; value.String, LogTRACE.String);
	
	return value;

epilog

end;</source>
        <Parameter name="chargeByUnits" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityCARGObyType" id="1297fc62-4adb-44bd-bcf3-482481df1628">
        <source>quantityCARGObyType(_chargeByUnits	: Integer; _isBlockUnit : Boolean) : Real;
/*
Purpose:		// PAR 30681	
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
29 Aug 2022			jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	value, valueOut, numTEU : Real;
	chargedDaysWorking	: Boolean;
	terminal	: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	calcType : CM_CalculationType;
	titran	:CM_TITransaction;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
	blockUnit : Integer;
	
begin

	if self.myTransactionTI &lt;&gt; null then // if it has a TI it is not  a manual invoice line.
		titran := self.myTransactionTI;
		chargedDaysWorking := titran.getChargedDaysWorking();
		chargedDaysWorkingAndComp := titran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		app.invLog(method.qualifiedName &amp; " _chargeByUnits=" &amp; _chargeByUnits.String &amp; " _isBlockUnit=" &amp; _isBlockUnit.String, LogTRACE.String);
		
		if _chargeByUnits = INV_CALC_TYPE_UNITY then
			value := 1.0;
		elseif _chargeByUnits = INV_CALC_TYPE_QUANTITY then
			value := self.trackedItemQuantity;
		elseif _chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
			if self.myResourceTypeUsage &lt;&gt; null then	//13 Jan 2010	NDL	CCMS MES 1006
				value := self.myResourceTypeUsage.quantity;
			else
				value := titran.getChargeQuantity();
			endif;
		elseif _chargeByUnits = INV_CALC_TYPE_WEIGHT then
			value := self.trackedItemWeight;
		elseif _chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
			value := self.trackedItemWeight/1000;
		elseif _chargeByUnits = INV_CALC_TYPE_VOLUME then
			value := self.trackedItemVolume;
				
			if value = 0 then
				value := titran.getChargeVolume();
			endif;
		elseif _chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
		/*	if self.trackedItemVolume &gt; self.trackedItemWeight / 1000 then
				value := self.trackedItemVolume;
			else
				value := self.trackedItemWeight / 1000;
			endif; */
			value := self.myTransactionTI.getRTvalue(); //08 May 2019	NDL	TFS 38525
		// per-day calculation types - refactored for CCMS 1295 free storage days
		elseif _chargeByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL or
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_SUBTERM or 	//28 Jun 2018	NDL	TFS 39338
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU or
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT or	//08 May 2018	NDL	TFS 38525
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_IN or
			   _chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
			   _chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT or
			   _chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME or 
			   _chargeByUnits = INV_CALC_TYPE_BOARDFEET_DAYS
			   then
			terminal := self.getTerminal();
			if terminal &lt;&gt; null then
				storageConfig := terminal.myStorageConfig;
			endif;

			value := self.getElapsedDays(_chargeByUnits,  chargedDaysWorking, storageConfig, chargedDaysWorkingAndComp);
			// 35365 handle escalating charging, get the actual days for this individual invoice line, if it a block unit not the main type	
			if _isBlockUnit then
				value := self.adjustQuantityForRange(value);		
			endif;
			// now do the calculation-type specific processing
			if _chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				numTEU := titran.myTrackedItem.getNumTEU();
				if numTEU &gt; 0 then
					value := (value * numTEU);
				endif;
			elseif _chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
				value := value * self.myTransactionTI.getRTvalue;
			elseif _chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
				value := value * self.trackedItemWeight;
			elseif _chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
				value := value * self.trackedItemVolume;
			elseif _chargeByUnits = INV_CALC_TYPE_BOARDFEET_DAYS then
				if titran.myTrackedItem &lt;&gt; null then
					value := value * titran.myTrackedItem.getBoardFeetAmount;				
				endif;
			endif;
		elseif _chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
			value := self.bank.evaluateDaysOnsiteAtCalendar(titran.getStartDateTime(_chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI );
			// 36438 handle escalating charging, get the actual days for this individual invoice line, if it a block unit not the main type	
			//  (copy the 35365 fix above for days onsite)
			if _isBlockUnit then
				value := self.adjustQuantityForRange(value);		
			endif;
			
		elseif _chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
			value := titran.getChargeQuantity();
			
		elseif _chargeByUnits = INV_CALC_TYPE_DISCREPANCYVALUE then	//19 Mar 2018	NDL	TFS 37558
			value := self.myTransactionTI.getChargeQuantity();
			
		elseif _chargeByUnits = INV_CALC_TYPE_DISCREPANCYABS then	//21 Jun 2018	NDL	TFS 39217
			value := self.myTransactionTI.getChargeQuantity().abs;
		elseif _chargeByUnits = INV_CALC_TYPE_WO_EXTRA then	// TFS 42221
			calcType := self.invoiceLineDesc.myCalculationType;
			if calcType &lt;&gt; null then
				blockUnit := calcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			value := titran.getInvoiceQuantityForWOExtra(blockUnit); // TFS 42221 19DEC18
			// TFS 42221 19DEC18			value := self.quantityCARGObyType(blockUnit, true); //	TFS 42221 use the details on the transaction
			
		elseif _chargeByUnits = INV_CALC_TYPE_BOARDFEET then
				if titran.myTrackedItem &lt;&gt; null then
					value := titran.myTrackedItem.getBoardFeetAmount;				
				endif;	
		elseif _chargeByUnits = INV_CALC_TYPE_QUANTITY_ONBOARD then //jlier1 TFS 63956 20/5/24
			value:= titran.onboardQuantity;
		endif;
	endif;

	return value;

end;</source>
        <Parameter name="_chargeByUnits" type="Integer"/>
        <Parameter name="_isBlockUnit" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityEvent" id="03cc3a3b-3e8d-4329-acd7-1e891ce02941">
