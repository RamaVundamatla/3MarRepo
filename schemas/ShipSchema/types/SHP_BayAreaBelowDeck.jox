    <JadeMethod name="drawMinature" id="58660ed6-1fef-4224-ac0a-839df5ea2928">
        <source>drawMinature(_frame: Frame input; _scale: Integer);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TOOLBAR_OFFSET = 25;
	OFFSET = 4;
	ANGLE = 6;
	WIDTH = 35;
	HEIGHT = 25;
vars
	theX1,theX2,theY1,theY2 : Real;
	thePoly : RealArray;
begin
	if self.drawMe = false then
		return;
	endif;
	if self.allGridPoints.isEmpty then
		return;
	endif;
	create thePoly transient;

	if _scale &gt; 0 then
		self.getXsYs(theX1,theX2,theY1,theY2);
		theX1 := (theX1 / _scale).Real;
		theX2 := (theX2 / _scale).Real;
		theY1 := (theY1 / _scale).Real;
		theY2 := (theY2 / _scale).Real;
	else
		theX1 := ((self.column - 1) * WIDTH);
		theX2 := theX1 + WIDTH;
		theY1 := ((self.row - 1) * HEIGHT);
		theY2 := theY1 + HEIGHT;
	endif;	
	theX1 := theX1  + OFFSET;
	theX2 := theX2  - OFFSET;
	theY1 := theY1  + OFFSET + TOOLBAR_OFFSET;
	theY2 := theY2  - OFFSET + TOOLBAR_OFFSET;

	thePoly.add(theX1); thePoly.add(theY1); // 1
	thePoly.add(theX2); thePoly.add(theY1); // 2
	thePoly.add(theX2); thePoly.add(theY2 - ANGLE); // 3
	thePoly.add(theX2 - ANGLE); thePoly.add(theY2); // 4
	thePoly.add(theX1 + ANGLE); thePoly.add(theY2); // 5
	thePoly.add(theX1); thePoly.add(theY2 - ANGLE); // 6
	thePoly.add(theX1); thePoly.add(theY1); // 7
	
	_frame.drawFillColor := 16764573;
	_frame.drawFilledPolygon(thePoly,Blue);
epilog
	delete thePoly;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfter" id="12ad2125-daf2-4648-98c0-cae1bfb3d838">
        <source>drawSpecialAfter();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	offSet, rowOffset,rowOffset2 : Real;
	theX, theY,numSlotsOD, numSlotsUD,theMiddleX,theSpace,aColour : Integer;
	theString : String;
	aColumn : CMUI_GridColumn; //SHP_BayColumn;
	aRow : CMUI_GridRow;
	theRowHeight,
	theColWidth,thePaddingRows, theLastPointX2, theLastPointY2,theScaleFactor : Real;
	firstPoint, lastPoint : CMUI_GridPoint;
	theLabel,pileWeight : String;
	amPrinting : Boolean;
	theFrame : CMUI_GridAreaFrame;
	largeOutput, mediumOutput : Boolean;
begin
	amPrinting := self.amPrinting();

	if self.allGridPoints.isEmpty and not amPrinting then
		return;
	endif;

	
	theScaleFactor := self.scaleYFactor;
	theFrame := self.myGridAreaFrame;
	largeOutput := (amPrinting and theScaleFactor = self.PrintScaleLarge);
	mediumOutput := (amPrinting and theScaleFactor = self.PrintScaleMedium);
	
	if largeOutput then
		theRowHeight := self.PrintScaleLargeHeight;
		theColWidth	 := self.PrintScaleLargeWidth;
	else
		theRowHeight := RowHeight *  theScaleFactor;
		theColWidth	 := ColWidth * theScaleFactor;
	endif;
	theFrame.setDefaultFont();

	if  (amPrinting and theScaleFactor = self.PrintScaleSmall) then
		theSpace := 0;
	elseif  (amPrinting and theScaleFactor = self.PrintScaleLarge) then
		theSpace := 23;
	elseif theScaleFactor = 1  then
		theSpace := 0;
	elseif theScaleFactor = 1.5 then
		theSpace := 2;
	elseif theScaleFactor = 2 then
		theSpace := 5;
	elseif theScaleFactor = 3 then
		theSpace := 10;
	elseif theScaleFactor = 4 then
		theSpace := 10;
	elseif theScaleFactor = 6 then
		theSpace := 20;
	elseif theScaleFactor = 9 then
		theSpace := 40;
	endif;

	// try to pin point the middle of our column
	if self.allGridPoints.isEmpty then
		theLastPointX2 := self.totalPointWidth;
		theLastPointY2 := self.totalPointHeight;
		theMiddleX := (theLastPointX2 / 2).Integer;
		theY := 0;
	else
		firstPoint := self.allGridPoints.first;
		lastPoint := self.allGridPoints.last;
		theLastPointX2 := lastPoint.x2;
		theLastPointY2 := lastPoint.y2;
		theMiddleX := (firstPoint.x1 + (theLastPointX2 - firstPoint.x1) / 2).Integer;
		theY := (firstPoint.y1 - 15).Integer;
	endif;
	

	theX := theMiddleX;


	if amPrinting and theScaleFactor  = self.PrintScaleSmall then
		offSet := theLastPointY2; 
	else
		offSet := theLastPointY2 - 15; // scale factor 1 default
	endif;
	
	// do not print this stuff on the small print
	if theScaleFactor &gt; 1 and not self.allGridPoints.isEmpty then //(self.amPrinting and theScaleFactor  = self.PrintScaleSmall) then
		// #################
		// draw the column labels
		// #################
		foreach aColumn in self.allGridColumns do
//			aCell := aColumn.SHP_BayColumn.myCell;
			theLabel := aColumn.SHP_BayColumn.label;
			offSet := ((aColumn.SHP_BayColumn.allignment  ) * theColWidth) + LeftMargin + theSpace;
			offSet := offSet - theColWidth - 2;
//			theFrame.drawTextAt(theLabel,offSet + 1,theY + 1,White);
			theFrame.drawTextAt(theLabel,offSet,theY,Black);


			if theScaleFactor &gt;1 and self.displayMode &lt;&gt; ShpDisplayMode_Defn
			and not mediumOutput then 
//				aColumn.SHP_BayColumn.drawPileWeight(theFrame,theScaleFactor,offSet.Integer,(theLastPointY2 + 6).Integer);
				aColumn.SHP_BayColumn.drawPileWeight(theFrame,theScaleFactor,false);
/*
				aColour := Black;
				if aColumn.SHP_BayColumn.pileWeight &gt; aColumn.SHP_BayColumn.pileWeightMAX then
					aColour := Red;
				endif;
				// cell total weight
				pileWeight := aColumn.SHP_BayColumn.pileWeight.String.padLeadingZeros(2);
				if pileWeight.length &gt; 2 and theScaleFactor = 1.5 then
					pileWeight := "&gt;C";
				endif;
				if pileWeight.length &gt; 2 and theScaleFactor = 2 then
					offSet := offSet - 5;
				endif;
				if pileWeight.length &gt; 2 and theScaleFactor = 3 then
					offSet := offSet - 3;
				endif;
//				theFrame.drawTextAt(pileWeight,offSet + 1,theLastPointY2 + 5 ,White);
				theFrame.drawTextAt(pileWeight,offSet,theLastPointY2 + 6,aColour);
				*/
			endif;

		endforeach;
	

		
		rowOffset := firstPoint.x1 - 15;
		rowOffset2 := lastPoint.x2 + 2;
		if theScaleFactor = 1.5 then		
			offSet := 17;
		elseif theScaleFactor = 2 then		
			offSet := 20;
		else
			offSet := 25;
		endif;
		
		// draw row labels
		foreach aRow in self.allGridRows do
			theLabel := aRow.label;
//			theFrame.drawTextAt(theLabel,rowOffset + 1,offSet + 1,White);
			theFrame.drawTextAt(theLabel,rowOffset,offSet,Black);
			if self.displayMode &lt;&gt; ShpDisplayMode_Defn 
			and not mediumOutput then 
				aRow.SHP_BayRow.drawTierWeight(self.myGridAreaFrame,theScaleFactor,false);
/*
				aColour := Black;
				// tear total weight
				pileWeight := aRow.SHP_BayRow.pileWeight;
				theFrame.drawTextAt(pileWeight,rowOffset2,offSet,aColour);
			*/
			endif;
			offSet := offSet + theRowHeight;
		endforeach;
	endif;	

	if self.myJobSeqSheet &lt;&gt; null then // do not print this on the sequence sheet
		return;
	endif;

	
	// draw the number of slot OD UD, in total, the bay ID and the hold id
	if mediumOutput then
		theY := offSet.Integer;
	elseif theScaleFactor &lt; 3 then		
		theY := (offSet + 25).Integer;
	else
		theY := (offSet + 15).Integer;
	endif;	
	if not (amPrinting and theScaleFactor = self.PrintScaleSmall) then
		if self.displayMode = ShpDisplayMode_Defn then
			self.myBay.getNumberOfSlotsAvailable(numSlotsOD, numSlotsUD);
		else
			numSlotsOD := self.numberSlotsOD;
			numSlotsUD := self.numberSlotsUD;
		endif;
		
		if theScaleFactor = 1 then	
			thePaddingRows := 7;
		elseif theScaleFactor = 1.5 then	
			thePaddingRows := 3;
		elseif theScaleFactor = 2 then	
			thePaddingRows := 2;
		elseif theScaleFactor = 3 then	
			thePaddingRows := 2;
		elseif theScaleFactor = 4 then	
			thePaddingRows := 2;
		elseif theScaleFactor = 6 then	
			thePaddingRows := 2;
		elseif theScaleFactor = 9 then	
			thePaddingRows :=1;
		endif;
		
		if amPrinting then
			theY := theY - 2;
			if self.allGridPoints.isEmpty then
				theY := theY - 26;
			endif;
			theFrame.setDefaultFont();
			theFrame.drawFontSize := 7;
			theString := numSlotsOD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY,Black);
			theFrame.drawLine(theX + 15,theY+ 11,theX + 25,theY+ 11, Black);
			theString := numSlotsUD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY+ 10,Black);
			theString := (numSlotsUD + numSlotsOD).String ;
			theFrame.drawTextAt(theString,theX + 30,theY+ 5,Black);
			
			theFrame.drawFontSize := 8;
		else
			theString := numSlotsOD.String ;
//			theFrame.drawTextAt(theString,theX + 1,theY + 1,White);
			theFrame.drawTextAt(theString,theX,theY,Black);
			
//			theFrame.drawLine(theX - 4,theY + 16, theX + 16 , theY + 16, White);
			theFrame.drawLine(theX - 5,theY + 15, theX + 15 , theY + 15, Black);
		
		
			theString := (numSlotsUD + numSlotsOD).String ;
//			theFrame.drawTextAt(theString,theX + 21,theY + 8,White);
			theFrame.drawTextAt(theString,theX + 20,theY + 7,Black);
			
			theString := numSlotsUD.asStringJMT;
//			theFrame.drawTextAt(theString,theX + 1,theY + 21,White);
			theFrame.drawTextAt(theString,theX,theY + 20,Black);
		endif;

	
		theY := (self.totalPointHeight - 3).Integer;
	
		if not amPrinting then
//			theFrame.drawLine(10, theY , self.width, theY , White);
			theFrame.drawLine(11, theY + 1, self.width, theY + 1 , 12566463);
		endif;
	endif;

	if amPrinting then
		if theScaleFactor = self.PrintScaleLarge then
			theY := offSet.Integer + 12;
		else
			theY := offSet.Integer;
		endif;
	else
		if theScaleFactor &lt; 3 then		
			theY := (offSet + 25).Integer;
		else
			theY := (offSet + 15).Integer;
		endif;	
	
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.label &amp; " W " &amp; self.totalPointWidth.String &amp; " H " &amp; self.totalPointHeight.String);
	if self.allGridRows.isEmpty and amPrinting then
		theY := 0;
	endif;
	self.drawSpecialAfterBayId(theX,theY,false);
end;</source>
    </JadeMethod>
    <JadeMethod name="getTopMargin" id="eeb42bf2-0d4f-4a47-b2cb-f4f6c6c34a69">
        <source>getTopMargin(): Integer;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTopMargin : Integer;

begin
	if  (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall) then
		theTopMargin := 2;
	elseif self.scaleXFactor = 1  then
		theTopMargin := 5;
	else
		theTopMargin := 17; //22
	endif;
	return theTopMargin;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f8533537-5d17-4273-9d5a-5e8783127215">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreate(_theBayDefn : CM_Bay; _theColumn : Integer; _theRow : Integer; _theMode : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aGridCol : CMUI_GridColumn;
	aBayPoint		: SHP_BayPoint;
	aLidPoint : SHP_LidPoint;
	
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLid : CM_HatchLid;
	loadState : Boolean;
	cellODStart, cellUDStart,cellODEnd,cellUDEnd :	SHP_BayColumn;
	thePointsOD, thePointsUD : CMUI_GridPointsByColumnDict;
	theColumnOrdinal, theRowOrdinal : Integer;
	aSlotC : CM_SlotController;
begin

	if _theBayDefn = null then
		return;
	endif;

	if _theMode = ShpDisplayMode_GetAll then
		foreach aSlot in _theBayDefn.allSlotsOnDeck do
			// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
			theRowOrdinal := _theBayDefn.allTiersOnDeck.size - (aSlot.ordinalTier - 1);
			// the ordinals for cells are NOT upside down
			theColumnOrdinal := aSlot.ordinalCell;
	
			aBayPoint := self.allGridPoints[theRowOrdinal,theColumnOrdinal].SHP_BayPoint;
			if aBayPoint &lt;&gt; null then
				aSlotC := aSlot.CM_SlotDefnVoyage.mySlotController;
				
				aBayPoint.setForCreateController(theColumnOrdinal, theRowOrdinal,aSlotC , self);
			endif;			
		endforeach;
		return;
	endif;

	app.cmsBeginLoad(loadState);
	
	self.label := _theBayDefn.id;
	self.column := _theColumn;
	self.row := _theRow;
	self.myBay := _theBayDefn;
	self.displayMode := _theMode;
//	app.myRoot.allDrawingAttributes.copy(self.allDrawingAttributes);
	self.drawMe := true;
	
	// nothing to draw if there are no slots!!!
	if _theBayDefn.allSlotsUnderDeck.size = 0 then // PAR 4900
		return;
	endif;

	foreach aCell in _theBayDefn.allCellsUnderDeckByOrdinal do
		create aBayCol transient;
		aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
	endforeach;

	foreach aTier in _theBayDefn.allTiersUnderDeck reversed do
		create aBayRow transient;
		theRowOrdinal := _theBayDefn.allTiersUnderDeck.size - (aTier.ordinal - 1);
		aBayRow.setForCreate(aTier.id,theRowOrdinal, self);
	endforeach;

	foreach aSlot in _theBayDefn.allSlotsUnderDeck do
//		if app.isDevelopmentSystem then
//			theRowOrdinal := aSlot.ordinalTier;
//			theColumnOrdinal := aSlot.ordinalCell;
//		else
	
			// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
			theRowOrdinal := _theBayDefn.allTiersUnderDeck.size - (aSlot.ordinalTier - 1);
			// the ordinals for cells are NOT upside down
			theColumnOrdinal := aSlot.ordinalCell;
//		endif;



		create aBayPoint transient;
		if self.displayMode = ShpDisplayMode_Defn then
			aBayPoint.setForCreate(theColumnOrdinal, theRowOrdinal,null , self,aSlot,true);
		else
			aBayPoint.setForCreateEmpty(theColumnOrdinal, theRowOrdinal , self); // this is done and the XML from the voyage updates the points later
		endif;
	endforeach;

epilog
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_theBayDefn" type="CM_Bay"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateController" id="62849894-4a6c-4a29-a16e-9e8a285ebcd2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateController(_theBay : CM_BayVoyage; _theColumn : Integer; _theRow : Integer; _theMode : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	aSlotC : CM_SlotController;
	aGridCol : CMUI_GridColumn;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLidPoint : SHP_LidPoint;
	theXML : String;
	aLid : CM_HatchLid;
	cellODStart, cellUDStart,cellODEnd,cellUDEnd :	SHP_BayColumn;
	thePointsOD, thePointsUD : CMUI_GridPointsByColumnDict;
	ordinalODStartCell, ordinalODEndCell : Integer;
	startsMidCell, endsMidCell : Boolean;
	theLidTier : Integer;
	loadState : Boolean;
	theColumnOrdinal, theRowOrdinal : Integer;
	isAft : Boolean; 
	isFwd : Boolean; 
	bayType : Integer; 
	theBay : CM_BayVoyage;
	bayFwdID,bayAftID : String;
begin
	theBay := _theBay;
	if theBay = null then
		return;
	endif;
	isAft := theBay.isAftBay;
	isFwd := not isAft;
	bayType := theBay.bayType;


	if theBay = null then
		return;
	endif;

	self.label := theBay.id;
	self.column := _theColumn;
	self.row := _theRow;
	self.displayMode := _theMode;
	self.myBay := theBay;
	self.drawMe := true;
	
	
	// nothing to draw if there are no slots!!!
	if theBay.allSlotsUnderDeck.size = 0 then
		if theBay.allSlotsUnderDeck.size = 0 then
			return;
		endif;
		// if no ON deck use under deck to create a row so that they can draw hatch lids
		foreach aCell in theBay.allCellsUnderDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
	else
	
	
		foreach aCell in theBay.allCellsUnderDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
		foreach aTier in theBay.allTiersUnderDeck reversed do
			create aBayRow transient;
			theRowOrdinal := theBay.allTiersUnderDeck.size - (aTier.ordinal - 1);
			aBayRow.setForCreate(aTier.id,theRowOrdinal, self);
		endforeach;
	endif;
/*
	// this row is used for the hatch lids
	theLidTier := theBay.allTiersUnderDeck.size + 1;
	create aBayRow transient;
	aBayRow.setForCreate("ZZ",theLidTier, self);
	aBayRow.setYPos(aBayRow.y1, aBayRow.y1 + 20);
	// for drawing a hatch lid create a point above each column in the grid and attach the lid to each of them
	// that way on the click on the lid we know what object to look at.
	// NOTE points get their X and Y from the column and row that they are referencing - the X and Y's  are virtual
	// A point cannot span multiple columns or rows, so create lots of points all looking at the same thing, in this case a lid

	foreach aLid in theBay.allHatchLids do
	
		theXML := aLid.getGridDefinitionXML();
		ordinalODStartCell :=  theXML.cnEcGetTagValueOfName("ODS").Integer;
		ordinalODEndCell :=  theXML.cnEcGetTagValueOfName("ODE").Integer;
		startsMidCell  :=  theXML.cnEcGetTagValueOfName("SMC").Integer.Boolean;
		endsMidCell  :=  theXML.cnEcGetTagValueOfName("EMC").Integer.Boolean;

		cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
		cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
		cellUDStart := null;
		cellUDEnd := null;

		foreach aGridCol in self.allGridColumns do
		
			if aGridCol.column &gt;= ordinalODStartCell and aGridCol.column &lt;= ordinalODEndCell then
				if aGridCol.allGridPointsByRow[theLidTier] = null then
					create aLidPoint transient;
					aLidPoint.setForCreate( aGridCol.column,theLidTier,self, cellODStart, cellODEnd,cellUDStart,cellUDEnd ,startsMidCell, endsMidCell,aLid,aGridCol);
				endif;
			endif;
		endforeach;

	endforeach;
*/	
	foreach aSlot in theBay.allSlotsUnderDeck do
		// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
		theRowOrdinal := theBay.allTiersUnderDeck.size - (aSlot.ordinalTier - 1);
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := aSlot.ordinalCell;

		create aBayPoint transient;
		aSlotC := aSlot.CM_SlotDefnVoyage.mySlotController;
//		aBayPoint.setForCreate(theColumnOrdinal, theRowOrdinal, aSlotC,self,aSlot,false);
		aBayPoint.populateController(aSlotC,isAft,isFwd,bayType,theBay, theRowOrdinal,theColumnOrdinal,self,bayFwdID,bayAftID);
	endforeach;
epilog

end;</source>
        <Parameter name="_theBay" type="CM_BayVoyage"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="d829a4a5-707c-48d9-b51e-a2ab009f8e94">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theRowHeight,
	theColWidth,thePaddingRows : Real;
	theBottomMargin : Integer;

	isLidRow, smallOutput,mediumOutput,largeOutput : Boolean;
begin
	if not self.drawMe then
		self.totalPointHeight := 0;
		return;
	endif;
	smallOutput :=  self.scaleXFactor = 1 or (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall);
	mediumOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleMedium);
	largeOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleLarge);
	
	if largeOutput then
		theRowHeight := self.PrintScaleLargeHeight;
		theColWidth	 := self.PrintScaleLargeWidth;
	else
		theRowHeight := RowHeight *  self.scaleYFactor;
		theColWidth	 := ColWidth * self.scaleXFactor;
	endif;
	if self.amPrinting then
		theBottomMargin := 30;
	else
		theBottomMargin := 55;
	endif;
	if smallOutput then
		thePaddingRows := 0;
	elseif mediumOutput then
		thePaddingRows := 15;
	elseif largeOutput then
		thePaddingRows := 35;
	else
		thePaddingRows := 25;
	endif;
	
	self.totalPointHeight := ((self.allGridRows.size) * theRowHeight);

	self.totalPointHeight := self.totalPointHeight + theBottomMargin + thePaddingRows;

	inheritMethod();

end;</source>
    </JadeMethod>
</Class>
