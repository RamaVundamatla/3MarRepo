    <JadeMethod name="doMnuInvLinkCreditClick" id="15ad22d8-485b-43a2-bbc0-faf222c3e909">
        <source>doMnuInvLinkCreditClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55537

*/

vars
	form 					: INV_LinkToCreditNote;
	allInvoicesToLink		: CM_InvoiceSet;
	invoice					: CM_Invoice;
	theTable				: CM_DataTable;
	hasNotPosted			: Boolean;
	msg						: String;
	mainInvoiceProcess,
	invoiceProcessToCheck	: CM_InvoiceProcess;
begin
	
	form := app.loadForm(INV_LinkToCreditNote, INV_Assistant, false, false, false, self.myTerminal, null).INV_LinkToCreditNote;
	
	if form = null then
		return;
	endif;
	
	theTable := self.tblData;
	
	create allInvoicesToLink transient;
	
	foreach invoice in theTable.allSelectedObjects as CM_Invoice where not invoice.isCreditNote() do
		
		if mainInvoiceProcess = null then
			mainInvoiceProcess := invoice.getMyInvoiceProcess();
		else
			invoiceProcessToCheck := invoice.getMyInvoiceProcess();
			if invoiceProcessToCheck &lt;&gt; mainInvoiceProcess then
				app.msgBox(app.getErrorString(InvoicesInDifferentInvProcess), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				return;
			endif;
		endif;
		
		if not invoice.isPosted() then
			hasNotPosted := true;
			if msg = null then
				msg := invoice.sequenceNum.String;
			else
				msg &amp;= ", " &amp; invoice.sequenceNum.String;
			endif;
			continue;
		endif;
		
		allInvoicesToLink.add(invoice);
	endforeach;
	
	if hasNotPosted then
		app.msgBox(app.getErrorString1(OnlyPostedInvLinkToCrdNote, msg), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		if allInvoicesToLink.isEmpty() then
			return;
		endif;
	endif;
	
	if allInvoicesToLink.isEmpty() then
		app.msgBox(app.getErrorString(No_Invoice_to_link), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	allInvoicesToLink.copy(form.allInvoicesToLink);
	form.myBank := self.myCurrentBank;
	form.myTerminal := self.myTerminal;
	form.showModal();
	
epilog
	delete allInvoicesToLink;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInvMergeClick" id="a5cab6ca-e969-4ccb-95a5-31f1fbb7a7c7">
        <source>doMnuInvMergeClick();
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	form 					: INV_InvoiceMerge;
	allInvoicesToMerge		: CM_InvoiceSet;
	invoice					: CM_Invoice;
	theTable				: CM_DataTable;
	hasNotPosted			: Boolean;
	msg, msgStr						: String;
	mainInvoiceProcess,
	invoiceProcessToCheck	: CM_InvoiceProcess;
	debtor : CM_Debtor;
	category : Integer;
	bu : CM_Bank;
begin
	
	form := app.loadForm(INV_InvoiceMerge, INV_Assistant, false, false, false, self.myTerminal, null).INV_InvoiceMerge;
	
	if form = null then
		return;
	endif;
	
	theTable := self.tblData;
	
	create allInvoicesToMerge transient;
	category := -1;
	foreach invoice in theTable.allSelectedObjects as CM_Invoice do
		
		if mainInvoiceProcess = null then
			mainInvoiceProcess := invoice.getMyInvoiceProcess();
		else
			invoiceProcessToCheck := invoice.getMyInvoiceProcess();
			if invoiceProcessToCheck &lt;&gt; mainInvoiceProcess then
				msgStr := "Invoice " &amp; invoice.sequenceNum.String &amp; " will be ignored, cannot mix invoice processes";
				if msg = "" then
					msg := msgStr;
				else
					msg := msg &amp; CrLf &amp; msgStr;
				endif;
				
				continue;
			endif;
		endif;
		
		if bu = null then
			bu := invoice.bank;
		else
			if bu &lt;&gt; invoice.bank then
				msgStr := "Invoice " &amp; invoice.sequenceNum.String &amp; " will be ignored, cannot mix Business Units";
				if msg = "" then
					msg := msgStr;
				else
					msg := msg &amp; CrLf &amp; msgStr;
				endif;
				
				continue;
			endif;
		endif;
		
		if debtor = null then
			debtor := invoice.debtor;
		else
			if debtor &lt;&gt; invoice.debtor then
				msgStr := "Invoice " &amp; invoice.sequenceNum.String &amp; " will be ignored, cannot mix Debtors";
				if msg = "" then
					msg := msgStr;
				else
					msg := msg &amp; CrLf &amp; msgStr;
				endif;
				
				continue;
			endif;
		endif;
		
		if category &lt; 0 then
			category := invoice.category;
		else
			if category &lt;&gt; invoice.category then
				msgStr := "Invoice " &amp; invoice.sequenceNum.String &amp; " will be ignored, invoice and credit notes cannot be mixed";
				if msg = "" then
					msg := msgStr;
				else
					msg := msg &amp; CrLf &amp; msgStr;
				endif;
				
				continue;
			endif;
		
		endif;
		
		
		if not invoice.canMerge then
			msgStr := "Invoice " &amp; invoice.sequenceNum.String &amp; " is posted cannot be merged";
			if msg = "" then
				msg := msgStr;
			else
				msg := msg &amp; CrLf &amp; msgStr;
			endif;
				
			continue;
		
		endif;
		
		allInvoicesToMerge.add(invoice);
	endforeach;
	
	if msg &lt;&gt; null then
		app.msgBox("Some Invoices had issues and will not be included" &amp; CrLf &amp; msg, app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		if allInvoicesToMerge.isEmpty() then
			return;
		endif;
	endif;
	
	if allInvoicesToMerge.isEmpty() then
		app.msgBox(app.getErrorString(No_Invoice_to_link), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	allInvoicesToMerge.copy(form.allInvoicesToLink);
	form.myBank := self.myCurrentBank;
	form.myTerminal := self.myTerminal;
	form.showModal();
	
epilog
	delete allInvoicesToMerge;
end;</source>
    </JadeMethod>
