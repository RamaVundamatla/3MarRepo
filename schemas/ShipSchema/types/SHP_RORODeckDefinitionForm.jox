    <JadeMethod name="createProxyUpdate" id="4b297720-c41a-4ebd-806b-18aab97f4e8e">
        <updating/>
        <source>createProxyUpdate() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpLayer : CM_DeckLayerLayout;
begin
	self.myCurrentProxyDeck:=app.createUpdateProxy(self.myCurrentDeck).CM_Deck;
	// PAR 27509
	foreach tmpLayer in self.myCurrentProxyDeck.myDeckLayout.allDeckLayerLayouts  discreteLock  where tmpLayer.isVisible and tmpLayer.isDefinable() do
		self.myCurrentProxyLayerLayout := tmpLayer;
		break;
	endforeach;

epilog

end;</source>
