    <JadeMethod name="getSetdownTrx" id="78791e4a-5f26-47b4-b41a-cb18898b129a">
        <source>getSetdownTrx() : CM_SetDown;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2019	jlger1	Initial creation 44965

*/

vars
	ti : CM_TrackedItem;
	iter : Iterator;
	foundTxn,
	txn 	: CM_TITransaction;
	nextMachineMoveHist : CM_MachineHistory;
 machineMoveHistory : CM_MachineHistory;
begin
	machineMoveHistory :=self.allMachineMoveHistories.first.CM_MachineMoveHistory;
	
	if machineMoveHistory = null then
		return null;
	endif;
	if not machineMoveHistory.isKindOf(CM_MachineMoveHistory) then
		return null;
	endif;
	nextMachineMoveHist:=machineMoveHistory.myNextHistory ;
	if  nextMachineMoveHist = null or  not machineMoveHistory.isKindOf(CM_MachineMoveHistory) then
		return null;
	endif;
	if nextMachineMoveHist.CM_MachineMoveHistory.myMoveTransaction.isKindOf(CM_SetDown) then
		return nextMachineMoveHist.CM_MachineMoveHistory.myMoveTransaction.CM_SetDown;
	endif;
	
	return null;
	
epilog
	
end;</source>
        <ReturnType type="CM_SetDown"/>
    </JadeMethod>
