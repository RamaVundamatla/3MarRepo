    <JadeMethod name="tableRowLimitException" id="93319d0a-dfa6-4cfa-ac53-80ef49c36343">
        <source>tableRowLimitException(_exObj: Exception): Integer;

vars

begin
	if _exObj.errorCode = 14049 then
		app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)
					,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;
	return Ex_Pass_Back;
end;</source>
