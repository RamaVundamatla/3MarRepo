    <JadeMethod name="doEnableControls" id="427e45fe-e720-4464-9ba5-5c94ef40a27d">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Enables or disables controls based upon the current state of the form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSelected	: Boolean;
	
begin
	if self.aMyLocationsController = null then
		optAvailable.enabled	:=	false;
		optClosed.enabled		:=	false;
		btnOk.enabled			:=	false;
	else
		optAvailable.enabled	:=	true;
		optClosed.enabled		:=	true;
		btnOk.enabled			:=	true;
	endif;
	
	if tblLocation.cnEcIsValidRow(tblLocation.row) then
		btnRemoveAlloc.enabled	:=	true;
	else
		btnRemoveAlloc.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFindAllocationsForLocation" id="020b5507-bfd3-4ddd-a513-005de780cdaf">
        <updating/>
        <source>doFindAllocationsForLocation() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Using the location ID entered by the user, find the Locations Controller,
//				and then get all of its Yard Allocations.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//23.6.2008		cnwrd1		Check for locations wioth no valid codes for table and display message to user.
// adm 270509 Par 19483 myTerminal
vars
	terminalObj			: CM_Terminal;
	controllerObj		: CM_LocationsController;
	allAllocationsObj	: CM_YardAllocationSet;
	foundHeight			: Integer;
	locationId			: String;
	
begin
//	tblLocation.clear();
	self.aAllYardAllocations.clear();
	self.aAllRemovedAllocations.clear();
	self.aMyLocationsController	:=	null;
	
	terminalObj	:=	self.myTerminal();
	locationId	:=	txtLocation.cnEcString();
	
	if locationId = null then
		app.msgBox("Please enter the Location to search for.", app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
		txtLocation.setFocus();
		return;
	endif;
	
	terminalObj.findLocationFromString(locationId, false, controllerObj, foundHeight);
	
	if controllerObj = null then
		optAvailable.cnEcSet(false);
		optClosed.cnEcSet(false);
		app.msgBox("Location '" &amp; locationId &amp; "' was not found.", app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
	else
		self.aMyLocationsController	:=	controllerObj;
		optAvailable.cnEcSet(controllerObj.status &lt;&gt; LC_Status_Closed);
		optClosed.cnEcSet(controllerObj.status = LC_Status_Closed);
		create allAllocationsObj transient;
		controllerObj.getAllYardAllocations(allAllocationsObj);
		
// cnwdad1 24/06/2008 - PAR # 17170: Moved this error message to here from below.
		if not allAllocationsObj.isEmpty() then
			allAllocationsObj.copy(self.aAllYardAllocations);
		endif;
	endif;
	
	self.tableInitializeAllocations();
	
//	if tblLocation.rows = 1 then  				// cnwrd1 par #17003 23.6.2008
//		app.msgBox("Location '" &amp; locationId &amp; "' has no valid allocations.", app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
//	endif;
epilog
	delete allAllocationsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="d9717350-3350-4898-9372-a54b7e8aa514">
        <source>doSave():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		This is the standard form update method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj		: CM_LocationsController;
	allAllocationsObj	: CM_YardAllocationSet;
	locnStatus			: Integer;
	userResponse		: Integer;
	
begin
	if not self.validateForm() then
		return false;
	endif;
	
	controllerObj	:=	self.aMyLocationsController;
	
	create allAllocationsObj transient;
	self.aAllRemovedAllocations.copy(allAllocationsObj);
	
	if allAllocationsObj.cnEcIsNotEmpty() then
		userResponse	:=	app.msgBox(	"Are you sure you want to delete " &amp; allAllocationsObj.size().String &amp; " Yard Allocations ?",
										app.getString(Warning),
										MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		
		if userResponse &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	if optAvailable.value then
		locnStatus	:=	LC_Status_Open;
	elseif optClosed.value then
		locnStatus	:=	LC_Status_Closed;
	endif;
	
	// Finally, call the update transaction.
	
	//app.myTrxUA.trxSetControllerStatusWithYA(locnStatus, controllerObj, self.aEdition, allAllocationsObj, app.myPassport);
	app.myTrxUA.trxSetControllerStatusWithYA(locnStatus, controllerObj, controllerObj.edition, allAllocationsObj, app.myPassport);	//14 Sep 2012	NDL	Par 30327
	
	if app.myPassport.trxCompletedOK() then
		return true;
	else
		self.checkAndShowErrors();
		return false;
	endif;
epilog
	delete allAllocationsObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedAllocation" id="bfea732f-d6c0-47d9-b228-7b59763dbaa5">
        <source>getSelectedAllocation():CM_YardAllocation protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Yard Allocation.
//
// Parameters:	None
//
// Returns:		A reference to the selected Yard Allocation, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allocationObj	: CM_YardAllocation;
	tableObj		: Table;
	rowPointer		: Integer;
	
begin
	tableObj	:=	tblLocation;
	rowPointer	:=	tableObj.row;
	
	if tableObj.cnEcIsValidRow(rowPointer) then
		allocationObj	:=	tableObj.accessRow(rowPointer).itemObject.CM_YardAllocation;
		return allocationObj;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStatus" id="b72a2dc9-ce73-428e-909a-2688371dcf2d">
        <source>getSelectedStatus():Integer protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Returns the status for the Locations Controller based upon the options
//				that the User has selected.
//
// Parameters:	None
//
// Returns:		The status of the Locations Controller, or zero.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyLocationsController = null then
		return 0;
	else
		if optAvailable.value then
			return LC_Status_Open;
		elseif optClosed.value then
			return LC_Status_Closed;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleF7Key" id="6c677db2-ec84-4122-971c-2c7a5c6cc354">
