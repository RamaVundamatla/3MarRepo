    <JadeMethod name="addSplitterColumn" id="0cd4f14f-2c21-4920-9aaa-16eb1437e855">
        <source>addSplitterColumn(_table :Table input; _startRow :Integer )protected;
/*
Date		Who		Reason
29 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/

vars
	colour		:Integer;
	col, row	:Integer;
begin
	colour			:= self.colour_Total;
	col 			:= _table.columns;
	_table.accessColumn (col).gridRight	:= false;
	col 			:= col + 1;
	_table.columns 	:= col;
	
	_table.accessColumn (col).width 	:= 2;
	_table.accessedColumn.backColor		:= colour;
	_table.accessedColumn.gridBottom	:= false;
	_table.accessedColumn.gridRight		:= false;
	
	// this is manky but we need a way of identifying the column as a splitter column
	// I will set the itemObject to the Table
	_table.accessedColumn.itemObject	:= _table;
	
	foreach row in 1 to _table.fixedRows do
		if row &gt;= _startRow then
			_table.accessCell (row, col).mergeCells	:= Table.MergeCells_NotAvailable;
			_table.accessCell (row, col).backColor	:= colour;
		else
			
		endif;
	endforeach;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_startRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearTable" id="f641ec5a-630a-4f22-aef1-e73026dbd0ea">
        <source>clearTable();
/*
Date		Who		Reason
17 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	table	:Table;
begin
	table := self.myTable;
	
	if table = null then
		return;
	endif;
	
	table.rows := 0;
	
	self.allObjectsToGarbageCollect.purge;
epilog

end;</source>
    </JadeMethod>
