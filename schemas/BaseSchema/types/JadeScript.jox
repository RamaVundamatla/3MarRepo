// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	theString		: CnEcString;
	errorPosition	: Integer;
	allSubstrings	: CnEcSubstringArray;
	theSubstring	: CnEcSubstringObject;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create theString transient;
	theString.updateMe("1234-5678-9012-3456");
	theString.setPatternValue("9999-9999-9999-9999");
	
	errorPosition	:=	theString.getPatternMatch(true, true);
	
	if errorPosition = 0 then
		write "The string is a valid match for the pattern.";
	else
		write "Invalid character in position " &amp; errorPosition.String &amp; ".";
	endif;
	
	create allSubstrings transient;
	
	theString.setPatternValue("-");
	theString.getPatternOccurrences(allSubstrings);
	
	if allSubstrings.isEmpty() then
		write "There are no occurrences of the pattern.";
	else
		write "The following are the pattern occurrences:";
		
		foreach theSubstring in allSubstrings do
			write "    " &amp; theSubstring.getStringValue() &amp; " at position " &amp; theSubstring.substringPosition.String;
		endforeach;
	endif;
epilog
	delete theString;
	delete allSubstrings;
	
	write "String Mask completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_StringMatch" id="602f49b0-8cea-4a16-b8f6-9b365bdf0977">
        <source>cnwdad1_Test_StringMatch() protected;
// --------------------------------------------------------------------------------
// Created:		31 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime			: Integer;
	
begin
	startTime	:=	app.clock();
	
	if "BaseSchema".cnEcIsMatch("*Schema*") then
		write "The string matched the wildcard pattern.";
	else
		write "The string did not match the wildcard pattern.";
	endif;
epilog
	write "String match completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_StripDecimalZeros" id="89e7ab75-45be-4bab-8e96-d210eb082d02">
        <source>cnwdad1_Test_StripDecimalZeros();
// --------------------------------------------------------------------------------
// Created:		27 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	value	: Decimal[12,4];
	count	: Integer;
	
begin
	foreach count in 1 to 100 do
		value	:=	count / 8;
		write count.String &amp;
			". Decimal: " &amp; value.cnEcStripDecimalZeros().padBlanks(6) &amp;
			"  String: " &amp; value.String.cnEcStripDecimalZeros();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_SubstringCount" id="205a1028-0588-4c7c-8290-3cc3baeff80b">
        <source>cnwdad1_Test_SubstringCount();
// --------------------------------------------------------------------------------
// Created:		14 October 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theString	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	theString	:=	"a\b\c\";
	write "There are " &amp; theString.cnEcSubstringCount("\").String &amp; " occurrences of '\'.";
epilog
	write "Substring Count completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_TcpConnection" id="d687b2d1-f451-4ce8-9c34-14450e253dd4">
        <source>cnwdad1_Test_TcpConnection();
// --------------------------------------------------------------------------------
// Created:		27 June 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tcpConnect	: CnEcTcpConnection;
	response	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	create tcpConnect transient;
	if tcpConnect.cnEcDoWebPostRequest("cnwdad1a", "/WebHub/jadehttp.dll?webhub&amp;", "&lt;LOGON&gt;", 2, response) then
//	if tcpConnect.cnEcWebPostRequest("www.ozemail.com.au", "/~darrelld/", null, 2, response) then
		write "Success!" &amp; response;
	else
		write "Error: " &amp; tcpConnect.cnEcErrorMessage;
	endif;

	write response;
epilog
	delete tcpConnect;
	
	write "TCP Connection completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Time" id="ff521a92-06a3-4fb9-bc6b-070d796decda">
        <source>cnwdad1_Test_Time();
// -----------------------------------------------------------------------------
// Created:		29 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	theTime		: CnEcTime;
	startTime	: Integer;
	time		: Time;
	
begin
	startTime	:=	app.clock();
	
	write "Data Value";
	write "==========";
	create theTime transient;
	write "It is " &amp; theTime.timeClient.String &amp; " on the client, and " &amp; theTime.timeServer.String &amp; " on the server.";
	
	write "Current time is " &amp; theTime.timeClient.String &amp; ".";
	theTime.addMinutes(30);
	write "Adjusted time is " &amp; theTime.timeClient.String &amp; ".";
	
	write CrLf &amp; "Primitive:";
	time.setTime(10, 0, 0, 0);
	write time.String &amp; " + 5 hours is " &amp; time.cnEcAddHours(5).String;
	write time.String &amp; " - 5 hours is " &amp; time.cnEcAddHours(-5).String;
	write time.String &amp; " + 200 hours is " &amp; time.cnEcAddHours(200).String;
	write time.String &amp; " - 200 hours is " &amp; time.cnEcAddHours(-200).String;
	write time.String &amp; " + 45 minutes is " &amp; time.cnEcAddMinutes(45).String;
	write time.String &amp; " - 45 minutes is " &amp; time.cnEcAddMinutes(-45).String;
	write time.String &amp; " + 1500 minutes is " &amp; time.cnEcAddMinutes(1500).String;
	write time.String &amp; " - 1500 minutes is " &amp; time.cnEcAddMinutes(-1500).String;
	write time.String &amp; " + 45 seconds is " &amp; time.cnEcAddSeconds(45).String;
	write time.String &amp; " - 45 seconds is " &amp; time.cnEcAddSeconds(-45).String;
	write time.String &amp; " + 88000 seconds is " &amp; time.cnEcAddSeconds(88000).String;
	write time.String &amp; " - 88000 seconds is " &amp; time.cnEcAddSeconds(-88000).String;
	write "Display=" &amp; time.cnEcDisplayMS();
	write "ANSI format=" &amp; time.cnEcGetAnsiFormat();
epilog
	delete theTime;
	
	write CrLf &amp; "Time test completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_TimeStampMidPoint" id="48043265-6be9-4d26-9a63-0dc57bb6c1f0">
        <source>cnwdad1_Test_TimeStampMidPoint() protected;
// --------------------------------------------------------------------------------
// Created:		08 November 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestamp1	: TimeStamp;
	timestamp2	: TimeStamp;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	timestamp2	:=	timestamp1.cnEcAddDays(5);
	timestamp2	:=	timestamp2.cnEcAddHours(7);
	timestamp2	:=	timestamp2.cnEcAddMinutes(35);
	
	write "The midpoint between '" &amp; timestamp1.String &amp; "' and '" &amp; timestamp2.String &amp; "' is:";
	write timestamp1.cnEcMidPoint(timestamp2);
epilog
	write "Timestamp midpoint done in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Timestamp" id="ecca9d0b-7f28-41eb-9c34-4d895e3f7354">
        <source>cnwdad1_Test_Timestamp();
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTimestamp	: CnEcTimestamp;
	startTime		: Integer;
	timestamp		: TimeStamp;
begin
	startTime	:=	app.clock();
	
	write "Data Value";
	write "==========";
	create theTimestamp transient;
	write "Client Timestamp: " &amp; theTimestamp.timestampClient.String;
	write "Server Timestamp: " &amp; theTimestamp.timestampServer.String;
	write "Client GMT Bias: " &amp; theTimestamp.getGMTBiasClient().String;
	write "Server GMT Bias: " &amp; theTimestamp.getGMTBiasServer().String;
	write "GMT Timestamp: " &amp; theTimestamp.getGMTTimestamp().String;
	
	theTimestamp.addDays(2);
	theTimestamp.addMinutes(30);
	write "Timestamp adjusted by 2 days &amp; 30 minutes is " &amp; theTimestamp.timestampClient.String;
	
	write CrLf &amp; "Primitive:";
	timestamp.setTime("10:00".Time);
	write timestamp.String &amp; " + 5 hours is " &amp; timestamp.cnEcAddHours(5).String;
	write timestamp.String &amp; " - 5 hours is " &amp; timestamp.cnEcAddHours(-5).String;
	write timestamp.String &amp; " + 200 hours is " &amp; timestamp.cnEcAddHours(200).String;
	write timestamp.String &amp; " - 200 hours is " &amp; timestamp.cnEcAddHours(-200).String;
	write timestamp.String &amp; " + 45 minutes is " &amp; timestamp.cnEcAddMinutes(45).String;
	write timestamp.String &amp; " - 45 minutes is " &amp; timestamp.cnEcAddMinutes(-45).String;
	write timestamp.String &amp; " + 1500 minutes is " &amp; timestamp.cnEcAddMinutes(1500).String;
	write timestamp.String &amp; " - 1500 minutes is " &amp; timestamp.cnEcAddMinutes(-1500).String;
	write timestamp.String &amp; " + 45 seconds is " &amp; timestamp.cnEcAddSeconds(45).String;
	write timestamp.String &amp; " - 45 seconds is " &amp; timestamp.cnEcAddSeconds(-45).String;
	write timestamp.String &amp; " + 88000 seconds is " &amp; timestamp.cnEcAddSeconds(88000).String;
	write timestamp.String &amp; " - 88000 seconds is " &amp; timestamp.cnEcAddSeconds(-88000).String;
	write timestamp.String &amp; " + 5 days is " &amp; timestamp.cnEcAddDays(5).String;
	write timestamp.String &amp; " - 5 days is " &amp; timestamp.cnEcAddDays(-5).String;
	write timestamp.String &amp; " + 5 months is " &amp; timestamp.cnEcAddMonths(5).String;
	write timestamp.String &amp; " - 5 months is " &amp; timestamp.cnEcAddMonths(-5).String;
	write timestamp.String &amp; " + 5 years is " &amp; timestamp.cnEcAddYears(5).String;
	write timestamp.String &amp; " - 5 years is " &amp; timestamp.cnEcAddYears(-5).String;
	
	write CrLf &amp; "The age of " &amp; timestamp.String &amp; " is " &amp; timestamp.cnEcAge().String;
	write "The age of " &amp; timestamp.String &amp; " in days, is " &amp; timestamp.cnEcAgeInDays().String;
	write "The short full format of " &amp; timestamp.String &amp; " is " &amp; timestamp.cnEcShortFullFormat();
	write "The short part format of " &amp; timestamp.String &amp; " is " &amp; timestamp.cnEcShortPartFormat();
epilog
	delete theTimestamp;
	
	write CrLf &amp; "Timestamp test completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_TotalAvailMemory" id="7c897e62-bbf1-4ec4-ad7a-7dd6f4360d33">
        <source>cnwdad1_Test_TotalAvailMemory();
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	totalMemory		: Integer;
	availableMemory	: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	node.cnEcGetServerMemory(totalMemory, availableMemory);
	
	write "Server:" &amp; CrLf &amp; "-------";
	write "Total memory: " &amp; totalMemory.cnEcNumberFormat();
	write "Available memory: " &amp; availableMemory.cnEcNumberFormat();

	node.cnEcGetMemory(totalMemory, availableMemory);
	
	write "";
	write "Client:" &amp; CrLf &amp; "-------";
	write "Total memory: " &amp; totalMemory.cnEcNumberFormat();
	write "Available memory: " &amp; availableMemory.cnEcNumberFormat();
epilog
	write CrLf &amp; "Total and Available Memory completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Transform" id="5a578afd-9471-444f-9fd7-f15409fedce4">
        <source>cnwdad1_Test_Transform();
// --------------------------------------------------------------------------------
// Created:		14 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	write "              Metaphone   Soundex";
	write "              =========   =======";
//	self.cnwdad1_Transform_Write("Cat");
//	self.cnwdad1_Transform_Write("Kat");
//	return;
	
	self.cnwdad1_Transform_Write("Alison");
	self.cnwdad1_Transform_Write("Darrell");
	self.cnwdad1_Transform_Write("Dave");
	self.cnwdad1_Transform_Write("David");
	self.cnwdad1_Transform_Write("Kevin");
	self.cnwdad1_Transform_Write("Lorcan");
	self.cnwdad1_Transform_Write("Lucy");
	self.cnwdad1_Transform_Write("Mitch");
	self.cnwdad1_Transform_Write("Nelson");
	self.cnwdad1_Transform_Write("Simon");
epilog
	write CrLf &amp; "Transform completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_UnitOfMeasure" id="2d09cdac-b1aa-4923-a6f6-376913bdc089">
        <source>cnwdad1_Test_UnitOfMeasure() protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AREA_TO_CONVERT			: Real = 15;
	DENSITY_TO_CONVERT		: Real = 0.5;
	ENERGY_TO_CONVERT		: Real = 0.257;
	FORCE_TO_CONVERT		: Real = 253;
	LENGTH_TO_CONVERT		: Real = 5;
	LINEDENSITY_TO_CONVERT	: Real = 410.75;
	POWER_TO_CONVERT		: Real = 180;
	PRESSURE_TO_CONVERT		: Real = 120;
	SPEED_TO_CONVERT		: Real = 100;
	SPREADRATEM_TO_CONVERT	: Real = 25;
	SPREADRATEV_TO_CONVERT	: Real = 25;
	TEMPERATURE_TO_CONVERT	: Real = 23;
	TORQUE_TO_CONVERT		: Real = 150;
	VOLUME_TO_CONVERT		: Real = 5;
	WEIGHT_TO_CONVERT		: Real = 12;
	
vars
	areaObj			: CnEcArea;
	densityObj		: CnEcDensity;
	energyObj		: CnEcEnergy;
	forceObj		: CnEcForce;
	lengthObj		: CnEcLength;
	lineDensityObj	: CnEcLineDensity;
	powerObj		: CnEcPower;
	pressureObj		: CnEcPressure;
	speedObj		: CnEcSpeed;
	spreadRateMObj	: CnEcSpreadRateByMass;
	spreadRateVObj	: CnEcSpreadRateByVolume;
	temperatureObj	: CnEcTemperature;
	torqueObj		: CnEcTorque;
	volumeObj		: CnEcVolume;
	weightObj		: CnEcWeight;
	startTime		: Integer;
	displayValue	: String;
	newTemperature	: Real;
	
begin
	startTime	:=	app.clock();
	create areaObj transient;
	displayValue	:=	"Area: " &amp; AREA_TO_CONVERT.String &amp; " acres to hectares = ";
	areaObj.updateMe(AREA_TO_CONVERT, CnEcArea.ACRES);
	displayValue	:=	displayValue &amp; areaObj.convertMeasure(CnEcArea.HECTARES).numberFormat();
	write displayValue;
	
	create densityObj transient;
	displayValue	:=	"Density: " &amp; DENSITY_TO_CONVERT.String &amp; " kilograms per litre to kilograms per cubic metre = ";
	densityObj.updateMe(DENSITY_TO_CONVERT, CnEcDensity.KILOGRAMS_PER_LITRE);
	displayValue	:=	displayValue &amp; densityObj.convertMeasure(CnEcDensity.KILOGRAMS_PER_CUBIC_METRE).numberFormat();
	write displayValue;
	
	create energyObj transient;
	displayValue	:=	"Energy: " &amp; ENERGY_TO_CONVERT.String &amp; " joules to ergs = ";
	energyObj.updateMe(ENERGY_TO_CONVERT, CnEcEnergy.JOULES);
	displayValue	:=	displayValue &amp; energyObj.convertMeasure(CnEcEnergy.ERGS).numberFormat();
	write displayValue;
	
	create forceObj transient;
	displayValue	:=	"Force: " &amp; FORCE_TO_CONVERT.String &amp; " tonnes force to kilograms force = ";
	forceObj.updateMe(FORCE_TO_CONVERT, CnEcForce.TONNES_FORCE);
	displayValue	:=	displayValue &amp; forceObj.convertMeasure(CnEcForce.KILOGRAMS_FORCE).numberFormat();
	write displayValue;
	
	create lengthObj transient;
	displayValue	:=	"Length: " &amp; LENGTH_TO_CONVERT.String &amp; " miles to kilometres = ";
	lengthObj.updateMe(LENGTH_TO_CONVERT, CnEcLength.MILES);
	displayValue	:=	displayValue &amp; lengthObj.convertMeasure(CnEcLength.KILOMETRES).numberFormat();
	write displayValue;
	
	create lineDensityObj transient;
	displayValue	:=	"Line Density: " &amp; LINEDENSITY_TO_CONVERT.String &amp; " tex to pounds per mile = ";
	lineDensityObj.updateMe(LINEDENSITY_TO_CONVERT, CnEcLineDensity.TEX);
	displayValue	:=	displayValue &amp; lineDensityObj.convertMeasure(CnEcLineDensity.POUNDS_PER_MILE).numberFormat();
	write displayValue;
	
	create powerObj transient;
	displayValue	:=	"Power: " &amp; POWER_TO_CONVERT.String &amp; " kilowatts to horsepower (metric) = ";
	powerObj.updateMe(POWER_TO_CONVERT, CnEcPower.KILOWATTS);
	displayValue	:=	displayValue &amp; powerObj.convertMeasure(CnEcPower.HORSEPOWER_METRIC).numberFormat();
	write displayValue;
	
	create pressureObj transient;
	displayValue	:=	"Pressure: " &amp; PRESSURE_TO_CONVERT.String &amp; " newtons per square millimetre to pounds force per square inch = ";
	pressureObj.updateMe(PRESSURE_TO_CONVERT, CnEcPressure.NEWTONS_PER_SQUARE_MM);
	displayValue	:=	displayValue &amp; pressureObj.convertMeasure(CnEcPressure.POUNDS_FORCE_PER_SQUARE_INCH).numberFormat();
	write displayValue;
	
	create speedObj transient;
	displayValue	:=	"Speed: " &amp; SPEED_TO_CONVERT.String &amp; " miles per hour to kilometres per hour = ";
	speedObj.updateMe(SPEED_TO_CONVERT, CnEcSpeed.MILES_PER_HOUR);
	displayValue	:=	displayValue &amp; speedObj.convertMeasure(CnEcSpeed.KILOMETRES_PER_HOUR).numberFormat();
	write displayValue;
	
	create spreadRateMObj transient;
	displayValue	:=	"Spread Rate (by mass): " &amp; SPREADRATEM_TO_CONVERT.String &amp; " tons (UK) per acre to kilograms per hectare = ";
	spreadRateMObj.updateMe(SPREADRATEM_TO_CONVERT, CnEcSpreadRateByMass.TONS_UK_PER_ACRE);
	displayValue	:=	displayValue &amp; spreadRateMObj.convertMeasure(CnEcSpreadRateByMass.KILOGRAMS_PER_HECTARE).numberFormat();
	write displayValue;
	
	create spreadRateVObj transient;
	displayValue	:=	"Spread Rate (by volume): " &amp; SPREADRATEV_TO_CONVERT.String &amp; " cubic feet per acre to cubic metres per hectare = ";
	spreadRateVObj.updateMe(SPREADRATEV_TO_CONVERT, CnEcSpreadRateByVolume.CUBIC_FEET_PER_ACRE);
	displayValue	:=	displayValue &amp; spreadRateVObj.convertMeasure(CnEcSpreadRateByVolume.CUBIC_METRES_PER_HECTARE).numberFormat();
	write displayValue;
	
	create temperatureObj transient;
	write "The Body temperature is " &amp; temperatureObj.getBodyTemperature(CnEcTemperature.CELSIUS).String &amp; " Centigrade.";
	write "The temperature of Boiling Point is " &amp; temperatureObj.getBoilingPoint(CnEcTemperature.CELSIUS).String &amp; " Centigrade.";
	write "The temperature of Freezing Point is " &amp; temperatureObj.getFreezingPoint(CnEcTemperature.CELSIUS).String &amp; " Centigrade.";
	
	temperatureObj.updateMe(TEMPERATURE_TO_CONVERT, CnEcTemperature.CELSIUS);
	newTemperature	:=	temperatureObj.convertMeasure(CnEcTemperature.KELVIN);
	write "A room temperature of " &amp; TEMPERATURE_TO_CONVERT.String &amp; " Centigrade is " &amp; newTemperature.String &amp; " Kelvin.";
	
	create torqueObj transient;
	displayValue	:=	"Torque: " &amp; TORQUE_TO_CONVERT.String &amp; " pound force inches to kilogram force centimetres = ";
	torqueObj.updateMe(TORQUE_TO_CONVERT, CnEcTorque.POUND_FORCE_INCHES);	
	displayValue	:=	displayValue &amp; torqueObj.convertMeasure(CnEcTorque.KG_FORCE_CENTIMETRES).numberFormat();
	write displayValue;
	
	create volumeObj transient;
	displayValue	:=	"Volume: " &amp; VOLUME_TO_CONVERT.String &amp; " litres to gallons = ";
	volumeObj.updateMe(VOLUME_TO_CONVERT, CnEcVolume.LITRES);
	displayValue	:=	displayValue &amp; volumeObj.convertMeasure(CnEcVolume.GALLONS_UK).numberFormat();
	write displayValue;
	
	create weightObj transient;
	displayValue	:=	"Weight: " &amp; WEIGHT_TO_CONVERT.String &amp; " stones to kilograms = ";
	weightObj.updateMe(WEIGHT_TO_CONVERT, CnEcWeight.STONES);
	displayValue	:=	displayValue &amp; weightObj.convertMeasure(CnEcWeight.KILOGRAMS).numberFormat();
	write displayValue;
epilog
	delete areaObj;
	delete densityObj;
	delete energyObj;
	delete forceObj;
	delete lengthObj;
	delete lineDensityObj;
	delete powerObj;
	delete pressureObj;
	delete speedObj;
	delete spreadRateMObj;
	delete spreadRateVObj;
	delete temperatureObj;
	delete torqueObj;
	delete volumeObj;
	delete weightObj;
	
	write "Units of Measure completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ValidatePathName" id="c8110c02-88cd-4dda-9a7e-f5d7325aa8a7">
        <source>cnwdad1_Test_ValidatePathName();
// --------------------------------------------------------------------------------
// Created:		03 September 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	INVALID_CHARACTERS	: String = '\/:*?"&lt;&gt;|';
	
vars
	fileName1	: String;
	fileName2	: String;
	fileName3	: String;
	
begin
	fileName1	:=	"c:\temp\darrell\spellwords.zip";
	fileName2	:=	"c:\temp\dar?rell\spellwords.zip";
	fileName3	:=	"d:\";
	
	write "Valid file: " &amp; fileName1 &amp; " - " &amp; fileName1.cnEcIsValidPathName().String;
	write "Valid file: " &amp; fileName2 &amp; " - " &amp; fileName2.cnEcIsValidPathName().String;
	write "Valid file: " &amp; fileName3 &amp; " - " &amp; fileName3.cnEcIsValidPathName().String;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_WebBrowser" id="eded6a36-20d2-49d6-a811-f7c6fa625210">
        <source>cnwdad1_Test_WebBrowser() protected;
// --------------------------------------------------------------------------------
