<Class name="CMIF_OnsiteCargo" id="e16a1d26-acc8-4a16-bc51-6e341eef33f9">
    <superclass name="CMIF_PreNote"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="actionForCreate" id="a06d6e8f-5953-441a-aff6-b23bb3301305">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;
/*
Purpose:			
Date		Who		Reason
07 February 2017	cnwab1	Initial creation
 14/04/2023	navkc1	CR 57036 Task 57590: UI - Cargo Enquiry Create New Cargo
*/

vars
	result : Boolean;
	oriMode : String;
	
begin
	// 14/04/2023	navkc1	CR 57036 Task 57590
	oriMode := self.transportMode;
	
	self.transportMode := "";
//	write self.String;
	
	result := inheritMethod(pProxy, _passport);
	if not result then
		return result;
	endif;
	
	self.moveToOnsite(_passport);
	
	// 14/04/2023	navkc1	CR 57036 Task 57590
	// Reset the transport mode if failed at moving. Otherwise the TRX validation will fail because transport mode is invalid.
	if _passport.hasErrorsOrWarnings() then
		self.transportMode := oriMode;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveToOnsite" id="efca4039-d9fc-4090-be76-b219bac70b89">
        <updating/>
        <source>moveToOnsite(_passport : CM_Passport input) updating;

vars
	toTgtStr : String;
	createTrans,
	isOperational : Boolean;
	voy : CM_Voyage;
	locn,
	foundLC : CM_LocationsController; 
	foundHeight : Integer;
	isPlannedRORO	: Boolean;
begin
	exclusiveLock(self.myPersistentTrackedItem);

	toTgtStr := self.stowageLocation;
	
//	write "move " &amp; self.myPersistentTrackedItem.id &amp; " to " &amp; toTgtStr;
	
	self.myTerminal.findLocationFromString(toTgtStr, false, locn, foundHeight);
	if locn = null then 
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, toTgtStr, null, null);
		return;
	endif;
	voy := self.myTerminal.lookupVoyage(voyageCode.trimBlanks, null, false);
	if voy = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, null, null);
		return;
	endif;
	//-------------------
	//We only create transactions if a non-worked voyage (This means the Box is actually there!)
	//If its a non-worked voyage then they are putting the box on, and want export stats
	//-------------------
	
	createTrans := voy.isHOLDSorSHIP();
	if createTrans then
	// PAR 33644  and  not isPlannedRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
		//overwrite depending on what the users are doing. This is passed in from the UI.
		//Basically we need to know if we build transactions (the box was released), or its being
		//simply placed so it can be discharged by the ops process.
		if self.nonWorkedReleaseType = TransactionedMoveType then
			//Set the box as an export.
			isOperational := createTrans;	//We WANT an operational move if its a non-worked voyage
			self.myPersistentTrackedItem.setImExStatus(TI_IMEX_STATUS_EXPORT);
		else
			createTrans := false;
			isOperational := false;
			//Leave as a transit.
		endif;
	endif;	

	//---------------------
	//Do the actual move
	//---------------------
	self.myPersistentTrackedItem.moveToLocation(locn, null, null, null, REAL_MODE, true, isOperational, false, false, false, false, null, null, null, null, null, _passport);	// TFS 2651

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
