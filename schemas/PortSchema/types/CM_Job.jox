    <JadeMethod name="getMyTodoTask" id="06ebe5d7-def0-4bc4-bdcd-7c6d2e5b11cb">
        <source>getMyTodoTask():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 June 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
11 Sep  2024    navbk1  ChangeRequest 62456: EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
*/

vars
	wod		  : CM_WorkOrderDtl;
	wodTodo	  : CM_WodToDo;
begin
	//START 11.09.2024 navbk1 #62456
	wod := self.getMyWorkOrderDtl();

	if wod &lt;&gt; null and wod.isKindOf(CM_WorkOrderTIDtl) then			
		if wod.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty() then
			wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first.CM_WodToDo;
			if wodTodo &lt;&gt; null then
				return wodTodo.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name);			
			endif;
		endif;
	endif;
	//END 11.09.2024 navbk1 #62456
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
