    <JadeMethod name="getBaseAdjustmentDescr" id="82229dd5-1439-4847-a24b-32de87a57a78">
        <source>getBaseAdjustmentDescr( ts : TimeStamp ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

*/

vars

	str : String;
	dpl : Integer;

begin

	if self.isCostPerUnitBased then
		return null;
	endif;

	str := app.getErrorString(Base_rate);
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 13 Feb 2018
	
	if self.adjustmentToBase &lt;&gt; 0 then
		if self.adjustmentToBase &gt; 0 then
			//str := str &amp; " + " &amp; self.adjustmentToBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
			str := str &amp; " + " &amp; self.adjustmentToBase.asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
		else
			//str := str &amp; " - " &amp; ( self.adjustmentToBase * -1 ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
			str := str &amp; " - " &amp; ( self.adjustmentToBase * -1 ).asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
		endif;
	elseif self.percentageOfBase &lt;&gt; 0 then
		//str := str &amp; " x " &amp; self.percentageOfBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; "%";
		str := str &amp; " x " &amp; self.percentageOfBase.asStringJMTWithPrecision(dpl, true) &amp; "%"; // TFS 36954 MPD 20 Feb 2018
	else
		return null;
	endif;
	
	
	return str;

epilog

end;</source>
        <Parameter name="ts" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBaseRateEntry" id="58a9cc35-c4a8-4936-998b-5b339bd77a16">
        <source>getBaseRateEntry( _ts : TimeStamp ):CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	debtorNode : CM_DebtorNode;
	rootDebtorGroup : CM_RootDebtorGroup;
	defaultRe : CM_RateEntry;

begin

	if self.isCostPerUnitBased then
		return null;
	endif;

	if self.rate = null then
		return null;
	endif;
	
	return self.rate.getBaseRateEntry( _ts );

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getBubbleHelp" id="1e0eadbf-dedd-4890-a94d-18697fef98b9">
        <source>getBubbleHelp() : String;
// ---------------------------------------------------------------------------
// Created:		28 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpStr, rangeStr, nameStr : String;
	aRate : Real;
	aCT : CM_CalculationType;
	idx,from,too, st, en : Integer;
	tmpRate : CM_Rate;
	tmpService : CM_Service;
begin
	tmpRate := self.rate;
	if tmpRate = null then
		return null;
	endif;
	tmpService := tmpRate.service;
	if tmpService = null then
		return null;
	endif;
	
	aCT := tmpService.myCalculationType;
	if aCT = null then
		return null;
	endif;
	nameStr := tmpService.name &amp; Cr &amp; Cr;
	if aCT = null then
		foreach aRate in self.allCostPerUnits do
			if tmpStr = null then
				tmpStr := nameStr &amp;  aRate.String;
			else
				tmpStr := tmpStr &amp; ", " &amp; aRate.String;
			endif;
		endforeach;
	else
	
	
	
		//if aCT.calculationType = 10 then		// INV_CALC_TYPE_BUSINESS_HRS_QTY
		if aCT.calculationType = INV_CALC_TYPE_BUSINESS_HRS_QTY then		 
			tmpStr := nameStr;
			foreach aRate in self.allCostPerUnits do
				idx := idx + 1;
				if idx = 1 then
					rangeStr := app.getErrorString(Included_hrs_rate) &amp; " "; // PAR 30681
				else
					rangeStr := app.getErrorString(Excluded_hrs_rate) &amp; " "; // PAR 30681
				
				endif;
				tmpStr := tmpStr &amp; rangeStr &amp; " - " &amp; aRate.String &amp; Cr;
			endforeach;
		elseif aCT.calculationType = INV_CALC_TYPE_BUSHRSVESELVALUE // PAR 30681
		or aCT.calculationType = INV_CALC_TYPE_BUSHRSCARGOVALUE then		 
			tmpStr := nameStr;
			foreach aRate in self.allCostPerUnits do
				idx := idx + 1;
				if idx = 1 then
					rangeStr := app.getErrorString(Normal_hrs_rate) &amp; " ";
				elseif idx = 2 then
					rangeStr := app.getErrorString(Overtime_hrs_rate) &amp; " ";
				else
					rangeStr := app.getErrorString(Excluded_hrs_rate) &amp; " ";
				
				endif;
				tmpStr := tmpStr &amp; rangeStr &amp; " - " &amp; aRate.String &amp; Cr;
			endforeach;
		elseif (aCT &lt;&gt; null and aCT.integerRange1.size = 0) then
			foreach aRate in self.allCostPerUnits do
				if tmpStr = null then
					tmpStr := nameStr &amp;  aRate.String;
				else
					tmpStr := tmpStr &amp; ", " &amp; aRate.String;
				endif;
			endforeach;
		else
			tmpStr := nameStr;
			from := 1;
			if aCT.integerRange1.size &lt;&gt; 0 then
				foreach aRate in self.allCostPerUnits do
					idx := idx + 1;
					if idx &gt; aCT.integerRange1.size then
						break;
					endif;
					too := aCT.integerRange1[idx];
					rangeStr := from.String &amp; " to " &amp; too.String;
					tmpStr := tmpStr &amp; rangeStr &amp; " - " &amp; aRate.String &amp; Cr;
					from := too + 1;
				endforeach;
				
				// EXTRA???
				if idx &lt; aCT.integerRange1.size 
				and idx &gt; 0 then
					st := idx;
					en := aCT.integerRange1.size;

					foreach idx in st to en do
						if idx = 0 or idx &gt; en then
							break;
						endif;
						too := aCT.integerRange1[idx];
						rangeStr := from.String &amp; " to " &amp; too.String;
						tmpStr := tmpStr &amp; rangeStr &amp; " - 0.00" &amp; Cr;
						from := too + 1;
					
					endforeach;
				endif;

			endif;		
		endif;	
	endif;
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCPUMovementIndex" id="4db0650b-f3d6-4da9-8dbf-cab058f1d261">
        <source>getCPUMovementIndex( _invLine : CM_InvoiceLine ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 April 2019	jlgndl1	Initial creation	TFS 43687
23 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	woDtl :CM_WorkOrderVoyageDtl;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if app.isInProformaMode then
		if _invLine.myTransactionWO &lt;&gt; null then
			if _invLine.myTransactionWO.myWorkOrder &lt;&gt; null then
				if _invLine.myTransactionWO.myWorkOrder.isWorkOrderForShift then
					// at this point in time we know it is a shift, but there is no shift movment created yet
					if self.allCostPerUnits.size &gt; 2 then
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranWO ", LogTRACE.String);	
						endif;
						return 3;
					else
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranWO but no cpu!", LogTRACE.String);	
						endif;
					endif;
				endif;
			endif;
		elseif _invLine.myTransactionHMS &lt;&gt; null then
			if _invLine.myTransactionHMS.myResourceUsed &lt;&gt; null then
				woDtl := _invLine.myTransactionHMS.myResourceUsed.myWorkOrderVoyageDtl;
				if woDtl.isWorkOrderForShift then
					// at this point in time we know it is a shift, but there is no shift movment created yet
					if self.allCostPerUnits.size &gt; 2 then
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranHMS ", LogTRACE.String);	
						endif;
						return 3;
					else
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranHMS but no cpu!", LogTRACE.String);	
						endif;
					endif;
				elseif woDtl.isWorkOrderMarineServiceDtl and woDtl.CM_WodMarineServiceDetail.myShiftMovement &lt;&gt; null then
					// at this point in time we know it is a shift, but there is no shift movment created yet
					if self.allCostPerUnits.size &gt; 2 then
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranHMS ", LogTRACE.String);	
						endif;
						return 3;
					else
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog(method.qualifiedName &amp; " Shift WO found from tranHMS but no cpu!", LogTRACE.String);	
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

	movement := _invLine.getMyMovementObject();
	if movement &lt;&gt; null then
		if ( movement.isArrival or movement.isMoveTypeArrCancelled ) then
			if not self.allCostPerUnits.isEmpty then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Arrival 'Movement' found", LogTRACE.String);	
				endif;
				return 1;
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Arrival 'Movement' found but no cpu!", LogTRACE.String);
				endif;
			endif;
		elseif ( movement.isMovementTypeDeparture or movement.isMoveTypeDepCancelled ) then
			if self.allCostPerUnits.size &gt; 1 then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Departure 'Movement' found", LogTRACE.String);	
				endif;
				return 2;
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Departure 'Movement' found but no cpu!", LogTRACE.String);	
				endif;
			endif;
		elseif ( movement.isMovementTypeShift or movement.isMoveTypeShiftCancelled ) then
			if self.allCostPerUnits.size &gt; 2 then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Shift 'Movement' found", LogTRACE.String);	
				endif;
				return 3;
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Shift 'Movement' found but no cpu!", LogTRACE.String);	
				endif;
			endif;
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Invalid 'Movement' type found!", LogTRACE.String);	
			endif;
		endif;
	endif;
	
	return 0;
	
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCPUforObject" id="1046c737-3a1e-480b-a85e-42d1b9f9d0da">
        <source>getCPUforObject( _obj : CM_Object ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS	39338 

*/

vars

	subTerminal : CM_SubTerminal;
	subTerminalRate : CM_SubTerminalRate;
	tidalClass : HMS_TidalClass;
	tidalClassRate : CM_TidalClassRate;

begin

	if _obj = null then
		return 0.0;
	endif;
	
	if _obj.isKindOf( CM_SubTerminal ) then
		subTerminal := _obj.CM_SubTerminal;
		subTerminalRate := self.allRatesBySubTerminal.getAtKey( subTerminal );
		if subTerminalRate = null then
			return 0.0;
		else
			return subTerminalRate.costPerUnit;
		endif;
		
	elseif _obj.isKindOf( HMS_TidalClass ) then
		tidalClass := _obj.HMS_TidalClass;
		tidalClassRate := self.allRatesByTidalClass.getAtKey( tidalClass );
		if tidalClassRate = null then
			return 0.0;
		else
			return tidalClassRate.costPerUnit;
		endif;
		
	else
		return 0.0;
		
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCostPerUnit" id="3d0ef24d-0ffb-44d6-8160-c4f8bd2aed1c">
        <source>getCostPerUnit(_service : CM_Service; _invLine : CM_InvoiceLine; _total : Real output; _ts : TimeStamp) : Real;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
7/10/2013	cnwjre1	Par 32727 handle zero quantity (generally only from an incorrect transaction map setup)
04/04/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels taht use a Ramp
23 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	str	: String;
	found	: Boolean;
	i	: Integer;
	cpu : Real;
	increment	: Real;
	intValue	: Integer;
	value	: Real;
	qty		: Real;
	previousQty : Integer;
	hmsTrans : HMS_VTMISTransaction;
	tiTrans : CM_TITransaction;
	rateTidalClass	: HMS_TidalClass;
	tidalClass	: HMS_TidalClass;
	root	: CM_Root;
	calcType, idx : Integer;
	calcUnit	: Integer;
	perDays	: Integer;
	actionTS : TimeStamp;
	oa	: ObjectArray;
	obj	: Object;
	aCT : CM_CalculationType;
	theVoy : CM_Voyage;
	voyageData : HMS_VoyageData;
	invalid 		: Boolean;
	wotrans : CM_WOTransaction;
	permitType : Integer;
	debtorn : CM_DebtorNode;
	debtorName : String;
	movement : HMS_VoyageMovement;
	rampIndex : Integer;						// TFS 43694
	cpuIndex : Integer;	//12 Apr 2019	NDL	TFS 43687
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " STARTING", LogINFO.String); 
	endif;
	if not self.isCostPerUnitBased then
		return self.getDerivedCostPerUnit(_ts);
	endif;
	
	root := CM_Root.firstInstance;
	aCT := _service.myCalculationType;
	if aCT &lt;&gt; null then
		calcType := aCT.calculationType;
		calcUnit := aCT.theCalcTypeUnit;
	endif;
	// 32727 use 1 for zero quantity
	qty := _invLine.quantity;
	if qty = 0 then
		qty := 1;
	endif;
	
	if (aCT &lt;&gt; null) then // ### TFS 2682
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Rate for '" &amp; self.rate.service.name &amp; "' used Calc Type '" &amp; aCT.description &amp; "'", LogINFO.String);	 // ### TFS 2682
		endif;
		debtorn := self.getMyDebtorNode() ;
		debtorName := "UNKNOWN";
		if debtorn&lt;&gt; null then
		debtorName := debtorn.name;
		endif; 
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Rate for Debtor '" &amp; debtorName &amp; "'", LogINFO.String);	
		endif;
	endif;
	
	if aCT &lt;&gt; null and aCT.rateType = aCT.RateTypeHMSMovementType then	//22 Mar 2019	NDL	TFS 43687
		
		cpuIndex := self.getCPUMovementIndex( _invLine );
		if cpuIndex &gt; 0 then
			cpu := self.allCostPerUnits[cpuIndex];
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " 'Movement' not found for 'Movement Calc Type' " &amp; aCT.description &amp; " using invoice line!", LogINFO.String);	//05 Apr 2019	NDL	TFS 43687
			endif;
		endif;
		
	// TFS 43694 Ramp Rate Type
	elseif aCT &lt;&gt; null and aCT.rateType = aCT.RateTypeRamp then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Using Rate Type 'Ramp' - " &amp; aCT.description, LogINFO.String);
		endif;
		movement := _invLine.getMyMovementObject;
		if movement &lt;&gt; null then
		

			rampIndex := movement.getRampUsage(_invLine);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " movement.getRampUsage(_invline) returned " &amp; rampIndex.String &amp; ", self.allCostsPerUnit.size is " &amp; self.allCostPerUnits.size.String, LogINFO.String);
			endif;
			if rampIndex = CM_Rate.RAMP_USED and not self.allCostPerUnits.isEmpty then
				cpu := self.allCostPerUnits[1];
			elseif rampIndex = CM_Rate.RAMP_NOT_USED and self.allCostPerUnits.size &gt; 1 then
				cpu := self.allCostPerUnits[2];
			elseif rampIndex = CM_Rate.RAMP_PENALTY and self.allCostPerUnits.size &gt; 2 then
				cpu := self.allCostPerUnits[3];
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Invalid rampIndex returned!", LogINFO.String);
				endif;
			endif;
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " No movement found for nvoice line " &amp; _invLine.getOidString &amp; "!", LogINFO.String);
			endif;
		endif;
	// TFS 43694 end
	
	elseif calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then // ### VOYAGE INVOICING ONLY
		// if the calc type is INV_CALC_TYPE_BUSINESS_HRS_QTY then it should 
		// have 7 yes and no s in the boolean list, 1 for each day of the week plus 2 times.
		if self.allCostPerUnits.size &lt; 1 or self.allCostPerUnits.size &gt; 2 then
			cpu := self.getDerivedCostPerUnit(_ts);
		else
			hmsTrans := _invLine.myTransactionHMS;
			if hmsTrans &lt;&gt; null and hmsTrans.myResourceUsed &lt;&gt; null then
				actionTS := hmsTrans.myResourceUsed.fromDateTime;
			else
				actionTS := _invLine.chargeTime; // ### PAR 10431
			endif;	
			if aCT.isTimeIncluded(actionTS, _invLine.bank.terminal) then
				cpu := self.allCostPerUnits[self.INDEX_INCLUDED];
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is INCLUDED rate", LogINFO.String);	 	// ### TFS 6536
				endif;
			else
				cpu := self.allCostPerUnits[self.INDEX_EXCLUDED];
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is EXCLUDED rate ", LogINFO.String);	// ### TFS 6536
				endif;
			endif; 
		endif;
	elseif calcType = INV_CALC_TYPE_WO_PERMIT then // TFS 39236 
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("WO Permit derived rate Evaluating", LogINFO.String);	 // ### TFS 39236
		endif;
		if self.allCostPerUnits.size &lt; 1 or self.allCostPerUnits.size &gt; 5 then
			cpu := self.getDerivedCostPerUnit(_ts);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is WO Permit derived rate ", LogINFO.String);	 // ### TFS 39236
			endif;
		else
			wotrans := _invLine.myTransactionWO;
			if wotrans &lt;&gt; null then
				permitType := wotrans.getPermitType();
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("WO Permit Transaction Permit Index Is " &amp; permitType.String, LogINFO.String);	 // ### TFS 39236
				endif;
				if permitType &gt; 0 and permitType &lt;= self.allCostPerUnits.size then
					cpu := self.allCostPerUnits[permitType];
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is WO Permit Type " &amp; permitType.String &amp; " Rate is " &amp; cpu.String, LogINFO.String);	 // ### TFS 39236
					endif;
				endif;
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("WO Permit Transaction is NULL", LogINFO.String);	 // ### TFS 39236
				endif;
			endif;
		
		endif;
		
	// TFS 42221
	elseif calcType = INV_CALC_TYPE_WO_EXTRA then 
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("WO Extra Cargo derived rate Evaluating", LogINFO.String);	 
		endif;
		if self.allCostPerUnits.size &lt; 1 or self.allCostPerUnits.size &gt; 5 then
			cpu := self.getDerivedCostPerUnit(_ts);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is WO Extra Cargo derived rate ", LogINFO.String);	 
			endif;
		else
			tiTrans := _invLine.myTransactionTI;
			if tiTrans &lt;&gt; null then
				permitType := tiTrans.getInvoiceWOPermitType();
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("WO Extra Cargo Transaction Permit Index Is " &amp; permitType.String, LogINFO.String);	
				endif;
				if permitType &gt; 0 and permitType &lt;= self.allCostPerUnits.size then
					cpu := self.allCostPerUnits[permitType];
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is WO Extra Cargo Type " &amp; permitType.String &amp; " Rate is " &amp; cpu.String, LogINFO.String);	 
					endif;
				endif;
			else
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("WO Extra Cargo Transaction is NULL", LogINFO.String);	 
				endif;
			endif;
		
		endif;
		
	// PAR 30681
	elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE  // ### VOYAGE INVOICING ONLY
	or  calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // ### CARGO 
		if self.allCostPerUnits.size &lt; 1 or self.allCostPerUnits.size &gt; 3 then
			cpu := self.getDerivedCostPerUnit(_ts);
		else
			actionTS := _invLine.chargeTime;
			if calcType = INV_CALC_TYPE_BUSHRSVESELVALUE then
				hmsTrans := _invLine.myTransactionHMS;
				if hmsTrans &lt;&gt; null and hmsTrans.myResourceUsed &lt;&gt; null then
					actionTS := hmsTrans.myResourceUsed.fromDateTime;
				endif;
			else
				tiTrans := _invLine.myTransactionTI;
				if tiTrans &lt;&gt; null  then
					actionTS := tiTrans.dateTime;
				endif;
			
			endif;
			
			if aCT.isTimeExcludedTime(actionTS, _invLine.bank.terminal) then // WEEKENDS/ HOLIDAYS
				cpu := self.allCostPerUnits[self.INDEX_EXCLUDEDTIME];
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is EXCLUDED hours rate ", LogINFO.String);	 // ### TFS 6536
				endif;
			elseif aCT.isTimeNormalTime(actionTS, _invLine.bank.terminal) then
				cpu := self.allCostPerUnits[self.INDEX_NORMALTIME];
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is NORMAL hours rate ", LogINFO.String);	 // ### TFS 6536
				endif;
			elseif aCT.isTimeOverTime(actionTS, _invLine.bank.terminal) then
				cpu := self.allCostPerUnits[self.INDEX_OVERTIME];
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is OVERTIME hours rate ", LogINFO.String);	 // ### TFS 6536
				endif;
			else
				cpu := self.allCostPerUnits[self.INDEX_NORMALTIME]; // DEFAULT
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Rate for '" &amp; actionTS.asStringJMT() &amp; "' is NORMAL (default) hours rate ", LogINFO.String);	 // ### TFS 6536
				endif;
			endif; 
		endif;
	elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1	// ### VOYAGE INVOICING ONLY
			or calcType = INV_CALC_TYPE_TIDAL_CLASS) then											// 34489 add tidal class
		// ### We need the voyage's dimensions, so get the voyage first
		hmsTrans := _invLine.myTransactionHMS;
		if hmsTrans &lt;&gt; null then
			theVoy := hmsTrans.myVoyage;
			if hmsTrans.myMovement &lt;&gt; null then
				rateTidalClass := hmsTrans.myMovement.myTidalClass;
			endif;
		else
			theVoy := _invLine.invoice.myVoyage; // ### PAR 10451
		endif;
		
		if theVoy &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, theVoy, invalid);
			voyageData := theVoy.myHMSVoyageData;
			
			if voyageData &lt;&gt; null then
				// 34489 CCMS 1327 use tidal class to get the rate
				if calcType = INV_CALC_TYPE_TIDAL_CLASS then
					if rateTidalClass &lt;&gt; null then
						cpu := self.getCPUforObject( rateTidalClass );	//29 Jun 2018	NDL	TFS 39338
						// get tidal classes sorted by description to match the order from the rate maintenance
				/*		create oa transient;
						app.sortTidalClasses(oa);
						idx := 0;
						found := false;
						foreach obj in oa do
							tidalClass := obj.HMS_TidalClass;
							idx := idx + 1;
							if tidalClass.description = rateTidalClass.description then
								app.invLog("Rate chosen for '" &amp; tidalClass.description &amp; "'");	 // ### TFS 6536
								found := true;
								break;
							endif;
						endforeach;
						if not found then
							idx := 1;
						endif;
					else
						idx := 1; */
					endif;
				else
					// 30680 CCMS 2178 user-defined unit not just hard-coded GRT
					if calcUnit = INV_CALC_TYPE_UNIT_GRT then
						intValue := voyageData.dim_GrossRegTonnes; 
					elseif calcUnit = INV_CALC_TYPE_UNIT_NRT then
						intValue := voyageData.dim_NetRegTonnes; 
					elseif calcUnit = INV_CALC_TYPE_UNIT_LENGTH then
						intValue := voyageData.dim_LengthOverall.Integer; 
					elseif calcUnit = INV_CALC_TYPE_UNIT_BEAM then
						intValue := voyageData.dim_Beam.Integer; 
					elseif calcUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
						intValue := voyageData.dim_DeadWeight;
					else // DEFAULT
						intValue := voyageData.dim_GrossRegTonnes;
					endif;
					
					idx := aCT.getRangeIndex(intValue);
		//		endif;
					if idx &lt; 1 or idx &gt; self.allCostPerUnits.size then
						cpu := self.getDerivedCostPerUnit(_ts);
					else			
						cpu := self.allCostPerUnits[idx];
					endif;
				
				endif;
			else
				cpu := self.getDerivedCostPerUnit(_ts);
			endif;
		else // NO VOYAGE so use first CPU
			cpu := self.getDerivedCostPerUnit(_ts);
		endif;
		
	elseif calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then 
		tiTrans := _invLine.myTransactionTI;
		if tiTrans &lt;&gt; null and tiTrans.mySubTerminal &lt;&gt; null then
			cpu := self.getCPUforObject( tiTrans.mySubTerminal );
		endif;
		
	else	// ## ALL CARGO INVOICING and the rest of the voyage invoicing

		if self.allCostPerUnits.isEmpty then
			cpu := self.getDerivedCostPerUnit(_ts);
		else
			cpu := self.allCostPerUnits.first;
		endif;
		//	CCMS SFW 1279 May 2012 Storage Escalating Charges
		if aCT &lt;&gt; null then
			if aCT.allQuantityRanges.size &gt; 0 then
				// escalating invoice lines
				idx := aCT.getQuantityRangeIndex(_invLine.quantityRangeStart.Integer, _invLine.quantityRangeEnd.Integer, perDays);
				if idx &gt; 0 and idx &lt;= self.allCostPerUnits.size then
					
					//cnwrns1 17/09/2012 to accomdate amount being a value not a rate
					if self.costIsAmount = true then
						cpu :=  self.allCostPerUnits[idx] / qty;		// 32727
					else
						cpu := self.allCostPerUnits[idx];
					endif;
					
					
					if perDays &gt; 0 and
					   idx &lt; self.allCostPerUnits.size then
						// full escalating
						if _invLine.escalatingCount &gt; 0 then
							increment := self.allCostPerUnits[idx + 1];
							//if the increment is percentage then 
							// the value will be increment % * cpu
							//cnwrns1 24/8/2012 to accomodate the precentage increment
							if self.costIsAmount then
								value := aCT.getQuantityRangeValue(0, _invLine.quantityRangeStart.Integer, qty.Integer, self.allCostPerUnits, self.costIsAmount);
								if self.rateIsPercentage then 
									foreach i in 1 to _invLine.escalatingCount - 1 do
										value := value + ((increment/100)* value);
									endforeach;
								else
									value := value + increment * (_invLine.escalatingCount - 1);
								endif;							
								cpu := value / qty;		// 32727
							endif;
							
							if self.rateIsPercentage then 
								foreach i in 1 to _invLine.escalatingCount - 1 do
									cpu := cpu + ((increment/100)* cpu);
								endforeach;
							else
								cpu := cpu + increment * (_invLine.escalatingCount - 1);
							endif;
							
						else
						// consolidated
							value := aCT.getQuantityRangeValue(0, _invLine.quantityRangeStart.Integer, qty.Integer, self.allCostPerUnits,self.costIsAmount);
							cpu := value / qty;		// 32727
						endif;
						// pass back the actual total to use - may be more accurate than composite rate * qty
						_total := value;
					endif;
				endif;
				// single consolidated invoice line
				if _invLine.quantityRangeStart = 0 and
				   _invLine.quantityRangeEnd = 0 then
					if _invLine.isStorageByDays() then
						previousQty := _invLine.getPreviousLinkedAmount().Integer;
					endif;
					value := aCT.getQuantityRangeValue(previousQty, 0, qty.Integer, self.allCostPerUnits,self.costIsAmount);
					cpu := value / qty;		// 32727
					// pass back the actual total to use - may be more accurate than composite rate * qty
					_total := value;
				endif;
			endif;
		endif;
	endif;

	return cpu;
epilog
	delete oa;
end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_total" type="Real" usage="output"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCostPerUnitLabels" id="4a8270ec-9a23-4170-a9fa-bb7ec3b6880b">
        <source>getCostPerUnitLabels(_rateLabels : StringArray input);

// 16/10/2012	cnwmh5	#30549 - Add extracting of calculationType's allQuantityRanges and change to use 
// 28/03/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
vars
	calculationType : CM_CalculationType;
	range			: CM_QuantityRange;								// 16/10/2012 cnwmh5 #30549
	calcType		: Integer;
	int ,first		: Integer;
	aCaption 		: String;
	tidalClassRate : CM_TidalClassRate;
	subTerminalRate : CM_SubTerminalRate;
begin
	_rateLabels.clear;
	calculationType := self.rate.service.myCalculationType;
	if calculationType = null then
		_rateLabels.add(rate.service.name.removeCrLfs());				// 17/10/2012 cnwmh5 #30549 - Remove CrLf's	
		return;
	endif;
	calcType:=calculationType.calculationType;

	if calculationType.rateType = calculationType.RateTypeHMSMovementType then	//22 Mar 2019	NDL	TFS 43687
		_rateLabels.add( app.getMoveTypeDescription(HMSMovementTypeArrival) );
		_rateLabels.add( app.getMoveTypeDescription(HMSMovementTypeDeparture) );
		_rateLabels.add( app.getMoveTypeDescription(HMSMovementTypeShift) );
	elseif calculationType.rateType = calculationType.RateTypeRamp then		// TFS 43694
		_rateLabels.add(CM_Rate.RAMP_USED_STR);								// TFS 43694
		_rateLabels.add(CM_Rate.RAMP_NOT_USED_STR);							// TFS 43694
		_rateLabels.add(CM_Rate.RAMP_PENALTY_STR);							// TFS 43694
	elseif calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
//		_rateLabels.add("Included Hrs Rate");
//		_rateLabels.add("Excluded Hrs Rate");
		_rateLabels.add(app.getErrorString(Included_hrs_rate));// PAR 30681
		_rateLabels.add(app.getErrorString(Excluded_hrs_rate));// PAR 30681
	elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE or calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
		_rateLabels.add(app.getErrorString(Normal_hrs_rate));
		_rateLabels.add(app.getErrorString(Overtime_hrs_rate));
		_rateLabels.add(app.getErrorString(Excluded_hrs_rate));
	//elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1) then 
	elseif calcType = INV_CALC_TYPE_WO_PERMIT then // TFS 39236
		_rateLabels.add(app.getErrorString(STR_WO_PERMIT_METMAL));
		_rateLabels.add(app.getErrorString(STR_WO_PERMIT_CARPEN));
		_rateLabels.add(app.getErrorString(STR_WO_PERMIT_CARNOPEN));
		_rateLabels.add(app.getErrorString(STR_WO_PERMIT_CONPEN));
		_rateLabels.add(app.getErrorString(STR_WO_PERMIT_CONNOPEN));
	
	elseif not calculationType.integerRange1.isEmpty() then									// 16/10/2012 cnwmh5 #30549
		first := 1;
		foreach int in calculationType.integerRange1 do
			aCaption := first.String &amp; " - " &amp; int.String;
			_rateLabels.add('Range: ' &amp; aCaption);
			first := int + 1;
		endforeach;
	elseif not calculationType.allQuantityRanges.isEmpty() then								// 16/10/2012 cnwmh5 #30549 - add this
		foreach range in calculationType.allQuantityRanges do
			aCaption := range.rangeStart.String &amp; " - " &amp; range.rangeEnd.String;
			_rateLabels.add('Range: ' &amp; aCaption);
			if range.daysIncrement &lt;&gt; 0 then
				aCaption := aCaption &amp; " every " &amp; range.daysIncrement.String &amp; " days";
				_rateLabels.add('Range: ' &amp; aCaption);
			endif;
		endforeach;
	elseif calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
		foreach subTerminalRate in self.allRatesBySubTerminal do
			_rateLabels.add( subTerminalRate.mySubTerminal.description );
		endforeach;
	elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
		foreach tidalClassRate in self.allRatesByTidalClass do
			_rateLabels.add( tidalClassRate.myTidalClass.description );
		endforeach;
	else
		_rateLabels.add(rate.service.name.removeCrLfs());			// 16/10/2012 cnwmh5 #30549 - Remove CrLf's		
	endif;
	
end;</source>
        <Parameter name="_rateLabels" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDerivedCostPerUnit" id="3f92fbba-c1b6-4176-b2d5-825384e313e0">
        <source>getDerivedCostPerUnit( _ts :TimeStamp ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375
//07 Jun 2016	cnwrs1	TFS2107 change rate/cost per unit from 12,6 to 16,6
*/

vars

	baseRateEntry : CM_RateEntry;
	//cpu : Decimal[16,6];
	cpu : Decimal[23,6];	//11 May 2018	NDL	TFS 38528

begin

	if self.isCostPerUnitBased then
		return self.getRawCostPerUnit;
	endif;

	baseRateEntry := self.rate.getBaseRateEntry( _ts );
	if baseRateEntry = null then
		return cpu;
	endif;
	
	if self.isAdjustmentBased then
		cpu := ( baseRateEntry.getRawCostPerUnit + self.adjustmentToBase ).Decimal;
	elseif self.isPercentBased then
		cpu := ( ( baseRateEntry.getRawCostPerUnit * self.percentageOfBase ) / 100 ).Decimal;
	endif;
	
	if cpu &lt; 0 then
		cpu := 0;
	endif;
	
	return cpu;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="99cf9ffb-a715-4c32-864e-fb4bb370adc4">
        <source>getDisplayString() : String;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

vars
	str : String;
	code : String;
begin

	code := self.rate.getCode();
	str := code &amp; Tab &amp;
			//self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; Tab &amp;
			self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true) &amp; Tab &amp;		// TFS 36954 MPD 20 Feb 2018
			self.startTimestamp.String &amp; Tab &amp;
			self.userId;		//NFS GD Xpose 1342
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="53c3694d-cc26-4b56-8823-5b8ee26be0f4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// 23582 for ent table usage
// 16 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
vars

begin
	if _attrName = ETRow_RateOwner then
		return self.rate.getListName();		// so default debtor is not 'RDG'
	elseif _attrName = ETRow_StartTime then
		return self.systemToLocalTime(self.startTimestamp).asStringJMT;// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_ExpiryDate then
		return self.systemToLocalTime(self.expiryTimestamp).asStringJMT;// 16 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Ignore then
		return self.ignoreThisEntry.asStringJMT;
	elseif _attrName = ETRow_CostPerUnit then
		//return self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
		return self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true);	// TFS 36954 MPD 20 Feb 2018
	elseif _attrName = ETRow_ChangedBy then
		return self.userId;
	elseif _attrName = ETRow_BaseRateChange then
		return self.getBaseAdjustmentDescr( app.getChargeRateEffectiveDate );
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="72ea0a0f-cf33-4698-8a7d-fe58f241b13f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2012	cnwndl1	Initial creation	Par 30375
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
04 Apr 2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

	block : CM_DataContainerBlock;
	startTsArray : TimeStampArray;
	endTsArray : TimeStampArray;
	ts : TimeStamp;
	rangeString, caption : String;
	index : Integer;
	dpl : Integer;
	aCT : CM_CalculationType;
	calcType, count, first, int : Integer;
	cpu : Decimal[23,6];
	subTermRate : CM_SubTerminalRate;
	tidalClassRate : CM_TidalClassRate;
	
begin

	dpl := self.getRateEntryDecimalPlaces(); // TFS 36954 MPD 20 Feb 2018

	if self.isCostPerUnitBased then
			block := _dataContainer.addNewBlock;
	
		if self.allCostPerUnits.size &lt;= 1
		and self.allRatesByTidalClass.isEmpty	//28 Jun 2018	NDL	TFS 39338
		and self.allRatesBySubTerminal.isEmpty	//28 Jun 2018	NDL	TFS 39338
		then
			block.addNewItem(app.getErrorString(Cost_per_unit), DC_Label, 1, self);
			//block.addNewItem(self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
			block.addNewItem(self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
		else
		
			if self.rate.service &lt;&gt; null  then
				
				aCT := self.rate.service.myCalculationType;
				if aCT &lt;&gt; null then
					calcType := aCT.calculationType;
					
					if aCT.rateType = aCT.RateTypeHMSMovementType then	//22 Mar 2019	NDL	TFS 43687
						count := 1;
						foreach cpu in self.allCostPerUnits do
							if count = 1 then
								block.addNewItem(app.getMoveTypeDescription(HMSMovementTypeArrival), DC_Label, 1, self);
							elseif count = 2 then
								block.addNewItem(app.getMoveTypeDescription(HMSMovementTypeDeparture), DC_Label, 1, self);
							else
								block.addNewItem(app.getMoveTypeDescription(HMSMovementTypeShift), DC_Label, 1, self);
							endif;
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); 
							count := count + 1;
						endforeach;	
						
					// TFS 43694 Ramp Used
					elseif aCT.rateType = aCT.RateTypeRamp then
						count := 1;
						foreach cpu in self.allCostPerUnits do
							if count = 1 then
								block.addNewItem(CM_Rate.RAMP_USED_STR, DC_Label, 1, self);
							elseif count = 2 then
								block.addNewItem(CM_Rate.RAMP_NOT_USED_STR, DC_Label, 1, self);
							elseif count = 3 then
								block.addNewItem(CM_Rate.RAMP_PENALTY_STR, DC_Label, 1, self);
							endif;
							block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); // JLGAB1 found during testing
							count := count + 1; // JLGAB1  found during testing
						endforeach;
					// TFS 43694 end
						
					elseif aCT.isCargoCalcType then
						if calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
							count := 1;
							foreach cpu in self.allCostPerUnits do
								if count = 1 then
									block.addNewItem(app.getErrorString(Normal_hrs_rate), DC_Label, 1, self);
								elseif count = 2 then
									block.addNewItem(app.getErrorString(Overtime_hrs_rate), DC_Label, 1, self);
								else
									block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, self);
								endif;
								//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, self);
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); // TFS 36954 MPD 20 Feb 2018
								count := count + 1;
							endforeach;					
						
						//27 Jun 2018	NDL	TFS 39246
						elseif calcType = INV_CALC_TYPE_WO_EXTRA then 
							count := 1;
							foreach cpu in self.allCostPerUnits do
								if count = 1 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_METMAL), DC_Label, 1, self);
								elseif count = 2 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARPEN), DC_Label, 1, self);
								elseif count = 3 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARNOPEN), DC_Label, 1, self);
								elseif count = 4 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CONNOPEN), DC_Label, 1, self); // TFS 42221 19DEC18
								else
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CONPEN), DC_Label, 1, self); // TFS 42221 19DEC18
								endif;
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self); 
								count := count + 1;
							endforeach;						
						
						//28 Jun 2018	NDL	TFS 39338
						elseif calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then
							foreach subTermRate in self.allRatesBySubTerminal do
								block.addNewItem(subTermRate.mySubTerminal.description, DC_Label, 1, self);
								block.addNewItem(subTermRate.costPerUnit.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self); 
							endforeach;
							
						endif;
						
					elseif aCT.isWorkOrderType then // TFS 39198
						
						if calcType = INV_CALC_TYPE_WO_PERMIT then 
							count := 1;
							foreach cpu in self.allCostPerUnits do
								if count = 1 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_METMAL), DC_Label, 1, self);
								elseif count = 2 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARPEN), DC_Label, 1, self);
								elseif count = 3 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CARNOPEN), DC_Label, 1, self); // TFS 42221 19DEC18
								elseif count = 4 then
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CONNOPEN), DC_Label, 1, self); // TFS 42221 19DEC18
								else
									block.addNewItem(app.getErrorString(STR_WO_PERMIT_CONPEN), DC_Label, 1, self);
								endif;
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self); 
								count := count + 1;
							endforeach;
						endif;
					elseif aCT.isVoyageCalcType then
						calcType := aCT.calculationType;
						if calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
							count := 1;
							foreach cpu in self.allCostPerUnits do
								if count = 1 then
									block.addNewItem(app.getErrorString(Included_hrs_rate), DC_Label, 1, self);
								else
									block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, self);
								endif;
								//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, self);
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); // TFS 36954 MPD 20 Feb 2018
								count := count + 1;
							endforeach;
						elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE then // PAR 30681
							count := 1;
							foreach cpu in self.allCostPerUnits do
								if count = 1 then
									block.addNewItem(app.getErrorString(Normal_hrs_rate), DC_Label, 1, self);
								elseif count = 2 then
									block.addNewItem(app.getErrorString(Overtime_hrs_rate), DC_Label, 1, self);
								else
									block.addNewItem(app.getErrorString(Excluded_hrs_rate), DC_Label, 1, self);
								endif;
								//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, self);
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); // TFS 36954 MPD 20 Feb 2018
								count := count + 1;
							endforeach;
						elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1) then 
							first := 1;
							count := 1;
							foreach cpu in self.allCostPerUnits  do
								int := aCT.integerRange1[count];
								caption := first.String &amp; " - " &amp; int.String;
								block.addNewItem(caption, DC_Label, 1, self);
								first := int + 1;
								//block.addNewItem(cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false), DC_Data, 1, self);
								block.addNewItem(cpu.asStringJMTWithPrecision(dpl, false), DC_Data, 1, self); // TFS 36954 MPD 20 Feb 2018
								count := count + 1;
							endforeach;
							
						//28 Jun 2018	NDL	TFS 39338
						elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then
							foreach tidalClassRate in self.allRatesByTidalClass do
								block.addNewItem(tidalClassRate.myTidalClass.description, DC_Label, 1, self);
								block.addNewItem(tidalClassRate.costPerUnit.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self); 
							endforeach;
							
						endif;
					endif;
				endif;
			endif;
		endif;
		
	elseif ( self.isPercentBased or self.isAdjustmentBased ) then

		create startTsArray transient;
		create endTsArray transient;
		self.getAllTimeStampRangesForEntry( startTsArray, endTsArray );
	
		foreach ts in startTsArray do
			index := index + 1;
			rangeString := startTsArray[index].asStringJMT &amp; "-" &amp; endTsArray[index].asStringJMT;
			
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Cost_per_unit) &amp; " - " &amp; rangeString, DC_Label, 1, self);
			//block.addNewItem(self.getDerivedCostPerUnit( ts ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
			block.addNewItem(self.getDerivedCostPerUnit( ts ).asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
		
			
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Base_rate) &amp; " - " &amp; rangeString, DC_Label, 1, self);
			//block.addNewItem(self.getBaseRateEntry( ts ).getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
			block.addNewItem(self.getBaseRateEntry( ts ).getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
		endforeach;
		
		if self.isPercentBased then
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Percent_base_rate), DC_Label, 1, self);
			//block.addNewItem("x " &amp; self.percentageOfBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
			block.addNewItem("x " &amp; self.percentageOfBase.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
		
		elseif self.isAdjustmentBased then
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Base_rate_adjustment), DC_Label, 1, self);
			if self.adjustmentToBase &lt; 0 then
				//block.addNewItem("- " &amp; ( self.adjustmentToBase * -1 ).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
				block.addNewItem("- " &amp; ( self.adjustmentToBase * -1 ).asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
			else
				//block.addNewItem("+ " &amp; self.adjustmentToBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true), DC_Data, 1, self);
				block.addNewItem("+ " &amp; self.adjustmentToBase.asStringJMTWithPrecision(dpl, true), DC_Data, 1, self);	// TFS 36954 MPD 20 Feb 2018
			endif;
		
		endif;
	endif;

epilog

	delete startTsArray;
	delete endTsArray;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtorNode" id="33433a05-e3b3-4cf1-8777-b84de2a7794e">
        <source>getMyDebtorNode() : CM_DebtorNode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	rate : CM_Rate;

begin

	rate := self.rate;
	if rate = null then
		return null;
	endif;
	
	return rate.getMyDebtorNode;
	
epilog

end;</source>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="getObjectRateForObject" id="df1c7bc0-5b24-4be1-bad3-221374623309">
        <source>getObjectRateForObject( _obj : CM_Object ):CM_ObjectRate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS	39338 

*/

vars

	subTerminal : CM_SubTerminal;
	subTerminalRate : CM_SubTerminalRate;
	tidalClass : HMS_TidalClass;
	tidalClassRate : CM_TidalClassRate;

begin

	if _obj = null then
		return null;
	endif;
	
	if _obj.isKindOf( CM_SubTerminal ) then
		subTerminal := _obj.CM_SubTerminal;
		subTerminalRate := self.allRatesBySubTerminal.getAtKey( subTerminal );
		return subTerminalRate;
		
	elseif _obj.isKindOf( HMS_TidalClass ) then
		tidalClass := _obj.HMS_TidalClass;
		tidalClassRate := self.allRatesByTidalClass.getAtKey( tidalClass );
		return tidalClassRate;
		
	else
		return null;
		
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="CM_ObjectRate"/>
    </JadeMethod>
