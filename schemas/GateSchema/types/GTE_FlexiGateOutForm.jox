    <JadeMethod name="showPickerForReceivalByTypes" id="f45b8725-6b91-4c84-a88f-cd319fac9254">
        <source>showPickerForReceivalByTypes(_wle : CM_WorkListEntry) : CMGTE_ReceivalByType protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwjk3	ccms 1071
15 Mar 2017	NDL	TFS 3758 - Make use EntTables

*/

vars
	gteReceivalByType	: CMGTE_ReceivalByType;
	gteReceivalInfo		: CM_GTEReceivalInfo;
	receivalRequestInfo	: CM_ReceivalRequestInfo;
	recRequest			: CM_ReceivalRequest; 
	pickWin				: CMUI_Picker;
	allObjects 			: CM_ObjectArrayActual;
begin
	
	if _wle = null then 
		return null;
	endif;
	
	if not _wle.myRequest.isKindOf(CM_ReceivalRequest) then 
		return null;
	endif;

	recRequest := _wle.myRequest.CM_ReceivalRequest;
	if recRequest.allReceivalInfo.size = 1 then
		return recRequest.allReceivalInfo.first().CM_ReceivalRequestInfo.myGTEReceivalInfo.myGTEReceivalByType;
	endif;
	
	create pickWin transient;
	create allObjects transient;
	
	foreach receivalRequestInfo in recRequest.allReceivalInfo do
		gteReceivalInfo := receivalRequestInfo.myGTEReceivalInfo;
		gteReceivalByType := gteReceivalInfo.myGTEReceivalByType;
		allObjects.add(gteReceivalByType);
	endforeach;
	
	pickWin.setListTableUsingEntTable( allObjects, ETDef_ReceivalByType, 600, true );

	if pickWin.showModal() = MsgBox_Return_OK then
		return pickWin.selectedObject.CMGTE_ReceivalByType;
	endif;
		
	return null;
epilog

	delete allObjects;
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="CMGTE_ReceivalByType"/>
    </JadeMethod>
