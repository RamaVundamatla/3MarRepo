			elseif transCount = 2 then
				self.assertEqualMsg(invCount, 3, "Cargo 2 second storage invoice lines");
			elseif transCount = 3 then
				self.assertEqualMsg(invCount, 2, "Cargo 2 third storage invoice lines");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 3, "Cargo 2 storage transactions");
end;
</source>
