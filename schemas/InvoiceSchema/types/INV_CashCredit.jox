    <JadeMethod name="addRowCargo" id="0be273f4-9e7a-41d3-a01e-7c9246041ba9">
        <source>addRowCargo(_trackedItem : CM_TrackedItem ;_enableChk : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
*/

vars
	table : CM_DataTable;
	row   : Integer;
begin
	table                             := self.tblCharges;
	row                               := table.rows + 1;
	table.rows                        := row;
	table.accessCell(row, 2).text     := _trackedItem.id;
	table.accessCell(row, 2).fontBold := true;
	table.accessCell(row, 3).text     := _trackedItem.cargoTypeDescr;
	
	if _enableChk then
		table.accessRow(row).backColor    := LightYellow;
	else
		table.accessRow(row).backColor    := LightYellow;
	endif;
	
	table.accessRow(row).itemObject   := _trackedItem;                
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_enableChk" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRowPayment" id="27654a69-5094-416a-89da-960d98faebe1">
        <source>addRowPayment(_cashPayment : CM_CashPayment ; _row : Integer; _enableCheck : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly

*/

vars
	valueOnPayment,
	valueOnPaymentTax,
	creditOnPayment,
	creditOnPaymentTax	: Decimal[23,6];
	table			 	: CM_DataTable;
	type,
	creditNumber,
	narration   	 	: String;
	invLine     	 	: CM_InvoiceLine;
	proformaDetail   	: CM_ProformaDetails;
	cashPaymentTax   	: CM_CashPayment;
begin
	table := self.tblCharges;
	
	valueOnPayment 	   := _cashPayment.cashValue;
	creditOnPayment    := _cashPayment.getCreditedAmount();
	
	if _cashPayment.hasTax then
		cashPaymentTax 	   := _cashPayment.myCashPaymentForTax;
		valueOnPaymentTax  := cashPaymentTax.cashValue;
		creditOnPaymentTax := cashPaymentTax.getCreditedAmount();
	endif;
	
	if _cashPayment.myInvoiceLine &lt;&gt; null then
		
		invLine    	   := _cashPayment.myInvoiceLine;
		narration  	   := invLine.invoiceLineDesc.narration;
		type      	   := "Invoiced";
	elseif _cashPayment.myProformaDetail &lt;&gt; null then
		proformaDetail := _cashPayment.myProformaDetail;
		narration      := proformaDetail.remarks;
		type           := "Estimated";
	endif;
	
	table.accessRow(_row).itemObject    := _cashPayment;

	if creditOnPayment &lt;&gt; 0 then
	
		narration := narration &amp; " [" &amp; app.getErrorString(Credit) &amp; ' ' &amp; 
					(creditOnPayment + creditOnPaymentTax).asStringJMTWithPrecision(2,true) &amp;  "]";
	endif;
		
	
	table.accessCell(_row, 4).text      := ( valueOnPayment + creditOnPayment).roundedTo(2).String;
	table.accessCell(_row, 5).text      :=  ( valueOnPaymentTax+creditOnPaymentTax).roundedTo(2).String;
	table.accessCell(_row, 6).text      := (( valueOnPayment + valueOnPaymentTax) +(creditOnPayment + creditOnPaymentTax)).roundedTo(2).String;
	if _enableCheck then
		table.accessCell(_row, 1).inputType := Table.InputType_CheckBox;
	else
		creditNumber                        :=  _cashPayment.getCreditNumber();
		if creditNumber &lt;&gt; null then
			creditNumber := "[" &amp; creditNumber &amp;"]";
		endif;
	endif;
	
	if creditNumber &lt;&gt; null then
		if type = "Invoiced" then
			type := type &amp; Space &amp;  Space &amp; Space &amp; Space&amp; Space&amp; creditNumber;
		elseif type = "Estimated" then
			type := type &amp;  Space &amp;  Space &amp; Space &amp; creditNumber;
		endif;
		
	endif;
	table.accessCell(_row, 1).text 	    := "";
	table.accessCell(_row, 2).text      := type;
	table.accessCell(_row, 3).text      := narration;

	
	
epilog

end;</source>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_enableCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRowPaymentCreditTotal" id="bb68076a-ba90-479e-994f-dfedd87353f6">
        <source>addRowPaymentCreditTotal(_total : Decimal ;_enableCheck : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	table : CM_DataTable;
	row : Integer;
begin
	table 						       := self.tblCharges;
	row								   := table.rows + 1;
	table.rows 						   := row;
	if _enableCheck then
		table.accessCell(row, 3).text	   := "Credit Total";
	else
		table.accessCell(row, 3).text	   := "Previous Credit Total";
	endif;
	table.accessCell(row, 3).fontBold  := true;
	table.accessCell(row, 6).fontBold  := true;
	table.accessCell(row, 6).enabled   := false;
	
	self.setTableCreditTotal(_enableCheck);
epilog

end;</source>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="_enableCheck" type="Boolean"/>
    </JadeMethod>
