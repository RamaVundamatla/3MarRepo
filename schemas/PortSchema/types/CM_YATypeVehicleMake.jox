<Class name="CM_YATypeVehicleMake" id="6d2f6cb6-1eb9-4ad1-9831-33356a67b8b4">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="783995f1-154d-49fb-9f64-ac0ddf49fef9">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	app.myDutyDocRoot.allVehicleMakes.copy(_allCriteriaValues);
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="8f48bf1e-eaa5-46bb-b44e-96ba83b03cb0">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	if _ti.isCar then
		_criteriaObject := app.myDutyDocRoot.allVehicleMakes[_ti.CM_Car.make];
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="eec10420-f455-49b6-ae2b-5bcbf5754441">
