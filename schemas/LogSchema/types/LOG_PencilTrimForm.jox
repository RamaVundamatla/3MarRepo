    <JadeMethod name="addToolbarControls" id="ffb073e5-437a-4de4-a3ae-7a3df6fd7b4d">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbGrade_gotFocus" id="4d8cfd22-9998-4b8a-ac13-ba27dc9271b9">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGrade_gotFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.origValueStr := combobox.text;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbGrade_lostFocus" id="b05eef89-4d25-412c-8d82-afa6cb4b5c58">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGrade_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	assistant 	: LOG_Assistant;
	logGrade	: CM_LogGrade;
begin

	self.tblNewSpecs.setValueByControlName(combobox.name, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		assistant := self.myAssistant.LOG_Assistant;
		logGrade := combobox.listObject.CM_LogGrade;
//		assistant.setLogType(self.tblNewSpecs, self.cmbType, logGrade, null);
//		assistant.setLogTreatment(self.tblNewSpecs, self.cmbTreatment, logGrade, null);	
//		assistant.setLogLength(self.tblNewSpecs, self.cmbLength, logGrade, null);
		self.cmbType.setObjectAndGrade(null, logGrade);
		self.tblNewSpecs.setValueByControlName(self.cmbType.name, null);
		self.cmbTreatment.setObjectAndGrade(null, logGrade);
		self.tblNewSpecs.setValueByControlName(self.cmbTreatment.name, null);
		self.cmbLength.setObjectAndGrade(null, logGrade);
		self.tblNewSpecs.setValueByControlName(self.cmbLength.name, null);
	endif;	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
