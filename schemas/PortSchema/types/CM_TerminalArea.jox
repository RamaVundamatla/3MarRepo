    <JadeMethod name="terminalAreaExceptionHandler" id="96fd6e03-555c-49c8-b866-9456fdee5266">
        <source>terminalAreaExceptionHandler(exObj : CM_Exception) : Integer;

vars
	errStr : String;

begin

	errStr := 'Error (' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.extendedErrorText;
	app.msgBox(errStr, 'Error', MsgBox_OK_Only);
	return Ex_Pass_Back;

end;</source>
