    <JadeMethod name="translateForm" id="11750c14-fda6-494f-a0a0-fc0008eead50">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019110, locale);
	btnAdvanced.translateCaption(Xlat_0016157, locale);
	btnCancel.translateCaption(Xlat_0016158, locale);
	btnSave.translateCaption(Xlat_0016159, locale);
	btnSelector.translateCaption(Xlat_0016160, locale);
	lblAssignCargo.translateCaption(Xlat_0016161, locale);
	lblNewQuantity.translateCaption(Xlat_0019111, locale);
	lblSrcLocn.translateCaption(Xlat_0016170, locale);
end;</source>
    </JadeMethod>
</GUIClass>
