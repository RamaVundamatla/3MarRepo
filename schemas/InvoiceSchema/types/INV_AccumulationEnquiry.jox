    <JadeMethod name="setFilters" id="92085ad7-ba40-4fc1-834b-6dbc60865d2a">
        <updating/>
        <source>setFilters()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	
begin
	self.filterQueryContract := self.txtContractId.text.trimBlanks().toUpper();
	self.filterQueryContractFromStart.setDate(self.mskContractFromStart.getDate());
	self.filterQueryContractFromEnd.setDate(self.mskContractFromEnd.getDate());
	self.filterQueryContractFromStart.setTime(self.mskContractFromStartTime.getTime());
	self.filterQueryContractFromEnd.setTime(self.mskContractFromEndTime.getTime());
	self.filterQueryVoyage	:= self.cmbVoyage.listObject.CM_Voyage;
	self.filterQueryDebtor := self.cmbDebtor.listObject.CM_Debtor;
	self.filterQueryVessel := self.cmbVessel.listObject.CM_Vessel;
epilog

end;</source>
