        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblCashDrs_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation

*/

vars
	selected	: Boolean;
	string : String;
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	string :=  self.myAssistant.displayEntryDebtor(obj.CM_Debtor);
	
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; string;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; string;
	endif;
	
end;</source>
