    <JadeMethod name="setColourSorted" id="d94b63ea-71ec-4f1e-9dca-3f63274bdfc7">
        <updating/>
        <source>setColourSorted(_colour : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/12/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285 
// 04/02/2014	cnwah9		par 33402
//
vars
	colours			: StringArray;
	sortedColour	: CM_VehicleColour;
	sortedColours	: CM_VehicleColourByColour;
	col				: String;

begin
	//cnwah9 03/02/2014 par 33402
	if self.myTerminal &lt;&gt; null then
		if not self.myTerminal.getConfig(ValidateColour).Boolean then
			self.colour := _colour;
			
		else
			create colours transient;
			create sortedColours transient;
			_colour.getTokensForDelimiter(Space, colours);
			foreach col in colours do
				sortedColour := app.myDutyDocRoot.allVehicleColours[col];
				if sortedColour = null then
					app.raiseCMException1(ERR_INVALID_COLOURCODE, col, "colour", null);
				else
					sortedColours.addNoDuplicates(sortedColour, false);
				endif;
			endforeach;
			
			// now get colours in alphabetical order and build self.colour from them
			col := null;
			foreach sortedColour in sortedColours do
				if col &lt;&gt; null then
					col := col &amp; Space;
				endif;
				col := col &amp; sortedColour.colour;
			endforeach;
			self.colour := col;
		endif;
	endif;

epilog
	delete colours;
	delete sortedColours;
end;</source>
        <Parameter name="_colour" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDiameter" id="aa196028-b307-45eb-a5aa-23c82f45ad41">
        <updating/>
        <source>setDiameter(_diameter : Decimal) updating;
/* --------------------------------------------
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.diameter := _diameter; // ### TFS 54021 29June2022 NAVPW1 - Using virtual property
