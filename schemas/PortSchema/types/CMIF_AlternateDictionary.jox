        <source>getCarrierByDesc( _carrierDesc : String ) : CM_Carrier updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgndl1	Initial creation	TFS 44194

*/

vars

	carrier : CM_Carrier;

begin

	if _carrierDesc = null then
		return null;
	endif;

	if self.carrierDictNeedsRefresh or self.allCarriersByDescription.isEmpty then
		self.populateCarriers();	
	endif;

	carrier := self.allCarriersByDescription.getAtKey( _carrierDesc ).CM_Carrier;
	
	return carrier;

epilog

end;</source>
        <Parameter name="_carrierDesc" type="String"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
