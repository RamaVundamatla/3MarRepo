<GUIClass name="CMUI_BGPErrorForm" id="a5f820c9-17d5-4f6a-a12b-68b7392607f6">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkError" id="8af5207b-ffca-420e-ada6-a59f1a4ebeb6">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblError" id="89380fae-0f7d-45b3-934d-2064b480b75a">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="translateForm" id="57a86268-10d9-439a-bf6b-4f5b73a3bcb3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007281, locale);
	chkError.translateCaption(Xlat_0000081, locale);
	lblError.translateCaption(Xlat_0000082, locale);
end;</source>
    </JadeMethod>
</GUIClass>
