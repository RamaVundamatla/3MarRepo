    <JadeMethod name="doSave" id="ab099b38-e0da-457b-b911-b2599886eab5">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	theForm : SOP_TableMaintForm;	
	proxy : CM_VoyageJobTransferType;
	description			: String;
	id 	: Integer;
	code : String;
begin

	theForm := self.myForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VoyageJobTransferType transient;
			proxy := theForm.myProxyObject.CM_VoyageJobTransferType;
			theForm.tblInput1.setValueByName( ETRow_Id, theForm.myProxyObject.CM_VoyageJobTransferType.getNextId.String );
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	else
		proxy := theForm.myProxyObject.CM_VoyageJobTransferType;
	endif;

	
	id := theForm.tblInput1.getValueByName(ETRow_Id).Integer;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;
	code 		:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	proxy.setProxy(id,description,code);
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateVoyJobTfrType( proxy, theForm.myCurrentObject, app.myPassport );
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVoyJobTfrType( proxy, app.myPassport );
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
