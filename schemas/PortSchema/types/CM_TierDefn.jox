    <JadeMethod name="cloneMySelf" id="fbea47e8-dc3a-4a16-885a-38bb8153d817">
        <source>cloneMySelf() : SelfType;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	selfCopy:SelfType;
begin
	selfCopy := self.cloneSelf(false);
	return selfCopy;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getFirstLastSlotDefn" id="e7b84663-cec3-45a2-a73a-4d79fb6c6e68">
        <source>getFirstLastSlotDefn(_first : Boolean; _avail : Boolean) : CM_SlotDefn;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpSD : CM_SlotDefn;
begin
	if _first then
		foreach tmpSD in self.allSlotDefinitions discreteLock do
			if _avail then
				if not tmpSD.unavailable then
					return tmpSD;
				endif;
			else
				return tmpSD;
			endif;
		endforeach;
	else
		foreach tmpSD in self.allSlotDefinitions reversed, discreteLock do
			if _avail then
				if not tmpSD.unavailable then
					return tmpSD;
				endif;
			else
				return tmpSD;
			endif;
		endforeach;
	
	endif;
epilog

end;</source>
        <Parameter name="_first" type="Boolean"/>
        <Parameter name="_avail" type="Boolean"/>
        <ReturnType type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="getFirstSlotController" id="b97d2f87-f57e-46b4-8f1f-66cc668b08e3">
        <source>getFirstSlotController() : CM_SlotController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2013	cnwmc5	Initial creation	PAR 32879

*/

vars
	slotDefn : CM_SlotDefn;
begin
	foreach slotDefn in self.allSlotDefinitions do
		if slotDefn.isKindOf(CM_SlotDefnVoyage) then
			return slotDefn.CM_SlotDefnVoyage.mySlotController;
		endif;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getFirstVisibleSlotController" id="77d88db5-8ed2-4aed-8d70-4d61b136034c">
        <source>getFirstVisibleSlotController() : CM_SlotController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2013	cnwmc5	Initial creation	PAR 32879

*/

vars
	slotDefn : CM_SlotDefn;
begin
	foreach slotDefn in self.allSlotDefinitions do
		if slotDefn.isKindOf(CM_SlotDefnVoyage) and not slotDefn.unavailable then
			return slotDefn.CM_SlotDefnVoyage.mySlotController;
		endif;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getSlotControllers" id="b1d6cd02-0d5d-4ed4-a22f-eb9d326247b6">
        <source>getSlotControllers(_slotControllers : ObjectSet input);
/*

Date		Who		Reason
07 January 2016	cnwer1	Initial creation PAR 37142

*/

vars
	slotDefn : CM_SlotDefn;
	slotDefnVoyage : CM_SlotDefnVoyage;
begin
	
	if self.myBay = null or not self.myBay.isKindOf(CM_BayVoyage) then
		return;
	endif;
	
	foreach slotDefn in self.allSlotDefinitions do
		slotDefnVoyage:=slotDefn.CM_SlotDefnVoyage;
		_slotControllers.add(slotDefnVoyage.mySlotController);
	endforeach;
epilog

end;</source>
        <Parameter name="_slotControllers" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfile" id="81de2e53-9b40-4edd-8dd6-3cf9f83ab183">
        <updating/>
        <source>getXMLGridSideProfile(_row,_col : Integer) : String updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	xml,tml, selfLabel : String;
	totalLoadCC,totalDischCC : Integer;
	totalLoadPLN,totalDischPLN : Integer;
	theCL, theCD ,theCLP, theCDP : Integer;
	aBay : CM_Bay;
	aSlot : CM_SlotDefn;
	onDeck : Boolean;
	odString : String;
	theTI : CM_TrackedItem;
	theSlotController : CM_SlotController;
	codesDPort,codesLPort,codesCommodity, codesConsignee, codesISOType, codesOperator : StringArray;
	coloursDPort, coloursLPort, coloursCommodity, coloursConsignee, coloursISOType, coloursOperator : IntegerArray;
	dPort : CM_Port;
	idx,maxIdx,maxCode,arraySize : Integer;
	
	theCode : String;
	theColour : Integer;
begin
	create codesDPort transient;	
	create coloursDPort transient;
	onDeck := self.myBayOD &lt;&gt; null;
	if onDeck then
		odString := "Y";
	else
		odString := "N";
	endif;
	aBay := self.myBay;
	selfLabel := self.id.trimBlanks;
	xml := xml &amp; "&lt;GP&gt;&lt;Row&gt;" &amp; _row.String &amp; "&lt;/Row&gt;&lt;Col&gt;" &amp; _col.String &amp; "&lt;/Col&gt;&lt;BY&gt;" &amp; 
				getOidStringForObject(aBay) &amp; "&lt;/BY&gt;&lt;LB&gt;" &amp; selfLabel &amp; "&lt;/LB&gt;&lt;OD&gt;" &amp; odString &amp; "&lt;/OD&gt;&lt;TD&gt;" &amp; 
				getOidStringForObject(self) &amp; "&lt;/TD&gt;";
	totalLoadCC := 0; // Colour Coding LOAD
	totalDischCC := 0; // Colour Coding Discharge
	foreach aSlot in self.allSlotDefinitions do
		if not aSlot.isKindOf(CM_SlotDefnVoyage) then
			continue;
		endif;
		theSlotController := aSlot.CM_SlotDefnVoyage.mySlotController;
		tml := null;
		if theSlotController &lt;&gt; null then
			theSlotController.getGridProfileXMLTotals(theCL, theCD,theCLP, theCDP);
			totalLoadCC := totalLoadCC + theCL;
			totalDischCC := totalDischCC + theCD;
			totalLoadPLN := totalLoadPLN + theCLP;
			totalDischPLN := totalDischPLN + theCDP;
			
// PAR 36816			if not theSlotController.allTrackedItems.isEmpty then
//	PAR 36816			theTI := theSlotController.allTrackedItems[1];
			tml := null;
			theTI := theSlotController.allTrackedItems.first;  // PAR 36816 - .first handles a null
			if theTI &lt;&gt; null then
				self.getXMLGridSideProfileCodeCol(codesDPort,coloursDPort,theTI.dischargePort);
			endif;
// PAR 36816			endif;
		endif;
		xml := xml &amp; tml;
	endforeach;
	
	xml := xml &amp; "&lt;ColCodes&gt;";

	self.getXMLGridSideProfileMax(TI_ColourMode_DischargePort,codesDPort,coloursDPort,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_DischargePort.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";

	xml := xml &amp; "&lt;/ColCodes&gt;";
	
	if onDeck then
		xml := xml &amp; "&lt;ODL&gt;" &amp; totalLoadCC.String &amp; "&lt;/ODL&gt;&lt;ODD&gt;" &amp; totalDischCC.String &amp;  "&lt;/ODD&gt;&lt;UDD&gt;0&lt;/UDD&gt;&lt;UDL&gt;0&lt;/UDL&gt;";
		xml := xml &amp; "&lt;ODLP&gt;" &amp; totalLoadPLN.String &amp; "&lt;/ODLP&gt;&lt;ODDP&gt;" &amp; totalDischPLN.String &amp;  "&lt;/ODDP&gt;&lt;UDDP&gt;0&lt;/UDDP&gt;&lt;UDLP&gt;0&lt;/UDLP&gt;";
	else
		xml := xml &amp; "&lt;UDL&gt;" &amp; totalLoadCC.String &amp; "&lt;/UDL&gt;&lt;UDD&gt;" &amp; totalDischCC.String &amp;  "&lt;/UDD&gt;&lt;ODD&gt;0&lt;/ODD&gt;&lt;ODL&gt;0&lt;/ODL&gt;";
		xml := xml &amp; "&lt;UDLP&gt;" &amp; totalLoadPLN.String &amp; "&lt;/UDLP&gt;&lt;UDDP&gt;" &amp; totalDischPLN.String &amp;  "&lt;/UDDP&gt;&lt;ODDP&gt;0&lt;/ODDP&gt;&lt;ODLP&gt;0&lt;/ODLP&gt;";
	endif;
	xml := xml &amp; "&lt;/GP&gt;";

	return xml;
epilog
	delete coloursDPort;	delete codesDPort;

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfileCodeCol" id="07b3cd1a-ea75-4382-a779-f1a8d70e11a9">
        <updating/>
        <source>getXMLGridSideProfileCodeCol(_codes : StringArray input;_colours : IntegerArray input;_code : String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	if _code = null then
		return;
	endif;
	idx := _codes.indexOf(_code);
	if  idx = 0 then
		_codes.add(_code);
		_colours.add(1); // TI_ColourMode_DischargePort
	else
		_colours[idx] := _colours[idx] + 1;
	endif;

end;</source>
        <Parameter name="_codes" type="StringArray" usage="input"/>
        <Parameter name="_colours" type="IntegerArray" usage="input"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfileMax" id="348d30e7-461e-497a-aa77-984bb2688fc1">
        <source>getXMLGridSideProfileMax(_index : Integer ;dPortCodes : StringArray; dPortColours  : IntegerArray;_code : String output; _colour : Integer output);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars
	maxIdx		: Integer;
	maxCode		: Integer;
	idx			: Integer;
	arraySize	: Integer;
	dPort		: CM_Port;
	dCommGroup	: CM_CommodityGroup;
	dConsignee	: CM_ConsigneeConsignor;
	dISOType	: CM_ISOTypeGroup;
	dOperator	: CM_Operator;
	dshippingLine: CM_ShippingLine; //53204
	
begin
	arraySize := dPortCodes.size;
	maxCode := 0;
	
	
	foreach idx in 1 to arraySize do
		if dPortColours[idx] &gt; maxCode then
			maxCode := dPortColours[idx];
			maxIdx := idx;
		endif;
	endforeach;
	if maxIdx &lt;&gt; 0 then
		_code := dPortCodes[maxIdx];
		
		if _index = TI_ColourMode_DischargePort then
			//dPort := app.myRoot.allPorts[_code];
			dPort := app.myRoot.allPorts[_code];
			if dPort &lt;&gt; null then
				_colour := dPort.colour;
			else
				_code := null;
			endif;
		elseif _index = TI_ColourMode_LoadPort then
			//dPort := app.myRoot.allPorts[_code];
			dPort := app.myRoot.allPorts[_code];
			if dPort &lt;&gt; null then
				_colour := dPort.colour;
			else
				_code := null;
			endif;
		elseif _index = TI_ColourMode_CommodityGroup then
			dCommGroup := app.myRoot.allCommodityGroups[_code];
			if dCommGroup &lt;&gt; null then
				_colour := dCommGroup.colour;
			else
				_code := null;
			endif;
		elseif _index = TI_ColourMode_Consignee then
			dConsignee := app.myRoot.allConsigneeConsignors[_code];
			if dConsignee &lt;&gt; null then
				_colour := dConsignee.colour;
			else
				_code := null;
			endif;
		elseif _index = TI_ColourMode_ISOTypeGroup then
			dISOType := app.myRoot.allISOTypeGroups[_code];
			if dISOType &lt;&gt; null then
				_colour := dISOType.colour;
			else
				_code := null;
			endif;
		elseif _index = TI_ColourMode_Operator then
			dOperator := app.myRoot.allOperators[_code];
			if dOperator &lt;&gt; null then
				_colour := dOperator.colour;
			else
				_code := null;
			endif;
			
		//Start 07-06-2022 navtnr20 53204
		elseif _index = TI_ColourMode_ShippingLine then
			dshippingLine := app.myRoot.allShippingLines[_code];
			if dshippingLine &lt;&gt; null then
				_colour := dshippingLine.colour;
			else
				_code := null;
			endif;

		//End	07-06-2022 navtnr20 53204
			
		endif;
	endif;

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="dPortCodes" type="StringArray"/>
        <Parameter name="dPortColours" type="IntegerArray"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_colour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfileOLD" id="22f9524e-0fcb-40cf-b40d-e9790fa036b0">
        <updating/>
        <source>getXMLGridSideProfileOLD(_row,_col : Integer) : String updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//07-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars
	xml					: String;
	tml					: String;
	selfLabel			: String;
	totalLoadCC			: Integer;
	totalDischCC		: Integer;
	totalLoadPLN		: Integer;
	totalDischPLN		: Integer;
	theCL				: Integer;
	theCD				: Integer;
	theCLP				: Integer;
	theCDP				: Integer;
	aBay				: CM_Bay;
	aSlot				: CM_SlotDefn;
	onDeck				: Boolean;
	odString			: String;
	theTI				: CM_TrackedItem;
	theSlotController	: CM_SlotController;
	codesDPort			: StringArray;
	codesLPort			: StringArray;
	codesCommodity		: StringArray;
	codesConsignee		: StringArray;
	codesISOType		: StringArray;
	codesOperator		: StringArray;
	codesProduct		: StringArray;
	coloursDPort		: IntegerArray;
	coloursLPort		: IntegerArray;
	coloursCommodity	: IntegerArray;
	coloursConsignee	: IntegerArray;
	coloursISOType		: IntegerArray;
	coloursOperator		: IntegerArray;
	coloursProduct		: IntegerArray;
	coloursShippingLine : IntegerArray;//53204
	codesShippingLine  	: StringArray;	//53204
//	dPort				: CM_Port;
//	idx					: Integer;
//	maxIdx				: Integer;
//	maxCode				: Integer;
//	arraySize			: Integer;
	theCode				: String;
	theColour			: Integer;
	
begin
	create codesDPort transient;
	create coloursDPort transient;
	create codesLPort transient;
	create coloursLPort transient;
	create codesCommodity transient;
	create coloursCommodity transient;
	create codesConsignee transient;
	create coloursConsignee transient;
	create codesISOType transient;
	create coloursISOType transient;
	create codesOperator transient;
	create coloursOperator transient;
	create codesProduct transient;
	create coloursProduct transient;
	create coloursShippingLine transient; //53204
	create codesShippingLine transient; //53204
	
	onDeck := self.myBayOD &lt;&gt; null;
	
	if onDeck then
		odString := "Y";
	else
		odString := "N";
	endif;
	
	aBay			:=	self.myBay;
	selfLabel		:=	self.id.trimBlanks;
	xml				:=	xml &amp; "&lt;GP&gt;&lt;Row&gt;" &amp; _row.String &amp; "&lt;/Row&gt;&lt;Col&gt;" &amp; _col.String &amp; "&lt;/Col&gt;&lt;BY&gt;" &amp; 
						getOidStringForObject(aBay) &amp; "&lt;/BY&gt;&lt;LB&gt;" &amp; selfLabel &amp; "&lt;/LB&gt;&lt;OD&gt;" &amp; odString &amp; "&lt;/OD&gt;&lt;TD&gt;" &amp; 
						getOidStringForObject(self) &amp; "&lt;/TD&gt;";
	totalLoadCC		:=	0; // Colour Coding LOAD
	totalDischCC	:=	0; // Colour Coding Discharge
	
	foreach aSlot in self.allSlotDefinitions do
		theSlotController := aSlot.CM_SlotDefnVoyage.mySlotController;
		tml	:=	null;
		
		if theSlotController &lt;&gt; null then
			theSlotController.getGridProfileXMLTotals(theCL, theCD,theCLP, theCDP);
			totalLoadCC		:=	totalLoadCC + theCL;
			totalDischCC	:=	totalDischCC + theCD;
			totalLoadPLN	:=	totalLoadPLN + theCLP;
			totalDischPLN	:=	totalDischPLN + theCDP;
			
			if not theSlotController.allTrackedItems.isEmpty then
				theTI	:=	theSlotController.allTrackedItems[1];
				tml		:=	null;
				
				if theTI &lt;&gt; null then
					self.getXMLGridSideProfileCodeCol(codesDPort,coloursDPort,theTI.dischargePort);
					self.getXMLGridSideProfileCodeCol(codesLPort,coloursLPort,theTI.loadPort);
					self.getXMLGridSideProfileCodeCol(codesCommodity,coloursCommodity,theTI.commodityGroup);
					self.getXMLGridSideProfileCodeCol(codesConsignee,coloursConsignee,theTI.consignee);
					self.getXMLGridSideProfileCodeCol(codesISOType,coloursISOType,theTI.isoTypeGroup);
					self.getXMLGridSideProfileCodeCol(codesOperator,coloursOperator,theTI.operatorCode);
					self.getXMLGridSideProfileCodeCol(codesShippingLine,coloursShippingLine,theTI.getShippingLineCode());	//13/07/2022 navgm20 tfs 53195
					
					
//					if theTI.dischargePort &lt;&gt; null then
//						idx := codesDPort.indexOf(theTI.dischargePort);
//						if  idx = 0 then
//							codesDPort.add(theTI.dischargePort);
//							coloursDPort.add(1); // TI_ColourMode_DischargePort
//						else
//							coloursDPort[idx] := coloursDPort[idx] + 1;
//						endif;
//					endif;
				endif;
			endif;
		endif;
		xml := xml &amp; tml;
	endforeach;
	
	xml := xml &amp; "&lt;ColCodes&gt;";

	self.getXMLGridSideProfileMax(TI_ColourMode_DischargePort,codesDPort,coloursDPort,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_DischargePort.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_LoadPort,codesLPort,coloursLPort,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_LoadPort.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_CommodityGroup,codesCommodity,coloursCommodity,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_CommodityGroup.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_Consignee,codesConsignee,coloursConsignee,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_Consignee.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_ISOTypeGroup,codesISOType,coloursISOType,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_ISOTypeGroup.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_Operator,codesOperator,coloursOperator,theCode,theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_Operator.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	self.getXMLGridSideProfileMax(TI_ColourMode_Product, codesProduct, coloursProduct, theCode, theColour);
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_Product.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";
	
	self.getXMLGridSideProfileMax(TI_ColourMode_ShippingLine,codesShippingLine,coloursShippingLine,theCode,theColour);					//07-06-2022 navtnr20	 53204
	xml := xml &amp; "&lt;IDX&gt;" &amp; TI_ColourMode_ShippingLine.String &amp; "&lt;/IDX&gt;" &amp; "&lt;CDE&gt;" &amp; theCode &amp; "&lt;/CDE&gt;&lt;COL&gt;" &amp; theColour.String &amp; "&lt;/COL&gt;";//07-06-2022 navtnr20  53204

	xml := xml &amp; "&lt;/ColCodes&gt;";
/*
	arraySize := codesDPort.size;
	maxCode := 0;
	foreach idx in 1 to arraySize do
		if coloursDPort[idx] &gt; maxCode then
			maxCode := coloursDPort[idx];
			maxIdx := idx;
		endif;
	endforeach;
	if maxIdx &lt;&gt; 0 then
		dPort := app.myRoot.allPorts[codesDPort[maxIdx]];
		if dPort &lt;&gt; null then
		endif;
	endif;
*/	
	
	if onDeck then
		xml := xml &amp; "&lt;ODL&gt;" &amp; totalLoadCC.String &amp; "&lt;/ODL&gt;&lt;ODD&gt;" &amp; totalDischCC.String &amp;  "&lt;/ODD&gt;&lt;UDD&gt;0&lt;/UDD&gt;&lt;UDL&gt;0&lt;/UDL&gt;";
		xml := xml &amp; "&lt;ODLP&gt;" &amp; totalLoadPLN.String &amp; "&lt;/ODLP&gt;&lt;ODDP&gt;" &amp; totalDischPLN.String &amp;  "&lt;/ODDP&gt;&lt;UDDP&gt;0&lt;/UDDP&gt;&lt;UDLP&gt;0&lt;/UDLP&gt;";
	else
		xml := xml &amp; "&lt;UDL&gt;" &amp; totalLoadCC.String &amp; "&lt;/UDL&gt;&lt;UDD&gt;" &amp; totalDischCC.String &amp;  "&lt;/UDD&gt;&lt;ODD&gt;0&lt;/ODD&gt;&lt;ODL&gt;0&lt;/ODL&gt;";
		xml := xml &amp; "&lt;UDLP&gt;" &amp; totalLoadPLN.String &amp; "&lt;/UDLP&gt;&lt;UDDP&gt;" &amp; totalDischPLN.String &amp;  "&lt;/UDDP&gt;&lt;ODDP&gt;0&lt;/ODDP&gt;&lt;ODLP&gt;0&lt;/ODLP&gt;";
	endif;
	
	xml := xml &amp; "&lt;/GP&gt;";

	return xml;
epilog
	delete coloursDPort;
	delete codesDPort;
	delete codesLPort;
	delete coloursLPort;
	delete codesCommodity;
	delete coloursCommodity;
	delete codesConsignee;
	delete coloursConsignee;
	delete codesISOType;
	delete coloursISOType;
	delete codesOperator;
	delete coloursOperator;
	delete codesProduct;
	delete coloursProduct;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTotallyUnavailable" id="2a6c9f15-bbb9-4bcf-9f49-39bbef4c6e0d">
        <updating/>
        <source>isTotallyUnavailable() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     February 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpSlotDefn	: CM_SlotDefn;
begin
	foreach tmpSlotDefn in self.allSlotDefinitions where (not tmpSlotDefn.unavailable) do
		return false;
	endforeach;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myBay" id="8718d112-8950-4b09-afa6-a2aea2f78a92">
        <methodInvocation>mapping</methodInvocation>
        <source>myBay(set: Boolean; _value: CM_Bay io) mapping;
/*
 ------------------------------------------------------------------------
Created:			15 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	_value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myBayOD &lt;&gt; null then
		_value := self.myBayOD;
	else
		_value := self.myBayUD;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Bay" usage="io"/>
    </JadeMethod>
    <JadeMethod name="overDeck" id="ea3b8f19-a614-48bd-bc4b-5a559014aedd">
        <source>overDeck():Boolean;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	return (self.myBayOD &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8358bb17-079f-427e-89c5-d02863e0a517">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy:SelfType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="aa9c17a8-b26f-4f53-87c2-a8cfda9272fa">
        <updating/>
        <source>setForCreate(_proxy:SelfType;_realBayDefn : CM_Bay input;_onDeck : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin


	_proxy.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxy,_passport);
	
	if _onDeck then
		//PAR 15510
		if _realBayDefn.allTiersOnDeckByLabel[self.id] &lt;&gt; null then
			app.raiseCMException2(DUPLICATE_ID_ERROR, "Tier", "Bay " &amp; _realBayDefn.id &amp; " has aduplicate ondeck Tier ID '" &amp; self.id &amp; "'.", null, _realBayDefn);
			return;
		endif;
		self.myBayOD := _realBayDefn;
	else
		//PAR 15510
		if _realBayDefn.allTiersUnderDeckByLabel[self.id] &lt;&gt; null then
			app.raiseCMException2(DUPLICATE_ID_ERROR, "Tier", "Bay " &amp; _realBayDefn.id &amp; " has aduplicate underdeck Tier ID '" &amp; self.id &amp; "'.", null, _realBayDefn);
			return;
		endif;
		self.myBayUD := _realBayDefn;
	
	endif;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_realBayDefn" type="CM_Bay" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c8a03b33-db00-4186-ab2f-fbde07aa9f19">
        <updating/>
        <source>setForUpdate(_proxy:SelfType; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id := _proxy.id;
	self.alignment := _proxy.alignment;
//	self.myBayDefnOD := _proxy.myBayDefnOD;
//	self.myBayDefnUD := _proxy.myBayDefnUD;
	self.ordinal := _proxy.ordinal;
	
	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxy,_passport);
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHasAvailableSlot" id="2433c6e7-562a-4dba-9596-56b27db46780">
        <updating/>
        <source>setHasAvailableSlot() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSlotDefn	: CM_SlotDefn;
begin
	foreach tmpSlotDefn in self.allSlotDefinitions where (not tmpSlotDefn.unavailable) do
		return true;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyBay" id="d5948c79-cf44-49be-8ba1-8b2daaaaece5">
        <updating/>
        <source>setMyBay(_bay : CM_Bay; _onDeck:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if _onDeck then
		self.myBayUD := null;
		self.myBayOD := _bay;
	else
		self.myBayOD := null;
		self.myBayUD := _bay;
	endif;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4604bc1b-2547-412e-9977-45e2d80b20eb">
        <updating/>
        <source>setProxy(_id:String; _alignment:Real; _ordinal:Integer; _myBayOD, _myBayUD:CM_Bay) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.alignment := _alignment;
	self.id := _id;
	self.ordinal := _ordinal;

	self.myBayOD := _myBayOD;
	self.myBayUD := _myBayUD;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_alignment" type="Real"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_myBayOD" type="CM_Bay"/>
        <Parameter name="_myBayUD" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyOrdinal" id="acaa220f-7ff5-4458-b249-a82145dd39cb">
        <updating/>
        <source>setProxyOrdinal(_ordinal: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 March 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	if _ordinal = self.ordinal then
		return;
	endif;
	
	self.ordinal := _ordinal;

epilog

end;</source>
        <Parameter name="_ordinal" type="Integer"/>
    </JadeMethod>
