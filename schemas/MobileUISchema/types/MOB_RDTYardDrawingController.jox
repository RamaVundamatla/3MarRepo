	endif;
	
	while not finishedCols do	
		
		gridRow := self.myGridArea.allGridRows[col];	
		//self.drawRowsPortrait(x1, gridWidth, gridHeight, gridRow);
		
		
		col := col + 1;
		if self.flipH then
			finishedCols := col &gt; self.leftGridColDraw;
		else
			finishedCols := col &gt; self.rightGridColDraw;
		endif;	
		
		// Move accross
		if self.flipH then
			x1 := x1 - gridWidth;
		else
			x1 := x1 + gridWidth;
		endif;

	endwhile;
	
epilog

end;</source>
