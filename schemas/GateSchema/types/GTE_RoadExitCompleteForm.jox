    <JadeMethod name="tblReceivals_mouseMove" id="0350add0-7f0c-4e0a-8c36-5fbb68b6bd1e">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReceivals_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 July 2007
//
//----------------------------------------------------------------------

vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if button = 1 then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doTblDataDragTrackedItem(table.CM_DataTable);
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
