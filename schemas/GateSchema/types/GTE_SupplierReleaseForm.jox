    <JadeMethod name="initTblInput" id="92330741-6fb8-4433-b55f-445b95bec70f">
        <source>initTblInput(pTable : CM_EntryTable; pDef : String) protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	theTable.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, CM_BaseForm::entTableDefSetupWarning.name);
	
	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	
	theTable.pictureViewMethod := CM_BaseForm::picViewMethod.name;
	theTable.pictureLoadMethod := CM_BaseForm::picLoadMethod.name;
	theTable.pictureExtractMethod := CM_BaseForm::picExtractMethod.name;
	theTable.resetSize();
	theTable.optimiseHeadingColumn();
	
	self.setColorsForEntryTable(theTable);
	//Par 5846 23092003 CNWSH3	
	//Used in doCancel method to check if a change has occured on the CM_EntryTable control
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
			
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="8342d46e-c9c0-498c-92c2-3bbd5350686f">
        <source>loadCombos() protected;

// cnwdvb1 18 October 2002 

vars
	cargoType : CM_CargoType;
begin
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	if (not self.myTerminal.allCargoBOLTypes.includes(cargoType)) then
		cargoType := app.myPassport.getDefaultCargoType();
	endif;	

	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, cargoType);
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoTypeFlt, cargoType);
	if self.cmbCargoType.listObject &lt;&gt; null then
		self.tblInput1.setValueByControlName(self.cmbCargoType.name, self.cmbCargoType.text);
	endif;
//	self.myAssistant.comboBoxOperator(self.cmbOperator, null, null);
//	self.myAssistant.comboBoxOperator(self.cmbOperatorFlt, null, null);
	
//	self.cmbTransfer.addItem(Choice_Yes);
//	self.cmbTransfer.addItem(Choice_No);
	
//	self.cmbAudit.addItem(Choice_Yes);
//	self.cmbAudit.addItem(Choice_No);
	
	self.cmbWhole.addItem(Choice_All);
	self.cmbWhole.addItem(Choice_Vol);
	self.cmbWhole.addItem(Choice_Weight);
	
	
//	self.cmbConsignee.listCollection(app.myRoot.allConsigneeConsignors,true,0);
	self.cmbTerminal.listCollection(app.myRoot.allTerminals, true,0);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForEdit" id="da20dc00-8a5d-49c6-ab96-6ec069557d62">
        <updating/>
        <source>loadDataForEdit(_header : CM_StockOrderHeaderGeneric) protected, updating;

// cnwdvb1 22 October 2002 

vars

	cargoType	: CM_CargoType;
	order		: CM_StockOrderProductLine;
	productLog	: CM_ProductLog;
	tmpLC		: CM_LocationsController;
	tmpLineAlloc		: CM_StockOrderLineAlloc;
begin

	order := _header.allStockOrderLines.first.CM_StockOrderProductLine;
	self.enableRows(false, false);
	cargoType := _header.getCargoType();
	if cargoType &lt;&gt; null then	
		self.tblInput1.setValueByName(ETRow_CargoType, cargoType.description);
		self.cmbCargoType.listObject := cargoType;
	endif;
	
	self.tblInput1.setValueByName(ETRow_OrderNo, _header.orderNo);
	self.tblInput1.setValueByName(ETRow_ReqdQuantity, order.reqdQuantity.Integer.String);
	self.tblInput1.setValueByName(ETRow_MyOperator, _header.myOperator.code);
//	self.cmbOperator.listObject := _header.myOperator;
	self.cmbOperator.setObject(_header.myOperator);
	self.tblInput1.setValueByName(ETRow_Audit, _header.isAudit.Integer);
	self.tblInput1.setValueByName(ETRow_Comments, order.comments);
	
	if self.myCargoType.id = TI_CargoType_Log then
		self.tblInput1.setValueByName(ETRow_Transfer, _header.isTransfer.Integer);
		if _header.myConsignee &lt;&gt; null then
			self.tblInput1.setValueByName(ETRow_MyConsignee, _header.myConsignee.code);
		endif;
//		self.cmbConsignee.listObject := _header.myConsignee;
		self.cmbConsignee.setObject(_header.myConsignee);
		if _header.myTransferTerminal &lt;&gt; null then
			self.tblInput1.setValueByName(ETRow_Terminal, _header.myTransferTerminal.code);
		endif;
		self.cmbTerminal.listObject := _header.myTransferTerminal;
		self.tblInput1.setValueByName(ETRow_WholeRow, self.convertUnitsOfMeasure(order.unitOfMeasure));
		self.cmbWhole.text := self.convertUnitsOfMeasure(order.unitOfMeasure);
		self.loadSpecies();
		productLog := order.myProduct.CM_ProductLog;			
		if productLog.myLogSpecies &lt;&gt; null then
			self.tblInput1.setValueByName(ETRow_LogSpecies, productLog.speciesCode);
//			self.cmbSpecies.listObject := productLog.myLogSpecies;
			self.cmbSpecies.setObject(productLog.myLogSpecies);
			self.loadGrade();
			if productLog.myLogGrade &lt;&gt; null then
				self.tblInput1.setValueByName(ETRow_LogGrade, productLog.gradeCode);
//				self.cmbGrade.listObject := productLog.myLogGrade;
				self.cmbGrade.setObject(productLog.myLogGrade);
				self.loadTypeTreatmentLength();
				if productLog.myLogType &lt;&gt; null then
					self.tblInput1.setValueByName(ETRow_LogType, productLog.typeCode);
//					self.cmbType.listObject := productLog.myLogType;
					self.cmbType.setObject(productLog.myLogType);
				endif;
				if productLog.myLogTreatment &lt;&gt; null then
					self.tblInput1.setValueByName(ETRow_LogTreatment, productLog.treatmentCode);
//					self.cmbTreatment.listObject := productLog.myLogTreatment;
					self.cmbTreatment.setObject(productLog.myLogTreatment);
				endif;
				if productLog.myLogLength &lt;&gt; null then
					self.tblInput1.setValueByName(ETRow_LogLength, productLog.lengthCode);
//					self.cmbLength.listObject := productLog.myLogLength;
					self.cmbLength.setObject(productLog.myLogLength);
				endif;
			endif;
			tmpLineAlloc := order.allStockAllocations.first;
			if tmpLineAlloc &lt;&gt; null then
				self.doLocationsLoad();
				tmpLC := tmpLineAlloc.myLocationsController;
				if tmpLC &lt;&gt; null then
					self.tblInput1.setValueByName(ETRow_Location, tmpLC.displayEntry());
					if (self.cmbLocations.findObject(tmpLC) &lt;= 0) then
						self.cmbLocations.addItemObject(self.myAssistant.displayEntryLocationController(tmpLC), tmpLC);
					endif;
					self.cmbLocations.listObject :=	tmpLC;
				endif;
			endif;
		endif;
	else
		if _header.myConsignee &lt;&gt; null then
			self.tblInput1.setValueByName(ETRow_MyConsignee, _header.myConsignee.code);
		endif;
//		self.cmbConsignee.listObject := _header.myConsignee;
		self.cmbConsignee.setObject(_header.myConsignee);
		self.tblInput1.setValueByName(ETRow_Product, order.myProduct.code);
		self.cmbProduct.listObject := order.myProduct;
	endif;
	self.tblInput1.moveFirst(); 
	self.tblInput1.setFocus();
end;</source>
        <access>protected</access>
        <Parameter name="_header" type="CM_StockOrderHeaderGeneric"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="599f5c5b-8ebc-4a41-80a5-75471f5cc25e">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	rowIdx : Integer;

begin
	inheritMethod();

	if self.myCurrentObject &lt;&gt; null then
		if self.tblData.findObjectInRow(self.myCurrentObject, rowIdx) then
			self.tblData.row := rowIdx;
			self.tblData.refresh();
			if self.myCurrentObject.isKindOf(CM_StockOrderHeader) then
				self.showThumbnailData(self.myCurrentObject.CM_StockOrderHeaderGeneric);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadGrade" id="e2fd44a3-c19b-4c07-845b-0fe2a8675613">
        <source>loadGrade() protected;

vars

	species : CM_LogSpecies;

begin

	species := self.cmbSpecies.myObject.CM_LogSpecies;
	if species &lt;&gt; null then
		clear(CLEAR_GRADE);
//		self.myAssistant.comboBoxGeneral(self.cmbGrade, species.allLogGrades);
		self.cmbGrade.setObjectAndSpecies(null,species);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadProductTypes" id="26db888d-3e4e-455e-87e5-f8768eecc4d6">
        <source>loadProductTypes(_cargoType : CM_CargoType) protected;

// cnwdvb1 22 October 2002 

vars

	proDict : CM_ProductByOpCodeProCodeDict;

begin

	proDict := _cargoType.allProducts;

	if proDict.size &gt; 0 then
		self.cmbProduct.listCollection(proDict, true, 0);
