<GUIClass name="MB_TableNamedCols" id="2e4e1939-fa2c-47fb-9223-4cfbc201b1cb">
    <superclass name="Table"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="addNamedRow" id="8010280a-6dd1-484f-9547-633a2a067897">
        <updating/>
        <source>addNamedRow(_rowName:String; _text:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		20 January 2006 by cnwdad1
//
// Purpose:		Adds a named row to the receiver.
//
// Parameters:	_rowName - The name of the row to add.
//				_text - The text value of the new row.
//
// Returns:		True if the row was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	TheColumn	: Integer = 2;
	
vars
	rowPointer		: Integer;
	rowObj			: JadeTableRow;
	columnObj		: JadeTableColumn;
	tmpHeight		: Integer;
	offsetColor		: Integer;
	
begin
	// Darrell. Now not adding row if it is empty;
	if _text = null then
		return false;
	endif;
	
	rowPointer	:=	self.getNamedRow(_rowName);
	
	if rowPointer = 0 then
		rowPointer	:=	self.addItem(_rowName &amp; Tab &amp; _text);
	else
		self.setCellText(rowPointer, TheColumn, _text);
	endif;
	
	rowObj			:=	self.accessRow(rowPointer);
	columnObj		:=	self.accessColumn(TheColumn);
	columnObj.width	:=	375;

	self.accessCell(rowPointer, TheColumn).wordWrap := true;
	tmpHeight := self.getTextHeightForWidth(_text, self.accessColumn(TheColumn).width - 18).Integer + 10; 	// add fudge factor
	rowObj.height := tmpHeight.max(40);
	
	if rowPointer.isOdd() then
		offsetColor	:=	self.backColor - 150;
		
		if offsetColor &lt; 0 then
			offsetColor	:=	self.backColor + 150;
		endif;
		
		rowObj.backColor	:=	offsetColor;
	endif;
	
	return true;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNamedRow" id="9ed46e89-e054-451b-9f9d-d2891ab6023c">
        <source>getNamedRow(_rowName:String):Integer;
// --------------------------------------------------------------------------------
// Created:		20 January 2006 by cnwdad1
//
// Purpose:		Returns the index of a named row.
//
// Parameters:	_rowName - The name of the row who's index to return.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startRow	: Integer;
	totalRows	: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	totalRows	:=	self.rows;
	
	foreach rowPointer in startRow to totalRows do
		if self.getCellText(rowPointer, 1) = _rowName then
			return rowPointer;
		endif;
	endforeach;
	
	return 0;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNamedRowValue" id="55b86cac-4528-4a0c-98e0-7196b593605a">
        <source>getNamedRowValue(_rowName:String):String;
// --------------------------------------------------------------------------------
// Created:		20 January 2006 by cnwdad1
//
// Purpose:		Returns the text value of a named row.
//
// Parameters:	_rowName - The name of the row who's value to return.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.getNamedRow(_rowName);
	
	if rowPointer = 0 then
		return null;
	else
		return self.getCellText(rowPointer, 2);
	endif;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeNamedRow" id="d1c6cb81-fcba-4d1a-aa2b-955bad239464">
        <source>removeNamedRow(_rowName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		20 January 2006 by cnwdad1
//
// Purpose:		Removes a named row from the receiver.
//
// Parameters:	_rowName - The name of the row to remove.
//
// Returns:		True if the row was successfully removed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.getNamedRow(_rowName);
	
	if rowPointer = 0 then
		return false;
	else
		self.removeItem(rowPointer);
		return true;
	endif;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateNamedRow" id="23451752-1181-4786-a1c3-6e4eafa6db6a">
        <updating/>
        <source>updateNamedRow(_rowName:String; _text:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2006 by cnwdad1
//
// Purpose:		Updates the text value of a named row to the receiver.
//
// Parameters:	_rowName - The name of the row to add.
//				_text - The text value of the new row.
//
// Returns:		True if the row was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.getNamedRow(_rowName);
	
	if rowPointer = 0 then
		return false;
	else
		self.setCellText(rowPointer, 2, _text);
		return true;
	endif;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="0b0f85dc-d6f1-4b38-85b8-a8c92b9f032b">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		20 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	//self.fontSize := 18;

	self.columns		:=	2;
	self.rows			:=	0;
	self.fixed3D		:=	false;
	self.fixedColumns	:=	0;
	self.fixedRows		:=	0;
	self.accessColumn(2).fontBold	:=	true;
	
	//self.fontSize := 18;
	
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
