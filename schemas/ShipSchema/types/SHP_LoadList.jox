vars
begin
	self.frmUserColours.visible := not self.frmUserColours.visible;
	self.frmUserColours.left := 300;
	self.frmUserColours.top := 200;

	self.clrPlanned.setColor(xmlColourPlanned);
	self.clrNonPlanned.setColor(xmlColourNonPlanned);
	self.clrOnShip.setColor(xmlColourOnShip);
	self.frmUserColours.zOrder(1);

end;</source>
