    <JadeMethod name="getVoyagesForVessel" id="d2f3917e-5433-4e37-9bba-eaf5715c141c">
        <updating/>
        <source>getVoyagesForVessel() updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage", "Vessel Query Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.myVesselVoyageController = null then
		create self.myVesselVoyageController;
	endif;
	
	self.myVesselVoyageController.myCallingForm := self;
	self.myVesselVoyageController.myVoyage := self.myCurrentVoyage;
	self.myVesselVoyageController.myVessel := self.myCurrentVoyage.getMyVessel();
	self.myVesselVoyageController.mode := CMIF_GetVoyages.Mode_View4Vessel;
	
	self.myAssistant.SHP_Assistant.showVoyageListForm(self.myVesselVoyageController);

end;</source>
    </JadeMethod>
