    <JadeMethod name="populateTableFromConstants" id="1d0f9f21-11bd-4960-95cd-c2fd68dd2387">
        <updating/>
        <source>populateTableFromConstants() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.currentMode = Mode_Exceptions then
		self.showExceptions();
	elseif self.currentMode = Mode_TEvents then
		self.showTermEvents();
	elseif self.currentMode = Mode_Permissions or
	   self.currentMode = Mode_SpecialPermissions then
		self.showPermissions();
	elseif self.currentMode = Mode_Subscriptions then	//16 June 2010	NDL	TFS 49569
		self.showSubscriptions();
	elseif self.currentMode = Mode_Config then
		self.showConfig();
	endif;
	
	if self.savedRow &gt; 0 and self.savedRow &lt;= tblData.rows then
		tblData.topRow := self.savedTopRow;
		tblData.row := self.savedRow;
		tblData.accessRow(self.savedRow).selected := true;
		self.savedTopRow := 0;
		self.savedRow := 0;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
