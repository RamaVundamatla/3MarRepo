    <JadeMethod name="tblCustEntry_gotFocus" id="69954ac0-e1be-46bd-bd4b-a6cc9fe8c7b5">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCustEntry_gotFocus(table: Table input) updating;

vars
	str : String;
	idx : Integer;
	editTable	: CM_EntryTable;
begin
	editTable := self.getTableForRow(ETRow_CustomsEntryNumber);
	if editTable &lt;&gt; null then
		editTable.cnEcResizeContents();
	endif;
	//+cnwml2 PAR24416
	self.tblCustEntry.clear();
	idx := 1;
	foreach str in self.myProxyObject.CM_TrackedItem.allCustomsEntryNumbers do
		idx := idx + 1;
		self.tblCustEntry.addItemAt(str, idx);
	endforeach;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCustEntry_lostFocus" id="1dff2271-968b-4e14-8c1f-7842fc3bf5ee">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCustEntry_lostFocus(table: Table input) updating;

/*

Date		Who		Reason
????				PAR 16184 changed to use self.doTblEditQueryRowColChg, as this lost focus 
					does not work well with main edit table scroll bar
26 Jun 2008	cnwkpd1	PAR #17183 - rework again to better handle lostFocus in all situations

*/

vars
	parentTable		: CM_EntryTable;
	
begin
	if table.parent &lt;&gt; null and table.parent.isKindOf(CM_EntryTable) then
		parentTable := table.parent.CM_EntryTable;
		self.myAssistant.stringsTableLostFocus(parentTable, self.saveRowHeight, table.CM_Table);

		// PAR 16824 - for bulk edit need to fire this for row changed
		//parentTable.doChangedComparismForControl(table.name);				//-cnwml2 PAR24416
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
