    <JadeMethod name="insertNewColumn" id="e4be55a3-06de-4205-9f05-4660f5dbddc5">
        <updating/>
        <source>insertNewColumn(insertColumn : Integer ; caption : String) updating;

vars

begin
	if insertColumn &gt; columnHeadingArray.size() then
		columnHeadingArray.add(caption);
		columnAlignmentArray.add('0 - Default');
		columnInputTypeArray.add('0 - None');
		columnVisibleArray.add('1 - True');
		columnPictureArray.add(false);
		columnLengthArray.add(0);
		columnWidthArray.add(50);
		buildTableColumns();
	else
		columnHeadingArray.insert(insertColumn, caption);
		columnAlignmentArray.insert(insertColumn, '0 - Default');
		columnInputTypeArray.insert(insertColumn, '0 - None');
		columnVisibleArray.insert(insertColumn, '1 - True');
		columnPictureArray.insert(insertColumn, false);
		columnLengthArray.insert(insertColumn, 0);
		columnWidthArray.insert(insertColumn, 50);
	endif;
end;</source>
        <Parameter name="insertColumn" type="Integer"/>
        <Parameter name="caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="itemSelected" id="929d6e04-825a-430b-b39c-6559ff8bae71">
        <updating/>
        <source>itemSelected(itemRow : Integer) : Boolean updating;

vars
	saveCol				: Integer;
	saveRow				: Integer;
begin
	saveRow	:= self.row;
	saveCol	:= self.column;

	self.row	:= itemRow;
	self.column	:= 1;
	return(selectedObjects.includes(self.itemObject));

epilog
	self.column	:= saveCol;
	self.row	:= saveRow;
end;</source>
        <Parameter name="itemRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="c567859d-f516-496f-a484-3176b2986070">
        <updating/>
        <source>keyDown(table : Table input; keyCode : Integer io; shift : Integer) updating;
// --------------------------------------------------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/11/2001	cnwdad1		Added the calling of the click event so that the table
//							imitates a click when the user presses the arrow keys.
//
// 19/11/2001	cnwdad1		Added the handing of Page Down and Page Up keys to
//							scroll the table and select the new row.
// --------------------------------------------------------------------------------

vars
	saveRow		: Integer;
	
begin
	app.mousePointer	:=	Busy;
	
	inheritMethod(table, keyCode, shift);

	// Set key indicators for enhanced select
	if shift.bitAnd(1) &lt;&gt; 0 then
		shiftDown:=true;
	else
		shiftDown:=false;	
	endif;
	if shift.bitAnd(2) &lt;&gt; 0 then	
		cntlDown:=true;
	else
		cntlDown:=false;	
	endif;
	if shift.bitAnd(4) &lt;&gt; 0 then	
		altDown:=true;
	else
		altDown:=false;	
	endif;

	if not self.disableVirtualScroll then
		saveRow := self.row;
		if keyCode = CNEC_KEY_ARROWUP then
			keyCode := 0;
			if self.row = self.fixedRows + 1 then
				if myVerticalScrollBar.value - 1 &gt;= myVerticalScrollBar.min then
					myVerticalScrollBar.value := myVerticalScrollBar.value - 1;
					self.scrollTable();
				endif;
				if saveRow &lt; self.rows then
					self.row := saveRow + 1;
				else
					self.row := saveRow;
				endif;
			endif;
			if not self.selectedObjects.includes(self.getRowObject()) then
				self.unselectRow();
			endif;
			self.row := self.row - 1;

			self.selectRow();
			self.click(self);		// cnwdad1 19/11/2001.
//			self.refreshNow;		// cnwdad1 19/11/2001
		elseif keyCode = CNEC_KEY_ARROWDOWN then
			keyCode := 0;
			if self.row = self.rows then
				if myVerticalScrollBar.value + 1 &lt;= myVerticalScrollBar.max then
					myVerticalScrollBar.value := myVerticalScrollBar.value + 1;
					self.scrollTable();
				endif;
				self.row := saveRow - 1;
			endif;
			if not self.selectedObjects.includes(self.getRowObject()) then
				self.unselectRow();
			endif;
			if self.row &lt; self.rows then
				self.row := self.row + 1;
			endif;

			self.selectRow();
			self.click(self);		// cnwdad1 19/11/2001.
//			self.refreshNow;		// cnwdad1 19/11/2001
			
		elseif keyCode = CNEC_KEY_PAGEUP then
			// cnwdad1 19/11/2001 - Added handling of Page Up.
			saveRow		:=	self.row;
			keyCode		:=	0;
			self.myVerticalScrollBar.doScrollLarge(1);
			self.row	:=	saveRow;
			self.selectRow();
			self.click(self);
			
		elseif keyCode = CNEC_KEY_PAGEDOWN then
			// cnwdad1 19/11/2001 - Added handling of Page Down.
			saveRow		:=	self.row;
			keyCode		:=	0;
			self.myVerticalScrollBar.doScrollLarge(-1);
			self.row	:=	saveRow;
			self.selectRow();
			self.click(self);
			
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lines" id="e6d14288-e54a-468a-b935-85734b59811a">
        <updating/>
        <source>lines() : Integer updating;

vars

begin
	if disableVirtualScroll then
		if currentSession = null then
		//	make it a normal table with the maximum number of rows
			return(64 * 1024 - 1);
		else
		//	Limit the internet interface to this number or rows,
		//	and use bwd &amp; fwd buttons/labels to page thru table
			return(TABLE_ROWS_ON_WEB);
		endif;
	else
		if currentSession = null then
			if self.dropDown &gt; 0 then
				return((self.expandedHeight / self.rowHeight[1]).Integer - self.scrollsHorizontally().Integer + 1);
			else
				return((self.height / self.rowHeight[1]).Integer - self.scrollsHorizontally().Integer + 1);
			endif;
		else
		//	Limit the internet interface to this number or rows,
		//	and use bwd &amp; fwd buttons/labels to page thru table
			return(TABLE_ROWS_ON_WEB);
		endif;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listCollection" id="4c598a7d-a120-4f0b-94cf-0d3579938f6a">
        <updating/>
        <source>listCollection(c: Collection; update: Boolean; showHow: Integer)updating;
/*
	Purpose:	
	Parameters:	startPoint 	index incollection to start at
				whichEnd 	START_OF_LIST
							END_OF_LIST
	Returns:	nothing	

	Created by cms on 03 November 1997
	Copied by wmb on 12 April 1998
*/
vars

begin
	if showHow = SORT_REVERSED then
		sortOrder := SORT_REVERSED;
	else
		sortOrder := SORT_COLLECTION;
	endif;
	
	self.selectedObject := null;
	self.sortColumn[1] := 0;
	setCollection (c, update);
	self.refreshNow();
end;</source>
        <Parameter name="c" type="Collection"/>
        <Parameter name="update" type="Boolean"/>
        <Parameter name="showHow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadSubset" id="cc5f5028-3c02-431c-9d26-6d4af3ed0b01">
        <updating/>
        <source>loadSubset(whichEnd :Integer)updating, protected;
/*
	Purpose		:	to load rows into the table going forward thru the iterator
	Parameters	:	none
	Returns		:	nothing	
*/
vars
	i					: Integer;
	r					: Integer;
	o					: Object;
	tableRows			: Integer;
	coll				: Collection;
begin
	rowsHaveBeenExcluded := false;
	i := self.currentIteratorPosition;
	tableRows := self.lines();
	selectedRow := 0;

	r := self.rows;
	coll := self.cnEcGetCollection();
 	while self.myIterator.next(o) do
 		if stopLoading(o, coll, true) then
			self.myVerticalScrollBar.max := (self.myVerticalScrollBar.value + i - currentIteratorPosition) - self.myVerticalScrollBar.largeChange;
 			break;
 		endif;
 		i := i + 1;
 		if excludeObject(o) then
 			rowsHaveBeenExcluded := true;
 		else
 			r := r + 1;
	        self.addNewRowAt(o, r);	    	

	        if selectedObjects.includes(o) then
	        	self.row := r;
	        	self.selectRow();
	        endif;
	        if selectedObject = o then
	        	self.row := r;
	        	self.selectRow();
	        	selectedRow := r;
	        endif;

	        if showUpdates then
   	        	beginNotification (o, Object_Update_Event ,Response_Continuous, 
	        						NOTIFY_INSTANCE_UPDATE);
			endif;
	    	if r = tableRows then
	    		break;
	    	endif;
    	endif;
 	endwhile;
	if currentSession = null then
		self.currentIteratorPosition := i;
	else
		if self.myVerticalScrollBar.value &gt; self.myVerticalScrollBar.min then		//	= self.rows then
			webPreviousButton.enabled := true;
			webPreviousButton.scroll := i - self.currentIteratorPosition + 1;	//	self.myVerticalScrollBar.value; // - (self.rows);
		else
			webPreviousButton.enabled := false;
		endif;
		self.currentIteratorPosition := i;
		if self.currentIteratorPosition &lt; currentCollectionSize then
			webNextButton.enabled := true;
			webNextButton.scroll := self.rows - 1;
		else
			webNextButton.enabled := false;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="whichEnd" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadSubsetReversed" id="9aaa0eb5-ee39-4f7c-8d2b-c047c43e331a">
        <updating/>
        <source>loadSubsetReversed(whichEnd :Integer)updating, protected;
/*
	Purpose		:	to load rows into the table going backward thru the iterator
	Parameters	:	none
	Returns		:	nothing	
*/
vars
	i					: Integer;
	r					: Integer;
	o					: Object;
	tableRows			: Integer;
	coll				: Collection;
	rowsBWD				: Integer;
	rowsFWD				: Integer;
begin
	rowsHaveBeenExcluded := false;
	i := self.currentIteratorPosition;
	tableRows := self.lines();
	selectedRow := 0;

	r := self.rows;
	coll := self.cnEcGetCollection();
 	while self.myIterator.back(o) do			// reversed
 		if stopLoading(o, coll, false) then
			self.myVerticalScrollBar.max := (self.myVerticalScrollBar.value + currentIteratorPosition - i) - self.myVerticalScrollBar.largeChange;
			break;
 		endif;
 		i := i - 1;
 		if excludeObject(o) then
 			rowsHaveBeenExcluded := true;
 		else
 			r := r + 1;
	        self.addNewRowAt(o, r);	    	

	        if selectedObjects.includes(o) then
	        	self.row := r;
	        	self.selectRow();
	        endif;
	        if selectedObject = o then
	        	self.row := r;
	        	self.selectRow();
	        	selectedRow := r;
	        endif;

	        if showUpdates then
   	        	beginNotification (o, Object_Update_Event ,Response_Continuous, 
	        						NOTIFY_INSTANCE_UPDATE);
			endif;
	    	if r = tableRows then
	    		break;
	    	endif;
    	endif;
 	endwhile;

	if currentSession = null then
		self.currentIteratorPosition := i;
	else
		if self.myVerticalScrollBar.value.abs &gt; self.myVerticalScrollBar.min then		//	self.rows then
			webPreviousButton.enabled := true;
			webPreviousButton.scroll := i.abs - self.currentIteratorPosition.abs + 1;	//	self.myVerticalScrollBar.value - (self.rows);
		else
			webPreviousButton.enabled := false;
		endif;
		self.currentIteratorPosition := i;
		if self.currentIteratorPosition.abs &lt; currentCollectionSize then
			webNextButton.enabled := true;
			webNextButton.scroll := self.rows - 1;
		else
			webNextButton.enabled := false;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="whichEnd" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="eee65ac9-bff5-4707-9388-a723f8f70649">
        <updating/>
        <source>lostFocus(table : Table input) updating;

vars

begin
	if self.dropDown &gt; 0 then
		if myVerticalScrollBar &lt;&gt; null then
			myVerticalScrollBar.visible := false;
		endif;
	endif;

	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="7f82c3c2-a162-467c-9503-99a0057ea74d">
        <updating/>
        <source>mouseDown(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars
	formX				: Real;
	formY				: Real;
begin
	// Set key indicators for enhanced select
	if shift.bitAnd(1) &lt;&gt; 0 then
		shiftDown:=true;
	else
		shiftDown:=false;	
	endif;
	if shift.bitAnd(2) &lt;&gt; 0 then	
		cntlDown:=true;
	else
		cntlDown:=false;	
	endif;
	if shift.bitAnd(4) &lt;&gt; 0 then	
		altDown:=true;
	else
		altDown:=false;	
	endif;

	clickColumn := 0;
	if self.mousePointer = Control.MousePointer_NS or self.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if app.mousePointer = Control.MousePointer_NS or app.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if button = 1 then
		self.autoRedraw := true;
		self.drawStyle := Window.DrawStyle_Dot;
		mouseIsDown := true;
		mouseDownDrawSize := self.drawSize;
		mouseDownX := x;
		mouseDownY := y;
		if y &lt; self.rowHeight[1] then
			clickColumn := convertPositionToColumn(x);
		endif;
	else
		if y &lt; self.rowHeight[1] then
			self.column := self.convertPositionToColumn(x);
			self.myMenuForm.transientTable := self;
			self.myMenuForm.initialiseMenuItems();
			self.myMenuForm.screenToWindow(formX, formY);
			self.windowToScreen(formX, formY);
			self.myMenuForm.popupMenu(self.myMenuForm.mTablePopup, (formX + x).Integer, (formY + y).Integer);
		endif;
	endif;

	inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="cc4d2127-052d-43bb-95cb-bf37e947ec0f">
        <updating/>
        <source>mouseMove(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars
	formX					: Real;
	formY					: Real;
	halfWidth				: Real;
	halfHeight				: Real;
	arrowX					: Real;
	arrowY					: Real;
begin
	if self.mousePointer = Control.MousePointer_NS or self.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if app.mousePointer = Control.MousePointer_NS or app.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if mouseIsDown then
	    if (x - mouseDownX).abs &gt; 2 then
	    	if clickColumn &lt; 1 or clickColumn &gt; self.columns then
	    		return;
	    	endif;
			halfWidth := (self.columnWidth[clickColumn] / 2);
			halfHeight := (self.rowHeight[1] / 2);
	    	self.drawUndo(mouseDownDrawSize);
//			self.form.controlToForm(self.hwnd, formX, formY);
			formX := formX + x;
			formY := formY + y;
			if (formY - halfHeight) &lt; 0 then
				formY := halfHeight;
			endif;

			if (formX - halfWidth) &lt; 0 then
				if self.leftColumn &gt; 1 then
					self.leftColumn := self.leftColumn - 1;
				endif;
			endif;
			if (formX + halfWidth) &gt; self.width then
				if self.leftColumn &lt; self.columns then
					self.leftColumn := self.leftColumn + 1;
				endif;
			endif;

			if (formY + self.rowHeight[1]) &gt; self.height then
				formY := self.height - self.rowHeight[1];
			endif;
	    	self.drawRectangle(formX - halfWidth,
	    							formY - halfHeight,
	    							formX + halfWidth,
	    							formY + halfHeight,
	    							DarkBlue);
//			arrow down &amp; to the right
			self.drawLine(	formX + (halfWidth / 2), formY + halfHeight,
								formX + (halfWidth / 2), formY + (halfHeight * 1.5),
								DarkBlue);
			arrowX := formX + halfWidth;
			arrowY := formY + (halfHeight * 1.5);
			self.drawLine(	formX + (halfWidth / 2), formY + (halfHeight * 1.5),
								arrowX, arrowY,
								DarkBlue);
//			draw right arrow head
			self.drawLine(	arrowX, arrowY, arrowX - 6, arrowY - 3, DarkBlue);
			self.drawLine(	arrowX - 6, arrowY - 3, arrowX - 4, arrowY, DarkBlue);
			self.drawLine(	arrowX - 4, arrowY, arrowX - 6, arrowY + 3, DarkBlue);
			self.drawLine(	arrowX - 6, arrowY + 3, arrowX, arrowY, DarkBlue);
//			arrow down &amp; to the left
			self.drawLine(	formX - (halfWidth / 2), formY + halfHeight,
								formX - (halfWidth / 2), formY + (halfHeight * 1.5),
								DarkBlue);
			arrowX := formX - halfWidth;
			arrowY := formY + (halfHeight * 1.5);
			self.drawLine(	formX - (halfWidth / 2), formY + (halfHeight * 1.5),
								arrowX, arrowY,
								DarkBlue);
//			draw left arrow head
			self.drawLine(	arrowX, arrowY, arrowX + 6, arrowY - 3, DarkBlue);
			self.drawLine(	arrowX + 6, arrowY - 3, arrowX + 4, arrowY, DarkBlue);
			self.drawLine(	arrowX + 4, arrowY, arrowX + 6, arrowY + 3, DarkBlue);
			self.drawLine(	arrowX + 6, arrowY + 3, arrowX, arrowY, DarkBlue);
	    endif;
	endif;

	inheritMethod(table, button, shift, x, y);
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMoveSaved" id="5f1e2825-116b-478e-a24d-f246632aa37c">
