    <JadeMethod name="refreshRowObjects" id="2736b755-3d91-4e29-ae59-52e5371477f6">
        <updating/>
        <source>refreshRowObjects() updating;
/*

Date		Who		Reason
15 April 2016	cnwer1	Initial creation TFS 1826

*/

vars
	coll				: ObjectSet;
	obj : Object;
	invalidObj : Boolean;
	edition : Integer;
begin


	create coll transient;
	self.getAllRowObjects(coll);
	
	self.clearAllData();
	
	on Exception do app.handleDeletedObject(exception,obj,invalidObj);
	
	foreach obj in coll discreteLock do
		invalidObj:=false;
		edition:=obj.edition;
		if not invalidObj then
			self.addObject(obj.CM_Object);
		endif;
	endforeach;
epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeColumnByEntRowName" id="264e4db9-fade-45bf-9832-cec6df2ca713">
        <updating/>
        <source>removeColumnByEntRowName(_entRowName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

	heading : String;
	column, i  : Integer;
	idx, entIdx,offset, colIdx	: Integer;
	found 	: Boolean;
	entTableRow : EntTableRow;
	cell : JadeTableCell;
begin
	
	entTableRow:=self.myEntTableDef.getEntTableRow(_entRowName);
	if entTableRow = null then
		return;
	endif;
	heading:=entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale).trimBlanks;
	row:= self.fixedRows;
	i:=1;
	foreach column in i to self.columns do
		cell:=self.accessCell(row,column);
		if cell.text = heading then		
			colIdx:=i;
			//self.accessColumn(column).visible := false;
			found:=true;
			break;
		endif;	
		i:=i+1;
	endforeach;
	
	if not found then
		return;
	endif;
	
	self.deleteColumn(colIdx);
	offset:=self.columns - self.allTblDataEntRows.size;
	self.allTblDataColHeadings.removeAt(colIdx);
	self.allTblDataEntRows.removeAt(colIdx);
	self.allTblDataColPropertyNames.removeAt(colIdx);
	self.allTblDataColInputTypes.removeAt(colIdx);

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeDeletedObject" id="27d5116c-4351-4b55-bed4-97f35fd409a4">
        <updating/>
        <source>removeDeletedObject(_obj : Object) : Boolean updating;
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
begin
	
	numRows := self.rows;

	startPos := (self.fixedRows + 1);
	if startPos &gt; numRows then
		return found;
	endif;	 

	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			self.removeItem(idx);
			found := true;
			break;
		endif;
	endforeach;

epilog
	return found;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeInvalidSortColumns" id="cf98e398-271e-439f-846d-9416f2558f15">
        <updating/>
        <source>removeInvalidSortColumns() updating, protected;
//--------------------------------------------------------------
//Created: January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	entRow		: EntTableRow;
	tmpStr		: String;
	numCols,
	idx			: Integer;
	valid		: Boolean;
begin

	// Need to check that the sort columns are still valid for the new columns
	numCols := self.allTblDataSortColumns.size;
	foreach idx in numCols to 1 step -1 do
		tmpStr := self.allTblDataSortColumns[idx];
		valid := false;
		foreach entRow in self.allTblDataEntRows do
			if entRow.name = tmpStr then
				// the sort column is still a valid column
				valid := true;
				break;
			endif;
		endforeach;
		// the sort column is not a valid column so must remove
		if (not valid) then
			self.zRemoveSortColumn(tmpStr);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeItem" id="f1062066-db23-448e-86c0-a82b49eeee2f">
