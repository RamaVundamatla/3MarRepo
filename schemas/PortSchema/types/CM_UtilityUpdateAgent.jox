	exclusiveLock(realYardInternalJob);

	if _passport.noErrors and realYardInternalJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'YardInternalJob', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realYardInternalJob.setForUpdate(pProxyYardInternalJob, _passport.myTerminal);
	endif;

end;</source>
        <Parameter name="pProxyYardInternalJob" type="CM_YardInternalJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardRequestDoorsDir" id="d17e7be1-36cf-4a34-8872-3671de305d5e">
        <source>utlUpdateYardRequestDoorsDir(_yardRequest : CM_YardRequest input;
							_newDoorsForwardValue : Boolean;
							_passport : CM_Passport input
							);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2011	cnwndl1	Initial creation	Par 27582

*/


vars

	wle : CM_WorkListEntry;

begin

	self.initialiseActivity();
	
	if _yardRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _yardRequest.getName, null, null);
		return;
	endif;

	exclusiveLock(_yardRequest);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Yard Job', null, null);
		return;
	endif;
	
	if _yardRequest.doorsForward &lt;&gt; _newDoorsForwardValue then
		app.myAA.auditUpdate(_yardRequest, "doorsForward", _newDoorsForwardValue);
		_yardRequest.setDoorDir( _newDoorsForwardValue );
	endif;

end;</source>
        <Parameter name="_yardRequest" type="CM_YardRequest" usage="input"/>
        <Parameter name="_newDoorsForwardValue" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardRequestQuantity" id="8b92031e-feef-41b8-9908-f9851e4d745e">
        <updating/>
        <source>utlUpdateYardRequestQuantity(_wle : CM_YardWLE input; 
							_quantity : Integer;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
07 October 2013	cnwer1	Initial creation PAR 32509

*/

vars
	rtQEntry : CM_RTQueueEntry;
	yardRequest : CM_YardRequest;
	diff : Integer;
begin
	if _wle = null then
		return;
	endif;
	
	if _wle.status = WLE_COMPLETED then
		return;
	endif;
	
	diff:=_quantity - _wle.quantity;
	
	yardRequest:=_wle.myRequest.CM_YardRequest;
	
	if yardRequest.isKindOf(CM_DeliveryRequest) then

		app.myAA.auditUpdate(yardRequest, CM_DeliveryRequest::totalRequested.name, yardRequest.CM_DeliveryRequest.totalRequested + diff);
		yardRequest.CM_DeliveryRequest.totalRequested:=yardRequest.CM_DeliveryRequest.totalRequested + diff;
		// epr 34880 19/9/14
		if yardRequest.myGateEntity &lt;&gt; null then
			yardRequest.myGateEntity.setTotalQuantity(yardRequest.CM_DeliveryRequest.totalRequested );
		endif;
	endif;
	
	_wle.setQuantity(_quantity);
	rtQEntry:= _wle.allRTQueueEntries.first;
	if rtQEntry = null or (rtQEntry &lt;&gt; null and
		rtQEntry.isBreakBulkGenericMaster) then
		
		if rtQEntry &lt;&gt; null then
			rtQEntry.setQuantity(_quantity);
			app.myEventManager.createSingleObjInfoNoteEvt( rtQEntry,app.myPassport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(_wle,_passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);
	endif;
	
	//epr par 34880 19/9/14
	if yardRequest.isKindOf(CM_TIRequest) then 
		//epr par 37074 19/11/15
		yardRequest.CM_TIRequest.setQuantity(yardRequest.getWLEQuantity());
		if yardRequest.myGateEntity &lt;&gt; null then
			yardRequest.myGateEntity.setTotalQuantity(yardRequest.getWLEQuantity());
		endif;
	endif;	

	
epilog

end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardRequestRemarks" id="98dfbdc2-51b3-45bf-8378-ff54852c45b8">
        <source>utlUpdateYardRequestRemarks(_yardRequest : CM_YardRequest input; _remarks : String; _passport : CM_Passport input);
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	
	if _yardRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _yardRequest.getName, null, null);
		return;
	endif;

	exclusiveLock(_yardRequest);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Yard Job', null, null);
		return;
	endif;
	
	if _yardRequest.remarks &lt;&gt; _remarks then
		app.myAA.auditUpdate(_yardRequest, "remarks", _remarks);
		_yardRequest.setRemarks(_remarks);
	endif;


end;</source>
        <Parameter name="_yardRequest" type="CM_YardRequest" usage="input"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardRequestWeight" id="5f4e363f-f402-4adf-b5c4-810f8615b319">
        <updating/>
        <source>utlUpdateYardRequestWeight(_wle : CM_YardWLE input; 
							_weight : Decimal; 
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
18 June 2014	cnwer1	Initial creation PAR 34406

*/

vars

	rtQEntry : CM_RTQueueEntry;
	yardRequest : CM_YardRequest;
	diff : Decimal[14,4];
begin
	if _wle = null then
		return;
	endif;
	
	if _wle.status = WLE_COMPLETED then
		return;
	endif;
	
	yardRequest:=_wle.myRequest.CM_YardRequest;

	diff:=_weight - _wle.weight;
	
	app.myAA.auditUpdate(yardRequest, CM_Request::weightRequested.name, yardRequest.weightRequested +  diff);
	yardRequest.setWeightRequested(yardRequest.weightRequested +  diff);
		
	if yardRequest.myGateEntity &lt;&gt; null and yardRequest.isKindOf(CMGTE_Release) then
		yardRequest.myGateEntity.setWeight(yardRequest.weightRequested);
	endif;
	
	_wle.setWeight(_weight);
	rtQEntry:= _wle.allRTQueueEntries.first;
	if rtQEntry = null or rtQEntry &lt;&gt; null and
		rtQEntry.isBreakBulkGenericMaster then
		
		if rtQEntry &lt;&gt; null then
			rtQEntry.setWeight(_weight);
			app.myEventManager.createSingleObjInfoNoteEvt( rtQEntry,app.myPassport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(_wle,_passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);
	endif;
		

epilog

end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdategeneratorType" id="20c04f37-4b42-4b64-9d85-fd5333795aed">
        <updating/>
        <source>utlUpdategeneratorType(  _pxyGeneratorType: CM_GeneratorType; _passport : CM_Passport input ) updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realGeneratorType	: CM_GeneratorType;
	expectedEdition		: Integer;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	
	_pxyGeneratorType.pxyGetRealObjectAndEdition(realGeneratorType, expectedEdition);
	
	_pxyGeneratorType.validateForUpdate();
	if _passport.hasErrors then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock( realGeneratorType );

	if _passport.noErrors and realGeneratorType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Generator Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGeneratorType, true);
	endif;
	
	if _passport.noErrors then
		realGeneratorType.setForUpdate(_pxyGeneratorType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGeneratorType, false);
	endif;


end;</source>
        <Parameter name="_pxyGeneratorType" type="CM_GeneratorType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlVVRSecurityGateExit" id="2af8b389-87e6-48b5-a9f6-2da2ad7ae9ec">
        <updating/>
        <source>utlVVRSecurityGateExit(_realVVR : CM_VehicleVisitRecord input; _exitTime : TimeStamp; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

