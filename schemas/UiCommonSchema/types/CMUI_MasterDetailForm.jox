    <JadeMethod name="doQueryRowColumnChange" id="14d12173-8374-43ea-8ffd-6054b646ca35">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				
		self.doDetailAdd();
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row
			self.doDetailAdd();
			return;
		endif;
		col := col+1;			
	endwhile;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
