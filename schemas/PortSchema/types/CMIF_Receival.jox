        <updating/>
        <source>setMyPersistentTrackedItem(value : CM_TrackedItem) updating;
//Simply sets the persistent TI pproperty to the passed in value after checks
vars

begin
	value.raiseExceptionIfTransient(method);
	if value = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Persistent TrackedItem", null, null);	
	endif;
	if self.myPersistentTrackedItem = value then 
		return;
	endif;
	self.myPersistentTrackedItem := value;
end;</source>
