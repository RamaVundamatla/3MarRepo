    <JadeMethod name="doRefresh" id="9e5ff9fa-02d2-4e17-8439-2aa0db9976ac">
        <updating/>
        <source>doRefresh() updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 July 2007 by cnwyl1
//
// Purpose:		Reimplementation of the standard refresh method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/07/2007	cnwyl1		PAR #11909 - Implemented this method.
// --------------------------------------------------------------------------------

vars
	locationObj	: Object;
	listPointer	: Integer;
begin
	if self.selection = LOGLOCATION and cmbLocation.listIndex &lt;&gt; CNEC_NULL_INDEX then
		locationObj	:=	cmbLocation.listObject;
	endif;

	inheritMethod();
	
	if self.selection = LOGLOCATION and locationObj &lt;&gt; null then
		listPointer	:=	cmbLocation.findObject(locationObj);
		
		if listPointer &lt;&gt; CNEC_NULL_INDEX then
			cmbLocation.listIndex	:=	listPointer;
			self.startSearch();
		endif;
	endif;	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveMultiDef" id="5161c8d5-aed0-408d-81d4-6c0ae985e9db">
        <updating/>
        <source>doSaveMultiDef() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	docketDef	: CMIF_DocketLogDef;
	err			: CM_Error;
	numDone,
	totNum		: Integer;
	passport	: CM_Passport;
	//result		: Integer;
	isTrxCompletedOk,
	isNotTrxCompleted	: Boolean;
	
begin

	self.setSelectedDocketDefs();
	
	if self.allSelectedDocketLogDefs.isEmpty then
		app.msgBox('Nothing has been selected', 'Error', MsgBox_OK_Only);
		return true;
	endif;
	
	passport := app.myPassport;		//PAR 22727 11/03/2010
	if passport.hasErrorsOrWarnings() then	// Pasport's old errors are cleared in Trx phase. Unfortunately, this form raises some errors
		passport.clearErrorsWarnings();		// in GUI phase before trx. In this case, a Warning dialog will include old redundant errors as well.
	endif;
	
	foreach docketDef in self.allSelectedDocketLogDefs do
		totNum := totNum + docketDef.allTi.size;
	endforeach;

   	self.myCMIFMonitor.partsInJob := totNum;
   	self.myCMIFMonitor.partsDone := 0;
   	self.pbProgressBar.visible := true;   	

	self.updateProgress(self.myCMIFMonitor);	
	isNotTrxCompleted	:= false;
	isTrxCompletedOk	:= false;

	foreach docketDef in self.allSelectedDocketLogDefs do
		self.myCMIFMonitor.message := 'Regrading Row ' &amp; docketDef.myLocationsController.getID &amp; ' ' &amp; self.myCMIFMonitor.partsDone.String &amp; '/' &amp; self.myCMIFMonitor.partsInJob.String;
	   //	self.updateProgress(self.myCMIFMonitor);	
		if (not self.saveDocketLogDef(docketDef)) then
			isNotTrxCompleted := true;	// at least one log docket is not processed.
			//self.addAllErrorWarnings(passport);	// copies errors to this form. // I removed this, because all warning and errors are displayed noe in the saveDocketLogDef(). There is "while" organized fro blue warnings.
		else
			isTrxCompletedOk := true;
		endif;
		numDone := numDone + docketDef.allTi.size;
	   	self.myCMIFMonitor.partsDone := numDone;
		self.updateProgress(self.myCMIFMonitor);	
	endforeach;
	
	// There are some errors in GUI phase, not in trx. It is because we need to manage 
	// some required fields before trx starts eihter in GUI or BGP mode.
	// In this case, errors are populated in self.allErrorsWarnings and need ErrorsWarning dialog to be displayed here.
	if (not self.allErrorWarnings.isEmpty) then
	
		foreach err in self.allErrorWarnings do
			err.addToPassport(passport);
		endforeach;
	
		app.showErrorWarningDialog('Regrade', passport, ErrWarnMode_Update);
		// As discusseed with Richard, we don't need an extra non-modal WarningsErrors screen for the later review. 11/03/2010 cnwvu1
		//app.showErrorWarningForm(self);	// If to use this extra non-modal WarningsErrors screen, we need to save all errors for each docket in the saveDocketLogDef() method when a user presses Cancel. cnwvu1
		self.setAllErrorWarnings(app.myPassport);	// Now, because we don't use an extra non-modal WarningsErrors screen, we can clear errors on the passport

		return false;
		
	endif;
	
	if isTrxCompletedOk and isNotTrxCompleted then	// when there are some dockets processed and some not at the same time,
		self.doRefresh();							// just refresh the screen, but return false, i.e. don't close this screen
	endif;
	
	// when isNotTrxCompleted = true - it means one docket, at least, was not processed - returns false - screen not closed
	// when isNotTrxCompleted = false - it means all dockets were processed - returns true - screen will be refreshed and closed if require
	return (not isNotTrxCompleted);	// if at leat one docket not processed - don't close this window

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="929cb42a-5967-4c61-abcb-bfae6073192f">
        <updating/>
        <source>doSearch(_isLostFocus: Boolean) : Boolean updating, protected;

vars

	species : CM_LogSpecies;
	length	: CM_LogLength;

begin

	// Clear.
	clearCombos();
	if inheritMethod(_isLostFocus) then
		// Get details.
		self.getRegradingDetail();
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isLostFocus" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
