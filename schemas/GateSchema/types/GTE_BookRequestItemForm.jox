    <JadeMethod name="changeGenCombo" id="22ce402a-34b7-44f7-adc7-5819b5366d7f">
        <updating/>
        <source>changeGenCombo(_refreshCommodityCombo : Boolean)updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
06 July 2009		cnwml2	Initial creation
08 September 2009	cnwjo3	Updated method so Frames would not cover buttons and removed height change
14/10/2010			cnwmh5	PAR 22033 - Don't reload the commodity combo
04/03/2010			cnwcs5	par 22562 - incorrect locaing of commodity combo
13/11/13			cnwer1	par 32951
19/10/2016			cnwdap1	TFS 2652 Reset cargo type on proxy booking item otherwise document action form breaks
21 Dec 2016			cnwrs1	TFS 3151 all vehicles to have subcargotype when adding bookings
28 Jan 2020         cnwma1	Bug 48389: JMT - When adding multiple Booking Items it doesn't display the correct default commodity on the 2nd Item
*/
vars
	commodity 	: CM_Commodity;
	cargoType	: CM_CargoType;
	product     : CM_Product;
	isoType     : CM_ISOType;
begin
	self.grpDetail.height 		:= 614;
	self.grpGeneral.height 		:= 500;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.grpRelease.height 		:= 96;
	self.grpReefer.height 		:= 219;
	self.grpCDGeneral.height 	:= 402;
	
	if self.cmbCargoType.listIndex &lt; 1 then
		// theObject is not set at closeup time
		cargoType := null;
	else
		cargoType := self.cmbCargoType.myObject.CM_CargoType;	// 04/03/2010 par 22562
	endif;
	
	if cargoType &lt;&gt; null and 	// par 22762
		cargoType.id = TI_CargoType_Container then

		commodity := self.cmbCommodity.listObject.CM_Commodity;
		isoType   := self.cmbIsoType.listObject.CM_ISOType;
		if commodity &lt;&gt; null and commodity.isEmpty then
			self.setupISOEmptyControls();
		elseif (isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp ) then//commodity &lt;&gt; null and commodity.hasTemp then
			self.setupISOReeferControls();			
		else
			self.setupISOControls();
		endif;
		
		//cnwjo3 par 23472
		if _refreshCommodityCombo then
			self.loadCommodityCombo(cargoType);						//+cnwml2 PAR22980
		endif;
	else
		if cargoType &lt;&gt; null and cargoType.productType = ProductType_Vehicle then
			self.setupCarControls(cargoType);
			product := null;
			if self.cmbProduct.visible then
				product	:= self.cmbProduct.listObject.CM_Product;
				self.setProductCombo();
				
				if product &lt;&gt; null and cargoType.allProducts.includes(product)  then
					self.cmbProduct.setObject(product);
				else
					self.cmbProduct.setObject(cargoType.allProducts.first);
					product	:= self.cmbProduct.listObject.CM_Product;
				endif;
			else 																					//cnwmc5 - 24 Nov 2015 - PAR 37120
				self.cmbProduct.setObject(null);													//cnwmc5 - 24 Nov 2015 - PAR 37120
			endif;
			//cnwjo3 par 23472
			if _refreshCommodityCombo then
				self.loadCommodityCombo(cargoType);					//+cnwml2 PAR22980
			endif;
		elseif cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Generator then	//Generator Field
			self.setupGeneratorControls(cargoType);
			
		elseif cargoType &lt;&gt; null and cargoType.productType = ProductType_Trailer then
			// controls change depending on commodity (reefer)
			// refresh comodities first so don't display controls from previous commodity
			if _refreshCommodityCombo then	// TFS 46575 jlgzm1 01/10/2019
				self.loadCommodityCombo(cargoType);
			endif;
			self.setupTrailerControls(cargoType);
			
		else 

			self.setupCargoControls(cargoType);  // 28.01.2020 cnwma1 #48389
			
			if _refreshCommodityCombo then
				self.loadCommodityCombo(cargoType);
			endif;
			self.setSpecialStow;
		endif;
	endif;
	
	if cargoType &lt;&gt; null then										// TFS 2652
		self.myProxyBookingRefItem.setCargoType(cargoType.id);		// TFS 2652
	endif;															// TFS 2652
	
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - start
	if self.cmbMatchMode.listIndex = 2 then
		self.txtMatchModeDetails.text := app.getErrorString(Strict_match_desc);		
	else		
		self.txtMatchModeDetails.text := app.getErrorString(Basic_match_desc);
	endif;
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - end
	
	//cnwjo3 par 20615, need to resize here since everything else gets resized first
	self.grpCargoDetails.height := self.btnCancel.top-self.grpCargoDetails.top;
	//cnwjo3 par 20615, i give up.  Frames keep covering buttons.  Just bring buttons forward
	self.btnCancel.zOrder(1);
	self.btnSave.zOrder(1);
	self.btnNext.zOrder(1);
epilog

end;</source>
        <Parameter name="_refreshCommodityCombo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkHasChanged" id="f9b663df-74d9-4c3f-8c81-4b74fbc6220b">
        <source>checkHasChanged() : Boolean;
/*
Date		Who		Reason
11 September 2008	cnwer1	Initial creation
18/09/2012	cnwcs5	par 30390 - change of signature for CM_ReserveSelection setProxy
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
14 Jun 2022 jlier1	TFS 53678
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
*/

vars
	versionChecker 		: CM_DisplayVersionChecker;
	bookingItem 		: CM_BRefItemContainer;
	reserveSelection 	: CM_ReserveSelection;
	isoGroup			: CM_ISOTypeGroup;  		//cnwrd1 par 20810 9/10/9
begin
	if self.hasErrors(false) then
		return false;  //on a Cancel if there are errors on form can't check for changes
	endif;

	create versionChecker transient;
	create bookingItem transient;
	
	self.saveProxyBookingRefItem(bookingItem);
	
	versionChecker.init(self.myProxyBookingRefItem,bookingItem);
	
	if versionChecker.allChangedProperties.size &gt; 0 then
		if app.isSpecial then
			versionChecker.writeChangedProperties;
		endif;
		return true;
	endif;

	isoGroup := app.myRoot.allISOTypeGroups[bookingItem.isoTypeGroup];  //cnwrd1 par 20810 9/10/9

	create reserveSelection  transient;
	
	reserveSelection.setProxy(CM_ReserveSelection.PackType_Parent, 
									bookingItem.myCargoType,
									null,
									bookingItem.myISOType,
									isoGroup,  //cnwrd1 par 20810 9/10/9
									null, 
									null,
									null,
									self.txtTotalUnits.text.trimBlanks.Integer,
									null, //avail grades
									null,//clean
									null, //iso check
									self.chkHeavy.value, //heavy rated
									null, //mask ids
									self.txtMaxRel.text.trimBlanks.Integer,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									false,
									null,
									null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
									null,	// ### TFS 53953 11July2022 NAVPW1
									null,null,  //12-07-2022 navtnr20 53974
									null, //28/06/2023 navmv20 CR 58410 Task 58411
									false, // 6/12/2023 navcs2 ChangeRequest 57537
									false, //19/02/2023	navkc1 CR 60078 Task 62450
									null,  //24/04/2025	navrv30	MTN 34319
									null);
									
	versionChecker.init(self.myProxyBookingRefItem.myReserveDetail,reserveSelection);
	
	if versionChecker.allChangedProperties.size &gt; 0 then
		if app.isSpecial then
			versionChecker.writeChangedProperties;
		endif;
		return true;
	endif;
	
	return false;
epilog
	delete versionChecker;
	delete bookingItem;
	
	if reserveSelection &lt;&gt; null then
		delete reserveSelection;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
