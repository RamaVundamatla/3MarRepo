    <JadeMethod name="userNotificationUpdate" id="8248d157-955a-44f4-8ba6-133785b4a8a5">
        <updating/>
        <source>userNotificationUpdate(_event : Integer; _obj : CM_Object; _anyObject : CM_Object)updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
	idx,
	backColour,
	foreColour : Integer;
begin

	if _event = VoyageJob_Delete_Event then
		self.tblData.findObjectInRow(_obj, idx);
		if idx &gt; 0 then
			self.tblData.removeItem(idx);
		endif;
		return;
	endif;
	
	if _obj = null or (not global.isValidObject(_obj)) then
		return;
	endif;
	
	backColour := White;
	foreColour := Black;
	
	if _event = VoyageJob_Create_Event then
		str := _obj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		idx := self.tblData.addItem(str);
	elseif _event = VoyageJob_Update_Event then
		self.tblData.findObjectInRow(_obj, idx);
		str := _obj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);		
		if idx &gt; 0 then
			self.tblData.removeItem(idx);
			self.tblData.addItemAt(str, idx);
		else
			self.tblData.addItem(str);		
		endif;
	endif;
	
	self.tblData.accessedRow.itemObject := _obj;
	if _obj.isKindOf(CM_Job) then
		_obj.CM_Job.getRowColour(foreColour, backColour);
	elseif _obj.isKindOf(CM_WorkListEntry) then
		_obj.CM_WorkListEntry.getRowColour(foreColour, backColour);
	endif;
	self.tblData.accessedRow.backColor := backColour;
	self.tblData.accessedRow.foreColor := foreColour;

	if backColour = Red then
		self.tblData.accessedRow.fontBold := true;	
	else		
		self.tblData.accessedRow.fontBold := false;		
	endif;
		
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_anyObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="96755c81-4dfe-4edf-b5f7-f110c7217c31">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	event : Integer;
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.userNotificationUpdate(event, theObject.CM_Object, userInfo.CM_Object);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateNotificationRemoval" id="f0ea48fb-964d-413c-b613-de3b30ed11e3">
        <source>validateNotificationRemoval(_removedNotifications, _notificationCount : Integer);
// --------------------------------------------------------------------------------
// Created:		23 Februrary 2010 by cnwjo3
//
// Purpose:		simple method.  Check that allNotableObjects have been removed
//				par 21915
//
vars
	nObj : Object;
begin
	if _removedNotifications &lt; _notificationCount and app.isDevelopmentSystem then
		write "Removed " &amp; _removedNotifications.String &amp; " notification but there were " &amp; _notificationCount.String &amp; " notification in the notification array";
		write "This means that the " &amp; self.name &amp; " form is possibly not correctly removing each kind of Object notifications in " &amp; self.name &amp; "::doNotableClear()";
		write "";
		write "The following kinds of Objects were found: ";
		foreach nObj in self.allNotableObjects do
			write "     " &amp; nObj.getName;
		endforeach;
		write "";
		write method.qualifiedName;
	endif;
end;</source>
        <Parameter name="_removedNotifications" type="Integer"/>
        <Parameter name="_notificationCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zCloneMenu" id="aceef9d1-487b-4ccd-9511-f8fc50aef983">
        <updating/>
        <source>zCloneMenu(_cloneMaster, _sourceMenu : MenuItem input; _loadAsSubMenu : Boolean; _clonedMenuCount : Integer io): MenuItem updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	oidStr	: String;
	newMenu	: MenuItem;
	invalidObject : Boolean;
	ed : Integer;
	
begin

	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
		if newMenu &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception,newMenu,invalidObject);
			ed := newMenu.edition();
		endif;
	endif;
	
	if newMenu = null or invalidObject then
		_clonedMenuCount := _clonedMenuCount + 1;
		
		if _loadAsSubMenu then
			newMenu := _cloneMaster.loadSubMenu(_clonedMenuCount);
		else
			newMenu := _cloneMaster.loadMenu(_clonedMenuCount);
		endif;
		newMenu.userObject	:= _sourceMenu;
		
		_sourceMenu.description	:= newMenu.getOidString;
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	
	return newMenu;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_loadAsSubMenu" type="Boolean"/>
        <Parameter name="_clonedMenuCount" type="Integer" usage="io"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
</GUIClass>
