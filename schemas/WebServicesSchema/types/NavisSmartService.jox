<Class name="NavisSmartService" id="c516263b-1118-4144-9ad9-2fbfa7b240fa">
    <superclass name="WS_NavisRestProvider"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="getExample" id="af8b8108-021c-49d8-a830-f1327ea1f417">
        <updating/>
        <source>getExample() : WS_NSDSResponse updating;
/*

Purpose:			
	Example GET method with framework requirements
Parameters:			
	None - parameters are passed via Request Query String
	QS Parameter - echo
Return Value:			

Date		Who		Reason
18 June 2020	jlgrr1	Initial creation TFS 49632

*/


constants
	ECHO = "echo";
vars
	terminal	: CM_Terminal;
	user		: CM_User;
	
	response 	: WS_NSDSResponse;
	content		: WS_NSDSContentText;
	text		: String;

	echo		: String;
begin

	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "mypassport failed, so returning", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;

	//==== Get Terminal and user ====
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	echo := self.qsData.getValue(ECHO);
	if echo.trimBlanks = "INVALID"  then
		create response as WS_NSDSErrResponse transient;
		app.raiseCMException1(Input_field_not_valid,"INVALID PARAMETER", null, null);
		return response;
	endif;
		
	//==== Process REST Method ====
	app.writeLog("NAVIS SMART DATA: Processing Example Method", LogDEBUG);
	text := user.code &amp; "-" &amp; terminal.code &amp; ": " &amp; echo;
	
	//==== Set Content and Return ====
	create response as WS_NSDS200Response transient;	
	create content transient;	
	content.text := text;
	response.setContent(content);
	return response;
	
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="getMicroserviceToken" id="0a24ed2b-afdc-4b00-8256-3a40d49d12e9">
        <updating/>
        <source>getMicroserviceToken() : WS_NSDSResponse updating;
/*

Purpose:			
Special method that takes the Microservice name and listening URL to find the matching active external web service definition 
and return the AuthToken using the OPSVIEW user.


Parameters:			

Return Value:		

Date			Who		Reason
09 July 2020	jlgrr1	Initial creation TFS 49632
14 Feb 2021		navmd1	Add some additional logging to work out what an error actually means!

*/

vars
	response     : WS_NSDSResponse;	
	content      : WS_NSDSContentToken;
	authToken    : String;
	microservice : String;
	targetUrl 	 : String;
	wsDef        : CM_OpsViewServiceDef;
	user         : CM_User;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);		
	
	// Ensure Start Transaction is set
	self.startCnTrx := cnStartTransaction(method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);	
	
	// License has already been validated
	
	// We are using Basic Auth with the microservice name and target url
	self.parseBasicAuth(microservice, targetUrl);

	
	// Microservice should match supported microservices
	// TFS 49632 - DEV NOTE: TO BE UPDATED 
	// Replace "NavisSmart_OpsView" with const - not a XLAT, but a normal constant!
	if microservice = app.getErrorString(Navissmart_opsview) then

		wsDef := app.myRoot.getFirstActiveExtWebService(CM_OpsViewServiceDef).CM_OpsViewServiceDef;
		
		if wsDef = null then
		
			create response as WS_NSDSErrResponse transient;
			self.httpStatusCode := HttpResponseUnauthorized;
			app.writeLog(method.qualifiedName &amp; " No External Web Service definition found [" &amp; app.getErrorString(Navissmart_opsview) &amp; "]", LogERROR);
			return response;
		endif;
	
		if wsDef.baseEndpoint = targetUrl then
			
			user := app.myRoot.allUsers[OPSVIEWUSER_Str];
		
			if user = null then
				create response as WS_NSDSErrResponse transient;
				self.httpStatusCode := HttpResponseUnauthorized;
				app.writeLog(method.qualifiedName &amp; " [" &amp; OPSVIEWUSER_Str &amp; "] user does not exist, unable to continue", LogERROR);
				return response;
			endif;
	
			authToken := user.getOpsViewToken();
			create response as WS_NSDS200Response transient;	
			create content transient;	
			content.token := authToken;
			response.setContent(content);
			return response;
		else
			create response as WS_NSDSErrResponse transient;
			self.httpStatusCode := HttpResponseForbidden;
			app.writeLog(method.qualifiedName &amp; " External Web Service endpoint [" &amp; wsDef.baseEndpoint &amp; "] does not match Opsview listen address [" &amp; targetUrl &amp; "]", LogERROR);
			return response;
		endif;
			
		
	
	endif;
	
	// Service name is not valid / supported
	create response as WS_NSDSErrResponse transient;
	self.httpStatusCode := HttpResponseForbidden;
	app.writeLog(method.qualifiedName &amp; " Invalid service name [" &amp; microservice &amp; "], nothing to do", LogERROR);
	return response;

epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="mtnServiceName" id="2cc1d01d-8bc4-465d-93c4-e8d448e0b2c2">
        <source>mtnServiceName() : String;
/*

Purpose:			
 Retrieves the Request Header with the Microservice Name
Parameters:			

Return Value:		
	Microservice Name
	- Initial supported values NavisSmart_OpsView
	
Date			Who		Reason
09 July 2020	jlgrr1	Initial creation TFS 49632
23 Nov 2021		navmd1	Moved debug code up a level and changed to Trace

*/

vars
	name : String;
begin
	name := self.getServerVariable("HTTP_MTN_SERVICENAME").trimBlanks;
	app.writeLog(method.qualifiedName &amp; ": MTN-SERVICENAME=" &amp; name, LogTRACE);
	
	return name;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="postProducerStatus" id="2e9ed68f-2ab6-4f73-b37a-c02546fabbc8">
        <updating/>
        <source>postProducerStatus(_request : WS_NSDSStatusRequest ): WS_NSDSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2021 cnwma1	ChangeRequest 50529: MTN - Ops View ProducerStatus API

*/

vars
	response 		: WS_NSDSResponse ;
	content         : WS_NSDSContentProducerStatus;
	isSnapShotReq	: Boolean;
	tsConverted     : TimeStamp;
	serviceName, statMessage : String;
	wsDef, pxydef			: CM_OpsViewServiceDef;
	currentStatus : String;
	lastSuccessfulSeq : Integer;
begin
	
	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	

	if  _request.lastSuccessfulDateTime &lt;&gt; null then 
		tsConverted 			:= _request.lastSuccessfulDateTime.convertISO8601ToUTCTimeStamp;
	endif;
	tsConverted 			:= app.myTimeZoneHelper.convertTimeFromUtc(tsConverted, app.myTimeZoneHelper.getSystemTimeZoneID);
	
	
	// ###### O P S V I E W ######
	if self.mtnServiceName() = app.getErrorString(Navissmart_opsview) then // "NavisSmart_OpsView" ### TFS 50529 02AUG2021 NAVAB1
		wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef; // ### TFS 50529 02AUG2021 NAVAB1
		if wsDef &lt;&gt; null then // ### TFS 50529 02AUG2021 NAVAB1
			currentStatus := wsDef.status;
			pxydef := app.createUpdateProxy(wsDef).CM_OpsViewServiceDef; // ### TFS 50529 02AUG2021 NAVAB1
			
			lastSuccessfulSeq := _request.lastSuccessfulSequence.Integer.max(wsDef.lastSuccessfullSequence.Integer); // ### TFS 51855 17FEB2022 NAVAB1 Ram had set the producer to send the last successful every 2 days, so basically we never got it, so on the WSDEF it was a very low number which resulted in 1000s of messages being resent every morning in Mmast..
		else
			create response as WS_NSDSErrResponse transient;	
			app.raiseCMException1(Input_required_field,method.qualifiedName &amp; " - " &amp; "No Active EWS OPSVIEW", null, null);
			return response;
		endif;

		app.writeLog(method.qualifiedName &amp; " " &amp; _request.producerStatus, LogDEBUG);
		
		// ### IDLE
		if _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Idle  then
		   isSnapShotReq := false;
			if pxydef &lt;&gt; null then // ### TFS 50529 25AUG2021 NAVAB1
				if _request.statusMessage &lt;&gt; null then
					statMessage:= "(" &amp; app.actualTimeServer.String &amp; ") " &amp; _request.statusMessage;
				else
					statMessage:= "(" &amp; app.actualTimeServer.String &amp; ") Producer is waiting for START Instruction to be sent from Master Terminal";
				endif;
				pxydef.setProxyForStatus(EWS_STATUS_IDLE, pxydef.lastSuccessfullSequence, pxydef.lastSuccessfullTS, statMessage); // ### TFS 50529 25AUG2021 NAVAB1
			endif;	
			// 
		// ### RUNNING
		elseif _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Running  then
		   isSnapShotReq := false;
			if pxydef &lt;&gt; null then // ### TFS 50529 02AUG2021 NAVAB1
				
				// if the EWS is currently 'starting' it means that it is running through the back log still, change the status to ready to run
				//  CM_OpsViewServiceDef::createBGPRequestsForSTARTING will change the status to ready to run when it has finished catching up
				if wsDef.status = EWS_STATUS_STARTING then 
					pxydef.setProxyForStatus(EWS_STATUS_READYTORUN, pxydef.lastSuccessfullSequence, pxydef.lastSuccessfullTS, null); // ### TFS 50529 02AUG2021 NAVAB1
				else
					// status is ready to run so set to running
					pxydef.setProxyForStatus(EWS_STATUS_RUNNING, pxydef.lastSuccessfullSequence, pxydef.lastSuccessfullTS, null); // ### TFS 50529 02AUG2021 NAVAB1
							
				endif;
			endif;	
			
		// ### STOPPING
		elseif _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Stopping then
		   // PAUSE BGP
			if pxydef &lt;&gt; null then // ### TFS 50529 02AUG2021 NAVAB1
				if _request.statusMessage &lt;&gt; null then
					statMessage:= "(" &amp; app.actualTimeServer.String &amp; ") " &amp; _request.statusMessage;
				endif;
				pxydef.setProxyForStatus(EWS_STATUS_STOPPED, lastSuccessfulSeq, tsConverted, statMessage); // ### TFS 50529 02AUG2021 NAVAB1
			endif;		   
			isSnapShotReq := false;
		// ### STARTING
		elseif  _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Starting then // ### TFS 53105 14JUL2022 NAVAB1
			if not wsDef.updateSeqNumFromProducer(lastSuccessfulSeq) then  // ### TFS 53105 14JUL2022 NAVAB1 -  If last successful sequence is older than 24 hours then do nto send any data. Update EWS DEF to last instance
				lastSuccessfulSeq := CM_EWSActivityOpsview.lastInstance.sequence;  // ### TFS 53105 14JUL2022 NAVAB1
			endif;
		
			if pxydef &lt;&gt; null then // ### TFS 50529 02AUG2021 NAVAB1
				pxydef.setProxyForStatus(EWS_STATUS_STARTING, lastSuccessfulSeq, wsDef.lastSuccessfullTS, null); // ### TFS 50529 02AUG2021 NAVAB1  // ### TFS 51855 17FEB2022 NAVAB1
			endif;		   
			
		endif;
		
		if pxydef &lt;&gt; null then // ### TFS 50529 02AUG2021 NAVAB1
			app.myTrxUA.trxUpdateOpsViewStatus(pxydef,app.myPassport); // ### TFS 50529 02AUG2021 NAVAB1
			if not app.myPassport.trxCompletedOK then
				app.writeLog(app.myPassport.getAllErrorsAndWarningsAsStr(), LogDEBUG);
			endif;
		endif;		   

		// Cause Event - PortSchema::BGP_ExternalWSController::sysNotification

		// ### RUNNING
		if _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Running 
		and wsDef.status = EWS_STATUS_RUNNING then
			system.causeEvent(BGP_Object.BGP_NavisSmartProducerRunning, true, null);
		// ### STOPPING
		elseif _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Stopping then
			system.causeEvent(BGP_Object.BGP_NavisSmartProducerStopped, true, null);
		// ### STARTING
		elseif  _request.producerStatus = WS_NSDSStatusRequest.ProdStatus_Starting
		and currentStatus &lt;&gt; _request.producerStatus then // if changing
			
			isSnapShotReq:= wsDef.isProducerDownMoreThan();
			
			if isSnapShotReq then
				// IF forced or 'STOPPED' MORE THAN X HOURS ITS A SNAPSHOT
				// logically delete all paused EWS activity
				system.causeEvent(BGP_Object.BGP_NavisSmartProducerSnapshot, true,null);
				// Response of isSnapShotRequired= true will make producer call API for snap shot data.

			else
				if wsDef.lastSuccessfullSequence.Integer &gt; 0 then
					// REPLAY FROM THIS SEQUENCE PLUS 1
					system.causeEvent(BGP_Object.BGP_NavisSmartProducerStarting, true, wsDef.lastSuccessfullSequence.Integer);
				else
					// all the 'requests' that have not been sent will be activities with a status of CREATED
					// pass over to the BGP controller for OpsView to run through the EWS activities
					// PortSchema::BGP_ExternalWSController::sysNotification
					system.causeEvent(BGP_Object.BGP_NavisSmartProducerStarting, true, null);
					
				endif;

			endif;

		endif;
		
	endif;
	
	create response as WS_NSDS200Response transient;	
	create content transient;	
	content.isSnapShotRequired := isSnapShotReq;
	response.setContent(content);
	return response;

epilog
	delete pxydef; // ### TFS 50529 02AUG2021 NAVAB1
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_request" type="WS_NSDSStatusRequest"/>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="postUpdateLatestSequenceDetail" id="32407ff8-8084-46c0-b539-3fca8ee0c0e2">
        <updating/>
        <source>postUpdateLatestSequenceDetail(_request : WS_NSDSStatusRequest ): WS_NSDSResponse updating;
/*
Purpose:			

Date		Who		Reason
18AUG2021	NAVAB1	TFS 50529
*/

vars
	response 		: WS_NSDSResponse ;
	content         : WS_NSDSContentProducerStatus;
	isSnapShotReq	: Boolean;
	tsConverted     : TimeStamp;
	serviceName, statMessage : String;
	wsDef, pxydef			: CM_OpsViewServiceDef;
	currentStatus : String;
	lastSuccessfulSeq : Integer64; 

begin

	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " initiaizepassport failed, so returning", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	

	if  _request.lastSuccessfulDateTime &lt;&gt; null then 
		tsConverted := _request.lastSuccessfulDateTime.convertISO8601ToUTCTimeStamp;
	endif;
	tsConverted := app.myTimeZoneHelper.convertTimeFromUtc(tsConverted, app.myTimeZoneHelper.getSystemTimeZoneID);
	

	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
	if wsDef &lt;&gt; null then
		pxydef := app.createUpdateProxy(wsDef).CM_OpsViewServiceDef;
	else
		create response as WS_NSDSErrResponse transient;	
		app.raiseCMException1(Input_required_field,method.qualifiedName &amp; " - " &amp; "No Active EWS OPSVIEW", null, null);
		return response;
	endif;

	app.writeLog(method.qualifiedName &amp; " " &amp; _request.producerStatus, LogDEBUG);
	
	if _request.lastSuccessfulSequence.length &gt; 18 then  // ### TFS 51855 31JAN2022 NAVAB1
		create response as WS_NSDSErrResponse transient;	  // ### TFS 51855 31JAN2022 NAVAB1
		app.raiseCMException1(Input_required_field,method.qualifiedName &amp; " - " &amp; " Last Successful Seuence ERROR. Number too long '" &amp; _request.lastSuccessfulSequence &amp; "'", null, null);  // ### TFS 51855 31JAN2022 NAVAB1
		return response;  // ### TFS 51855 31JAN2022 NAVAB1
	
	endif;
	
	if _request.lastSuccessfulSequence.Integer64 = -1 then  // ### TFS 51855 31JAN2022 NAVAB1
		app.writeLog(method.qualifiedName &amp; " from PRODUCER - lastSuccessfulSequence: " &amp; _request.lastSuccessfulSequence, LogDEBUG);
		app.writeLog(method.qualifiedName &amp; " Negative One from Producer means that the file for lastSuccessfulSequence is not available, not updating Ops View.", LogDEBUG);
	
	else
		app.writeLog(method.qualifiedName &amp; " from PRODUCER - lastSuccessfulSequence: " &amp; _request.lastSuccessfulSequence, LogDEBUG);
		app.writeLog(method.qualifiedName &amp; " Updating Ops View with last successful sequence.", LogDEBUG);
		
		if _request.lastSuccessfulSequence.Integer &lt; wsDef.lastSuccessfullSequence.Integer then // ### TFS 53105 14JUL2022 NAVAB1
		
			app.writeLog(method.qualifiedName &amp; " Producer Last Seq Num: " &amp; _request.lastSuccessfulSequence &amp; " Is less than the one stored in MTN which is " &amp; wsDef.lastSuccessfullSequence.String &amp; "Keeping MTN one", LogDEBUG); // ### TFS 53105 14JUL2022 NAVAB1
		endif;
		
		lastSuccessfulSeq := _request.lastSuccessfulSequence.Integer.max(wsDef.lastSuccessfullSequence.Integer); 		 // ### TFS 53105 14JUL2022 NAVAB1
		
		if wsDef.updateSeqNumFromProducer(lastSuccessfulSeq) then // ### TFS 53105 14JUL2022 NAVAB1
			
 // ### TFS 53105 14JUL2022 NAVAB1		pxydef.setProxyForStatus(wsDef.status, _request.lastSuccessfulSequence.Integer,tsConverted, _request.statusMessage);
			pxydef.setProxyForStatus(wsDef.status, lastSuccessfulSeq.Integer,tsConverted, _request.statusMessage); // ### TFS 53105 14JUL2022 NAVAB1
			
			if pxydef &lt;&gt; null then
				app.myTrxUA.trxUpdateOpsViewStatus(pxydef,app.myPassport);
				if not app.myPassport.trxCompletedOK then
					app.writeLog(app.myPassport.getAllErrorsAndWarningsAsStr(), LogDEBUG);
				endif;
			endif;		
		else // ### TFS 53105 14JUL2022 NAVAB1
			app.writeLog(method.qualifiedName &amp; " Activity record for sequence " &amp; lastSuccessfulSeq.String&amp; " Is older than 24 hours so not updating WS DEF with last successful sequence", LogDEBUG); // ### TFS 53105 14JUL2022 NAVAB1
		
		endif;
	endif;
	
	create response as WS_NSDS200Response transient;	
	create content transient;	
	content.isSnapShotRequired := false;
	response.setContent(content);
	return response;

epilog
	delete pxydef;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_request" type="WS_NSDSStatusRequest"/>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
</Class>
