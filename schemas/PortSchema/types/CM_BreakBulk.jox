    <JadeMethod name="getStorageChargeForPeriod" id="374929b4-b8c0-4fbf-a9b4-23e520bc26df">
        <source>getStorageChargeForPeriod(_startDate,
							_endDate : Date) :Decimal;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	m3Days				: Decimal[16,6];
	chargableDays		: Integer;
	product 			: CM_Product;
	invalid				: Boolean;
begin
	chargableDays := self.getDaysOnsiteForPeriod(_startDate, _endDate);

	//cnwjo3, not sure why but all our CM_BreakBulks have no products.
	//need new condition here since 'Storage Changes' report not working
	on Exception do app.handleDeletedObject(exception,product,invalid);
	product := self.myProduct;
	if product &lt;&gt; null then
		m3Days := product.getStorageChargeRate * self.getMyTotalVolume;
	endif;
	return (chargableDays * m3Days);

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
