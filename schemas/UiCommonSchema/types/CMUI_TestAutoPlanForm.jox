    <JadeMethod name="doHandleNotification" id="a5be22d8-1070-4827-a8e0-2cd600ba5587">
        <source>doHandleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	testEdition	: Integer;
	rowIndex : Integer;
	isInvalid	: Boolean;
	isPlanned : Boolean;
	str : String;
	result : CM_TestAutoPlanResult;

begin

	if theObject = null or not theObject.isKindOf( CM_TrackedItem ) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, isInvalid);
	ti := theObject.CM_TrackedItem;
	// 34605 check that ti is valid
	testEdition := ti.edition;
	if isInvalid then
		return;
	endif;
	
	if not self.allNotableTis.includes( ti ) then
		return;
	endif;
	
	self.tblSelectedCargo.findObjectInRow( ti, rowIndex );
	if rowIndex &lt; 1 then
		return;
	endif;
	str := ti.getAttributeStringForDefArray(self.tblSelectedCargo.allTblDataEntRows);
	isPlanned := ti.myPrimaryPlannedLocation &lt;&gt; null;
	if isPlanned then
		self.tblSelectedCargo.accessRow( rowIndex ).backColor := Grey;
		result := self.myTestAutoPlanRoot.getResultFor(ti);
		if result = null then
			return;
		endif;
		if result.isFailed then
			self.refreshTable( self.tblFailed, true );
		elseif result.isPlanned then
			self.refreshTable( self.tblWouldPlan, true );
		endif;
	else
		self.tblSelectedCargo.accessRow( rowIndex ).backColor := White;
		
	endif;
	
	

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="af8d5e4e-4428-4ff7-bb26-5ec0ce57a3b3">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin
	
	self.shtSelected.setFocus();
	
	self.refreshTable( self.tblSelectedCargo, false );
	self.refreshTable( self.tblWouldPlan, true );
	self.refreshTable( self.tblFailed, true );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="9239c591-6127-4995-ba48-d18ea9c17a6f">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	vGap : Real;
	vLeft : Real;

begin

	vGap := self.btnClose.left - self.btnClear.left;
	vLeft := ( vGap / 2 ) + self.btnClear.left;
	self.btnTestAP.left := vLeft;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblFailedDragTrackedItem" id="bb1b00c7-ca18-4144-bb3b-1f4be2d61374">
        <updating/>
        <source>doTblFailedDragTrackedItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	result : CM_TestAutoPlanResult;
	theTI : CM_TrackedItem;
	pic : Picture;
	
begin

	result := self.tblFailed.accessRow( self.tblFailed.row ).itemObject.CM_TestAutoPlanResult;
	if result &lt;&gt; null and
	   result.myTrackedItem &lt;&gt; null then
	   theTI := result.myTrackedItem;
	else
		return;
	endif;
	
	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI);
	self.tblFailed.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblFailed.dragCursor := pic.picture;
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTestAutoPlan" id="26fceda2-f368-4846-884a-b363514a31e9">
        <updating/>
        <source>doTestAutoPlan( term : CM_Terminal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	terminal : CM_Terminal;
	iter : Iterator;
	result : CM_TestAutoPlanResult;
	planSize : Integer;
	failSize : Integer;

begin

	self.fldMain.topSheet := self.shtSelected;
	self.fldMain.doWindowEvents(0);

	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		app.msgBox(app.getErrorString(Must_select_valid_term), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbTerminal.setFocus();
		return;
	endif;

	self.clearWouldPlanAndFailed();

	self.myTestAutoPlanRoot.doTestAutoPlan( self.tblSelectedCargo,	//_tblSelected : Table input;
											null,	//_alternateSelection : CM_TIArray input;
											terminal,	//_terminal : CM_Terminal;
											null,	//_terminalArea : CM_TerminalArea
											true
											);
											
	iter := myTestAutoPlanRoot.allTestAutoPlanResults.createIterator;	
	while iter.next( result ) do
		if result.isFailed then
			self.tblFailed.addItemObject( result, result.getAttributeStringForDefArray(self.tblFailed.allTblDataEntRows) );
		elseif result.isPlanned then
			self.tblWouldPlan.addItemObject( result, result.getAttributeStringForDefArray(self.tblWouldPlan.allTblDataEntRows) );
		endif;
	endwhile;
	
	planSize := self.tblWouldPlan.rows - self.tblWouldPlan.fixedRows;
	self.shtResults.caption := "(x" &amp; planSize.String &amp; ") " &amp; app.getErrorString(Would_plan);
	
	failSize := self.tblFailed.rows - self.tblFailed.fixedRows;
	self.shtFail.caption := "(x" &amp; failSize.String &amp; ") " &amp; app.getErrorString(Failed_test_plan);
	
	if failSize &gt; 0 then
		self.fldMain.topSheet := self.shtFail;
	elseif planSize &gt; 0 then
		self.fldMain.topSheet := self.shtResults;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getSelectedResultTIs" id="6590ef3b-499a-4bc6-9f45-bdecb0bfa442">
        <source>getSelectedResultTIs( _table : CM_DataTable; _tiArray : CM_TIArray input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	iter : Iterator;
	obj : Object;
	result : CM_TestAutoPlanResult;
	invalidObject : Boolean;
	ti : CM_TrackedItem;

begin

	if _table = null then
		return;
	endif;
	
	if _table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, result, invalidObject );
	
	iter := _table.allSelectedObjects.createIterator;
	while iter.next( obj ) do
		result := obj.CM_TestAutoPlanResult;
		invalidObject := false;
		ti := result.myTrackedItem;
		if invalidObject then
			continue;
		endif;
		if ti &lt;&gt; null then
			_tiArray.addExclusive(ti);
		endif;
	endwhile;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="951d8f31-ac82-4f19-a192-82a4170daa91">
