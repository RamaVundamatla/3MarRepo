    <JadeMethod name="tStopAction" id="36a2726a-3e0e-4a72-ac53-e272ba5b2af5">
        <source>tStopAction();
//
// 30 Nov 2015	cnwrs1	Par 34702 - Add support for JMT XML
//
constants
	USER_DEF_NAME : String = "JMTInternalStop";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	self.setTerminalConfig(NoImportStops, false);
	passportObj	:=	app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalStop xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalStop.xsd"&gt;
	&lt;AllCargoUpdateRequest&gt;
		&lt;CargoUpdateRequest&gt;
			&lt;directDelivery/&gt;
			&lt;clearanceExpiryDate/&gt;
			&lt;updateType/&gt;
			&lt;billOfLading/&gt;
			&lt;cargoRemarks/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;deliveryReleaseNumber/&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;gradeCode/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;stopAction&gt;D&lt;/stopAction&gt;
			&lt;stopCode&gt;994&lt;/stopCode&gt;
			&lt;subTerminalCode/&gt;
			&lt;toDoAction/&gt;
			&lt;toDoRemarks/&gt;
			&lt;toDoTaskShort/&gt;
			&lt;voyageCode/&gt;
		&lt;/CargoUpdateRequest&gt;
	&lt;/AllCargoUpdateRequest&gt;
&lt;/JMTInternalStop&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tStopAction"&amp;CrLf, "wrong remarks");
	self.assertNotEqualMsg(container.getStop(994), null, "stop not found");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStowAdviceAction" id="0cd2fdd9-f85a-4137-97a8-d51f36f70fc3">
        <source>tStowAdviceAction();
//
//14 August 2017	jlgrs1	Initial creation
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 21 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
constants
	USER_DEF_NAME : String = "JMTInternalStowAdvice";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
begin
	self.setTerminalConfig(NoImportStops, false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalStowAdvice xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalStowAdvice.xsd"&gt;
	&lt;AllDataStowAdvice&gt;
		&lt;DataStowAdvice&gt;
			&lt;operatorCode/&gt;
			&lt;fromPort/&gt;
			&lt;sendTime/&gt;
			&lt;toPort/&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;AllStowageAdvice&gt;
				&lt;StowageAdvice&gt;
					&lt;isTranshipItem/&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;cooledType/&gt;
					&lt;loadOrder/&gt;
					&lt;quantity/&gt;
					&lt;temperature/&gt;
					&lt;bookingRef/&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity/&gt;
					&lt;commodityDescription/&gt;
					&lt;description/&gt;
					&lt;destinationPort/&gt;
					&lt;dischargePort/&gt;
					&lt;fullOrMT/&gt;
					&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
					&lt;isoType/&gt;
					&lt;isoTypeGroup/&gt;
					&lt;loadPort/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;mode&gt;LOA&lt;/mode&gt;
					&lt;newStowageId&gt;010682&lt;/newStowageId&gt;
					&lt;operatorCode/&gt;
					&lt;remarks/&gt;
					&lt;stowageId/&gt;
					&lt;dischargePorts&gt;NZAKL NZWLG AUSYD&lt;/dischargePorts&gt;
				&lt;/StowageAdvice&gt;
			&lt;/AllStowageAdvice&gt;
		&lt;/DataStowAdvice&gt;
	&lt;/AllDataStowAdvice&gt;
&lt;/JMTInternalStowAdvice&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tStowAdviceAction"&amp;CrLf, "wrong remarks");
	self.assertNotEqualMsg(container.getStop(994), null, "stop not found");

end;
</source>
    </JadeMethod>
    <JadeMethod name="tTfs52330" id="c094ff7c-7311-4c85-bdea-1c9d254335ea">
        <source>tTfs52330();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2021 navma1	ChangeRequest 52330: SAL - EDI operations - Cargo On Site

*/
constants
	REF			  : String = 'UT52330';
	USER_DEF_NAME : String = UT_EDI.UT_UDT_52330;
vars
	bs1		  	  : CM_BlockStack;
	voyage	  	  : CM_Voyage;
	vessel    	  : CM_Vessel;
	cargoType 	  : CM_CargoType;
	ti        	  : CM_TrackedItem;
	oper	  	  : CM_Operator;
	dischargePort : CM_Port;
	ediFileObj 	  : CM_EDIFile;
	ediDataObj 	  : CM_EDIData;
	ediText 	  : String;
	errorMsg 	  : String;
	recDT		  : TimeStamp;
begin
	
	/*
	1- Preparation  
	*/
	
	/*1.A - Delete EDI User Def*/
	self.ediDeleteUserDefinedDefinition("UT_UDT_52330",EDIFileType_UserDefined);
	
	/*1.B - Create EDI User Def*/
	self.ediImportUserDefinedDefinition(USER_DEF_NAME, USER_DEF_NAME);
	
	/*1.C - Delete TA*/
	self.deleteTerminalArea(REF);
	
	/*1.D - Create TA*/
	bs1 := self.addBlockStack(REF,999,null);
	assertNotNull(bs1);
	
	/*1.E - Delete Voyage - Vessel */
	self.deleteVessel(REF);
	self.deleteVoyage(REF);
	
	/*1.F - Create Voyage - Vessel*/
	oper   := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	vessel := addVesselCellular(REF, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	
	voyage := addVoyageWithContainerStructur(REF, REF, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	
	
	/*1.G - Delete Cargo*/
	cargoType := app.myRoot.getCargoTypeFromAbbrev('CONT');
	self.deleteCargo('UTC1'&amp;REF,cargoType);
	
	/*1.H- Add Cargo on Voyage*/
	self.opts.purge();
	self.opts.addAssoc('CargoType', cargoType.id );
	
	ti := self.addContainerAtLocation(REF, oper, "2200", "GENL", 1, voyage.myShipBlockStack);
	self.assertNotNullMsg(ti, "Add cargo failed");
	
	/*
	2- Discharge Cargo  
	*/
	/*2.A -Discharge Cargo*/
	self.instantMove(ti,bs1.myLocationsController);
	
	self.assertNotNullMsg(ti.myPrimaryActualLocation = bs1.myLocationsController, "Cargo no at Yard ");
	
	
	/*
	3 - Load Edi 
	*/
	/*3.A - Load Edi File*/
	ediText :='&lt;?xml version="1.0"?&gt;
	&lt;JMTInternalCargoOnSite xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoOnSite.xsd"&gt;
		&lt;AllCargoOnSite&gt;
			&lt;CargoOnSite&gt;
				&lt;messageMode&gt;M&lt;/messageMode&gt;
				&lt;id&gt;UT52330&lt;/id&gt;
				&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
				&lt;remarks&gt;UT52330&lt;/remarks&gt;
				&lt;locationId&gt;UT52330&lt;/locationId&gt;
				&lt;receiveDate&gt;01 January 2020 12:45:00&lt;/receiveDate&gt;
				&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
			&lt;/CargoOnSite&gt;
		&lt;/AllCargoOnSite&gt;
	&lt;/JMTInternalCargoOnSite&gt;';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, 'UT_UEDI_52330');
	self.assertNotNull(ediFileObj);

	self.ediVerify(ediFileObj);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFileObj);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	/*
	4- Validate Receive Date Time 
	*/
	recDT.setDate("01/01/2020".Date);
	recDT.setTime("12:45:00".Time);
	self.assertTrueMsg(ti.receivedDT = recDT, 'Receive Date Time has not been updated');
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoTaskAction" id="49feb7c3-16d0-4bb3-a2cc-ab6f9d484455">
        <source>tToDoTaskAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalToDoTask";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalToDoTask xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalToDoTask.xsd"&gt;
	&lt;AllToDoTask&gt;
		&lt;ToDoTask&gt;
			&lt;isComplete&gt;false&lt;/isComplete&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;taskCode&gt;MISCELL&lt;/taskCode&gt;
			&lt;toDoRemarks/&gt;
		&lt;/ToDoTask&gt;
	&lt;/AllToDoTask&gt;
&lt;/JMTInternalToDoTask&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tToDoTaskAction"&amp;CrLf, "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTrainAction" id="e1531105-2161-4c9a-90aa-6d762eec3b6c">
        <source>tTrainAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalTrain";
	TRAIN : String = "UTTRAIN01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	train : CM_Train;
	ediText : String;
	errorMsg : String;
	now : TimeStamp;
begin
	passportObj := app.myPassport;
	train := self.getTrain(TRAIN, null);
	self.deleteTrainAndAssociatedObjs(train);
	train := self.getTrain(TRAIN, null);
	self.assertIsDeletedMsg(train, "train");
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTrain xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTrain.xsd"&gt;
	&lt;AllTrain&gt;
		&lt;Train&gt;
			&lt;description&gt;Stuff&lt;/description&gt;
			&lt;fullOrMT/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;scheduleCode/&gt;
			&lt;trainCode&gt;'&amp;TRAIN&amp;'&lt;/trainCode&gt;
			&lt;trainDestination/&gt;
			&lt;trainOrigin/&gt;
			&lt;scheduledArrivalDT&gt;'&amp;now.asStringJMT&amp;'&lt;/scheduledArrivalDT&gt;
			&lt;scheduledDepartureDT/&gt;
		&lt;/Train&gt;
	&lt;/AllTrain&gt;
&lt;/JMTInternalTrain&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	self.assertEqualMsg(train.description, "Stuff", "wrong description");

end;
</source>
    </JadeMethod>
    <JadeMethod name="tTrainConsist" id="2a89f040-fd6f-46f7-9e09-e2fb7cd37b3c">
        <source>tTrainConsist();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
constants
	USER_DEF_NAME : String = "JMTInternalTrainConsist";
	TRAIN = "UT-TRAIN02";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ti : CM_TrackedItem;
	ediText : String;
	errorMsg : String;
	wagon : CM_Wagon;
	train : CM_Train;
begin
//	process.profiler.start();
	
	passportObj	:=	app.myPassport;
	train := self.getTrain(TRAIN, null);
	if train &lt;&gt; null then
		wagon := self.getWagon("UK1022", train);
		self.deleteTrainAndAssociatedObjs(train);
	endif;
	train := self.getTerminal.getNullTrain;
	wagon := self.getWagon("UK1022", train);
	self.deleteWagonAndAssociatedObjs(wagon);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalTrainConsist&gt;
&lt;AllTrain&gt;
&lt;Train&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;00000001&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;scheduleCode&gt;DDTEST&lt;/scheduleCode&gt;
&lt;trainCode&gt;UT-TRAIN02&lt;/trainCode&gt;
&lt;trainDestination&gt;NZDUD&lt;/trainDestination&gt;
&lt;trainOrigin&gt;NZCHC&lt;/trainOrigin&gt;
&lt;scheduledArrivalDT&gt;05 April 2010, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;scheduledDepartureDT&gt;01 May 2010, 00:00:00&lt;/scheduledDepartureDT&gt;
&lt;AllWagon&gt;
&lt;Wagon&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;id&gt;00000002&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;trainCode&gt;UT-TRAIN02&lt;/trainCode&gt;
&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;scheduledArrivalDT&gt;05 April 2010, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;/Wagon&gt;
&lt;/AllWagon&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;receiveDate&gt;11 August 2014&lt;/receiveDate&gt;
&lt;weight&gt;5000.0000&lt;/weight&gt;
&lt;packTempC&gt;-273&lt;/packTempC&gt;
&lt;packTempF&gt;-273&lt;/packTempF&gt;
&lt;bookingRef&gt;UT_BK_0013&lt;/bookingRef&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;commodityDescription&gt;General&lt;/commodityDescription&gt;
&lt;consignee&gt;ABCNE&lt;/consignee&gt;
&lt;consignor&gt;ABCNR&lt;/consignor&gt;
&lt;customsSeal&gt;MAFSEAL&lt;/customsSeal&gt;
&lt;sealTerminalOperator&gt;TermOpSeal1&lt;/sealTerminalOperator&gt;
&lt;destinationPort&gt;AUBNE&lt;/destinationPort&gt;
&lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
&lt;fullOrMT&gt;f&lt;/fullOrMT&gt;
&lt;id&gt;MAEU1111111&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
&lt;sealNum&gt;OPSEAL&lt;/sealNum&gt;
&lt;sealNumberVent&gt;VSEAL&lt;/sealNumberVent&gt;
&lt;AllSealDetails&gt;
&lt;SealDetails&gt;
&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
&lt;sealEDINum&gt;SHSEAL1&lt;/sealEDINum&gt;
&lt;/SealDetails&gt;
&lt;SealDetails&gt;
&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
&lt;sealEDINum&gt;SHSEAL2&lt;/sealEDINum&gt;
&lt;/SealDetails&gt;
&lt;/AllSealDetails&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;receiveDate&gt;11 August 2014&lt;/receiveDate&gt;
&lt;weight&gt;5000.0000&lt;/weight&gt;
&lt;packTempC&gt;-273&lt;/packTempC&gt;
&lt;packTempF&gt;-273&lt;/packTempF&gt;
&lt;bookingRef&gt;UT_BK_0013&lt;/bookingRef&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;commodityDescription&gt;General&lt;/commodityDescription&gt;
&lt;consignee&gt;ABCNE&lt;/consignee&gt;
&lt;consignor&gt;ABCNR&lt;/consignor&gt;
&lt;destinationPort&gt;AUBNE&lt;/destinationPort&gt;
&lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
&lt;fullOrMT&gt;f&lt;/fullOrMT&gt;
&lt;id&gt;MAEU2222222&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/Train&gt;
&lt;/AllTrain&gt;
&lt;/JMTInternalTrainConsist&gt;
';
//&lt;id&gt;MAEU1111111&lt;/id&gt;

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 10, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem("MAEU1111111");
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal1", "Incorrect Terminal Operator Seal");
	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Terminal Operator Seal");
epilog
//	process.profiler.stop();
//	process.profiler.report();
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTrainConsistAction" id="4ad4ab9b-419e-417b-af92-be2505a18b06">
        <source>tTrainConsistAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalTrainConsist";
	TRAIN : String = "UTTRAIN01";
	WAGON : String = "UTWAGON_01";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	train : CM_Train;
	wagon : CM_Wagon;
	carrier : CM_Carrier;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	now : TimeStamp;
begin
	self.setTerminalConfig(EdiGateDocInvConsignor, false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	wagon := self.getWagon(WAGON, train);
	self.deleteWagonAndAssociatedObjs(wagon);
	self.tTrainAction();
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	carrier := app.myRoot.allCarriers["ABC"];
	self.assertIsDeleted(wagon);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTrainConsist xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTrainConsist.xsd"&gt;
	&lt;AllTrain&gt;
		&lt;Train&gt;
			&lt;description&gt;Stuff&lt;/description&gt;
			&lt;fullOrMT/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;scheduleCode/&gt;
			&lt;trainCode&gt;'&amp;TRAIN&amp;'&lt;/trainCode&gt;
			&lt;trainDestination/&gt;
			&lt;trainOrigin/&gt;
			&lt;scheduledArrivalDT&gt;'&amp;now.asStringJMT&amp;'&lt;/scheduledArrivalDT&gt;
			&lt;scheduledDepartureDT/&gt;
			&lt;AllWagon&gt;
				&lt;Wagon&gt;
					&lt;maxCargoHeight/&gt;
					&lt;maxCargoWeight/&gt;
					&lt;tareWeight/&gt;
					&lt;carrierCode&gt;'&amp;carrier.code&amp;'&lt;/carrierCode&gt;
					&lt;description/&gt;
					&lt;fullOrMT/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;trainCode&gt;'&amp;TRAIN&amp;'&lt;/trainCode&gt;
					&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
					&lt;wagonNumber&gt;'&amp;WAGON&amp;'&lt;/wagonNumber&gt;
					&lt;wagonSeals&gt;:WAGON SEAL=WSeal01:&lt;/wagonSeals&gt;
					&lt;scheduledArrivalDT&gt;'&amp;now.asStringJMT&amp;'&lt;/scheduledArrivalDT&gt;
					&lt;AllPrenote&gt;
						&lt;Prenote&gt;
							&lt;curtainsIn/&gt;
							&lt;hasRadio/&gt;
							&lt;isControlledAtmosphere/&gt;
							&lt;isNew/&gt;
							&lt;isWeightCertified/&gt;
							&lt;offsiteCleaned/&gt;
							&lt;offsitePreTrip/&gt;
							&lt;onPowerDuringTransit/&gt;
							&lt;selfPropelled/&gt;
							&lt;updateVGMOnly/&gt;
							&lt;certificate1Expiry/&gt;
							&lt;certificate2Expiry/&gt;
							&lt;docsCleared/&gt;
							&lt;docsReceived/&gt;
							&lt;docsReturned/&gt;
							&lt;docsSent/&gt;
							&lt;expectedArrivalDate/&gt;
							&lt;expiryDate/&gt;
							&lt;packDate/&gt;
							&lt;receiveDate/&gt;
							&lt;transitOnPowerDate/&gt;
							&lt;cargoWeight/&gt;
							&lt;height/&gt;
							&lt;length/&gt;
							&lt;overHeight/&gt;
							&lt;overLengthBack/&gt;
							&lt;overLengthFront/&gt;
							&lt;overWidthLeft/&gt;
							&lt;overWidthRight/&gt;
							&lt;tareWeight/&gt;
							&lt;timeAllowedOffPower/&gt;
							&lt;vent/&gt;
							&lt;volume/&gt;
							&lt;weight&gt;40000&lt;/weight&gt;
							&lt;width/&gt;
							&lt;availabilityGrade/&gt;
							&lt;carbonDioxide/&gt;
							&lt;coolingType/&gt;
							&lt;doors/&gt;
							&lt;humidity/&gt;
							&lt;oxygen/&gt;
							&lt;parentCargoTypeCode/&gt;
							&lt;productQuantity/&gt;
							&lt;totalQuantity/&gt;
							&lt;voltageType/&gt;
							&lt;year/&gt;
							&lt;packTempC/&gt;
							&lt;packTempF/&gt;
							&lt;temperature/&gt;
							&lt;alternativeId/&gt;
							&lt;availabilityGradeDesc/&gt;
							&lt;bol/&gt;
							&lt;bookingRef/&gt;
							&lt;carType/&gt;
							&lt;cargoGroupId/&gt;
							&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
							&lt;carrierCode&gt;'&amp;carrier.code&amp;'&lt;/carrierCode&gt;
							&lt;certificate1/&gt;
							&lt;certificate2/&gt;
							&lt;chassisNo/&gt;
							&lt;clientRef/&gt;
							&lt;colour/&gt;
							&lt;commodity/&gt;
							&lt;commodityDescription/&gt;
							&lt;consignee/&gt;
							&lt;consignor/&gt;
							&lt;consignorVoyage/&gt;
							&lt;customExportEntryNumber/&gt;
							&lt;customsAgent/&gt;
							&lt;customsReference/&gt;
							&lt;customsSeal/&gt;
							&lt;description/&gt;
							&lt;destinationPort/&gt;
							&lt;destinationTerminal/&gt;
							&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
							&lt;eirNumber/&gt;
							&lt;engineNo/&gt;
							&lt;freightForwarder/&gt;
							&lt;fullOrMT/&gt;
							&lt;generatorType/&gt;
							&lt;heatTreated/&gt;
							&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
							&lt;imexStatus/&gt;
							&lt;invoiceNumber/&gt;
							&lt;isExternallyMonitored/&gt;
							&lt;isoType&gt;4102&lt;/isoType&gt;
							&lt;isoTypeGroup/&gt;
							&lt;loadPort/&gt;
							&lt;locationId/&gt;
							&lt;make/&gt;
							&lt;mark/&gt;
							&lt;markNumber/&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;model/&gt;
							&lt;operatorCode&gt;'&amp;OPERATORCODE&amp;'&lt;/operatorCode&gt;
							&lt;operatorImportReleasePIN/&gt;
							&lt;orderNumber/&gt;
							&lt;palletType/&gt;
							&lt;parentCargoID/&gt;
							&lt;parentCargoType/&gt;
							&lt;product/&gt;
							&lt;registration/&gt;
							&lt;remarks/&gt;
							&lt;sealNum/&gt;
							&lt;sealNumberVent/&gt;
							&lt;sealShipper/&gt;
							&lt;sealTerminalOperator/&gt;
							&lt;sealUnknown/&gt;
							&lt;serviceOrder/&gt;
							&lt;shippingLineCode/&gt;
							&lt;statusString/&gt;
							&lt;storeOnPallet/&gt;
							&lt;subTerminalCode/&gt;
							&lt;trackingNumber1/&gt;
							&lt;trackingNumber2/&gt;
							&lt;trailerType/&gt;
							&lt;transportMode&gt;RAIL&lt;/transportMode&gt;
							&lt;vehicle/&gt;
							&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
							&lt;vgmAuthSignature/&gt;
							&lt;vgmCommsType/&gt;
							&lt;vgmDocumentDetails/&gt;
							&lt;vgmEDITransmission/&gt;
							&lt;vgmElectronicMail/&gt;
							&lt;vgmMail/&gt;
							&lt;vgmPhone/&gt;
							&lt;vgmTelefax/&gt;
							&lt;vgmTelephone/&gt;
							&lt;vin/&gt;
							&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
							&lt;wagonClass/&gt;
							&lt;wagonNumber&gt;'&amp;WAGON&amp;'&lt;/wagonNumber&gt;
							&lt;weightCertifiedName/&gt;
							&lt;weightCertifiedReference/&gt;
							&lt;expectedArrivalTime/&gt;
							&lt;packTime/&gt;
							&lt;transitOnPowerTime/&gt;
							&lt;vgmDeterminationDT/&gt;
							&lt;vgmDocsIssuedDT/&gt;
							&lt;AllSealDetails&gt;
								&lt;SealDetails&gt;
								&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
								&lt;messageMode&gt;A&lt;/messageMode&gt;
								&lt;sealEDINum&gt;SEAL01&lt;/sealEDINum&gt;
								&lt;sealEDIType&gt;OPER&lt;/sealEDIType&gt;
								&lt;/SealDetails&gt;
							&lt;/AllSealDetails&gt;
						&lt;/Prenote&gt;
					&lt;/AllPrenote&gt;
				&lt;/Wagon&gt;
			&lt;/AllWagon&gt;
		&lt;/Train&gt;
	&lt;/AllTrain&gt;
&lt;/JMTInternalTrainConsist&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	self.assertEqualMsg(train.description, "Stuff", "wrong description");
	wagon := self.getWagon(WAGON, train);
	self.assertNotNull(wagon);
	self.assertEqualMsg(wagon.getSealNumbersOnly, "WSeal01", "wrong seal Number");
	self.assertEqualMsg(wagon.myCarrier, carrier, "wrong carrier");
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong remarks");
end;
</source>
