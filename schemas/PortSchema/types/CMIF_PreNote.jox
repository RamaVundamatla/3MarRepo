    <JadeMethod name="moveToRailNew" id="7ca1d657-f2b7-4376-8fd4-745386af6c39">
        <source>moveToRailNew(_passport : CM_Passport input);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
//This places the TI on the nominated wagon
//AA 21/5/01: Even if there is no wagon passed in...
vars
	ti : CM_TrackedItem;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
begin

	//27 Feb 2015	NDL	Par 35499
	if self.isChild then
		return;
	endif;

	ti := self.myPersistentTrackedItem;
	
	if ti = null then		//Should always have one of these
		app.raiseCMException1(ERR_NO_OBJECT,"myPersistentTrackedItem in CMIF_PreNote","", null); 
		return;
	endif; 

	create  wagonUpdateCtrl transient;	
	wagonUpdateCtrl.allTrackedItems.add(ti);
	wagonUpdateCtrl.wagonCode := self.wagon;
	wagonUpdateCtrl.myWagonClass := self.myWagonClass;	//12 May 2014	NDL	Par 33615
	wagonUpdateCtrl.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 59837
	wagonUpdateCtrl.actionForPrenote(_passport, self.slotNumber);
	
epilog
	delete wagonUpdateCtrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveToShip" id="145643b2-be04-4673-91a6-160b36ab0ebe">
        <updating/>
        <source>moveToShip(_passport : CM_Passport input) updating;
/*
This plonks the prenoted TI physically onto the ship. Remember that ship 'prenotes'are real TIs that get placed aboard when created
30 Jun 2025 navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	toTgtStr 			: String;
	createTrans,
	isOperational 		: Boolean;
	voy 				: CM_Voyage;
	locn 				: CM_LocationsController; 
	foundHeight     	: Integer;
	isVoyHOLDSorSHIP	: Boolean;
begin
	
	exclusiveLock(self.myPersistentTrackedItem);
	
	if stowageLocation &lt;&gt; null and stowageLocation.pos(voyageCode,1) = 1 then	//30 Jul 2013	NDL	Par 31702
		toTgtStr := stowageLocation.trimBlanks;
	else
		toTgtStr := voyageCode.trimBlanks &amp; " " &amp; stowageLocation.trimBlanks;
	endif;
	
	self.myTerminal.findLocationFromString(toTgtStr, false, locn, foundHeight);
	
	if locn = null then 
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, toTgtStr, null, null);
		return;
	endif;
	
	voy := self.myTerminal.lookupVoyage(voyageCode.trimBlanks, null, false);
	
	if voy = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, null, null);
		return;
	endif;
	//-------------------
	//We only create transactions if a non-worked voyage (This means the Box is actually there!)
	//If its a non-worked voyage then they are putting the box on, and want export stats
	//-------------------
	
	
	isVoyHOLDSorSHIP	:= voy.isHOLDSorSHIP();			//30.06.2025 navma1 #MTN-34090
	createTrans 		:= isVoyHOLDSorSHIP;			//30.06.2025 navma1 #MTN-34090
	if createTrans then
		// PAR 33644  and  not isPlannedRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
		//overwrite depending on what the users are doing. This is passed in from the UI.
		//Basically we need to know if we build transactions (the box was released), or its being
		//simply placed so it can be discharged by the ops process.
		if self.nonWorkedReleaseType = TransactionedMoveType then
			//Set the box as an export.
			isOperational := createTrans;	//We WANT an operational move if its a non-worked voyage
			self.myPersistentTrackedItem.setImExStatus(TI_IMEX_STATUS_EXPORT);
		else
			createTrans   := false;
			isOperational := false;
			//Leave as a transit.
		endif;
	endif;	

	//PAR 1345 AA 29/8/01: Set items for discharge here to be imports. This is because these
	//types of voyage do not have a colour code that resets the status to import, and discharge of
	//transits does not generate the correct charges
	// PAR 33644	if (voy.isNonPlannedVoyage or voy.isNonWorkedVoyage) and
	// PAR 33644	   not isPlannedRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
	if isVoyHOLDSorSHIP then		//30.06.2025 navma1 #MTN-34090
		if self.myPersistentTrackedItem.dischargePort = self.myTerminal.getConfig(PortDestCode).String then
			self.myPersistentTrackedItem.setImExStatus(TI_IMEX_STATUS_IMPORT);
		endif;
	endif;	
	
	//---------------------
	//Do the actual move
	//---------------------
	self.myPersistentTrackedItem.moveToLocation(locn, null, null, null, REAL_MODE, true, isOperational, false, false, false, false, null, null, null, null, null, _passport);	// TFS 2651

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sendNotificationEmail" id="8b30c678-5fec-480a-8668-af97c31ff28f">
        <source>sendNotificationEmail(_ti : CM_TrackedItem);
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	Delim = ',';
vars
	email 				: CM_EmailTemplate;
	sender,
	emailAddress,
	emailAddresses	: String;
	nextPos,
	tmpPos,
	counter : Integer;
	
begin

	nextPos := 1;
	counter :=0;
	emailAddress :='';
	emailAddresses := app.myPassport.myTerminal.getAutoPlanPreNotifyEmail();   //SFW1030 04/08/2008
	if emailAddresses = null then //cnwrs1 Par 20082 dont produce a blank address email
		return;
	endif;
	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	while (true) do
		tmpPos := nextPos;
		if emailAddress = null then //cnwrs1 Par 20082 dont produce a blank address email
			emailAddress := emailAddresses.cnEcNextDelimitedField(Delim, nextPos).trimBlanks() &amp; ';';
		else
			emailAddress := emailAddress &amp; emailAddresses.cnEcNextDelimitedField(Delim, nextPos).trimBlanks() &amp; ';';
		endif;
		if tmpPos &gt;= nextPos or counter = 100 then
			break;
		endif;
		counter := counter +1; // counter is for safty.
	endwhile;
		
	app.myUtilityCA.utlCreateEmailSendRequest(true, _ti.id &amp; ' Could not be auto planned to a yard location.',emailAddress, sender, null, null,_ti.id &amp; ' Could not be auto planned to a yard location.',
						 						'Could not auto plan item ' &amp; _ti.id &amp; ' to a yard location', null, null, null, null,EmailSource_System, null, app.myPassport);
												
		

	

end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
