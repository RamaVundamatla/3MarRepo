    <JadeMethod name="getNumTIs" id="1c17b2d9-8223-45ac-a35c-f3c2a18bba15">
        <source>getNumTIs(_mode : Integer): Integer;
// returns each 40' once not twice as numTIs does
// NOTE: this is slow  as it has to check each ti
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	count : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
	futureMove : CM_FutureMove;
 	deepCount : Boolean;
begin

	deepCount := self.deepCountTrackedItems;
	
	if _mode = REAL_MODE then
		if self.allTrackedItems.isEmpty then
			return 0;
		endif;
		iter := self.allTrackedItems.createIterator();
		while iter.next(ti) do
			
			if not ti.isLCBackEnd(self, _mode) then
 				if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endwhile;
	elseif _mode = PLANNING_MODE then
		if self.allPlannedFutureMoves.isEmpty then
			return 0;
		endif;
		foreach futureMove in self.allPlannedFutureMoves do
			ti := futureMove.getTrackedItem();
			
			if not ti.isLCBackEnd(self, _mode) then
	 			if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endforeach;
	elseif _mode = QUEUE_MODE then
		if self.allQueuedFutureMoves.isEmpty then
			return 0;
		endif;
		foreach futureMove in self.allQueuedFutureMoves do
			ti := futureMove.getTrackedItem();
			
			if not ti.isLCBackEnd(self, _mode) then
 				if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endforeach;
	endif;
	return count;
epilog
	delete iter; //epr par 18417 3/11/08
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
