    <JadeMethod name="initFilterTable" id="3b3c8980-b9a5-456d-869c-955130f31b8a">
        <updating/>
        <source>initFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars
	entTableDef		: EntTableDef;
	businessUnits	: CM_CompanyByCodeDict;
	comboBank 		: CMUI_ComboBox;
	company,
	currentBU		: CM_Bank;
begin
	
	create businessUnits transient;
	
	comboBank := self.cmbBank;
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvSvcTypeSearch);
	
	if entTableDef &lt;&gt; null then
		tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		tblSearch.adjustHeight(200);
		tblSearch.accessColumn(1).width := 100;
	endif;
	
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	
	foreach company in self.myTerminal.companies where company.isBusinessUnit do
		comboBank.addItem(company.code);
		comboBank.itemObject[comboBank.newIndex] := company;
	endforeach;
	
	if currentBU &lt;&gt; null then
		comboBank.listObject := currentBU;
	endif;
	
epilog
	delete businessUnits;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="be834ef5-e220-4c36-9166-1246075f6c1a">
        <updating/>
        <source>initForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars
	glcode			: CM_GLCode;
	service			: CM_ServiceObject;
	serviceSet		: CM_ObjectSet;
begin

	// Init Data table Ent detail
	self.initTblEntDetail();
	// Init GL Code Combobox
	self.initGLCombo();
	// Init Multi Select Group
	self.initMSG();
	
	create serviceSet transient;
	
	foreach glcode in self.myCurrentBank.glCodes where not glcode.isNotAvailableForEntry do
		foreach service in glcode.services where not service.isNotAvailableForEntry and service.isKindOf(CM_Service) do
			serviceSet.add(service);
		endforeach;
	endforeach;
	
	self.msgServices.setAvailable(serviceSet, true);
epilog
	delete serviceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="initGLCombo" id="6d99b6bd-dc79-47b6-a5b0-767b25f44dab">
        <source>initGLCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	tmpGLCode		: CM_GLCode;
	theCmbBox		: CMUI_ComboBox;

begin
	// Set the combobox
	theCmbBox := self.cmbGLCode;
	theCmbBox.clear();
	// Populate GL Code to Combobox
	foreach tmpGLCode in self.myCurrentBank.glCodes where not tmpGLCode.isNotAvailableForEntry and tmpGLCode.services.size() &gt; 0 do
		theCmbBox.addItemObject(tmpGLCode.code ,tmpGLCode);
	endforeach;
	
	// Add empty option to first item;
	theCmbBox.addItemAt("", 1);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initMSG" id="59e80e52-0d42-4d83-a71b-211a52cee185">
        <source>initMSG();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars
	theGroupBox		: CMUI_MultiSelectGroupBox;
	
begin
	
	theGroupBox 							:= self.msgServices;
	theGroupBox.caption 					:= null;
	theGroupBox.lockBottom 					:= false;
	theGroupBox.lockRight					:= false;
	theGroupBox.stretchHeight 				:= true;
	theGroupBox.stretchWidth 				:= true;
	theGroupBox.multiSelect 				:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName 	:= "displayService";
	theGroupBox.availableHeading 			:= app.getErrorString(Available_services);
	theGroupBox.selectedHeading 			:= app.getErrorString(Selected_services);
	theGroupBox.myBaseForm					:= self;
	theGroupBox.mySelectedListBox.sorted	:= false;
	theGroupBox.readOnly 					:= false;
	
	theGroupBox.cnEcResizeContents();
		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="f563eb42-c6db-4d00-a840-f1724754c82d">
        <source>initTblEntDetail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	
begin
	
	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvSvcTypeMaint);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="fbfe4dab-0b8e-4ad9-999f-c4afae281a48">
        <updating/>
        <source>populateEntDetailTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	entDef				: EntTableDef;
	entRow 				: EntTableRow;
	serviceType			: CM_ServiceType;
	displayValue		: String;
begin

	entDef := app.myController.getEntTableDef(ETDef_InvSvcTypeMaint);
	
	serviceType := self.myCurrentObject.CM_ServiceType;
	
	if serviceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		self.tblEntDetail.showRowByName(entRow.name, false);
		
		if serviceType &lt;&gt; null then
			displayValue := serviceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		self.tblEntDetail.setValueByName(entRow.name, displayValue);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="b2a90d8d-a43f-4aa2-ba83-3aa8bc5d7c96">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		self.tblEntDetail.setFocus();
		self.tblEntDetail.goToRowByName(ETRow_Code);
		self.msgServices.mySelectedListBox.clear();
	elseif self.mode = Mode_Update then
		self.populateEntDetailTable();
	endif;
	
	self.tblEntDetail.enabled := true;
	self.cmbGLCode.enabled := true;
	self.msgServices.enabled := true;
	self.initGLCombo();
	self.setServiceAvailable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="e0e375a7-a806-4c16-9c96-c64272084898">
        <updating/>
