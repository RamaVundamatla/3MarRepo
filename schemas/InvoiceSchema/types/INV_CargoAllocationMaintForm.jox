    <JadeMethod name="createFromNote" id="155ca42d-3c77-4e39-bc5f-5043ac96346e">
        <source>createFromNote(_alloc : CM_InvoiceCargoAllocation);
/*

Purpose:			// TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	idx : Integer;
begin
		idx := self.tblData.addItemObject(_alloc,  _alloc.description  &amp; Tab &amp; 
										  _alloc.getDescriptionTransaction() &amp; Tab &amp; 
										  _alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
										  _alloc.getNumberOfMappings().asStringJMT() ); 
epilog

end;</source>
        <Parameter name="_alloc" type="CM_InvoiceCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="30977da4-80a6-41c4-a5ef-1a3275204f48">
        <updating/>
        <source>doDelete() updating;
/*
Purpose:			
Date		Who		Reason
17 March 2015	cnwab1	Initial creation
*/

vars

	result 					: Integer;
begin	
	if self.myCurrentAllocation = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Please_confirm_deletion, self.myCurrentAllocation.description), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then 
		return;
	endif;

	while true do
		app.myTrxDA.trxDeleteInvoiceCargoAlloc(self.myCurrentAllocation);  // ### TFS 51219 25MAY2021 NAVAB1
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myCurrentAllocation := null;
 // TFS 7496			self.populateTable();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Allocation), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="1701b469-c8c5-4b74-a37d-bab816c6f0c5">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.btnNew.enabled 		:= false;
	self.btnDelete.enabled 		:= false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNote" id="1623f888-7534-41fb-89fe-b58ea7587c44">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
18 March 2015	cnwab1	Initial creation
*/

vars
	event : Integer;
	alloc : CM_InvoiceCargoAllocation;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_INVCARGOALLOC_UPDATE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceCargoAllocation) then
				alloc := userInfo.CM_InvoiceCargoAllocation;
				self.updateFromNote(alloc);
			else
				self.populateTable();
			endif;
	
	endif;
	
	if event = EVENT_INVCARGOALLOC_CREATE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceCargoAllocation) then
				alloc := userInfo.CM_InvoiceCargoAllocation;
				self.createFromNote(alloc);
			else
				self.populateTable();
			endif;
	
	endif;
	
	if event = EVENT_INVCARGOALLOC_DELETE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceCargoAllocation) then
				alloc := userInfo.CM_InvoiceCargoAllocation;
				self.tblData.removeDeletedObject(alloc);
			else
				self.populateTable();
			endif;
				

	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="f63c5e38-2043-4c62-801a-6684f5f1d74c">
        <source>initTable();
/*
Purpose:			
Date		Who		Reason
17 Mar 2015	cnwab1	Initial creation
30 May 2017	cnwkpd1	TFS #4542 - Add Priority column to the table
*/

vars

begin
	self.tblData.rows := 0;
	self.tblData.columns := 4;// TFS 6536
	self.tblData.selectMode := Table.SelectMode_WholeRows; // TFS 7496
// TFS 6536	self.tblData.addItem(app.getErrorString(Allocation) &amp; Tab &amp; app.getErrorString(Priority) &amp; Tab &amp; app.getErrorString(Transaction));



	// If you change this order you must change tblData_dblClick which sets the priority column to be numeric
	self.tblData.addItem(app.getErrorString(Allocation) &amp; Tab &amp; 
								app.getErrorString(Transaction) &amp; Tab &amp; 
								app.getErrorString(Priority) &amp; Tab &amp; 
								app.getErrorString(Mapping)
								);

	self.tblData.fixedRows := 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="e8f80bf8-9bab-432b-ade3-d5150f3e6431">
        <source>populateTable();
/*

Purpose:			

Date		Who		Reason
17 Mar 2015	cnwab1	Initial creation
30 May 2017	cnwkpd1	TFS #4542 - Add Priority column to the table, and list in Priority order
15 Nov 2017 	CNWAB1	TFS 7496 - refactored whole table
*/

vars
	alloc : CM_InvoiceAllocation;

	ya : CM_YardAllocation;
	listbox : CMUI_ListBox;
	idx, size : Integer;
	qrm : CM_QuantityRangeMap;
begin
	self.tblData.rows := self.tblData.fixedRows;

	if self.myCurrentTransactionMap &lt;&gt; null then
		foreach ya in self.myCurrentTransactionMap.allInvoiceCargoAllocByPriority discreteLock do
			alloc := ya.CM_InvoiceAllocation;
			
		
			
			idx := self.tblData.addItemObject(alloc,  alloc.description  &amp; Tab &amp; 
											  alloc.getDescriptionTransaction() &amp; Tab &amp; 
											  alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
											  alloc.getNumberOfMappings().asStringJMT() 
											  ); 
			
		endforeach;
	elseif self.myCurrentTanMapInventory &lt;&gt; null then // ### TFS 51219 03JUN2021 NAVAB1
		foreach ya in self.myCurrentTanMapInventory.allInvoiceAllocByPriority discreteLock do
			alloc := ya.CM_InvoiceAllocation;
			
		
			
			idx := self.tblData.addItemObject(alloc,  alloc.description  &amp; Tab &amp; 
											  alloc.getDescriptionTransaction() &amp; Tab &amp; 
											  alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
											  alloc.getNumberOfMappings().asStringJMT() 
											  ); 
			
		endforeach;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6ebe0264-e935-4ba1-bed8-921291da96fb">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
11 March 2015	cnwab1	Initial creation
04/05/2023		navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/

vars
	caption : String;
	tranmap : CM_Object;
begin
	inheritMethod();
	
	 // ### TFS 51219 25MAY2021 NAVAB1
	if self.myCurrentTransactionMap &lt;&gt; null then
		caption := self.myCurrentTransactionMap.description &amp; " - " &amp; app.getErrorString(Cargo_invoice_allocation);
		tranmap := self.myCurrentTransactionMap;
	elseif self.myCurrentTanMapInventory &lt;&gt; null then
		caption := self.myCurrentTanMapInventory.description &amp; " - " &amp; app.getErrorString(Inventory_allocations);
		tranmap := self.myCurrentTanMapInventory;
	endif;
	
	self.setCaption(caption); // ### TFS 51219 25MAY2021 NAVAB1
	
	self.initTable();
	
	self.populateTable();
	
	// 04/05/2023	navkc1	Bug 57484 
	self.doNoMaintPermDisableControls();
	
	 // ### TFS 51219 25MAY2021 NAVAB1
	self.beginNotification(tranmap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE), Response_Continuous, null); 
	self.beginNotification(tranmap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), Response_Continuous, null); 
	self.beginNotification(tranmap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_CREATE), Response_Continuous, null);
	
	self.frmTabelFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
