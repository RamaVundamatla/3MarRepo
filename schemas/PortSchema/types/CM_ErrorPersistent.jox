    <JadeMethod name="getErrorText" id="624d0187-52af-4047-80f9-78fedb48e61d">
        <source>getErrorText() : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.text[self.text.pos(self.errorCode.String,1) + self.errorCode.String.length() + 2 : end].trimBlanks(); // Remove "Code 12345 - "
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="7a4defdc-5443-4e07-b768-c11118f40879">
        <source>getStatusString() : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.status = CM_ErrorPersistent.Status_Closed then
		return "Closed";
	elseif self.status = CM_ErrorPersistent.Status_Ignore then
		return "Ignore";
	elseif self.status = CM_ErrorPersistent.Status_Open then
		return "Open";
	else
		return "Unknown";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="c2bd2afa-409a-4f2d-b902-6d0e5ab5eeee">
        <source>getTypeString() : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.type = CM_ErrorPersistent.Type_Error then
		return "Error";
	elseif self.type = CM_ErrorPersistent.Type_Statement then
		return "Statement";
	elseif self.type = CM_ErrorPersistent.Type_Warning then
		return "Warning";
	else
		return "Unknown";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasTrouble" id="1fb101ed-c0d3-4354-a5e9-b785ec2b5ee0">
        <source>hasTrouble() : Boolean;
// ---------------------------------------------------------------------------
// Created:     14 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.isStatement() then // Statement
		return false;
	endif;
	if self.isError() and self.isClosed() then // closed error
		return false;
	elseif self.isWarning() and self.isIgnored() then // ignored warning
		return false;
	elseif self.isWarning() and self.isClosed() then // closed warning
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="identity" id="ee687d7b-d8d6-45cc-9831-0db636780308">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.transactionNum &amp; " " &amp; self.errorCode.String;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="92f8d94f-9145-4cc0-bd24-0a3632adce67">
        <updating/>
        <source>init(_vvr : CM_VehicleVisitRecord; _tranNum : String; _gateEntity : CMGTE_Entity) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.status := CM_ErrorPersistent.Status_Open;
	self.transactionNum := _tranNum;
	self.myGateEntity := _gateEntity;
	self.myVehicleVisit := _vvr;
	self.userCode := app.myPassport.userCode;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_gateEntity" type="CMGTE_Entity"/>
    </JadeMethod>
