    </JadeMethod>
    <JadeMethod name="lookupAllTIsOfIdCargoType" id="61fe8dbe-1125-4581-849f-f9795bff85ce">
        <source>lookupAllTIsOfIdCargoType(_id : String; _cargoType : Integer; _tis : Btree input; _searchArchivedVoyages, _searchReversed : Boolean; _cmifMonitor : CMIF_Monitor input);
/*
 ------------------------------------------------------------------------
Created:			07 October 2002 by cnwdwq1
Purpose:			Trolls the entire planet, looking for ALL ids == whats passed in.
					The set returned is "clean", that is itr has NO DUPLICATE oids in it.
							
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
---------------------------------------------------------------------------
*/
vars
	upperId, 
	reverseId	: String;
	voy 	: CM_Voyage;
	ls : Boolean;
	tSet : CM_TISet;
begin

//	app.cmsBeginLoad(ls);	//Removed because of duration of load state in this situation DQ 31/05/2004
	ls := process.isInLoadState;
	endLoad;
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tiSet', null, null);
		return;
	endif;
	//--------------------
	//Clear the set
	//--------------------
	_tis.clear; 
	
	create tSet transient;	
	upperId := _id.toUpper.trimBlanks;
	reverseId := upperId.reverse;
	//-----------
	//Grab all offsite 1st
	//-----------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Offsite), 7, 1)) then
			return;
		endif;
	endif;
		
	beginLoad;
	self.lookupAllOffSiteTrackedItems(_cargoType, upperId, tSet, _searchReversed, _cmifMonitor);
	endLoad;

	if (not tSet.isEmpty) then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	tSet.clear;
	//-----------
	//Search on site
	//-----------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Onsite), 7, 2)) then
			return;
		endif;
	endif;
	beginLoad;
	if _cargoType = null then
		self.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allOnsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;
	
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	if _searchReversed or
		tSet.isEmpty then
		tSet.clear;
		beginLoad;
		//Reversed Dictionary
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if _cargoType = null then
			self.allOnsiteTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		else
			self.allOnsiteTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
		endif;
	endif;
	tSet.clear;
	//----------------------
	// TBA Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_TBA), 7, 3)) then
			return;
		endif;
	endif;
	beginLoad;	
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
	if _cargoType = null then
		self.allTbaTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allTbaTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;

	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	if _searchReversed or
		tSet.isEmpty then
		tSet.clear;
		//Reversed Dictionary
		beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if _cargoType = null then
			self.allTbaTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		else
			self.allTbaTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
		endif;
	endif;
	tSet.clear;
	
	//16 Mar 2020	NDL	TFS 47004
	//----------------------
	// RRP Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_TBA), 7, 3)) then
			return;
		endif;
	endif;
	beginLoad;	
	if _cargoType = null then
		self.allRRPTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allRRPTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;

	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	
	tSet.clear;
	
	//----------------------
	//Pre-Notified Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Pre_Notified), 7, 4)) then
			return;
		endif;
	endif;
	beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
	if _cargoType = null then
		self.allNotifiedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allNotifiedTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	if _searchReversed or
		tSet.isEmpty then
		tSet.clear;
		//Reversed Dictionary
		beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if _cargoType = null then
			self.allNotifiedTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		else
			self.allNotifiedTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
		endif;
	endif;
	tSet.clear;
	//----------------------
	// Deleted Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Deleted), 7, 5)) then
			return;
		endif;
	endif;

	beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
	if _cargoType = null then
		self.allDeletedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allDeletedTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	if _searchReversed or
		tSet.isEmpty then
		tSet.clear;
		//Reversed Dictionary
		beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if _cargoType = null then
			self.allDeletedTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		else
			self.allDeletedTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
		endif;
	endif;
	tSet.clear;
	//----------------------
	//Voyages
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Current_Voyages), 7, 6)) then
			return;
		endif;
	endif;
	beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
	self.lookupAllOnShipTrackedItems(upperId, _cargoType, true, false, _searchReversed, _tis, _cmifMonitor);
	endLoad;
	/*
	foreach voy in self.allVoyages do
	 	//Search in each voyage
		voy.lookupAllTrackedItems(upperId, _cargoType, tSet);
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis);
			tSet.clear;
		endif;
	endforeach;
	*/
	//----------------------
	//Archived Voyages
	//----------------------
	if _searchArchivedVoyages then
		if _cmifMonitor &lt;&gt; null then
			if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Archived_Voyages), 7, 7)) then
				return;
			endif;
		endif;

		foreach voy in self.allVoyagesArchived do
			//Search in each archived voyage
			beginLoad;
			if (not voy.lookupAllTrackedItems(upperId, _cargoType, true, _searchReversed, tSet, _cmifMonitor)) then
				break;
			endif;
			endLoad;
			if tSet.isEmpty = false then
				tSet.copyNoDuplicates(_tis, false);
				tSet.clear;
			endif;
		endforeach;
		endLoad;
	endif;
epilog
	delete tSet;
	//app.cmsEndLoad(ls);	//Removed because of duration of load state in this situation DQ 31/05/2004
	if ls and not process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_searchArchivedVoyages" type="Boolean"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupArchivedVoyages" id="d9c8b37d-1e0e-46c5-99ab-b37cb1cd5e66">
        <source>lookupArchivedVoyages(_voyageArray : CM_VoyageArray input; _voyCode : String; _imo : String;
				      _startDate, _endDate : Date);
//--------------------------------------------------------------
//Created: 26 November 2002 By: cnwgd1
//11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
//--------------------------------------------------------------
vars
	voy		: CM_Voyage;
	globalVoyage	: CM_VoyageGlobal;
	iter	: Iterator;
	keyCode	: String;
	arrivalDT : TimeStamp;
	systemStart,
	systemEnd: TimeStamp;
begin
	
	if _voyageArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Dict. Contact Developer.');
		return;
	endif;
	
	// if no search options are set, show all archived voyages
	if (_voyCode = null and _imo = null) and
	   (not _startDate.isValid) and
	   (not _endDate.isValid) then
	   	self.allVoyagesArchived.copy(_voyageArray);
	   	return;
	endif;
	
	if _startDate.isValid() then
		systemStart := self.localToSystemTime(_startDate.TimeStamp);	// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
	else
		systemStart := null;
	endif;
	if _endDate.isValid() then
		systemEnd := self.localToSystemTime((_endDate + 1).TimeStamp);	// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
	else
		systemEnd := null;
	endif;
	
	iter := self.allVoyagesArchived.createIterator;
	if _voyCode &lt;&gt; null then
		self.allVoyagesArchived.startKeyGeq(_voyCode, null, iter);
	endif;

	while iter.next(voy) do
		iter.getCurrentKeys(keyCode,arrivalDT); //MTN-35226
		if _voyCode &lt;&gt; null and (not keyCode.startsWith(_voyCode)) then
			break;
		endif;
		// CCMS 1124 IMO search (in global voyage vesselCode)
		if _imo &lt;&gt; null then
			globalVoyage := voy.getGlobalVoyage();
			if globalVoyage &lt;&gt; null and
			   globalVoyage.vesselCode &lt;&gt; null and
			   globalVoyage.vesselCode &lt;&gt; _imo then
				continue;
			endif;
		endif;
		if systemStart.isValid() then
			if voy.archivedDT &lt; systemStart then	// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
				continue;
			endif;
		endif;
		if systemEnd.isValid() then
			if voy.archivedDT &gt;= systemEnd then		// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
				continue;
			endif;
		endif;
		_voyageArray.add(voy);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageArray" type="CM_VoyageArray" usage="input"/>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_imo" type="String"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="lookupInTransitTI" id="1b311043-6ef3-4150-b17c-ecc13c9d01ce">
        <source>lookupInTransitTI(pId : String; pCargoType: Integer): CM_TrackedItem;
//----------------------------------------------------------------
//	Created:	23 July 2004	by Jason Chapman  (cnwjc2)
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
//----------------------------------------------------------------
vars
	term		: CM_Terminal;
	termDict	: CM_TerminalByCodeDict;
	tmpTI		: CM_TrackedItem;
	iter		: Iterator;
	dict		: CM_TIsInTransitFromByToTypeId;
	keyTerm		: CM_Terminal;
	keyCargoType: Integer;
	keyID		: String;
	pIdLength	: Integer;
begin
	pIdLength := pId.length;
	
	create termDict transient;
	
	self.getOtherTerminals(termDict);
	foreach term in termDict do
		dict := term.allInTransitTIsFromByToTypeId;
		if iter &lt;&gt; null then
			delete iter;
		endif;
		iter := dict.createIterator;
		
		dict.startKeyGeq(self, null, null, iter);
	
			
		while iter.next(tmpTI) do
			iter.getCurrentKeys(keyTerm,keyCargoType,keyID);  //MTN-35226
		
			if keyTerm &lt;&gt; self then
				break;
			endif;
			
			if pCargoType &gt; TI_CargoType_Null
			and pCargoType &gt; keyCargoType then
				break;
			endif;
			
			if keyID = pId then
				//match
				return tmpTI;
			elseif keyID.reverse[1:pIdLength] = pId.reverse then
				return tmpTI;
			endif;
				
		endwhile;	
	endforeach;
	 return null;
epilog
	delete iter;
	delete termDict;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupNumTIMatchesWithId" id="9b4760a2-0f1f-48b2-a816-f7aa13cbf683">
        <source>lookupNumTIMatchesWithId(pId : String; pCargoType : Integer; state : Integer; matches : Integer output)	: CM_TrackedItem;
//This method searches for the appropriate id, be aware that it can be slow because it searches for ALL
//with the id. Be SPECIFIC with what you pass in and it shouldnt be too bad.
//*****************************************
//If you are looking for a single TI, call the lookupTrackedItem method on terminal.
//Params re-arranged to be just like the lookup method.
//*****************************************

//PAR 3730 AJA 25/9/00: Revised to record the number of containers that match the key passed in
//For normal dicts this will always be 1, but reversed dicts could have several that match and
//the user needs a warning when there is more than one
vars
	ti : CM_TrackedItem;
	aDict : CM_TrackedItemDicts;
 	upperId : String;
 	reverseId : String;
 	set : CM_TISet;
begin

	matches := 0;
	upperId := pId.trimBlanks.toUpper;

	ti := self.lookupTrackedItem(upperId, pCargoType, state, null, true);

	if ti &lt;&gt; null then
		matches := 1;	//Only one item matches the key
		return ti;
	endif;
	//-----------------
	//Search for REVERSED key
	//-----------------
	reverseId := upperId.reverse;

	if state = TI_STATE_NORMAL then
		aDict := self.allOnsiteTIsByIdCargoTypeRev;
	elseif state = TI_STATE_NOTIFIED then
		aDict := self.allNotifiedTIsByIdCargoTypeRev;
	elseif state = TI_STATE_TBA then
		aDict := self.allTbaTIsByIdCargoTypeRev;
	else
		// not sure why this was here as a default - put back in if required (RJS - 11/9/01)
		//aDict := self.allOnsiteTIsByIdCargoTypeRev;
	endif;
	if aDict = null then
		return null;	//Handle dicts not yet here...
	endif;

	create set transient;
	aDict.lookupAllTIsUsingIdCargoType(reverseId, pCargoType, set, null);
	if set.isEmpty then
		return null;
	endif;
	matches := set.size;
	return set.first;		
epilog
	delete set;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="state" type="Integer"/>
        <Parameter name="matches" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupOffsiteTrackedItem" id="66c042ee-9147-448c-8807-c4cff60228e2">
        <source>lookupOffsiteTrackedItem(pCargoType : Integer; pId : String; _tryReversed : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwdwq1
//
// Purpose: 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	18 Oct 02		DWQ			Removed index, it is NEVER used to access the TI
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
begin
	theTI := self.allOffsiteTIsByIdCargoType.lookupTIUsingIdCargoType(pId, pCargoType);
	
	if theTI &lt;&gt; null then
		return theTI;
	endif;
	if _tryReversed then
		// Check for reversed
		return self.allOffsiteTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(pId, pCargoType);
	endif;
	
	return null;

end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="_tryReversed" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupOnShipTrackedItem" id="3550b521-4f7b-4b07-80db-8375247906f0">
        <source>lookupOnShipTrackedItem(_id : String; _cargoType : Integer) : CM_TrackedItem;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	upperId	: String;
	voy 	: CM_Voyage;
	ls		: Boolean;
	ti		: CM_TrackedItem;
begin

	upperId := _id.toUpper;
//	app.cmsBeginLoad(ls);
	ls := process.isInLoadState;
	endLoad;
	beginLoad;

	foreach voy in self.allVoyagesByCode discreteLock do
	 	//Search in each voyage
		ti := voy.allOnshipTIsByIdCargoType.getAtKey(upperId, _cargoType);
		if ti = null then
			ti := voy.allOnshipTIsByIdCargoTypeRev.getAtKey(upperId.reverse, _cargoType);
		endif;
		if ti &lt;&gt; null then
			return ti;
		endif;
	endforeach;
	
	return null;
	
epilog
	if ls and not 	process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
//	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupPrenoteByIDExact" id="a24676b8-4f9d-4646-b948-5db96c8bbdbe">
        <source>lookupPrenoteByIDExact(pId : String): CM_TrackedItem;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	upperId,
	reverseId	: String;
	theTI 		: CM_TrackedItem;
	voy 		: CM_Voyage;
begin
	upperId := pId.toUpper;

	theTI := self.allNotifiedTIsByIdCargoType.lookupTIUsingIDExact(upperId);
	return theTI;

end;</source>
        <Parameter name="pId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTIsForIDCargoTypeVoyage" id="bc8fceaa-9018-4753-bc7e-2b896ab6c4c6">
        <source>lookupTIsForIDCargoTypeVoyage( _cargoId : String; _cargoType : Integer; _voyage : CM_Voyage; _allTIs : CM_TISet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2014	cnwmc5	Initial creation

*/

vars
	iter 		: Iterator;
	firstTI,
 	ti			: CM_TrackedItem;
begin
	if _voyage &lt;&gt; null then
		firstTI := _voyage.allOnshipTIsByCargoTypeId.getAtKey(_cargoType, _cargoId);
		if firstTI &lt;&gt; null then
			iter := _voyage.allOnshipTIsByCargoTypeId.createIterator;
			iter.startAtObject(firstTI);
			while iter.next(ti) do
				if ti.id &lt;&gt; _cargoId or ti.cargoType &lt;&gt; _cargoType then
					break;
				endif;
				_allTIs.add(ti);
			endwhile;
		endif;
		firstTI := _voyage.allOnsiteTIsByCargoTypeId.getAtKey(_cargoType, _cargoId);
		if firstTI &lt;&gt; null then
			iter := _voyage.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject(firstTI);
			while iter.next(ti) do
				if ti.id &lt;&gt; _cargoId or ti.cargoType &lt;&gt; _cargoType then
					break;
				endif;
				_allTIs.add(ti);
			endwhile;
		endif;
	endif;
	
	firstTI := self.allOnsiteTIsByCargoTypeId.getAtKey(_cargoType, _cargoId);
	if firstTI &lt;&gt; null then
		iter := self.allOnsiteTIsByCargoTypeId.createIterator;
		iter.startAtObject(firstTI);
		while iter.next(ti) do
			if ti.id &lt;&gt; _cargoId or ti.cargoType &lt;&gt; _cargoType then
				break;
			endif;
			_allTIs.addNoDuplicates(ti, false);
		endwhile;
	endif;
	
	firstTI := self.allNotifiedTIsByCargoTypeId.getAtKey(_cargoType, _cargoId);
	if firstTI &lt;&gt; null then
		iter := self.allNotifiedTIsByCargoTypeId.createIterator;
		iter.startAtObject(firstTI);
		while iter.next(ti) do
			if ti.id &lt;&gt; _cargoId or ti.cargoType &lt;&gt; _cargoType then
				break;
			endif;
			_allTIs.addNoDuplicates(ti, false);
		endwhile;
	endif;
epilog
	//cnwmc5 - 28 Jan 2015 - PAR .....
	if iter &lt;&gt; null then
		delete iter;
	endif;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupTerminalArea" id="1c1511ab-fa9e-48bd-8c72-613672cbd21d">
        <source>lookupTerminalArea(_value : String) : CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:			08 June 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
