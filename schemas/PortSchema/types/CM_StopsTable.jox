    <JadeMethod name="getAuditText" id="8187535d-9cec-4214-a1bc-9eac4dd3d8d4">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     19 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
17 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars
	txt		: String;
	tmpStr	: String;
	//cargoTyp	: CM_CargoBOLType;	//17 Jul 2022	navsj20	TFS 53862
	cargoTyp	: Object;			//17 Jul 2022	navsj20	TFS 53862
	applyArea, preventArea, processArea : Integer;
	stopTableTemplate : CM_StopTableTemplate;
	invalid 		: Boolean;
	criteria : CM_YACriteria;
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	on Exception do app.handleDeletedObject(exception, cargoTyp, invalid);
	//foreach cargoTyp in self.allCargoTypesNew do																			//17 Jul 2022	navsj20	TFS 53862
	if self.myStopCriteria &lt;&gt; null then																			//17 Jul 2022	navsj20	TFS 53862
		foreach criteria in self.myStopCriteria.allCriteria do
			if tmpStr = null then
				tmpStr := criteria.getDescription();
			else
				tmpStr := tmpStr &amp; ', ' &amp; criteria.getDescription;
			endif;
		endforeach;
/*		foreach cargoTyp in self.myStopCriteria.allCriteria.first.CM_YACriteria.myYAData.CM_YADataObjects.allObjects where cargoTyp.isKindOf(CM_CargoBOLType) do		//17 Jul 2022	navsj20	TFS 53862
	
	//		if not global.isValidObject(cargoTyp) then
	//			continue;
	//		endif;
				if tmpStr = null then
					//tmpStr := cargoTyp.abbreviation;					//17 Jul 2022	navsj20	TFS 53862
					tmpStr := cargoTyp.CM_CargoBOLType.abbreviation;	//17 Jul 2022	navsj20	TFS 53862
				else
					//tmpStr := tmpStr &amp; ', ' &amp; cargoTyp.description;					//17 Jul 2022	navsj20	TFS 53862
					tmpStr := tmpStr &amp; ', ' &amp; cargoTyp.CM_CargoBOLType.description;		//17 Jul 2022	navsj20	TFS 53862
				endif;
		endforeach;*/
	endif;
	txt := txt &amp; 'Cargo Types selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
//	foreach stopTableTemplate in self.allStopTableTemplates do
//		txt := txt &amp; stopTableTemplate.getAuditText();
//	endforeach;
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypesAsStr" id="f637bb19-fbbb-4ce1-a22f-2fc3fd02a587">
        <source>getCargoTypesAsStr(_delim : String; _attrName : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Feb 2022	navma1	Initial creation ChangeRequest 52930: MTN - Stops Data Table - Cargo Types
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars
	str  	: String;
	obj  	: Object;
	iter 	: Iterator;
	invalid : Boolean;
	criteria : CM_YACriteria;
begin
	
	on Exception do app.handleDeletedObject(exception, obj, invalid); 
	//if self.allCargoTypesNew.isEmpty then
	if self.myStopCriteria &lt;&gt; null then									//27 Jul 2022	navsj20	TFS 53862
		foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType and criteria.myYAData.CM_YADataObjects.allObjects.isEmpty  
		and criteria.myYAData.CM_YADataObjects.allObjects.isEmpty do	//27 Jul 2022	navsj20	TFS 53862
			return null;
		endforeach;														//27 Jul 2022	navsj20	TFS 53862
	endif;
	
	
	
	//iter:=self.allCargoTypesNew.createIterator;		//17 Jul 2022	navsj20	TFS 53862
	if self.myStopCriteria &lt;&gt; null then					//17 Jul 2022	navsj20	TFS 53862
		foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType and criteria.myYAData.CM_YADataObjects.allObjects.isEmpty do	//27 Jul 2022	navsj20	TFS 53862
			iter := criteria.myYAData.CM_YADataObjects.allObjects.createIterator;	//27 Jul 2022	navsj20	TFS 53862
																			//27 Jul 2022	navsj20	TFS 53862
		while iter.next(obj) do
				if obj.isKindOf(CM_CargoBOLType) then
					invalid := false;
					
				obj.fetchLatest();
				
				if invalid then
					continue;
				endif;
				
				
				if str &lt;&gt; null then
					str := str &amp; _delim;
				endif;
				
				if _attrName = CM_CargoBOLType::abbreviation.name or  _attrName = CM_CargoBOLType::description.name then
					str := str &amp; obj.getPropertyValue(_attrName).String.trimBlanks;
				else 
					str := str &amp; obj.CM_CargoBOLType.abbreviation &amp; ' - ' &amp;  obj.CM_CargoBOLType.description;
				endif;
			endif;
		endwhile;			//17 Jul 2022	navsj20	TFS 53862
		endforeach;
	endif;					//17 Jul 2022	navsj20	TFS 53862
	return str;
epilog
	delete iter;
end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetails" id="148b88eb-235e-4bca-91bf-5b294961a951">
        <source>getDetails() : String;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars
	str : String;
	type : Integer;
	//cargoType : CM_CargoBOLType;	//20 Jul 2022	navsj20	TFS 53862
	cargoType : Object;				//20 Jul 2022	navsj20	TFS 53862
	stopTableTemplate : CM_StopTableTemplate;
	voyage : CM_Voyage;
	invalid 		: Boolean;
	criteria : CM_YACriteria;
begin
	str := '&lt;'&amp;self.class.name&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::id.name&amp;'&gt;'&amp;self.id.String&amp;'&lt;/'&amp;CM_StopsTable::id.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::code.name&amp;'&gt;'&amp;self.code&amp;'&lt;/'&amp;CM_StopsTable::code.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::shortHeading.name&amp;'&gt;'&amp;self.shortHeading&amp;'&lt;/'&amp;CM_StopsTable::shortHeading.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::heading.name&amp;'&gt;'&amp;self.heading&amp;'&lt;/'&amp;CM_StopsTable::heading.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::isNotAvailableForEntry.name&amp;'&gt;'&amp;self.isNotAvailableForEntry.String&amp;'&lt;/'&amp;CM_StopsTable::isNotAvailableForEntry.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::allowClearanceExpiryDate.name&amp;'&gt;'&amp;self.allowClearanceExpiryDate.String&amp;'&lt;/'&amp;CM_StopsTable::allowClearanceExpiryDate.name&amp;'&gt;'&amp;CrLf;	// cnwrl1 08/12/2009 PAR 21889
	str := str&amp;'&lt;'&amp;CM_StopsTable::requiresInfo.name&amp;'&gt;'&amp;self.requiresInfo.String&amp;'&lt;/'&amp;CM_StopsTable::requiresInfo.name&amp;'&gt;'&amp;CrLf;
	str := str&amp;'&lt;'&amp;CM_StopsTable::requiresInfoType.name&amp;'&gt;'&amp;self.requiresInfoString()&amp;'&lt;/'&amp;CM_StopsTable::requiresInfoType.name&amp;'&gt;'&amp;CrLf;
	
	//if self.allCargoTypesNew.size &gt; 0 then		//20 Jul 2022	navsj20	TFS 53862
	if self.myStopCriteria &lt;&gt; null then
		foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType and criteria.myYAData.CM_YADataObjects.allObjects.isEmpty 
		and criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 0 do			//27 Jul 2022	navsj20	TFS 53862
			//str := str&amp;'&lt;'&amp;CM_StopsTable::allCargoTypesNew.name&amp;'&gt;';			//20 Jul 2022	navsj20	TFS 53862
			str := str&amp;'&lt;'&amp;CM_StopsTable::myStopCriteria.name&amp;'&gt;';				//20 Jul 2022	navsj20	TFS 53862
			on Exception do app.handleDeletedObject(exception, cargoType, invalid);
			//foreach cargoType in self.allCargoTypesNew do						//20 Jul 2022	navsj20	TFS 53862
			foreach cargoType in criteria.myYAData.CM_YADataObjects.allObjects	where cargoType.isKindOf(CM_CargoBOLType) do	//20 Jul 2022	navsj20	TFS 53862
				//	if global.isValidObject(cargoType) then
				//str := str&amp;cargoType.description&amp;',';							//20 Jul 2022	navsj20	TFS 53862
				str := str&amp;cargoType.CM_CargoBOLType.description&amp;',';			//20 Jul 2022	navsj20	TFS 53862
				//	endif;
			endforeach;		//27 Jul 2022	navsj20	TFS 53862
			//str := str&amp;'&lt;/'&amp;CM_StopsTable::allCargoTypesNew.name&amp;'&gt;'&amp;CrLf;		//20 Jul 2022	navsj20	TFS 53862
			str := str&amp;'&lt;/'&amp;CM_StopsTable::myStopCriteria.name&amp;'&gt;'&amp;CrLf;			//20 Jul 2022	navsj20	TFS 53862
			endforeach;			//27 Jul 2022	navsj20	TFS 53862
	endif;
	foreach stopTableTemplate in self.allStopTableTemplates do
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::myTerminal.name&amp;'&gt;'&amp;stopTableTemplate.myTerminal.code&amp;'&lt;/'&amp;CM_StopTableTemplate::myTerminal.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isMT.name&amp;'&gt;'&amp;stopTableTemplate.isMT.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isMT.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isFull.name&amp;'&gt;'&amp;stopTableTemplate.isFull.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isFull.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isChildIgnore.name&amp;'&gt;'&amp;stopTableTemplate.isChildIgnore.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isChildIgnore.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isChildOnly.name&amp;'&gt;'&amp;stopTableTemplate.isChildOnly.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isChildOnly.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isCoastalIgnore.name&amp;'&gt;'&amp;stopTableTemplate.isCoastalIgnore.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isCoastalIgnore.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isCoastalOnly.name&amp;'&gt;'&amp;stopTableTemplate.isCoastalOnly.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isCoastalOnly.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isTranshipIgnore.name&amp;'&gt;'&amp;stopTableTemplate.isTranshipIgnore.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isTranshipIgnore.name&amp;'&gt;'&amp;CrLf;
		str := str&amp;'&lt;'&amp;CM_StopTableTemplate::isTranshipOnly.name&amp;'&gt;'&amp;stopTableTemplate.isTranshipOnly.String&amp;'&lt;/'&amp;CM_StopTableTemplate::isTranshipOnly.name&amp;'&gt;'&amp;CrLf;
		if stopTableTemplate.allApplyAreas.size &gt; 0 then
			str := str&amp;'&lt;'&amp;CM_StopTableTemplate::allApplyAreas.name&amp;'&gt;';
			foreach type in stopTableTemplate.allApplyAreas do
				str := str&amp;self.convertTypeToString(type)&amp;',';
			endforeach;
			str := str&amp;'&lt;/'&amp;CM_StopTableTemplate::allApplyAreas.name&amp;'&gt;'&amp;CrLf;
		endif;
		if stopTableTemplate.allPreventAreas.size &gt; 0 then
			str := str&amp;'&lt;'&amp;CM_StopTableTemplate::allPreventAreas.name&amp;'&gt;';
			foreach type in stopTableTemplate.allPreventAreas do
				str := str&amp;self.convertTypeToString(type)&amp;',';
			endforeach;
			str := str&amp;'&lt;/'&amp;CM_StopTableTemplate::allPreventAreas.name&amp;'&gt;'&amp;CrLf;
		endif;
		if stopTableTemplate.allProcessAreas.size &gt; 0 then
			str := str&amp;'&lt;'&amp;CM_StopTableTemplate::allProcessAreas.name&amp;'&gt;';
			foreach type in stopTableTemplate.allProcessAreas do
				str := str&amp;self.convertTypeToString(type)&amp;',';
			endforeach;
			str := str&amp;'&lt;/'&amp;CM_StopTableTemplate::allProcessAreas.name&amp;'&gt;'&amp;CrLf;
		endif;
		if stopTableTemplate.allHoldVoyages.size &gt; 0 then //ccms1824 cnwrs1 may 2009
			str := str&amp;'&lt;'&amp;CM_StopTableTemplate::allHoldVoyages.name&amp;'&gt;';
			foreach voyage in stopTableTemplate.allHoldVoyages do
				str := str&amp;voyage.code&amp;',';
			endforeach;
			str := str&amp;'&lt;/'&amp;CM_StopTableTemplate::allHoldVoyages.name&amp;'&gt;'&amp;CrLf;
		endif;
	endforeach;
	str := str&amp;'&lt;/'&amp;self.class.name&amp;CrLf;
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailsForRequiredInfo" id="d5a8636f-3751-4ae9-821c-25c7a7c36c76">
        <source>getDetailsForRequiredInfo(_caption, _currentInfo :String output; _maxLength, _case :Integer output; _ti :CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     par 24342 - provide information for formatting input controls for 
//				extra information required by the receiver
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2010	cnwcs5		par 24342 - allow a null _ti parameter
//16 May 2013	cnwrs1	Par operator ImportReleaspIn is 11 long
// ---------------------------------------------------------------------------
vars

begin
	if self.requiresInfoType = CEDO then
		// in D mast this is stop Id 2 "Customs Export (CEDO)"
		_caption		:= app.getErrorString( CM_CEDO );
		_maxLength		:= CM_TrackedItem::customExportEntryNumber.getLengthForString;
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.customExportEntryNumber; 
		endif;
	elseif self.requiresInfoType = CustomsEntryNumber then
		// in D mast this is stop Id 1 "Customs Import Documents"
		_caption		:= app.getErrorString( CM_Customs_Entry_Number );
		_maxLength		:= CM_TrackedItem::customsEntryNumber.getLengthForString;
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.customsEntryNumber;
		endif;
	elseif self.requiresInfoType = ImportReleasePIN then
		// in D mast this is stop Id 35 "Operator Stop Import Maersk"
		_caption		:= app.getErrorString( CM_Operator_Import_PIN );
		_maxLength		:= 11;		// and usually needs to be exactly 6 long!
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.getOperatorImportReleasePIN();	// usually will be null!
		endif;
	elseif self.requiresInfoType = ExportReleaseNumber then
		// in D mast this is stop Ids 36 "Operator Stop Export Maersk"
		_caption		:= app.getErrorString( CM_Operator_Export_Rel_Number );
		_maxLength		:= 20;
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.getOperatorExpReleaseNo();		// usually will be null!
		endif;
	elseif self.requiresInfoType = DeliveryRelease then
		// in D mast this is stop Id 42 "Delivery Release Stop"
		_caption		:= app.getErrorString( Delivery_Release_Number );
		_case			:= TextBox.Case_Upper;
		_maxLength		:= CM_TrackedItem::deliveryRelease.getLengthForString;
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.deliveryRelease;
		endif;
	elseif self.requiresInfoType = CustomsReference then	//30 Jun 2015	NDL	Par 36543
		_caption		:= app.getErrorString( Customs_reference );
		_case			:= TextBox.Case_Upper;
		_maxLength		:= CM_TrackedItem::customsReference.getLengthForString;
		if _ti &lt;&gt; null then
			_currentInfo	:= _ti.customsReference;
		endif;
	elseif self.requiresInfoType = SOLAS then
		_caption := app.getErrorString(SOLAS_VGM_Details);
		
	endif;
epilog

end;</source>
        <Parameter name="_caption" type="String" usage="output"/>
        <Parameter name="_currentInfo" type="String" usage="output"/>
        <Parameter name="_maxLength" type="Integer" usage="output"/>
        <Parameter name="_case" type="Integer" usage="output"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="49b2e748-497a-414a-b9d6-40cabba717d0">
        <source>getDisplayDetails(_short: Boolean): String;
//ccms1824 cnwrs1 may 2009
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars
	txt		: String;
	tmpStr	: String;
	//cargoTyp	: CM_CargoBOLType;	//17 Jul 2022	navsj20	TFS 53862
	cargoTyp	: Object;			//17 Jul 2022	navsj20	TFS 53862
	applyArea, preventArea, processArea : Integer;
	stopTableTemplate : CM_StopTableTemplate;
	invalid 		: Boolean;
	criteria : CM_YACriteria;
begin
	txt[10000] := '*';
	txt := null;
//	txt := inheritMethod(_short)&amp;CrLf;
//	txt := txt &amp; 'Code ' &amp; '=' &amp; self.code &amp; CrLf;
	txt := txt &amp; 'Id ' &amp; "=" &amp; self.id.String &amp; CrLf;
	txt := txt &amp; 'Heading ' &amp; "=" &amp; self.heading &amp; CrLf;
//	txt := txt &amp; 'Short Heading ' &amp; "=" &amp; self.shortHeading &amp; CrLf;
	txt := txt &amp; 'Is Not Available For Entry' &amp; "=" &amp; self.isNotAvailableForEntry.String &amp; CrLf;
	txt := txt &amp; 'Requires Info ' &amp; "=" &amp; self.requiresInfo.String &amp; CrLf;
	if self.requiresInfo then
		txt := txt &amp; 'Requires Info Type' &amp; "=" &amp; self.requiresInfoString() &amp; CrLf;
	endif;
	
	on Exception do app.handleDeletedObject(exception, cargoTyp, invalid);
	// START 17 Jul 2022	navsj20	TFS 53862
	//foreach cargoTyp in self.allCargoTypesNew do		//17 Jul 2022	navsj20	TFS 53862
	if self.myStopCriteria &lt;&gt; null then 				//17 Jul 2022	navsj20	TFS 53862	
		foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	//27 Jul 2022	navsj20	TFS 53862
			foreach cargoTyp in criteria.myYAData.CM_YADataObjects.allObjects where cargoTyp.isKindOf(CM_CargoBOLType) do		//17 Jul 2022	navsj20	TFS 53862
			
			//		if not global.isValidObject(cargoTyp) then
			//			continue;
			//		endif;
			
				if tmpStr = null then
					//tmpStr := cargoTyp.abbreviation;										//17 Jul 2022	navsj20	TFS 53862
					tmpStr := cargoTyp.CM_CargoBOLType.abbreviation;						//17 Jul 2022	navsj20	TFS 53862
				else
					//tmpStr := tmpStr &amp; ', ' &amp; cargoTyp.description;						//17 Jul 2022	navsj20	TFS 53862
					tmpStr := tmpStr &amp; ', ' &amp; cargoTyp.CM_CargoBOLType.description;			//17 Jul 2022	navsj20	TFS 53862
				endif;
			endforeach;
		endforeach;		//27 Jul 2022	navsj20	TFS 53862
	endif;				//17 Jul 2022	navsj20	TFS 53862
	txt := txt &amp; 'Cargo Types selected ' &amp; "=" &amp; tmpStr &amp; CrLf;	
	
//	foreach stopTableTemplate in self.allStopTableTemplates do
//		txt := txt &amp; stopTableTemplate.getAuditText();
//	endforeach;
	return txt;
end;

</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e5d22a9b-2cdf-4898-8acb-6401194c8213">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
// 04 Mar 2022  navgm20     TFS #52930 MTN - Stops Data Table - Cargo Types
//11 July 2022  navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars
	attrName : String;
begin

	if _attrName = ETRow_Code then	
		return code ; 
	elseif _attrName = ETRow_ShortHeading then 
		return shortHeading ; 
	elseif _attrName = ETRow_NotAvailableForEntry then	
		return isNotAvailableForEntry.String ; 
	elseif _attrName = ETRow_AllowClearanceExpiryDate then	
		return allowClearanceExpiryDate.String  ; 
	elseif _attrName = ETRow_StopsCTAbbr then					//04.03.2022  navgm20	TFS #52930
		attrName := self.getCargoTypesAsStr(Comma, CM_CargoBOLType::abbreviation.name);
		return attrName;										
	elseif _attrName = ETRow_StopsCTDesc then					//04.03.2022  navgm20	TFS #52930
		attrName := self.getCargoTypesAsStr(Comma, CM_CargoBOLType::description.name);	
		return attrName;										
	elseif _attrName = ETRow_StopsCTAbbrDesc then				//04.03.2022  navgm20	TFS #52930
		attrName := self.getCargoTypesAsStr(Comma, null);	
		return attrName;
	elseif _attrName = ETRow_SetCriteria then				//11 July 2022 navhl20 TFS 53862
		return getStopCritDisp();
	endif ; 
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIActionName" id="4ae189fc-1604-4d55-a829-166d5d4e4538">
        <source>getEDIActionName(): String;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return app.getErrorString(Stop) &amp; " " &amp; self.heading;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHoldVoyages" id="c1abd5da-9824-4cdf-beec-5be5283df9ce">
        <source>getHoldVoyages(_terminal : CM_Terminal; _holdVoyages : CM_VoyageSet io);
// ccms1824 cnwrs1 may 2009
vars
	stopTableTemplate : CM_StopTableTemplate;
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self];
	if stopTableTemplate &lt;&gt; null then
		stopTableTemplate.allHoldVoyages.copy(_holdVoyages);
	endif;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_holdVoyages" type="CM_VoyageSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getJadeCode" id="370e6d36-f2d9-421a-9dc9-e55448b28dff">
        <source>getJadeCode() : String;
// ---------------------------------------------------------------------------
// Created:     Aug 2008 Par17724
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myHookCode = null then
		return null;
	endif;
	return self.myHookCode.getCurrentJadeCode();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="bedfded0-e991-4fc0-b98e-d3ae35ef8b9e">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					self.id.display &amp; Tab &amp;
					self.code.padBlanks( 5 ) &amp; Tab &amp;
					self.heading.padBlanks( 30 );
	/*
	returnStr	:=	// inheritMethod() &amp; Tab &amp;
					code &amp; Tab &amp;
					heading.padBlanks( 30 ) &amp; Tab &amp;
					( 'requiresInfo ' &amp; requiresInfo.cnEcGetYesNo ).padBlanks( 16 ) &amp; Tab &amp;
					'allStops ' &amp; allStops.size.display &amp; Tab &amp;
					'allStopTableTemplates ' &amp; allStopTableTemplates.size.display &amp; Tab &amp;
					creationTime.shortCurrentLocaleFormat;
	*/
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopCritDisp" id="d3d84bb3-8da4-43c2-8ea8-a40fefa10f09">
        <source>getStopCritDisp():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.myStopCriteria = null or self.myStopCriteria.getCriteriaSummary(", ") = null then
		return app.getErrorString(Criter_not_config_double_click);
	endif;

	return self.myStopCriteria.getCriteriaSummary(", ").formatWithEllipsis(1,100,true);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopNotRevelantReason" id="37a9dbf7-8d51-4285-b1b8-5b2263b067d2">
        <source>getStopNotRevelantReason(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:		20 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		This method shows why a Stop has not been applied to a particular tracked item.
//
// ---------------------------------------------------------------------------
// 01/07/2010	cnwcs5	par 24341 - remove method call to self.isValidForTranshipSetting
// 01 Oct 2010  cnwrs1      par25912 allow for tranship coastals
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars
	mess		: String;
//	termOK : Boolean;
	hookResult	: Boolean;
	ti			: CM_TrackedItem;
begin
	// cnwrl1 13/08/2009 PAR 20466 - start of coding
	ti		:= _ti;
	mess	:= null;
	
	//if not self.isValidForCargoType(ti.cargoType) then	//20.10.2022	navsj20	TFS 53862
	if not self.isValidForStopCriteria(ti) then			//20.10.2022	navsj20	TFS 53862
		//mess	:= "Cargo Type Settings";				//20.10.2022	navsj20	TFS 53862
		mess	:= "Tracked item Settings";				//20.10.2022	navsj20	TFS 53862
	endif;
	
	if not self.isValidForCoastalSetting(ti.isCoastalInbound, _ti.isCoastalOutbound, ti.myTerminal) then  //cnwrs1 par25912 1 Oct 2010
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Coastal Settings";
	endif;
	
	if not self.isValidForChildSetting(ti.isChild, ti.myTerminal) then
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Child Settings";
	endif;
/*	par 24341
	if not self.isValidForTranshipSetting(ti.isTranshipItem, ti.myTerminal) then
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Tranship Settings";
	endif;
*/	
	if not self.isValidForMTs(ti.isEmpty, ti.myTerminal) then
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Empty Settings";
	endif;
	
	if not self.isValidForFulls(not ti.isEmpty, ti.myTerminal) then
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Full Settings";
	endif;
	
	hookResult	:= true;
	app.myHookAgent.runHookLinkPublic(HookType_IsStopRelevant, self, self, ti, hookResult);
	
	if not hookResult then
		if mess &lt;&gt; null then
			mess := mess &amp; ", ";
		endif;
		mess	:= mess &amp; "Hook Code";
	endif;
	
	return mess;
	// cnwrl1 13/08/2009 PAR 20466 - end of coding
	
	/* cnwrl1 13/08/2009 PAR 20466 - what it was
	if not self.isValidForCargoType(_ti.cargoType) then
		mess := mess &amp; " Cargo Type Settings, ";
	endif;
//	if self.allStopTableTemplates[_ti.myTerminal, self] = null then //cnwrs1 par 17129 June 2008
//		mess := mess &amp; " Terminal Settings, ";
//	else
//		termOK := true;
//	endif;
	
	if not self.isValidForCoastalSetting(_ti.isCoastal, _ti.myTerminal) and termOK then //cnwrs1 par 17129 June 2008
		mess := mess &amp; " Coastal Settings, ";
	endif;
	
	if not self.isValidForChildSetting(_ti.isChild, _ti.myTerminal) and termOK then //cnwrs1 par 17129 June 2008
		mess := mess &amp; " Child Settings, ";
	endif;
	
	if not self.isValidForMTs(_ti.isEmpty, _ti.myTerminal) and termOK then //cnwrs1 par 17129 June 2008
		mess := mess &amp; " Empty Settings, ";
	endif;
	if not self.isValidForFulls(_ti.isEmpty, _ti.myTerminal) and termOK then //cnwrs1 par 17129 June 2008
		mess := mess &amp; " Full Settings, ";
	endif;
	ti := _ti;
	app.myHookAgent.runHookLinkPublic(HookType_IsStopRelevant, self, self, ti, result);

	if not result then
		mess := mess &amp; " Hook Code, "; //ccms 1100 Mar 2008 cnwrs1 //par17724 Aug 2008
	endif;
	return mess;
	cnwrl1 13/08/2009 PAR 20466 - end of what it was */
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
