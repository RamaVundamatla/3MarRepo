    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

This transient class is used to represent the CM_DEBTOR MAP object's mappings.</text>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myDebtorMap" id="d627c54b-9757-460d-935c-10f9250ec6a5">
