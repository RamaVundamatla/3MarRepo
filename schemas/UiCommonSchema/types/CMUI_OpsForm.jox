    <JadeMethod name="getAllTIsInTableSelected" id="48f57a60-1719-4520-a7e4-5aa9e5bb69ff">
        <updating/>
        <source>getAllTIsInTableSelected(_tiArray : CM_TIArray input) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
begin

	on Exception do self.handleExceptionWLE(exception, wle);
	
	create wleArray transient;
	self.getAllWLEsInTableSelected(wleArray);
	
	foreach wle in wleArray do
		if wle.myTrackedItem &lt;&gt; null then
			_tiArray.add(wle.myTrackedItem );
		endif;
	endforeach;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInTable" id="1e8b0e73-b963-4094-9a1e-90f24de6e00f">
        <updating/>
        <source>getAllWLEsInTable(_wleArray : CM_WLEArray input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle : CM_WorkListEntry;
	idx,
	rows : Integer;
begin

	on Exception do self.handleExceptionWLE(exception, wle);
	rows := self.tblWorkEntries.rows;
	
	foreach idx in 2 to rows do
		wle := self.tblWorkEntries.accessRow(idx).itemObject.CM_WorkListEntry;
		if wle = null then
			continue;
		endif;		
		wle.fetchLatest();
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;

		if (not _wleArray.includes(wle)) then			
			_wleArray.add(wle);
		endif;
	endforeach;

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInTableSelected" id="d65c373d-8bbb-419e-9667-acc598079cfc">
        <source>getAllWLEsInTableSelected(_wleArray : CM_WLEArray input) ;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	wle	: CM_WorkListEntry;
begin

	on Exception do self.handleExceptionWLE(exception, wle);
	
	foreach obj in self.tblWorkEntries.allSelectedObjects do
		if CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;
			wle.fetchLatest();
		endif;	
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		_wleArray.add(wle);
	endforeach;

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
