epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEditDest_click" id="287f253e-a96f-48c3-84d0-d9e3346545e3">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditDest_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars

begin
	if lstDestination.listIndex &gt; 0 and lstDestination.listIndex &lt;= lstDestination.listCount then
		self.myEditTerminal      := lstDestination.itemObject[lstDestination.listIndex].CM_InterTermTargetTermInfo.myTargetTerminal;
		self.myInterTerminalInfo := lstDestination.itemObject[lstDestination.listIndex].CM_InterTermTargetTermInfo;
		showDestinationTerminalForm(Mode_Edit);
		vUpdated := true;
	else
		self.myEditTerminal := null;
		app.raiseCMException1(Input_Required_For_TA, null, null, null);
		self.lstDestination.setFocus;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="2d9ae4aa-eada-4a1c-bc7b-1b8a47c9b514">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEdit_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars

	result : Boolean;
begin

	result := checkForChanges(false);
	if result = false then
		return;
	endif;
	
	if cmbConfigName.listIndex &lt; 1 then
		app.raiseCMException1(/*ConfigNameMissing*/85708, ' must supply a config name', null, null);
		return;
	endif;

	setupForEdit;
	self.vMode    := Mode_Edit;
	self.vUpdated := true;
	btnDelete.enabled := false;
	btnAdd.enabled    := false;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="24b4133e-cc0a-4e80-b7d0-3759dd41f93a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	conkc1	Initial creation

*/

vars
	result : Boolean;
begin
	result := self.doSave;
	//
	// Check we completed OK
	//
	if result = true then
		self.resetForm;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkForChanges" id="13dcaa5e-8695-48fd-9447-e01d442be362">
        <updating/>
        <source>checkForChanges(fromCancelButton : Boolean) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2010	conkc1	Initial creation
*/
vars
	result : Integer;
begin
//	write method.qualifiedName &amp; ' ' &amp; vUpdated.String;
	if vUpdated = true then
		result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if result = MsgBox_Return_Cancel then
			// cancel changes to existing item and start again
			if fromCancelButton = true then
				return false;
			endif;
			// do NOT move to new row.
			return true;
		elseif result = MsgBox_Return_No then
			// cancel changes to existing item and start again
			if fromCancelButton = true then
				return true;
			endif;
			self.resetForm;
			return true;
		elseif result = MsgBox_Return_Yes then
			// save the existing item, if successful then move to the new row;
			self.btnSave_click(btnSave);
			if fromCancelButton = true then
				return true;
			endif;
			return true;
		endif;	
	endif;

	return true;
epilog

end;</source>
        <Parameter name="fromCancelButton" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
