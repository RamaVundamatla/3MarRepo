    <JadeMethod name="setProxyYRDPadColumn" id="e00d27ff-2652-4603-99cb-ae11865b459a">
        <source>setProxyYRDPadColumn(_gridArea : CM_GridArea) : CM_GridColumn;

vars

	gridColumn : CM_GridColumn;

begin

// This can wait until we sort out a few problems with proxies.
//	if self.myGridCol &lt;&gt; null then
//		gridColumn := app.createUpdateProxy(self.myGridCol).CM_GridColumn;
//	else
		create gridColumn transient;
//	endif;
	gridColumn.setForProxy(self.column, self.label, _gridArea);
	return gridColumn;
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <ReturnType type="CM_GridColumn"/>
    </JadeMethod>
