    <JadeMethod name="isMyHarbour" id="6c1dfdb1-fe6f-422e-85eb-7a2a44d47f87">
        <source>isMyHarbour(_harbourObj:HMS_Harbour):Boolean;
// --------------------------------------------------------------------------------
// Created:		28 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver bel;ongs to
//				the specified Harbour.
//
// Parameters:	_harbourObj - A reference to the Harbour for the Terminal.
//
// Returns:		True if the receiver belongs to the Harbour, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.myHarbour = _harbourObj then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_harbourObj" type="HMS_Harbour"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="118f23e0-6754-4f56-9613-ef3ca014292b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyUserTerminal	: CM_UserTerminal;
	completedOK		: Boolean;
	
begin

	pxyUserTerminal := inheritMethod();
	
	pxyUserTerminal.mySecurityRole			:= self.mySecurityRole;
	pxyUserTerminal.myTerminal				:= self.myTerminal;
	pxyUserTerminal.myUser					:= self.myUser;
	pxyUserTerminal.myDefaultCargoType 		:= self.myDefaultCargoType;
	pxyUserTerminal.myDefaultBOLType 		:= self.myDefaultBOLType;
	pxyUserTerminal.myDefaultCargoBOLType 	:= self.myDefaultCargoBOLType;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyUserTerminal;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyUserTerminal;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetNavMenuFromJMTDefault" id="5be6d72e-c02d-4a55-a827-9476b3c77070">
        <updating/>
        <source>resetNavMenuFromJMTDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
			
begin

	if self.myMenuRoot = null then
		self.createMenuRoot();
	endif;
	
	self.myMenuRoot.resetMenu(app.myRoot.myMenuRoot, _clearFirst);
	self.checkNavMenuAgainstPermissions(true);
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetNavMenuFromSysDefault" id="4f375c4a-412d-4e93-a3e8-40dfde8d07ba">
        <updating/>
        <source>resetNavMenuFromSysDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;		
begin
	create agent transient;
	
	if self.myMenuRoot = null then
		self.createMenuRoot();
	endif;
	
	agent.trxSaveToSourceMenuRoot(agent.mySystemMenuRoot, self.myMenuRoot, self.myUser, _clearFirst);
	self.checkNavMenuAgainstPermissions(true);
epilog
	delete agent;
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetReportMenuFromJMTDefault" id="008adaaa-56ef-450f-9eda-62b8fa0b29eb">
        <updating/>
        <source>resetReportMenuFromJMTDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
			
begin

	if self.myReportMenuRoot = null then
		self.createReportMenuRoot();
	endif;
	
	self.myReportMenuRoot.resetMenu(app.myRoot.myReportMenuRoot, _clearFirst);
	self.checkReportMenuAgainstSecurity();
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetReportMenuFromSysDefault" id="ce577b33-d1b9-4f08-8223-c78d1f035e4f">
        <updating/>
        <source>resetReportMenuFromSysDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;		
begin
	create agent transient;
	
	if self.myReportMenuRoot = null then
		self.createReportMenuRoot();
	endif;
	
	agent.trxSaveToSourceMenuRoot(agent.mySystemMenuReportRoot, self.myReportMenuRoot, self.myUser, _clearFirst);
	self.checkReportMenuAgainstSecurity();
	
epilog
	delete agent;
end;</source>
