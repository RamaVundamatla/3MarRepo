    <JadeMethod name="cloneMySelf" id="1355b722-024e-45bd-a44d-c48369cc21fc">
        <source>cloneMySelf(_newLayer : CM_DeckLayerLayout; _copy : Boolean; _nextOrd : Boolean) : CM_ROROLocnDefn;// PAR 27528 
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : CM_ROROLocnDefn;
begin

	newMe := inheritMethod(_newLayer, _copy, _nextOrd).CM_ROROLocnDefn;


	
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_nextOrd" type="Boolean"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="createProxySlots" id="4fc70085-570c-41aa-b2a6-326b8cd3b596">
        <source>createProxySlots();
/*
Purpose:			
Date		Who		Reason
19 April 2011	cnwab1	Initial creation
*/

vars
	pxySlot : CM_ROROSlotDefnVessel;
	idx : Integer;
begin

	foreach idx in 1 to self.numTiers do
		create pxySlot transient;
		pxySlot.setProxy(self.code &amp; idx.String, null, null, idx, true, false, self);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="dc6ccf9e-ed6e-4c58-a885-d4d9d6c20174">
        <source>pxyCreateUpdateProxy(): SelfType ;
/*
Purpose:			
Date			Who		Reason
21 April 2011	cnwab1	Initial creation
27/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyMe : SelfType;
	pxyVess : CM_ROROVesselStructure;
	completedOK		: Boolean;

begin
	pxyMe :=  inheritMethod();

	pxyVess := self.myROROStructure.pxyGetProxyObject();
	pxyMe.myROROStructure := pxyVess;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="47b16145-c259-47be-96fb-2b815937c9fd">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
19 April 2011	cnwab1	Initial creation
*/

vars
	
begin

	self.myROROStructure := _proxyDeckItem.myROROStructure;
	inheritMethod(_proxyDeckItem, _passport);
	self.isRotatable := true;	

epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="66502b6a-6931-4fbb-8c5d-9a7a6a351a7b">
        <updating/>
        <source>setForCreateImport(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	inheritMethod(_proxyDeckItem, _passport);
	
	self.myROROStructure:=self.myDeckLayerLayout.myDeckLayout.myDeck.CM_DeckVessel.getROROStructure;
	
	
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
