    <JadeMethod name="doAcceptTask" id="2e1b7f32-4fb9-4eb3-b1ff-4a66dad8b4f2">
        <updating/>
        <source>doAcceptTask(rtQueueEntry,_twinQueueEntry: CM_RTQueueEntry input;
			_sideAccessDirection : Integer input;
			_tandemLift	: Boolean;
			_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(rtQueueEntry,_twinQueueEntry,_sideAccessDirection,_tandemLift, _errorMsgs);

	if _errorMsgs.size = null then
		self.setRTGState(SETTINGDOWN);
	endif;
	if self.myMachine.allCurrentQueueTasks.size = null then
		self.setRTGState(IDLE);
	endif;
epilog

end;</source>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_twinQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancelTask" id="16ce11a9-7ad6-4817-80e3-84570ab97cd6">
        <updating/>
        <source>doCancelTask(rtQueueEntry: CM_RTQueueEntry input; 
				_restore : Boolean;
				_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(rtQueueEntry, _restore,_errorMsgs);

	if self.myMachine.allCurrentQueueTasks.size &lt;&gt; null then
		self.setRTGState(PICKINGUP);
		return;
	endif;
	if self.myMachine.allCurrentQueueTasks.size = null then
		self.setRTGState(IDLE);
	endif;
epilog

end;</source>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_restore" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveCurrentOverstow" id="d24d995b-11b2-448b-b8d0-eff33296417d">
        <updating/>
        <source>doMoveCurrentOverstow(_locId: String; _errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(_locId, _errorMsgs);
	
	if _errorMsgs.size = null then
		if self.myMachine.machineStatus = STATUS_IDLE then
			self.setRTGState(IDLE);
		else
			self.setRTGState(PICKINGUP);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
