    <JadeMethod name="getReceivalDocket" id="76a77833-f946-4518-a918-8249f0df5a6d">
        <source>getReceivalDocket(_bol, _operatorCode : String; _type : Integer) : CM_BOLIn;
// -------------------------------------------
// Created 26 March 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
vars
	iter 			: Iterator;
	docket	 		: CM_BOLIn;
	keyType	: Integer;
	keyNum			: String;
	keyTS			: TimeStamp;

begin

	iter := self.allBOLsReceivedByTypeNumberDT.createIterator();
	self.allBOLsReceivedByTypeNumberDT.startKeyGeq(_type, _bol, null, iter);
	while iter.next(docket) do
		iter.getCurrentKeys(keyType,keyNum,keyTS); //MTN-35226
		if keyType &lt;&gt; _type or
		   keyNum &lt;&gt; _bol then
			break;
		endif;

		if	docket.getOperatorCode = _operatorCode then
			return docket;
		endif;
	endwhile;
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getReeferBlock" id="00493ad4-56b0-4276-b60b-4c62998a6609">
        <source>getReeferBlock(_blockName : String) : CM_ReeferBlock;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2022	navsp1	Initial creation - ChangeRequest 54899: PEN - Reefer Monitor App Changes

*/

vars
	 ta : CM_TerminalArea;
	 walk : CM_ReeferBlock;
begin
	foreach ta in self.allTerminalAreas discreteLock do	:outerLoop
		foreach walk in ta.allReeferBlocks discreteLock do
			if walk.name.toUpper = _blockName.toUpper() then
				return walk;
			endif;
		endforeach;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_blockName" type="String"/>
        <ReturnType type="CM_ReeferBlock"/>
    </JadeMethod>
    <JadeMethod name="getReeferJobs" id="6ced20a4-068d-4681-8691-265f37ef6d6b">
        <source>getReeferJobs( 	_yardActivityType : Integer; 
				_includeFutureActivity : Boolean;
				_yardActivities : CM_YardActivityArray input
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	yardActivity : CM_YardActivity;
	now : TimeStamp;
	iter : Iterator;
	startObject : CM_YardActivity;

begin

	if self.allYardActivities.isEmpty or _yardActivities = null then
		return;
	endif;
	
	now := app.actualTimeAppServer;
	
	iter := self.allYardActivities.createIterator;
	if _yardActivityType &lt;&gt; 0 then
		startObject := self.allYardActivities.getAtKeyGeq( _yardActivityType, null, null );
		if startObject = null then
			return;
		else
			iter.startAtObject( startObject );
		endif;
	endif;
	
	while iter.next( yardActivity ) do
		if _yardActivityType &lt;&gt; 0 then
			if yardActivity.type &lt;&gt; _yardActivityType then
				break;
			endif;
		endif;
		if _includeFutureActivity then
			_yardActivities.add( yardActivity );
		elseif yardActivity.actionTime &lt;= now then
			_yardActivities.add( yardActivity );
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_yardActivityType" type="Integer"/>
        <Parameter name="_includeFutureActivity" type="Boolean"/>
        <Parameter name="_yardActivities" type="CM_YardActivityArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRelevantShift" id="60ac31e7-deee-4de8-8058-72db51e104fc">
        <source>getRelevantShift(_startTs : TimeStamp):CM_Shift;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	iter  : Iterator;
	shift : CM_Shift;
	dict  : CM_ShiftStartDateCodeDict;
begin
	dict := self.allShiftsDay;
	
	dict.getAtKeyGeq(_startTs,null);
	iter := dict.createIterator();
	
	while iter.next( shift ) do
		if shift.startDateTime &gt; _startTs then
			continue;
		endif;
		if shift.endDateTime &lt; _startTs then
			continue;
		endif;
		return shift;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_startTs" type="TimeStamp"/>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getRoadReceiptReport" id="3f977fa8-c59b-482e-92a8-5b3d67e01ffb">
        <source>getRoadReceiptReport() : String;

// Changed On	Changed By	Reason
// -----------	----------	--------------------------------------
// 22 Feb 2010	consw1		PAR #21156 - Gate Config Report Names

vars
	str	: String;
begin
	str := self.getConfig(GateRoadJobReceipt).String;
	if str = null then
		str := DefRep_GateRoadJobReceipt;
	endif;

	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDate" id="2936b94e-7bbc-47ef-a5c5-3f4121b51598">
        <source>getSOHLevelsForDate(_date : Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer io;
					_totVol			: Decimal io;
					_totWeight 		: Decimal io);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta				: CM_TerminalArea;
	
begin
	
	foreach ta in self.allTerminalAreas where ta.isStockControlled do
		ta.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endforeach;
	
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
        <Parameter name="_totWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsNoProduct" id="3063f53d-9725-41d6-aeeb-136b471dacfd">
        <source>getSOHLevelsNoProduct(_closingLevel 	: Boolean; 
					_totQty			: Integer io;
					_totVol			: Decimal io;
					_totWeight 		: Decimal io);
// ---------------------------------------------------------------------------
// Created:   
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta				: CM_TerminalArea;
	
begin
	
	foreach ta in self.allTerminalAreas where ta.isStockControlled do
		ta.getSOHLevelsNoProduct(_closingLevel, _totQty, _totVol, _totWeight);
	endforeach;
	
end;</source>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
        <Parameter name="_totWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSOHLocationsForLogSpec" id="4fd24e32-e8b9-4931-a669-a9a2d43b0fe1">
        <source>getSOHLocationsForLogSpec(_operator : CM_Operator; _speciesCode, _gradeCode, _typeCode, _treatCode, _lengthCode : String; 
						_sohLocnDict : CM_SOHLocationsByLocnProduct input);
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	productCode	: String;
	product		: CM_Product;
	productSet	: CM_ProductSet;
	logSpecies	: CM_LogSpecies;
	sohLocn		: CM_SOHLocation;

begin

	if _operator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'operator', ETRow_Operator, null);
		app.raiseCMException(Input_required_field_operator, ETRow_Operator, null);
		return;
	endif;

	create productSet transient;

	productCode := app.buildLogProductCode(_speciesCode, _gradeCode, _typeCode, _treatCode, _lengthCode);
	product 	:= _operator.allProducts[TI_CargoType_Log, productCode].CM_ProductLog;

	if product &lt;&gt; null then
		productSet.add(product);
	elseif _speciesCode &lt;&gt; null then
		logSpecies := _operator.getLogSpecies(_speciesCode);
		if logSpecies &lt;&gt; null then
			logSpecies.getProductsForGrdeTypTreatLen(_operator, _gradeCode, _typeCode, _treatCode, 
													_lengthCode, productSet);
		else
			app.raiseCMException1(ERR_INVALID_VALUE, 'log species', ETRow_Species, null);
			return;
		endif;
	else
		_operator.allProducts.copy(productSet);
	endif;

	foreach product in productSet do
		foreach sohLocn in product.allSOHLocations do

			// RJS - 3/6/2010 - change for performance and to explicitly exclude non-yard locations - PAR15591/18081
			if sohLocn.myTerminal &lt;&gt; self or
			   sohLocn.myTerminalArea = null or
			   (not sohLocn.myLocationsController.isKindOf(CM_YardController)) or
			   sohLocn.myLocationsController.status = LC_Status_PhysicallyEmpty  then
				continue;
			endif;
			
			/*
			if sohLocn.myTerminal &lt;&gt; self then
				continue;
			endif;
			if sohLocn.myTerminalArea = null then
				continue;
			endif;
			if sohLocn.myLocationsController.status = LC_Status_PhysicallyEmpty  then
				continue;
			endif;
			*/
			
			if sohLocn.currentVolume &gt; 0 then
				_sohLocnDict.add(sohLocn);
			endif;
		endforeach;
	endforeach;

epilog
	delete productSet;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_speciesCode" type="String"/>
        <Parameter name="_gradeCode" type="String"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_treatCode" type="String"/>
        <Parameter name="_lengthCode" type="String"/>
        <Parameter name="_sohLocnDict" type="CM_SOHLocationsByLocnProduct" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSOHValuesForProduct" id="59ec0aee-0d29-40ae-bd68-b8f3d5963722">
        <source>getSOHValuesForProduct(_product: CM_Product; _quantity: Integer io; _weight: Decimal io; _volume: Decimal io);
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta		: CM_TerminalArea;
	qty		: Integer;
	wght	: Decimal[14,4];
	vol		: Decimal[16,4];

begin

	foreach ta in self.allTerminalAreas do
		ta.getSOHValuesForProduct(_product, qty, wght, vol);
		_quantity	:= _quantity + qty;
		_weight		:= _weight + wght;
		_volume		:= _volume + vol;
	endforeach;

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_volume" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSVGForTerminal" id="979f3626-9828-4109-96c7-497252133e5c">
        <source>getSVGForTerminal() : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theSVG, tmpString, theColourHex : String;
	aPoint : Point;
begin

// &lt;polygon points="0,2,347,1,158,497,197,766,366,782,632,704,670,891,578,1036,1,1081,0,2" stroke="#008000" fill="none"/&gt;
// notive none for no fill
	foreach theGraphic in self.allLayoutGraphics  do
		thePoints := theGraphic.pointsPolygon;
		theColour := theGraphic.CM_LayoutGraphic.drawLineColour;
		theColourHex := "#" &amp; theColour.cnEcGetHexColor;
		
		theSVG := theSVG &amp; '&lt;polygon points="';
		tmpString := null;
		foreach aPoint in thePoints do
			tmpString := tmpString &amp; aPoint.x.String &amp; ",";
			tmpString := tmpString &amp; aPoint.y.String &amp; ",";
		endforeach;
		tmpString := tmpString[1:tmpString.length - 1];
		
		theSVG := theSVG &amp; tmpString &amp; '" stroke="' &amp; theColourHex &amp; '" fill="' &amp; theColourHex &amp; '"/&gt;' &amp; CrLf; 
	endforeach;
	
	
	return theSVG;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSVGForTerminalAll" id="2bb87f89-6809-4846-a477-165618878650">
        <source>getSVGForTerminalAll() : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminalArea : CM_TerminalArea;
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theSVG, tmpString, theColourHex : String;
	aPoint : Point;
begin
//  CHECK width="1200" height="2000" in here
	theHeader := '&lt;?xml version="1.0" encoding="ISO-8859-1" standalone="no"?&gt;' &amp; CrLf 
		&amp; '&lt;!DOCTYPE svg PUBLIC "-//W3C//DTD SVG 20010904//EN"' &amp; CrLf
		&amp; '"http://www.w3.org/TR/2001/REC-SVG-20010904/DTD/svg10.dtd"&gt;' &amp; CrLf
		&amp; '&lt;svg width="1200" height="2000" xmlns="http://www.w3.org/2000/svg"' &amp; CrLf
		&amp; 'xmlns:xlink="http://www.w3.org/1999/xlink"&gt;' &amp; CrLf
		&amp; 'viewBox="0,0,1200,2000"' &amp; CrLf;
	theFooter := "&lt;/svg&gt;";

		
	theDocument := theHeader;
	
	theSVG := self.getSVGForTerminal();
	foreach theTerminalArea in self.allTerminalAreas do
		theSVG := theSVG &amp; theTerminalArea.getSVGForTerminalArea();
	endforeach;
	
	theDocument := theDocument &amp; theSVG;
	theDocument := theDocument &amp; theFooter;
	return theDocument;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSapTPP" id="01fe673d-4bb1-4aac-aa46-d846b233ec00">
        <source>getSapTPP(_tppArr : CMIF_TPPArray io;_type :String):CMIF_TPPArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report
*/

constants
	BARANG		= "BARANG";
	KAPAL		= "KAPAL";
	PRODUKSI	= "PRODUKSI";
	REVENUE		= "REVENUE";
	
vars
	bank     : CM_Bank;
	invArr   : ObjectArray;
	inv      : CM_Invoice;
	tpp      : CMIF_TPP;
	tppArr,
	grpTPP	 : CMIF_TPPArray;
	extRef,
	extRef2	 : String;
	invLine  : CM_InvoiceLine;
	transArr : CM_TransactionArray;
	trans    : CM_TITransaction;
	blurb	: String;

begin
	
	if _type = KAPAL then
		if self.code = "1012" then //Sibolga Terminal
			extRef := "4JT";
		else
			extRef := "4A0";
		endif;

		create invArr transient;

		foreach bank in self.companies discreteLock do
			foreach invLine in bank.allInvLinesByExtTS02 discreteLock do
				inv := invLine.invoice;
				blurb := method.qualifiedName() &amp; " (TPP Kapal) Terminal: " &amp; self.code &amp; ", Bank: " &amp; bank.code &amp; ", Invoice: " &amp; inv.sequenceNum.String &amp; ", Inv line: " &amp; invLine.sequenceNum.String;

				if invLine.externalTS02 &lt;&gt; null then
					app.writeLog(blurb &amp; " - already has TS02 timestamp populated", LogDEBUG);
					break;
				endif;

				if inv.invoiceType.externalReference &lt;&gt; extRef then
					app.writeLog(blurb &amp; " - inv type not " &amp; extRef, LogDEBUG);
					continue;
				endif;

				if not invLine.isTPPKapal() then
					app.writeLog(blurb &amp; " - failed isTPPKapal check", LogDEBUG);
					continue;
				endif;

				app.myTrxUA.trxUpdateInvLineExtTS02(invLine, app.actualTimeServer(), app.myPassport);
				if app.myPassport.hasErrors then
					blurb := blurb &amp; " - timestamping failed";
					app.myPassport.clearErrorsWarnings();
				else
					if invArr.includes(inv) then
						blurb := blurb &amp; " - this invoice is already included";
					else
						invArr.add(inv);
						blurb := blurb &amp; " - selected for inclusion";

						create tpp transient;
						tpp.myInvoice  := inv;
						tpp.myVoyage   := inv.myVoyage;
						tpp.myTerminal := inv.myTerminal;

						tpp.copyTrafficKapal(inv);
						_tppArr.add(tpp);
					endif;
				endif;
				app.writeLog(blurb, LogDEBUG);
			endforeach;
		endforeach;
	

	elseif _type = BARANG then
		extRef := "4B0";
		extRef2 := "4NK";

		create transArr transient;
		create grpTPP transient;

		foreach bank in self.companies discreteLock do
			foreach invLine in bank.allInvLinesByExtTS01 discreteLock do
				inv := invLine.invoice;
				blurb := method.qualifiedName() &amp; " (TPP Barang) Terminal: " &amp; self.code &amp; ", Bank: " &amp; bank.code &amp; ", Invoice: " &amp; inv.sequenceNum.String &amp; ", Inv line: " &amp; invLine.sequenceNum.String;

				if invLine.externalTS01 &lt;&gt; null then
					app.writeLog(blurb &amp; " - already has TS01 timestamp populated", LogDEBUG);
					break;
				endif;

				if inv.invoiceType.externalReference &lt;&gt; extRef and inv.invoiceType.externalReference &lt;&gt; extRef2 then
					app.writeLog(blurb &amp; " - inv type neither " &amp; extRef &amp; " nor " &amp; extRef2, LogDEBUG);
					continue;
				endif;

				if not invLine.isTPPBarang() then
					app.writeLog(blurb &amp; " - failed isTPPBarang check", LogDEBUG);
					continue;
				endif;

				if invLine.myTransactionTI = null then
					app.writeLog(blurb &amp; " - has no TI transaction", LogDEBUG);
					continue;
				endif;

				app.myTrxUA.trxUpdateInvLineExtTS01(invLine, app.actualTimeServer(), app.myPassport);
				if app.myPassport.hasErrors then
					blurb := blurb &amp; " - timestamping failed";
					app.myPassport.clearErrorsWarnings();
				else
					blurb := blurb &amp; " - selected for inclusion";
					create tpp transient;	
					tpp.copyTrafficBarang(invLine);
					_tppArr.add(tpp);
				endif;
				app.writeLog(blurb, LogDEBUG);
			endforeach;
		endforeach;

	elseif _type = PRODUKSI then
		extRef := "4A0";

		foreach bank in self.companies discreteLock do
			foreach invLine in bank.allInvLinesByExtTS03 discreteLock do
				inv := invLine.invoice;
				blurb := method.qualifiedName() &amp; " (TPP Produksi) Terminal: " &amp; self.code &amp; ", Bank: " &amp; bank.code &amp; ", Invoice: " &amp; inv.sequenceNum.String &amp; ", Inv line: " &amp; invLine.sequenceNum.String;

				if invLine.externalTS03 &lt;&gt; null then
					app.writeLog(blurb &amp; " - already has TS03 timestamp populated", LogDEBUG);
					break;
				endif;
				
				if not invLine.isTPPRevenue then
					app.writeLog(blurb &amp; " - failed invLine isTPPProduksi check", LogDEBUG);
					continue;
				endif;

				app.myTrxUA.trxUpdateInvLineExtTS03(invLine, app.actualTimeServer(), app.myPassport);
				if app.myPassport.hasErrors then
					blurb := blurb &amp; " - timestamping failed";
					app.myPassport.clearErrorsWarnings();
				else
					blurb := blurb &amp; " - selected for inclusion";
					create tpp transient;	
					tpp.copyProduksi(invLine);
					_tppArr.add(tpp);
				endif;
				app.writeLog(blurb, LogINFO);
			endforeach;
		endforeach;


	elseif _type = REVENUE then
		foreach bank in self.companies discreteLock do
			foreach invLine in bank.allInvLinesByExtTS04 discreteLock do
				inv := invLine.invoice;
				blurb := method.qualifiedName() &amp; " (TPP Revenue) Terminal: " &amp; self.code &amp; ", Bank: " &amp; bank.code &amp; ", Invoice: " &amp; inv.sequenceNum.String &amp; ", Inv line: " &amp; invLine.sequenceNum.String;

				if invLine.externalTS04 &lt;&gt; null then
					app.writeLog(blurb &amp; " - already has TS04 timestamp populated", LogDEBUG);
					break;
				endif;

				if not invLine.isTPPRevenue then
					app.writeLog(blurb &amp; " - failed invLine isTPPRevenue check", LogDEBUG);
					continue;
				endif;

				app.myTrxUA.trxUpdateInvLineExtTS04(invLine, app.actualTimeServer(), app.myPassport);
				if app.myPassport.hasErrors then
					blurb := blurb &amp; " - timestamping failed";
					app.myPassport.clearErrorsWarnings();
				else
					blurb := blurb &amp; " - selected for inclusion";
					create tpp transient;	
					tpp.copyRevenue(invLine);
					_tppArr.add(tpp);
				endif;
				app.writeLog(blurb, LogDEBUG);
			endforeach;
		endforeach;
	endif;

	return _tppArr;
epilog
	delete invArr;
	delete transArr;
	delete grpTPP;
end;</source>
        <Parameter name="_tppArr" type="CMIF_TPPArray" usage="io"/>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CMIF_TPPArray"/>
    </JadeMethod>
    <JadeMethod name="getSealCheckTypeForContext" id="b4372f21-d6df-4dba-b05f-05dde931b5fe">
        <source>getSealCheckTypeForContext( _context : Integer ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 23715
02 Feb 2024			jlier1 TFS 62142
*/

vars

	returnType : Integer;
	
begin

	if _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKUNLOAD,CARGO_CHECK_CONTEXT_GATE_REC,CARGO_CHECK_CONTEXT_ROAD_REC) then	//07 May 2014	NDL	Par 34076
		returnType := self.sealCheckRoadReceival;
//	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKLOAD,CARGO_CHECK_CONTEXT_GATE_REL) then
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKLOAD,CARGO_CHECK_CONTEXT_GATE_REL, CARGO_CHECK_CONTEXT_ROAD_REL ) then	//19 Nov 2019	NDL	TFS 47568
		returnType := self.sealCheckRoadRelease;
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_SHIP_LOAD, CARGO_CHECK_CONTEXT_TMANLOAD,CARGO_CHECK_CONTEXT_VOYOP_LOAD) then
		returnType := self.sealCheckShipRelease;
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_SHIP_DISC, CARGO_CHECK_CONTEXT_TMANDISC,CARGO_CHECK_CONTEXT_VOYOP_DISC) then
		returnType := self.sealCheckShipReceival;
	elseif _context = CARGO_CHECK_CONTEXT_RAIL_REC then
		returnType := self.sealCheckRailReceival;
	elseif _context = CARGO_CHECK_CONTEXT_RAIL_REL then
		returnType := self.sealCheckRailRelease;
//	elseif _context = CARGO_CHECK_CONTEXT_PACK then	//04 Jul 2011	NDL	Par 26476
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_PACK, CONT_CHECK_CONTEXT_PACK) then	//08 Mar 2017	NDL	TFS 3635
		returnType := self.sealCheckPack;
//	elseif _context = CARGO_CHECK_CONTEXT_UNPACK then	//04 Jul 2011	NDL	Par 26476
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_UNPACK, CONT_CHECK_CONTEXT_UNPACK) then	//08 Mar 2017	NDL	TFS 3635
		returnType := self.sealCheckUnpack;
	elseif _context = WAGON_CHECK_CONTEXT_PLACE_IN then	//11 Mar 2015	NDL	Par 35828
		returnType := self.sealCheckWagonDischarge;
	elseif _context = WAGON_CHECK_CONTEXT_PLACE_OUT then	//11 Mar 2015	NDL	Par 35828
		returnType := self.sealCheckWagonLoad;
	endif;
	
	return returnType;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getShiftEndTimeForDOW" id="29257c2a-fcb0-4e88-beca-bb0ea9481385">
        <source>getShiftEndTimeForDOW(_dayOfWeek : Integer) : Time;
// --------------------------------------------------------------------------------
// Created:		09 September 2010 by cnwjo3
//
// Purpose:		par 25615.  What is the end time of the last shift for a 
//				particular day.
//
vars
	endTime : Time;
	standardShift : CM_ShiftStd;
begin
	endTime.setTime(23,59,59,999);  //if no shift is found for this day then set end time to last hour
	
	foreach standardShift in self.allShiftsStandard do
		if standardShift.shiftDay = _dayOfWeek then
			endTime := standardShift.endTime;  //we have made the assumption here that standard shifts (defaults) are ordered logically (by time) in the collection
		endif;
	endforeach;
	
	return endTime;
end;</source>
        <Parameter name="_dayOfWeek" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getShiftForTimeStamp" id="2920e7e5-42ad-4bd2-ab2f-8d78046502e3">
        <source>getShiftForTimeStamp(_ts : TimeStamp) : CM_Shift;
/*

Purpose:			Return a transient CM_Shift that spans the time passed in
					Caller must delete the CM_Shift

Parameters:			TimeStamp to find a matching Shift for

Return Value:		Transient CM_Shift object


Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Fix performance in Voyage KPI processing

*/

vars
	shifts 			: CM_ShiftStartDateCodeDict;
	shift			: CM_Shift;
	
begin
	create shifts transient;
	self.getShiftsFromRange(shifts, _ts, _ts);
	
	foreach shift in shifts do
		// "Ignored" standard shifts are returned by the getShiftsFromRange method, and we
		// don't want to return them
		if not shift.ignore then
			// Found a good one, remove it from the collection before returning it, so
			// it doesn't get "purged"
			shifts.remove(shift);
			return shift;
		endif;
	endforeach;
	
	return null;
	
epilog
	if shifts &lt;&gt; null then
		shifts.purge;
		delete shifts;
	endif;
	
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getShiftForTimeStampOld" id="8a769342-a853-4d73-b97a-5769a806448c">
        <source>getShiftForTimeStampOld(_ts : TimeStamp) : CM_Shift;
// ---------------------------------------------------------------------------
// Created:		15 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Fix performance in Voyage KPI processing
					Method getShiftsForTimeStamp rewritten
					
*/

vars
	posNeg, idx, numOfDays, dayOfWeek : Integer;
	aStdShift : CM_ShiftStd;
	tmpShift, theShift : CM_Shift;
	dates : DateArray;
	aDate, bDate : Date;
	shiftTS, stTS, endTS : TimeStamp;
	tmpTime : Time;
	shift : CM_ShiftStartDateCodeDict;

begin
	// ********  DO NOT USE  ***********

	create dates transient;
	create shift transient;
	
	aDate := _ts.date - 1;
	stTS.setDate(aDate);
	tmpTime.setTime(0,0,0,0);
	stTS.setTime(tmpTime);
	
	foreach idx in 1 to 3 do
		dates.add(aDate);
		aDate := aDate + 1;
	endforeach;

	// ### build up an array of shifts over the days
	foreach aDate in dates do
		dayOfWeek := aDate.dayOfWeek();
		foreach aStdShift in self.allShiftsStandard discreteLock 
			where aStdShift.shiftDay = dayOfWeek do

			shiftTS.setDate(aDate);
			shiftTS.setTime(aStdShift.startTime);
			
			tmpShift := self.allShiftsDay[shiftTS,aStdShift.code]; // is there a persistent shift for this time?
			
			if tmpShift = null then
				create tmpShift transient;
				tmpShift.setProxy(null,null, null, aStdShift.code, aStdShift.description,aStdShift.myTerminal, false);
				
				tmpShift.startDateTime := shiftTS;
				
				bDate := aDate;
				if aStdShift.startTime &gt; aStdShift.endTime then
					bDate := bDate + 1;
				endif;
				
				tmpShift.endDateTime.setDate(bDate);
				tmpShift.endDateTime.setTime(aStdShift.endTime);
				shift.add(tmpShift);
			endif;
		endforeach;
		
		endTS.setDate(aDate);
		tmpTime.setTime(23,59,59,0);
		endTS.setTime(tmpTime);
		
		foreach tmpShift in self.allShiftsDay discreteLock 
			where tmpShift.startDateTime &gt;= stTS and tmpShift.startDateTime &lt;= endTS do
			if not shift.includes(tmpShift) then
				shift.add(tmpShift);

			endif;

		endforeach;

	endforeach;

	foreach tmpShift in shift do
		if _ts &gt;= tmpShift.startDateTime
		and _ts &lt;= tmpShift.endDateTime then
			theShift := tmpShift.cloneSelf(true);
			return theShift;
		endif;
	endforeach;

	// PAR 21305 	nothing exactly matching but we do have some candidates
	//					so find one for same day at least
	if theShift = null and not shift.isEmpty() then
		foreach tmpShift in shift reversed do
			if _ts.date = tmpShift.endDateTime.date then
				theShift := tmpShift.cloneSelf(true);
				return theShift;
			endif;
		endforeach;
		// nothing for same day so use last
		if theShift = null then
			tmpShift := shift.last;
			theShift := tmpShift.cloneSelf(true);
			return theShift;
		endif;
	endif;
	return null;

epilog
	delete dates;

	shift.purge;
	delete shift;

end;
</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getShiftForTimeStampReal" id="a6ecc956-2dbf-4564-abbd-6ce41bcc2866">
        <source>getShiftForTimeStampReal(_toTS : TimeStamp) : CM_Shift;
// Get a real shift object for this timestamp
vars
	iter			: Iterator;
	shift			: CM_Shift;
	startTS,
	endTS			: TimeStamp;
	
begin
	// No shift can span more than one day, so start looking from midnight one day before _fromTS
	startTS := null;
	startTS.setDate(_toTS.date - 1);
	
	iter := self.allShiftsDay.createIterator();
	self.allShiftsDay.startKeyGeq(startTS, null, iter);
	
	while iter.next(shift) do
		if shift.startDateTime &lt;= _toTS 
		and shift.endDateTime &gt;= _toTS then
			return shift;
		endif;
	endwhile;

	return null;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_toTS" type="TimeStamp"/>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getShiftStartTimeForDOW" id="7aa86954-49dc-47ee-abb7-e8865670c57d">
        <source>getShiftStartTimeForDOW(_dayOfWeek : Integer) : Time;
// --------------------------------------------------------------------------------
// Created:		09 September 2010 by cnwjo3
//
// Purpose:		par 25615.  What is the start time of the first shift for a 
//				particular day.
//
vars
	startTime : Time;
	standardShift : CM_ShiftStd;
begin
	startTime.setTime(0,0,0,0);  //if no shift found then this is the default value
	
	foreach standardShift in self.allShiftsStandard do
		if standardShift.shiftDay = _dayOfWeek then
			startTime := standardShift.startTime;
			break;  //we've found the first shift.  we can break now.
		endif;
	endforeach;
	
	return startTime;
end;</source>
        <Parameter name="_dayOfWeek" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getShiftsFromRange" id="4c855ddf-01da-48c2-ba12-1f5997ee5d88">
        <source>getShiftsFromRange(_shiftDict : CM_ShiftStartDateCodeDict input;
				   _fromTS, _toTS : TimeStamp);

/*

Purpose:			Create transient shifts representing all the shifts covering the range
					specified in the range of _fromTS to _toTS, and add them t0 _shifts.
					It is the caller's responsibility to delete these transients when they
					have finished with them.
					Note that "ignored" standard shifts are returned in the collection, and the
					caller needs to deal with them appropriately.

Parameters:			_shiftDict collection to populate
					Range of timestamps to find shifts for

Return Value:		_shiftDict populated with transient CM_Shift objects


Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Fix performance in Voyage KPI processing
					Rewritten to use new algorithm

*/

vars
	realShifts		: CM_ShiftStartDateCodeDict;
	realShift,
	tempShift		: CM_Shift;
	standardShift 	: CM_ShiftStd;
	startDate,
	endDate,
	thisDate		: Date;
	standardIter	: Iterator;
	dayOfWeek 		: Integer;
	shiftStartTS,
	shiftEndTS		: TimeStamp;
	
begin
	// Start by getting the persistent shifts for the date range
	create realShifts transient;
	self.getShiftsFromRangeReal(realShifts, _fromTS, _toTS);
	
	// Populate the receiving collection with clones of the real shifts
	foreach realShift in realShifts do
		create tempShift transient;
		
		tempShift.setProxy(null, null, null, realShift.code, realShift.description, self, realShift.ignore);
		tempShift.startDateTime :=  realShift.startDateTime;
		tempShift.endDateTime   :=  realShift.endDateTime;

		_shiftDict.add(tempShift);
	endforeach;
	
	// Now need to generate shifts from the standard shifts that do not clash with the real shifts
	// No shift can span more than one day, so start from one day before _fromTS
	startDate := _fromTS.date - 1;
	endDate := _toTS.date;
	
	//19 Sep 2019	NDL	TFS 46628
	if not startDate.isValid or not endDate.isValid then
		return;
	endif;
	
	standardIter := self.allShiftsStandard.createIterator();
	
	foreach thisDate in startDate to endDate do
		dayOfWeek := thisDate.dayOfWeek();
	
		self.allShiftsStandard.startKeyGeq(dayOfWeek, null, standardIter);
		while standardIter.next(standardShift) do
			if standardShift.shiftDay &lt;&gt; dayOfWeek then
				break;
			endif;
	
			// Generate actual timestamps for this "standard" shift
			shiftStartTS.setDate(thisDate);
			shiftStartTS.setTime(standardShift.startTime);
		//	shiftStartTS := self.localToSystemTime( shiftStartTS);
			if standardShift.startTime &gt; standardShift.endTime then
				shiftEndTS.setDate(thisDate + 1);
			else
				shiftEndTS.setDate(thisDate);
			endif;
			shiftEndTS.setTime(standardShift.endTime);
		//	shiftEndTS := self.localToSystemTime( shiftEndTS);
			// If the new shift would be outside the range we are interested in, then ignore it
			if shiftEndTS &lt;= _fromTS then
				continue;
			endif;
			if shiftStartTS &gt; _toTS then
				continue;
			endif;
			
			// If we haven't already got a shift at this time, then create a transient one
			if _shiftDict[shiftStartTS, standardShift.code] = null then
				create tempShift transient;
				tempShift.setProxy(null, null, null, standardShift.code, standardShift.description, self, false);
			
				tempShift.startDateTime := shiftStartTS;
				tempShift.endDateTime := shiftEndTS;
				
				_shiftDict.add(tempShift);
			endif;
			
		endwhile;
	
	endforeach;
	

epilog
	delete realShifts;
	delete standardIter;
	
end;</source>
        <Parameter name="_shiftDict" type="CM_ShiftStartDateCodeDict" usage="input"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getShiftsFromRangeOld" id="6f615d87-b407-4969-8e22-14d1f3598540">
        <source>getShiftsFromRangeOld(_shift : CM_ShiftStartDateCodeDict input; _from, _to : TimeStamp);
// ---------------------------------------------------------------------------
// Created:		15 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Fix performance in Voyage KPI processing
					Method getShiftsFromRange rewritten
					
*/
vars
	posNeg, idx, numOfDays, dayOfWeek : Integer;
	aStdShift : CM_ShiftStd;
	pxyShift : CM_Shift;
	dates : DateArray;
	aDate, bDate : Date;
	shiftTS, stTS, endTS : TimeStamp;
	tmpTime : Time;

begin
	// ********  DO NOT USE  ***********
	
	create dates transient;
	_from.differenceAsTime(_to,posNeg, numOfDays);
	numOfDays := numOfDays + 2;
	aDate := _from.date - 1;
	stTS.setDate(aDate);
	tmpTime.setTime(0,0,0,0);
	stTS.setTime(tmpTime);
	
	foreach idx in 1 to numOfDays do
		dates.add(aDate);
		aDate := aDate + 1;
	endforeach;
	
	// ### build up an array of shifts over the days
	foreach aDate in dates do
		dayOfWeek := aDate.dayOfWeek();
		if stTS = null then
			stTS.setDate(aDate);
			tmpTime.setTime(0,0,0,0);
			stTS.setTime(tmpTime);
		endif;
		foreach aStdShift in self.allShiftsStandard discreteLock 
			where aStdShift.shiftDay = dayOfWeek do
	
			shiftTS.setDate(aDate);
			shiftTS.setTime(aStdShift.startTime);
			
			pxyShift := self.allShiftsDay[shiftTS,aStdShift.code]; // is there a persistent shift for this time?
			
			if pxyShift = null then
				create pxyShift transient;
				pxyShift.setProxy(null,null, null, aStdShift.code, aStdShift.description,aStdShift.myTerminal, false);
				pxyShift.startDateTime := shiftTS;
				bDate := aDate;
				if aStdShift.startTime &gt; aStdShift.endTime then
					bDate := bDate + 1;
				endif;
				pxyShift.endDateTime.setDate(bDate);
				pxyShift.endDateTime.setTime(aStdShift.endTime);

			endif;
			_shift.add(pxyShift.CM_Shift);		
		endforeach;
		
		endTS.setDate(aDate);
		tmpTime.setTime(23,59,59,0);
		endTS.setTime(tmpTime);
		
		foreach pxyShift in self.allShiftsDay discreteLock 
			where pxyShift.CM_Shift.startDateTime &gt;= stTS and pxyShift.CM_Shift.startDateTime &lt;= endTS do
			if not _shift.includes(pxyShift.CM_Shift) then
				_shift.add(pxyShift.CM_Shift);
			endif;

		endforeach;
	
	endforeach;






epilog
	delete dates;
end;</source>
        <Parameter name="_shift" type="CM_ShiftStartDateCodeDict" usage="input"/>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getShiftsFromRangeReal" id="434b7a38-5c1d-4a0f-97da-5295a191e693">
        <source>getShiftsFromRangeReal(_shifts : Collection input;
					   _fromTS, _toTS : TimeStamp);

/*

Purpose:			Populate the _shifts collection with all the persistent actual shifts
					that include the range specified by from and to timestamps given

Parameters:			Collection to be populated
					From and To timestamps

Return Value:		_shifts collection populated


Date		Who		Reason
23 Jun 2010	cnwkpd1	PAR #24609 - KPI performance enhancements

*/

vars
	iter			: Iterator;
	shift			: CM_Shift;
	startTS,
	endTS			: TimeStamp;
	
begin
	// No shift can span more than one day, so start looking from midnight one day before _fromTS
	startTS := null;
	startTS.setDate(_fromTS.date - 1);
	
	iter := self.allShiftsDay.createIterator();
	self.allShiftsDay.startKeyGeq(startTS, null, iter);
	
	while iter.next(shift) do
		// Break out when the shift starts after the end of the range
		if shift.startDateTime &gt; _toTS then
			break;
		endif;
	
		// Ignore any shifts ending before the start of the range
		if shift.endDateTime &lt;= _fromTS then
			continue;
		endif;
	
		_shifts.add(shift);
	
	endwhile;

	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_shifts" type="Collection" usage="input"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStateData" id="8849c06a-a824-433d-a9bc-0c919553c380">
        <source>getStateData(pGroup : Integer; pKey : String) : Any protected;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/08/2006	cnwdad1		Added condition to test for existance of app.myPassport	before dereferencing it.
// 07/12/2022 	navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	if pGroup &lt; 1 then
		return null;
	endif;
	
	if app.myPassport &lt;&gt; null and not app.myPassport.isInEdiVerifyMode then						//07.12.2022 navma1 #52499
		app.myPassport.myActivityCapture.logConfig('Group:' &amp; pGroup.String &amp; ' Key:' &amp; pKey);
	endif;
	
	if pGroup &lt;= self.allStateObjects.size then
		stateObj := self.allStateObjects[pGroup];
	endif;
	
	if stateObj = null then
		return null;
	endif;
	
	return stateObj.getStateData(pKey);

end;</source>
        <access>protected</access>
        <Parameter name="pGroup" type="Integer"/>
        <Parameter name="pKey" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSystemCargoBOLTypes" id="f998cefd-638b-4f0b-bc14-f0252dae1a83">
        <source>getSystemCargoBOLTypes(_cargoBOLTypeArray : CM_CargoBOLTypeArray input);
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter					: Iterator;
	cargoBOLType			: CM_CargoBOLType;
begin

	iter := self.allCargoBOLTypes.createIterator;
	while iter.next(cargoBOLType) do
		if cargoBOLType.isSystemCargoBOLType then
			_cargoBOLTypeArray.add(cargoBOLType);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_cargoBOLTypeArray" type="CM_CargoBOLTypeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSystemTimeZoneID" id="9806e8e9-f7a1-4cbf-8145-d4967f3da233">
        <source>getSystemTimeZoneID() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwns1	Initial creation

*/

vars

begin
	return app.systemTimeZoneID;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTAFromClassString" id="a9d8d224-abdf-4cda-8f36-55c2e91dc747">
        <source>getTAFromClassString(_str : String; _startIdx : Integer io; _class : Class) : CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	tmpStr : String;
	tmpTA : CM_TerminalArea;
begin
	
	if _startIdx &gt; _str.length then
		return null;
	endif;
	
	foreach idx in _startIdx to _str.length do
		tmpStr := _str[1:idx];
		tmpTA := self.allTerminalAreas[tmpStr];
		if tmpTA.isKindOf(_class) then
			return tmpTA;
		endif;
	endforeach;


	return null;
epilog
	_startIdx:=idx;	
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_startIdx" type="Integer" usage="io"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getTITxns" id="5657acb0-6865-4cab-a6e5-ff8576ee97ba">
        <source>getTITxns(_type : Integer; 
			_startDate, _endDate : TimeStamp;
			_lookupByType : Boolean; //false = lookup by DT,Type; true by Type,DT
			_callBackMethod : String; 
			_callBackObject : Object;
			_col : Collection input);
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     
//	11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   		 
// ----------   ----------  --------------------------------------------------
vars
	iter			: Iterator;
	trans			: CM_TITransaction;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	dictByTypeDT	: CM_TITransactionByTypeDateDict;
	dictByDTType	: CM_TITransactionByDateTypeDict;
	filterRpt		: CMQF_FilterReports;
	
begin
	passport := app.myPassport;
	if _col = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection passed is null');
		return;
	endif;
	
	if _lookupByType then
		dictByTypeDT := self.allTITransactionsByTypeDate;
		iter := dictByTypeDT.createIterator();
		dictByTypeDT.startKeyGeq(_type, _startDate, iter);
	else
		dictByDTType := self.allTITransactions;
		iter := dictByDTType.createIterator();
		dictByDTType.startKeyGeq(_startDate, _type, iter);
	endif;
	
	while iter.next(trans) do
		if _lookupByType then
			iter.getCurrentKeys(keyType,keyTimeStamp);  //MTN-35226
		else
			iter.getCurrentKeys(keyTimeStamp,keyType);  //MTN-35226
		endif;
			
		if _type &lt;&gt; null and keyType &lt;&gt; _type then
			break;
		endif;
		
		if keyTimeStamp &gt; _endDate then
			break;
		endif;
		
		if breakOut then  
			break;
		endif;
		
		if _callBackMethod &lt;&gt; null and _callBackObject &lt;&gt; null then
			if (not _callBackObject.sendMsgWithIOParamsJMT(_callBackMethod, trans, passport, breakOut).Boolean) then
				continue;
			endif;
		endif;
		
		if _callBackObject &lt;&gt; null and _callBackObject.isKindOf(CMQF_FilterReports) then
			filterRpt := _callBackObject.CMQF_FilterReports;
			filterRpt.checkStatusIncludesObject(null, passport, breakOut);
		endif;
		
		if (not _col.includes(trans)) then
			_col.add(trans);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_lookupByType" type="Boolean"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsByTypeFromOnsiteTIs" id="b19e5832-c663-4199-8574-5cacfc26f72e">
        <source>getTITxnsByTypeFromOnsiteTIs(_type : Integer;
					   _startDate,
					   _endDate : TimeStamp;
					   _cargoTypeId : Integer;
					   _callBackMethod : String;
					   _callBackObject : Object;
					   _collection : Collection input);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		25 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// MES CCMS 1015 PAR22444 - cnwsh3. Messina Reports (Document - Teminal Ops BRS 2.1)
//----------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	passport : CM_Passport;
	txnSet	: ObjectSet;
	
	iter : Iterator;
	
begin
//COULD REFACTOR THIS TO CHECK MORE THAN JUST THE ONSITE DICT BUT FOR THE TIME BEING THIS IS THE ONLY PLACE W'RE CHECKING
//SEE CM_VOYAGE::GETTITXNSBYTYPEFROMTIS AS EXAMPLE OF FUTHER IMPLEMENTATION.  AT THIS STAGE NOT WANTING TO CHECK OFFSITES
	passport := app.myPassport;
	create txnSet transient;

	if _collection = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection (_collection) item is null');
	endif; 
	//PAR22642 - cnwsh3 Changed to also start at a cargo type to allow for more direct lookup. 
	iter := self.allOnsiteTIsByCargoTypeId.createIterator();
	self.allOnsiteTIsByCargoTypeId.startKeyGeq(_cargoTypeId, null, iter);
	while iter.next(ti) do
		if _cargoTypeId &lt;&gt; null and 
		   _cargoTypeId &lt;&gt; ti.myCargoType.id then
			break;
		endif;
		
		ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, txnSet);
	endwhile;
	
	/*foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock where ti.allTransactions.isNotEmpty() do
		ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, txnSet);
	endforeach;*/
	
	txnSet.copy(_collection);
epilog
	delete iter;
	delete txnSet;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_cargoTypeId" type="Integer"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsForType" id="3b582256-2bb7-4b79-9b6b-28382f54a896">
        <source>getTITxnsForType(_type : Integer; _startDate, _endDate : Date; _col : Collection input);
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.getTITxnsForTypeAdvanced(_type, _startDate.TimeStamp, _endDate.TimeStamp, null, null, _col);

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsForTypeAdv" id="74d19847-f800-46fc-a6bd-d143b4d2e64b">
        <source>getTITxnsForTypeAdv(_type : Integer; _startDate, _endDate : TimeStamp; 
					_callBackMethod : String; _callBackObject : Object; 
					_isCAMS : Boolean; _col : Collection input) protected;
// --------------------------------------------------------------------------------
// Created:		30 August 2010 by cnwdad1
//
// Purpose:		N.B Some transaction types are 'SUB TYPES' of others. You will need
//				to call this method for EVERY specific trx type. (Still much faster
//				than searching by timestamp/type!)
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/08/2010	cnwdad1		Created for CCMS 1903 (PAR #24065).
// 01/11/2010	cnwdad1		PAR #26157 - refactored while loop to fix key checks.
// 11/12/2012	cnwcs5		par 30855 / CCMS SFW 1294 - use CAMS timestamp
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
// --------------------------------------------------------------------------------
vars
	coll			: Dictionary;
	iter			: Iterator;
	trx				: CM_TITransaction;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	query			: CMQF_FilterReports;
begin
	passport := app.myPassport;
	
	if _col = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection passed is null');
		return;
	endif;
	
	if _isCAMS then
		coll	:= self.allTITransactionsByCamsTS;
		iter	:= coll.createIterator();
		
		coll.startKeyGeq(_type, _startDate, iter);
	else
		coll	:= self.allTITransactionsByTypeDate;
		iter	:= coll.createIterator();
		
		coll.startKeyGeq(_type, _startDate, iter);
	endif;
	
	while iter.next(trx) do
		iter.getCurrentKeys(keyType, keyTimeStamp);  //MTN-35226
		
			
		if (keyType &lt;&gt; _type) or (keyTimeStamp &gt; _endDate) then
			break;
		endif;
		
		if _callBackMethod &lt;&gt; null and _callBackObject &lt;&gt; null then
		
			if (not _callBackObject.sendMsgWithIOParamsJMT(_callBackMethod, trx, passport, breakOut).Boolean) then
				continue;
			endif;
			
		elseif _callBackObject &lt;&gt; null and _callBackObject.isKindOf(CMQF_FilterReports) then
			query := _callBackObject.CMQF_FilterReports;
			
			// i think this is just so a user can cancel
			query.checkStatusIncludesObject(null, passport, breakOut);	
		endif;
		
		if (not _col.includes(trx)) then
			_col.add(trx);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_isCAMS" type="Boolean"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsForTypeAdvanced" id="bed43cc6-7835-4a5f-bbc4-3b29ed98c3ab">
        <source>getTITxnsForTypeAdvanced(	_type : Integer;
							_startDate,
							_endDate : TimeStamp;
							_callBackMethod : String;
							_callBackObject : Object;
							_col : Collection input);
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     N.B Some transaction types are 'SUB TYPES' of others. You will need to call this method for
//				EVERY specific trx type. (Still much faster than searching by timestamp/type!)
//			 
// ----------   ----------  --------------------------------------------------
// 25/08/2010	cnwdad1		CCMS 1903 (PAR 24065). Refactored.
// ---------------------------------------------------------------------------
begin
	self.getTITxnsForTypeAdv(_type, _startDate, _endDate, _callBackMethod, _callBackObject, false, _col);
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsForTypeAdvancedCams" id="87a112d5-18dd-4256-aca8-db671dce6592">
        <source>getTITxnsForTypeAdvancedCams(	_type : Integer;
							_startDate,
							_endDate : TimeStamp;
							_callBackMethod : String;
							_callBackObject : Object;
							_col : Collection input);
// --------------------------------------------------------------------------------
// Created:		30 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.getTITxnsForTypeAdv(_type, _startDate, _endDate, _callBackMethod, _callBackObject, true, _col);
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsForTypeAll" id="98481df8-2ea7-4259-8fea-2f9ad57eb51a">
        <source>getTITxnsForTypeAll(_type : Integer;
					_startDate,
					_endDate : TimeStamp;
					_callBackMethod : String;
					_callBackObject : Object;
					_col : Collection input);
// ---------------------------------------------------------------------------
// Created:		18 February 2003  by Jason Chapman  (cnwjc2)
//
//			Return all trxns of the specified type (i.e. include subtypes)
// ---------------------------------------------------------------------------

vars
	object			: Object;
	trxnType		: Integer;
	trxnTypesArr	: IntegerArray;
	tempCol			: CM_TITransactionByDateTypeDict;
	
begin
	if _col = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection passed is null');
		return;
	endif;
	
	create trxnTypesArr transient;
	create tempCol transient;
	
	global.getTxnTypesOfType(_type, trxnTypesArr);

	foreach trxnType in trxnTypesArr do : trans_loop
		tempCol.clear();
		self.getTITxnsForTypeAdvanced(trxnType, _startDate, _endDate, _callBackMethod , _callBackObject, tempCol);	
//		tempCol.copy(_col);			// cnwrl1 08/09/2009 PAR20198 - what it was
		// cater for the same transaction being picked up via different
		// selection criteria eg "Moved" and "Moved - Picked up".
		if tempCol.isEmpty then
			continue trans_loop;
		endif;
		foreach object in tempCol discreteLock do : col_loop
			if not _col.includes( object ) then
				_col.add( object );
			endif;
		endforeach col_loop;
	endforeach trans_loop;

epilog
	delete trxnTypesArr;
	delete tempCol;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsMatchingId" id="2a1bcad2-4aad-4559-8547-4bd2e155de32">
        <source>getTIsMatchingId( _tiId : String;  _cargoType : Integer; _allTis : CM_TISet io; _state : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2011	cnwndl1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	aDict : CM_TrackedItemDicts;
 	upperId : String;
 	reverseId : String;
begin

	upperId := _tiId.trimBlanks.toUpper;

	ti := self.lookupTrackedItem(upperId, _cargoType, _state, null, true);

	if ti &lt;&gt; null then
		_allTis.add(ti);	//One exact match
		return;
	endif;
	
	//-----------------
	//Search for REVERSED key
	//-----------------
	reverseId := upperId.reverse;

	if _state = TI_STATE_NORMAL then
		aDict := self.allOnsiteTIsByIdCargoTypeRev;
	elseif _state = TI_STATE_NOTIFIED then
		aDict := self.allNotifiedTIsByIdCargoTypeRev;
	elseif _state = TI_STATE_TBA then
		aDict := self.allTbaTIsByIdCargoTypeRev;	
	endif;
	if aDict = null then
		return;	//Handle dicts not yet here...
	endif;

	aDict.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, _allTis, null);
	
epilog
	
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_allTis" type="CM_TISet" usage="io"/>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIsNeedingSubTermOrBUReset" id="62498f1f-bb2a-4e1d-8b6c-ee93d78b9c91">
        <source>getTIsNeedingSubTermOrBUReset( _processOffsite : Boolean; _processOnsite : Boolean; _tisNeedingReset : CM_TISet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	unProcessedTis : CM_TISet;
	subTermAreaDef : CM_SubTerminalAreaDef;
	subTerm : CM_SubTerminal;
	tiSet : CM_TISet;
	iter : Iterator;
	ti : CM_TrackedItem;
	invalidObj : Boolean;
	edition : Integer;
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;
	bank : CM_Bank;
	defaultBank : CM_Bank;

begin
	
	if not self.getConfig(IsSubTerminalAreaDefined).Boolean then
		return;
	endif;
	
	
	create unProcessedTis transient;
	create tiSet transient;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidObj );
	
	defaultBank := self.getDefaultCompanyBank;
	
	if _processOnsite then
	
		// all onsite cargo get their sub-term set to the value associated with the location
		// that they are currently in. No association means null sub-term.
	
		self.allOnsiteTIsByCargoTypeId.copy( unProcessedTis );
	
		foreach subTermAreaDef in self.allSubTerminalAreaDefs discreteLock do
			subTerm := subTermAreaDef.mySubTerminal;
			bank := subTerm.getMyBank;
			tiSet.clear();
			subTermAreaDef.getAllTisInArea(tiSet );
			iter := tiSet.createIterator;
			while iter.next( ti ) do
				invalidObj := false;
				edition := ti.edition;
				if not invalidObj then
					if unProcessedTis.includes(ti) then
						unProcessedTis.removeIfPresent(ti);
						if ti.mySubTerminal &lt;&gt; subTerm or ti.companyOid &lt;&gt; bank then
							_tisNeedingReset.addNoDuplicates( ti, false );
						endif;
					endif;
				endif;
			endwhile;
			delete iter;

		endforeach;
		
		//we should be left with only the cargo that is not related to any sub terminals
		// defined areas, so null out the subterminal ref.
		
		iter := unProcessedTis.createIterator;
		while iter.next( ti ) do
			invalidObj := false;
			edition := ti.edition;
			if not invalidObj then
				if ti.isChild then
					// will be handled by the change to the parent.
					continue;
				endif;
				if ti.mySubTerminal &lt;&gt; null or ti.companyOid &lt;&gt; defaultBank then
					_tisNeedingReset.addNoDuplicates( ti, false );
				endif;
			endif;
		endwhile;
		delete iter;
		
	endif;
	
	// should only ever need this when first setting "IsSubTerminalAreaDefined"
	if _processOffsite then
		
		//all pre-notes and onship cargo get sub-term set to null, leave bank alone.
		iter := self.allNotifiedTIsByCargoTypeId.createIterator;
		while iter.next( ti ) do
			invalidObj := false;
			edition := ti.edition;
			if not invalidObj then
				if ti.mySubTerminal &lt;&gt; null then
					_tisNeedingReset.addNoDuplicates( ti, false );
				endif;
			endif;
		endwhile;
		delete iter;
			
		create voyages transient;
		self.getAllCurrentVoyages(voyages, true, true, true);
		
		foreach voyage in voyages do
			iter := voyage.allOnshipTIsByCargoTypeId.createIterator;
			while iter.next( ti ) do
				invalidObj := false;
				edition := ti.edition;
				if not invalidObj then
					if ti.mySubTerminal &lt;&gt; null then
						_tisNeedingReset.addNoDuplicates( ti, false );
					endif;
				endif;
			endwhile;
			delete iter;
			
			iter := voyage.allNotifiedTIsByCargoTypeId.createIterator;
			while iter.next( ti ) do
				invalidObj := false;
				edition := ti.edition;
				if not invalidObj then
					if ti.mySubTerminal &lt;&gt; null then
						_tisNeedingReset.addNoDuplicates( ti, false );
					endif;
				endif;
			endwhile;
			delete iter;
		
		endforeach;
	endif;

epilog

	delete unProcessedTis;
	delete voyages;
	delete tiSet;
	delete iter;

end;</source>
        <Parameter name="_processOffsite" type="Boolean"/>
        <Parameter name="_processOnsite" type="Boolean"/>
        <Parameter name="_tisNeedingReset" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTagReaderFromAddress" id="3efbdffb-06f7-49fa-99ab-8af3dde2161e">
        <source>getTagReaderFromAddress(_tcpAddress : String;
						_port : Integer) : CM_RFIDTagReader;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jun 2007	cnwdvb1	Initial creation
07 Sep 2009	cnwkpd1	PAR #20601 - Add in Port number to idetify Reader

*/


vars
	reader : CM_RFIDTagReader;

begin

	// THIS METHOD WILL BE REPLACED WITH A LOOK UP IN THE NEAR FUTURE 
	foreach reader in self.allRFIDTagReadersByCode discreteLock where reader.context &lt;&gt; TagReaderContext_Machine do
		if reader.ipAddress = _tcpAddress  and reader.portNumber = _port then
		
			return reader;
		endif;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="_tcpAddress" type="String"/>
        <Parameter name="_port" type="Integer"/>
        <ReturnType type="CM_RFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreaGroup" id="f92b55cd-5cbc-445c-85d8-1a753ce66b70">
        <source>getTerminalAreaGroup(_type : Integer; _first : Boolean) : CM_TerminalAreaGroup;
// ---------------------------------------------------------------------------
// Created:		01 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTAG : CM_TerminalAreaGroup;
begin
	if _first then
		foreach aTAG in self.allTerminalAreaGroups discreteLock do
			if aTAG.type = _type then
				return aTAG;
			endif;
		endforeach;
	else
		foreach aTAG in self.allTerminalAreaGroups  discreteLock, reversed do
			if aTAG.type = _type then
				return aTAG;
			endif;
		endforeach;
	
	endif;
	
	return null;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_first" type="Boolean"/>
        <ReturnType type="CM_TerminalAreaGroup"/>
    </JadeMethod>
    <JadeMethod name="getTerminalEvent" id="117028b7-b9ad-4bff-88c5-4a7f8ea0ead8">
        <source>getTerminalEvent(_event : Integer) : Integer;

// cnwdvb1 01 November 2002 
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	terminalInstId : Integer;

begin
	terminalInstId := self.getInstanceIdForObject64(self).Integer;
	return (terminalInstId * TERMINAL_EVENTS_FACTOR) + _event;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTerminalKinerja" id="eebb3cb1-8a60-42cf-8e61-f806308f6873">
        <source>getTerminalKinerja():CMIF_KinerjaArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars

 	kinerjaYorSor : CMIF_Kinerja;
	kinerjaArr	: CMIF_KinerjaArray;
	checkDT		: TimeStamp;
	iterVoy,
	iter		: Iterator;
	startDate,
	endDate 	: Date;
	year        : Integer;
	strStart,
	yearStr,
 	strEnd		: String;

begin
	checkDT := app.actualTimeAppServer;
	create kinerjaArr transient;
	
	//This only for YOR and SOR
	create kinerjaYorSor transient;
	kinerjaYorSor.myTerminal := self;
	kinerjaYorSor.setUTShedOccupancyRatio();
	kinerjaYorSor.setUTYardOccupancyRatio();
	kinerjaYorSor.dateTime := checkDT;
	kinerjaYorSor.dataSource := "MT";
	kinerjaArr.add(kinerjaYorSor);
	
	
	return kinerjaArr;
epilog

end;</source>
        <ReturnType type="CMIF_KinerjaArray"/>
    </JadeMethod>
    <JadeMethod name="getTextForAuditStrOnCargoType" id="20886ff7-8f5c-4272-866b-c2009a4c4c94">
        <source>getTextForAuditStrOnCargoType() : String;
/*

Purpose:			Returns Audit Text for Cargo Type

Parameters:			NONE

Return Value:		String:	Audit text to use for Cargo Type

Date		Who		Reason
03 June 2022	navpw1	Initial creation TFS: 53752

*/

begin
	return self.code &amp; "/" &amp; self.name &amp; Cr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeAtTerminal" id="98913a49-3f7f-4500-b62d-afc2f2b5132a">
        <source>getTimeAtTerminal(_cmif_GV : CMIF_VoyageGlobal; _cargoOperation : Integer) : Integer;
//-----------------------------------------------------------------------
//	Created:	31 January 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	minsDelayed : Integer;
	
begin

	if _cargoOperation = HMS_Movement.CargoOperation_Discharge then
		minsDelayed	:=	(self.getConfig(MinResTimeDisch).Decimal * 60).rounded();
	elseif _cargoOperation = HMS_Movement.CargoOperation_Load then
		minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
	else
		// default is to load
		minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
	endif;
	
	/*
	if _cmif_GV = null then
		minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
		
		if minsDelayed &lt; (self.getConfig(MinResTimeDisch).Decimal * 60).rounded() then
			minsDelayed	:=	(self.getConfig(MinResTimeDisch).Decimal * 60).rounded();
		endif;
	else
		if _cmif_GV.isLoadTerminal (self) then
			minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
		elseif _cmif_GV.isDischargeTerminal (self) then
			minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
		else
			minsDelayed	:=	(self.getConfig(MinResTimeLoad).Decimal * 60).rounded();
			if minsDelayed &lt; (self.getConfig(MinResTimeDisch).Decimal * 60).rounded() then
				minsDelayed	:=	(self.getConfig(MinResTimeDisch).Decimal * 60).rounded();
			endif;
		endif;
	endif;
	*/
	
	return minsDelayed;
end;</source>
        <Parameter name="_cmif_GV" type="CMIF_VoyageGlobal"/>
        <Parameter name="_cargoOperation" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUnmatchedLogDocket" id="f5bdfb02-5c93-4751-bf6e-957396dbc863">
        <source>getUnmatchedLogDocket(_bolNumber, _operatorCode : String; _numLogs : Integer;  _useIsMatchedAndMoved : Boolean) : CM_BOLIn;
// -------------------------------------------
// Created 22 March 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
vars

	iter 			: Iterator;
	logDocket 		: CM_BOLIn;
	ext 			: CM_BOLExtLogIn;
	keyType	: Integer;
	keyNum			: String;
	keyTS			: TimeStamp;

begin

	iter := self.allLogBOLsUnmatched.createIterator();
	self.allLogBOLsUnmatched.startKeyGeq(BOLType_Log, _bolNumber, null, iter);
	while iter.next(ext) do
		iter.getCurrentKeys(keyType,keyNum,keyTS);  //MTN-35226
		if keyType &lt;&gt; BOLType_Log or
		   keyNum &lt;&gt; _bolNumber then
			break;
		endif;

		// Resynch both because we usually use both from calling methods.
		logDocket := ext.myBOL.CM_BOLIn;
		
		if (not tryLock(logDocket, Share_Lock, Transaction_Duration, LockTimeout_Server_Defined)) then
			continue;
		endif;
		
		if _useIsMatchedAndMoved then
			if ext.isMatchedAndMoved() then
				continue;
			endif;
		else
			if logDocket.isMatched then
				continue;
			endif;
		endif;
	
		if logDocket.number = _bolNumber and 
		   logDocket.getOperatorCode = _operatorCode and 
		   ext.isNumItemsSameForMatch(_numLogs) then
			return logDocket;
		endif;
	endwhile;
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_numLogs" type="Integer"/>
        <Parameter name="_useIsMatchedAndMoved" type="Boolean"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoBOLTypes" id="ce07d765-3ad1-4f1a-885f-a6cf1bf9047a">
        <source>getUserCargoBOLTypes(_cargoBOLTypeArray : CM_CargoBOLTypeArray input);
// ---------------------------------------------------------------------------
// Created:     15 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter					: Iterator;
	cargoBOLType			: CM_CargoBOLType;
	
begin

	iter := self.allCargoBOLTypes.createIterator;
	while iter.next(cargoBOLType) do
		if not cargoBOLType.isSystemCargoBOLType then
			_cargoBOLTypeArray.add(cargoBOLType);
		endif;
	endwhile;
	
epilog

	delete iter;
end;</source>
        <Parameter name="_cargoBOLTypeArray" type="CM_CargoBOLTypeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVSBookInAdvanceDelivTimeInt" id="ab3b18df-f0fa-4734-ac48-610efb9640bb">
        <source>getVSBookInAdvanceDelivTimeInt( _origHrs : Integer output ):TimeStampInterval;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwndl1	Initial creation	Par 31393
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	ruleNumber : Integer;
	tsInt : TimeStampInterval;
	hrs : Integer;
	days : Integer;
	now : TimeStamp;
	ruleInt1 : TimeStampInterval;
	workTs : TimeStamp;

begin

	ruleNumber := self.getConfig(VsBookingRule).Integer;	// see constants on CM_VehicleBookings
	hrs := self.getConfig(VsBookMinAdvanceHrs).Integer;
	if hrs = 0 and ruleNumber = 0 then
		return null;
	endif;
	
	_origHrs := hrs;
	
	if hrs &gt; 0 then 	
		while hrs &gt; 23 do
			days := days + 1;
			hrs := hrs - 24;
		endwhile;
		tsInt.set(days, hrs * 60 * 60000);
	endif;
	
	if ruleNumber = 0 then	//CM_VehicleBookings.BVR0
		return tsInt;
		
	elseif ruleNumber = 1 then	//CM_VehicleBookings.BVR1
		// Recifes rule
		now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if now.time &gt;= "08:00".Time and now.time &lt;= "16:00".Time then
			// during working hours, std "VsBookMinAdvanceHrs" applies
			return tsInt;
			
		else
			// outside of normal working hours, you can only book for normal working hours
			if now.time &lt; "08:00".Time then
				workTs.setDate(now.Date);
			elseif now.time &gt; "16:00".Time then
				workTs.setDate( (now.Date + 1 ).Date );	
			endif;
			
			workTs.setTime("08:00".Time);
			ruleInt1 := workTs - now;
			if ruleInt1 &gt; tsInt then
				_origHrs := ruleInt1.asHours.Integer + 1;
				return ruleInt1;
			else
				return tsInt;
			endif;
			
		endif;
	
	endif;
	
	return tsInt;
	
	///// Just to provide a reference of where these are really used...
	write CM_VehicleBookings.BVR0;
	write CM_VehicleBookings.BVR0;

epilog

end;</source>
        <Parameter name="_origHrs" type="Integer" usage="output"/>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getVSBookInAdvancePuTimeInt" id="c4f96c9c-81d9-4ece-af69-4ff7f55a429c">
        <source>getVSBookInAdvancePuTimeInt( _origHrs : Integer output ):TimeStampInterval;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	tsInt : TimeStampInterval;
	hrs : Integer;
	days : Integer;

begin

	hrs := self.getConfig(VsBookMinAdvancePu).Integer;
	if hrs = 0 then
		return null;
	endif;
	
	_origHrs := hrs;
	
	while hrs &gt; 23 do
		days := days + 1;
		hrs := hrs - 24;
	endwhile;
	tsInt.set(days, hrs * 60 * 60000);
	
	return tsInt;

epilog

end;</source>
        <Parameter name="_origHrs" type="Integer" usage="output"/>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getVSTimeslotGraceTimeInterval" id="a54e2831-872f-4097-afbc-b40f75ec75d4">
        <source>getVSTimeslotGraceTimeInterval( _origMins : Integer output):TimeStampInterval;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	tsInt : TimeStampInterval;
	graceMins : Integer;

begin

	graceMins := self.getConfig(VsOntimeGracePeriod).Integer;
	if graceMins = 0 then
		return null;
	endif;
	
	_origMins := graceMins;
	
	tsInt.set(0, graceMins * 60000);
	
	return tsInt;

epilog

end;</source>
        <Parameter name="_origMins" type="Integer" usage="output"/>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getValidLocationActivityObjs" id="133006f8-8f9c-4adb-bdd7-900c15e8023d">
        <source>getValidLocationActivityObjs( 	_trainSet : CM_TrainSet input;
									_voyageSet : CM_VoyageSet input;								
									_vvrSet : CM_VehicleVisitRecordSet input;
									_earliest : TimeStamp
									);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	now : TimeStamp;
	earliest : TimeStamp;
	iter : Iterator;
	
	train : CM_Train;
	
	voyage: CM_Voyage;
	startVoyage: CM_Voyage;
	
	vvr : CM_VehicleVisitRecord;
	startVVR : CM_VehicleVisitRecord;

begin

	now := app.actualTimeAppServer;
	if _earliest &lt;&gt; null and _earliest.isValid then
		earliest := _earliest;
	else
		earliest := now.cnEcAddDays( ( self.getLocationActivityMaxDays() * -1 ) );
	endif;
	
	if _trainSet &lt;&gt; null then
		foreach train in self.allTrainsOnTerminal discreteLock do
			if train.isNullTrain() then
				continue;
			endif;
			_trainSet.add(train);
		endforeach;
		
		foreach train in self.allTrainsDepartedReversed discreteLock do
			if train.isNullTrain() then
				continue;
			endif;
			if earliest &gt; train.departureDT then
				break;
			endif;
			_trainSet.add(train);
		endforeach;
		
	endif;
	
	if _voyageSet &lt;&gt; null then
		iter := self.allVoyagesByArrivalDTCode.createIterator;
		startVoyage := self.allVoyagesByArrivalDTCode.getAtKeyGeq( earliest, null );
		
		if startVoyage &lt;&gt; null then
			iter.startAtObject( startVoyage );
			while iter.next( voyage ) do
				_voyageSet.addNoDuplicates( voyage, false );
			endwhile;
		endif;
		delete iter;
		
		iter := self.allVoyagesByDepartDTCode.createIterator;
		startVoyage := self.allVoyagesByDepartDTCode.getAtKeyGeq( earliest, null );
		
		if startVoyage &lt;&gt; null then
			iter.startAtObject( startVoyage );
			while iter.next( voyage ) do
				_voyageSet.addNoDuplicates( voyage, false );
			endwhile;
		endif;
		delete iter;
		
	endif;
	
	if _vvrSet &lt;&gt; null then
		iter := self.allVehicleVisits.createIterator;
		startVVR := self.allVehicleVisits.getAtKeyGeq( earliest );
		
		if startVVR &lt;&gt; null then
			iter.startAtObject( startVVR );
			while iter.next( vvr ) do
				_vvrSet.add( vvr );
			endwhile;
		endif;
		delete iter;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_trainSet" type="CM_TrainSet" usage="input"/>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_vvrSet" type="CM_VehicleVisitRecordSet" usage="input"/>
        <Parameter name="_earliest" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getValidRoadOpsDispCrit" id="39501442-ba7e-4e66-98e8-393553f446ea">
        <source>getValidRoadOpsDispCrit( includeArray : IntegerArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation		TFS 2995 / 2638

*/

vars

begin

	//The list of valid options to sort the wle's within the Truck list in Road Operations
	//if you change these you also need to change 
	
	// CM_Terminal::setupDynaDictForRoadOps
	// CM_Request::addStringForRaodOpsDDKey
	// CM_TrackedItem::addStringForRaodOpsDDKey

	includeArray.clear();
	
	includeArray.add(YACriteriaType_AvGrade);
	includeArray.add(YACriteriaType_BOL);
	includeArray.add(YACriteriaType_BookingRef);
	includeArray.add(YACriteriaType_CargoGroup);
	includeArray.add(YACriteriaType_CargoType);
	includeArray.add(YACriteriaType_Colour);
	includeArray.add(YACriteriaType_Commodity);
	includeArray.add(YACriteriaType_Consignee);
	includeArray.add(YACriteriaType_Consignor);
	includeArray.add(YACriteriaType_DestinationPort);
	includeArray.add(YACriteriaType_DischargePort);
	includeArray.add(YACriteriaType_FreightForward);
	includeArray.add(YACriteriaType_Hazardous);
	includeArray.add(YACriteriaType_ImexStatus);
	includeArray.add(YACriteriaType_ISO);
	includeArray.add(YACriteriaType_LoadPort);
	includeArray.add(YACriteriaType_Mark);
	includeArray.add(YACriteriaType_OperatorItem);
	includeArray.add(YACriteriaType_Product);
	includeArray.add(YACriteriaType_SpecialLift);
	includeArray.add(YACriteriaType_SpecialStow);
	includeArray.add(YACriteriaType_Voyage);

epilog

end;</source>
        <Parameter name="includeArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVehicleVisitForBatNumber" id="9564c911-09b0-451d-90a5-f5244fd7a9d0">
        <source>getVehicleVisitForBatNumber(_batNumber : String) : CM_VehicleVisitRecord;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	tmpVVR, vvr : CM_VehicleVisitRecord;

begin
	foreach vvr in self.allVehicleVisits reversed, discreteLock do 
		if vvr.getBatNumber() = _batNumber then
			tmpVVR := vvr;
			break;
		endif;
		// gone back more than 7 days? - just give up
		if (app.actualTimeServer.Date - vvr.timeIn.Date) &gt; 7 then
			break;
		endif;
	endforeach;
	
	if tmpVVR &lt;&gt; null and vvr.isCancelled then
		tmpVVR := null;
	endif;
	
	return tmpVVR;

epilog

end;</source>
        <Parameter name="_batNumber" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getVehicleVisitGateItemsByTran" id="321e1342-c289-4080-aba8-2bf23e8041e8">
        <source>getVehicleVisitGateItemsByTran(_tranNum : String; _trans : CMGTE_EntitySet input; _clear : Boolean);
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gate, subItem : CMGTE_Entity;
	len : Integer;
	today : Date;
	tmpDict : CMGTE_GateEntityByTranDateDict;
	iter : Iterator;
begin
	if _trans = null then
		return;
	endif;
	
	if _clear then
		_trans.clear;
	endif;
	
	len := _tranNum.length();
	create tmpDict transient;
	self.allGateEntityByTranNumDate.copy(tmpDict);
	
	iter := tmpDict.createIterator();
	tmpDict.startKeyGeq(_tranNum, today, iter);
	
	while iter.next(gate) do : outerLoop
		if gate.tranNumber[1:len] &lt;&gt; _tranNum  then
			break;
		endif;
		
		foreach subItem in _trans discreteLock do
			if gate.date = subItem.date then
				continue outerLoop;
			endif;
		endforeach;
		_trans.add(gate);
	endwhile;
epilog
	delete tmpDict;
	delete iter;
end;</source>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_trans" type="CMGTE_EntitySet" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getVehicleVisitRecordByTran" id="3312e23d-95ce-428f-ada8-eb01dc47a225">
        <source>getVehicleVisitRecordByTran(_tran : String) : CM_VehicleVisitRecord;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	 ts : TimeStamp;
begin
	ts := app.actualTimeServer;	// TFS 1970// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	return self.allVehicleVisitsByNumDT.getAtKeyGeq(_tran.trimBlanks(), ts);	
end;</source>
        <Parameter name="_tran" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getVesselVisitCount" id="2942972a-22da-425d-a7ea-92c278a5225c">
        <source>getVesselVisitCount(_vesselCode : String; _endDT : TimeStamp) : Integer;
//--------------------------------------------------
// Created:	17 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	checkDT : Boolean;
	cnt : Integer;
	iter : Iterator;
	tmpVoyage : CM_Voyage;
begin
	if _vesselCode = null then
		return null;
	endif;
	
	iter := self.allVoyagesByVesselCodeArrivDT.createIterator();
	self.allVoyagesByVesselCodeArrivDT.startKeyGeq(_vesselCode, null, iter);
	checkDT := _endDT.isValid();
	
	while iter.next(tmpVoyage) do
		if tmpVoyage.vesselCode &lt;&gt; _vesselCode then
			break;
		endif;
		if checkDT
		and tmpVoyage.arrivedDT.isValid()
		and tmpVoyage.arrivedDT &gt; _endDT then
			break;
		endif;
		cnt := cnt+1;	
	endwhile;

	return cnt;

epilog
	delete iter;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_endDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVesselsFormBOLs" id="7d3bc1df-e4ed-4715-852a-86693b2c2fff">
        <source>getVesselsFormBOLs(vesselSet : CM_VesselSet input;
				  _bolNumber  : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2020	jlgma1	Initial creation
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	voyageSet        : CM_VoyageSet;
	voyage           : CM_Voyage;
	vessel 			 : CM_Vessel;
begin
	create voyageSet transient;
	self.getVoyagesFormBOLs(voyageSet,_bolNumber);
	
	foreach voyage in voyageSet discreteLock do
		vessel := voyage.getMyVessel();					//05.06.2025 navma1 #MTN-34114
		if vessel &lt;&gt; null then
			vesselSet.tryAdd(vessel);
		endif;
	
	endforeach;
epilog
	delete voyageSet;
end;</source>
        <Parameter name="vesselSet" type="CM_VesselSet" usage="input"/>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselsLastVoyage" id="45f0b5a8-0de6-4dfb-a0e0-c35992c62369">
        <source>getVesselsLastVoyage(_vesselCode : String) : CM_Voyage;
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter : Iterator;
	lastVoyage,
	tmpVoyage : CM_Voyage;
begin
	if _vesselCode = null then
		return null;
	endif;
	
	iter := self.allVoyagesByVesselCodeArrivDT.createIterator();
	self.allVoyagesByVesselCodeArrivDT.startKeyGeq(_vesselCode, null, iter);

	// return the last voyage to arrive, usually a future voyage as typically voyages
	// are added to the system in advance, with an arrival date that is in the future
	while iter.next(tmpVoyage) do
		if tmpVoyage.vesselCode &lt;&gt; _vesselCode then
			break;
		endif;
		if tmpVoyage.myHMSVoyageData &lt;&gt; null then
			//Only interested in voyages with harbour details
			lastVoyage := tmpVoyage;
		endif;
	endwhile;
	
	return lastVoyage;

epilog
	delete iter;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageForVesselSchedule" id="29749ab5-7082-405b-9ceb-dfb07ae20fa3">
        <source>getVoyageForVesselSchedule(_voyageSet : CM_VoyageSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2018	jlger1	Initial creation 41267

*/

vars
	voyage  : CM_Voyage;
	iter : Iterator;
	departedHours : Integer;
	departedTS,
	scheduledTS,
	now : TimeStamp;
	failedDAC : CM_DataAccessController;
begin
	now := app.actualTimeServer;
	
	departedHours := app.myPassport.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if departedHours = 0 then
		departedHours := 48;
	endif;
		
	departedTS := now.changeByXXHours(-departedHours);
	scheduledTS := now.addDays(30);
	
	iter := self.allVoyagesByDepartDTCode.createIterator();
	self.allVoyagesByDepartDTCode.startKeyGeq(departedTS,null,iter);
	while iter.next(voyage) do
		if voyage.isNullVoyage or voyage.archived or voyage.isCancelled then //jlier1 TFS 51963 5/10/21
			continue;
		endif;
		if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		if voyage.arrivedDT &gt; scheduledTS then
			// outside of timeframe
			break;
		endif;
		_voyageSet.addNoDuplicates(voyage, false);		// 14/12/19 MAP TFS48037
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVoyageFromVesselCusRes" id="b5686d00-ab89-4b40-b114-dfa19007a514">
        <source>getVoyageFromVesselCusRes(_vesselCode: String; _matchDate: TimeStamp): CM_Voyage;
//----------------------------------------------------------------
//	Created:	13 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars	
	iter					: Iterator;
	voyage,
	tmpVoyage				: CM_Voyage;
	arrivalDateTmpVoyage,
	arrivalDateVoyage		: TimeStamp;
	daysToCheckDeparted : Integer; //CCMS1547
	oldestDT : TimeStamp;
	
begin
	daysToCheckDeparted := self.getConfig(CarCusresOldVoyageDays).Integer;
	iter := self.allVoyagesByVesselCodeArrivDT.createIterator();
	self.allVoyagesByVesselCodeArrivDT.startKeyGeq(_vesselCode, null, iter);

	while iter.next(tmpVoyage) do
		if tmpVoyage.vesselCode &lt;&gt; _vesselCode then
			break;
		endif;
		if tmpVoyage.archived then //cnwrs1 May 2007 Par14115 
			continue;
		endif;
		if daysToCheckDeparted &gt; 0 then //cnwrs1 CCMS 1070 sept 07
			oldestDT := _matchDate.addDays(-daysToCheckDeparted);
			if tmpVoyage.arrivedDT &lt; oldestDT then
				continue;
			endif;
		endif;
		if voyage &lt;&gt; null then
			//workout which arrival is closer to date
			arrivalDateTmpVoyage := tmpVoyage.arrivedDT;
			arrivalDateVoyage := voyage.arrivedDT;
			if _matchDate.getDifference(arrivalDateTmpVoyage) &lt; _matchDate.getDifference(arrivalDateVoyage) then
				voyage := tmpVoyage;
			else
				//leave as is
			endif;
		else
			voyage := tmpVoyage;
		endif;
	endwhile;

	return voyage;
	
epilog					// cnwrl1 18/08/2010 PAR 24050
	delete iter;		// cnwrl1 18/08/2010 PAR 24050
	
end;
</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_matchDate" type="TimeStamp"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyagesFormBOLs" id="ad29f7b9-ea6b-4513-8619-3fb731a1b60a">
        <source>getVoyagesFormBOLs(_voyageSet : CM_VoyageSet input;
				  _bolNumber : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2020 cnwma1  Bug 49996: ASPA - Voyage Group Code - Issues
11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
*/

vars
	iter				: Iterator;
	bolDict				: CM_BOLByTypeNumberDTDict;
	bolIn				: CM_BOLIn;
	typeKey				: Integer;
	bolNumKey			: String;
	dtKey               : TimeStamp;
begin
	bolDict := self.allBOLsReceivedByTypeNumberDT;
	iter    := bolDict.createIterator;
	bolDict.startKeyGeq(BOLType_GeneralBillOfLading, _bolNumber,null, iter);
	
	while iter.next(bolIn) do
		iter.getCurrentKeys(typeKey,bolNumKey,dtKey);  //MTN-35226
			
		if typeKey &lt;&gt; BOLType_GeneralBillOfLading then 
			break;
		endif;

		if  bolNumKey &lt;&gt; _bolNumber then
			break;
		endif;
	   
	   if bolIn.getMyVoyage() = null then
			continue;
	   endif;
	   
		_voyageSet.addNoDuplicates(bolIn.getMyVoyage(),false);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonClass" id="5f1f262a-ec8c-4bfa-9781-a72ecd83a154">
        <source>getWagonClass(_wagonNumber: String; _wagonClass: String):CM_WagonClass;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2014	cnwndl1	Initial creation	Par 33615

*/

vars

	wagonVisit : CM_Wagon;
	wagonMaster : CM_WagonMaster;
	wagonClassId : String;
	tmpWagonClass : CM_WagonClass;

begin

	if _wagonNumber.trimBlanks &lt;&gt; null then
	
		//first off get the on-site one if there is one.
		wagonVisit := self.getCurrentWagonByID(_wagonNumber.trimBlanks);
		if wagonVisit &lt;&gt; null then
			tmpWagonClass := wagonVisit.myWagonClass;
			if tmpWagonClass &lt;&gt; null then
				return tmpWagonClass;
			endif;
		endif;
		
		//second see if we have seen it before at this terminal and use that
		wagonMaster := app.myRoot.allWagonMasters[_wagonNumber.trimBlanks];
		if wagonMaster &lt;&gt; null then
			tmpWagonClass := wagonMaster.myWagonClass;
			if tmpWagonClass &lt;&gt; null then
				return tmpWagonClass;
			endif;
		endif;
	
		//third, try the hook code 
		wagonClassId := app.myRoot.getWagonClassViaHookCode( self, _wagonNumber.trimBlanks, null );
		if wagonClassId &lt;&gt; null then
			tmpWagonClass := app.myRoot.allWagonClasses[wagonClassId];
			if tmpWagonClass &lt;&gt; null then
				return tmpWagonClass;
			endif;
		endif;
		
	endif;
	
	//ok if we got this far and they have entered one, try that
	if _wagonClass.trimBlanks &lt;&gt; null then
		//if they have supplied it use this
		tmpWagonClass := app.myRoot.allWagonClasses[_wagonClass.trimBlanks];
		if tmpWagonClass &lt;&gt; null then
			return tmpWagonClass;
		endif;
		
	else 
		//nothing entered, use the default one
		wagonClassId := self.getConfig(DefWagonClass).String;
		if wagonClassId &lt;&gt; null then
			tmpWagonClass := app.myRoot.allWagonClasses[wagonClassId];
			return tmpWagonClass;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_wagonNumber" type="String"/>
        <Parameter name="_wagonClass" type="String"/>
        <ReturnType type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="getWagonClassFromId" id="ffc8220a-7f60-4386-925d-8d8f62f9c625">
        <source>getWagonClassFromId(inWagonId	: String)	: String;
//When passed a wagon Id (ie, "UKC12345"), returns the wagonClass
//portion of the string if it exists. (ie "UKC")
vars
	wagonClassId	:	String;
	wagonId	:	String;
	i	:	Integer ;
begin

	wagonId	:= inWagonId.trimRight;
	if wagonId = null then
		return null;
	endif;
	i := 1;
	while i &lt;= wagonId.length do
		if not wagonId[i:1].isInteger then
			wagonClassId := wagonClassId &amp; wagonId[i:1];
		else
			break;
		endif;
		i := i + 1;
	endwhile;
	wagonClassId := wagonClassId.toUpper;
	return wagonClassId;
end;</source>
        <Parameter name="inWagonId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonForToday" id="ec312de6-59da-4442-a230-11017d4c024a">
        <source>getWagonForToday(_code : String) : CM_Wagon;
// ---------------------------------------------------------------------------
// Created:     29 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	//today : TimeStamp;
	wagon : CM_Wagon;
	maxTimeStamp : TimeStamp;
begin
	//today := app.actualTimeServer; //- cnwmd1, Par 22948
	maxTimeStamp.setDate("#255".Binary.Date); //+ cnwmd1, Par 22948
					
	//wagon := self.allWagons.getAtKeyGeq(_code, today); //- cnwmd1, Par 22948
	wagon := self.allWagons.getAtKeyGeq(_code, maxTimeStamp);  //+ cnwmd1, Par 22948
		
	if wagon &lt;&gt; null then
		if wagon.id = _code then
		//and (wagon.dateTime.date = today.date) then //- cnwmd1, Par 22948
			return wagon;
		endif;
	endif;
		

	

	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getWeighbridgeForComputer" id="d8d82671-f839-4a4d-a357-34dad7610b5b">
        <source>getWeighbridgeForComputer(_isIn : Boolean) : CM_WeighBridgeObj;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlger1	Initial creation

*/

vars
	wBridge : CM_WeighBridgeObj;
begin
	foreach wBridge in self.allWeighBridges discreteLock do
		if wBridge.computerName.toUpper() = app.computerName.toUpper() then
			if wBridge.myGateLane &lt;&gt; null and wBridge.myGateLane.isIn  = _isIn  then
				return wBridge;
			endif;
		endif;	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="getWeighedAtWeightForId" id="dd1a8fc8-4a8a-4274-9bfa-60f346e050eb">
        <source>getWeighedAtWeightForId( _ti : CM_TrackedItem ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2019	jlgndl1	Initial creation

*/

vars

	tiSet : CM_TISet;
	iter : Iterator;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;
	//cargoTYpe : Integer;
	trxTi : CM_Weighed;
	totalWeighedAt : Decimal[16,4];
	voyage : CM_Voyage;

begin

	create tiSet transient;

	if _ti.myCargoType.allowDuplicates then
		//onsite
		startObject := self.allOnsiteTIsByIdCargoType.getAtKeyGeq( _ti.id, _ti.cargoType );
		if startObject &lt;&gt; null then
			iter := self.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.id &lt;&gt; _ti.id or ti.cargoType &lt;&gt; _ti.cargoType then
					break;
				endif;
				tiSet.add( ti );
			endwhile;
			delete iter;
		endif;
		//offsite
		startObject := self.allOffsiteTIsByIdCargoType.getAtKeyGeq( _ti.id, _ti.cargoType, null );
		if startObject &lt;&gt; null then
			iter := self.allOffsiteTIsByIdCargoType.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.id &lt;&gt; _ti.id or ti.cargoType &lt;&gt; _ti.cargoType then
					break;
				endif;
				tiSet.add( ti );
			endwhile;
			delete iter;
		endif;
		
		//And now for cargo released on all non archived voyages too - 08 Aug 2019	NDL
		foreach voyage in self.allVoyagesByCode discreteLock do
		
			startObject := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( _ti.id, _ti.cargoType );
			if startObject &lt;&gt; null then
				iter := voyage.allOnshipTIsByIdCargoType.createIterator;
				iter.startAtObject( startObject );
				while iter.next( ti ) do
					if ti.id &lt;&gt; _ti.id or ti.cargoType &lt;&gt; _ti.cargoType then
						break;
					endif;
					if not ti.releasedDT.date.isValid then
						continue;
					endif;
					tiSet.add( ti );
				endwhile;
				delete iter;
			endif;
		
		endforeach;
		
	else
		tiSet.add( _ti );
		
	endif;
	
	foreach ti in tiSet do
		trxTi := ti.getLastTransOfClass(CM_Weighed).CM_Weighed;
		if trxTi &lt;&gt; null then
			totalWeighedAt := totalWeighedAt + trxTi.weighedAtWeight;
		endif;
	endforeach;
	
	return totalWeighedAt;

epilog

	delete tiSet;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointJobSheet" id="e59a3c3e-6062-4956-9ccd-dbb409a3fb4c">
        <source>getWorkPointJobSheet(_id : String): CM_WorkPointJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1  ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	jobSheet,
	workPointJobSheet : CM_WorkPointJobSheet;
	id				  : String;
	jobSheetDict 	  : CM_WPJobSheetByDate;
begin
	
	id := _id.toUpper;
	
	create jobSheetDict transient;
	self.allJobSheetsForWorkPoints.copy(jobSheetDict);
	
	foreach jobSheet in jobSheetDict discreteLock do 			//25.02.2025 navma1 #MTN-34075
		if jobSheet.externalName = id then						//25.02.2025 navma1 #MTN-34075
			workPointJobSheet := jobSheet;
			break;
		endif;
	endforeach;
	
	return workPointJobSheet;
epilog
	delete jobSheetDict;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="getXMLForTerminalLayout" id="f9ae0c5b-67ce-4a96-9857-ae525b007712">
        <source>getXMLForTerminalLayout() : String;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theXML, tmpString, theColourHex : String;
	aPoint : Point;
begin

	theXML := "&lt;TERM&gt;&lt;id&gt;" &amp; self.code &amp; "&lt;/id&gt;";
	
	foreach theGraphic in self.allLayoutGraphics  do
		thePoints := theGraphic.pointsPolygon;
		theColour := theGraphic.CM_LayoutGraphic.drawLineColour;
		
		theXML := theXML &amp; "&lt;GR&gt;";
		theXML := theXML &amp; "&lt;lb&gt;" &amp; theGraphic.label &amp; "&lt;/lb&gt;&lt;lc&gt;" &amp; theGraphic.lineColour.String &amp; "&lt;/lc&gt;&lt;tp&gt;" &amp;  theGraphic.CM_LayoutGraphic.type.String 
				&amp; "&lt;/tp&gt;&lt;cl&gt;" &amp; theColour.String &amp; "&lt;/cl&gt;";

		
		tmpString := null;
		foreach aPoint in thePoints do
			tmpString := tmpString &amp; aPoint.x.String &amp; ",";
			tmpString := tmpString &amp; aPoint.y.String &amp; ",";
		endforeach;
		tmpString := tmpString[1:tmpString.length - 1];
		
		theXML := theXML &amp; "&lt;Points&gt;" &amp; tmpString &amp; "&lt;/Points&gt;" ; 
		theXML := theXML &amp; "&lt;/GR&gt;";
	endforeach;
	theXML := theXML &amp; "&lt;/TERM&gt;";
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLForTerminalLayoutAll" id="4bbb7fa4-1dba-40d4-858c-b46e5b012f79">
        <source>getXMLForTerminalLayoutAll() : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminalArea : CM_TerminalArea;
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theXML, tmpString, theColourHex : String;
	aPoint : Point;
begin
	
	theXML := self.getXMLForTerminalLayout();
	foreach theTerminalArea in self.allTerminalAreas do
		theXML := theXML &amp; theTerminalArea.getXMLForTerminalAreaLayout();
	endforeach;
	
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode" id="60ab3edb-f4fb-47d4-b2d8-f68a54ea729f">
        <source>getXlationSystemCode(_foreignCode:String; _type:Integer; _foundMatch :Boolean output):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2018	jlger1	Initial creation 42095
04 Sep 2024	navdap1	TFS 63842 NSW | OnePort Integration Dev
27 Sep 2024 navsp1  TFS Defect 66167(JIRA 11746): NSW - Oneport - agentCode from the OnePort response message is not mapped to Operator in MTN
*/

vars
	systemCode, foreignCode	: String;
	xlationTable 			: CM_XlationTable;
	opTerm					: CM_OperatorTerminal;
begin
	//if _type &lt;&gt; XLATION_TYPE_WORKPOINT then											// TFS 63842
	if _type &lt;&gt; XLATION_TYPE_WORKPOINT and _type &lt;&gt; XLATION_TYPE_OPERATOR_BYTERM then	// TFS 63842
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid translation type");
	endif;
	
	foreignCode	:= _foreignCode.trimBlanks;
	
	// TFS 63842 Deal with operator by terminal first
	if _type = XLATION_TYPE_OPERATOR_BYTERM then
		foreach opTerm in self.allOperatorTerminals discreteLock do
			xlationTable := opTerm.allXlationTables[_type, null];
			if xlationTable &lt;&gt; null then
				systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch);
			endif;
			if not _foundMatch then
				systemCode := foreignCode;
			else
				break;
			endif;
		endforeach;
		
		if systemCode = null then		//JIRA 11746
			systemCode := foreignCode;	//JIRA 11746
		endif;							//JIRA 11746
		
		return systemCode;
	endif;
	// TFS 63842 end
	
	if foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[_type, null];		// PAR #25810
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch);	// par 31259 March 2013
		endif;
		
		if not _foundMatch then
			systemCode := foreignCode;
		endif;
	endif;
	
	return systemCode;
epilog

end;</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
