    <JadeMethod name="getTotalForAtttribute" id="e4803d2c-c811-452e-bd48-f3bf6b396096">
        <source>getTotalForAtttribute(_coll :Collection; _attribute :Attribute):Decimal protected;
/*

Date		Who		Reason
01 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	kpi			:CM_KPIVoyageMoveDtl;
	value		:Decimal [12, 2];
	strName		:String;
begin
	if _coll = null then
		return null;
	endif;
	
	strName := _attribute.name;
	
	foreach kpi in _coll.CM_KPIVoyageMoveDtlDict do
		value := value + kpi.getPropertyValue (strName).Decimal;
	endforeach;

	return value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_attribute" type="Attribute"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
