    <JadeMethod name="isTAStorageGroup_Match" id="7d9f7b33-d6be-4766-984f-cfea4c80ca23">
        <source>isTAStorageGroup_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	taStorageGroup : CM_TerminalAreaStorageGroup;
	str			   : String;
	trackedItem    : CM_TrackedItem;
	locStr		   : String;
	location 	   : CM_LocationsController;
	terminal		: CM_Terminal;
	terminalArea	: CM_TerminalArea;
begin
	locStr := self.myTransaction.getLocationStr();
	
	//21/06/2024	navkc1 Bug 64706 - If we have a location str, take that and look for the storage group.
	if locStr &lt;&gt; null then
		terminal := self.myTransaction.myTerminal;
		if terminal &lt;&gt; null then
			terminalArea := terminal.allTerminalAreas[locStr];
			if terminalArea &lt;&gt; null then
				taStorageGroup := terminalArea.allTerminalAreaStorageGroups.first();
				if taStorageGroup &lt;&gt; null then
					str := taStorageGroup.code;
				endif;
			endif;
		endif;
	endif;
	
	//if locStr = null then
	//20/06/2024	navkc1 CR 64611 Task 64623
	if str = null then
		trackedItem := self.myTransaction.myTrackedItem;
	
		if trackedItem &lt;&gt; null then
			taStorageGroup := trackedItem.getTAStorageGroup();
			if taStorageGroup &lt;&gt; null then
				str := taStorageGroup.code;
			endif;
		endif;
	endif;
	
	// Only priorities will be empty.
	if str &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isTAStorageGroup_Compare, str);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoTasks_Match" id="9a8ba31d-4fc7-467b-9cc0-39a2515943f2">
        <source>isToDoTasks_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:	

Date		Who		Reason
22 July 2024	navab1	BUG 65167
*/

vars
	transaction		: CM_TITransaction;
	ti				: CM_TrackedItem;
	tododesc : CM_ToDoTaskDesc;
begin
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myResourceTypeUsage &lt;&gt; null then // do not remove this. The allocation must have either a to do task type and no resource types OR no to do task type and have to do task resopurce type, not both.
		return false;
	endif;
	
	transaction := self.myTransaction;
	
	if transaction = null then
		return null;
	endif;
	
	if transaction.myToDoTask = null then
		return null;
	endif;
	
	tododesc := transaction.myToDoTask.toDoTaskDesc;
	
	if tododesc = null then
		return false;
	endif;
	
	return _yaData.matches(tododesc);

epilog

end;</source>
