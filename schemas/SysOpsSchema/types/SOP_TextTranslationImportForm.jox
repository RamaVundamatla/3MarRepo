    <JadeMethod name="updateProgress" id="f6d9fdbf-a265-45e5-8b22-d5b47cb4d630">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
//--------------------------------------------------------------
// Created: 21 Aug 2006 By: RBarr 
// Reimplemented so refresh happens properly
//--------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time based rather than object-count based
// This is the callback method from CMIF_Monitor.
vars
	lastUpdate : Decimal [20];									// PAR #35843
begin
	if not frmModalDialog.visible then
		return;
	endif;

	// Only update display periodically or when 100% done.
	if self.userScript &lt;&gt; null and self.userScript.isDecimal then										// PAR #35843
		lastUpdate := self.userScript.Decimal;															// PAR #35843
	endif;																								// PAR #35843
	//if _cmifMonitor.partsDone mod 50 = 0 or _cmifMonitor.partsDone = _cmifMonitor.partsInJob then		// PAR #35843
	if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates 				// PAR #35843
	or _cmifMonitor.partsDone = _cmifMonitor.partsInJob then											// PAR #35843
		pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
		pbProgressBar.partsDone := _cmifMonitor.partsDone;
		pbProgressBar.refreshNow;
	endif;
	self.userScript := app.relativeMachineTime.String;													// PAR #35843
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zFinaliseProgressMonitor" id="00b2b3bd-695f-4dc0-96ec-1ff4e5c1c12b">
        <updating/>
        <source>zFinaliseProgressMonitor() protected, updating;

// restore cursor = hourglass, and stop/hide progress bar

begin
	if myProgress = null then
		return;
	endif;

	// show final amount
	myProgress.updateProgress(myProgress.message, myProgress.partsInJob, myProgress.partsDone);
	statusLine.caption := "CSV Import completed";

	myLog.logServer("Finalizing import of translations");
	myLog.logServer("Number of translatable text items processed: " &amp; myProgress.partsDone.String);

	delete myProgress;
	app.myPassport.setMyCMIFMonitor(null);
	
	frmModalDialog.visible := false;					
	app.mousePointer := MousePointer_Default;									

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zInitialiseProgressMonitor" id="9ebbb73a-e655-4bef-b57e-b01d953be841">
        <updating/>
        <source>zInitialiseProgressMonitor(_partsDone, _partsInJob : Integer; _message : String) updating, protected;

// set cursor = hourglass, and start/show progress bar
// MUST call corresponding zFinaliseProgressMonitor in epilog

begin
	app.mousePointer := MousePointer_HourGlass;				

	if myProgress = null then
		create myProgress transient;
		myProgress.myParent := self;
	endif;

	modalDialogReturnValue := ModalDialogReturn_Null;	
	modalDialogShow(null, null, null, null, _message,  'Please Wait....');
	pbProgressBar.visible := true;

	create myLog;
	myLog.fileName := "TranslatableTextImport.log";
	myLog.logServer("");
	myLog.logServer("Initializing import of translations");
	myLog.logServer("Number of translatable text items to process: " &amp; _partsInJob.String);

	myProgress.updateProgress(myProgress.message, _partsInJob, _partsDone);

end;</source>
        <access>protected</access>
        <Parameter name="_partsDone" type="Integer"/>
        <Parameter name="_partsInJob" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="zUpdateProgressMonitor" id="3c84801b-6eea-4be7-82ae-736ff3856888">
        <updating/>
        <source>zUpdateProgressMonitor(_partsDone : Integer):Boolean protected, updating;

vars

begin
	return myProgress.updateProgress(myProgress.message, myProgress.partsInJob, _partsDone);
end;</source>
        <access>protected</access>
        <Parameter name="_partsDone" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
