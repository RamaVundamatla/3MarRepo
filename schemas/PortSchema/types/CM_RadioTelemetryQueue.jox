    <JadeMethod name="includesQueue" id="34ebe087-5f6f-4677-b7a5-ba190c5b1532">
        <source>includesQueue(qToSeek	:	CM_RadioTelemetryQueue):	Boolean;

vars
	aQ	:	CM_RadioTelemetryQueue;
begin
	if qToSeek = null then
		return false;
	endif;
	if qToSeek = self then
		return true;
	endif;
	//---------------
	//Is this in our sub-queue list?
	//---------------
	if self.allSubQueuesById.includes(qToSeek) then
		return true;
	endif;
	//---------------
	//Or, is it in one of my sub-queues?
	//---------------
	foreach aQ in self.allSubQueuesByOrder do
		//----------------		
		//Recursive call
		//----------------		
		if aQ.includesQueue(qToSeek) then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="qToSeek" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
