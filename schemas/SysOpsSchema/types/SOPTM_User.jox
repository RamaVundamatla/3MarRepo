    <JadeMethod name="includeObject" id="452374fc-171c-433b-ad71-456e4760c91a">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	
/*	if self.includeNotAvailableEntries then
		return true;
	else
		return (not _obj.CM_User.isNotAvailableForEntry);
	endif;*/
	
	if _obj.CM_User.isInternalSystemUser then	//17 Jun 2021	NDL	TFS 51310
		if app.myPassport.myUser = null then
			return app.isSpecial;
		else
			return app.isSpecial or app.myPassport.myUser.isSuperUser;
		endif;

	elseif self.includeNotAvailableEntries then
		if self.filterStatus = -1 then
			return true;
		else
			return (_obj.CM_User.status = self.filterStatus);
		endif;
	else	// we have to check notAvailableForEntry for users
		if _obj.CM_User.isNotAvailableForEntry then
			return false;
		else
			if self.filterStatus = -1 then
				return true;
			else
				return (_obj.CM_User.status = self.filterStatus);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
