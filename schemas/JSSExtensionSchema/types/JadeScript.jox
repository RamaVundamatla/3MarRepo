    <JadeMethod name="cnwdad1_Test_Evaluate" id="065398a8-a854-43ad-b4fe-4b17683bb174">
        <source>cnwdad1_Test_Evaluate();
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: Any;
	errorMessage	: String;
	expression		: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	// Calculate the value of PI.
//	expression		:=	"22/7";
//	errorMessage	:=	process.jssEvaluate(expression, Real, app, returnValue);

	// Calculate the integer value of PI, then get the result in words.
	expression		:=	"(22 div 7).jssAsWords(app.currentLocaleInfo)";
	errorMessage	:=	process.jssEvaluate(expression, String, app, returnValue);
	
	if errorMessage = null then
		write returnValue;
	else
		write errorMessage;
	endif;
epilog
	write "Evaluation complete in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_External_Process" id="20993aca-68d6-4f96-a432-d65622b87b60">
        <source>cnwdad1_Test_External_Process();
// --------------------------------------------------------------------------------
// Created:		19 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	processResult	: Integer;
	returnValue		: Integer;
	allArguments	: StringArray;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create allArguments transient;
	
	allArguments.add("d:\jade\system\");
	returnValue	:=	node.createExternalProcess(	null,//"c:\temp\",
												"c:\temp\directory.bat",
												allArguments,
												null,
												false,
												true,
												processResult);

	write "Return Value: " &amp; returnValue.String;
	write "Process Result: " &amp; processResult.String;
epilog
	delete allArguments;
	
	write "External process started in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FileEx_Handler" id="820997d5-ebba-4243-8fc9-7bb0954a1844">
        <source>cnwdad1_Test_FileEx_Handler();
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile		: File;
	fileData	: String;

begin
	on FileException do global.jssFileException(exception);

	create theFile;
	theFile.fileName	:=	"c:\junk\junk.dat";
	theFile.kind		:=	File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version

	if theFile.tryOpen() then
		theFile.writeString(fileData);
	else
		app.msgBox(	$JSS_FILE_CANNOT_OPEN(theFile.fileName),
					$JSS_FILE_ERROR,
					MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	delete theFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FileNode_Copy" id="14a93b1a-bf76-4ed5-bd7e-4a4c3d66d8e5">
        <source>cnwdad1_Test_FileNode_Copy();
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	theFolder	: FileFolder;
	theFileNode	: FileNode;
	result		: Integer;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create theFolder transient;
	theFolder.fileName	:=	"c:\temp\test";
	
	if theFolder.jssCopy("c:\darrell") then
		write "Copy worked.";
	else
		write "Copy failed.";
	endif;
epilog
	delete theFolder;
	
	write "File node copy completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
