    <JadeMethod name="getProDetailForUnassign" id="3e248fe9-57ce-456c-81a9-7aa4690fc8f5">
        <source>getProDetailForUnassign():CM_ProformaDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	proDetail : CM_ProformaDetails;
	invLineType : CM_InvoiceLineDesc;
	qty : Real;
	amount : Decimal[23,6];

begin

	if self.myCashReceipt &lt;&gt; null then
		if self.myInvoiceLine &lt;&gt; null then
			invLineType := self.myInvoiceLine.invoiceLineDesc;
			qty := self.myInvoiceLine.quantity;
			amount := self.myInvoiceLine.lineTotal;
			proDetail := self.myCashReceipt.findProformaMatching( invLineType, qty, amount );
		endif;
	endif;

	return proDetail;

epilog

end;</source>
        <ReturnType type="CM_ProformaDetails"/>
    </JadeMethod>
    <JadeMethod name="getProformaString" id="5184d208-d7cb-446f-9bc4-4be17527dc59">
        <source>getProformaString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	result	: String;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myProformaDetail.myInvoiceLineType, invalid); // JLGAB1 Added during testing
		
	if self.myProformaDetail &lt;&gt; null then
		if self.isManual then	// TFS 45953 do not use void as manual indicator		// manual payment
			result := self.proformaDesc;
		elseif self.myProformaDetail.myTrackedItem &lt;&gt; null then // TFS 39349
			result := self.myProformaDetail.myTrackedItem.id.String &amp; " - " &amp; self.myProformaDetail.myInvoiceLineType.narration;
		
		else
			result := self.myProformaDetail.myInvoiceLineType.narration;
		endif;
	else
		result := self.proformaDesc;
	endif;
	
	if invalid and result = "" then
		result := self.proformaDesc;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
