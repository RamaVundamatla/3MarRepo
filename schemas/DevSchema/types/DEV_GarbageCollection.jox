    <JadeMethod name="deleteOffsiteItems" id="c661c80d-e7ee-4af5-8063-3b41030843a6">
        <updating/>
        <source>deleteOffsiteItems(_setTime : TimeStamp) updating;
//AJA 10/8/00: NFS 3577: Allow users to clear out the offsite dictionary
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	ti : CM_TrackedItem;
    dict : CM_TIArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Offsite Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	iter := app.getMyTerminalDO_NOT_USE().allOffsiteTIsByCargoTypeId.createIterator;

	size := app.getMyTerminalDO_NOT_USE().allOffsiteTIsByCargoTypeId.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " TIs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	
	while iter.next(ti) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TIs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". TIs to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if not ti.isChild then
			if ti.releasedDT &lt; _setTime then
				if global.isValidObject(ti) then
					dict.add(ti);
				endif;
			endif;
		endif;
	endwhile;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(ti) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Offsite TIs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;ti.id&amp;" releasedDT on "&amp;ti.releasedDT.String&amp;" "&amp;ti.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		ti.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TI's erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	on Exception do null;

end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteOldSlotControllers" id="eeca11cf-ff17-4282-8875-ba9ddf821176">
        <source>deleteOldSlotControllers();

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	object : CM_Object;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting SlotControllers..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_SlotController.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " SlotController for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("SlotController checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". SlotController to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if obj.CM_SlotController.myBayVoyage = null then
			dict.add(obj);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(obj) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased SlotController: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;tempReading.String&amp;" "&amp;tempReading.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		obj.CM_Object.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " SlotController erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
