    <JadeMethod name="setIsComplete" id="19e81699-ebeb-403d-9b9b-eaa1ca553a3a">
        <updating/>
        <source>setIsComplete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	dtl : CM_WorkOrderDtl;
	workOrder : CM_WorkOrder;
	complete : Boolean;

begin
	self.isComplete := true;
	workOrder:=self.getMyParent;
	// check is parent is now also complete
	complete := true;
	foreach dtl in workOrder.allWoDtls do
		if not dtl.CM_WorkOrderVoyageDtl.isComplete then
			complete := false;
			break;
		endif;
	endforeach;
	if complete then 
		workOrder.completeMe();
//	else	//19 Oct 2018	NDL	TFS 41450
//		workOrder.setTaskStatus(WO_STATUS_PARTCOMPLETE);
	endif;
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Update);
	workOrder.causeTerminalEvent(Event_WorkOrder_Update);
	// update edition on parent so we get a notification in the Work Order Enquiry screen
	self.updateObjectEdition(workOrder);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="344c3f34-ab8d-42b1-a1b7-1abe3801d510">
        <updating/>
        <source>setMarineDetsFromResourceUsed(_resourceUsedSet: HMS_ResourceUsedSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlger1	Initial creation 41310

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	marineServices,
	purgeSet : CM_WodMarineServiceDetailSet;

begin
	marineServices:=self.getAllMarineServiceDetails();
	if marineServices = null then
		return;
	endif;
	
	create purgeSet transient;
	foreach wodMarineServiceDtl in marineServices do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			marineServices.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	if _resourceUsedSet= null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		wodMarineServiceDtl := marineServices.findWodMarineServiceDet( resourceUsed.myResource );
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			marineServices.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
