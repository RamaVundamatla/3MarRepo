        <source>hasStopOfType(_stopTable : CM_StopsTable) : Boolean;
// ---------------------------------------------------------------------------
// Created:		CCMS 1017 cnwrs1 Aug 2007
// ---------------------------------------------------------------------------

vars

begin
	if _stopTable &lt;&gt; null then
