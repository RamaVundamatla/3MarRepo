    <JadeMethod name="createContractRateEntry" id="3fe7ab24-3ec6-4bb5-bb78-1a324c760b5a">
        <updating/>
        <source>createContractRateEntry()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	contractRateEntry , proxyRateEntry		: CM_InvoiceContractRateEntry;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	theReturn, idx 			: Integer;
	fromAmount  			: Decimal[23,2];
	toAmount 				: Decimal[23,2];
	rate 					: Decimal [23,4];
	contractrate 			: CM_InvoiceContractRate;
	proxyRate, realRate 	: CM_InvoiceContractRate;
	bulkRates 				: CMIF_InvoiceContractBulkRates;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myContractRate = null then
		create proxyRate transient;
		proxyRate.setProxy(null, self.myService, self.myContractDetail, self.myCalculationType); // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
		while true do
			app.myTrxCA.trxCreateInvContractDtlRt(proxyRate, self.myContractRate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_creat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
	endif;
	
	bank := self.myBank;
	scheduleTSstart.setDate(self.mskStartDate.text.asDateJMT());
	scheduleTSstart.setTime(self.mskStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskEndDate.text.asDateJMT());
	scheduleTSend.setTime(self.mskEndTime.text.asTimeJMT());

	create bulkRates transient;
	
	foreach idx in 2 to self.tblData.rows do
		fromAmount := self.tblData.accessCell(idx,FROM_AMOUNT).text.asDecimalJMT();
		toAmount := self.tblData.accessCell(idx,TO_AMOUNT).text.asDecimalJMT();
		rate := self.tblData.accessCell(idx,RATE).text.asDecimalJMT();
		if fromAmount &lt; 0 or toAmount = 0 then // ### JIRA 34344 027MAR 2025 NAVAB1 - Zero is OK for a start
			continue;
		endif;
		create contractRateEntry transient;
		contractRateEntry.setProxy(contractRateEntry.id,rate,fromAmount,toAmount,self.localToSystemTime(scheduleTSstart),self.localToSystemTime(scheduleTSend), 
		self.myContractRate, contractRateEntry.myBusinessUnit);
		bulkRates.allPxyRateEntries.add(contractRateEntry);
	endforeach;
	
	while true do
		app.myTrxCA.trxAddCntrctRateEntries(bulkRates, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoi_contr_rate_entri_creat_s), app.getErrorString(Message),MsgBox_OK_Only);
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_creat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

epilog
	self.mousePointer := Window.MousePointer_Default;
	delete bulkRates;
	delete proxyRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="createRateEntryDate" id="c52d9cbb-2d5c-4290-b1d1-584476350a95">
        <updating/>
        <source>createRateEntryDate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	cmifRangeEntry : CMIF_ContractRangeEntry;
begin	
	if self.myContractRateEntryDates &lt;&gt; null then
		cmifRangeEntry := self.myContractRateEntryDates.myCMIFRangeEntry;
		delete self.myContractRateEntryDates;
		cmifRangeEntry.createCMIFRateEntryDate(self.myContractRate,self.fromTS,self.toTS);
		self.setCMIFRateEntryDates(cmifRangeEntry.allDateRanges[self.fromTS,self.toTS]);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalculationTypes" id="71c4ad70-462b-4839-a592-f38209aa5716">
        <source>doCmbCalculationTypes();
/*
Purpose - 	
Who - NAVAB1
Date - 13FEB2024
ADO -  CR 61579 TASK 62453
*/

vars
	tmpDesc : String;
	aCT,defaultCT : CM_CalculationType;
	invLineType : CM_InvoiceLineDesc;
begin
	invLineType := self.myContractDetail.myInvoiceLineType;
	defaultCT := self.myCalculationType;
	
	self.cmbDeriveQuantity.clear;
	self.cmbDeriveQuantity.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if invLineType &lt;&gt; null
		and not invLineType.isSameCalcType(aCT) then
			continue;
		endif;
		
		tmpDesc := aCT.getComboDescription();               
		self.cmbDeriveQuantity.addItemObject(tmpDesc,aCT); 
	endforeach;
	

    if defaultCT &lt;&gt; null then													//28.8.2023 navhl20 #59914
 // BUG 59913 31AUG2023 NAVAB1       self.cmbDeriveQuantity.text := "Cargo - " &amp; defaultCT.description;
		
		// ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
		if self.cmbDeriveQuantity.findObject(defaultCT) &lt; 1 then
			tmpDesc := defaultCT.getComboDescription();               
			self.cmbDeriveQuantity.addItemObject(tmpDesc,defaultCT);
		endif;
		self.cmbDeriveQuantity.listObject := defaultCT;

    endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="91bd8347-aaf7-4241-b1c0-8fcb09ed8f81">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars
	hasMaintPerm	: Boolean;
begin
	hasMaintPerm := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	
	self.btnNew.enabled		:= hasMaintPerm;
	self.btnSave.enabled	:= hasMaintPerm;
	self.btnRemove.enabled	:= hasMaintPerm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="226fe2d5-4c39-4db1-b775-38875e5bc71c">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	theReturn : Integer;
	contractRate, contractRateEntry, rateEntryObject	: CM_InvoiceContractRateEntry ;
	idx : Integer;
	fromAmount, toAmount : Decimal[23,4];
	rate : Decimal[23,4];
	scheduleTSstart, scheduleTSend : TimeStamp;

begin
	contractRate := _obj.CM_InvoiceContractRateEntry;
	if contractRate = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(Sure_want_remov_invoi_contr_ra, null,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	scheduleTSstart.setDate(self.mskStartDate.text.asDateJMT());
	scheduleTSstart.setTime(self.mskStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskEndDate.text.asDateJMT());
	scheduleTSend.setTime(self.mskEndTime.text.asTimeJMT());
	
	if contractRate.isTransient then
		self.allPxyRateEntries.clear();
		foreach idx in 2 to self.tblData.rows do
			if idx = self.tblData.row then
				continue;
			endif;
			rateEntryObject := self.tblData.accessRow(idx).itemObject.CM_InvoiceContractRateEntry;
			if rateEntryObject.isTransient then
				fromAmount := self.tblData.accessCell(idx,FROM_AMOUNT).text.Decimal;
				toAmount := self.tblData.accessCell(idx,TO_AMOUNT).text.Decimal;
				rate := self.tblData.accessCell(idx,RATE).text.Decimal;
				create contractRateEntry transient;
				contractRateEntry.setProxy(contractRateEntry.id,rate,fromAmount,toAmount,self.localToSystemTime(scheduleTSstart),self.localToSystemTime(scheduleTSend), 
				self.myContractRate, contractRateEntry.myBusinessUnit);
				self.allPxyRateEntries.add(contractRateEntry);
			endif;
		endforeach;
		
	else
		while true do
		app.myTrxDA.trxDeleteInvContractDtlRtEntry(contractRate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				self.allPxyRateEntries.clear();
				foreach idx in 2 to self.tblData.rows do
					if idx = self.tblData.row then
						continue;
					endif;
					rateEntryObject := self.tblData.accessRow(idx).itemObject.CM_InvoiceContractRateEntry;
					if rateEntryObject.isTransient then
						fromAmount := self.tblData.accessCell(idx,FROM_AMOUNT).text.Decimal;
						toAmount := self.tblData.accessCell(idx,TO_AMOUNT).text.Decimal;
						rate := self.tblData.accessCell(idx,RATE).text.Decimal;
						create contractRateEntry transient;
						contractRateEntry.setProxy(contractRateEntry.id,rate,fromAmount,toAmount,self.localToSystemTime(scheduleTSstart),self.localToSystemTime(scheduleTSend), 
						self.myContractRate, contractRateEntry.myBusinessUnit);
						self.allPxyRateEntries.add(contractRateEntry);
					endif;
				endforeach;
				
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors 
				and theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	endif;
	
	self.createRateEntryDate();
	//self.myParentForm.INV_ContractRateMaint.tblDisplayRow();				//14.10.2024 navlc30 #19508
	if self.myParentForm.isKindOf(INV_ContractRateMaint) then				//14.10.2024 navlc30 #19508
		self.myParentForm.INV_ContractRateMaint.tblDisplayRow();
	endif;		

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="ce361eeb-8ea0-428f-9906-84f6efcdd393">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

