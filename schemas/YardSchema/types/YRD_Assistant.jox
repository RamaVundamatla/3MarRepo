    <JadeMethod name="showRailOps" id="d4ae0779-f2b6-44a0-af08-6684b30a5cf5">
        <source>showRailOps(_railArea : CM_Rail; _defaultTrain : CM_Train; _masterMenuAction : CMUI_MenuAction; _mode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2009	cnwndl1	Initial creation

*/

vars

