    <JadeMethod name="doSave" id="a0e7abbb-8e06-4890-831c-39b29f6dedfa">
        <updating/>
        <source>doSave() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars
	myITCProxyObject      : CM_InterTerminalConfig;
	myITBRProxyObject     : CM_InterTerminalBulkRelease;
	configName            : String;
	result                : Boolean;
	rtnValue              : Boolean;
	selectedTerminalAreas : CM_TerminalAreaSet;
begin
	if self.vMode = Mode_Add then
		configName   := tbxConfigName.text.trimBlanks;
	else
		configName   := self.myInterTerminalConfig.configName;
	endif;

	if self.vMode &lt;&gt; Mode_Delete then
		
		if self.vMode = Mode_Edit then
			myITCProxyObject := app.createUpdateProxy(self.myInterTerminalConfig).CM_InterTerminalConfig;
		else
			create myITCProxyObject transient;
		endif;

		create myITBRProxyObject  transient;

		result := doValidate(configName, myITBRProxyObject);
		if result = false then
			return false;
		endif;
	
		selectedTerminalAreas := getSelectedTerminalAreas;
		
		myITBRProxyObject.setProxyForITBR(tbxRelNumber.text.trimBlanks, self.myConsignee, self.txtConsignorVoy.text, 
										  myDeliveryReleaseReason.id, myDeliveryReleaseReason.description,
										  self.myTerminal, null, null /*voyagecode*/, self.mySubTerminal);

		myITCProxyObject.setProxy(configName, self.myGate, self.myLane, myITBRProxyObject,
								  self.myTerminal, selectedTerminalAreas, self.chxAutoAssign.value, 
								  self.chxAutoUnassign.value);
								  
		self.allInterTermTargetTermInfo.copy(myITCProxyObject.allInterTermTargetTermInfo);
	else


	endif;

	rtnValue := self.doTransaction(myITCProxyObject, myITBRProxyObject);
	
	if rtnValue = false then
		app.showErrorWarningDialog(app.getString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_Update);
		self.clearErrorWarnings();
		return rtnValue;
	endif;
	
	return rtnValue;
epilog
	delete selectedTerminalAreas;
	delete myITBRProxyObject;
	delete myITCProxyObject;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTransaction" id="713abb28-8db4-4217-887a-81ac7503dc81">
        <updating/>
        <source>doTransaction(	myITCProxyObject      : CM_InterTerminalConfig io;
				myITBRProxyObject     : CM_InterTerminalBulkRelease io) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	conkc1	Initial creation
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
*/

vars
	rtnValue		: Boolean;
	localCaption	: String;
begin

	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	self.mousePointer := Window.MousePointer_HourGlass;
	localCaption:=self.caption;
	while true do

		if self.vMode = Mode_Add then
	
			app.myTrxCA.trxCreateInterTerminalConfig(myITCProxyObject, self.myInterTerminalConfig, myITBRProxyObject, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
			
		elseif self.vMode = Mode_Edit then
			app.myTrxUA.trxUpdateInterTerminalConfig(myITCProxyObject, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
	
		elseif self.vMode = Mode_Delete then
			app.myTrxDA.trxDeleteInterTerminalConfig(self.myInterTerminalConfig, app.myPassport);
			self.myInterTerminalConfig := null;
			rtnValue	:=	app.myPassport.trxCompletedOK;
	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.vMode.String &amp; ')');
			rtnValue := false;
			break;
		
		endif;
		
		if rtnValue = true then
			break;
		endif;
			
		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;	
		
		self.updateCaptionDeadlockRetry(localCaption);
	endwhile;

	return rtnValue;

epilog
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption:=localCaption;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="myITCProxyObject" type="CM_InterTerminalConfig" usage="io"/>
        <Parameter name="myITBRProxyObject" type="CM_InterTerminalBulkRelease" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidate" id="773f2291-b8fc-4d0d-bf04-b368f52fec2c">
        <updating/>
        <source>doValidate(_configName : String; _bRProxyObject  : CM_InterTerminalBulkRelease) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/
vars
	interTerminalConfig      : CM_InterTerminalConfig;
	defaultDateRequested     : TimeStamp;
begin
	if self.vMode = Mode_Add then

		if _configName = null then
			app.msgBox (app.getErrorString (InterTermConNameMissin), app.getErrorString (Error), MsgBox_OK_Only);
			self.tbxConfigName.setFocus;
			return false;
		endif;

		foreach interTerminalConfig in self.myTerminal.allInterTerminalConfigs do
			if interTerminalConfig.configName.toUpper = _configName.toUpper then
				app.msgBox (app.getErrorString (DuplicateInterTermConfigName) &amp; " '" &amp; _configName &amp; "'", app.getErrorString (Error), MsgBox_OK_Only);
				self.tbxConfigName.setFocus;
				return false;
			endif;
		endforeach;

	endif;

	if self.grpMultiSelect.mySelectedListBox.listCount = 0 then
		app.msgBox (app.getErrorString (Input_Required_For_TA), app.getErrorString (Error), MsgBox_OK_Only);
		self.grpMultiSelect.myAvailableListBox.setFocus;
		return false;
	endif;
	
	if self.lstDestination.listCount = 0 then
		app.msgBox (app.getErrorString (No_Terminal_specified), app.getErrorString (Error), MsgBox_OK_Only);
		self.lstDestination.setFocus;
		return false;
	endif;

	if self.tbxRelNumber.text.trimBlanks = null then
		app.msgBox (app.getErrorString (Must_enter_release_number), app.getErrorString (Error), MsgBox_OK_Only);
		self.tbxRelNumber.setFocus;
		return false;
	endif;
	
	if self.myGate = null then
		app.msgBox (app.getErrorString (Gate_Error11), app.getErrorString (Error), MsgBox_OK_Only);
		self.cmbDefaultGate.setFocus;
		return false;
	endif;

	if self.myConsignee = null then
		app.msgBox (app.getErrorString (ConsigneeRequired), app.getErrorString (Error), MsgBox_OK_Only);
		self.cmbConsignee.setFocus;
		return false;
	endif;

	if self.txtConsignorVoy.text.trimBlanks = null then
		app.msgBox (app.getErrorString (PleaseSelectAVoyage), app.getErrorString (Error), MsgBox_OK_Only);
		self.txtConsignorVoy.setFocus;
		return false;
	endif;
		
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
			app.msgBox (app.getErrorString (SubTerminalRequired), app.getErrorString (Error), MsgBox_OK_Only);
			self.cmbSubTerminal.setFocus;
			return false;
		endif;
	endif;

	if self.myDeliveryReleaseReason = null then
		app.msgBox (app.getErrorString (DeliveryReleaseReasonRequire), app.getErrorString (Error), MsgBox_OK_Only);
		self.cmbDeliveryReasn.setFocus;
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_configName" type="String"/>
        <Parameter name="_bRProxyObject" type="CM_InterTerminalBulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="da7fce67-8488-4eff-8440-ef85ab35045d">
        <updating/>
