    <JadeMethod name="getVoyageDetailsFromTDT" id="a14db65a-3059-4ff8-9780-c16362548c1f">
        <source>getVoyageDetailsFromTDT(	_msgHelper			: CMIF_EDIFACTHelper;
							_voyageCode			: String output;
							_operatorVoyageCode	: String output;	// AKA the CarrierCode
							_operatorVoyage		: CM_Operator output;	// cnwrl1 26/07/2010 PAR 25093
							_vesselName			: String output;
							_lloyds				: String output;
							_callSign			: String output ) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		17 June 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 17/06/2010   cnwsh3      Moving common code to it's own method for 
// 03 Apr 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//----------------------------------------------------------------------
vars
	maxLength	: Integer;
	msgHelper	: CMIF_EDIFACTHelper;
	carrierName : String;
	foundMatch	: Boolean;
begin
	// TDT+20 = The main carriage transport so we assume that the sender means voyage.
	msgHelper	:= _msgHelper;		// to reduce dereferencing
	maxLength	:= CM_Operator::code.getLengthForString();
	
	msgHelper.setNextField;
	_voyageCode := msgHelper.currentField;
	
	msgHelper.setNextField();					// mode of transport
	msgHelper.setNextField();					// transport means
	msgHelper.setNextField();					// Voyage Operator AKA Carrier
	_operatorVoyageCode	:= msgHelper.currentSubItem;	// use full text eg COSCO for the translation below!
	// check if there is a operator translation
	_operatorVoyageCode	:= app.myRoot.getXlationSystemOperatorCode( null, _operatorVoyageCode, foundMatch )[ 1 : maxLength ];
	_operatorVoyage		:= app.myRoot.allOperators[ _operatorVoyageCode ];
	msgHelper.setNextSubItem();	//par 25195 cnwrs1 13 aug 2010
	msgHelper.setNextSubItem();
	msgHelper.setNextSubItem();
	carrierName := msgHelper.currentSubItem[1:30];	//par 25195 cnwrs1 13 aug 2010
	msgHelper.setNextField();					// Excess Transportation Info
	msgHelper.setNextField();					// Transportation Id
	msgHelper.setNextField();					// Excess Transportation Info
	_lloyds := msgHelper.currentSubItem;
	msgHelper.setNextSubItem();
	if msgHelper.currentSubItem = '103' then	// call sign
		_callSign	:= _lloyds;
		_lloyds		:= null;
	endif;
	
	msgHelper.setNextSubItem();					// Code List Responsible Agency
	msgHelper.setNextSubItem();
	_vesselName := msgHelper.currentSubItem;
	if _vesselName = null and	//par 25195 cnwrs1 13 aug 2010
	   carrierName &lt;&gt; null then
		_vesselName := carrierName; //this is to allow for unifeeder sending the vessel name in the carrier name field
	endif;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
        <Parameter name="_operatorVoyageCode" type="String" usage="output"/>
        <Parameter name="_operatorVoyage" type="CM_Operator" usage="output"/>
        <Parameter name="_vesselName" type="String" usage="output"/>
        <Parameter name="_lloyds" type="String" usage="output"/>
        <Parameter name="_callSign" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXlationOperatorVoyageCode" id="158f05c1-5a49-46dc-b2fd-60b4b6c12593">
        <source>getXlationOperatorVoyageCode(
	_operatorSender	: CM_Operator;
	_operatorVoyage	: CM_Operator;
	_voyageCode		: String;
	_vesselName		: String;
	_lloydsNumber	: String;
	_callSign		: String ) : String protected;

/*
Purpose:	This method will attempt to match the VoyageCode supplied against the
			EDI Translations using the vesselName or callSign.
			The translations will be attempted on the Sender Operator if it is not null
			else the Voyage Operator if not null will be used.

Date			Who		Reason
19 July 2010	cnwrl1	Initial creation as part of PAR 25046 - Ensure EDIFACT voyage code translation uses vessel name and call sign.
05/04/2013		cnwcs5	CCMS POL 2097 / par 31259
*/
	
vars
	xlationVoyagecode	: String;
	operator			: CM_Operator;
	foundMatch			: Boolean;
begin
	if _operatorSender = null and _operatorVoyage = null then
		return _voyageCode;
	endif;
	
	if _operatorSender &lt;&gt; null then
		operator	:= _operatorSender;
	else
		operator	:= _operatorVoyage;
	endif;
	
	xlationVoyagecode	:= operator.getXlationSystemCode_Voyage(_voyageCode, _vesselName, _lloydsNumber, _callSign, foundMatch);
	return xlationVoyagecode;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_operatorSender" type="CM_Operator"/>
        <Parameter name="_operatorVoyage" type="CM_Operator"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTFile" id="1fae79be-b95a-4c94-8e1d-d563b52559fd">
        <updating/>
        <source>processEDIFACTFile(_ediFile: CM_EDIFile input; _ediData : CM_EDIData io; _reload : Boolean) protected, updating;
/*
Purpose:
Provide an overall processing Framework for EDIFACT Files.
This will handle UNT/UNH, UNA, UNB/UNZ and CNT segments

Parameters:			
_ediFile is where the raw data is


Date		Who		Reason
18 Nov 2011	cnwgb1	CCMS POL 2122 par 28696 Initial creation
23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
15 aug 2012 cnwrs1	par 30203 failing to load with muliple UNH/UNTs
08 Apr 2013	cnwcs5	CCMS POL 2097 / par 31259
10 Jul 2013	cnwcs5	par 31942 - 
16 Sep 2013 cnwah9  removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//14 Jun 2016   cnwma1	TFS #2048 POL - HSD EDI Empty Release Request
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 24/08/2016	cnwdap1	TFS #2566 AAT EDI IFCSUM - allow for a finalize method on this file type
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 13 Aug 2024  navsaa30 Ticket 65354: POB - IFCSUM - Issues with Load and Discharge Ports
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	msgHelper 		: CMIF_EDIFACTHelper;
    msgCount, numMsgs, 
	untCount 		: Integer;
    lineStr, rawEDIData, message, 
	senderCode 		: String;
	passport 		: CM_Passport;
	ediPartyRules	: CM_EDIPartyRules;
    ediOperator 	: CM_Operator;
	theLines : HugeStringArray;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	rawSenderCode : String;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
	msgHelper.setCurrentGroup(0);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		rawEDIData	:=	rawEDIData &amp; lineStr &amp; CrLf;
		msgCount	:=	msgCount + 1;

		untCount := untCount + 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs

		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	
//CNT
        if msgHelper.currentTag = "CNT" and _ediFile.myEDIFileType.type &lt;&gt; EDIFileType_CusCar then		//cnwmc5 - 23 July 2014 - CCMS 2353 PEN
            if msgHelper.currentGroup = 7 or msgHelper.currentGroup = 9 then
                msgHelper.setCurrentGroup(0);
            endif;

//UNB
		elseif msgHelper.currentTag = "UNB" then
			self.getUNBData(_ediData, msgHelper, senderCode, rawSenderCode, recipientCode, ediPartyRules, ediOperator, creationTS, sequence);
			_ediFile.setFileSenderCode(rawSenderCode); //jlier1 TFS 56234 21/12/22 need the sender code when verifing to get the edi party			//13/8/24 navsaa30 #65354
//UNA
		elseif msgHelper.currentTag = "UNA" then

//UNH
		elseif msgHelper.currentTag = "UNH" then
			untCount := 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
			self.getUNHData(_ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(senderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				_ediFile.ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then 
			self.finalizeFile(msgHelper,ediPartyRules);											// TFS #2566

//UNZ
		elseif msgHelper.currentTag = "UNZ" then

		else
			//self.processEDIFACTSegment(msgHelper, _ediFile, _ediData, ediOperator, ediPartyRules, _reload);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
			self.processEDIFACTSegment(msgHelper, _ediFile, _ediData, ediOperator, ediPartyRules, _reload,version);  //cnwma1 TFS #2048 14/06/2016 
		endif;
		message := msgHelper.currentMessage;
    endforeach;
epilog
    delete msgHelper;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_reload" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTSegment" id="bc14a491-2d18-4be9-8a21-e696d5748d73">
