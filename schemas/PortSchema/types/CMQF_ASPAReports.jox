    <JadeMethod name="getMyEventStart" id="a6a1e087-338f-47a6-bb96-753d774b29b5">
        <source>getMyEventStart():CM_EventType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	eventType : CM_EventType;
	edition : Integer;
	invalid : Boolean;

begin

	eventType := self.myEventStart;
	if eventType = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, eventType, invalid );
		
	edition := eventType.edition;
	if invalid then
		return null;
	endif;

	return eventType;

epilog

end;</source>
        <ReturnType type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="getMyWeightMeasureType" id="725cf0e7-865c-4d28-a0fc-88dbb48e663d">
        <source>getMyWeightMeasureType():CM_MeasurementType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	measureType : CM_MeasurementType;
	edition : Integer;
	invalid : Boolean;

begin

	measureType := self.myWeightMeasureType;
	if measureType = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, measureType, invalid );
		
	edition := measureType.edition;
	if invalid then
		return null;
	endif;

	return measureType;

epilog

end;</source>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="3d861b1f-aeff-4582-bbc1-04c0198c34a4">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	now : TimeStamp;

begin

	if _attrName = ETRow_DateToRun then
		if _getCalculatedDate then
			now := app.actualTimeAppServer;
			return self.setDateFromTemplate(self.dateToRunType, self.dateToRunFactor, now.Date).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.dateToRunType, self.dateToRunFactor);
		endif;
		
	elseif _attrName = ETRow_DateYearStart then
		return self.dateYearStart.String;
	
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isVoyageTmlInAllTmls" id="e13b0cdd-afbc-4c10-9f0f-1bdba92298b9">
        <source>isVoyageTmlInAllTmls(_voyage : CM_Voyage; _allTerminals : CM_TerminalByCodeDict) : Boolean;
/*

Purpose:			Check if _voyage is in one of the terminals selected for the report

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Loading Summary
*/

vars
	terminal : CM_Terminal;
begin
	foreach terminal in _allTerminals where _voyage.myTerminal = terminal do
		return true;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_allTerminals" type="CM_TerminalByCodeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateInputFields" id="afd5cd4d-2e34-462b-a579-7f166d01f9e3">
        <source>validateInputFields():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2019	jlgndl1	Initial creation	TFS 47247

*/

vars

	etDef : EntTableDef;
	etRow : EntTableRow;
	errorRowName : String;
	
	isUnload : Boolean;
	isLoad : Boolean;

begin

	etDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_SpecialVoySum);

	if self.allNonBargeVessels.isEmpty() and self.allBargeVessels.isEmpty then
		errorRowName := "Vessels";
		app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
		return false;
	endif;
	
	if self.allNonBargeVessels.isNotEmpty() then
		isLoad := true;
	elseif self.allBargeVessels.isNotEmpty() then
		isUnload := true;
	endif;
	
	if not self.dateYearStart.isValid then
		errorRowName := "Year Start Date";
		if etDef &lt;&gt; null then
			etRow := etDef.getEntTableRow( ETRow_DateYearStart );
			if etRow &lt;&gt; null then
				errorRowName := etRow.getRawHeadingValue;
			endif;
		endif;
		app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
		return false;
	 endif;
	 
	 if not self.dateToRun.isValid then
		errorRowName := "Date To Run";
		if etDef &lt;&gt; null then
			etRow := etDef.getEntTableRow( ETRow_DateToRun );
			if etRow &lt;&gt; null then
				errorRowName := etRow.getRawHeadingValue;
			endif;
		endif;
		app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
		return false;
	 endif;
	
	 if self.myEventStart = null then
		errorRowName := "Event Start";
		if etDef &lt;&gt; null then
			etRow := etDef.getEntTableRow( ETRow_MyEventStart );
			if etRow &lt;&gt; null then
				errorRowName := etRow.getRawHeadingValue;
			endif;
		endif;
		app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
		return false;
	 endif;
	 if self.myEventFinish = null then
		errorRowName := "Event Finish";
		if etDef &lt;&gt; null then
			etRow := etDef.getEntTableRow( ETRow_MyEventFinish );
			if etRow &lt;&gt; null then
				errorRowName := etRow.getRawHeadingValue;
			endif;
		endif;
		app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
		return false;
	 endif;
	 
	  if isUnload then	  
		 if self.myEventPlaced = null then
			errorRowName := "Event Placed";
			if etDef &lt;&gt; null then
				etRow := etDef.getEntTableRow( ETRow_MyEventPlaced );
				if etRow &lt;&gt; null then
					errorRowName := etRow.getRawHeadingValue;
				endif;
			endif;
			app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
			return false;
		 endif;	 
	 
		 if self.myEventPulled = null then
			errorRowName := "Event Pulled";
			if etDef &lt;&gt; null then
				etRow := etDef.getEntTableRow( ETRow_MyEventPulled );
				if etRow &lt;&gt; null then
					errorRowName := etRow.getRawHeadingValue;
				endif;
			endif;
			app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
			return false;
		 endif;
			 
	elseif isLoad then
		if self.myWeightMeasureType = null then
			errorRowName := "Weight MeasurementType";
			if etDef &lt;&gt; null then
				etRow := etDef.getEntTableRow( ETRow_WeightMeasureType );
				if etRow &lt;&gt; null then
					errorRowName := etRow.getRawHeadingValue;
				endif;
			endif;
			app.raiseCMException1(Input_required_field_Required, errorRowName, null, null); 
			return false;
		endif;
	endif;
	  
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
