    <JadeMethod name="addToolbarControls" id="93d6223f-beef-4f89-8b4d-88c620ebbdee">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: RBarr
// Note add and delete buttons are for developers only 

//--------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowReplace, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);

	if self.isDeveloperMode then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	JLGAB1 JUN19	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
//	JLGAB1 JUN19	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	 //	JLGAB1 JUN19 if you foget to be special when you open the screen you can make yourself special then close and reopen the searcher
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	// 	JLGAB1 JUN19
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left); // 	JLGAB1 JUN19

	if not self.isDeveloperMode then //	JLGAB1 JUN19
		self.btnNew.visible := false; //	JLGAB1 JUN19
		self.btnDelete.visible := false; //	JLGAB1 JUN19
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLocaleMaint, CMUI_Toolbar.Control_Alignment_Left);
	
	if self.isDeveloperMode then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnGenerate, CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnReload, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.addButton(self.btnReplace, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.butSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCloseSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	self.setSearchToolbar();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
