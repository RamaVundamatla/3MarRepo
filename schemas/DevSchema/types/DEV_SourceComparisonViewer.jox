    <JadeMethod name="checkNppAvailable" id="63b682b6-95f2-4c6b-87fa-1960deda8e26">
        <updating/>
        <source>checkNppAvailable() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navpw1	Initial creation

*/

vars
	nppProg86,
	nppProg	: File;
	
begin
	//Check if Notepad ++ is installed in default path either Program Files or Program Files (x86)
	create nppProg86 transient;
	nppProg86.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\Notepad++\notepad++.exe";
	
	create nppProg transient;
	nppProg.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\Notepad++\notepad++.exe";
	
	if nppProg86.isAvailable() or nppProg.isAvailable() then
		self.isNppAvailable := true;
	else
		self.isNppAvailable := false;
	endif;

epilog
	delete nppProg86;
	delete nppProg;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkWinMergeAvailable" id="0e16f9eb-7ef2-46af-839e-97d8fef4c243">
        <updating/>
        <source>checkWinMergeAvailable() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022	navpw1	Initial creation TFS: 52202

*/

vars
	winMergeProg86,
	winMergeProg	: File;
	
begin
	//Check if WinMerge is installed in default path either Program Files or Program Files (x86)
	
	create winMergeProg86 transient;
	winMergeProg86.fileName := "C:\Program Files (x86)\WinMerge\WinMergeU.exe";
	
	create winMergeProg transient;
	winMergeProg.fileName := "C:\Program Files\WinMerge\WinMergeU.exe";
	
	if winMergeProg86.isAvailable() or winMergeProg.isAvailable() then
		self.isWinMergeAvailable := true;
	else
		self.isWinMergeAvailable := false;
	endif;

epilog
	delete winMergeProg86;
	delete winMergeProg;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearForm" id="9f9dc367-1c7f-4fdd-afde-125ff9689de7">
        <source>clearForm() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2023	navpw1	Initial creation

*/

begin
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.btnOpenInWinMerge.visible 		:= false;
	self.btnClearFilter.enabled 		:= true;
	self.btnOpenInNPP.visible 			:= false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbSelectReport_click" id="6ccfafbf-a5d0-40d2-aec6-8115761e23ce">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSelectReport_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	report		: DEV_SourceCompareReport;
	
begin
	if combobox.text = null then
		return;
	endif;
	
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.btnOpenInWinMerge.visible 		:= false;
	self.btnOpenInNPP.visible 			:= false;
	
	report := self.cmbSelectReport.listObject.DEV_SourceCompareReport;
	self.loadData(report, self.txtSearchString.text);
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="compareClassDetail" id="b1a9b12e-1f64-42ca-a186-5b2924944bb5">
        <source>compareClassDetail(_listbox : ListBox; _entity : DEV_SchemaObjectEntity) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

vars
	scm					: Schema;
	currentClass		: Class;
	currentAttribute	: Property;
	currentReference	: Property;
	currentClassConstant: Constant;
	
	currentText,
	newText				: String;
	selIndex,
	dialogResult		: Integer;
	jadeRegexReplacePat	: JadeRegexPattern;
	
	currentTimestamp	: TimeStamp;
	currentModifiedBy,
	currentDocText,
	entityType			: String;
	objectExists		: Boolean;
	devEnt				: DEV_SchemaObjectEntity;
	
begin
	if _entity = null then
		return;
	endif;
	
	objectExists := true;
	
	scm					:= _entity.getMySchema();
	currentClass		:= _entity.getMyClass(scm);
	
	if currentClass = null then
		objectExists := false;
	endif;
	
	if _entity.isKindOf(DEV_Class) and objectExists then
		currentTimestamp	:= currentClass.cnEcGetModifyTimeStamp();
		currentModifiedBy	:= currentClass.getModifiedByJMT();
		currentDocText		:= currentClass.text;
		entityType := "Class";
		
	elseif _entity.isKindOf(DEV_Attribute) and objectExists then
		currentAttribute	:= currentClass.getProperty(_entity.name);
		if currentAttribute = null then
			objectExists := false;
		else
			currentTimestamp	:= currentAttribute.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentAttribute.getModifiedByJMT();
			currentDocText		:= currentAttribute.text;
		endif;
		entityType := "Attribute";
		
	elseif _entity.isKindOf(DEV_Reference) and objectExists then
		currentReference	:= currentClass.getProperty(_entity.name);
		if currentReference = null then
			objectExists := false;
		else
			currentTimestamp	:= currentReference.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentReference.getModifiedByJMT();
			currentDocText		:= currentReference.text;
		endif;
		entityType := "Reference";
		
	elseif _entity.isKindOf(DEV_ClassConstant) and objectExists then
		currentClassConstant:= currentClass.getConstant(_entity.name);
		if currentClassConstant = null then
			objectExists := false;
		else
			currentTimestamp	:= currentClassConstant.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentClassConstant.getModifiedByJMT();
			currentDocText		:= currentClassConstant.text;
		endif;
		entityType := "Class Constant";
		
	endif;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	if not objectExists then
		//Show only the loaded constant
		self.lblCurrLastModified.caption := null;
		self.lblLoadLastModified.caption := _entity.modifiedTimeStamp.String &amp; " - " &amp; _entity.modifiedBy.toUpper();
		self.qlbClassData.enabled := false;
		self.qlbClassData.refreshNow();
		newText := _entity.documentationTextData;
		self.jeLoaded.text := newText;
		self.jeCurrent.text := "";
		self.slStatus.caption := "Source Comparison: Missing";
		return;
	endif;
	
	self.lblCurrLastModified.caption := currentTimestamp.String &amp; " - " &amp;  currentModifiedBy.toUpper();
	self.lblLoadLastModified.caption := _entity.modifiedTimeStamp.String &amp; " - " &amp; _entity.modifiedBy.toUpper();
	
	self.qlbClassData.enabled := false;
	self.qlbClassData.refreshNow();
	
	currentText := currentDocText;
	newText := _entity.documentationTextData;
	
	self.jeCurrent.text := currentText;
	self.jeLoaded.text := newText;
	
	self.compareTextEditors();
	
	/*if _entity.isKindOf(DEV_Class) then
		isSame := self.compareClass(_entity.DEV_Class, currentClass, comparisonResult, exists);
		
	elseif _entity.isKindOf(DEV_Attribute) then
		comparisonResult := self.compareAttribute(_entity.DEV_Attribute, currentAttribute);
		
	elseif _entity.isKindOf(DEV_Reference) then
		comparisonResult := self.compareReference(_entity.DEV_Reference, currentReference);
		
	elseif _entity.isKindOf(DEV_ClassConstant) then
		comparisonResult := self.compareClassConstant(_entity.DEV_ClassConstant, currentClassConstant);
		
	endif;
	
	if not isSame then
		if _entity.reason = DEV_SourceCompareReportAgent.Object_Missing and exists then
			beginTransaction;
			_entity.reason := DEV_SourceCompareReportAgent.Object_Different;
			commitTransaction;
		endif;
		
	else
		//Resolve code goes here
		
	endif;*/
	
	if process.isPW and jadeRegexReplacePat.replaceAll(currentDocText, "") = jadeRegexReplacePat.replaceAll(_entity.documentationTextData, "") then
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - No Logical Differences Found only";
	else
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - Class Detail Differences Found";
	endif;
	
	if _entity.resolvedBy = null then
		dialogResult := app.msgBox(entityType &amp; ' has been found, continue?', 'Method Found', MsgBox_Yes_No);
		if dialogResult = MsgBox_Return_Yes then
			selIndex := _listbox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := _listbox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			self.doClearItemForIndex(selIndex, _listbox);
		endif;
	endif;
	
	if _entity.resolvedBy &lt;&gt; null then
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - Resolved by: " &amp; _entity.resolvedBy &amp; "@" &amp; _entity.resolvedAt.String;
	endif;
	
epilog
	self.qlbClassData.enabled := true;
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="ListBox"/>
        <Parameter name="_entity" type="DEV_SchemaObjectEntity"/>
    </JadeMethod>
    <JadeMethod name="compareGlobalConstant" id="e7cb8b70-5c38-46f6-b94a-6881b93f3c44">
        <source>compareGlobalConstant(_newConstant: DEV_GlobalConstant) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 June 2022	navmd1	Initial creation

*/

vars
	scm					: Schema;
	currentConstant		: Constant;
	
	currentText,
	newText				: String;
	dialogResult		: Integer;
	jadeRegexReplacePat	: JadeRegexPattern;
	
begin
	if _newConstant = null then
		return;
	endif;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	scm := rootSchema.getSchema(_newConstant.myGcCategory.mySchema.name);
	currentConstant := scm.getConstant(_newConstant.name);
	
	if currentConstant = null then
		//Show only the loaded constant
		self.lblCurrLastModified.caption := null;
		self.lblLoadLastModified.caption := _newConstant.modifiedTimeStamp.String &amp; " - " &amp; _newConstant.modifiedBy.toUpper();
		self.qlbGlobalConstants.enabled := false;
		self.qlbGlobalConstants.refreshNow();
		newText := _newConstant.documentationTextData;
		self.jeLoaded.text := newText;
		self.jeCurrent.text := "";
		self.slStatus.caption := "Source Comparison: Missing";
	else
		lblCurrLastModified.caption := currentConstant.getModifiedTimestamp().String &amp; " - " &amp;  currentConstant.getModifiedByJMT().toUpper();
		lblLoadLastModified.caption := _newConstant.modifiedTimeStamp.String &amp; " - " &amp; _newConstant.modifiedBy.toUpper();
		
		self.qlbGlobalConstants.enabled := false;
		self.qlbGlobalConstants.refreshNow();
		
		currentText := currentConstant.text;
		newText := _newConstant.documentationTextData;
		
		self.jeCurrent.text := currentText;
		self.jeLoaded.text := newText;
		
		self.compareTextEditors();
		
		if currentConstant.text = newText and currentConstant.getSource() = _newConstant.value then
			self.slStatus.caption := "Source Comparison: No Differences Found";
			
			if _newConstant.resolvedBy = null then
				dialogResult := app.msgBox('No Changes found would you like to Resolve this item', 'No Changes Found', MsgBox_Yes_No);
				if dialogResult = MsgBox_Return_Yes then
					//schema := _method.myClass.mySchema;
					//class := _method.myClass;
					//selectedMethod := _method;
					
					// navmd1 - lets just mark as resolved rather than deleting, this way we can see historical stuff/complete reports
					/*beginTransaction;
					delete selectedMethod;
					
					if class.allMethods.size &lt; 1 then
						delete class;
					endif;
					
					if schema.allClasses.size  &lt; 1 then
						delete schema;
					endif;
					commitTransaction;*/
					
					//self.qlbDifferentMethods.clear();										// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					//self.loadDifferingMethods(self.myReport, self.txtSearchString.text);	// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					
					// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					self.mnuLBContext.userObject := self.qlbGlobalConstants;
					self.doClearSelectedItem();
					self.mnuLBContext.userObject := null;
					// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					
					self.qlbGlobalConstants.enabled := false;
					//self.qlbDifferentMethods.refreshNow();								// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					self.lblCurrLastModified.caption := null;
					self.lblLoadLastModified.caption := null;
					//self.jeCurrent.text := "";											// ### TFS 52791 (58881) 26Jun2023 NAVPW1
					//self.jeLoaded.text := "";												// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				endif;
			endif;
	else
		if process.isPW and jadeRegexReplacePat.replaceAll(currentConstant.text, "") = jadeRegexReplacePat.replaceAll(_newConstant.documentationTextData, "") and currentConstant.getSource() = _newConstant.value then
			self.slStatus.caption := "Source Comparison: No Logical Differences Found only";
		else
			self.slStatus.caption := "Source Comparison: Constant Differences Found";
		endif;
	endif;
		
	endif;
	
epilog
	self.qlbGlobalConstants.enabled := true;
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_newConstant" type="DEV_GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="compareMethod" id="946784c6-8427-4b78-950f-bf81db96e06f">
        <source>compareMethod(_method : DEV_Method) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202
26 June 2023		navpw1	TFS: 52791 (58881) - Used Mason's clearing code alongside my database object deletion code, as the source code is the same.
												Removed locking down to my user code as well
*/

vars
	schemaName,
	className 		: String;
	currentMethod 	: Method;
	currentSource,
	newSource		: String;
	dialogResult	: Integer;
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	selectedMethod 	: DEV_Method;
	systemSchema	: Schema;
	
begin
	if _method.myClass = null then
		return;
	endif;
	
	if _method.myClass.mySchema = null then
		return;
	endif;
	
	className := _method.myClass.name;
	schemaName := _method.myClass.mySchema.name;
	systemSchema := rootSchema.getSchema(schemaName);
	currentMethod := systemSchema.getClass(className).getMethod(_method.name);
	
	lblCurrLastModified.caption := currentMethod.getModifiedTimestamp().String &amp; " - " &amp; currentMethod.getModifiedBy().toUpper();
	lblLoadLastModified.caption := _method.modifiedTimeStamp.String &amp; " - " &amp; _method.modifiedBy.toUpper();
	
	// Prevent the user from changing methods again until we're finished
	self.qlbDifferentMethods.enabled := false;
	self.qlbDifferentMethods.refreshNow();
	
	self.jeCurrent.text := "";
	self.jeLoaded.text 	:= "";
	
	currentSource := currentMethod.getSource();
	newSource := _method.desc;
	
	self.jeCurrent.text := currentSource;
	self.jeLoaded.text 	:= newSource;
	
	if systemSchema &lt;&gt; null then
		self.jeLoaded.setCurrentSchema(systemSchema);
		self.jeCurrent.setCurrentSchema(systemSchema);
	endif;
	
	self.compareTextEditors();
	
	if currentMethod.getSource() = _method.desc and currentMethod.text = _method.documentationTextData then
		self.slStatus.caption := "Source Comparison: No Differences Found";
		
		if _method.resolvedBy = null then
			dialogResult := app.msgBox('No Changes found would you like to Resolve this item', 'No Changes Found', MsgBox_Yes_No);
			if dialogResult = MsgBox_Return_Yes then
				//schema := _method.myClass.mySchema;
				//class := _method.myClass;
				//selectedMethod := _method;
				
				// navmd1 - lets just mark as resolved rather than deleting, this way we can see historical stuff/complete reports
				/*beginTransaction;
				delete selectedMethod;
				
				if class.allMethods.size &lt; 1 then
					delete class;
				endif;
				
				if schema.allClasses.size  &lt; 1 then
					delete schema;
				endif;
				commitTransaction;*/
				
				//self.qlbDifferentMethods.clear();										// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				//self.loadDifferingMethods(self.myReport, self.txtSearchString.text);	// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				
				// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				self.mnuLBContext.userObject := self.qlbDifferentMethods;
				self.doClearSelectedItem();
				self.mnuLBContext.userObject := null;
				// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				
				self.qlbDifferentMethods.enabled := false;
				//self.qlbDifferentMethods.refreshNow();								// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				self.lblCurrLastModified.caption := null;
				self.lblLoadLastModified.caption := null;
				//self.jeCurrent.text := "";											// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				//self.jeLoaded.text := "";												// ### TFS 52791 (58881) 26Jun2023 NAVPW1
			endif;
		endif;
	elseif currentMethod.getSource() &lt;&gt; _method.desc then
		self.slStatus.caption := "Source Comparison: Method Differences Found";
	else
		self.slStatus.caption := "Source Comparison: Method Documentation Text Differences Found";
	endif;
	
	if _method.resolvedBy &lt;&gt; null then
		self.slStatus.caption &amp;= " - Resolved by: " &amp; _method.resolvedBy &amp; "@" &amp; _method.resolvedAt.String;
	endif;
	
epilog
	self.qlbDifferentMethods.enabled := true;
	//abortTransaction;
	
end;</source>
        <access>protected</access>
        <Parameter name="_method" type="DEV_Method"/>
    </JadeMethod>
    <JadeMethod name="compareTextEditors" id="f65c3ba5-458e-4fff-a123-602d777fa685">
        <source>compareTextEditors() protected;
/*

Purpose:			Compare the two sources line-by-line

Parameters:			

Return Value:		

Date			Who		Reason
27 June 2022	navmd1	Initial creation

*/

vars
	newSrcPos,
	currentSrcPos,
	tempPos				: Integer;
	
	currentSource,
	newSource,
	currentSourceLine,
	newSourceLine,
	tempSourceLine		: String;
	
	marks				: IntegerArray;
	
	currentTextEditor,
	newTextEditor		: JadeTextEdit;
begin
	newTextEditor := self.jeLoaded;
	currentTextEditor := self.jeCurrent;
	
	newSource := newTextEditor.text;
	currentSource := currentTextEditor.text;
	
	newSrcPos := 1;
	currentSrcPos := 1;
	
	if newSource = null then
		newTextEditor.text := "&lt;&lt;ERROR LOADING SOURCE&gt;&gt;";
		return;
	endif;
	
	if currentSource = null then
		currentTextEditor.text := "&lt;&lt;ERROR LOADING SOURCE&gt;&gt;";
		return;
	endif;
	
	while true do
		newSourceLine := "";
		currentSourceLine := "";
		
		if newSrcPos &lt;&gt; 0 then
			newSourceLine := newSource.scanUntil(CrLf, newSrcPos);
		endif;
		if currentSrcPos &lt;&gt; 0 then
			currentSourceLine := currentSource.scanUntil(CrLf, currentSrcPos);
		endif;
		
		if newSourceLine &lt;&gt; currentSourceLine then
			if newSrcPos &lt;&gt; 0 then
				newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
			else
				newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
			endif;
			
			// Fudge things a little, and try and hanndle just those "1 line" differences a bit nicer
			tempPos := newSrcPos + 2;
			tempSourceLine := "";
			if tempPos &lt; newSource.length then
				tempSourceLine := newSource.scanUntil(CrLf, tempPos);
			endif;
			
			if tempSourceLine = currentSourceLine then
				newSrcPos := tempPos;
			else			
				if currentSrcPos &lt;&gt; 0 then
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endif;
		endif;
		
		if newSrcPos = 0 and currentSrcPos &lt;&gt; 0 then
			// New method has less lines than the old
			
			while currentSrcPos &lt;&gt; 0 do
				currentSrcPos += 2;	// Skip the CrLf
				if currentSrcPos &gt; currentSource.length then
					break;
				endif;
				
				currentSourceLine := currentSource.scanUntil(CrLf, currentSrcPos);
				if currentSrcPos &lt;&gt; 0 then
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endwhile;
		endif;
		
		if newSrcPos &lt;&gt; 0 and currentSrcPos = 0 then
			// New method has more lines than the old
			
			while newSrcPos &lt;&gt; 0 do
				newSrcPos += 2;	// Skip the CrLf
				if newSrcPos &gt; newSource.length then
					break;
				endif;
				
				newSourceLine := newSource.scanUntil(CrLf, newSrcPos);
				if newSrcPos &lt;&gt; 0 then
					newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endwhile;
		endif;
		
		// We're done here, move on
		if newSrcPos = 0 or currentSrcPos = 0 then
			break;
		endif;
		
		newSrcPos += 2;			// Skip the CrLf
		currentSrcPos += 2;		// Skip the CrLf
		
		if newSrcPos &gt; newSource.length then
			newSrcPos := 0;
		endif;
		if currentSrcPos &gt; currentSource.length then
			currentSrcPos := 0;
		endif;
	endwhile;
	
	create marks transient;
	newTextEditor.getLinemarkLines(JadeTextEdit.MARKER_JAD_LINEMARK, false, marks);
	if marks.size &gt; 0 then
		newTextEditor.currentPosition := marks[1];
		currentTextEditor.currentPosition := marks[1];
	endif;
epilog
	delete marks;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoResolveForUser" id="8ebfc234-8f11-4c9f-b2f0-c149206aa0c8">
        <updating/>
        <source>doAutoResolveForUser() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2023	navpw1	Initial creation

*/

vars
	report						: DEV_SourceCompareReport;
	devSchema 					: DEV_Schema;
	devClass 					: DEV_Class;
	devMethod 					: DEV_Method;
	
	systemSchema				: Schema;
	systemClass					: Class;
	systemMethod				: Method;
	
	resolvedMethodCount,
	resolvedMissingMethodCount	: Integer;
	
begin
	if app.msgBox("Are you sure you want to auto resolve all differences for your usercode?", "Auto Resolve Items", MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	report := self.myReport;
	
	if report = null then
		return;
	endif;
	
	foreach devSchema in report.allSchemas do
		systemSchema := rootSchema.getSchema(devSchema.name);
		foreach devClass in devSchema.allClasses do
			systemClass := systemSchema.getClass(devClass.name);
			//Different method resolving
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				systemMethod := systemClass.getMethod(devMethod.name);
				
				if devMethod.modifiedBy &lt;&gt; process.getUserCode and (systemMethod &lt;&gt; null and systemMethod.getModifiedByJMT &lt;&gt; process.getUserCode) then
					continue;
				endif;
				
				//Check not resolved
				if devMethod.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				//Check the same
				if systemMethod.getSource() = devMethod.desc and systemMethod.text = devMethod.documentationTextData then
					//resolve the method
					devMethod.setResolved(process.getComputerName);
					resolvedMethodCount += 1;
					
				endif;
				
			endforeach;
			
			//Missing method resolving
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				systemMethod := systemClass.getMethod(devMethod.name);
				if systemMethod = null then
					continue;
				endif;
				
				//resolve the method
				devMethod.setResolved(process.getComputerName);
				resolvedMissingMethodCount += 1;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	app.msgBox("Resolved Different Methods: " &amp; resolvedMethodCount.String &amp; CrLf &amp; 
				"Resolved Missing Methods: " &amp; resolvedMissingMethodCount.String &amp; CrLf &amp; 
				"These items are now resolved", "Auto Resolved Items", MsgBox_OK_Only);
	
	self.clearForm();
	
	self.loadData(report, self.txtSearchString.text);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCheckMethodExists" id="e745af7d-7862-4ab8-b6ec-a3bb43e0d22d">
        <source>doCheckMethodExists(_listBox : ListBox; _method : DEV_Method);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2023	navpw1	Initial creation

*/

vars
	schemaName,
	className 		: String;
	currentMethod 	: Method;
	currentSource,
	newSource		: String;
	dialogResult	: Integer;
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	selectedMethod 	: DEV_Method;
	selIndex : Integer;
	devEnt : DEV_SchemaObjectEntity;
	
begin
	self.slStatus.caption := "Source Comparison: Method does not exist";
	
	if _method.myClass = null then
		return;
	endif;
	
	if _method.myClass.mySchema = null then
		return;
	endif;
	
	className := _method.myClass.name;
	schemaName := _method.myClass.mySchema.name;
	currentMethod := rootSchema.getSchema(schemaName).getClass(className).getMethod(_method.name);
	
	// Prevent the user from changing methods again until we're finished
	self.qlbMissingMethods.enabled := false;
	self.qlbMissingMethods.refreshNow();
	
	if currentMethod = null then
		return;
	endif;
	
	if _method.resolvedBy = null then
		dialogResult := app.msgBox('Method has been found, continue?', 'Method Found', MsgBox_Yes_No);
		if dialogResult = MsgBox_Return_Yes then
			selIndex := _listBox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := _listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			self.doClearItemForIndex(selIndex, _listBox);
		endif;
	endif;
	
	if _method.resolvedBy &lt;&gt; null then
		self.slStatus.caption &amp;= " - Resolved by: " &amp; _method.resolvedBy &amp; "@" &amp; _method.resolvedAt.String;
	endif;
	
epilog
	self.qlbMissingMethods.enabled := true;
	
end;</source>
        <Parameter name="_listBox" type="ListBox"/>
        <Parameter name="_method" type="DEV_Method"/>
    </JadeMethod>
    <JadeMethod name="doClearFilter" id="c5315766-6d45-45b2-b25b-3deacca2b5e6">
        <updating/>
        <source>doClearFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2022	navpw1	Initial creation

*/

begin
	self.txtSearchString.text := "";
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.btnOpenInWinMerge.visible 		:= false;
	self.btnClearFilter.enabled 		:= false;
	self.btnOpenInNPP.visible 			:= false;
	
	if self.myReport = null then
		return;
	endif;
	
	self.loadData(self.myReport, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearItemForIndex" id="0b57b42a-d901-4340-8233-89ec6fdc960c">
        <source>doClearItemForIndex(_index : Integer; _listBox : ListBox) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 June 2023	navmd1	Initial creation

*/

vars
	listBox		: ListBox;
	index,
	selLevel,
	level		: Integer;
begin
	//listBox := self.mnuLBContext.userObject.ListBox;
	listBox := _listBox;
	
	if listBox = null or _index &lt; 1 or _index &gt; listBox.listCount then
		if not process.isPW then
			app.raiseUnexpectedProgramError(class.name, method.name, "Invalid Item Index");
		endif;
		return;
	endif;
	
	selLevel := listBox.itemLevel[_index];

	// Remove the selected item
	listBox.removeItem(_index);
	
	// Also remove the 'Header' items if this was the only subitem
	index := _index;
	level := selLevel;
	while index &gt; 1 do
		// If the one above us is at a lower level,
		// and the one below us (if it exists) is also at a lower level
		if listBox.itemLevel[index-1] &lt; level and (listBox.listCount &lt; index or listBox.itemLevel[index] &lt; level) then
			listBox.removeItem(index-1);
			index -= 1;
			level -= 1;
			continue;
		endif;
		break;
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_listBox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="doClearSelectedItem" id="53967b83-e0c0-4232-a22a-10bcdfce19f5">
        <source>doClearSelectedItem() protected;
/*

Purpose:			Remove 'Checked-Off' items from the list

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2022	navmd1	Initial creation
26 June 2023	navpw1	TFS: 52791 (58881) - Added code to clear out the last modified fields

*/

vars
	listBox		: ListBox;
	selIndex	: Integer;
	devEnt		: DEV_SchemaObjectEntity;
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	if selIndex &lt; 1 then
		return;
	endif;
	
	devEnt := listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
	
	// Mark the difference object as 'resolved'
	if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
		if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
			devEnt.setResolved(process.getComputerName);
		endif;
	endif;
	
	self.doClearItemForIndex(selIndex, listBox);
	
	// Now that we have nothing selected, clear the top boxes
	self.jeCurrent.text := null;
	self.jeLoaded.text := null;
	self.lblCurrLastModified.caption := null;		// ### TFS 52791 (58881) 26Jun2023 NAVPW1
	self.lblLoadLastModified.caption := null;		// ### TFS 52791 (58881) 26Jun2023 NAVPW1
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExportReport" id="54886f11-b62c-4c56-a30a-cbc88ae92812">
        <source>doExportReport();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2022	navpw1	Initial creation TFS: 52791

*/

vars
	reportData,
	statsData		: String;
	
	report			: DEV_SourceCompareReport;
	outputFile,
	notepadPlusPlus : File;
	notepad			: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	str				: String;
	args			: StringArray;
	result,
	exitCode		: Integer;
	allArgs			: String;
	statsOnly		: Integer;
	
begin
	report := self.myReport;
	if process.isPW then
		statsOnly := app.msgBox("Would you like to view stats only", "Stats Only", MsgBox_Yes_No);
		
		if statsOnly = 6 then
			statsData := report.getStats(self.txtSearchString.text);
			self.doExportStats(statsData);
			
			return;
			
		endif;
	endif;
	
	reportData := report.getReportOrd(self.txtSearchString.text);
	
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	create outputFile transient;
	
	//outputFile.usePresentationFileSystem := false;
	outputFile.usePresentationFileSystem := true;
	//outputFile.openOutput(appLogTmpDir &amp; "\" &amp; "exportedReport.jadeReport");
	outputFile.fileName := process.getTempPath() &amp; "exportedReport.jadeReport";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFile.isAvailable and not outputFile.isOpen then
		outputFile.cnRemoveFile(5, 5000);
	endif;
	
	outputFile.writeString(reportData);
	
	//app.copyFileToLocalMachine(appLogTmpDir &amp; "\" &amp; "exportedReport.jadeReport", "C:\temp\"&amp; "exportedReport.jadeReport");
	
	//app.msgBox("Report outputted to '" &amp; process.getTempPath() &amp; "exportedReport.jadeReport'", "Report Created!!!", MsgBox_OK_Only);
	
	//Notepad node.getEnvironmentVariable("WINDIR")\notepad.exe
	create notepad transient;
	notepad.usePresentationFileSystem := true;
	notepad.fileName := node.getEnvironmentVariable("WINDIR") &amp; "\notepad.exe";
	if not notepad.isAvailable then
		notepad.close();
		write "Notepad not found in " &amp; notepad.fileName;
		return;
	endif;
	
	create args transient;
	args[1] := outputFile.fileName;

	result := node.createExternalProcess(".", notepad.fileName, args, null, true, true, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_Successful or exitCode &lt;&gt; 0 then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepad.fileName &amp; allArgs;
		write "Error running Notepad " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
	//Notepad ++ node.getEnvironmentVariable("PROGRAMFILES")\Notepad++\notepad++.exe
	//Notepad ++ node.getEnvironmentVariable("PROGRAMFILES(X86)")\Notepad++\notepad++.exe
	/*create notepadPlusPlus transient;
	notepadPlusPlus.usePresentationFileSystem := true;
	notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\Notepad++\notepad++.exe";
	if not notepadPlusPlus.isAvailable then
		notepadPlusPlus.close();
		write "Notepad not found in " &amp; notepadPlusPlus.fileName;
		notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\Notepad++\notepad++.exe";
		if not notepadPlusPlus.isAvailable then
			//write "Winmerge not found in " &amp; winmerge.fileName;
			return;
		endif;
	endif;
	
	create args transient;
	args[1] := outputFile.fileName;

	result := node.createExternalProcess(".", notepadPlusPlus.fileName, args, null, true, true, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_Successful or exitCode &lt;&gt; 0 then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepadPlusPlus.fileName &amp; allArgs;
		write "Error running Notepad " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;*/
	
epilog
	delete outputFile;
	delete outputFolder;
	delete notepad;
	//delete notepadPlusPlus;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportStats" id="ee9621c6-80f1-410a-a0e1-b89f3e0ff540">
        <source>doExportStats(_statsData : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2023	navpw1	Initial creation

*/

vars
	outputFile,
	notepadPlusPlus : File;
	notepad			: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	str				: String;
	args			: StringArray;
	result,
	exitCode		: Integer;
	allArgs			: String;
	statsOnly		: Integer;
	
begin
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	create outputFile transient;
	
	//outputFile.usePresentationFileSystem := false;
	outputFile.usePresentationFileSystem := true;
	//outputFile.openOutput(appLogTmpDir &amp; "\" &amp; "exportedReport.jadeReport");
	outputFile.fileName := process.getTempPath() &amp; "exportedReport.jadeReport";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFile.isAvailable and not outputFile.isOpen then
		outputFile.cnRemoveFile(5, 5000);
	endif;
	
	outputFile.writeString(_statsData);
	
	//Notepad node.getEnvironmentVariable("WINDIR")\notepad.exe
	create notepad transient;
	notepad.usePresentationFileSystem := true;
	notepad.fileName := node.getEnvironmentVariable("WINDIR") &amp; "\notepad.exe";
	if not notepad.isAvailable then
		notepad.close();
		write "Notepad not found in " &amp; notepad.fileName;
		return;
	endif;
	
	create args transient;
	args[1] := outputFile.fileName;

	result := node.createExternalProcess(".", notepad.fileName, args, null, true, true, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_Successful or exitCode &lt;&gt; 0 then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepad.fileName &amp; allArgs;
		write "Error running Notepad " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
epilog
	delete outputFile;
	delete outputFolder;
	delete notepad;
	
end;</source>
        <access>protected</access>
        <Parameter name="_statsData" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFilter" id="e006395c-ce4c-4842-9176-e0a6605e9e02">
        <updating/>
        <source>doFilter() updating;
/*

Purpose:			Filters the screen for Methods, References, Attributes, Constants, Global Constants changed by the current user

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2022	navpw1	Initial creation

*/

vars
	
begin
	if self.txtSearchString.text = null or self.myReport = null then
		return;
	endif;
	
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.btnOpenInWinMerge.visible 		:= false;
	self.btnClearFilter.enabled 		:= true;
	self.btnOpenInNPP.visible 			:= false;
	
	self.loadData(self.myReport, self.txtSearchString.text);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotifications" id="1e7bdbfc-52d5-4e38-ba84-e55fc1d3d5de">
        <source>doHandleNotifications(_devEnt : DEV_SchemaObjectEntity) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 June 2023	navmd1	Initial creation

*/

vars
	objIndex	: Integer;
	clear		: Boolean;
begin
	if _devEnt.isKindOf(DEV_Method) or _devEnt.isKindOf(DEV_Class) or _devEnt.isKindOf(DEV_Schema) then
		clear := _devEnt.resolvedBy &lt;&gt; null;
		
		objIndex := self.qlbDifferentMethods.findObject(_devEnt);
		if objIndex &lt; 1 then
			// Not in our list
			return;
		endif;
		
		if clear then
			if not self.chkShowResolved.value then
				if objIndex = self.qlbDifferentMethods.listIndex then
					// This is the one we're currently viewing, so just call clear
					self.doClearSelectedItem();
				else
					self.doClearItemForIndex(objIndex, self.qlbDifferentMethods);
				endif;
			else
				self.qlbDifferentMethods.itemForeColor[objIndex] := Gray;
				// Other entries have their own notifications, so no need to loop through parents or children
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_devEnt" type="DEV_SchemaObjectEntity"/>
    </JadeMethod>
    <JadeMethod name="doOpenInNPP" id="6c5671af-4052-4ba7-8444-f9650b82a929">
        <source>doOpenInNPP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navpw1	Initial creation

*/

vars
	outputFileLeft,
	outputFileRight,
	notepadPlusPlus,
	nppSessionFile	: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	loadedClass,
	targetDir,
	appToStart,
	str,
	allArgs			: String;
	args			: StringArray;
	currentMethod 	: Method;
	result,
	exitCode		: Integer;
	
begin
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	if self.loadedMethod.myClass = null then
		return;
	endif;
	
	if self.loadedMethod.myClass.mySchema = null then
		return;
	endif;
	
	create outputFileLeft transient;
	create outputFileRight transient;
	
	loadedClass := self.loadedMethod.myClass.name;
	currentMethod := rootSchema.getSchema(self.loadedMethod.myClass.mySchema.name).getClass(loadedClass).getMethod(self.loadedMethod.name);
	
	outputFileLeft.usePresentationFileSystem := true;
	//outputFileLeft.openOutput(appLogTmpDir &amp; "\" &amp; "Loaded-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileLeft.fileName := process.getTempPath() &amp; "Loaded-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileLeft.isAvailable and not outputFileLeft.isOpen then
		outputFileLeft.cnRemoveFile(5, 5000);
	endif;
	
	outputFileLeft.writeString(jeLoaded.text);
	outputFileLeft.close();
	
	outputFileRight.usePresentationFileSystem := true;
	//outputFileRight.openOutput(appLogTmpDir &amp; "\" &amp; "Current-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileRight.fileName := process.getTempPath() &amp; "Current-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileRight.isAvailable and not outputFileRight.isOpen then
		outputFileRight.cnRemoveFile(5, 5000);
	endif;
	
	outputFileRight.writeString(jeCurrent.text);
	outputFileRight.close();
	
	//Run Code to open in WinMerge
	create notepadPlusPlus transient;
	notepadPlusPlus.usePresentationFileSystem := true;
	notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\Notepad++\notepad++.exe";
	if not notepadPlusPlus.isAvailable then
		//write "Winmerge not found in " &amp; winmerge.fileName;
		notepadPlusPlus.close();
		notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\Notepad++\notepad++.exe";
		if not notepadPlusPlus.isAvailable then
			//write "Winmerge not found in " &amp; winmerge.fileName;
			return;
		endif;
	endif;
	
	create nppSessionFile transient;
	nppSessionFile.usePresentationFileSystem := true;
	nppSessionFile.fileName := process.getTempPath() &amp; "sourceCompareSessionFile.xml";
	if nppSessionFile.isAvailable and not nppSessionFile.isOpen then
		nppSessionFile.cnRemoveFile(5, 5000);
	endif;
	
	nppSessionFile.writeString('&lt;?xml version="1.0" encoding="UTF-8" ?&gt;
&lt;NotepadPlus&gt;
    &lt;Session activeView="1"&gt;
        &lt;mainView activeIndex="155"&gt;
            &lt;File firstVisibleLine="1" xOffset="0" scrollWidth="736" startPos="13752" endPos="13761" selMode="0" offset="0" wrapCount="1" lang="None (Normal Text)" encoding="-1" userReadOnly="no" filename="' &amp; outputFileLeft.fileName &amp; '" backupFilePath="" originalFileLastModifTimestamp="1512048640" originalFileLastModifTimestampHigh="30957285" mapFirstVisibleDisplayLine="-1" mapFirstVisibleDocLine="-1" mapLastVisibleDocLine="-1" mapNbLine="-1" mapHigherPos="-1" mapWidth="-1" mapHeight="-1" mapKByteInDoc="151" mapWrapIndentMode="-1" mapIsWrap="no" /&gt;
        &lt;/mainView&gt;
        &lt;subView activeIndex="155"&gt;
            &lt;File firstVisibleLine="1" xOffset="0" scrollWidth="1152" startPos="3491" endPos="3491" selMode="0" offset="0" wrapCount="1" lang="None (Normal Text)" encoding="-1" userReadOnly="no" filename="' &amp; outputFileRight.fileName &amp; '" backupFilePath="" originalFileLastModifTimestamp="-2012347430" originalFileLastModifTimestampHigh="30978122" mapFirstVisibleDisplayLine="-1" mapFirstVisibleDocLine="-1" mapLastVisibleDocLine="-1" mapNbLine="-1" mapHigherPos="-1" mapWidth="-1" mapHeight="-1" mapKByteInDoc="512" mapWrapIndentMode="-1" mapIsWrap="no" /&gt;
        &lt;/subView&gt;
    &lt;/Session&gt;
&lt;/NotepadPlus&gt;');
	nppSessionFile.close();
	
	create args transient;
	args[1] := '-openSession "' &amp; nppSessionFile.fileName &amp; '"';

	self.enableAllControls(false);
	self.refreshNow();
	
	result := node.createExternalProcess(".", notepadPlusPlus.fileName, args, null, true, false, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_InitiateOK then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepadPlusPlus.fileName &amp; allArgs;
		write "Error running Notepad ++ " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
epilog
	delete outputFileLeft;
	delete outputFileRight;
	delete nppSessionFile;
	delete outputFolder;
	delete args;
	delete notepadPlusPlus;
	
	self.enableAllControls(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenInWinMerge" id="b4e5b8ca-97f0-4a45-9423-69bc0da03f7b">
        <source>doOpenInWinMerge();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navpw1	Initial creation

*/

vars

begin

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="cbd8bb25-b01b-46c8-8199-3d193f0215de">
        <source>doRefresh();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2022	navpw1	Initial creation

*/

vars
	sourceCompareReport : DEV_SourceCompareReport;
	sourceCompareRoot 	: DEV_SourceCompareRoot;
	oldReportTimestamp 	: String;
	newIndex,
	index				: Integer;
	
begin
	if self.cmbSelectReport.listIndex &lt;&gt; -1 then
		oldReportTimestamp := self.cmbSelectReport.itemText[self.cmbSelectReport.listIndex];
	endif;
	
	self.cmbSelectReport.clear();
	self.cmbSelectReport.sorted := false;
	sourceCompareRoot := DEV_SourceCompareRoot.instances.first.DEV_SourceCompareRoot;
	
	if sourceCompareRoot &lt;&gt; null and sourceCompareRoot.allSourceCompareReports &lt;&gt; null then
		foreach sourceCompareReport in sourceCompareRoot.allSourceCompareReports reversed where sourceCompareReport.isAvailable do
			newIndex := self.cmbSelectReport.addItem(sourceCompareReport.getDisplayName);
			self.cmbSelectReport.itemObject[newIndex] := sourceCompareReport;
			
			if sourceCompareReport.reportType = DEV_SourceCompareReport.ReportType_Manual then
				self.cmbSelectReport.itemBackColor[newIndex] := PalePink;
			endif;
			
		endforeach;
	endif;
	
	index := self.cmbSelectReport.findString(1, oldReportTimestamp);
	if index &lt; 1 then
		return;
	endif;
	
	self.cmbSelectReport.listIndex := index;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnresolveSelectedItem" id="4d9133ab-1578-4637-aa26-010f7216c6de">
        <updating/>
        <source>doUnresolveSelectedItem() updating, protected;
/*

Purpose:			Clears the Resolved By and Resolved At flags

Parameters:			

Return Value:		

Date			Who		Reason
29 June 2023	navmd1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex,
	selLevel,
	index		: Integer;
	devEnt		: DEV_SchemaObjectEntity;
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	if selIndex &lt; 1 then
		return;
	endif;
	
	selLevel := listBox.itemLevel[selIndex];
	devEnt := listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
	
	if devEnt &lt;&gt; null and devEnt.resolvedBy &lt;&gt; null then
		devEnt.setResolved(null);
		
		if devEnt.isKindOf(DEV_Method) then
			self.compareMethod(devEnt.DEV_Method);
		endif;
		
		listBox.itemForeColor[selIndex] := Window.Color_WindowText;
		
		// Now go down the tree and reset the colour of any subitems
		index := selIndex;
		while true do
			index += 1;
			
			// End of list
			if listBox.listCount &lt; index then
				break;
			endif;
			
			// Same level as us, or higher, so we can stop
			if listBox.itemLevel[index] &lt;= selLevel then
				break;
			endif;
			
			listBox.itemForeColor[index] := Window.Color_WindowText;
		endwhile;
		
		// Same with our direct parents
		index := selIndex;
		while true do
			index -= 1;
			
			// Beginning of list
			if index = 0 then
				break;
			endif;
			
			// Found the next sibling, or children thereof, so skip
			if listBox.itemLevel[index] &gt;= selLevel then
				continue;
			endif;
			
			// Parent is already cleared and the right colour, so we're done
			if listBox.itemForeColor[index] = Window.Color_WindowText then
				break;
			endif;
			
			devEnt := listBox.itemObject[index].DEV_SchemaObjectEntity;
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				listBox.itemForeColor[index] := Window.Color_WindowText;
			endif;
		endwhile;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableAllControls" id="985c5fcd-9710-407d-a5ce-56bf83c6ffbf">
        <source>enableAllControls(_enable: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2022	navmd1	Initial creation

*/

vars

	numControls,
	int:	Integer;
	ctl:	Control;
begin
	
	inheritMethod(_enable);
	
	numControls := self.controlCount;
	int := 1;
	while int &lt;= numControls do
		ctl := self.controls(int);
		if ctl.isKindOf(Label)
		or ctl.isKindOf(CMUI_ButtonForToolbar) then
			int := int+1;
			continue;
		elseif ctl.isKindOf(CMUI_ListBox) then
			ctl.enabled := _enable;
		elseif ctl.isKindOf(JadeTextEdit) then
			ctl.enabled := _enable;
		endif;
		int := int+1;
	endwhile;

epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
