    <JadeMethod name="getOpenInvoices" id="afe6ce6f-e796-4db2-acc5-6dd25338d067">
        <source>getOpenInvoices(_set : CM_InvoiceBySeqNumDict input; _param : CMIF_InvoiceSelection input);
// get all matching invoices for the given status
vars

	theInvoice	: CM_Invoice;
	iter 		: Iterator;
	tmpStatus : Integer;
begin
	tmpStatus := _param.status; // PAR 17895
	
	_set.clear();
	
	iter := self.invoicesByStatus.createIterator();
	self.invoicesByStatus.startKeyGeq(tmpStatus, iter); // PAR 17895
	while iter.next(theInvoice) do

		if theInvoice.status &lt;&gt; tmpStatus then // PAR 17895
			break;
		endif;
		
		if not theInvoice.isMatch(_param) then
			continue;
		endif;
				
		_set.add(theInvoice);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_set" type="CM_InvoiceBySeqNumDict" usage="input"/>
        <Parameter name="_param" type="CMIF_InvoiceSelection" usage="input"/>
    </JadeMethod>
