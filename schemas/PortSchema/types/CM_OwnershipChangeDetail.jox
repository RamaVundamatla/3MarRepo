	if self.myOwnershipChange &lt;&gt; null then // ### TFS CR 58230 TASK 58232 26JUL2023 NAVAB1 - sub item are linked to myParentOwnershipChangeDetail
		self.myOwnershipChange.addTI(self.myTrackedItem);// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
