    <JadeMethod name="mnuInspectObject_click" id="2ea125c7-0028-4283-9dad-b4b7f350f0c7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspectObject_click(menuItem: MenuItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation PAR #
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold JOb Ops Loading Changes
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	table : CM_DataTable;
	obj : Object;

begin

	if menuItem.userObject &lt;&gt; null then	//29 Jun 2017	NDL TFS 4948
		menuItem.userObject.inspectModal();
		return;
	endif;
	
	if self.fldData.topSheet = self.shtOnShip then
		table := self.tblOnShip;
	elseif self.fldData.topSheet = self.shtOnSite then
		table := self.tblOnSite;
	elseif self.fldData.topSheet = self.shtPreNote then			// TFS 39964
		table := self.tblPreNote;								// TFS 39964
	elseif self.fldData.topSheet = self.shtTranship then		// TFS 47085
		table := self.tblTranship;								// TFS 47085
	else
		table := self.tblAllocatedGang.getControl(self.fldData.topSheet.tag.Integer+1).CM_DataTable;
	endif;
	if table = null then
		return;
	endif;
	
	obj := table.accessRow(table.row).itemObject;
	obj.inspect;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuQtyChg_click" id="845cbaa9-fb9f-4a69-a9f1-6aba9aed676b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuQtyChg_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	form : CMUI_MoveAmountForm;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	newQuantity : Integer;
	newWeight : Decimal[16,4];
	moveController : CMIF_MoveController;
	req : CM_HoldRequest;
	theReturn : Integer;

begin

	app.mousePointer := MousePointer_Default;

	wle := menuItem.userObject.CM_WorkListEntry;
	if wle = null or wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	newWeight := wle.weight;
	newQuantity := wle.quantity;
	
	ti := wle.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	req := wle.myRequest.CM_HoldRequest;
	if req = null then
		return;
	endif;
	
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		return;
	endif;
	
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
	
	create moveController transient;
	app.myMoveController := moveController;
	moveController.setMyTrackedItem( ti );
	moveController.setMyToPrimaryLocation( wle.getTargetLocation );
	moveController.setQuantity( wle.quantity);
	moveController.setWeight( wle.weight); //epr TFS 8220 6/12/17 
	moveController.setMoveMode( PLANNING_MODE );
	
	create form transient;
	form.myTrackedItem := ti;
	form.myWorkListEntry := wle;
	form.targetLocation := wle.locationTarget;
	
	if form.showModal &lt;&gt; IDOK then
		return;
	endif;
	
	if form.byQuantity then
		newQuantity := form.getQuantity;	
	else
		newWeight := form.getWeightMovedKgs;
	endif;
	
	if newQuantity = wle.quantity and  newWeight = wle.weight then
		return;
	endif;
	
	while true do 
		app.myTrxUA.trxUpdateHoldReqQty( req, wle, newWeight, newQuantity, app.myPassport );	
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move_amount), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	// TFS42872 jlgzm1 22/07/2019
	// updating the qty will have incremented the object's edition
	// will need to reset proxy so that the editions match when saving the form
	if self.mode &lt;&gt; Mode_View then
		if self.myPxyJobForEdit &lt;&gt; null then
			self.setMyPxyJobForEdit(self.myPxyJobForEdit.pxyGetRealObject(), false);
		endif;
	endif;
	
epilog

	if moveController &lt;&gt; null then
		if app.myMoveController = moveController then
			app.myMoveController := null;
		endif;
		delete moveController;
	endif;

	mousePointer := MousePointer_Default;
	delete form;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
