        <source>displayEntryHatch(_num : Integer) : String;
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _num = null then
		return null;
	endif;
	return _num.String;
	
end;</source>
        <Parameter name="_num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryLocationController" id="619ee937-5012-465c-bb33-100271fe450a">
        <source>displayEntryLocationController(_location : CM_LocationsController) : String;
//--------------------------------------------------------------
//Created: 31 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _location &lt;&gt; null then
		return _location.displayEntryWithSpaces(app.myPassport);
	endif;
	return null;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryVoyLoadOutDocket" id="ab269eef-a298-46d5-acbd-6045308377d6">
        <source>displayEntryVoyLoadOutDocket(bol : CM_BOL) : String;
// ---------------------------------------------------------------------------
// Created:     29 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ext		: CM_BOLExtension;
	logExt	: CM_BOLExtLogOut;
	str		: String;

begin

	ext := bol.myExtension;
	
	if ext &lt;&gt; null and
	   CM_BOLExtLogOut.hasInstance(ext) then
		logExt := ext.CM_BOLExtLogOut;
		str := bol.number &amp; Tab &amp; logExt.myLogLot.lotNo &amp; Tab &amp; 
				logExt.hatch.String &amp; Tab &amp; 
				app.vesselPlaceEnumToStr(logExt.place) &amp; Tab &amp;
				bol.myOperator.code &amp; Tab &amp;
				logExt.getSpecsDisplayStr();
	else
		str := bol.number &amp; Tab &amp;
				bol.myOperator.code &amp; Tab &amp;
				bol.productCode;
	endif;
	
	
	return str;

end;</source>
        <Parameter name="bol" type="CM_BOL"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doScalingDataMerge" id="71492db0-29c3-4812-8afc-fe9e31f1c0b0">
        <source>doScalingDataMerge(_first, _second : CM_LogScalingHdr input) : Boolean;

// cnwdvb1 02 December 2002 

vars

	realSecond	: CM_LogScalingHdr;
	detail		: CM_LogScalingDtl;
	iter		: Iterator;
	result			: Integer;

begin

	if _first.bolNumber &lt;&gt; _second.bolNumber then	
		app.raiseCMWarning(Err_InvalidDocketForMerge, null, null, _first);
		return false;
	endif;
	
	if _first.operatorCode &lt;&gt; _second.operatorCode then
		app.raiseCMWarning(Err_InvalidSupplierForMerge, null, null, _first);
		return false;
	endif;

	realSecond := _second.pxyGetRealObject();
	if global.isValidObject(realSecond) then
		iter := _second.allLogScalingDtls.createIterator;
		while iter.next(detail) do
			if _first.allLogScalingDtls.includesKey(detail.logID) then
				app.raiseCMWarning1(Err_DuplicateScalingDtl, detail.logID,null, null, detail);
				return false;
			endif;
		endwhile;
		iter.reset();
		while iter.next(detail) do
			detail.setProxy(detail.logID, detail.conditionCode, detail.minSED, detail.maxSED, _first, detail.scalerCode);
		endwhile;
		delete iter;
		// Move old scaling information onto merged header.
		_second.createScalingExtra(_first);
		while true do
			app.myTrxCA.trxCreateLogScalingMerge(_first, realSecond, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				result := app.showErrorWarningDialog('Scaling Data Merge', app.myPassport, ErrWarnMode_Add);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_first" type="CM_LogScalingHdr" usage="input"/>
        <Parameter name="_second" type="CM_LogScalingHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doScalingDataSplit" id="9533bb7a-d0c6-4d94-ba7e-c215045a1e8f">
        <source>doScalingDataSplit(_selectedTicket : CM_LogScalingHdr input);

// cnwdvb1 25 November 2002 

vars

	splitForm	: LOG_ScalingDataSplitForm;
	
begin


	splitForm := app.loadForm(LOG_ScalingDataSplitForm, self.class, false, false, false, self.myTerminal, null).LOG_ScalingDataSplitForm;

	if splitForm = null then
		return;
	endif;

	splitForm.centreWindow;
	splitForm.initForm(_selectedTicket);

	if splitForm.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;

epilog
	if splitForm &lt;&gt; null then
		delete splitForm;
	endif;
	
end;</source>
        <Parameter name="_selectedTicket" type="CM_LogScalingHdr" usage="input"/>
    </JadeMethod>
    <JadeMethod name="inputLogReleaseData" id="c225c100-d610-4489-8668-ff2fcdd8bb74">
        <source>inputLogReleaseData(_selectedHdr : CM_BOLOutHeader);
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	loadOutForm : LOG_LoadOutForm;
	selectedHdr : CM_BOLOutHeader;
begin

	selectedHdr := _selectedHdr;
	loadOutForm := app.loadForm(LOG_LoadOutForm, self.class, false, false, false, self.myTerminal, null).LOG_LoadOutForm;

	if loadOutForm = null then
		return;
	endif;

	loadOutForm.centreWindow;
	loadOutForm.show();
	loadOutForm.initForReleaseByRoad(selectedHdr);	
	loadOutForm.resize();
	
end;</source>
        <Parameter name="_selectedHdr" type="CM_BOLOutHeader"/>
    </JadeMethod>
    <JadeMethod name="inputLogScalingData" id="46354630-1bb2-4426-8abf-9872ec8dd6f8">
        <source>inputLogScalingData(_selectedTicket:CM_LogScalingHdr);
//--------------------------------------------------------------
//Created: 11 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	attachFrm : LOG_ScalingDataForm;
	selectedTicket : CM_LogScalingHdr;
begin

	selectedTicket := _selectedTicket;
//	attachFrm := app.loadForm(LOG_ScalingDataForm, self.class, false, false, false, self.myTerminal, null).LOG_ScalingDataForm;
	create attachFrm transient;	//Par 15346 - we don't use app.loadForm()
	
	if attachFrm = null then
		return;
	endif;

	attachFrm.createMyAssistant( self.class );	//Par 15346
	attachFrm.setMyTerminal( self.myTerminal );	//Par 15346
	
	attachFrm.centreWindow;
	attachFrm.initTables(TI_CargoType_Log, selectedTicket);
//	attachFrm.handleMenusForModalDisplay();
	
	if attachFrm.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;

epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
end;</source>
        <Parameter name="_selectedTicket" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setAllVoyagesStatuses" id="b23f8db6-1461-438b-b4db-f517d8ac7064">
        <source>setAllVoyagesStatuses();
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/02/2017 	cnwrh7      TFS3464       #- Voyage definition / voyage status
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
vars
	voyageProcess : CM_VoyageProcess;
	status : CM_VoyageStatus;

begin
	self.allVoyageStatuses.clear();
	voyageProcess := self.myTerminal.getDefaultVoyageProcess();
	if voyageProcess &lt;&gt; null then
		foreach status in voyageProcess.allStatuses do
			self.allVoyageStatuses.add(status.description);
		endforeach;
	endif;
	
	/*self.allVoyageStatuses.add(app.getErrorString(VoyageCmb_Status_Archived_Str));			//+TFS3464
 	self.allVoyageStatuses.add(app.getErrorString(VoyageCmb_Status_Closed_Str));
 	self.allVoyageStatuses.add(app.getErrorString(VoyageCmb_Status_LdComplte_Str));
 	self.allVoyageStatuses.add(app.getErrorString(VoyageCmb_Status_Loading_Str));
 	self.allVoyageStatuses.add(app.getErrorString(VoyageCmb_Status_Pending_Str));*/
end;</source>
    </JadeMethod>
