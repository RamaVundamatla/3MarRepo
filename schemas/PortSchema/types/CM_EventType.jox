    <JadeMethod name="validateForDelete" id="54a1f0a2-eebd-4caf-8c75-2cfe736a3f5c">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	04 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason

----------   ----------  --------------------------------------------------
*/
vars

	bank : CM_Bank;
	eventBroker : CM_EventServiceBroker;
	event : CM_TranMapEvent;

begin
	
		
//	if self.category = self.SYSTEM_EVENT or self.category = self.WAGON_EVENT then
	//if self.category = self.SYSTEM_EVENT or self.category = self.WAGON_EVENT or self.category = self.LOCATION_EVENT then	//14 Apr 2021	NDL	TSF 50906
	if self.isSystemEventType() then //13/03/2024	navkc1 CR 62890 Task 62893
		app.raiseCMException1(ERR_DELETE_SYS_EVENTTYPE, self.type.String, ETRow_Type, null);
		return;
	endif;
	
	if (not self.allEventTransactions.isEmpty) then
		app.raiseCMWarning1(Warn_Events_Delete_With_Type, self.allEventTransactions.size.String, null, null, self);
	endif;
	
	if not self.allCamProtocols.isEmpty then	// PAR 21905 CCMS MES 1008 - PHB
		app.raiseCMException2(ObjectStillHasEntries, self.name &amp; " Event Type", "CAM protocol", null, null);
	endif;
	
	//12 Aug 2011	NDL	Par 27792
	foreach event in CM_TranMapEvent.instances do
		eventBroker := event.allEventServiceBrokers.getAtKeyGeq(self); // tfs42038 jlgzm1 09/05/19
		if eventBroker &lt;&gt; null and eventBroker.myEventType = self then
			app.raiseCMException2(Event_type_used_by, self.name, event.description, null, null);
			return;
		endif;
	endforeach;
end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="29247a05-c034-4e79-aa1f-5fc350c69929">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
23/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
*/
vars
	tmpEvent		: Object;
	iter			: Iterator;
	existingEventType,
	realEventType,
	eventType		: CM_EventType;
	terminal		: CM_Terminal;
	interestedWarning			: CM_InterestedWarning;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.type = null then
		app.raiseCMException(Input_required_field_type, 'type', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.name = null then
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
		return;
	endif;

		//29 Oct 2009	NDL	Par 21519
	if self.category = 0 then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Category), app.getErrorString(Category), null); // cnwdb2	PAR 35364
		return;
	endif; 
	
	//epr par 36902 14/6/15
	if self.amountDecimalPlaces &gt; 4 then
		app.raiseCMException(Not_have_more_than_decim_place,null,null);
	endif;
	
	if self.myRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'root is null');
		return;
	endif;
	
	// jlizm1 TFS 54165 29/07/2022
	if self.showWeight and self.myWeightType = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Measurement_type), app.getErrorString(Measurement_type), null);
	endif;
	
	//Check only one event type with this number
	existingEventType	:= app.myRoot.allEventTypesByType[self.type];
	realEventType	:= self.pxyGetRealObject;
	if existingEventType &lt;&gt; null and existingEventType &lt;&gt; realEventType then
		//app.raiseCMException2(DuplicateItem, app.getErrorString(Event_type), self.type.String, null, null);  //23/06/2022 NAVDS20 TFS 53760
		//Event Type already exists for %1 : Event_type_already_exists
		app.raiseCMException1(Event_type_already_exists, self.type.String, null, null);  //23/06/2022 NAVDS20 TFS 53760
		
	endif;	
	//Check only one event type with this name
	foreach existingEventType in app.myRoot.allEventTypesByType 
	   where existingEventType &lt;&gt; realEventType do
	   
		if existingEventType.name = self.name then
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Event_type), self.name.String, null, null); //23/06/2022 NAVDS20 TFS 53760
			//Event Type already exists for %1 : Event_type_already_exists
			app.raiseCMException1(Event_type_already_exists, self.name.String, null, null);  //23/06/2022 NAVDS20 TFS 53760
		endif;
	endforeach;
	
	if self.myClassToCreate = null then // or currentSchema.getClass(self.classNameToCreate) = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class to create (' &amp; self.classNameToCreate.String &amp; ') specified is null.');
		return;
	endif;
	
	create tmpEvent as self.myClassToCreate transient;
	
	if (not tmpEvent.isKindOf(CM_EventTransaction)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class to create is not a CM_EventTransaction for (' &amp; self.description &amp; ')');
		return;
	endif;
	
	if self.myClassToCreate = CMEVT_OverriddenWarning and self.type &lt;= EVT_MAX_JMT then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type is not valid for user defined event type (' &amp; self.type.String &amp; ')');
		return;
	endif;
		
	/*if self.type &lt;= EVT_MAX_JMT and tmpEvent.CM_EventTransaction.type &lt;&gt; self.type then
		// create method on tmEvent should set eventType to be the id.
		app.raiseUnexpectedProgramError(class.name, method.name, 
			'Class (' &amp; self.myClassToCreate.name &amp; ') does not instantiate itself correctly - ' &amp;
			'eventType not set to ' &amp; self.type.String &amp; '  for ' &amp; self.description &amp; ' in the create method');
		return;
	endif;*/
	
	foreach interestedWarning in self.allInterestedWarnings do
		if interestedWarning.errorCode = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'interestedWarning.errorCode is null.');
		endif;
	endforeach;

epilog
	delete iter;
	delete tmpEvent;
end;


</source>
    </JadeMethod>
</Class>
