    <JadeMethod name="setForCreate" id="db20a181-258b-4f63-902a-bb3c8d8c9bf7">
        <updating/>
        <source>setForCreate(_proxy :CM_TrailerArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy: CM_TrailerArea; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	self.parkStyle := _proxy.parkStyle;
	
	inheritMethod(_proxy, _passport);

	self.locationLength	:= _proxy.locationLength;
	self.locationWidth	:= _proxy.locationWidth;

end;</source>
        <Parameter name="_proxy" type="CM_TrailerArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
