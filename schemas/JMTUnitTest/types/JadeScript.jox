    <JadeMethod name="checkWithNewRunMissing" id="2eb8ecc3-78d1-47c0-9792-63401e7f2671">
        <source>checkWithNewRunMissing();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 September 2011	cnwmh5	Initial creation

*/

vars

	klass							: Class;
	meth							: Method;
	category						: UM_Category;
	file							: File;
		
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	
	methodsAddedArray				: ObjectArray;
	fileMethodArray					: StringArray;
	
	totalRunnableTests				: Integer;
	count							: Integer;
	methodText						: String;
	klassText						: String;
	line							: String;
	pos, pos2						: Integer;
	
begin
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "c:\temp\newrun.txt";
	
	create fileMethodArray transient;
	while not file.endOfFile do
		line := file.readLine();
		pos := line.pos(Tab, 1);
		if pos = 0 then
			continue;
		endif;
		pos2 := line.pos(Tab, pos + 1);
		methodText := line[pos+1:pos2-1-pos];
		fileMethodArray.add(methodText);	
	endwhile;
	
	// get the main unit test class, not found the leave
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create methodsDict transient;
	create methodsAddedArray transient;
	
	foreach klass in classes do
		
		if klass.name = "UT_DSL" then
			continue;
		endif;
				
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict do
			// if not runnable unit test method then next
			if not meth.isRunnableUnitTestMethod() then
				continue;
			endif;
			
			count := count + 1;
			
			if not fileMethodArray.includes(klass.name &amp; '::' &amp; meth.name) then
				write klass.name &amp; '::' &amp; meth.name;
			endif;
			
		endforeach;
		
	endforeach;
	write count.String;
	
epilog

	delete classes;
	delete methodsAddedArray;
	delete file;
	delete fileMethodArray;

end;
</source>
    </JadeMethod>
    <JadeMethod name="convertDataAddOverlapDetails" id="fe1175ab-91f4-4bc0-934b-8c8f80e965ec">
        <source>convertDataAddOverlapDetails();

/*

Purpose:		Add the overlap details to the Dumped Test Runs	

Date			Who		Reason
07/03/2013		cnwmh5	Initial creation

*/
constants

	DELIM					: String = ",";
	
vars

	dict					: DynaDictionary;
	jdo						: JadeDynamicObject;
	obj						: Object;
	
	inputFile				: File;
	outputFile				: File;
	
	
	lineArray				: StringArray;
	
	line 					: String;
	currStartTS				: TimeStamp;
	currFinishTS			: TimeStamp;
	prevStartTS				: TimeStamp;
	prevFinishTS			: TimeStamp;
	prevSet					: Boolean;
	overlapStr				: String;
	nonOlapTime				: Time;
	overlapAmount			: Time;
	nonOlapTimeStr			: String;
	overlapAmountStr		: String;
	count					: Integer;
	posNeg					: Integer;
	days					: Integer;
	schedule				: String;
	elapsed					: String;
	elapsedHours			: Decimal[5,2];

begin

	// initialisations
	create lineArray transient;

	// create the dict to save stuff in
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(Date, 8, true, false);			// Start Date 
	dict.addExternalKey(Time, 8, true, false);			// Start Time 
	dict.addExternalKey(Integer, 8, false, false);			// count 
	dict.endKeys(false);

	// create the input file;
	create inputFile transient;
	inputFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	inputFile.fileName := "C:\Temp\Unit_Test_Run_Details.csv";
	
	// load the file details up
	while not inputFile.endOfFile do
	
		lineArray.clear();
	
		// get rid of the header
		if line = null then
			line := inputFile.readLine();
		endif;
	
		// read the line and get the individual details
		line := inputFile.readLine();
		lineArray := line.cnGetTokens(DELIM);
		
		create jdo transient;
		jdo.addProperty("system", String);
		jdo.setPropertyValue("system", lineArray[1]);
		jdo.addProperty("startDate", Date);
		jdo.setPropertyValue("startDate", lineArray[2].Date);
		jdo.addProperty("startTime", Time);
		jdo.setPropertyValue("startTime", lineArray[3].Time);
		jdo.addProperty("finishDate", Date);
		jdo.setPropertyValue("finishDate", lineArray[4].Date);
		jdo.addProperty("finishTime", Time);
		jdo.setPropertyValue("finishTime", lineArray[5].Time);
		jdo.addProperty("runnable", Integer);
		jdo.setPropertyValue("runnable", lineArray[6].Integer);
		jdo.addProperty("testsRun", Integer);
		jdo.setPropertyValue("testsRun", lineArray[7].Integer);
		jdo.addProperty("elapsed", Real);
		jdo.setPropertyValue("elapsed", lineArray[8].Real);
		jdo.addProperty("schedule", String);
		jdo.setPropertyValue("schedule", lineArray[9]);
		jdo.addProperty("logResult", Boolean);
		jdo.setPropertyValue("logResult", lineArray[10].Boolean);
		
		count := count + 1;
				
		dict.putAtKey(lineArray[2].Date, lineArray[3].Time, count, jdo);
		
		
	endwhile;
	inputFile.close();
	
	// create the output file;
	create outputFile transient;
	outputFile.fileName := "C:\Temp\Unit_Test_Run_Details_Overlap.csv";
	if outputFile.isAvailable() then
		outputFile.purge;	
	endif;
	outputFile.writeLine('System' &amp; DELIM &amp; 'Start Date' &amp; DELIM &amp; "Start Time" &amp; DELIM &amp; "Finish Date" &amp; DELIM &amp; "Finish Time" &amp; DELIM &amp; 
		"Runnable" &amp; DELIM &amp; "Tests Run" &amp; DELIM &amp; "Elapsed (mins)" &amp; DELIM &amp; "Elapsed (hours)" &amp; DELIM &amp; "Schedule" &amp; DELIM &amp; 
		"LogResult" &amp; DELIM &amp; "Overlapped" &amp; DELIM &amp; "Non Overlap Time" &amp; DELIM &amp; "Overlap Amount");	
	
	
	// now loop through the details and work out any overlaps
	prevSet := false;
	foreach obj in dict do
		
		currStartTS.setDate(obj.JadeDynamicObject.getPropertyValue('startDate').Date);
		currStartTS.setTime(obj.JadeDynamicObject.getPropertyValue('startTime').Time);
		currFinishTS.setDate(obj.JadeDynamicObject.getPropertyValue('finishDate').Date);
		currFinishTS.setTime(obj.JadeDynamicObject.getPropertyValue('finishTime').Time);
		schedule := obj.JadeDynamicObject.getPropertyValue('schedule').String;
		schedule := schedule.replaceString("^^", "");
		elapsed := obj.JadeDynamicObject.getPropertyValue('elapsed').String;
		elapsed := elapsed.replaceString("^^", "");
		elapsedHours := (elapsed.Real / 60).Decimal;
		
		overlapStr := null;
		nonOlapTimeStr := null;
		overlapAmountStr := null;

		// work out that is overlapped and what isn't
		if prevSet then
		
			if currFinishTS &gt; prevStartTS then
				overlapAmount := currFinishTS.differenceAsTime(prevStartTS, posNeg, days);
				if overlapAmount &lt;&gt; "00:00:00".Time then
					overlapAmountStr := overlapAmount.String;
					overlapStr := "Overlap";
					
					nonOlapTime := currStartTS.differenceAsTime(prevStartTS, posNeg, days);
					nonOlapTimeStr := nonOlapTime.String;
					
				endif;
			endif;
			
		endif;
		
		// set the previous details
		prevStartTS := currStartTS;
		prevFinishTS := currFinishTS;
		prevSet := true;
				
		outputFile.writeLine(obj.JadeDynamicObject.getPropertyValue('system').String  &amp; DELIM &amp; currStartTS.date.String &amp; DELIM &amp; currStartTS.time.String &amp; DELIM &amp; 
			currFinishTS.date.String &amp; DELIM &amp; currFinishTS.time.String &amp; DELIM &amp; obj.JadeDynamicObject.getPropertyValue('runnable').String &amp; DELIM &amp; 
			obj.JadeDynamicObject.getPropertyValue('testsRun').String &amp; DELIM &amp;	elapsed &amp; DELIM &amp; elapsedHours.String &amp; DELIM &amp; schedule &amp; 
			DELIM &amp; obj.JadeDynamicObject.getPropertyValue('logResult').String &amp; DELIM &amp; overlapStr &amp; DELIM &amp; nonOlapTimeStr &amp; DELIM &amp; overlapAmountStr);
	
	endforeach;
	outputFile.close();
	
epilog

	foreach obj in dict do
		delete obj;
	endforeach;
	delete dict;
	
	delete inputFile;
	delete outputFile;
	delete lineArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cstResendSummaryEmails" id="8c164f7d-98b7-4ff1-9dfe-60001e5da8d3">
        <source>cstResendSummaryEmails();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 March 2025		navcs2	Initial creation
08/05/2025			navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

vars
	testRunner 					: JMTTestController;
	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	association					: CM_Association;
	summary						: String;
	iter						: Iterator;
	user						: String;
	userIgnore					: String;
	testRoot					: UM_Root;
	previousRun					: UM_UnitTestRun;
	previousTestResults			: UT_TestResultsByName;
	allPreviousUMResults		: UM_UnitTestResultByMRunTS;
	umResult					: UM_UnitTestResult;
	utResult					: UT_TestResult;
	isOk						: Boolean;
	retVal						: Integer;
begin
	/*
	 * NOTE: The 'To' address of an email is overwritten in app.emailReports_Navis
	 * based on process.isRunningScript and process.isMPD
	 */

	app.initialize();
	testRoot := UM_Root.firstInstance;
	iter := testRoot.allUnitTestRuns.createIterator();
	iter.back(previousRun);
	
	if previousRun &lt;&gt; null and not previousRun.endTS.isValid() then
		retVal := app.msgBox("Are you sure you want to continue ?" &amp; CrLf &amp; "Script will likely break." &amp; CrLf &amp; CrLf &amp; "Retry to get the run before this one", "Previous run did not finish", MsgBox_Abort_Retry_Ignore);
		if retVal = MsgBox_Return_Abort then
			return;
		elseif retVal = MsgBox_Return_Retry then
			iter.back(previousRun);
		endif;
	endif;
	
	if previousRun = null then
		app.msgBox("No Unit Test run found", "Error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	create testRunner transient;
	testRunner.setTotalRunableTests(previousRun.totalRunnable);
	testRunner.setPropertyValue(JMTTestController::startTime.name, previousRun.startTS);
	testRunner.setPropertyValue(JMTTestController::finishTime.name, previousRun.endTS);
	testRunner.checkLeaks := previousRun.checkLeaks;
	testRunner.logResult := previousRun.logResult;
	testRunner.setScheduleName(previousRun.scheduleName);
	
	previousTestResults := testRunner.getTestResults();
	
	create allPreviousUMResults transient;
	previousRun.allFailed.copy(allPreviousUMResults);
	previousRun.allIgnored.copy(allPreviousUMResults);
	previousRun.allPassed.copy(allPreviousUMResults);
	
	// ... the hard way it is then (surely there is a better way to get the previous results)
	foreach umResult in allPreviousUMResults do
		create utResult transient;
		utResult.elapsedTime.set(0, (umResult.elapsedTime.asRealJMT()*1000).Integer);
		utResult.errorText := umResult.details.uncompressToString().trimBlanks();
		utResult.setPropertyValue(UT_TestResult::ignored.name, umResult.hasBeenIgnored());
		utResult.owner := umResult.ownerName;
		utResult.passed := umResult.hasPassed;
		utResult.profile := null;
		utResult.runTime := umResult.methodRunStartTS;
		utResult.terminals := null;
		utResult.testClass := umResult.myClassMethod.className;
		utResult.testMethod := umResult.myClassMethod.methodName;
		previousTestResults.add(utResult);
	endforeach;
	
	create userSummaryDict transient;
	create userIgnoreDict transient;
	
	testRunner.setSendEmail(true);
/*	summary := testRunner.getResultsSummary(userSummaryDict, userIgnoreDict);
	app.emailReports(summary, "Summary", 1, testRunner);
	
	summary := "";*/
	summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, false);
	if not summary.cnContains("Failed: 0 ") then
		write "Sending Failure Summary Email...";
		app.emailReports(summary, "Failure Summary", 1, testRunner, null,false);
		write "Done";
	endif;
	
	/*iter := userSummaryDict.createIterator();
	summary := "";
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		summary := summary &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf;
		app.emailReports(app.formatFailureDetails(association.asString), user, 0, testRunner);
	endwhile;
	
	app.emailReports(summary, "User Summary", 2, testRunner);
	
	delete iter;
	iter := userIgnoreDict.createIterator();
	userIgnore := "";
	while iter.next(association) do
		userIgnoreDict.getIteratorKeys(user, iter);
		userIgnore := userIgnore &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf;
	endwhile;
	app.emailReports(userIgnore, "User Ignore Summary", 3, testRunner);*/

	isOk := true;
epilog
	if not isOk then
		delete utResult;
	endif;
	
	delete testRunner;
	delete allPreviousUMResults;
	delete userSummaryDict;
	delete userIgnoreDict;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteTIStop" id="2adb309e-253f-4848-8b52-4d89212f8de2">
        <source>deleteTIStop();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	ti : CM_TrackedItem;
	tiSet: CM_TISet;
	ceNum : String;
	proxy: CM_TrackedItem;
	stop: CM_Stops;
	stopType: CM_StopsTable;
	iter: Iterator;
begin
	app.initialize;
	app.myPassport.setMyUser("2412.12".asOid.CM_User);
	ti:="2367.1060298".asOid.CM_TrackedItem;
	proxy	:= app.createUpdateProxy( ti ).CM_TrackedItem;
	iter	:= proxy.getAllStops.createIterator();
	while iter.next(stop) do 
		stopType := stop.myStopsTable;
		if stopType &lt;&gt; null and stopType.requiresInfo then
			proxy.setRequiresInformation( stopType.requiresInfoType, "1234" );
		endif;
	endwhile;
	proxy.getAllStops.purge();
	create tiSet transient;
	tiSet.add(proxy);
	// acknowledge all warnings
	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTrackedItems( tiSet, TI_UPDMODE_NORMAL, null, app.myPassport);
epilog
	delete tiSet;
	delete proxy;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteUnReqVesselVoyages" id="691e1b08-c1ae-4378-b027-341c28c6549a">
        <source>deleteUnReqVesselVoyages();

/*

Purpose:		Delete all unused voyages and vessels

Date			Who		Reason
26/01/2015		cnwmh5	Initial creation

*/
constants

	DELIM						: String = ",";

vars

	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	outFile						: File;
	fileXML						: File;
	
	vesselVoyagesToIgnore		: StringArray;
	tiSet						: CM_TISet;
	vesselsDone					: StringArray;
	
	dict						: DynaDictionary;
	voyageDict					: DynaDictionary;
	

	iter						: Iterator;

	voyageFound					: Boolean;
	vesselCode					: String;
	voyageCode					: String;
	currentVesselCode			: String;
	voyageCount					: Integer;
	canDelete					: Boolean;
	terminalCode				: String;
	voyageOid					: String;
	currentTerminal				: String;
	reason						: String;
	text						: String;
	
begin

	app.initialize();
	
	on FileException do  app.fileExceptionHandler(exception);
	
	// change this depending on whether you are deleting the voyages and vessels or 
	// just getting the details of those that need deleting.
	canDelete := false;
	
	// get the dat file sizes at the start to compare with when finished
	create dict transient;
	dict.setMembership(CM_Vessel);
	dict.addExternalKey(String, 25, false, true);				// Vessel name
	dict.addExternalKey(String, 25, false, true);				// Reason
	dict.endKeys(false);
	
	create voyageDict transient;
	voyageDict.setMembership(CM_Voyage);
	voyageDict.addExternalKey(String, 25, false, true);			// Terminal
	voyageDict.addExternalKey(String, 25, false, true);			// Vessel name
	voyageDict.addExternalKey(String, 20, false, true);			// Voyage name
	voyageDict.addExternalKey(String, 50, false, true);			// Voyage oid
	voyageDict.endKeys(false);
	
	create vesselVoyagesToIgnore transient;
	//vesselVoyagesToIgnore.add("");
	
	create tiSet transient;	
	foreach vessel in CM_Vessel.instances discreteLock do
		voyageFound := false;
		voyageCount := 0;
		
		// read through the arrived voyages to see if any don't empty
		foreach voyage in vessel.allVoyagesByTermCodeArrival discreteLock do
			voyageFound := true;
			
			// read all the ti collections to see if any ti's exist for the voyage
			tiSet.clear();
			voyage.allOnsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allDeletedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOnshipTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allNotifiedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOffsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allTranshipTIsImport.copyNoDups(tiSet);
			voyage.allTranshipTIsExport.copyNoDups(tiSet);
			voyage.allTbaTIsByIdCargoType.copyNoDups(tiSet);
			voyage.allRRPTIsByIdCargoType.copyNoDups(tiSet);	//16 Mar 2020	NDL	TFS 47004
			voyage.allTisByHouseBol.copyNoDups(tiSet);
			
			if tiSet.isEmpty() then
				voyageCount := voyageCount + 1;
				voyageDict.putAtKey(voyage.myTerminal.code, vessel.code, voyage.code, voyage.getOidString(), voyage);
			endif;
			
		endforeach;
		
		if not voyageFound then
			dict.putAtKey(vessel.code, "No Voyages", vessel);
		elseif voyageCount = vessel.allVoyagesByTermCodeArrival.size then
			dict.putAtKey(vessel.code, "No Voyage(s) with Cargo", vessel);
		else
			dict.putAtKey(vessel.code, null, vessel);
		endif;
		
	endforeach;
	
	create outFile transient;
	outFile.fileName := "c:\temp\VesselVoyageToDelete.csv";
	if outFile.isAvailable() then
		outFile.purge();
	endif;	
	outFile.writeLine("Terminal,Vessel,Voyage,Creation Date, Creation Time, Reason,Don't Delete");
	
	iter := voyageDict.createIterator;
	while iter.next(voyage) do
	
		voyageDict.getIteratorKeys(terminalCode, vesselCode, voyageCode, voyageOid, iter);
	
		if currentTerminal &lt;&gt; terminalCode then
			if not canDelete then
				text := "has the following voyages that can be deleted as they have no assigned TI's:";
			else
				text := "has had the following voyages deleted:";
			endif;
			write "Terminal (" &amp; terminalCode &amp; ") " &amp; text;
			currentTerminal := terminalCode;
		endif;
		
		if currentVesselCode &lt;&gt; vesselCode then
			vessel := dict.getAtKeyGeq(vesselCode, reason).CM_Vessel;
			currentVesselCode := vesselCode;
			write Tab &amp; vessel.code &amp; Tab &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; vessel.creationTime.time.String;
		endif;
	
		write Tab &amp; Tab &amp; voyageCode &amp; Tab &amp; voyage.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; voyage.creationTime.time.String;
			
		outFile.writeLine(terminalCode &amp; DELIM &amp; vesselCode &amp; DELIM &amp; voyageCode &amp; DELIM &amp; voyage.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp; 
			voyage.creationTime.time.String &amp; DELIM &amp; "No assigned TI's");
			
		// delete the voyage
		if canDelete then
			////TODO/////UT_DSL.sendMsgWithParams("deleteVoyage", voyageCode);
		endif;
	
	endwhile;
	
	write CrLf &amp; CrLf &amp; "The following vessels can be deleted: ";
	delete iter;
	iter := dict.createIterator;
	while iter.next(vessel) do
		dict.getIteratorKeys(vesselCode, reason, iter);
		if reason &lt;&gt; null then
			write Tab &amp; vessel.code &amp; Tab &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
				vessel.creationTime.time.String &amp; Tab &amp; reason;
			outFile.writeLine("" &amp; DELIM &amp; vesselCode &amp; DELIM &amp; DELIM &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp; 
				vessel.creationTime.time.String &amp; DELIM &amp; reason);
				
			// delete the vessel
			////TODO/////if canDelete then
				delete fileXML;
				create fileXML transient;
				fileXML.fileName := "\\cnwchcm24\cnwpod$\Implementation\Vessel Definitions\" &amp; vesselCode &amp; ".xml";
				if fileXML.isAvailable() then
					fileXML.purge();
				endif;
				app.myTrxUA.trxExportAsXMLDoc(vessel, fileXML.fileName, app.myPassport);
				////TODO/////if not app.myPassport.hasErrorsOrWarnings() then
					////TODO/////UT_DSL.sendMsgWithParams("deleteVessel", vesselCode);
				////TODO/////endif;
			////TODO/////endif;
			
			break;
		endif;
	endwhile;
	
	
epilog

	delete iter;
	delete vesselVoyagesToIgnore;
	delete tiSet;
	delete dict;
	delete voyageDict;
	delete vesselsDone;
	delete fileXML;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="diDelOfflineFutureActInserter" id="cd0c8b5b-70f4-4fdd-bb1a-fee4942b3efa">
        <source>diDelOfflineFutureActInserter();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2019	jlgdi1	Initial creation

*/

vars
	allOfflineFutureActorInserters : ObjectArray;
	object : Object;
	offlineFutureActorInserter : CM_OfflineFutureActorInserter;	
	offlineFutureActor : CM_OfflineFutureActor;
	futureStorageProcess : CM_FutureStorageProcess;	
	iterator : Iterator;
	
begin
	write CM_OfflineFutureActorInserter.instances.size.String;
	iterator := CM_OfflineFutureActorInserter.instances.createIterator();
	while iterator.next(object) do 
		offlineFutureActorInserter := object.CM_OfflineFutureActorInserter;
		if not global.isValidObject(offlineFutureActorInserter.myOfflineFutureActor) then 
			write "Invalid " &amp; offlineFutureActorInserter.timestampCreated.String;
			beginTransaction;
			delete offlineFutureActorInserter;
			commitTransaction;
			//delete offlineFutureActorInserter;
		else
			futureStorageProcess := offlineFutureActorInserter.myOfflineFutureActor.CM_FutureStorageProcess;
			write "Valid " &amp; futureStorageProcess.myTrackedItem.id;
		endif;
	endwhile;
epilog
	delete iterator;
end;
</source>
    </JadeMethod>
    <JadeMethod name="diRemoveInvObjRef" id="6bc155b5-330a-4a07-809e-fb5d24617c0b">
        <source>diRemoveInvObjRef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2019	jlgdi1	Initial creation

*/

vars
	container : CM_Container;
	cmCreate : CM_Create;
	invalid : Boolean;	
	transController : CMIF_TITransactionController;
	transactions : CM_TITransactionByDateOrdDict;
	transaction : CM_TITransaction;
begin
	container := "2367.38865110".asOid.CM_Container;
	
	create transController transient;
	
	//create transactions transient;
	//transactions := container.getAllTransactions();
	
	foreach transaction in container.allTransactions do 
		on Exception do app.handleDeletedObject(exception, transaction, invalid);
		write transaction.edition;
		if invalid then
			//container.allTransactions.removeObject(container);
			transaction.setMyTrackedItem(container, transController);
		endif;
	endforeach;
	
	//cmCreate := "2381.43448991".asOid.CM_Create;
	
	/*
	create transController transient;
	cmCreate.setMyTrackedItem(container, transController);
	*/
	
epilog
	delete transController;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractTrxFormUnitTest_New" id="2c9e1d1a-0a0e-41fc-bca9-6c78fe2e05b3">
        <source>extractTrxFormUnitTest_New();

/*

Purpose:		Return what Form / Unit Test a trx is used on.

Date			Who		Reason
27/09/2012		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	klass						: Class;
	meth						: Method;
	outputFile					: File;

	methodsArray				: MethodSet;
	methodsAlreadyCheckedArray	: MethodSet;
	subSchemaArray				: SchemaNDict;
	classArray					: StringArray;
	methArray					: MethodNDict;
	refsByLevel					: IntegerArray;
	uniqueMethodByLevel			: IntegerArray;
	allRefs						: ObjectSet;

	schemaName					: String;
	className					: String;
	methName					: String;
	index						: Integer;
	
	
begin

	app.initialize();
	
	schemaName := "PortSchema";
	//className := "CM_TrxControlCreateAgent";
	//methName := "trxCreateCargoPhoto";
	
	create outputFile transient;
	outputFile.fileName := "c:\temp\trxformunittest.txt";
	if outputFile.isAvailable() then
		outputFile.purge;
	endif;	
	
	schema := rootSchema.getSchema(schemaName);
	if schema = null then
		write "Unable to find schema (" &amp; schemaName &amp; ")";
		return;
	endif;
	
	create refsByLevel transient;
	refsByLevel[10000] := 0;
	create uniqueMethodByLevel transient;
	uniqueMethodByLevel[10000] := 0;
	create allRefs transient;
	
	create classArray transient;
	classArray.add("CM_TrxControlCreateAgent");
	classArray.add("CM_TrxControlDeleteAgent");
	classArray.add("CM_TrxControlUpdateAgent");
	
	// get the required deatils
	create methodsArray	transient;	
	create methodsAlreadyCheckedArray transient;
	create methArray transient;
	
	write 'class' &amp; Tab &amp; 'method' &amp; Tab &amp; 'meth class' &amp; Tab &amp; 'meth name';
	outputFile.writeLine('class' &amp; Tab &amp; 'method' &amp; Tab &amp; 'meth class' &amp; Tab &amp; 'meth name');
	
	foreach className in classArray do		
	
		klass := schema.getClass(className);
		if klass = null then
			write "Unable to find class (" &amp; className &amp; ")";
			return;
		endif;
		//write klass.name &amp; Tab &amp; "*******************************";
		methArray.clear();
		methodsArray.clear();
	
		index := 1;
		
		klass.getMethods(methArray);
		foreach meth in methArray do
			
			methodsAlreadyCheckedArray.clear();
			
			if meth.name[1:3] &lt;&gt; "trx" then
				continue;
			endif;
			
			//if meth.name &lt;&gt; "trxDeleteShippingAgent" then //and meth.name &lt;&gt; "trxDeleteInterTerminalMove" then
			//if meth.name &lt;&gt; "trxVehicleRoadExit" then
			//if meth.name &lt;&gt; "trxCreateCargoPhoto" then
			//if meth.name &lt;&gt; "trxDeleteShippingAgent" then
			//if meth.name &lt;&gt; "trxDeleteYABlock" then
			//if meth.name &lt;&gt; "trxCreateCamProtocol" then
			//	continue;
			//endif;
		
		//	index := -1;
			///write "-" &amp; klass.name &amp; Tab &amp; meth.name;
			//self.addMethodToList(className, meth.name, meth, methodsArray, methodsAlreadyCheckedArray, index, outputFile);
			self.addMethodToList_New(className, meth.name, method, 1, refsByLevel, uniqueMethodByLevel, allRefs);
			
			
		endforeach;
	
	endforeach;
	
epilog

	delete methodsArray;
	delete methodsAlreadyCheckedArray;
	delete subSchemaArray;
	delete classArray;
	delete methArray;
	delete outputFile;
	delete uniqueMethodByLevel;
	delete refsByLevel;
	delete allRefs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="findClassMethodsWithText" id="e979c6d9-0ad3-48b7-b227-5b25007992d6">
        <source>findClassMethodsWithText();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 September 2011	cnwmh5	Initial creation

*/

vars

	klass							: Class;
	meth							: Method;
	category						: UM_Category;
		
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	
	methodsAddedArray				: ObjectArray;
	
	totalRunnableTests				: Integer;
	count							: Integer;
	methodText						: String;
	klassText						: String;
	
begin
		
	// get the main unit test class, not found the leave
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create methodsDict transient;
	create methodsAddedArray transient;
	
	foreach klass in classes do
		
		
	//	write klass.name;
	//	count := count + 1;
	//	continue;
		
		
		klassText := klass.text;
		klassText.replaceChar(Cr, " ");
		klassText.replaceChar(Lf, " ");
		
		if klassText &lt;&gt; null and klassText.cnContains("?xml version") then
			write klass.name &amp; Tab &amp; "**CLASS**" &amp; Tab &amp; klassText;
		endif;
		
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict do
			// if not runnable unit test method then next
			if not meth.isRunnableUnitTestMethod() then
				continue;
			endif;
			
			count := count + 1;
			
			methodText := meth.text;
			methodText.replaceChar(Cr, " ");
			methodText.replaceChar(Lf, " ");
			
			if methodText &lt;&gt; null and methodText.cnContains("?xml version") then
				write klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; methodText;
			endif;
			
			//meth.resynch();
			
			// check to see if the method's text has a category in it
			//self.updateAllCategories(meth, _className, _methodName, _scheduleName, _overnightRun, methodsAddedArray);
									
		//	endif;
			
		endforeach;
		
	endforeach;
	write count.String;
epilog

	delete classes;
	delete methodsAddedArray;

end;
</source>
    </JadeMethod>
    <JadeMethod name="fixContDischargePortIssue" id="8a9d1a58-16d1-4f79-b2a3-a922f7d951ae">
        <source>fixContDischargePortIssue();

/*

Purpose:		Fix issue with discharge ports	

Date			Who		Reason
19/11/2012		cnwmh5	Initial creation

*/

vars
		
	ti 						: CM_TrackedItem;
	terminal 				: CM_Terminal;
	
	mergeIter 				: MergeIterator;
	
	dischargePort			: String;
	
begin
	
	app.initialize();
	
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals discreteLock do
	
		delete mergeIter;
		create mergeIter transient;
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
		
		while mergeIter.next(ti) do
			if ti.dischargePort &lt;&gt; null and ti.dischargePort.trimBlanks().length &lt; 5 then
				//write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.dischargePort &amp; Tab &amp; terminal.code &amp; Tab &amp; ti.creationTime.String;
				if ti.dischargePort = "700" then
					dischargePort := "NZCHC";
				elseif ti.dischargePort = "AEF" then
					dischargePort := "GRAEF";
				elseif ti.dischargePort = "AKA" then
					dischargePort := "NZAKA";
				elseif ti.dischargePort = "AWR" then
					dischargePort := "DEAWR";
				elseif ti.dischargePort = "BRV" then
					dischargePort := "DEBRV";
				elseif ti.dischargePort = "CHC" then
					dischargePort := "NZCHC";
				elseif ti.dischargePort = "FPO" then
					dischargePort := "USFPO";
				elseif ti.dischargePort = "GMN" then
					dischargePort := "NZGMN";
				elseif ti.dischargePort = "GOB" then
					dischargePort := "NZGOB";
				elseif ti.dischargePort = "GRA" then
					dischargePort := "USGRA";
				elseif ti.dischargePort = "HAM" then
					dischargePort := "DEHAM";
				elseif ti.dischargePort = "KLA" then
					dischargePort := "GRKLA";
				elseif ti.dischargePort = "LAV" then
					dischargePort := "ITLAV";
				elseif ti.dischargePort = "MEL" then
					dischargePort := "AUMEL";
				elseif ti.dischargePort = "MSI" then
					dischargePort := "FRMSI";
				elseif ti.dischargePort = "NPL" then
					dischargePort := "NZNPL";
				elseif ti.dischargePort = "PAR" then
					dischargePort := "FRPAR";
				elseif ti.dischargePort = "SIN" then
					dischargePort := "SGSIN";
				elseif ti.dischargePort = "TPP" then
					dischargePort := "MYTPP";
				endif;
				ti.setDischargePort(dischargePort);
			endif;
		endwhile;
		
	endforeach;
	commitTransaction;
	
epilog
	delete mergeIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllDBFileSizes" id="ebdaf08c-171d-47f0-ad4b-5de5823d8938">
        <source>getAllDBFileSizes();

/*

Purpose:		

Date			Who		Reason
12 December 2013	cnwmh5	Initial creation

*/

vars

	dba							: JadeDatabaseAdmin;
	dbFile						: DbFile;
	file						: File;
	
	dbFiles						: DbFileArray;
	
begin

	app.initialize();
	
	
	create file transient;
	file.fileName := "C:\temp\doha2.txt";
	file.usePresentationFileSystem := true;
	if file.isAvailable() then
		file.purge();
	endif;
	
	// Compact unitTest.dat and audit.dat
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	foreach dbFile in dbFiles do
		write dbFile.name &amp; Tab &amp; dbFile.getFileLength().String;
		file.writeLine(dbFile.name &amp; Tab &amp; dbFile.getFileLength().String);
	endforeach;
	
epilog

	delete dba;
	delete dbFiles;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllOfWhomeversTests" id="dd100c36-1994-452f-9108-9e017e0580e8">
        <source>getAllOfWhomeversTests();

/*

Purpose:			To get all of the unit tests for a specfic owner

Date				Who		Reason
26/08/2013			cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	file				: File;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	tokens				: StringArray512;
	missingOwnerArray	: StringArray;
	
	methodSource		: String;
	line				: String;
	token				: String;
	linePos 			: Integer;
	found				: Boolean;
	userName			: String;
	methodCount			: Integer;
	
begin

	app.initialize();

	create tokens transient;
	create missingOwnerArray transient;

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	//self.assertNotNull(klass);
	if klass = null then
		return;
	endif;
	
	userName := "CNWDW1";
	methodCount := 0;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
	
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if token.toUpper().cnContains(userName) then
						found := true;
						break;
					endif;
				endforeach;
			endwhile;
			
			if found then 
				missingOwnerArray.add(klass.name &amp; "::" &amp; meth.name);
				methodCount := methodCount + 1;
			endif;			
			
		endforeach;
	
	endforeach;
		
	// check to see if anything was found
	if not missingOwnerArray.isEmpty then
		app.writeLog(CrLf &amp; "The following method(s) are owned by " &amp; userName &amp; CrLf &amp; missingOwnerArray.concatenate(CrLf), LogINFO);
		app.writeLog("count: " &amp; methodCount.String, LogINFO);
		write CrLf &amp; "The following method(s) are owned by " &amp; userName &amp; CrLf &amp; missingOwnerArray.concatenate(CrLf);
		write "count: " &amp; methodCount.String;
		//self.assertNull(missingOwnerArray);
	endif;
	
	// output the details to a file
	create file transient;
	file.fileName := "c:\temp\" &amp; userName &amp; "_UnitTests.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Class,Method,Assign To");
	
	foreach line in missingOwnerArray do
		line := line.replaceString("::", ",");
		file.writeLine(line &amp; ",");
	endforeach;
	file.close();	
	
epilog

	delete classes;
	delete tokens;
	delete missingOwnerArray;
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getTestableTests" id="5f9c7769-e084-4ae4-b91c-1713e2d2f1b9">
        <source>getTestableTests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2013	cnwmc5	Initial creation

*/

vars
	klass 				: Class;
	meth 				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	methodsAddedArray	: ObjectArray;
	
	count				: Integer;
	
begin
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create methodsDict transient;
	create methodsAddedArray transient;
	
	count := 0;
	
	foreach klass in classes do	
		methodsAddedArray.clear();
		
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict do
			// if not runnable unit test method then next
			if not meth.isRunnableUnitTestMethod() then
				continue;
			endif;
			
			count := count + 1;
			
			write klass.name &amp; "::" &amp; meth.name;
		endforeach;
	endforeach;
	
	write 'Total Runnable: ' &amp; count.String;
	
epilog
	delete methodsAddedArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getUnitTestMethodsCreationDate" id="87dd8a88-f5c5-4737-b96f-5c0eb30447bb">
        <source>getUnitTestMethodsCreationDate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	cnwmh5	Initial creation

*/

vars

	klass			: Class;
	
	meth			: Method;
	localVar 		: JadeLocalVar;
	value			: Any;
	
	file			: File;
	
	methodsDict		: MethodNDict;
	addHoursNotOK	: HugeStringArray;
	classes			: ClassColl;
	
	iter			: Iterator;
	
	tokens			: HugeStringArray;
	
	methodSource	: String;
	tokensSize		: Integer;
	
	token			: String;
	
	addHoursOK		: Boolean;
	addHoursFound	: Boolean;
		
	tokenPos		: Integer;
	pos				: Integer;
	attrib 			: String;

	str				: String;
	msgStr			: String;

	
begin

	// get the class
	klass := currentSchema.getClass("UT_DSL");
	//assertNotNull(klass);
	if klass = null then
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\methodsCreationDate.txt";
	if file.isAvailable() then
		file.purge;
	endif;
	file.writeLine("class" &amp; Tab &amp; 'method' &amp; Tab &amp; 'key' &amp; Tab &amp; 'date');
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	create addHoursNotOK transient;
	
	// go throught the class and check pxyCreateUpdateProxy
	foreach klass in classes do
		// class is null just return
		//if _class = null then
		//	return;
		//endif;	
		
		// Get all the references to the named class
		methodsDict := klass.cnGetMethods();
		iter:= methodsDict.createIterator;
		
		while iter.next(meth) do
			
			file.writeLine(klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; klass.name &amp; meth.name &amp; Tab &amp; meth.creationTime.date.String);
			
			/*
			//if meth.name = "check_addHoursUsage" or meth.name = "uCheck_addHoursUsageOK" then
			//if meth.name.cnContains("_addHoursUsage") then
			//	continue;
			//endif;
		
			//methodSource := self.removeCommentsFromSource(meth.getSource());
			//methodSource.replaceChar(Cr, " ");
			//methodSource.replaceChar(Lf, " ");
	
			// Break method source into tokens
			//delete tokens;
			//tokens := methodSource.getHugeTokens;
			//tokensSize := tokens.size;
	
			//addHoursOK := false;
			//addHoursFound := false;
			//token := null;
			//attrib := null;
			
			foreach tokenPos in 1 to tokensSize do	
				
				token := tokens[tokenPos];
				
				if token.cnContains("addHours") then
					pos	:= token.pos(".", 1);
					if pos &gt; 0 then
						attrib := token[1:pos-1];
						if attrib &lt;&gt; null then
							foreach localVar in meth.JadeMethod.cnGetLocalVars do
								if localVar.name = attrib then 
									value := localVar.type;
									if value.getName() = TimeStamp.getName() then
										addHoursOK := true;
									else 
										if not tokens[tokenPos+1].cnContains('.setTime(') then
											addHoursOK := true;
										endif;
									endif;
								endif;
							endforeach;
						endif;
					endif;
					addHoursFound := true;
				endif;
						
			endforeach;
			
			delete tokens;
			
			if addHoursFound and not addHoursOK then
				_addHoursNotOK.add(_class.name &amp; "::" &amp; meth.name &amp; " is using .addHours on a Time then .setTime on a TimeStamp");
			endif;		
			*/
			
		endwhile;
		
	endforeach;
	
	//foreach str in addHoursNotOK do
	//	msgStr := msgStr &amp; str &amp; CrLf;
	//endforeach;
	
	//assertEqualMsg(addHoursNotOK.size, 0, msgStr);	
	
	file.close();
	
epilog

	delete classes;
	delete addHoursNotOK;
	delete iter;
	delete tokens;
	delete file;

end;</source>
    </JadeMethod>
