    <JadeMethod name="erase" id="9b196090-f504-4c3d-84ce-e5933760a872">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

	row : CM_RowAreaRow;


begin

	// If it is the last controller then remove the row.
	if self.isTransient then
		inheritMethod(_eraseLevel);
	else
		if self.myRow &lt;&gt; null and self.myRow.allRowControllers.size = 1 then
			if self.myRowArea &lt;&gt; null and	//rs apr 2005 par 10003
			   not self.myRowArea.removeRowAreaRow(self.myRow) then
				app.raiseCMException1(RemoveLogRowError, null,null, null);	
			endif;
		else
			inheritMethod(_eraseLevel);
		endif;
	endif;

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0d2c05a1-26a3-4f58-8a17-7a4f9b24fdf1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_DistanceFromPrevious then
		// PAR 10139 - protect against null here
		if self.myRowArea &lt;&gt; null and self.myRow &lt;&gt; null then
			return self.myRowArea.getPrevGap(self.myRow).String;
		endif;
		return null;
	elseif _attrName = ETRow_RowId then
		return self.getID();
	elseif _attrName = ETRow_Width then
		if self.myRow &lt;&gt; null then
			return self.myRow.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
