    <JadeMethod name="setProxyBaseData" id="586456af-f1b3-49a7-8f39-d1eac355e73e">
        <updating/>
        <source>setProxyBaseData(	_maxStackHeight : Integer;
					_name : String;
					_neverMix : Boolean;
					_termAreaMaster : CM_TerminalAreaMaster
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin

	self.maxStackHeight := _maxStackHeight;
	self.name := _name;
	self.neverMix := _neverMix;
	self.setMyTerminalAreaMaster( _termAreaMaster );
					
epilog

end;</source>
        <Parameter name="_maxStackHeight" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_neverMix" type="Boolean"/>
        <Parameter name="_termAreaMaster" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d6c00a43-161e-4764-82ed-464f680fa173">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin
	inheritMethod();
	
	if self.name.trimBlanks = null then
		app.raiseCMException(Input_required_field_fileName, null, null);
	endif;
	
	if self.priority &lt;= 0 then
		app.raiseCMException(No_Priority_entered, null, null);
	endif;
	
	if self.maxStackHeight &lt;= 0 then
		app.raiseCMException2(Invali_value_must_greate_than, app.getErrorString(Max_Number_in_stack), "1", null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
