    </JadeMethod>
    <JadeMethod name="populateCmbTruck2" id="5cc8b39d-4c1c-45af-aa7d-706ab7b7d146">
        <source>populateCmbTruck2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	truck : CM_Vehicle;
	allTrucks : CM_VehicleSet;

begin

	self.cmbTruck2.clear();
	
	create allTrucks transient;
	self.getAllCurrentTrucks( allTrucks );

	
	foreach truck in allTrucks do
		self.cmbTruck2.itemObject[ self.cmbTruck2.addItem( truck.regNumber ) ] := truck;
	endforeach;
	
	
	if self.cmbTruck2.listCount = 1 then
		// there is only one select it.
		self.cmbTruck2.listIndex := 1;
		self.cmbTruck2.enabled := false;
		
	elseif self.cmbTruck2.listCount = 0 then
		self.cmbTruck2.addItem( app.getErrorString( NO_Other_trucks_found ) );
		self.cmbTruck2.listIndex := 1;
		self.cmbTruck2.enabled := false;
		
	else
		self.cmbTruck2.addItem( " &lt;" &amp; app.getErrorString( Select_other_truck ) &amp; "&gt;" );
		self.cmbTruck2.listIndex := 1;
		self.cmbTruck2.enabled := true;
		
	endif;
	
	self.cmbTruck2.click( self.cmbTruck2 );

epilog

	delete allTrucks;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbTruckWles" id="b7ed0564-de9e-4ef9-82ab-b248f446aa0c">
        <updating/>
        <source>populateCmbTruckWles( _cmbTruckWle : MOB_ComboBox input; _truck : CM_Vehicle ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

	vehicleVisit : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	allTrucks : CM_VehicleSet;
	truck : CM_Vehicle;

begin

	_cmbTruckWle.clear();
	
	create allTrucks transient;
	if _truck &lt;&gt; null then
		allTrucks.add( _truck );
	else
		self.getAllCurrentTrucks( allTrucks );
		if _cmbTruckWle = self.cmbTruck2Wle and self.myPrimaryTruck &lt;&gt; null then
			if allTrucks.includes( self.myPrimaryTruck ) then
				allTrucks.remove( self.myPrimaryTruck );
			endif;
		endif;
	endif;
	
	foreach truck in allTrucks do
		if truck &lt;&gt; null then
			vehicleVisit := truck.visitRecords.last;
			if vehicleVisit &lt;&gt; null then
				roadJob := vehicleVisit.myRoadJob;
			endif;
			if roadJob &lt;&gt; null and not roadJob.status = JOB_COMPLETE then
				foreach wle in roadJob.workListEntries do
					if wle.isReceipt then
						continue;
					endif;
					if wle.status = WLE_COMPLETED then
						continue;
					endif;

					if wle.myTrackedItem &lt;&gt; null then
						_cmbTruckWle.itemObject[_cmbTruckWle.addItem( wle.myTrackedItem.id )] := wle;
					else
						_cmbTruckWle.itemObject[_cmbTruckWle.addItem( wle.myRequest.getDisplayStringForAttribute(ETRow_CargoDetails, true) )] := wle;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	if _cmbTruckWle.listCount = 1 then
		// there is only one select it.
		_cmbTruckWle.listIndex := 1;
		_cmbTruckWle.enabled := false;
		
	elseif _cmbTruckWle.listCount = 0 then
		if _truck &lt;&gt; null then
			_cmbTruckWle.addItem( app.getErrorString( NO_Cargo_found_swap ) );
			_cmbTruckWle.listIndex := 1;
		endif;
		_cmbTruckWle.enabled := false;
		
	else
		if _cmbTruckWle = self.cmbTruck1Wle then
			_cmbTruckWle.addItem( " &lt;" &amp; app.getErrorString( Select_cargo_swap ) &amp; "&gt;" );
		else
			_cmbTruckWle.addItem( " &lt;" &amp; app.getErrorString( Select_other_cargo_swap ) &amp; "&gt;" );
		endif;
		_cmbTruckWle.listIndex := 1;
		_cmbTruckWle.enabled := true;
		
	endif;
	
	_cmbTruckWle.click( _cmbTruckWle );

epilog

	delete allTrucks;

end;</source>
        <Parameter name="_cmbTruckWle" type="MOB_ComboBox" usage="input"/>
        <Parameter name="_truck" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="c6cb5576-ab3e-485c-8159-83a49e346703">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

begin

	self.caption := app.getErrorString(Cargo_swap);
	self.myPrimaryTruck := self.myMobileGenericAgent.myTruck;
							
	self.doResizeControls(true);
	
	if self.myPrimaryTruck &lt;&gt; null then
		self.txtTruck1.text := self.myPrimaryTruck.regNumber;
		self.txtState1.text := self.myPrimaryTruck.state;
	endif;
	self.populateCmbTruckWles( self.cmbTruck1Wle, self.myPrimaryTruck );
	self.populateCmbTruck2();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e828fd66-aa53-4d83-a7cb-29365a08e054">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 30819

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="73896d7d-d01a-4630-8c3c-2d66b3ad7c5d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 November 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019346, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
