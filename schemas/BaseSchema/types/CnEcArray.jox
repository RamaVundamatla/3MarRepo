<CollClass name="CnEcArray" id="5fe1f81b-5e68-4931-8d01-e1655b3dde40">
    <memberType name="CnEcArrayObject"/>
    <superclass name="Array"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
