    <JadeMethod name="copyInvsExcludingReturned" id="686160a0-97df-4b9a-b5df-acdf76e11d07">
        <source>copyInvsExcludingReturned( _from : ObjectArray; _to : Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	obj : Object;
	inv : CM_Invoice;

begin

	foreach obj in _from where obj.isKindOf( CM_Invoice ) do
		inv := obj.CM_Invoice;
		if inv.isReversed or inv.isReverseCredit then
			continue;
		endif;
		_to.add( inv );
	endforeach;

epilog

end;</source>
        <Parameter name="_from" type="ObjectArray"/>
        <Parameter name="_to" type="Collection" usage="input"/>
    </JadeMethod>
