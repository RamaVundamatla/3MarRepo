    </JadeMethod>
    <JadeMethod name="setForCreateUpdateCommon" id="d42bf31e-a4c3-4887-a50b-244ceb42e396">
        <updating/>
        <source>setForCreateUpdateCommon(_pxyGTEEntity: CMGTE_Entity) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2009	cnwjk3	Initial creation

*/

vars
//	damageInstance,newDamageInstance : CM_DamageInstance;
	photo, newPhoto 				: CM_Attachment;
begin
	self.myTerminal 			:= _pxyGTEEntity.myTerminal;
	self.isChassisIn			:= _pxyGTEEntity.isChassisIn;
	self.isChassisOut			:= _pxyGTEEntity.isChassisOut;
	//self.jobTypeString		:= _pxyGTEEntity.jobTypeString; Mapped
	self.numPrints 				:= _pxyGTEEntity.numPrints;
	self.placardShowing 		:= _pxyGTEEntity.placardShowing;
	self.scaleWeight 			:= _pxyGTEEntity.scaleWeight;
	self.subTerminalCode 		:= _pxyGTEEntity.subTerminalCode;
	self.tranNumber				:= _pxyGTEEntity.tranNumber;
//slw	self.myParent 				:= _pxyGTEEntity.myParent;
	self.myYardRequest			:= _pxyGTEEntity.myYardRequest;
	self.myTransferToTerminal	:= _pxyGTEEntity.myTransferToTerminal;
	self.companyCode			:= _pxyGTEEntity.companyCode;
	
	if self.jobQueueNum &lt;&gt; _pxyGTEEntity.jobQueueNum then
		self.jobQueueNum			:= _pxyGTEEntity.jobQueueNum;
	endif;
	// Next attributes were moved up from CMGTE_Receival and CMGTE_Release
	self.description 			:= _pxyGTEEntity.description;
	self.eirNumber 				:= _pxyGTEEntity.eirNumber;
	self.freightForwarderCode 	:= _pxyGTEEntity.freightForwarderCode;
	self.height 				:= _pxyGTEEntity.height;
	self.heightString			:= _pxyGTEEntity.heightString;
	self.id 					:= _pxyGTEEntity.id;
	self.length 				:= _pxyGTEEntity.length;
	self.lengthString			:= _pxyGTEEntity.lengthString;
	self.mark					:= _pxyGTEEntity.mark;
	self.markNumber 			:= _pxyGTEEntity.markNumber;
	self.myBookingRefItem 		:= _pxyGTEEntity.myBookingRefItem;
	self.myProduct 				:= _pxyGTEEntity.myProduct;
	self.operatorCode 			:= _pxyGTEEntity.operatorCode;
	self.quantity 				:= _pxyGTEEntity.quantity;
	self.type					:= _pxyGTEEntity.type;
	//self.volume					:= _pxyGTEEntity.volume;
	self.setMyVolume(_pxyGTEEntity.getMyVolume);	//18 Jul 2011	NDL	Par 27868
	self.voyageCode 			:= _pxyGTEEntity.voyageCode;	
	self.weight 				:= _pxyGTEEntity.weight;
	self.width 					:= _pxyGTEEntity.width;
	self.widthString			:= _pxyGTEEntity.widthString;
	self.yardLocationTxt		:= _pxyGTEEntity.yardLocationTxt;
	
	self.clientRef				:= _pxyGTEEntity.clientRef; // cnwrd1 par 23337 19.5.2010
	
	self.directDelivery			:= _pxyGTEEntity.directDelivery;	//30 Jan 2013	NDL	Par 31102

	self.remarksAdditional1		:= _pxyGTEEntity.remarksAdditional1;	//	7/2/19 MAP TFS40701
	self.remarksAdditional2		:= _pxyGTEEntity.remarksAdditional2;
/*	self.allDamageInstancesByPos.purge;
	foreach damageInstance in _pxyGTEEntity.allDamageInstancesByPos do
		damageInstance.validateForUpdate();
		create newDamageInstance persistent;
		newDamageInstance.setForUpdateSubject(damageInstance,self);	
	endforeach; */
	self.setDamageFromProxy( _pxyGTEEntity  );	//07 May 2014	NDL	Par 34076
	
	self.allAttachments.purge;
	foreach photo in _pxyGTEEntity.allAttachments do
		create newPhoto as photo.class persistent;
		newPhoto.setForCreate(photo);
		newPhoto.setMyGTEEntity(self);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9b3ab25d-2b82-4d07-b569-286d2a02aea9">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_Entity; _realVVR : CM_VehicleVisitRecord ) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.setForCreateUpdateCommon(_pxyGTEEntity);
	self.date 					:= _pxyGTEEntity.date;
	if self.myParent = null and self.myVehicleVisitRecord &lt;&gt; _realVVR then
		self.myVehicleVisitRecord 	:= _realVVR;
	endif;
	self.status 				:= _pxyGTEEntity.status;
	
	//cnwrd1 par 24169 9.6.2010
	self.allSourceTAs.clear();
	_pxyGTEEntity.allSourceTAs.copy(self.allSourceTAs);
	
	//cnwrd1 par 28628 5.12.2011
	self.allSourceTAGridObjs.clear();	
	_pxyGTEEntity.allSourceTAGridObjs.copy(self.allSourceTAGridObjs);

epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Entity"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateErrorForMe" id="2f2c2cb6-4f36-4137-a4f1-2e76b1f2ff6b">
        <updating/>
        <source>setForUpdateErrorForMe(_vvr : CM_VehicleVisitRecord input; _err : CM_Error input; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStatus : Integer;
	tranNum : String;
	err : CM_Error;
	vvError : CM_ErrorPersistent;
	hasTrouble : Boolean;
begin
	if not _passport.errorsToIgnore.includes(_err.errorCode) then
		return false;
	endif;
	// ### Change status of existing warnings/errors if no longer trouble
	foreach vvError in self.allErrorsAndWarnings discreteLock do : outerLoop
		foreach err in _passport.allErrorWarnings discreteLock where err.myUserObject = self  do
			
			if vvError.text = err.text then
				if vvError.status = CM_ErrorPersistent.Status_Closed then
					vvError.updateStatus(CM_ErrorPersistent.Status_Open);
				endif;
				continue outerLoop; // still an error/warning so leave as is.
			endif;
		endforeach;
		
		vvError.updateStatus(CM_ErrorPersistent.Status_Closed);
	endforeach;
	
	tranNum := self.tranNumber;
	
	// NO DUPLICATES
	// do we have NEW trouble
	hasTrouble := true;
	foreach vvError in self.allErrorsAndWarnings discreteLock do
		// if we have a matching error that is still open then WE have trouble
		if vvError.text = _err.text then
			if vvError.status = CM_ErrorPersistent.Status_Open then
					self.changeStatus(CMGTE_Entity.Status_Trouble);
			endif;
			hasTrouble := false;
			break;
		endif;
	endforeach;
	
	if hasTrouble then
		create vvError;
		
		vvError.init(_vvr, tranNum, self);
		vvError.setFromError(_err);
		self.changeStatus(CMGTE_Entity.Status_Trouble);
		
		return true;
	endif;
	
	return false;
	
epilog
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_err" type="CM_Error" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateErrorsFromPassport" id="db6d8771-e6ee-4f15-9528-a3b8475bc188">
        <updating/>
        <source>setForUpdateErrorsFromPassport(_vvr : CM_VehicleVisitRecord; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStatus : Integer;
	tranNum : String;
	err : CM_Error;
	vvError : CM_ErrorPersistent;
	hasTrouble : Boolean;
begin

// currently the following is not true in all casses where this is called.
//    - assume that this is called on the transient (pxy) self and may or may not have a real VVR
//
// Needs more thought as to how to handle:
//  - cannot just call this with persistent


	if self.isTransient or _vvr.isTransient then
		// will need to change this but for now trap when we get here with transients and work out how to handle
//		process.debug;
//		app.raiseUnexpectedProgramError(class.name, method.name, 'Here with transient data ' &amp;
//				'CMGTE_Entity isTransient= ' &amp; self.isTransient.String &amp; ', _vvr.isTransient = ' &amp;
//				_vvr.isTransient.String);
//		return;
	endif;
	
	// ### Change status of existing warnings/errors if no longer trouble
	foreach vvError in self.allErrorsAndWarnings discreteLock do : outerLoop
		foreach err in _passport.allErrorWarnings discreteLock where err.myErrorPersistent = null  do
			
			if vvError.text = err.text then
				if vvError.status = CM_ErrorPersistent.Status_Closed then
					vvError.updateStatus(CM_ErrorPersistent.Status_Open);
				endif;
				err.myErrorPersistent := vvError;
				continue outerLoop; // still an error/warning so leave as is.
			endif;
		endforeach;
		
		vvError.updateStatus(CM_ErrorPersistent.Status_Closed);
	endforeach;

	tranNum := self.tranNumber;
	
	
	// Have had to temporarily disable the creation of persistent errors as it does not fit in with the new framework.
	/*
	// ### Check for any new errors and warnings
	foreach err in _passport.allErrorWarnings discreteLock where err.myErrorPersistent = null  do : outerLoop
	
		// NO DUPLICATES
		foreach vvError in self.allErrorsAndWarnings discreteLock do
			if vvError.text = err.text then
				continue outerLoop;
			endif;
		endforeach;
		
		create vvError persistent;
		
		vvError.init(_vvr, tranNum, self);
		vvError.setFromError(err);

	endforeach;
	*/

/*	
	foreach vvError in self.allErrorsAndWarnings discreteLock do : outerLoop
		if vvError.isTrouble() then
			hasTrouble := true;
		endif;
	endforeach;
	*/
//	if hasTrouble then
//		self.changeStatus(CMGTE_Entity.Status_Trouble);
//	else
		self.changeStatus(CMGTE_Entity.Status_Unverified);
//	endif;
	
epilog
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStatusForTrouble" id="fb0c7c78-02d2-4093-a6e2-af5167e28107">
        <updating/>
        <source>setForUpdateStatusForTrouble() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vvError : CM_ErrorPersistent;
	hasTrouble : Boolean;

begin
	foreach vvError in self.allErrorsAndWarnings discreteLock do 
		if vvError.hasTrouble() then
			hasTrouble := true;
			self.changeStatus(CMGTE_Entity.Status_Trouble);
			break;
		endif;
	endforeach;

	return hasTrouble;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
