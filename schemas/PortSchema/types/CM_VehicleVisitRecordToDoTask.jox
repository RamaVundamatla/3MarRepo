<Class name="CM_VehicleVisitRecordToDoTask" id="09ed8c65-5db4-4c15-aca2-dd85e231aac3">
    <superclass name="CM_ToDoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="myVVRComplete" id="c50bcbdf-20c2-4a20-8ced-90fb1c50927b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allToDoTasksCompleted"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVVRToDo" id="7b5f20c1-2a64-47f4-b6d2-cec39c8650ac">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allToDoTasksToDo"/>
    </ExplicitInverseRef>
    <JadeMethod name="getToDoObject" id="8befb738-c2c0-4c68-a826-a7389b995b95">
        <source>getToDoObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs

*/

vars

begin
	return self.myVVRToDo;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="1c3720df-88ce-4ab7-8f6f-079b480bb647">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date 		Who	   Reason
06 Jun 2023 navma1 Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars

begin
	if set then
		return;
	endif;
	
	if self.myVVRToDo &lt;&gt; null then
		_value := self.myVVRToDo.myTerminal;
	elseif self.myVVRComplete &lt;&gt; null then 
		_value := myVVRComplete.myTerminal;  
	else
		_value := null;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="492658cb-d9c5-470e-b3fd-c218de0a2a0c">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _passport : CM_Passport input; _vehicleVisit : CM_VehicleVisitRecord; _wod : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	event		: CMEVT_TruckEvent;
	transType	: Integer;
begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _passport.userCode);
	self.myVVRToDo := _vehicleVisit;

	transType :=  self.getToDoTaskCreateEventInt;
	
	if transType &lt;&gt; null then
		event := self.myVVRToDo.createTransaction(transType, app.actualTime(), null, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="updateVVRComplete" id="d0ae42eb-1eb7-4c52-9d30-5ffa7b2bddfa">
        <updating/>
        <source>updateVVRComplete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.myVVRComplete := self.myVVRToDo;
	self.myVVRToDo := null;
epilog

end;</source>
    </JadeMethod>
</Class>
