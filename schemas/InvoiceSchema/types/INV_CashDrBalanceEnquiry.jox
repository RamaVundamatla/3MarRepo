    <JadeMethod name="addTableData" id="6a883218-b01c-4e37-8413-2e2e81c122b9">
        <updating/>
        <source>addTableData( 	allDrTerms : ObjectArray;
				includeDetail : Boolean;
				includeSummary : Boolean
				) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2012	cnwndl1	Initial creation
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	sumUnalloc,
	sumProFroma,
	sumBalance,
	unalloc,
	proFroma,
	balance 			: Decimal [16,4];	//21.10.2019 cnwma1 TFS #47081
	index 				: Integer;
	tableLine,
	drString,
	termString,
	balanceString,
	sumUnallocString,
	unallocString,
	sumBalanceString,
	proFromaString,
	sumProFromaString   : String;
	obj 				: Object;
	drTerm				: CM_DebtorTerminal;
	firstDebtor 		: CM_Debtor;
	firstTerm 			: CM_Terminal;
	debtorChanged,
	termChanged 		: Boolean;

begin

	if allDrTerms.isEmpty then
		return;
	endif;

	
	foreach obj in allDrTerms do
		drTerm := obj.CM_DebtorTerminal;
		if not debtorChanged then
			if firstDebtor = null then
				firstDebtor := drTerm.myDebtor;
			elseif firstDebtor &lt;&gt; drTerm.myDebtor then
				debtorChanged := true;
			endif;
		endif;
		if not termChanged then
			if firstTerm = null then
				firstTerm := drTerm.myTerminal;
			elseif firstTerm &lt;&gt; drTerm.myTerminal then
				termChanged := true;
			endif;
		endif;
		
		drString 		:= drTerm.myDebtor.name;
		termString 		:= drTerm.myTerminal.name;
		unalloc 		:= drTerm.getCreditAmount;		// 37141
		unallocString 	:= unalloc.asCurrencyJMT;
		proFroma 		:= drTerm.getProformaAmount;
		proFromaString 	:= proFroma.asCurrencyJMT;
		balance 		:= unalloc + proFroma;
		balanceString 	:= balance.asCurrencyJMT;
		
		sumUnalloc 		:= sumUnalloc + unalloc;
		sumProFroma 	:= sumProFroma + proFroma;
		sumBalance 		:= sumBalance + balance;
			
		if includeDetail then
		
			tableLine := drString &amp; Tab
						&amp; termString &amp; Tab
						&amp; unallocString &amp; Tab
						&amp; proFromaString &amp; Tab
						&amp; balanceString;
			
			index := self.tblCash.addItem( tableLine );
			self.tblCash.accessRow(index).itemObject := drTerm;
			if balance &lt; 0 then
				self.tblCash.accessCell(index,5).backColor := LightRed;	
			endif;
			if unalloc &lt; 0 then
				self.tblCash.accessCell(index,3).backColor := LightRed;
			endif;
			
		endif;
		
	endforeach;
	
	
	if includeSummary then
		
		if not debtorChanged and not termChanged then
			if includeDetail then
				drString := null;
				termString := null;
			endif;
		elseif debtorChanged and termChanged then
			drString := app.getErrorString(CM_All_Debtors);
			termString := app.getErrorString(All_Terminals);
		else
			if debtorChanged then
				drString := app.getErrorString(CM_All_Debtors);
				if includeDetail then
					termString := null;
				endif;
			endif;
			if termChanged then
				termString := app.getErrorString(All_Terminals);
				if includeDetail then
					drString := null;
				endif;
			endif;
		endif;
		
		unallocString  := sumUnalloc.asCurrencyJMT;
		proFromaString := sumProFroma.asCurrencyJMT;
		balanceString  := sumBalance.asCurrencyJMT;
		
		tableLine := drString 		 &amp; Tab
					&amp; termString 	 &amp; Tab
					&amp; unallocString  &amp; Tab
					&amp; proFromaString &amp; Tab
					&amp; balanceString;
	
		index := self.tblCash.addItem( tableLine );
		self.tblCash.accessRow(index).itemObject := drTerm;
		self.tblCash.accessRow(index).backColor  := LightGray;
		self.tblCash.accessRow(index).fontBold   := true;
		if sumBalance &lt; 0 then
			self.tblCash.accessCell(index,5).backColor := Red;
		endif;
		if sumUnalloc &lt; 0 then
			self.tblCash.accessCell(index,3).backColor := Red;
		endif;
					
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="allDrTerms" type="ObjectArray"/>
        <Parameter name="includeDetail" type="Boolean"/>
        <Parameter name="includeSummary" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="197e6afb-64db-452d-be74-e1222d62cd56">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars

	frm : CMUI_Toolbar;
	frm2 : CMUI_Toolbar;
	
begin
	
	frm := self.frmToolbar;
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintTbl, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSV, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm2 := self.frmSearchToolbar;
	frm2.isPositionsCalculated := true;
	frm2.allLeftControls.purge();
	frm2.allRightControls.purge();
	
	frm2.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm2.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm2.positionToolbarControls();
	frm2.visible := true;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
