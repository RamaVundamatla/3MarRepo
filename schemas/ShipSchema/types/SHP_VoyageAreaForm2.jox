    <JadeMethod name="doBtnToolBarLOADDRAW" id="85550eb0-bb3f-4c6f-8d70-0aab4cb90c18">
        <updating/>
        <source>doBtnToolBarLOADDRAW() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trxCompletedOK : Boolean;
begin
	// DLR, SOB and basic Discharge and Load colour coding allow for the ALT key to be used. 
	// This checks that the same amount of slots have been slected either side of the 'ALT'
	if (not self.myBayDrawingController.validateCompareSelectedPoints("Load", "Slots")) then
		return;
	endif;

	if self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.updateSlotRequestAttribute(CM_SlotRequest.Attribute_ColourCode);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid displayMode (' &amp; self.displayMode.String &amp; ')');
	endif;
end;</source>
