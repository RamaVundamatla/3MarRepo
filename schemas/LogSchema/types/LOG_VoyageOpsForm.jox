    </JadeMethod>
    <JadeMethod name="volumeDisplayString" id="cc400e6c-6d37-47cd-a3c2-21960e913c33">
        <source>volumeDisplayString(_jasVolume : Real) : String;
//--------------------------------------------------
// Created:	12 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
begin
	if _jasVolume = null then
		return '0';
	endif;
	str := _jasVolume.jasVolumeString;
	if str = '0.000' then
		str := '0';
	endif;
	return str;
end;</source>
        <Parameter name="_jasVolume" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageFixupStock" id="3b910a5f-d232-45cb-8221-316dfc541191">
        <updating/>
        <source>voyageFixupStock(_voyageSet : CM_VoyageSet) updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;
	cmifMonitor : CMIF_Monitor;
	cancelSave 	: Boolean;
	comment		: String;
	hdrStr		: String;
	numVoyages	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	numVoyages := _voyageSet.size;
	if numVoyages = 0 then
		return;
	endif;
	
	hdrStr := 'You have changed the status of a voyage to complete.  ' &amp; CrLf &amp; 
			  'Do you want to check the summary stock figures now?';
	if app.msgBox(hdrStr, 'Check Voyage', MsgBox_Yes_No + MsgBox_Information_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	create cmifMonitor transient;
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Checking Stock for ';
   	self.modalDialogReturnValue := self.ModalDialogReturn_Null;   	
	self.modalDialogShow(null, 'Cancel', null, null, 'Fixing Stock', cmifMonitor.message);
	self.pbProgressBar.visible := true;

	comment := 'Automatic Data Fix on set to complete';

	foreach tmpVoyage in _voyageSet do
	
		hdrStr := 'Fixing Stock (' &amp; tmpVoyage.code &amp; '/' &amp; tmpVoyage.myTerminal.code &amp; ')';

		self.modalDialogShow(null, 'Cancel', null, null, hdrStr, cmifMonitor.message);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxFixupStockOnHandVoyage(tmpVoyage, comment, cmifMonitor, app.myPassport);	
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Stock Movements', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;

	endforeach;

	self.frmModalDialog.visible := false;
		
epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
end;</source>
        <Parameter name="_voyageSet" type="CM_VoyageSet"/>
    </JadeMethod>
    <JadeMethod name="voyageGlobalDeSelectPort" id="59166d5a-85c3-4fe9-b152-70fb308d19c7">
        <updating/>
        <source>voyageGlobalDeSelectPort() updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	statusCol : Integer;
	pxyVoyage : CM_Voyage;
	pxyGlobalVoyage	: CM_VoyageGlobal;
	lstTerminal, terminal	: CM_Terminal;
	row, int 	: Integer;
	dontAdd  	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.mode &lt;&gt; Mode_Add and
	   self.mode &lt;&gt; Mode_Update then
		return;
	endif;

	if self.lbxVoyTerminals.selectedCount &lt; 1 then
		return;
	endif;
	
	terminal := self.lbxVoyTerminals.listObject.CM_Terminal;

	if self.mode = Mode_Update and
	   self.myProxyObject &lt;&gt; null then
		pxyGlobalVoyage := self.myProxyObject.CM_VoyageGlobal;
		foreach pxyVoyage in pxyGlobalVoyage.allVoyages do
			if pxyVoyage.myTerminal = terminal then
				if pxyVoyage.status = Voyage_Status_Pending then
					// do this on the proxy to force the validation here
					
					//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
					while true do
					
						app.myTrxDA.trxDeleteVoyage(pxyVoyage, app.myPassport);
					
						if app.myPassport.trxCompletedOK then
							break;
						else
							theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
							if app.myPassport.noErrors and theResult = IDOK then
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
						endif;
						
						return;
						
					endwhile;
	
					break;
				else
					app.raiseCMException1(VoyDeleteStatusPending, self.myCurrentVoyageGlobal.code &amp; " of " &amp; terminal.name, null, null);
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	// remove from voyage table, for the update
	foreach row in 2 to self.tblVoyTermDtl.rows do
		if self.tblVoyTermDtl.accessCell(row, 1).itemObject.CM_Terminal = terminal then	
			self.tblVoyTermDtl.deleteRow(row);
			break;
		endif;
	endforeach;

	// remove from the Assigned list
	self.lbxVoyTerminals.removeItem(self.lbxVoyTerminals.listIndex);

// Par 9608 - when adding terminal from list box - should add in terminals CODE order. 
	if terminal &lt;&gt; null then 
		int := 1;
		row := self.lbxUnassTerminal.listCount + 1; // in case not set in loop - add at end
		
		while int &lt;= self.lbxUnassTerminal.listCount do
			lstTerminal := self.lbxUnassTerminal.itemObject[int].CM_Terminal;	
			if lstTerminal = terminal then // already in list so set boolean to not add
				dontAdd := true;			// only present for existing voyages that used old code. 
				break;
			endif;
			
			if lstTerminal.code &gt; terminal.code then 
				row := int; 
				break; // can break here as list is sorted by code order, so know where to insert and if it is already in list. 
			endif;	
			int := int + 1;
		endwhile;
		
		if not dontAdd then 
			self.lbxUnassTerminal.addItemAt(terminal.name, row);
			self.lbxUnassTerminal.itemObject[row] := terminal;
		endif;
	endif;
// Par 9608 end
epilog 
	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageGlobalDelete" id="af156850-dfb5-4b9c-8f46-6d98647946b6">
        <updating/>
        <source>voyageGlobalDelete()updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	result : Integer;
	msgStr : String;
begin
	if self.myCurrentVoyageGlobal = null then
		app.msgBox('Please select a Voyage from the tree list to Delete.','Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;			
	endif;
	
	app.mousePointer := MousePointer_HourGlass;			
	self.setMode(Mode_Delete);

	while true do
		app.myTrxDA.trxDeleteVoyageGlobal(self.myCurrentVoyageGlobal, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);//ErrWarnMode_Update + ErrWarnMode_Delete);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;

	endwhile;

	self.myCurrentVoyageGlobal := null;

epilog
	self.voyageGlobalRefresh(true);
	app.mousePointer := MousePointer_Default;						
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageGlobalEdit" id="c63bb405-3d75-4470-b745-d776efed9150">
        <updating/>
        <source>voyageGlobalEdit(_fromAdmin : Boolean) updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	voyCode	 		: String;
	imoCode			: String;
	pxyGlobalVoyage : CM_VoyageGlobal;
begin

	if  self.myCurrentVoyageGlobal = null then
		self.showCannotAccessSheetMsg(shtVoyageAdmin, 'You must select a Global Voyage from the table before you can edit.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtVoyageAdmin);		
	endif;
	app.mousePointer := MousePointer_HourGlass;
	self.setMode(Mode_Update);
	if _fromAdmin then
		self.setEnableObjectsVoyageAdmin();
	else
		self.setEnableObjectsVoyage();
	endif;
	self.setProxyObject(null);

	self.setProxyObject(self.myCurrentVoyageGlobal);

	pxyGlobalVoyage := self.myProxyObject.CM_VoyageGlobal;
	voyCode 		:= pxyGlobalVoyage.code;
	imoCode			:= pxyGlobalVoyage.vesselCode;
	
	self.tblVoyTermDtl.rows := self.tblVoyTermDtl.fixedRows;
	tblVoyTermDtl.userInputEnabled := true;
	
	tblVoyageAdmin.setValueByName(ETRow_IMO, imoCode);
	tblVoyageAdmin.setValueByName(ETRow_VoyageCode, voyCode);
	tblVoyageAdmin.setValueByName(ETRow_NumHatches, pxyGlobalVoyage.numHatches);	
	tblVoyageAdmin.setValueByName(ETRow_VesselName, pxyGlobalVoyage.vesselName);		
	
	self.showVoyageTerminalData(pxyGlobalVoyage.allVoyages);

	// CCMS 1124 edit from Voyage Admin tab vs from Voyage tab
	if _fromAdmin then
		self.tblVoyageAdmin.setFocus();
		self.tblVoyageAdmin.goToRowByName(ETRow_VoyageCode);
	else
		self.tblVoyTermDtl.setFocus();
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_fromAdmin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="voyageGlobalNew" id="fe0bf5e9-1088-422f-8b0a-11bdc1daca70">
        <updating/>
        <source>voyageGlobalNew()updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.tblVoyTermDtl.rows := self.tblVoyTermDtl.fixedRows;
	self.tblVoyage.clearValues();
	self.tblVoyageAdmin.clearValues();
	self.setMode(Mode_Add);
	self.setProxyObject(null);	
	self.setEnableObjectsVoyageAdmin();
	self.tblVoyageAdmin.setFocus();
	self.tblVoyageAdmin.goToRowByName(ETRow_VoyageCode);	
	self.listVoyTerminalsPopulate();
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageGlobalRefresh" id="edbc55e8-10e1-40ea-8946-548bf94a26bc">
        <updating/>
        <source>voyageGlobalRefresh(_fromAdmin : Boolean) updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	selectedObj : Object;
begin

	if self.mode = Mode_View or self.mode = Mode_Delete then
		self.tblVoyTermDtl.rows := self.tblVoyTermDtl.fixedRows;
		self.tblVoyage.clearValues();
		self.tblVoyageAdmin.clearValues();
	endif;

	self.setProxyObject(null);
	
	if self.mode &lt;&gt; Mode_Delete then
		if self.modeView = Mode_ArchiveView then
			self.archiveSearch();
		elseif self.mode = Mode_View or
		   self.mode = Mode_LimitedEdit then	// 28082
			if self.fldTreeView.topSheet = self.shtListSuppliers then
				selectedObj := self.lstSuppliers.listObject;
				self.listsSetSelected(self.lstSuppliers, selectedObj);							
			else
				selectedObj := self.lstPorts.listObject;
				self.listsSetSelected(self.lstPorts, selectedObj);			
			endif;
			self.showVoyageDetails();
		endif;
	endif;

	self.setMode(self.viewMode);	
	if _fromAdmin then
		self.setEnableObjectsVoyageAdmin();	
	else
		self.setEnableObjectsVoyage();
	endif;

end;</source>
        <Parameter name="_fromAdmin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="voyageGlobalSave" id="cc4a729c-f0d2-4f77-a280-87f50c1b637c">
        <updating/>
        <source>voyageGlobalSave()updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	hatch 			: Integer;
	voyageCount		: Integer;
	statusClosed	: Boolean;
	pxyVoyGlobal,
	realVoyGlobal	: CM_VoyageGlobal;
	pxyVoyage,
	realVoyage		: CM_Voyage;
	tmpVoyagesToCheck	: CM_VoyageSet;
	user			: CM_User;
	voyCode,
	vesselName,
	vesselCode 		: String;	
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	app.mousePointer := MousePointer_HourGlass;	

	self.tblVoyageAdmin.userScript := null;	

	if self.mode = Mode_Update then
		pxyVoyGlobal := self.myProxyObject.CM_VoyageGlobal;							
	elseif self.mode = Mode_Add then
		create pxyVoyGlobal transient;
		self.allProxies.add(pxyVoyGlobal);		
	endif;

	voyCode 	:= self.tblVoyageAdmin.getValueByName(ETRow_VoyageCode).String[1:20];
	vesselCode	:= self.tblVoyageAdmin.getValueByName(ETRow_IMO).String[1:7];
	vesselName 	:= self.tblVoyageAdmin.getValueByName(ETRow_VesselName).String[1:25];
	hatch 		:= self.tblVoyageAdmin.getValueByName(ETRow_NumHatches).Integer;
	
	pxyVoyGlobal.setProxy(voyCode, vesselName, vesselCode, null, null, null, null, hatch, null, app.myRoot);
	self.savePxyLogVoyages(pxyVoyGlobal);

	if self.mode = Mode_Update then
		create tmpVoyagesToCheck transient;
		// need to check if have changed status on any Log Voyages to "Complete" and
		// if so then run the stock fixup on them
		foreach pxyVoyage in pxyVoyGlobal.allVoyages do
			if pxyVoyage.status &lt;&gt; Voyage_Status_LoadComplete then
				// only interested in voyages that have been changed to Completed
				continue;
			endif;
			realVoyage := pxyVoyage.pxyGetRealObject();
			if realVoyage = null then
				continue;
			endif;
			if pxyVoyage.status = realVoyage.status then
				// no change in status
				continue;
			endif;
			tmpVoyagesToCheck.add(realVoyage);
		endforeach;
	endif;
	
	// 28082 set enabled/disabled status from voyage - do here so the form state is set for processing from notify from update
	statusClosed := true;
	user := app.getMyUser();
	voyageCount := 0;

	foreach pxyVoyage in pxyVoyGlobal.allVoyages do
		// 28275 get realVoyage and test for null before passing into includeVoyage
		realVoyage := pxyVoyage.pxyGetRealObject();
		if realVoyage = null then
			continue;
		endif;
	
		if (not self.includeVoyage(realVoyage, user)) then
			continue;
		endif;
		voyageCount := voyageCount + 1;
		if not pxyVoyage.isClosedStatus() then
			statusClosed := false;
		endif;
	endforeach;
	if voyageCount = 0 then
		statusClosed := false;
	endif;	
	if statusClosed then
		self.viewMode := Mode_LimitedEdit;
	else
		self.viewMode := Mode_View;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = Mode_Add then
			self.tblVoyageAdmin.userScript := voyCode;
			app.myTrxCA.trxCreateVoyageGlobal(pxyVoyGlobal, realVoyGlobal, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateVoyageGlobal(pxyVoyGlobal, app.myPassport);
		endif;	
		
		if app.myPassport.trxCompletedOK then
			if self.mode = Mode_Update then
				self.voyageFixupStock(tmpVoyagesToCheck);
			endif;
			break;
		else
			theResult :=app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.tblVoyageAdmin.userScript := null;
		return;
		
	endwhile;
	
	app.mousePointer := MousePointer_Default;

	//All proxies get deleted in here
	self.voyageGlobalRefresh(true);
epilog
	delete tmpVoyagesToCheck;

	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageGlobalSelectPort" id="7d98c372-9328-42ff-adf4-337e702869ff">
        <source>voyageGlobalSelectPort();
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row, backColour, statusCol, insertRow : Integer;
	found, insertRowSet : Boolean;
	berth, sideTo		: String;
	terminal : CM_Terminal;
	tblTerminal : CM_Terminal;
	harbour		: HMS_Harbour;
	wharf		: HMS_Wharf;
	hmsBerth	: HMS_Berth;

begin

	if self.mode &lt;&gt; Mode_Add and
	   self.mode &lt;&gt; Mode_Update then
		return;
	endif;

	if self.lbxUnassTerminal.selectedCount &lt; 1 then
		return;
	endif;
	
	tblVoyTermDtl.inputType := Table.InputType_TextBox;
	tblVoyTermDtl.userInputEnabled := true;
	statusCol := tblVoyTermDtl.getColumnByRowName(ETRow_Status);		
	terminal := lbxUnassTerminal.listObject.CM_Terminal;
		
	row := 2;
	insertRow := tblVoyTermDtl.rows + 1; // set up row to add to be at end in case not set in loop
	
	while row &lt;= tblVoyTermDtl.rows do
		tblTerminal := tblVoyTermDtl.accessCell(row, 1).itemObject.CM_Terminal;		
		if tblTerminal = terminal then
			found := true;
			break;
		endif;
		
		if insertRowSet = false and tblTerminal.code &gt; terminal.code then  	// Par 9608 - want terminals to be shown
			insertRow := row;												// in table by the order of their code. 
			insertRowSet := true;
		endif;		
		row := row + 1;
	endwhile;

	if found then
		return;
	endif;
	
	// CCMS 1124 default berth to first on wharf, default side-to from berth if any
	berth := null;
	sideTo := "Port";
	harbour := terminal.myHarbour;
	if harbour &lt;&gt; null then
		wharf := harbour.allWharves.first;
		if wharf &lt;&gt; null then
			hmsBerth := wharf.allBerths.first;
			if hmsBerth &lt;&gt; null then
				berth := hmsBerth.code;
				if hmsBerth.getStarboardBerthed() then
					sideTo := "Starboard";
				else
					sideTo := "Port";
				endif;
			endif;
		endif;
	endif;
	
//	Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, add sail date/time and load rate
// 33174 CCMS 1124 add berth, side to, arrival date and arrival time
	tblVoyTermDtl.addItemAt(terminal.name &amp; Tab &amp; berth &amp; Tab &amp; sideTo &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp;
								'' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp;
								'' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp;
								 app.voyageStatusEnumToString(Voyage_Status_Pending, true), insertRow);

	self.lbxUnassTerminal.removeItem(self.lbxUnassTerminal.listIndex);   // Par 9608 
	// 33174 add to Assigned list
	row := self.lbxVoyTerminals.addItem(terminal.name);
	self.lbxVoyTerminals.itemObject[row] := terminal;

	if (self.tblVoyTermDtl.rows mod 2) = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	tblVoyTermDtl.accessRow(insertRow).backColor := backColour;							 
	tblVoyTermDtl.accessCell(insertRow, statusCol).inputType := Table.InputType_ComboBox;							
	self.myAssistant.LOG_Assistant.comboBoxVoyageStatus(tblVoyTermDtl, statusCol, insertRow, Voyage_Status_Pending);
	tblVoyTermDtl.accessCell(insertRow, 1).itemObject := 	terminal;	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorDelete" id="59f4c20a-31c7-484c-a1b8-a191421c036e">
        <updating/>
        <source>voyageOperatorDelete()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyageOperator : CM_VoyageOperator;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if self.tblSupplierDtl.row &lt;= 1 then
		self.showCannotAccessSheetMsg(shtSuppliers, 'You must select a Supplier from the bottom table before you can delete supplier.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSuppliers);		
	endif;
	self.setMode(Mode_Delete);
	voyageOperator := self.tblSupplierDtl.accessRow(tblSupplierDtl.row).itemObject.CM_VoyageOperator;
	if voyageOperator = null then
		app.msgBox('Please select a supplier from the bottom table to delete.',
					'Select Supplier', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteVoyageOperator(voyageOperator, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Supplier Delete', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	self.myCurrentVoyageOperator := null;
	self.voyageOperatorRefresh();

epilog
	app.mousePointer := MousePointer_Default;					
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorEdit" id="c4776ea6-f100-486c-9087-17065fc45d44">
        <updating/>
        <source>voyageOperatorEdit()updating;
//--------------------------------------------------------------
//Created: 14 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 06/11/2009	cnwmh5		PAR18006 - Get Availble global voyage
//							terminals
//--------------------------------------------------------------
vars
	voyOper : CM_VoyageOperator;
begin

	if self.tblSupplierDtl.row &gt; 1 then
		voyOper := self.tblSupplierDtl.accessRow(tblSupplierDtl.row).itemObject.CM_VoyageOperator;
	endif;
	
	self.myCurrentVoyageOperator := voyOper;
	if self.myCurrentVoyageOperator = null then
		self.showCannotAccessSheetMsg(shtSuppliers, 'You must select a Supplier from the table before you can edit.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSuppliers);		
	endif;

	self.setMode(Mode_Update);
	self.setEnableObjectsSuppliers();

	self.setProxyObject(self.myCurrentVoyageOperator);
	self.voyageOperatorShow(self.myProxyObject.CM_VoyageOperator);
	
	// 06/11/2009 cnwmh5 PAR18006
	self.getAvailableGLBTerminals();
	
	self.tblSupplierEnt.moveFirst();
	self.tblSupplierEnt.setFocus();

end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorImportFile" id="6e25d850-f8d5-4268-8db6-dd3cbc3416fe">
        <source>voyageOperatorImportFile();
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	app.msgBox('This option is yet to be implemented', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorNew" id="648fd76f-5e21-437f-973c-c0cc718589d5">
        <updating/>
        <source>voyageOperatorNew()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 06/11/2009	cnwmh5		PAR18006 - Change so terminals uses
//							method to get them
//--------------------------------------------------------------
vars
	now : TimeStamp;	
	terminal : CM_Terminal;
	terminalName : String;
	obj				: Object;
	
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	if self.myCurrentVoyageGlobal = null then
		self.showCannotAccessSheetMsg(shtSuppliers,
				'You must select a Voyage or Terminal from the list before you can add supplier.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSuppliers);		
	endif;

	self.setMode(Mode_Add);
	self.setEnableObjectsSuppliers();
			
	self.tblSupplierEnt.clearValues();
   
	/*
	// 06/11/2009 cnwmh5 PAR18006 - replaced
	// Mohammad par#13527 17/4/2007
	obj := self.lstPorts.listObject;
	if obj.isKindOf(CM_Voyage) or obj.isKindOf(CM_VoyageOperator) then
		if self.myCurrentVoyage &lt;&gt; null then
			terminal := self.myCurrentVoyage.myTerminal;
			if terminal &lt;&gt; null then
				terminalName := terminal.name;
			endif;
		endif;
	endif;
	//self.myAssistant.LOG_Assistant.comboBoxTerminal(self.cmbPort, terminal, null);
	self.myAssistant.LOG_Assistant.comboBoxTerminalForGlbVoyage(self.cmbPort,self.myCurrentVoyageGlobal,self.permissionMaint, terminal); // Mohammad par#13524 20/4/2007
	*/
	//self.getAvailableGLBTerminals();		// 06/11/2009 cnwmh5 PAR18006
	terminalName := self.getAvailableGLBTerminals();			// 12/05/2010 cnwmh5 #24141
	self.tblSupplierEnt.setValueByName(ETRow_Port, terminalName);
	self.tblSupplierEnt.setValueByName(ETRow_LotPlanVersion, now.date.shortFormatJMT() &amp; ' ' &amp; now.time.userFormat($CM_ShortTime));
	self.setProxyObject(null);	
	self.tblSupplierEnt.setFocus();
	self.tblSupplierEnt.goToRowByName(ETRow_MyOperator);
	// Mohammad par#13527 17/4/2007
	if obj.isKindOf(CM_VoyageGlobal) then
		tblSupplierEnt.enableRowByName(ETRow_Port);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorRefresh" id="b978a5c5-52e9-4710-af81-741f07cc4d70">
        <updating/>
        <source>voyageOperatorRefresh()updating;
//--------------------------------------------------------------
//Created: 14 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	if self.mode = Mode_Add or self.mode = Mode_Delete then	
		self.tblSupplierEnt.clearValues();
		self.tblSupplierDtl.rows := self.tblSupplierDtl.fixedRows;
	endif;
	
	self.setProxyObject(null);	
	self.setMode(self.viewMode);
	self.setEnableObjectsSuppliers();
	if self.myCurrentVoyageGlobal &lt;&gt; null or self.myCurrentVoyage &lt;&gt; null then
		self.showSupplierDetails();
	endif;
	if self.myCurrentVoyageGlobal &lt;&gt; null then
		self.loadAllOrdersByVoyageGlobal(self.myCurrentVoyageGlobal);	
	endif;
	if self.myCurrentVoyage &lt;&gt; null then
		self.lstPorts.selectObject(self.myCurrentVoyage); // par13526 Mohammad 16/4/2007
	endif;
	
	self.btnSupNew.setFocus();
	tblSupplierEnt.disableRowByName(ETRow_Port); // Mohammad par13527 17/4/2007
	
	//par#14310 Mohammad Obaid 25/6/2007
	if self.fldTreeView.topSheet = self.shtListSuppliers then		
		self.listTreeViewChange(lstSuppliers);
	else
		self.listTreeViewChange(lstPorts);
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorSaveEdit" id="3c7e720d-55cc-424e-a5d7-636ce8972232">
        <updating/>
        <source>voyageOperatorSaveEdit()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//	05 Aug 2022		navrk21		Bug 54464: MTN - Log Voyage Supplier Stevedore Description causing String Too Long Exception
//--------------------------------------------------------------
vars
	operator 		: CM_Operator;
	voyage			: CM_Voyage;
	voyageGlobal 	: CM_VoyageGlobal;
	agentCode, lot, steve1Code, steve2Code	: String;
	pxyVoyageOperator, 
	realVoyageOperator : CM_VoyageOperator;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	app.mousePointer := MousePointer_HourGlass;					

	agentCode := tblSupplierEnt.getValueByName(ETRow_Agent).String;
	lot := self.localToSystemTime(tblSupplierEnt.getValueByName(ETRow_LotPlanVersion).TimeStamp).asStringJMT();	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	//Start 05.08.2022	navrk21	TFS 54464
	//steve1Code := tblSupplierEnt.getValueByName(ETRow_Stevedore1).String;
	if self.cmbStevedore1.myObject &lt;&gt; null then
		steve1Code := self.cmbStevedore1.myObject.CM_Stevedore.code;
	endif;
	//steve2Code := tblSupplierEnt.getValueByName(ETRow_Stevedore2).String;
	if self.cmbStevedore2.myObject &lt;&gt; null then
		steve2Code := self.cmbStevedore2.myObject.CM_Stevedore.code;
	endif;
	//End 05.08.2022 navrk21 TFS 54464
	if self.cmbSupplier.myObject &lt;&gt; null then
		operator := self.cmbSupplier.myObject.CM_Operator;
	endif;
	realVoyageOperator := self.myCurrentVoyageOperator;
	voyage := realVoyageOperator.myVoyage;
	voyageGlobal := realVoyageOperator.myVoyageGlobal;
	
	pxyVoyageOperator := self.myProxyObject.CM_VoyageOperator;	
	pxyVoyageOperator.setProxy(agentCode, lot, steve1Code, steve2Code, operator, voyage, voyageGlobal);

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageOperator(pxyVoyageOperator, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.voyageOperatorRefresh();
	
	self.tblSupplierDtl.selectObject(realVoyageOperator, true);
	self.voyageOperatorShow(realVoyageOperator);

epilog
	app.mousePointer := MousePointer_Default;				
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorSaveNew" id="dabf143a-7fab-4451-a4b4-a825e40a5e8d">
        <updating/>
        <source>voyageOperatorSaveNew()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
/* Changes

Date		Name	TFS#	Description
============================================================================
09/07/2019	jlgka1 	45365	JMT - Log Voyage Operations - Suppliers Tab - Lot Plan Version issue.
							Instead of using TimeStamp as a casting method use asTimeStampJMT.
05 Aug 2022	navrk21	Bug 54464: MTN - Log Voyage Supplier Stevedore Description causing String Too Long Exception
============================================================================*/
vars
	globVoy			: CM_VoyageGlobal;
	operator		: CM_Operator;
	terminal		: CM_Terminal;
	theVoyage, 
	voy				: CM_Voyage;	
	pxyVoyOperator,
	realVoyOperator,
	voyOper			: CM_VoyageOperator;
	agentCode, 
	lot,
	steve1Code,
	steve2Code		: String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if self.myCurrentVoyageGlobal = null then
		app.msgBox('Please select a Voyage or Terminal from the tree list.',
				'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;	
	
	// change cmbPort to have voyages as the objects but show terminal
	
	// sgp 14 May 2003: PAR #4794 - Use the entered terminal
	// instead of the terminal selected in the tree view.
	terminal := self.cmbPort.listObject.CM_Terminal;

	if terminal = null then
		app.msgBox('Please enter a Terminal/Port.',
				'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;
		
	globVoy := self.myCurrentVoyageGlobal;
	
	// need to be certain we get the correct object
	// Par 13440 Mohammad Using the wrong terminal.
	//theVoyage := globVoy.allVoyages.getAtKeyLeq(app.actualTimeServer,terminal);
	//theVoyage := globVoy.allVoyages.getAtKeyLeq(null,terminal);
	//theVoyage := globVoy.allVoyages.getAtKeyGeq(null,terminal);
	theVoyage := globVoy.getVoyageForArrivingDTTerminal(null, terminal);
	
//	theVoyage := globVoy.allVoyages.getAtKeyLeq(app.actualTimeServer, self.myTerminal).CM_Voyage;

	agentCode := self.tblSupplierEnt.getValueByName(ETRow_Agent).String;
	lot := self.localToSystemTime((tblSupplierEnt.getValueByName(ETRow_LotPlanVersion).asStringJMT()).asTimeStampJMT).asStringJMT();	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support //jlgka1 TFS 45365
	//Start 05.08.2022	navrk21	TFS 54464
	//steve1Code := self.tblSupplierEnt.getValueByName(ETRow_Stevedore1).String;
	if self.cmbStevedore1.myObject &lt;&gt; null then
		steve1Code := self.cmbStevedore1.myObject.CM_Stevedore.code;
	endif;
	//steve2Code := self.tblSupplierEnt.getValueByName(ETRow_Stevedore2).String;
	if self.cmbStevedore2.myObject &lt;&gt; null then
		steve2Code := self.cmbStevedore2.myObject.CM_Stevedore.code;
	endif;
	//End 05.08.2022 navrk21 TFS 54464
	if self.cmbSupplier.myObject &lt;&gt; null then
		operator := self.cmbSupplier.myObject.CM_Operator;		
	endif;
	
	create pxyVoyOperator transient;
	
	pxyVoyOperator.setProxy(agentCode, lot, steve1Code, steve2Code, operator, theVoyage, globVoy);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateVoyageOperator(pxyVoyOperator, realVoyOperator, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.voyageOperatorRefresh();
	
	self.myCurrentVoyageOperator := realVoyOperator;
	self.lstPorts.selectObject(realVoyOperator);
	self.tblSupplierDtl.selectObject(realVoyOperator, true);
	self.voyageOperatorShow(realVoyOperator);
	self.loadAllOrdersByVoyageOperator(realVoyOperator);

epilog
	delete pxyVoyOperator;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorSelect" id="a5871104-fac2-45c6-80c6-8c3066bb433f">
        <updating/>
        <source>voyageOperatorSelect()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	changed			: Boolean;
	newViewMode		: Integer;
	voyageOperator 	: CM_VoyageOperator;
	voyage			: CM_Voyage;
begin

	if self.tblSupplierDtl.row &lt;= 1 then
	
		return;
	endif;

	voyageOperator := self.tblSupplierDtl.accessRow(self.tblSupplierDtl.row).itemObject.CM_VoyageOperator;
	self.myCurrentVoyageOperator := voyageOperator;
	
	if self.myCurrentVoyageOperator = null then
		self.showCannotAccessSheetMsg(shtSuppliers, 'You must select a Supplier from the table before you can edit.');
		return;
	else
		// 28082 Sep 2011
		voyage   := self.myCurrentVoyageOperator.myVoyage;
		newViewMode := Mode_View;
		if voyage &lt;&gt; null then
			if voyage.isClosedStatus() then
				newViewMode := Mode_LimitedEdit;
			endif;
		endif;
		if self.modeView &lt;&gt; Mode_ArchiveView then
			if self.viewMode &lt;&gt; newViewMode then
				changed := true;
			endif;
			self.viewMode := newViewMode;
			self.modeView := self.viewMode;
			if changed then
				self.setEnableObjects();
			endif;
		endif;
		self.hideCannotAccessSheetMsg(shtSuppliers);		
	endif;
	
	self.lstPorts.selectObject(voyageOperator);
	self.voyageOperatorShow(voyageOperator);
	self.loadAllOrdersByVoyageOperator(voyageOperator);

end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorShow" id="86af71c6-7345-4ffd-9384-7f0c13efa7ad">
        <updating/>
        <source>voyageOperatorShow(_voyageOperator : CM_VoyageOperator) updating, protected;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
09/07/2019	jlgka1 	45365	JMT - Log Voyage Operations - Suppliers Tab - Lot Plan Version issue.
							Instead of using TimeStamp as a casting method use asTimeStampJMT.
============================================================================*/
vars
	agent			: CM_ShippingAgent;
	root			: CM_Root;
	steve1, steve2 	: CM_Stevedore;
	
begin
	self.tblSupplierEnt.clearValues();

	if _voyageOperator = null then
		return;
	endif;

	root := app.myRoot;
	agent := root.allShippingAgentsByCode[_voyageOperator.agentCode];
	steve1	:= root.allStevedores[_voyageOperator.stevedoreCode1];
	steve2	:= root.allStevedores[_voyageOperator.stevedoreCode2];	
	
	tblSupplierEnt.clearValues();
//	self.myAssistant.comboBoxSupplier(self.cmbSupplier, _voyageOperator.myOperator);
	self.cmbSupplier.setObject(_voyageOperator.myOperator);
	cmbSupplier.lostFocus(cmbSupplier);
	self.myAssistant.comboBoxTerminal(self.cmbPort, _voyageOperator.myVoyage.myTerminal, null);
	cmbPort.lostFocus(cmbPort);	
	
//	self.myAssistant.comboBoxShippingAgent(self.cmbAgent, agent);
	self.cmbAgent.setObject(agent);
	self.cmbAgent.lostFocus(cmbAgent);	
//	self.myAssistant.comboBoxStevedore(self.cmbStevedore1, steve1);	
	self.cmbStevedore1.setObject(steve1);	
	self.cmbStevedore1.lostFocus(cmbStevedore1);	
//	self.myAssistant.comboBoxStevedore(self.cmbStevedore2, steve2);
	self.cmbStevedore2.setObject(steve2);
	cmbStevedore2.lostFocus(cmbStevedore2);		
	tblSupplierEnt.setValueByName(ETRow_LotPlanVersion, self.systemToLocalTime(_voyageOperator.lotPlanVersion.asTimeStampJMT).asStringJMT());	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support // jlgka1 TFS 45365
end;</source>
        <access>protected</access>
        <Parameter name="_voyageOperator" type="CM_VoyageOperator"/>
    </JadeMethod>
</GUIClass>
