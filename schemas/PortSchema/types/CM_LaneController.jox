    <JadeMethod name="updateLaneDevices" id="6fd49044-139c-4358-8482-78d986b7f8be">
        <source>updateLaneDevices(_proxy :CM_LaneController)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld, pxyLD	:CM_LaneDevice;
	coll		:ObjectSet;
begin
	create coll transient;
	// copy existing lane devices to temporary collection
	self.allLaneDevices.copy (coll);
	
	foreach pxyLD in _proxy.allLaneDevices do
		ld := pxyLD.pxyGetRealObject;
		
		if ld = null then
			create ld as pxyLD.class persistent;
			
			ld.setForCreate (pxyLD, self);
		else			
			ld.setForUpdate (pxyLD);
			// remove real object from collection as we are keeping it
			coll.remove (ld);
		endif;
	endforeach;
	// anything left in collection can be deleted
	coll.purge;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="updateLaneDirection" id="fc7d2f93-9c40-4eff-8e6f-784c0f810bb7">
        <updating/>
        <source>updateLaneDirection(_proxy :SelfType):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	different : Boolean;
begin
	self.raiseExceptionIfTransient (method);
	
	different := self.isDirectionDifferent(_proxy);
	
	if different then
		// Something to do
		if not self.hasVehicles then
			self.vehicleDirection := _proxy.laneDirection;
		endif;
		
		self.laneDirection := _proxy.laneDirection;
		self.isUnavailable := _proxy.isUnavailable;
	endif;
	
	return different;
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5ac874b6-2c3a-4ce1-bd7a-d2dbb7a00427">
        <source>validate(_passport: CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	:CM_LaneDevice;
begin
	inheritMethod(_passport);
	
	foreach ld in self.allLaneDevices do
		if ld.pxyGetRealObject = null then
			ld.validateCreate (_passport);
		else
			ld.validateUpdate (_passport);
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
