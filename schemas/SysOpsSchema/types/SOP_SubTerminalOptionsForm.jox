    <JadeMethod name="chkAreasDefined_click" id="0c11663c-b89c-4441-8799-b15dfa42d3f6">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAreasDefined_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars

begin
	if self.chkDeliveryReq.value = true  and self.chkAreasDefined.value = false then
		self.lblDeliveryReq.visible :=  true;
		self.cmbDeliveryReq.visible := true;
	else
		self.lblDeliveryReq.visible :=  false;
		self.cmbDeliveryReq.visible := false;
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkDeliveryReq_click" id="86353876-ac79-480a-88cf-f28f1e52ac73">
