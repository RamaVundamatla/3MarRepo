    <JadeMethod name="addToStockMovement" id="a7f581f0-e01d-43df-8035-8b445432c74f">
        <updating/>
        <source>addToStockMovement(_stkMove: CM_StockMovement) updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _stkMove = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to null stockmove reference for ' &amp; self.String);
		return;
	endif;

	if _stkMove.isInwards then
		self.myStockMovementIn 	:= _stkMove;
	else
		self.myStockMovementOut := _stkMove;
	endif;

end;</source>
        <Parameter name="_stkMove" type="CM_StockMovement"/>
    </JadeMethod>
    <JadeMethod name="canEditAmount" id="6a9a2fd0-6e9d-405a-9a45-c132d783ad57">
        <source>canEditAmount(): Boolean;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	subType : CM_Product;
begin
	
	self.getCargoTypeAndSubType(ct,subType);
	
	if ct = null or not ct.allowDuplicates then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
