        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="298ec921-ce1a-4f03-b01e-daae753ffcd4">
        <source>includeObject(_voyageStatistic : CM_VoyageStatistic) : Boolean protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _voyageStatistic = null then
		return false;
	endif;
	if _voyageStatistic.isGroupTotal() then
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageStatistic" type="CM_VoyageStatistic"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="48585e1b-5ff8-417b-9cf4-226c514ef34c">
        <source>initComboBoxes() protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	idx,
	prevYear,
	tmpYear : Integer;
begin
	
	self.cmbMonth.sorted := false;
	self.cmbMonth.addItem('January');
	self.cmbMonth.addItem('February');
	self.cmbMonth.addItem('March');
	self.cmbMonth.addItem('April');
	self.cmbMonth.addItem('May');
	self.cmbMonth.addItem('June');
	self.cmbMonth.addItem('July');
	self.cmbMonth.addItem('August');
	self.cmbMonth.addItem('September');
	self.cmbMonth.addItem('October');
	self.cmbMonth.addItem('November');
	self.cmbMonth.addItem('December');

	self.cmbYear.sorted := false;
	tmpYear := app.actualTimeServer.date.year;
	prevYear := tmpYear-10;

	while tmpYear &gt;= prevYear do
		self.cmbYear.addItem(tmpYear.String);
		tmpYear := tmpYear-1;
		cnt := cnt + 1;		
		if cnt &gt; 20 then
			break;
		endif;
	endwhile;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initControlsForView" id="5fbbcc0a-8d92-403d-80fc-22ddbdcc1789">
        <updating/>
        <source>initControlsForView() updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	self.lstHarbours.clearTable();	
	self.lstTerminals.clearTable();		
					
	self.lstHarbours.displayCollection(app.myRoot.allHarbours, true, 0, self.myTerminal.myHarbour);
	
	if (not app.myRoot.isMultiHarbour()) then
		self.lstHarbours.visible := false;
		self.lblHarbours.visible := false;
		self.btnAllHarbour.visible := false;
		self.doSelectAll(self.lstHarbours);
		self.lstTerminals.width := self.lstTerminals.width + self.lstHarbours.width+5;		
		self.lstTerminals.left := self.lstHarbours.left;
		self.lblTerminals.left := self.lstTerminals.left;						
	else
		self.lstHarbours.visible := true;
	endif;				
	
	if (not app.myRoot.isMultiTerminal()) then
		self.lstTerminals.visible := false;
		self.lblTerminals.visible := false;
		self.doSelectAll(self.lstTerminals);
		self.btnAllTerminals.visible := false;		
		self.lstHarbours.width := self.lstHarbours.width + self.lstTerminals.width+5;
	else
		self.lstTerminals.visible := true;
	endif;
	
	if (not self.lstTerminals.visible)
	and (not self.lstHarbours.visible) then
		self.grpHarbours.visible := false;
		self.frmSearch.height := self.btnThisMonth.top + self.btnThisMonth.height+20;				
	endif;

	self.setFilterDefaults(true);
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblData" id="49fc0e67-aa0d-4bc1-bbd4-cfee15045c47">
        <source>initTblData() protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.tblData.disallowColumnSorter := true;
	
	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VoyageAnalysis));
	
	self.tblData.sortColumn[1] := null;
	self.tblData.setMyDataClass(HMS_Berth);
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	self.tblData.readOnly := true;
	self.setTblDataColumnAlignment();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="3707265f-f050-42ad-85a8-24f4f26aafa1">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
