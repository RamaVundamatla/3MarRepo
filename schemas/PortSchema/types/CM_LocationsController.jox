    <JadeMethod name="isPartOfTerminalArea" id="0f9c775b-f168-40cd-be5f-0b711b274937">
        <condition/>
        <source>isPartOfTerminalArea():Boolean condition;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
/*	CM_TerminalArea::allLocationsControllers inverse of CM_LocationsController::myTerminalArea

	The above releationsip is parent/child and it does not make sense that
	CM_VehicleController instances should be in the allLocationsController collection
	There may be other examples which should be excluded from this relationship
	
*/	if self.isKindOf (CM_VehicleController) or
		self.isKindOf (CM_RackShelfController) or
		self.isKindOf (CM_TILCController) then	// CM_TILCBlock or CMTILCRow
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimaryForMode" id="24ca3433-55d5-45fc-a175-2dd1045e9e97">
        <source>isPrimaryForMode(_moveMode : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Written for the JMT SilverLight Data Service Web Service
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
	tis: CM_TIArray;
begin
	if _moveMode = REAL_MODE then
		if self.allTrackedItems.isEmpty() then
			return true;
		endif;
		tmpTI := self.allTrackedItems.first();
		
		return (tmpTI.myPrimaryActualLocation = self);
	elseif _moveMode = QUEUE_MODE then
		create tis transient;
		self.getAllQueuedTrackedItems(tis, true);
		if tis.isEmpty() then
			return true;
		endif;
		tmpTI := tis.first();
		
		return (tmpTI.myPrimaryQueuedLocation = self);
	elseif _moveMode = PLANNING_MODE then
		create tis transient;
		self.getAllPlannedTrackedItems(tis, true, false);
		if tis.isEmpty() then
			return true;
		endif;
		tmpTI := tis.first();
		
		return (tmpTI.myPrimaryPlannedLocation = self);
	endif;
	
	return false;
epilog
	delete tis;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimaryLocationForFM" id="550e78aa-c434-4f98-95b8-09943193d1d0">
        <source>isPrimaryLocationForFM(_mode : Integer; _index : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	qfm : CM_FutureMoveQueued;
	pfm : CM_FutureMovePlanned;
begin
	if _mode = QUEUE_MODE then
		if self.allQueuedFutureMoves.isEmpty() then 
			return false;
		endif;
		
		if _index = 0 or _index &gt; self.allQueuedFutureMoves.size then
			qfm := self.allQueuedFutureMoves.first.CM_FutureMoveQueued;
		else
			qfm := self.allQueuedFutureMoves[_index].CM_FutureMoveQueued;
		
		endif;
		
		if qfm &lt;&gt; null then
			if qfm.allLocationsControllers.isEmpty() then
				return false;
			endif;
			return (qfm.allLocationsControllers.first = self);
		endif;
		
		return false;
		
	elseif _mode = PLANNING_MODE then
		if self.allPlannedFutureMoves.isEmpty() then 
			return false;
		endif;
		
		if _index = 0 or _index &gt; self.allQueuedFutureMoves.size then
			pfm := self.allPlannedFutureMoves.first.CM_FutureMovePlanned;
		else
			pfm := self.allPlannedFutureMoves[_index].CM_FutureMovePlanned;
		
		endif;
		
		if pfm &lt;&gt; null then
			if pfm.allLocationsControllers.isEmpty() then
				return false;
			endif;
			return (pfm.allLocationsControllers.first = self);
		endif;
		
		return false;
	endif;

	return false;
	
	
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
