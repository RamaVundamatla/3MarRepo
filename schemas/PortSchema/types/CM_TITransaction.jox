        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="typeCountForTI" id="ca9ad6d9-179b-42b0-af2b-0b63fa6154f0">
        <source>typeCountForTI(): Integer;
//----------------------------------------------------------------
//	Created:	25 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//returns the number of transactions of this type the TI has
//if self is a WASH and there is another wash for this TI then return 2
// no TI, return 0

vars
	tiTrans		: CM_TITransaction;
	num			: Integer;
begin

	if self.myTrackedItem = null then
		return 0;
	endif;
	
	num := 1;

	foreach tiTrans in self.myTrackedItem.allTransactions do
		if tiTrans &lt;&gt; self and tiTrans.type = self.type then
			num := num + 1;
		endif;
	endforeach; 

	return num;	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="fa054328-9ad8-4a47-a302-0b7bca023713">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
//--------------------------------------------------------------
//Created: 03 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	trxType	: CM_TransactionType;
begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	trxType := app.myRoot.allTransactionTypes[self.type];
	
	if trxType &lt;&gt; null then
		_value := trxType.description;
	else
		// If you are getting this you probably haven't set up the 
		// Constant "TransType_nnn"  where nnn = the type value.
		_value := 'Unknown Type';
	endif;
	
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unDelete" id="0935fc33-2f7a-4cac-8dfa-a26b0a7d35cd">
        <updating/>
        <source>unDelete() updating;
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18 Dec 2012	cnwcs5 CCMS SFW 1294 /par 30855
vars

begin 
	if self.deleted then
		if self.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then		// par 30855
			self.createCAMSAuditTransaction (AuditUpdated, self, app.myPassport);	// par 30855
		endif;																// par 30855
	endif;

	self.deleted := false;
	self.deletedByUser := null;		// 15/10/18 MAP TFS41191
	self.deletedReason := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateDateTime" id="80d318d3-9bfc-4751-a3b3-ab859d5d8cdd">
        <updating/>
        <source>updateDateTime(_dateTime : TimeStamp) updating;
// -------------------------------------------
// Created 31 January 2006 by cnwdvb1
// -------------------------------------------
// 07 Aug 2020	NDL	TFS 49852
vars

	ti : CM_TrackedItem;
	ordNo : Integer;

begin

	if self.dateTime = _dateTime then
		return;
	endif;

	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		if ti.allTransactions.includesKey( _dateTime, ordNo ) then
			// there is already at least one ttTrx with the same proposed date time.  So we need to use a non-zero orderNo key 
			ordNo := 1;
			while ti.allTransactions.includesKey( _dateTime, ordNo) do
				// need to increment orderNo until we don't find a pre-existing trx with the same keys
				ordNo := ordNo + 1;
			endwhile;
		endif;
		if ordNo &lt;&gt; self.orderNo then
			//we are going to need to set the keys.  Make sure changing this doesn't cause a clash with
			// another one at its current date/time before we get to change the date time. 
			if self.dateTime.Date.isValid then
				self.dateTime.setDate("31 Dec 2099".Date);
			endif;
			self.orderNo := ordNo;
		endif;
	endif;

	self.dateTime := _dateTime;

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateDateTimeFromEDI" id="9b376dcf-c23f-42bf-90fb-53f7119a5e29">
        <source>updateDateTimeFromEDI(_dateTime : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2021 navma1	ChangeRequest 52330: SAL - EDI operations - Cargo On Site

*/

vars
	txnController 					: CMIF_TITransactionController;
	tranType						: Integer;
	previousTrans,					
	trans 							: CM_TITransaction;
begin
	trans		:= self;
	tranType	:= self.type;
	
	global.createTxnControllerForType(tranType, txnController);
	
	txnController.dateTime				:= self.localToSystemTime(_dateTime);
	txnController.userGenerated 		:= true;
	txnController.hasBeenUpdated		:= true;
	txnController.myTerminal			:= trans.myTerminal;
	
	txnController.userId				:= trans.userId;
	txnController.myTrackedItem			:= trans.myTrackedItem;
	txnController.noCharge				:= trans.noCharge;
	txnController.urNumber				:= trans.urNumber;


	app.myUtilityUA.utlUpdateTITransaction(txnController, trans, app.myPassport);
	
	if not app.myPassport.hasErrors then
		if trans.previousVersions &lt;&gt; null and trans.previousVersions.size  &gt; 0 then
			previousTrans:= trans.previousVersions[1];
			if previousTrans &lt;&gt; null then
				previousTrans.setExtraData(TrnsExtraDataAuditInfo,"User Edited transaction" );
			endif;
		endif;
	endif;

	
epilog
	delete txnController;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updatePropertiesFromEDI" id="33852b73-c85e-4ac6-a122-dd4fd926bbf7">
        <updating/>
        <source>updatePropertiesFromEDI(_ediTI : CM_EDITransactionTI) updating;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//07 Dec 2022	jlika1		TFS 55586 HS Code User Defined EDI
// 11/01/2023	navkc1		TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
vars
	imexStatus : CM_IMEXStatus;
	ti : CM_TrackedItem;
	toDoTask : CM_ToDoTask;
	
begin
	if _ediTI.commodity &lt;&gt; null then
		self.commodity := _ediTI.commodity;
	endif;
	if _ediTI.companyCode &lt;&gt; null then
		self.companyCode := _ediTI.companyCode;
	endif;
	if _ediTI.consignee &lt;&gt; null then
		self.consignee := _ediTI.consignee;
	endif;
	if _ediTI.consignor &lt;&gt; null then
		self.consignor := _ediTI.consignor;
	endif;
	if _ediTI.contentsStatus &lt;&gt; null then
		self.contentsStatus := _ediTI.contentsStatus;
	endif;
	if _ediTI.customsAgent &lt;&gt; null then
		self.customsAgentCode := _ediTI.customsAgent;
	endif;
	if _ediTI.destination &lt;&gt; null then
		self.destinationPort := _ediTI.destination;
	endif;
	if _ediTI.dischargePort &lt;&gt; null then
		self.dischargePort := _ediTI.dischargePort;
	endif;
	if _ediTI.imexStatus &lt;&gt; null then
		imexStatus := _ediTI.getImExStatusObj();
		if imexStatus &lt;&gt; null then
			self.imExStatus := imexStatus.code;
		endif;
	endif;
	if _ediTI.operatorCode &lt;&gt; null then
		self.operatorCode := _ediTI.operatorCode;
	endif;
	if self.hasOtherTrackedItem then
		ti := _ediTI.getOtherTrackedItem();
		if ti &lt;&gt; null then
			self.setOtherTrackedItem(ti);
		endif;
	endif;
	if _ediTI.quantity &lt;&gt; null then
		self.totalQuantity := _ediTI.quantity;
	endif;
	if self.isCM_Move() then
		if _ediTI.sourceLocn &lt;&gt; null then
			self.CM_Move.sourceLocn := _ediTI.sourceLocn;
		endif;
		if _ediTI.sourceLocn &lt;&gt; null then
			self.CM_Move.targetLocn := _ediTI.targetLocn;
		endif;
	endif;
	if _ediTI.taskDescr &lt;&gt; null then
		if self.isKindOf(CM_TaskAdd) then
			self.CM_TaskAdd.setPropertyValue(CM_TaskAdd::todoTaskDesc.name, _ediTI.taskDescr);
		endif;
	endif;
	if _ediTI.volume &lt;&gt; null then
		self.totalVolume := _ediTI.volume;
	endif;
	if _ediTI.length &lt;&gt; null then // PAR 31615
		self.totalLength := _ediTI.length;
	endif;
	if _ediTI.voyageCode &lt;&gt; null then
		self.voyageCode := _ediTI.voyageCode;
	endif;
	if _ediTI.weight &lt;&gt; null then
		self.totalWeight := _ediTI.weight;
	endif;
	//jlier1 TFS 54846 30/9/22
	if _ediTI.countryOfOriginCode &lt;&gt; null then
		self.myCountryOfOrigin:=_ediTI.getCountryOfOrigin();
	endif;
	//jlika1 TFS 55586
	if _ediTI.hsCode &lt;&gt; null then
		self.hsCode :=_ediTI.hsCode;
	endif;
	// 11/01/2023	navkc1	TFS CR 55625 TASK 55660
	if _ediTI.contractIdForTIstring &lt;&gt; null then
		self.contractId := _ediTI.contractIdForTIstring;
	endif;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDITransactionTI"/>
    </JadeMethod>
