    <JadeMethod name="getDisplayStringForAttribute" id="ed57869c-a10b-43a7-aa4d-18ee6f848a7f">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;

/*
Date			Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498
*/

vars
	returnStr	: String;
	
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			returnStr	:= app.getErrorString( TransType_95 ) &amp; ColonAndSpace &amp; self.stopDescription;
			if self.isEventRequestStop then
				returnStr	:=	returnStr &amp;
								app.getString( Stop_Request_Entered ) &amp;
								self.eventRequestEnteredDT.shortCurrentLocaleFormat;
			else
				// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
				if self.custDocType &lt;&gt; null then
					returnStr := returnStr &amp; " (" &amp; self.custDocType &amp; ") ";
				endif;
				returnStr	:=	returnStr &amp; self.getCEDOVoyageChangeInfo();
			endif;
			returnStr	:= returnStr &amp; Period &amp; Space &amp; self.remarks;
			return returnStr;
		endif;

	elseif _attrName = ETRow_StopSet then
		returnStr	:= self.stopDescription;
		if self.isEventRequestStop then
			returnStr	:=	returnStr &amp; " " &amp; self.eventRequestEnteredDT.shortCurrentLocaleFormat;
		else
			// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
			if self.custDocType &lt;&gt; null then
				returnStr := returnStr &amp; " (" &amp; self.custDocType &amp; ") ";
			endif;
			returnStr	:=	returnStr &amp; self.getCEDOVoyageChangeInfo();
		endif;
		if self.remarks &lt;&gt; null then
			returnStr	:= returnStr &amp; Period &amp; Space &amp; self.remarks;
		endif;
		return returnStr;

	else
		return inheritMethod( _attrName, _short );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="93b6a35f-9fc2-4df6-8087-23d0e7a9b228">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rowString	: String;
	
begin
	if self.isEventRequestStop then
		return inheritMethod() &amp; app.getErrorString(TransType_95) &amp; ": " &amp; self.stopDescription &amp; ". Stop request entered " &amp; self.eventRequestEnteredDT.asStringJMT &amp; ' ' &amp; self.remarks;	
	else
		// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		if self.custDocType &lt;&gt; null then
			rowString := "(" &amp; self.custDocType &amp; ") ";
		endif;
		
		rowString := rowString &amp; self.getCEDOVoyageChangeInfo.trimBlanks();
		
		if rowString &lt;&gt; null then
			rowString	:=	rowString &amp; ".";
		endif;
		
		if self.remarks &lt;&gt; null then
			rowString	:=	rowString &amp; " " &amp; self.remarks;
		endif;
		
		return inheritMethod() &amp; app.getErrorString(TransType_95) &amp; ": " &amp; self.stopDescription &amp; ". " &amp; rowString;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="56a5dd81-3cb0-4ee8-978e-fcdefdb30a96">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= 	inheritMethod() &amp; Tab &amp;
					self.stopID.display &amp; Tab &amp;
					self.stopDescription;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTrackedItem.id;
	endif;
	
	if self.myStop = null then
		returnStr	:= returnStr &amp; Tab &amp; '************';
	else
		returnStr	:= returnStr &amp; Tab &amp; self.myStop.id.display;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopDescription" id="6131044b-743a-4fb2-9260-4e8b5775bfd5">
        <source>getStopDescription() : String;

/*
Purpose:	Reimplemented method for JRW.

Date				Who		Reason
03 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	return self.stopDescription;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasBeenCancelled" id="0d599d40-58ca-48bf-9854-aa24566c8195">
        <source>hasBeenCancelled():Boolean;
// ---------------------------------------------------------------------------
// Created:     22 June 2010 by cnwcs5
// Purpose:     determines whether the stop has been subsequently cancelled
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/07/2010	cnwcs5		Changed property to compare from myStop to stopID while investigating CCMS MES 1097 (PAR 23697)
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	ti		:CM_TrackedItem;
	coll	:Collection;
	txn		:CM_TITransaction;
begin
	ti 		:= self.myTrackedItem;
	coll	:= ti.allTransactions;
	iter	:= coll.createIterator;
	
	iter.startAtObject (self);
	// we read through the transactions which happened after the receiver
	// if we find a cancel for the same stop then we know the stop was cancelled
	// if we find a clear the same stop it was not cancelled but cleared
	while iter.next (txn) do
		if txn = self then
			continue;
		endif;
			
		if txn.type = TRANS_TYPE_STOPCANCEL and
			txn.CM_StopCancel.stopID = self.stopID then		// 19/07/2010 cnwcs5 - was comparing myStop which will always be null
			return true;
		endif;	
		
		if txn.type = TRANS_TYPE_STOPCLEAR then
			if self.myStop &lt;&gt; null and										// 19/07/2010 cnwcs5
				txn.CM_StopCleared.myStop = self.myStop then				// 19/07/2010 cnwcs5
				// I have been cleared no cancelled. No need to carry on
				break;														// 19/07/2010 cnwcs5
			endif;															// 19/07/2010 cnwcs5
			if txn.CM_StopCleared.stopID = self.stopID then					// 19/07/2010 cnwcs5 - was comparing myStop which will always be null
				// I have been cleared not cancelled.  No need to carry on
				break;
			endif;
		endif;
	endwhile;
	
	return false;
	
epilog
	delete iter;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCustDocRelavant" id="317ad254-f877-4d9d-82b8-bdcf73ec7f53">
        <source>isCustDocRelavant(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

