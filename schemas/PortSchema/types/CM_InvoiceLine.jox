    <JadeMethod name="zzGetShipOperatorDesc" id="b59c36a7-e531-438e-bf48-15484420f779">
        <source>zzGetShipOperatorDesc() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	invalidObject	: Boolean;
	
begin
	voyage := self.getMyVoyageObject();
	
	if voyage = null then
		return null;
		
	endif;
	
	on Exception do app.handleDeletedObject(exception, voyage, invalidObject);
	voyage.edition;
	on Exception do null;
	
	if invalidObject then
		return null;
		
	endif;
	
	operator := voyage.myOperator;
	if operator &lt;&gt; null then
		return operator.description;
		
	endif;
	
	return null;
	
end;</source>
