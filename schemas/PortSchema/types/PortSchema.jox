    <JadeMethod name="handleIt" id="db5b33eb-4f3f-46a4-b46a-7019a5f96740">
        <source>handleIt();

/*

Purpose:			Make any necessary ini file changes for the current JMT release

Parameters:			None

Return Value:		None


Date		Who		Reason
05 Sep 2012	cnwkpd1	PAR #30305 - Added [JMTerminal] IniFileUpdatedVersion and changed settings to 
					work correctly with the new JMT graphics
06 Nov 2012	cnwkpd1	PAR #30690 - add in display of status messages on splash screen

*/

constants
	ValueNone		= "&lt;none&gt;";
	ValueDefault	= "&lt;default&gt;";
	ValueNo			= "No";
	//SectionJMT	= "JMTThinClient";	// Moved to GlobalConstants so it can be used for other things
	KeyIniUpdate	= "IniFileUpdatedVersion";
	PatchNumber		= "001";		// Update this value for a patch to force ini updates

vars
	fileName		: String;
	iniValue		: String;
	root			: CM_Root;
	matchVersion	: String;
	
begin
	// PAR #30305 - The first time a user connects to a new JMT version, update the thin client ini 
	// file with all the required default settings
	if not process.isUsingThinClient then
		return;
	endif;
	
	fileName := app.getIniFileName();
	if fileName = null then
		return;
	endif;
	
	// Might be called before initialization
	root := app.myRoot;
	if root = null then
		root := CM_Root.firstInstance();
	endif;
	if root = null then
		return;
	endif;
	
	// PAR #30690 - add in a mechanism to force updates outside major version upgrades
	matchVersion := root.getVersionString();
	if PatchNumber &lt;&gt; null then
		matchVersion := matchVersion &amp; "_" &amp; PatchNumber;
	endif;
	
	// Only do the updating once per release
	iniValue := app.getProfileString(fileName, JMTThinClientSection, KeyIniUpdate, null);
	if iniValue = matchVersion then
		return;
	endif;
	
	app.setProfileString(fileName, 'Jade', 'ShowSplashScreen', true.String);
	app.setProfileString(fileName, 'Jade', 'SplashScreenFile', 'splash_terminal.png');
	
	app.setProfileString(fileName, 'Jade', 'ApplicationFontColors', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'ApplicationPos', ValueNo);
	
	app.setProfileString(fileName, 'Jade', 'AviFile', ValueNone);
	app.setProfileString(fileName, 'Jade', 'AviPos', ValueDefault);
	
	app.setProfileString(fileName, 'Jade', 'PathFontColors', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'PathPos', ValueNo);
	
	app.setProfileString(fileName, 'Jade', 'SchemaFontColors', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'SchemaPos', ValueNo);
	
	app.setProfileString(fileName, 'Jade', 'ServerFontColors', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'ServerPos', ValueNo);
	
	app.setProfileString(fileName, 'Jade', 'StatusFontColor', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'StatusPos', '40,220');		// PAR #30690
	
	app.setProfileString(fileName, 'Jade', 'VersionFontColors', ValueDefault);
	app.setProfileString(fileName, 'Jade', 'VersionPos', ValueNo);

	// And finally set the updated version so we don't try this again until the next release
	app.setProfileString(fileName, JMTThinClientSection, KeyIniUpdate, matchVersion);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleJSONParsingException" id="4f9fc8d9-6775-4c24-9915-3fad11c31fad">
        <source>handleJSONParsingException(_exc : Exception; _hadException : Boolean output) :  Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
18 January 2024			navmd1	Initial creation TFS 55021 TFS 55021 EA Mail Tidyup and Refactor. Moved up from CM_Agent

*/
constants
	JSONErrorRangeStart	: Integer = 11100;
	JSONErrorRangeEnd	: Integer = 11199;

vars
	returnVal		: Integer;
	
begin
	// Not an exception we care about
	if _exc.errorCode &lt; JSONErrorRangeStart or _exc.errorCode &gt; JSONErrorRangeEnd then
		returnVal := Ex_Pass_Back;
		return returnVal;
	endif;
	
	// Must be a JSON exception to get this far
	_hadException := true;
	returnVal := Ex_Resume_Next;
	
	app.writeLog(method.qualifiedName &amp; " (" &amp; _exc.errorCode.String &amp; ") " &amp; _exc.text &amp; CrLf &amp; _exc.extendedErrorText, LogERROR);
epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_hadException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNoDefaultPrinter" id="b8d04fe3-e243-492c-898d-7ff6997136bd">
        <source>handleNoDefaultPrinter( _exc : Exception; _raiseWarning : Boolean ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2013	cnwndl1	Initial creation	Par 32138 / 33003

*/

constants

	NoDefaultPrinter : Integer = 15021;
	NoPrinterAccess : Integer = 15014;
	
vars

	retVal : Integer;
	
begin

	retVal := Ex_Pass_Back;
	
	if _exc.errorCode = NoDefaultPrinter then
		if _raiseWarning then
			app.raiseCMWarning(No_Default_Printer, "Printer", null, null);
		endif;
		retVal := Ex_Resume_Next; 
	
	elseif _exc.errorCode = NoPrinterAccess then	//29 Jan 2019	NDL	TFS 43079
		if _raiseWarning then
			app.raiseCMWarning(Curre_unabl_acces_print_from_t, "Printer", null, null);
		endif;
		retVal := Ex_Resume_Next; 
		
	endif;
	
	return retVal;
	
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleODBCCreate" id="10d926f8-a647-4ae9-83a9-bdfff6a2c8ac">
        <updating/>
        <source>handleODBCCreate(exObj : ODBCException; _result : Integer output) : Integer updating;
/*
Purpose:			Handle Create of a SQL Row which already exists (duplicate)
					This can be remove once Jade fixes this

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2010	conkc1	Initial creation
*/
vars

begin
	if exObj.nativeError = 2627 then
		_result := 3258;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <Parameter name="exObj" type="ODBCException"/>
