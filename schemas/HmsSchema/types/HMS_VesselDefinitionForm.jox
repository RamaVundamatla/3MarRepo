    <JadeMethod name="loadCollections" id="edc57d49-2462-4d84-9726-11e0b7bf459c">
        <updating/>
        <source>loadCollections() updating;

vars
	term:		CM_Terminal;
	agent:		CM_ShippingAgent;
	root:		CM_Root;
begin
	term := self.myTerminal;
	root := app.myRoot;

  	// Load country flag combobox
	cbxCountryFlag.listCollection(root.allCountries,true,0);

	// Load tidal class comboboxes
	cbxTidalClassArrv.listCollection(root.allTidalClasses,true,0);
	cbxTidalClassDept.listCollection(root.allTidalClasses,true,0);
	// Set tidal class default to first class in the list
	if self.cbxTidalClassArrv.listCount &gt; 0 then
		cbxTidalClassArrv.listIndex:=1;	
		cbxTidalClassDept.listIndex:=1;
	endif;

	// Load shippingLine combobox
	//cbxShippingLine.listCollection(root.allShippingLines,true,0);

	// Load Line Company combobox
	cbxLinesCompany.listCollection(root.allLineCompanies,true,0);
	self.btnShipLine.enabled := false;

	// Load Vessel Type combobox
	cbxShipType.listCollection(root.allVesselTypes,true,0);
	// Set Ship Type default to first line in the list
	if cbxShipType.listCount&gt;0 then
		cbxShipType.listIndex:=1;
	endif;

	// Load Vessel Categories combobox
	cbxShipClass.listCollection(root.allVesselCategories,true,0);
	// Set Ship Categories default to first line in the list
	if cbxShipClass.listCount&gt;0 then
		cbxShipClass.listIndex:=1;
	endif;

	// Load Agents combobox
	/*cbxAgent.clear();
	cbxAgent.addItem("Not Applicable");
	foreach agent in root.allShippingAgentsByCode do
		cbxAgent.addItem(agent.description);
		cbxAgent.itemObject[cbxAgent.newIndex]:=agent;
	endforeach;
	cbxAgent.text:=cbxAgent.itemText[1];*/
	btnAgentContact.enabled:=false;

	// Load Berth Booking Priority list
	cbxBerthPriority.clear;
	cbxBerthPriority.addItem("1 - High");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=1;
	cbxBerthPriority.addItem("2");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=2;
	cbxBerthPriority.addItem("3");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=3;
	cbxBerthPriority.addItem("4");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=4;
	cbxBerthPriority.addItem("5 - Med");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=5;
	cbxBerthPriority.addItem("6");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=6;
	cbxBerthPriority.addItem("7");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=7;
	cbxBerthPriority.addItem("8");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=8;
	cbxBerthPriority.addItem("9");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=9;
	cbxBerthPriority.addItem("10 - Low");
	cbxBerthPriority.itemData[cbxBerthPriority.newIndex]:=10;

	cbxBerthPriority.listIndex:=1;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f7f6329c-b23d-4d0c-897a-14258285b581">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.cmbVessel.initialise(false);
	self.cmbShippingAgent.initialise(false);
	self.cmbShippingLine.initialise(false);
	self.loadCollections();
	self.loadBerthPrefTbl();
	
	self.setEnableObjects(false);
			
	if self.myCurrentVessel &lt;&gt; null then
		self.cmbVessel.listIndex := self.cmbVessel.findObject(self.myCurrentVessel);
	endif;

	self.setMyCurrentVessel(self.myCurrentVessel);	

	if (not self.viewModeOnly)
	and (not self.myHarbour = null) then
		self.btnEditTV.enabled := true;
		self.btnNewTV.enabled := true;
	endif;
	
	self.cmbVessel.setFocus();				

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDimensionsTbl" id="17a58e6b-acf0-48d6-a58e-aac232479b65">
        <updating/>
        <source>loadDimensionsTbl() updating;
// CCMS 1020 Remove unnessesary decimal points (i.e. if .00) with cnEcStripDecimalZeros
vars

begin
	// Set dimensions table headings
	tblBasicDimension.column:=1;
	tblBasicDimension.row:=1;
	tblBasicDimension.text:="Dimension";
	tblBasicDimension.column:=2;
	tblBasicDimension.text:="Value";
	tblBasicDimension.column:=3;
	tblBasicDimension.text:="Unit";

	// Set column widths
	tblBasicDimension.columnWidth[1]:=160;
	tblBasicDimension.columnWidth[2]:=45;
	tblBasicDimension.columnWidth[3]:=30;

	// Set number of rows
	tblBasicDimension.rows:=7;

	// Set table colours and input modes
	tblBasicDimension.accessMode:=tblBasicDimension.AccessMode_Column;
	tblBasicDimension.column:=1;
	tblBasicDimension.inputType:=tblBasicDimension.InputType_None;	
	tblBasicDimension.column:=2;
	tblBasicDimension.backColor:=White;
	tblBasicDimension.inputType:=tblBasicDimension.InputType_TextNumeric;
	tblBasicDimension.alignment:=tblBasicDimension.Alignment_Right;	
	tblBasicDimension.column:=3;
	tblBasicDimension.inputType:=tblBasicDimension.InputType_None;	
	tblBasicDimension.accessMode:=tblBasicDimension.AccessMode_Cell;

	// Set enteries in "Dimension" column
	tblBasicDimension.column:=1;
	tblBasicDimension.row:=2;
	tblBasicDimension.text:="Length Overall (LOA)";
	tblBasicDimension.row:=3;
	tblBasicDimension.text:="Gross Registered Tonnes (GRT)";
	tblBasicDimension.row:=4;
	tblBasicDimension.text:="Deadweight (DWT)";
	tblBasicDimension.row:=5;
	tblBasicDimension.text:="Beam";
	tblBasicDimension.row:=6;
	tblBasicDimension.text:="Draft (fore)";
	tblBasicDimension.row:=7;
	tblBasicDimension.text:="Draft (aft)";

	// Set maxLength's for each value
	tblBasicDimension.column:=2;
	//LOA eg. 172m
	tblBasicDimension.row:=2;
	tblBasicDimension.maxLength:=3;
	//GRT eg. 44500T (new max = 999999)
	tblBasicDimension.row:=3;
	tblBasicDimension.maxLength:=6;
	//DWT eg. 42100T (new max = 999999)
	tblBasicDimension.row:=4;
	tblBasicDimension.maxLength:=6;
	//Beam  eg. 25.3m
	tblBasicDimension.row:=5;
	tblBasicDimension.maxLength:=4;
	tblBasicDimension.inputType:=tblBasicDimension.InputType_TextBox;
	//Draft Fore  eg. 10.3m
	tblBasicDimension.row:=6;
	tblBasicDimension.maxLength:=4;
	tblBasicDimension.inputType:=tblBasicDimension.InputType_TextBox;
	//Draft Aft  eg. 10.3m
	tblBasicDimension.row:=7;
	tblBasicDimension.maxLength:=4;
 	tblBasicDimension.inputType:=tblBasicDimension.InputType_TextBox;

	// Set enteries for values column
	if self.myCurrentVesselData &lt;&gt; null then
		tblBasicDimension.column:=2;
		// LOA
		tblBasicDimension.row:=2;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_LengthOverall.rounded().asStringJMT;
		// GRT
		tblBasicDimension.row:=3;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_GrossRegTonnes.String;
		// DWT
		tblBasicDimension.row:=4;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_DeadWeight.String;
		// BEAM
		tblBasicDimension.row:=5;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_Beam.String;
		// DRAFT FORE
		tblBasicDimension.row:=6;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_DraftFore.String;
		// DRAFT AFT
		tblBasicDimension.row:=7;
		tblBasicDimension.text:= self.myCurrentVesselData.dim_DraftAft.String;
	endif;

	// Set enteries in "Units" column
	tblBasicDimension.column:=3;
	tblBasicDimension.row:=2;
	tblBasicDimension.text:="m";
	tblBasicDimension.row:=3;
	tblBasicDimension.text:="T";
	tblBasicDimension.row:=4;
	tblBasicDimension.text:="T";
	tblBasicDimension.row:=5;
	tblBasicDimension.text:="m";
	tblBasicDimension.row:=6;
	tblBasicDimension.text:="m";
	tblBasicDimension.row:=7;
	tblBasicDimension.text:="m";

end;</source>
    </JadeMethod>
    <JadeMethod name="loadKeyDistancesTbl" id="ebc91a0e-fbf9-49e2-9a22-84b86e6fc18c">
        <updating/>
        <source>loadKeyDistancesTbl() updating;

vars

begin
	// Set dimensions table headings
	tblKeyDistances.column:=1;
	tblKeyDistances.row:=1;
	tblKeyDistances.text:="Key Distance";
	tblKeyDistances.column:=2;
	tblKeyDistances.text:="Value";
	tblKeyDistances.column:=3;
	tblKeyDistances.text:="Unit";

	// Set column widths
	tblKeyDistances.columnWidth[1]:=160;
	tblKeyDistances.columnWidth[2]:=45;
	tblKeyDistances.columnWidth[3]:=30;

	// Set number of rows
