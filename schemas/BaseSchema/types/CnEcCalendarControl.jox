    </JadeMethod>
    <JadeMethod name="isStretchWidth" id="2374a351-3ce6-4805-b803-a051455c1bd0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isStretchWidth(set: Boolean; _value: Boolean io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
