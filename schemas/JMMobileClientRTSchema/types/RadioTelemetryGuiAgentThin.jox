    <JadeMethod name="clearStateObject" id="dc83b2be-54e6-4300-92a1-0909d897ad82">
        <source>clearStateObject();
// -------------------------------------------
// Created 13 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myStateObj.errorString	:= null;
	self.myStateObj.extraInfo	:= 0;
	self.myStateObj.guiState	:= 0;
	self.myStateObj.lastUpdateTs := null;
	
	self.myStateObj.warningsAcknowledged	:= false;
	self.myStateObj.hasWarningsOnly			:= false;

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="d6764da4-0b4f-4dce-a9e0-b3822bd43471">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	create self.myRTThinClientAgent transient;
	create self.myStateObj transient;
	create self.myNotesObj transient;
	
	self.beginNotification(self.myRTThinClientAgent, MobileServerRTThin::RadioTelemetryThinClientAgent.Event_Server_Note, Response_Continuous , null);


end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="7e9b514a-8608-40de-a063-08786ca6682f">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	delete self.myRTThinClientAgent;
	delete self.myStateObj;
	delete self.myNotesObj;

	self.endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeQueue" id="b4f64022-4e04-49bd-a542-a2fc4b1b8443">
        <source>doChangeQueue(_newQueueID : String;
			  _errorString: String output; 
			  _state: Integer output) : Boolean;

/*

Purpose:			Action a change of primary queue to the queue identified by _newQueueID 


Return Value:		_errorString and _state updated, and true if chnage successful


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	rtnValue		: Boolean;

begin
	self.clearStateObject();
	
	rtnValue := self.myRTThinClientAgent.doChangeQueue(_newQueueID, self.myStateObj);

	_errorString := self.myStateObj.errorString;
	_state := self.myStateObj.guiState;
	
	return rtnValue;

	
epilog

end;
</source>
        <Parameter name="_newQueueID" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogOff" id="739e2e16-92d3-4a33-bef2-3ebf2c9e8dae">
        <updating/>
        <source>doLogOff(_state	: Integer output; _errorString: String output; _warnings : Boolean io): Boolean updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

	rtnValue	: Boolean;

begin

	self.clearStateObject();
	
	self.myStateObj.warningsAcknowledged := _warnings;
	
	rtnValue := self.myRTThinClientAgent.doLogOff(self.myStateObj);

	_errorString	:= self.myStateObj.errorString;
	_state 			:= self.myStateObj.guiState;
	_warnings		:= self.myStateObj.hasWarningsOnly;

	return rtnValue;
end;</source>
        <Parameter name="_state" type="Integer" usage="output"/>
