    <JadeMethod name="getDisplayString" id="b9080666-0a0b-4161-b809-222cc28fb515">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     24 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	str := inheritMethod();
	
	str := str &amp; Tab &amp; 
			self.tiId &amp; Tab &amp; 
			self.sourceLocation &amp; Tab &amp; 
			self.targetLocation &amp; Tab &amp; 
			" " &amp; Tab &amp;
			self.remarks;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setInformation" id="fdf90d5e-e07f-4f96-ae37-4a06d13908f5">
        <updating/>
        <source>setInformation(	_infoType :Integer; 
				_task :CM_RTQueueTask;
				_newStatus :Integer; 
				_machine :CM_Machine;
				_details : String ) updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	setdownTask : CM_RTQueueTask;
	ti			:CM_TrackedItem;
	userId		:String;
begin
	
	//epr TFS 4620 16/6/17 changes for Vehicle Apps notifications and controller messages
	if _task &lt;&gt; null then
		ti := _task.ti;
		
		self.tiId:=_task.tiId;
		
		if ti &lt;&gt; null then
			self.cargoType	:= ti.cargoType;
		endif;
		self.sourceLocation	:= _task.sourceLocationId;
		if _task.isPickUp then
			setdownTask:=_task.myEntry.getDirectorOrSetDownTask; 
		else
			setdownTask:=	_task;
		endif;
		
		//epr 7681 8/11/17
		if setdownTask &lt;&gt; null then
			self.targetLocation:=setdownTask.getTargetLocationExtra;
		else
			self.targetLocation:=_task.targetLocationId;
		endif;
	endif;
	
	userId :=  app.myPassport.getUserCode;
	self.infoType 		:= _infoType;
	
	if _infoType = self.InfoType_Status_Change then
		self.remarks := ('Status changed from ' &amp; _task.statusString &amp; ' to ' &amp; 
					_task.getStatusStr (_newStatus));
	elseif _infoType = self.InfoType_Restore_Status then				
		self.remarks := ('Status restored from ' &amp; _task.statusString &amp; ' to ' &amp; 
						_task.getStatusStr (_newStatus));
	elseif _infoType = self.InfoType_Allocate_Machine then
		self.remarks := app.getErrorString(Contro_alloca_your_next_task) ;
	elseif _infoType = self.InfoType_Remove_Machine then
		self.remarks := app.getErrorString(Contro_remove_your_alloca_task);    
	elseif _infoType = self.InfoType_ControlReset then
		self.remarks := app.getErrorString(Control_reset_your_sesssio);
	elseif _infoType = self.InfoType_ChangeTarget then
		self.remarks := app.getErrorString1(Target_location_changed,self.targetLocation);
	elseif _infoType = self.InfoType_ChangeSource then
		self.remarks := app.getErrorString1(Source_location_changed,self.sourceLocation);
	elseif _infoType =  self.InfoType_ChangeQueue then
		self.remarks := app.getErrorString1(Control_transferred_queue,_machine.myPrimaryQueue.id);
	elseif _infoType = self.InfoType_LabourRestriction then
		self.remarks :=app.getErrorString1(Labour_restrict_at_location, _details);
	elseif _infoType = self.InfoType_ControlMessage then		
		self.remarks :=app.getErrorString1(Message_from_control,_details);
	endif;
			
	self.setDetails(self.Type_Info,_machine,userId);

epilog

end;</source>
        <Parameter name="_infoType" type="Integer"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
</Class>
