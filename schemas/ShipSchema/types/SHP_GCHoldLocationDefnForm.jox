    </JadeMethod>
    <JadeMethod name="translateForm" id="76647705-50c3-4354-8154-303c8191caf2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 February 2017 09:16:23.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019163, locale);
	btnAdd.translateCaption(Xlat_0019164, locale);
	btnCancel.translateCaption(Xlat_0019165, locale);
	btnClose.translateCaption(Xlat_0019166, locale);
	btnDelete.translateCaption(Xlat_0019167, locale);
	btnSave.translateCaption(Xlat_0019168, locale);
	btnSort.translateCaption(Xlat_0021866, locale);
	lblHoldNum.translateCaption(Xlat_0019169, locale);
	lblIsOnDeck.translateCaption(Xlat_0020906, locale);
	lblLocationName.translateCaption(Xlat_0019170, locale);
	lblLocationNum.translateCaption(Xlat_0019171, locale);
	lblMaxHeight.translateCaption(Xlat_0021867, locale);
	lblMaxVolume.translateCaption(Xlat_0021285, locale);
	lblMaxWeight.translateCaption(Xlat_0021162, locale);
	lblOnShipCrane.translateCaption(Xlat_0021286, locale);
end;</source>
    </JadeMethod>
