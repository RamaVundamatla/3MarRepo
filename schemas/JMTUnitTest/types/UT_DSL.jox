    <JadeMethod name="copyTranMapService" id="f13de4a3-1706-4c79-bb27-4073e54f0d5a">
        <source>copyTranMapService(_copyService : CM_TIServiceMap input; _tranMap : CM_TranMap; _cargoType : CM_CargoType) : CM_TIServiceMap;

vars
	newTISM	: CM_TIServiceMap;
begin
	app.myTrxCA.trxCopyInvoiceTMCargoType(_copyService, _cargoType, _tranMap, newTISM, app.myPassport);
