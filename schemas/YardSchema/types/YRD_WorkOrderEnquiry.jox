    <JadeMethod name="doMnuSendToReportWO" id="d7eb5daf-6d70-4a8b-b0cd-c4fc64353286">
        <updating/>
        <source>doMnuSendToReportWO(_selectedOnly : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	objArray : ObjectArray;
begin
	// Report writer throws exceptions when in transaction state.
	// Added flag to app to ignore any transaction calls that are not in 
	// the trx layer (Eg, CM_Charge.evaluateRate).
	app.isReportWriter := true;
	
	create objArray transient;
	
	self.getWOForReport(objArray, _selectedOnly);
	
	self.doSendToReport(objArray);
epilog
	delete objArray;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNewWorkOrder" id="4ac6c3bd-f83d-4b7c-a0aa-b0c94f6337fc">
        <source>doNewWorkOrder(_mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
22/07/2022 	navcs2	ChangeRequest 54156: MTN - Work Order New UI Release
28/08/2022  navma1	ChangeRequest 54644: MTN - Work Order Refactor - IsSpecial
*/

vars
	workOrderForm : YRD_WorkOrder;

begin
	
	app.mousePointer := MousePointer_HourGlass;

	workOrderForm := app.loadForm(YRD_WorkOrder, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrder;
	
	if workOrderForm = null then
		return;
	endif;

	workOrderForm.centreWindow;
	
	workOrderForm.setWorkOrderMode(YRD_WorkOrder.MODE_ADD);
	workOrderForm.setWorkOrderType( _mode);
	workOrderForm.setMyTerminal(self.myTerminal);
	workOrderForm.show;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="c3a10ee7-7cc5-4eea-a04f-9b340eaa372b">
        <source>doNotableAdd(_anObject: Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2025	jlier1	Initial creation MTN-34591 
*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	//jlier1 29/5/25 MTN-34591 
	
	if _anObject = null then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception,_anObject,invalid);
	ed := _anObject.edition;
	if invalid then
		return;
	endif;
	
	if CM_WorkOrder.hasInstance(_anObject) then
		self.allNotableObjects.add(_anObject);
		self.beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Update), Response_Continuous, null);
		self.beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Delete), Response_Continuous, null);
	//cnwjo3, used in YRD_WorkOrderEnquiry::addRowToTable, par 21915
	elseif CM_WorkOrderDtl.hasInstance(_anObject) then
		self.allNotableObjects.add(_anObject);
		self.beginNotification(_anObject,self.myTerminal.getTerminalEvent(Event_WODtl_Update), Response_Continuous, null);
		self.beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WODtl_Delete), Response_Continuous, null);
	endif;		
	

	//inheritMethod(_anObject);

epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="7ced1205-1ccf-4d41-a076-79f77c81cc7a">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin
	
	/* //23/06/2025	navkc1 JIRA MTN 34973
	foreach anObject in self.allNotableObjects do
		
		if anObject.isKindOf(CM_WorkOrder) then
			//jlier1 29/5/25 MTN-34591 		
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Update));
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Delete));
			
			//	endNotification(anObject, Object_Update_Event);
			//	endNotification(anObject, Object_Delete_Event);
			
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_WorkOrderDtl) then
			
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_WODtl_Update));
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_WODtl_Delete));
			
			//	endNotification(anObject, Object_Update_Event);
			//	endNotification(anObject, Object_Delete_Event);
			
			removedNotification := removedNotification + 1;
		endif;
		
		removedNotification := removedNotification + 1;
	endforeach;
	*/
	//validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	self.endNotificationForSubscriber(self);  //23/06/2025	navkc1 JIRA MTN 34973
	self.beginClassNotification(CM_WorkOrder,    	false, self.myTerminal.getTerminalEvent(Event_WorkOrder_Create), Response_Continuous, null);		 //23/06/2025	navkc1 JIRA MTN 34973
	self.beginClassNotification(CM_WorkOrderDtl,    false, self.myTerminal.getTerminalEvent(Event_WODtl_Create), Response_Continuous, null); //23/06/2025	navkc1 JIRA MTN 34973
	self.allNotableObjects.clear; //23/06/2025	navkc1 JIRA MTN 34973
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="4c8aac11-352b-4a27-bf02-79baa0829da3">
        <source>doNotableRemove(_anObject: Object);
/*

Purpose: 			This method remove the object from listening to notification;

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2025	navkc1 JIRA MTN 34973 MTN | Pagination - Work Order Enquiry

*/

vars
	
begin
	
	if _anObject.isKindOf(CM_WorkOrder) then
		self.endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Update));
		self.endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WorkOrder_Delete));
	elseif _anObject.isKindOf(CM_WorkOrderDtl) then
		self.endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WODtl_Update));
		self.endNotification(_anObject, self.myTerminal.getTerminalEvent(Event_WODtl_Delete));
	endif;
	
	self.allNotableObjects.tryRemove(_anObject);//23/06/2025	navkc1 JIRA MTN 34973 - using this to display how many records found
	
epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="76cb1876-2df3-46ac-979d-8a3a9fb5de12">
        <updating/>
        <source>doNoteHandlingObject(_notificationRecord: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/05/2025	navkc1 JIRA MTN-34592 MTN | Work Order Enquiry Notification Framework
04/06/2025	navsp1 JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars
	object 				: Object;
	termEvent,
	theRow,
	eventType,
	eventTag 			: Integer;
	userInfo 			: Any;
	isWO,
	isWODtl,
	isCorrectMode,
	isUpdate,
	isCreate,
	isDelete,
	include,
	invalid				: Boolean;
	theTable			: CM_DataTable;
	theWO				: CM_WorkOrder;
	theWODtl			: CM_WorkOrderTIDtl;
begin
	
	on Exception do app.handleDeletedObject(exception, object, invalid);

	object := _notificationRecord.myObject;
	eventType := _notificationRecord.eventType;
	eventTag := _notificationRecord.eventTag;
	userInfo := _notificationRecord.myUserInfo;
	
	//27/05/2025	navkc1 JIRA MTN-34972
	if object &lt;&gt; null then
		object.edition();
	endif;
	
	// Object deleted
	if invalid then
		self.removeFromTable(object.CM_Object);
		return;
	endif;
	
	// Make sure we are in WO mode when handliong WO object, and in TASK mode when handling WO details object
	isCorrectMode := 	(self.enquiryType = self.EnqType_Task 		and 	object.isKindOf(CM_WorkOrderDtl)) or
						(self.enquiryType = self.EnqType_WorkOrder 	and 	object.isKindOf(CM_WorkOrder));
	
	if not isCorrectMode then
		return;
	endif;
	
	theTable := self.tblData;
	
	// Check is WO or WO Details
	if object.isKindOf(CM_WorkOrderTIDtl) then
		isWODtl := true;
		theWODtl := object.CM_WorkOrderTIDtl;
		if theWODtl.getTransport() = TI_TRANSMODE_SHIP then
			return;
		endif;
	elseif object.isKindOf(CM_WorkOrder) then
		isWO := true;
		theWO := object.CM_WorkOrder;
	endif;
	
	// Do we want to include the object to table?
	if isWO then
		include := self.includeObject(theWO) or 
					self.allNotableObjects.includes(theWO);//13/06/2025	navkc1 JIRA MTN 35076
	elseif isWODtl then
		include := self.includeObjectWODtl(theWODtl, false) or          //JIRA-34585
					self.allNotableObjects.includes(theWODtl); //13/06/2025	navkc1 JIRA MTN 35076
	endif;
	
	// Do not include, return
	if not include then
		return;
	endif;
	
	// Get Terminal Event
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	//			//System event							// Terminal WO Event				 	//Terminal WO Details event
	isUpdate := eventType = Object_Update_Event 	or 	termEvent = Event_WorkOrder_Update 	or 	termEvent = Event_WODtl_Update;
	isCreate := eventType = Object_Create_Event 	or 	termEvent = Event_WorkOrder_Create 	or 	termEvent = Event_WODtl_Create;
	isDelete := eventType = Object_Delete_Event 	or 	termEvent = Event_WorkOrder_Delete 	or 	termEvent = Event_WODtl_Delete;
	
	if isUpdate then
		theTable.findObjectInRow(object, theRow);
		if theRow &gt; 0 then
			theTable.accessCell(theRow, 1).text := object.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			if isWO then
				self.displayExtraInfoForObj(theWO);
			endif;
		endif;
	elseif isCreate then
		if not theTable.findObjectInRow(object, theRow) then
			if isWO then
				self.addRowToTable(theWO, theTable, self.filterVoyWOdtlTaskNos, self.filterCargoWOdtlTaskNos, self.filterToDoWOdtlTasksNos);    //JIRA-34585
			else
				self.addRowToTableForTask(theWODtl, theTable);
			endif;
		endif;
	elseif isDelete then
		self.removeFromTable(object.CM_Object);
	endif;
	
	// Added/Deleted some rows, update the count
	if isCreate or isDelete then
		self.updateStatusBarCount();
	endif;
	
epilog

end;</source>
        <Parameter name="_notificationRecord" type="CMIF_NotificationRecord"/>
    </JadeMethod>
