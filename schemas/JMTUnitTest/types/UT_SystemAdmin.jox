	endLoad;
	
	pxyLRReason.setNotAvailableForEntry(false);
	
	app.myTrxUA.trxUpdateLRReasonCode(pxyLRReason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(lrReason.notAvailableForEntry, false);

epilog

	delete pxyLRReason;

end;</source>
