epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubTermCodeForRecRel" id="a1ab3249-2e36-44cd-8812-02b3d91350db">
        <source>getSubTermCodeForRecRel(_isRCEX, _isRCVF, _isSNTC : Boolean; _trans : CM_TITransaction; _ti : CM_TrackedItem) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
//
vars
	iter : Iterator;
	transaction : CM_TITransaction;
	termCode : String;

begin
	iter := _ti.allTransactions.createIterator;
	iter.startAtObject(_trans);
	while true do
		if _isSNTC then
			iter.back(transaction);
		else
			iter.next(transaction);
		endif;
		if transaction = null then
			break;
		endif;
		if transaction = _trans then
			continue;
		endif;
		
		if _isSNTC and transaction.type = TRANS_TYPE_REL_ST_MARINE_INT then
			if transaction.CM_SubTermReleaseMarineIntern.mySubTerminal &lt;&gt; null then
				termCode := transaction.CM_SubTermReleaseMarineIntern.mySubTerminal.code;
				break;
			endif;
		elseif (_isRCEX or _isRCVF) and transaction.type = TRANS_TYPE_REC_ST_MARINE_INT then
			if transaction.CM_SubTermReceiveMarineIntern.mySubTerminal &lt;&gt; null then
				termCode := transaction.CM_SubTermReceiveMarineIntern.mySubTerminal.code;
				break;
			endif;
		endif;
		
		if transaction.isCamsCodecoRecRelType then
			break;
		endif;
	endwhile;
	
	return termCode;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_isRCEX" type="Boolean"/>
        <Parameter name="_isRCVF" type="Boolean"/>
        <Parameter name="_isSNTC" type="Boolean"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="imExStatusToString" id="23689085-e717-4b22-b91f-4db8170361ce">
        <source>imExStatusToString(_ti: CM_TrackedItem): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	loadPort, destPort, ourPort : CM_Port;
	imexString : String;

begin
	loadPort := app.myRoot.allPorts[_ti.loadPort];
	destPort := app.myRoot.allPorts[_ti.dischargePort];
	ourPort := app.myRoot.allPorts[_ti.myTerminal.getConfig(PortDestCode).String];
	if loadPort &lt;&gt; null and destPort &lt;&gt; null and ourPort &lt;&gt; null then
		if loadPort.countryCode = destPort.countryCode and loadPort.countryCode = ourPort.countryCode then
			imexString := "1";
		endif;
	endif;
	
	if imexString = null then
		if _ti.isRehandle and not _ti.isARework then
			imexString := "5";  //Shifter(restow)
		elseif _ti.isSOB and not _ti.isARework then
			imexString := "5";  //remain on board
		elseif _ti.isExport then
			imexString := "2";
		elseif _ti.isStorage then//for Coarri a storage has been imported
			imexString := "3";
		elseif _ti.isImport then
			imexString := "3";
		elseif _ti.isTranshipItem then
			imexString := "6";  
		else
			imexString := "";
		endif;
	endif;
	
	return imexString;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageFTX_ABS" id="4ddd1dba-1a5f-4900-9a75-5c7670994500">
        <source>makeMessageFTX_ABS(_camProtocol : CM_CamProtocol; _group : HugeStringArray input; _ti : CM_Container);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
constants
	MESSAGE = "FTX";
	STAGE = "ABS";
	
vars
	msg, msgStart, solasMethod : String;
	plus, colon, singleQuote : Character;

begin
	// There are a vast number of ABS possible codes - we only support the following:
	//	1			Available (based on isAvailable)
	// 	6			Not damaged
	// 	51 / 52		Export Empty or Export Full
	// 	67			Clean (based on isClean)
	// 	68			Dirty (based on not isClean) - either 67 or 68 will be sent
	// 	78			All Stops Removed (based on allStops being empty)
	// 	91			Repaired (based on isAllDamagesRepaired)
	// 	SM1	/ SM2	Verify gross mass (based on Solas method of weight authority)
	// THERE CAN ONLY BE UP TO 9 REPEATS OF ABS, SO BEWARE OF THIS IF ADDING ANY NEW CODES
	plus		:= _camProtocol.elementSeparator;
	colon		:= _camProtocol.subElementSeparator;
	singleQuote	:= _camProtocol.segmentTerminator;
	
	msgStart := MESSAGE &amp; plus &amp; STAGE &amp; plus &amp; plus;
	
	// Is Available - 1
	if _ti.isAvailable then
		msg := msgStart &amp; "1" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// Not Damaged - 6
	if _ti.allDamageInstances.isEmpty then
		msg := msgStart &amp; "6" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// Export Empty - 51
	if _ti.isExport and _ti.isEmpty then
		msg := msgStart &amp; "51" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// Export Full - 52
	if _ti.isExport and not _ti.isEmpty then
		msg := msgStart &amp; "52" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// Clean - 67 and Dirty = 68
	if _ti.isClean then
		msg := msgStart &amp; "67" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	else
		msg := msgStart &amp; "68" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// All Stops Removed - 78
	if _ti.getAllStops.isEmpty then
		msg := msgStart &amp; "78" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// Repaired - 91
	if not _ti.allDamageInstances.isEmpty and _ti.getDamageQuantity = null then
		msg := msgStart &amp; "91" &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
	// verfied Gross mass method - SM1 / SM2
	if _ti.isWeightCertified and _ti.myVGMDetails &lt;&gt; null then
		if _ti.myVGMDetails.vgmCommsType &lt;&gt; null then
			solasMethod := _ti.myVGMDetails.vgmCommsType;
		elseif _ti.myVGMDetails.myWeighAuthTerminal &lt;&gt; null then
			solasMethod := _ti.myVGMDetails.myWeighAuthTerminal.myWeighAuthority.solasMethod;
		endif;
		msg := msgStart &amp; solasMethod &amp; colon &amp; colon &amp; "184" &amp; singleQuote;
		_group.add(msg);
	endif;
	
epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="makeMessageFTX_OSI" id="f20c6e27-321b-460e-a341-f899533aecde">
        <source>makeMessageFTX_OSI(_camProtocol : CM_CamProtocol; _group : HugeStringArray input; _ti : CM_TrackedItem);
//
// Purpose:		
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
constants
	MESSAGE = "FTX";
	STAGE = "OSI";
	
vars
	msg : String;
	plus, colon, singleQuote : Character;

begin
	plus		:= _camProtocol.elementSeparator;
	colon		:= _camProtocol.subElementSeparator;
	singleQuote	:= _camProtocol.segmentTerminator;
	
	if _ti.myVoyage = null or _ti.myVoyage.myTrade = null then
		return;
	endif;
	
	msg := MESSAGE &amp; plus &amp; STAGE &amp; plus &amp; plus &amp; _ti.myVoyage.myTrade.description &amp; colon &amp; "ZZZ" &amp; singleQuote;
	_group.add(msg);
epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_RE" id="c50dd130-5ee9-421d-bd47-93bf5c27de7d">
        <source>makeMessageRFF_RE(_camProtocol : CM_CamProtocol; _group : HugeStringArray input; _activity : Integer;  _ti : CM_TrackedItem; _transaction :CM_TITransaction) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/09/2020	jlgdap1		Initial creation TFS 50075 TML Swire Message SNTS and TRFE message missing RFF segment
//
vars
	ref : String;
	bulkRelease : CM_BulkRelease;

begin
	if _activity = CODECO_GATEIN then			// will be for TRFE - probably only going to have a booking
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.bookingReference.trimRight;						
			
			if ref = null then											
				ref := _ti.deliveryRelease.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "RE", ref);	
		endif;														
	endif;
	
	if _activity = CODECO_GATEOUT then
		if _ti.isFull then
			if _ti.deliveryRelease &lt;&gt; null then
				ref := _ti.deliveryRelease.trimRight;
			endif;
		else
			bulkRelease := _ti.allBulkReleasesReleased.first;
			if bulkRelease &lt;&gt; null then
				ref := bulkRelease.code.trimRight;
			endif;
		endif;
		if ref &lt;&gt; null then
			self.makeRFFSegment(_camProtocol, _group, "RE", ref);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="808d18bd-31d1-42a8-b9a3-c802125e8e65">
        <source>makeMessageSealsData(_ti : CM_TrackedItem; _camMessage : CM_CamMessage input; _group : HugeStringArray input; _camProtocol : CM_CamProtocol; _contentsStatus : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
//
vars
	strSeal : String;
	plus, singleQuote : Character;	
	seals : HugeStringArray;
	sealParty, ventSeal, seal : String;
	sealTI : CM_SealTI;
	sealed : Boolean;
	
begin
	create seals transient;
	
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	
	_ti.getSealNumStringArray(seals, SealType_Operator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CA" &amp; singleQuote);	
			sealed := true;
		endif;
	endforeach;
	
	seals.clear();
	_ti.getSealNumCustomsStringArray(seals);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	
			sealed := true;
		endif;
	endforeach;
	
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_Shipper);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);
			sealed := true;
		endif;
	endforeach;
	
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_TerminalOperator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "TO" &amp; singleQuote);
			sealed := true;
		endif;
	endforeach;
	
	if _ti.isKindOf (CM_Container) then
		seals.clear();
		_ti.getSealNumStringArray(seals, SealType_Vent);
		foreach strSeal in seals do
			if strSeal.trimRight &lt;&gt; "" then
				_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "AB" &amp; singleQuote);
				sealed := true;
			endif;
		endforeach;
	endif;
	
	foreach sealTI in _ti.allSeals do
		if sealTI.sealType = SealType_Customs or
		   sealTI.sealType = SealType_Operator or
		   sealTI.sealType = SealType_Shipper or
		   sealTI.sealType = SealType_TerminalOperator or
		   sealTI.sealType = SealType_Vent then
			continue;
		endif;		
		foreach seal in sealTI.allSealNums do
			//27 Aug 2020	NDL	TFS 49974 - Don't report 'unknown' type seals with no 'current' value.
			if _camProtocol.formatSeal(seal).trimBlanks = null then
				continue;
			endif;
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(seal) &amp; plus &amp; "AB" &amp; singleQuote);
			sealed := true;
		endforeach;
	endforeach;
	
	if not sealed then
		_group.add("SEL" &amp; plus &amp; "UNKNOWN" &amp; singleQuote);
	endif;
	
epilog
	delete seals;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="bb325276-824c-4ed2-ac1d-cf84aee3a1ea">
        <source>makeMessages(	_trackedItem: CM_TrackedItem; 
				_transaction: CM_TITransaction; 
				_camProtocol: CM_CamProtocol; 
				_camMessage: CM_CamMessage input; 
				_xlVoyageId: String; 
				_terminal: CM_Terminal; 
				_secondTrx: CM_TITransaction	);
//
/* Purpose:			This class looks after the specialised CODECO handling for Swire at Townsville
//					A summary of the main changes are:
					
				1.	SNTS Depot Road Release MT Storage
					This is an Empty Storage container released from a terminal area in the Depot sub-terminal
					
					TDT+20 segment is not required
					NAD+MS+&lt;Depotcode&gt;+160+184' includes the Depot code from the Cam group
					LOC+8+00UNK' to be included for all "Sent To Shipper" releases
					LOC+165+AUMEL:139:6+&lt;Sender depot code&gt;:STO:184' includes the Sender Depot Code from the Cam group. STO is for Depot activity
					RFF+RE if the container has a release or delivery release number
					RFF+BN if the container has a booking number
					
				2.	SNTC Marine Road Release Full Import
					This is a Full Import container released from a terminal area in the Marine sub-terminal
					
					TDT+20+&lt;voyagecode&gt;+1++SSL:172:184+++8809191:146 
					NAD+MS+&lt;Depotcode&gt;:160:87 includes the Depot code from the Cam Group
					EQD+CN equipment status should be 1 - Continental, 2 - Export, 3 - Import, 4 - Tranship
					RFF+BN+UNKNOWN if the booking number is unknown
					LOC+165+AUMEL+&lt;marine subterminal code&gt;:TER:184 includes the Marine sub-terminal code
					LOC+8+AUTSV include this LOC segment to show discharge port
					
				3.	RCVE Depot Road Receival MT Storage
					This is an Empty Storage container being road received into a terminal area in the Depot sub=terminal
					
					TDT+20 group 1 segment not required - TDT+20 segment should be in group 7
					NAD+MS+&lt;Depot sub-terminal&gt;:160:184 includes the Depot Sub-terminal code from the Cam group
					RFF+CN:&lt;shipping line&gt; new segment to show the shipping line code of the voyage
					LOC+9 not required
					LOC+165+AUMEL:139:6+&lt;Sender depot code&gt;:STO:184 includes the Sender Depot code from the Cam group
					FTX+DAR++10::184 New segment - container is damaged, record damage here
					FTX+ABS++68::184 Include if FTX+DAR is included
					MEA+AAE not required
					TDT+1++3++:::&lt;carrier code&gt;+++:::&lt;truck registration&gt; New segment showing the carrier and truck registration
					
				4.	RCVF Marine Road Receival Full Export
					This is a Full Export container being road received into a terminal area in the Marine sub-terminal
					
					TDT+20+&lt;voyage code&gt;+1++&lt;carrier code&gt;:172:184+++&lt;LLoyds number&gt;:146 includes the vessel operator's voyage code for the export voyage, and the vessel's LLoyd's Number
					NAD+MS+&lt;Terminal Depot code&gt;:160:184 includes the Terminal Depot code from the Cam Group
					EQD+CN equipment status should be 1 - Continental, 2 - Export, 3 - Import, 4 - Tranship
					LOC+165+AUMEL+&lt;Marine subterminal&gt;:TER:184 includes the Marine sub-terminal code
					LOC+8+SGSIN include this segment showing discharge port 
					SEL+ include this segment to record all seal details
					
				5.	RCEX Marine Road Receival MT Export
					This is an MT Export container being road received into a terminal area in the Marine sub-teminal
					
					TDT+20+&lt;voyage code&gt;+1++&lt;carrier code&gt;:172:184+++&lt;Lloyds number&gt;:146 includes the vessel operator's voyage code and the vessel's Lloyd's number
					NAD+MS+&lt;Terminal Depot code&gt;:160:184 includes the Terminal Depot code from the Cam Group
					EQD+CN equipment status should be 1 - Continental, 2 - Export, 3 - Import, 4 - Tranship
					LOC+165+AUMEL+&lt;Marine subterminal&gt;:TER:184 includes the Marine sub-terminal code
					
				6.	TRFE Internal transfer MT Storage or Export or Import from Depot to Marine or from Marine to Depot
					This is an internal move of an MT Storage or Export or Import from a terminal area in the Depot sub-terminal to a terminal area in the Marine sub-terminal
							or from a terminal area in the Marine sub-terminal to a terminal area in the Depot sub-terminal
					
					BGM will be BGM+36 (transfer from Depot to Marine is treated as a Gate Out)
					TDT+20 at group 1 not required (will be in group 7 instead)
					NAD+MS+&lt;Depot subterminal&gt;:160:184 includes the Depot sub-terminal code from the Cam group
					LOC+8+&lt;destination&gt; is the depot sender code from the Cam group for a move from Depot to Marine
					LOC+8+&lt;destination&gt; is the marine sender code from the Cam group for a move from Marine to Depot
					LOC+9+&lt;port of discharge&gt;
					LOC+165+AUMEL:139:6+&lt;Sender Depot code&gt;:STO:184 includes the Sender Depot code from the Cam group
					FTX+DAR++10::184 Included if the container is damaged
					FTX+ABS++68::184 Include to further define the container's damage
					TDT+1++3++:::&lt;carrire code&gt;+++:::&lt;registration number&gt; includes the carrier code and truck registration from the container's road receival
					RFF+RE if the container has a release or delivery release number
					RFF+BN if the container has a booking number
*///
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
// 18/09/2020	jlgdap1		TFS 50075 TML Swire Message SNTS and TRFE message missing RFF segment
// 20/01/2021	jlgdap1		TFS 50554 TML Swire TRFE LOC+8 field missing
// 20/07/2021	navdap1		TFS 51572 TML Swire Outbound EDI TRFE from Marine to Depot values incorrect
// 06/09/2021	navdap1		TFS 51921 TML Swire Cam protocol - LOC+8 target location not being captured for sub terminal
// 21/06/2022	jlizm1		TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
//
vars
	isRCEX, isRCVE, isRCVF, isSNTC, isSNTS, isTRFE : Boolean;
	ti : CM_TrackedItem;
	includeVGM : Boolean;
	contentsStatus : String;
	imExStatus : String;
	isoCode, fIsoCode : String;
	ourCode, code, pCode : String;
	location, relLoc : String;
	voyage : CM_Voyage;
	voyageCode, operatorCode, foreignCode, carrierCode : String;
	protocol : CM_CamProtocol;					// TFS 51921

begin
	ti := _transaction.myTrackedItem;
	if ti = null then
		app.writeLog("Transaction " &amp; _transaction.typeString &amp; " has no TI - ignoring", LogINFO);
		return;
	endif;
	if _camProtocol.useVGM 
	and _camProtocol.getIncludeExtraVGM 
	and ti.isWeightCertified 
	and not ti.isEmpty then
		includeVGM := true;
	endif;
	
	// RCEX Marine Road Receival MT Export
	if _camProtocol.terminalActivity and ti.isTMLRCEX(_transaction, _camMessage) then
		isRCEX := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as RCEX", LogINFO);
	endif;
	// RCVE Depot Road Receival MT Storage
	if _camProtocol.depotActivity and ti.isTMLRCVE(_transaction, _camMessage) then
		isRCVE := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as RCVE", LogINFO);
	endif;
	// RCVF Marine Road Receival Full Export
	if _camProtocol.terminalActivity and ti.isTMLRCVF(_transaction, _camMessage) then
		isRCVF := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as RCVF", LogINFO);
	endif;
	// SNTC Marine Road Release Full Import
	if _camProtocol.terminalActivity and ti.isTMLSNTC(_transaction, _camMessage) then
		isSNTC := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as SNTC", LogINFO);
	endif;
	// SNTS Depot Road Release MT Storage
	if _camProtocol.depotActivity and ti.isTMLSNTS(_transaction, _camMessage) then
		isSNTS := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as SNTS", LogINFO);
	endif;
	// TRFE Internal transfer MT Storage or Export or Import from Depot to Marine 
	// TFS 51572 also MT Storage or Export or Import from Marine to Depot
	//if _camProtocol.terminalActivity and ti.isTMLTRFE(_transaction, _camMessage) then									// TFS 51572
	if (_camProtocol.terminalActivity or _camProtocol.depotActivity) and ti.isTMLTRFE(_transaction, _camMessage) then	// TFS 51572
		isTRFE := true;
		app.writeLog("TI " &amp; ti.id &amp; Space &amp; _transaction.typeString &amp; " Processing as TRFE", LogINFO);
	endif;
	// Not one we're interested in? Just bail
	if not isRCEX and not isRCVE and not isRCVF and not isSNTC and not isSNTS and not isTRFE then
		app.writeLog("TI " &amp; ti.id &amp; " transaction " &amp; Space &amp; _transaction.typeString &amp; " is not a TML Swire type - ignoring", LogINFO);
		return;
	endif;
	
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	
	// EQD segment
	imExStatus := self.imExStatusToString(ti); 
	if  ti.isKindOf(CM_Container) then
		isoCode := ti.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	endif;
	self.makeEQDSegment(_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus);    //23/08/2017 cnwma1 TFS #5834
	_camMessage.eqdCount := _camMessage.eqdCount + 1;
	
	// RCVE - RFF+CN
	if isRCVE then
		if ti.myVoyage &lt;&gt; null and ti.myVoyage.myShippingLine &lt;&gt; null then
			self.makeRFFSegment(_camProtocol, _camMessage.group5, "CN", ti.myVoyage.myShippingLine.code);
		endif;
		
	// RCEX, RCVF, SNTC, SNTS, TRFE - RFF+BN
	//elseif isRCEX or isRCVF or isSNTC then																// TFS 50075
	elseif isRCEX or isRCVF or isSNTC or isSNTS or isTRFE then												// TFS 50075
		self.makeMessageRFF_BN(_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);
	endif;
	
	// TFS 50075 SNTS, TRFE - RFF+RE																		// TFS 50075
	if isSNTS or isTRFE then																				// TFS 50075
		self.makeMessageRFF_RE(_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// TFS 50075
	endif;																									// TFS 50075
	
	// DTM segment for everyone
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754
	
	// RCEX, RCVF, SNTC - LOC+11
	ourCode := _terminal.getConfig(PortDestCode).String;
	if isRCEX or isRCVF or isSNTC then
		code := ti.dischargePort;
		if code &lt;&gt; null then
			pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
			self.makeLOCSegment(_camProtocol, _camMessage.group5, '11', pCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	// RCEX, RCVF, TRFE (after TFS 51572) - LOC+9
	//if isRCEX or isRCVF then				// TFS 51572
	if isRCEX or isRCVF or isTRFE then		// TFS 51572
		code := ti.loadPort;
		if isTRFE then						// TFS 51572
			code := ti.dischargePort;		// TFS 51572
		endif;								// TFS 51572
		if code = null then
			code := ourCode;
		endif;
		if code &lt;&gt; null then
			pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
			self.makeLOCSegment(_camProtocol, _camMessage.group5, '9', pCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	// RCVF, SNTS, TRFE - LOC+8
	if isRCVF or isSNTS or isTRFE then
		if isSNTS then
			pCode := "00UNK";
		else
			// TFS 50554 For TRFE, LOC+8 should be the depot destination code from the CAM group, not the destination port
			if isRCVF then											// TFS 50554
				code := ti.destinationPort;
				if code &lt;&gt; null then
					pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
				endif;
			//elseif isTRFE then									// TFS 50554	// TFS 51921
			//	pCode := _camProtocol.camGroup.senderCodeDepot;		// TFS 50554	// TFS 51921
			//endif;												// TFS 50554	// TFS 51921
			// TFS 51921 If this is a TRFE from Depot to Marine, LOC+8 is the sender code depot from the CAM protocol
			// If this is a TRFE from Marine to Depot, LOC+8 is the sender code terminal from the Depot CAM protocol
			elseif isTRFE then
				if _transaction.type = TRANS_TYPE_REC_ST_MARINE_INT then
					app.writeLog(method.qualifiedName &amp; Tab &amp; "transaction for " &amp; _transaction.myTrackedItem.id &amp; " is a " &amp; _transaction.typeString &amp; " - setting LOC+8 to " &amp; _camProtocol.camGroup.senderCodeDepot, LogDEBUG);
					pCode := _camProtocol.camGroup.senderCodeDepot;
				elseif _transaction.type = TRANS_TYPE_REC_ST_DEPOT_INT then
					app.writeLog(method.qualifiedName &amp; Tab &amp; "transaction for " &amp; _transaction.myTrackedItem.id &amp; " is a " &amp; _transaction.typeString, LogDEBUG);
					foreach protocol in _camProtocol.terminal.camProtocols discreteLock where protocol.depotActivity and protocol.camGroup.shippersCode = "SSL" do
						pCode := protocol.camGroup.senderCode;
						app.writeLog(method.qualifiedName &amp; Tab &amp; "setting LOC+8 to " &amp; protocol.camGroup.senderCode &amp; " from protocol " &amp; protocol.code &amp; " and cam group " &amp; protocol.camGroup.code, LogDEBUG);
						break;
					endforeach;
				endif;
			endif;
			// TFS 51921 end
		endif;
		if pCode &lt;&gt; null then
			self.makeLOCSegment(_camProtocol, _camMessage.group5, '8', pCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	// everyone - LOC+165
	// Depot gets a location code of "STO", marine gets a location code of "TER"
	// RCVE, SNTS, TRFE uses Sender Depot code from Cam Group as relLoc
	// RCEX, RCVF, SNTC uses the sub-terminal code for Marine as relLoc
	if isRCVE or isSNTS or isTRFE then
		location := "STO";
		relLoc := _camProtocol.camGroup.facilityCode;
	else
		location := "TER";
		relLoc := self.getSubTermCodeForRecRel(isRCEX, isRCVF, isSNTC, _transaction, ti);
	endif;
	pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, ourCode, XLATION_TYPE_PORT_BYOP, _terminal);
	self.makeLOCSegment(_camProtocol, _camMessage.group5, '165', pCode, '139', '6', relLoc, location, "184"); 
	
	// everyone but RCVE - MEA+
	if not isRCVE then
		if _secondTrx &lt;&gt; null then	
			self.makeMEASegment(_camProtocol, _camMessage.group5, self.getMeasurementQualifier() , "G", "KGM", _secondTrx.totalWeight);
		else
			self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null);
		endif;
		if ti.weightTare &lt;&gt; 0 then
			self.makeMEASegment(_camProtocol, _camMessage.group5, 'AAE', 'T', 'KGM', ti.weightTare);	
		endif;	
	endif;
	
	// RCVE and TRFE - FTX+DAR and FTX+ABS
	if isRCVE or isTRFE then
		self.makeMessageFTX_Damage(_camProtocol, _camMessage.group5, ti);
		if ti.isContainer then
			self.makeMessageFTX_ABS(_camProtocol, _camMessage.group5, ti.CM_Container);
		endif;
	endif;
	
	// TRFE - FTX+OSI
	if isTRFE then
		self.makeMessageFTX_OSI(_camProtocol, _camMessage.group5, ti);
	endif;
	
	// RCEX, RCVF and SNTC - TDT+20 in group 7
	voyage := ti.myVoyage;
	voyageCode := ti.voyageCode;
	if voyage &lt;&gt; null then
		operatorCode := voyage.operatorCode;
	endif;
	foreignCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, operatorCode, XLATION_TYPE_CARRIER_BYOP, _camProtocol.terminal);
	if foreignCode = null then
		carrierCode := operatorCode;
	else
		carrierCode := foreignCode;
	endif;
	if voyageCode &lt;&gt; null and voyage.vesselName &lt;&gt; null then
		if _camProtocol.camGroup.useCallSign then
			self.makeTDT20SegmentGroup7(_camProtocol, voyageCode, '1', null, carrierCode, '172', '184', null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper, _camMessage.group5);
		else
			self.makeTDT20SegmentGroup7(_camProtocol, voyageCode, '1', null, carrierCode, '172', '184', null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper, _camMessage.group5);
		endif;
	else
		self.makeTDT20SegmentGroup7(_camProtocol, voyageCode, '1', null, carrierCode, '172', '184', null, null, null, '146', null, null, _camMessage.group5);
	endif;
	
	// RCVE, SNTS and TRFE - TDT+1
	if isRCVE or isSNTS or isTRFE then
		self.makeMessageTDT1Segment(_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti);
	endif;
	
	// RCVF - SEL+
	if isRCVF then
		self.makeMessageSealsData(ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
	endif;
	
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeTDT1Segment" id="e4363ca8-393b-4d49-a1b8-0cbdd5500d60">
        <source>makeTDT1Segment(	_protocol: CM_CamProtocol; 
					_group: HugeStringArray input; 
					_ref: String; 
					_mode: String; 
					_means: String; 
					_carrier: String; 
					_carrierQual: String; 
					_carrierAgency: String; 
					_direction: String; 
					_excess: String; 
					_transportMeansID: String; 
					_transportQual: String; 
					_transportAgency: String; 
					_transportID: String	) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
//
constants
	MESSAGE	= "TDT";
	STAGE = "1";

vars
	msg	:String;
	plus, colon, singleQuote	:Character;

begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; STAGE;
	if _ref = null and _mode = null and _means = null and _carrier = null and _carrierQual = null and _carrierAgency = null and
		_direction = null and _excess = null and _transportMeansID = null and _transportQual = null and _transportAgency = null and _transportID = null then
	else
		msg := msg &amp; plus &amp;
				_ref &amp; plus &amp;
				_mode &amp; plus &amp; 
				_means &amp; plus &amp; colon &amp; colon &amp; colon &amp;
				_carrier &amp; plus &amp; 
                _carrierQual &amp; plus &amp;
                _carrierAgency &amp; plus &amp; colon &amp; colon &amp; colon &amp;
				_transportID;
	endif;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_direction" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansID" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTDT20SegmentGroup7" id="66b878cf-8d98-44de-b13b-2cb6500f1a65">
        <source>makeTDT20SegmentGroup7(	_camProtocol : CM_CamProtocol; _voyageCode : String; 
						_mode, _means, _carrierCode, _carrierQual, _carrierAgency,
						_direction, _excess, _transportMeansId, _transportQual,
						_transportAgency, _transportId : String;
						_camGroup : HugeStringArray	input	) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
// 18/09/2020	jlgdap1		TFS 50071 TML Swire Message TDT+20 - Voyage code field max 17 chars
//
constants
	MESSAGE = "TDT";
	STAGE = "20";
	
vars
	msg	: String;
	plus, colon, singleQuote : Character;
	voyCode : String;					// TFS 50071

begin
	plus		:= _camProtocol.elementSeparator;
	colon		:= _camProtocol.subElementSeparator;
	singleQuote	:= _camProtocol.segmentTerminator;
	
	voyCode := _voyageCode[1:17];		// TFS 50071
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE &amp; plus &amp; 
			voyCode &amp; plus &amp;			// TFS 50071
			_mode &amp; plus &amp; 
			_means &amp; plus &amp;
			_carrierCode;
	
	if _carrierQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierQual;
	endif;

	if _carrierAgency &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierAgency;
	endif;
	
	msg := msg &amp; plus &amp; 
			_direction &amp; plus &amp;
			_excess &amp; plus &amp;
			_transportMeansId;
			
	if _transportQual &lt;&gt; null then
		msg := msg &amp; colon &amp; 
				_transportQual &amp; colon &amp; 
				_transportAgency &amp; colon &amp; 
				_transportId;
	endif;
	
	msg := msg &amp; singleQuote;
	if _camGroup &lt;&gt; null then
		_camGroup.add(msg);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_direction" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansId" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportId" type="String"/>
        <Parameter name="_camGroup" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="6abe42d8-f1f5-4bae-858a-44e5c4a083f0">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj: CM_Object; _transactions: CM_TITransactionSet) updating;
//
// Purpose:			Re-implemented so we can skip outputting a TDT+20 header - TML want this in group 5, not in the header
//					So this method is a copy of teh superclass method, without calling makeMessageTDT20Segment
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Ouotgoing EDI Depot and Terminal
// 11/11/2020	jlgdap1		TFS 50308 TML Swire Outbound EDI Message Structure Adjustment
// 23/12/2020	jlgdap1		TFS 50308 TML Swire Outbound EDI Message Structure Adjustment
//
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	una, unb : String;
	headerColl, trailerColl : HugeStringArray;	
	strLine : String;

begin
	app.writeLog("===================================", LogWARN);
	
	// UNA Segment
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);
	strLine := strLine &amp; una;
	//UNB header	
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null, _contextObj);
	strLine := strLine &amp; unb;
	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				if camMessage.group3.size = 0 and camMessage.group5.size = 0 then
					continue;
				endif;
				
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;

				// UNH/BGM header
				app.writeLog("cam message activity is " &amp; self.getMessageTypeString(camMessage.activity), LogINFO);
				strLine := strLine &amp; self.outputHeader_UNH_BGM (camMessage, _camTaskHistory, _camFile, _unhSeqNumber, headerColl);
				
				camMessage.segmentCount := camMessage.segmentCount + 1;

				//RFF header
				strLine := strLine &amp; self.outputHeader_RFF(_protocol, _camTaskHistory, camMessage, headerColl);
				//LOC1 header
				strLine := strLine &amp; self.outputHeader_LOC(_protocol, camMessage, _camTaskHistory, _terminal, headerColl);

				//NAD header
				strLine := strLine &amp; self.outputHeader_NAD(_protocol, camMessage, _camTaskHistory, headerColl);

				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);

				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);
				
				camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
			endforeach;
		endforeach;
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);

epilog

end;</source>
