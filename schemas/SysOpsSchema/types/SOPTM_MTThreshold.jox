    <JadeMethod name="setupThumbnailDetails" id="96759f1c-f842-4c6e-9637-2d0d75567af8">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	theForm : SOP_TableMaintForm;

begin
	
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_MTThresholdDisp);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_MTThresholdMaint);
	theForm.shtTblInput1.visible := true;
	
	theForm.myAssistant.comboBoxOperator(theForm.cmbOperator, null, null);
	theForm.myAssistant.comboBoxISOTypeGroup(theForm.cmbISOTypeGroup, null);
	theForm.myAssistant.comboBoxMTGrade(theForm.cmbGrade, null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="c5f4299b-f0ca-4301-abcf-f54f924f6012">
        <updating/>
        <source>showThumbnail( _threshold : CM_MTThreshold ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who			Reason
16 June 2011	cnwndl1	Initial creation	Par 27731
29 Aug 2017		cnwma1 		TFS #5624 JMT- Error appearing when opening Terminal Admin 'MT Threshold Details' table
28 July 2022 	navvt20 		Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
28 Jan 2024		navnk30		JIRA 33759: Delete MT threshold details
*/
vars
	idx			: Integer;
	operStr		: String;
	operator	: CM_Operator;
	cmbOperator	: CMUI_ComboBox;
	theForm		: SOP_TableMaintForm;
begin
	
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	theForm.tblInput1.setValueByName(ETRow_IsActive, _threshold.isActive);
	theForm.tblInput1.setValueByName(ETRow_LastNotified, _threshold.lastNotified);
	theForm.tblInput1.setValueByName(ETRow_MaxLevel, _threshold.maxThresholdLevel);
	theForm.tblInput1.setValueByName(ETRow_MinLevel, _threshold.minThresholdLevel);
	theForm.tblInput1.setValueByName(ETRow_Priority, _threshold.processingPriority);
	theForm.tblInput1.setValueByName(ETRow_ReNotifyMins, _threshold.reNotificationMinutes);
	
	operator := _threshold.myOperator;					//28.01.2024 navnk30 #33759 START
	cmbOperator := theForm.cmbOperator;
	if operator &lt;&gt; null and cmbOperator.findObject(operator) &lt; 1 then
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			operStr := operator.description &amp; Tab &amp; operator.code;
		else
			operStr := operator.code &amp; Tab &amp; operator.description;
		endif;
		idx := cmbOperator.addItem(operStr);
		cmbOperator.itemObject[idx] := operator;
	endif;												//28.01.2024 navnk30 #33759 END
	theForm.cmbOperator.listObject := _threshold.myOperator;

	if _threshold.myOperator = null then	
		theForm.tblInput1.setValueByName(ETRow_MyOperator, app.getErrorString(AnyString) );
	else
		//theForm.tblInput1.setValueByName(ETRow_MyOperator, _threshold.myOperator.code);  // 28.07.2022 navvt20 TFS 54199
		
		// START 28.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean  then    
            theForm.tblInput1.setValueByName(ETRow_MyOperator, _threshold.myOperator.description);                                                    
		else
			theForm.tblInput1.setValueByName(ETRow_MyOperator, _threshold.myOperator.code);
        endif;                                                                                   
        // END 28.07.2022 navvt20 TFS 54199
	endif;
	
	//theForm.cmbGrade.listObject := _threshold.myMTGrade; //29.08.2017 cnwma1 TFS #5624
	theForm.cmbGrade.setObject(_threshold.myMTGrade);      //29.08.2017 cnwma1 TFS #5624
	if _threshold.myMTGrade = null then
		theForm.tblInput1.setValueByName(ETRow_MyMTGrade, app.getErrorString(AnyString) );
	else		
		theForm.tblInput1.setValueByName(ETRow_MyMTGrade, _threshold.myMTGrade.code.String &amp; "      " &amp; _threshold.myMTGrade.description);
	endif;
	
	theForm.cmbISOTypeGroup.listObject := _threshold.myISOTypeGroup;
	if _threshold.myISOTypeGroup = null then
		theForm.tblInput1.setValueByName(ETRow_MyISOGroup, app.getErrorString(AnyString) );
	else		
		theForm.tblInput1.setValueByName(ETRow_MyISOGroup, _threshold.myISOTypeGroup.code &amp; "      " &amp; _threshold.myISOTypeGroup.description);
	endif;
//	

epilog

end;</source>
        <Parameter name="_threshold" type="CM_MTThreshold"/>
    </JadeMethod>
</Class>
