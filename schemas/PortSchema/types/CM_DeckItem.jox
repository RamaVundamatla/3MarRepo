    <JadeMethod name="setCode" id="49dec8fd-ddb3-412e-a30e-c9ec46b1378e">
        <updating/>
        <source>setCode(_code : String; _syncLayoutCode : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars

begin
	self.code := _code;
	
	if _syncLayoutCode and self.myLayout &lt;&gt; null then	//21 Jul 2016	NDL	TFS 2371
		self.myLayout.setCode(_code);
	endif;
epilog

end;</source>
