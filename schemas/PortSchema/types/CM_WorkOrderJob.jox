    <JadeMethod name="getRailCarrier" id="8c6a9061-614f-4b72-b9ee-0bbf5029fff3">
        <source>getRailCarrier():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jun 2023	navhl20	ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
27 Jun 2023	navma1	Defect 58904: MTN - Carrier/Sub Carrier is not populated for the Rail Jobs
*/

vars
	wod 	: CM_WorkOrderDtl;
	carrier : CM_Carrier;
begin
	
	if self.myWODtl &lt;&gt; null then
		wod := self.myWODtl;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then
		wod := self.myWorkOrderDtlToDo;
		
	endif;
	if wod &lt;&gt; null then
		carrier := wod.getCarrier();
	endif;
	if carrier &lt;&gt; null then
		return carrier.code &amp; Space &amp; carrier.description;
	endif;
	
epilog

end;</source>
