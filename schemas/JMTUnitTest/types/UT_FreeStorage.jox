    <JadeMethod name="moveAndCheckFreeExp" id="ffb1599f-aec6-4440-85ba-81f642faa74b">
        <source>moveAndCheckFreeExp(_voyage : CM_Voyage; _day : Integer; _lc : CM_LocationsController; _addDays : Integer);
/*
Purpose:	

Date		Who		Reason
// ### TFS BUG 65740 21AUG2024 NAVAB1
*/

vars
	moveTS, now : TimeStamp;
	ti : CM_TrackedItem;
	freeExp, expectedDate : Date;
begin
	moveTS.setDate(now.date.getNearestDay(_day));
	self.opts.addAssoc("effectiveTS", moveTS);
	
	ti := _voyage.allOnshipTIsByCargoTypeId.first;
	self.deleteStops(ti);
	self.instantMove(ti, _lc);

	 freeExp := ti.getFreeStorageExpiryDate();
	 expectedDate := moveTS.addDays(_addDays).date; // includes first day
	self.assertTrueMsg(ti.receivedDT.date = moveTS.date, "RECEIVE for " &amp; moveTS.date.dayName() &amp; " is Wrong");
	self.assertTrueMsg(freeExp = expectedDate,"FREE EXPIRY for " &amp; moveTS.date.dayName() &amp; " is Wrong. SBE " &amp; expectedDate.String &amp; " is " &amp; freeExp.String);

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_day" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_addDays" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFutureActorTS" id="92710bf4-b74f-438b-a5a2-f0882ed16e66">
        <source>setFutureActorTS(_parent : CM_Object; _ts : TimeStamp) protected;
// used when back-dating transactions to back-date any associated future actors to match
// do CM_OfflineFutureActorInserter and CM_FutureStorageProcess in case there is a future background running.

/*
------------------------------------------------------------------------
Date		Who		TFS		Reason
------------------------------------------------------------------------
28 Feb 2019	jlgdi1	43372	Added isValidObject - for some reason there are items that has invalid object reference
------------------------------------------------------------------------
*/
vars
	hadException	: Boolean;
	actor		: CM_OfflineFutureActorInserter;
	futureActor	: CM_OfflineFutureActor;
	futureStorageActor	: CM_FutureStorageProcess;
	root		: CM_Root;
	iter		: Iterator;
	parent		: CM_Object;
	actors			: ObjectArray;
	obj				: Object;
	
begin

	on Exception do app.handleDeletedObject(exception, futureStorageActor, hadException);

	create actors transient;
	CM_OfflineFutureActorInserter.allInstances(actors, 0, false);
	
	foreach obj in actors do
		hadException := false;
		actor := obj.CM_OfflineFutureActorInserter;
		// CM_FreeStorageExpiryStopCreate here as well
		if actor.myOfflineFutureActor.isKindOf(CM_FutureStorageProcess) then
			futureStorageActor := actor.myOfflineFutureActor.CM_FutureStorageProcess;
			
			if global.isValidObject(futureStorageActor) then 
			
				parent := futureStorageActor.myParentObject;
				if hadException then
					continue;
				endif;
				if parent = _parent then
					futureStorageActor.setActionTimeStamp(_ts);
				endif;
				
			endif;
		endif;
	endforeach;

	root := app.myRoot;

	on Exception do null;		// deactivate previous exception handling
	on Exception do app.handleDeletedObject(exception, futureActor, hadException);

	iter := root.allOfflineFutureActorParents.createIterator();
	root.allOfflineFutureActorParents.startKeyGeq(_parent, iter);
	while iter.next(futureActor) do
		if futureActor.myParentObject &lt;&gt; _parent then
			break;
		endif;
		futureActor.setActionTimeStamp(_ts);
	endwhile;

epilog
	delete actors;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setRates" id="f577a5b6-32ac-4d9e-8e6b-0737f637f4ba">
        <source>setRates(_debtor : CM_Debtor; _services : CM_ServiceByNameDict) protected;
// set the initial rates for future storage testing
vars
	lineCount	: Integer;
	service		: CM_Service;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costValue	: Decimal[8,2];
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	transients	: ObjectArray;

begin
	create transients transient;

	debtor := _debtor;

	create costs transient;
	foreach service in _services do
		lineCount := lineCount + 1;
		costs.clear();
		if lineCount = 1 then
			costValue := 3;		
		elseif lineCount = 2 then
			costValue := 4;		
		elseif lineCount = 3 then
			costValue := 5;		
		endif;

		costs.add(costValue);
		start.setDate("31/01/2010".Date);
		start.setTime("00:00".Time);
		expiry := null;
		debtorRate := debtor.serviceRates[service];
		if debtorRate = null then
			create debtorRate transient;
			debtorRate.setProxy(service, debtor);
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
			transients.add(debtorRate);
		else
			rateEntry := debtorRate.rateEntries.first;
			self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, ignoreEntry, costs, 0, 0, null,null);
		endif;
		self.assertNoTrxErrorsOrWarnings();
	endforeach;


epilog

	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete costs;
end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDate" id="7046a6e5-d8b0-489f-a0c1-4462aa751c67">
        <updating/>
        <source>setTransactionDate(realTI : CM_TrackedItem input; baseDate : Date) updating;
// same as the super-class except that it sets an explicit time for the receive and storage transactions
vars
	time	: Time;
	orderNo	: Integer;
	difference	: Integer;
	tranDate,
	now	: Date;
	tran : CM_TITransaction;
	startTran,
	startStartTran	: CM_TITransaction;
	tranTS : TimeStamp;
begin
	time := "12:00".Time;
	// set transaction date to base date, if not already done
	// handle free storage days CM_Storage - do a pre-pass to get the free days storage date difference from the receive transaction
	foreach tran in realTI.allTransactions do
		if tran.orderNo &gt; orderNo then
			orderNo := tran.orderNo;
		endif;
		if tran.isKindOf(CM_Storage) then
			startTran := tran.CM_Storage.startTransaction;
			if startTran &lt;&gt; null and
			   startTran.isKindOf(CM_Storage) and
			   startTran.noCharge = true then
				startStartTran := startTran.CM_Storage.startTransaction;
				if startStartTran &lt;&gt; null then
					difference := startTran.dateTime.date - startStartTran.dateTime.date;
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	foreach tran in realTI.allTransactions do
		if tran.dateTime.date = now then
			tranTS.setDate(baseDate);
			tranTS.setTime(tran.dateTime.time);
			// set an explicit time on receive and storage transactions for the 'days onsite at' calculations
			if tran.isKindOf(CM_Receive) or
			   tran.isKindOf(CM_Storage) then
				tranTS.setTime(time);
			endif;
			orderNo := orderNo + 1;
			beginTransaction;
			tran.setPropertyValue("orderNo", orderNo);
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
			if tran.isKindOf(CM_ReceiveShip) and
			   self.loadStart = null then
				self.loadStart := tran.dateTime;
			endif;
			if tran.isKindOf(CM_ReleaseShip) then
				self.unloadEnd := tran.dateTime;
			endif;
		// handle free storage days CM_Storage - apply the difference found above
			if tran.isKindOf(CM_Storage) then
				startTran := tran.CM_Storage.startTransaction;
				if startTran &lt;&gt; null and
				   startTran.isKindOf(CM_Storage) and
				   startTran.noCharge = true and
				   difference &gt; 0 then
					startStartTran := startTran.CM_Storage.startTransaction;
					if startStartTran &lt;&gt; null then
						tranTS.setDate(startStartTran.dateTime.date + difference);
						tranTS.setTime(startTran.dateTime.time);
						beginTransaction;
						startTran.setPropertyValue("dateTime", tranTS);
						commitTransaction;
					endif;
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="baseDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCargoCommodity" id="d8debb11-2989-45d1-8377-6f4ba7403861">
        <source>setVoyageCargoCommodity(_voyage : CM_Voyage) protected;
/*

Purpose:			The transaction map for tests using this method has a number of invoice line types for each per-day calculation type
					loaded against commodities UT_A through UT_H.  Each import and export cargo item is assigned the next commodity in turn,
					except for UT_B which corresponds to an export-only calculation type and UT_C which corresponds to an import-only calc type.
					Two containers have 'tweaked' commodities to ensure that there are 'days since first discharge' and 'days since last load'
					for each of the two days involved in these activities.
					Reefers keep their commodity of REEF.

Date		Who		Reason
04 October 2012	cnwjre1	Initial creation

*/

vars
	count,
	index,
	size		: Integer;
	commod		: String;
	importComms	: StringArray;
	exportComms	: StringArray;
	ti			: CM_TrackedItem;
begin

	create exportComms transient;
	exportComms.add("UT_A");
	exportComms.add("UT_B");
	exportComms.add("UT_D");
	exportComms.add("UT_E");
	exportComms.add("UT_F");
	exportComms.add("UT_G");
	exportComms.add("UT_H");
	size := exportComms.size;
	
	foreach ti in _voyage.allExportTIs where not ti.isReefer do
		index := index + 1;
		if index &gt; size then
			index := 1;
		endif;
		count := count + 1;
		commod := exportComms[index];
		if ti.id = 'XDOD8X99005' then		// make sure there are 'days since last load' containers for both days
			commod := 'UT_B';
		endif;
		self.opts.purge;
		self.opts.addAssoc("Commodity", commod);
		self.updateTI(ti);
	endforeach;

	create importComms transient;
	importComms.add("UT_A");
	importComms.add("UT_C");
	importComms.add("UT_D");
	importComms.add("UT_E");
	importComms.add("UT_F");
	importComms.add("UT_G");
	importComms.add("UT_H");
	size := importComms.size;
	
	index := 0;
	count := 0;
	foreach ti in _voyage.allImportTIs where not ti.isReefer do
		index := index + 1;
		if index &gt; size then
			index := 1;
		endif;
		count := count + 1;
		commod := importComms[index];
		if ti.id = 'GENL4X22446' then		// make sure there are 'days since first discharge' containers for both days
			commod := 'UT_C';
		endif;
		self.opts.purge;
		self.opts.addAssoc("Commodity", commod);
		self.updateTI(ti);
	endforeach;

epilog
	delete importComms;
	delete exportComms;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupCalendar" id="527fc2f0-ccc7-487f-89aa-8e318152411a">
        <source>setupCalendar() : CM_Calendar protected;
// cnwjre1 CCMS 1295 free storage days
//  setup a storage calendar with known weekends and holiday dates, for a set period
vars
	calendar		: CM_Calendar;
	startDate		: Date;

begin
	self.deleteCalendar("UTSC", "UTDAY");
	
	// set up the storage calendar for 2012 with weekends (Saturday and Sunday) and at least one holiday in the period covered in cargo storage
	//  which is June/July/August
	calendar := self.createCalendar("UTSC", "Unit test storage calendar", false, false, "UTDAY");
	startDate := "07/01/2012".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 51, "Saturday");
	startDate := "01/01/2012".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 52, "Sunday");
	startDate := "22/06/2012".Date;		// a Friday
	self.addSingleCalendarDate(startDate, "Holiday1", calendar);
	startDate := "09/07/2012".Date;		// a Monday
	self.addSingleCalendarDate(startDate, "Holiday2", calendar);
	startDate := "07/08/2012".Date;		// a Tuesday
	self.addSingleCalendarDate(startDate, "Holiday3", calendar);
	
	return calendar;
epilog

end;
</source>
        <access>protected</access>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setupCalendar2" id="024d1b1e-c479-4399-856f-1064abb816fe">
        <source>setupCalendar2() : CM_Calendar protected;
// cnwjre1 CCMS 1295 free storage days
//  setup a storage calendar with known weekends only, this year and next
vars
	calendar		: CM_Calendar;
	startDate		: Date;

begin
	self.deleteCalendar("UTS2", "UTDAY2");
	
	// set up the storage calendar for all of 2012 and 2013 with weekends (Saturday and Sunday)
	//  ** extend this in the future **
	calendar := self.createCalendar("UTS2", "Unit test storage calendar", false, false, "UTDAY2");
	startDate := "31/12/2011".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 52, "Saturday");
	startDate := "01/01/2012".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 52, "Sunday");

	startDate := "5/01/2013".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 51, "Saturday");
	startDate := "06/01/2013".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 51, "Sunday");

	return calendar;
epilog

end;
</source>
        <access>protected</access>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setupStorageConfig1" id="338a1dee-24de-4769-a8e1-71e7db086731">
        <source>setupStorageConfig1(_calendar : CM_Calendar; _includeFirstDay : Boolean; _includeLastDay : Boolean; _shipReceivalType : Integer; _shipReleaseType : Integer; _chargedDaysWorking : Boolean;
					_freeDaysWorking : Boolean; _deriveDebtorFrom : CM_DebtorType; _triggers : CM_StorageTriggerByType; _createDetails : Boolean) : CM_StorageConfig protected;
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with entered options, hard-coded calendar and criteria
vars
	storageConfig	: CM_StorageConfig;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;
	criteria	: IntegerArray;
	values		: ObjectArray;
	allTransients	: ObjectArray;
	slobField	: CM_SlobField;

begin
	self.deleteStorageConfig( false );
	
	// set up the storage config
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);

	storageConfig := self.createStorageConfig(criteriaTypes, _triggers, _deriveDebtorFrom, firstDayTimeCutoff, _includeFirstDay, _includeLastDay,
											  lastDayTimeCutoff, _shipReceivalType, _shipReleaseType, _calendar, null,null, -1, -1, -1);

	if not _createDetails then
		return storageConfig;
	endif;

	create allTransients transient;
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	criteria.add(YACriteriaType_Commodity);
	criteria.add(YACriteriaType_ContainerLength);
	criteria.add(YACriteriaType_ContentsStatus);
	criteria.add(YACriteriaType_ImexStatus);
	create values transient;
	values.add(self.getCargoType("CONT"));
	values.add(self.getCommodity("GENL"));
	create slobField transient;
	allTransients.add(slobField);
	slobField.setValueFromString("20");
	values.add(slobField);
	values.add(app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL]);
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT GENL 20 FCL Storage", criteria, values, 30, 30, _chargedDaysWorking, _freeDaysWorking, 0,0,false,null);	// TFS 2570 //21.07.2017 cnwma1 TFS #5409
	values.clear();
	values.add(self.getCargoType("CONT"));
	values.add(self.getCommodity("MT"));
	create slobField transient;
	allTransients.add(slobField);
	slobField.setValueFromString("20");
	values.add(slobField);
	values.add(app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_EMPTY]);
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT MT 20 Empty Storage", criteria, values, 45, 30, _chargedDaysWorking, _freeDaysWorking, 0,0,false,null);	// TFS 2570 //21.07.2017 cnwma1 TFS #5409

	return storageConfig;
epilog
	
	delete criteriaTypes;
	delete criteria;
	delete values;
	if allTransients &lt;&gt; null then
		allTransients.purge();
		delete allTransients;
	endif;

end;
</source>
