    <JadeMethod name="addToolbarControls" id="e75de553-23f0-49db-ae56-bb9c5190613f">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		    Who			Reason
18 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
vars
	toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addFrame(self.frmToolbarCombos,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewChild, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditChild, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveNext, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteChild, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
