<GUIClass name="ExcelDefnWizStep4Form" id="5c792363-b3ff-4b99-a337-85b9ce8c7128">
    <superclass name="ExcelWorkbookDefnWizForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="groupBox1" id="e8701b6b-1b38-47d6-936f-99082124fb19">
        <embedded/>
        <type name="GroupBox"/>
    </ImplicitInverseRef>
