    <JadeMethod name="tblSelectData_contextMenu" id="663900b1-648e-4668-99d7-8180dd7660a1">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectData_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;
begin

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuTblSelDataContext, x1.Integer, y1.Integer);
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
