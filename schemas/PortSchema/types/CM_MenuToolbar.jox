    <JadeMethod name="setToolbar" id="a9f944d7-ccee-423f-ae09-a1af03598829">
        <updating/>
        <source>setToolbar(_pic, _downPic, _heading, _toolTip, _menuId : String; _type : Integer; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.pictureStringButton		:= _pic;
	self.pictureStringButtonDown	:= _downPic;
	self.heading 					:= _heading;
	self.menuId						:= _menuId;
	self.toolTip					:= _toolTip;
	self.type	 					:= _type;
	self.myRoot						:= _root;
	
end;</source>
        <Parameter name="_pic" type="String"/>
        <Parameter name="_downPic" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_toolTip" type="String"/>
        <Parameter name="_menuId" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
</Class>
