	self.gbxLogAfter.backColor := self.backColor;
	self.gbxLogBefore.backColor := self.backColor;
	self.gbxLogBetweenA.backColor := self.backColor;
	self.gbxLogBetweenB.backColor := self.backColor;
	self.lblAnd.backColor := self.backColor;
	self.lblAtAfter.backColor := self.backColor;
	self.lblAtBefore.backColor := self.backColor;
	self.lblAtBetwnA.backColor := self.backColor;
	self.lblAtBetwnB.backColor := self.backColor;
	self.lblAuditView.backColor := self.backColor;
	self.lblFilterApplied.backColor := self.backColor;
	self.lblFilterAvailab.backColor := self.backColor;
	self.lblFilterTitle.backColor := self.backColor;												
	self.optLoggedAfter.backColor := self.backColor;
	self.optLoggedBefore.backColor := self.backColor;
	self.optLoggedBetween.backColor := self.backColor;		
	
	self.setColorsForTable(self.tblDetails);
	self.setColorsForTable(self.tblResults);	
		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setSelectedItems" id="df33a181-92f8-4d06-a83e-2c9d7edef7e6">
        <source>setSelectedItems();
//--------------------------------------------------
// Created:	12 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	idx,
	tmpType : Integer;
	tmpSearcher : CMIF_HMS_AuditEnquiry;
	tmpUser : CM_User;
	tmpTerminal : CM_Terminal;
	tmpVessel : CM_Vessel;
	tmpTrans : HMS_Transaction;
	tmpExpand : Boolean;
begin
	tmpSearcher := self.myAuditEnquirySearcher;
	if tmpSearcher = null then
		return;
	endif;
	foreach tmpUser in tmpSearcher.allSelectedUsers do
		idx := self.lbxFiltersAvail.findObject(tmpUser);
		if idx &gt; 0 then
			self.lbxFiltersAvail.itemSelected[idx] := true;
			tmpExpand := true;
		endif;
	endforeach;
	foreach tmpTerminal in tmpSearcher.allSelectedTerminals do
		idx := self.lbxFiltersAvail.findObject(tmpTerminal);
		if idx &gt; 0 then
			self.lbxFiltersAvail.itemSelected[idx] := true;
			tmpExpand := true;
		endif;
	endforeach;	
	foreach tmpVessel in tmpSearcher.allSelectedVessels do
		idx := self.lbxFiltersAvail.findObject(tmpVessel);
		if idx &gt; 0 then
			self.lbxFiltersAvail.itemSelected[idx] := true;
			tmpExpand := true;			
		endif;
	endforeach;	
	
	cnt := self.lbxFiltersAvail.listCount;
	foreach tmpType in tmpSearcher.allSelectedTransactionTypes do
		idx := 1;
		while idx &lt;= cnt do
			if HMS_Transaction.hasInstance(self.lbxFiltersAvail.itemObject[idx]) then
				if self.lbxFiltersAvail.itemData[idx] = tmpType then
					self.lbxFiltersAvail.itemSelected[idx] := true;
					tmpExpand := true;					
				endif;
			endif;
			idx := idx + 1;
		endwhile;
	endforeach;
	idx := 1;
	foreach idx in 1 to cnt do
		self.lbxFiltersAvail.itemExpanded[idx] := tmpExpand;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="7b6a2ac7-b378-4430-82ea-60e31d8a9ec1">
