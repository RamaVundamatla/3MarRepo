    <JadeMethod name="trxDeleteXlation" id="6821e131-3445-4d4c-be7e-f64dba9d294d">
        <updating/>
        <source>trxDeleteXlation(_xlation: CM_Xlation io; _passport : CM_Passport input) updating;
/*
Date		Who		Reason
16 Dec 2008	conks1	Initial creation
12/03/2013	cnwcs5	CCMS POL 2097 / par 31259
*/
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Ensure that we serialize all updates
	self.reserveLock(_xlation);

	app.myUtilityDA.utlDeleteXlation(_xlation, _passport);
	
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_xlation" type="CM_Xlation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteXlations" id="0f5d57f0-bced-4589-a563-ad1ea8bf851e">
        <updating/>
        <source>trxDeleteXlations(_coll :ObjectArray; _passport :CM_Passport input)updating;
/*
Date		Who		Reason
25 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation			:Object;
	gotException	:Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	// we don't expect this trx to be widely used
	on Exception do app.handleDeletedObject (exception, xlation, gotException);
	
	foreach xlation in _coll do
		self.reserveLock(xlation);
		
		if gotException then
			gotException := false;
			
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteXlation(xlation.CM_Xlation, _passport);
	endforeach;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteYABlock" id="f6e46c1e-27b6-4567-b896-0516de4e8ebf">
        <updating/>
        <source>trxDeleteYABlock(_yaBlocks: CM_YABlockArray input; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 Aug 2008 by cnwdw1
//
// Purpose:		Delete yaBlocks from a Yard Allocation
//
// Parameters:	
//				_yaBlocks - The list of blocks to be deleted
//				_passport - A reference to the user's Passport object.
//
// Returns:		Nothing
vars
	yardAllocationObj	: CM_YardAllocation;
	yaBlock: CM_YABlock;
	location: CM_YardController;
	tmpTerm : CM_Terminal;
	allYAs : CM_ObjectSet;
	obj 	: Object;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	create allYAs transient;
	
	beginTransaction;
	
	// Delete the blocks
	foreach yaBlock in _yaBlocks do
		//epr par 27082 31/12/13
		yardAllocationObj:=yaBlock.myYardAllocationIn;
		if not allYAs.includes(yardAllocationObj) then
			allYAs.add(yardAllocationObj);
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, true);
		endif;
		foreach location in yaBlock.allYardControllers discreteLock do
			yardAllocationObj.allYardControllers.removeIfPresent(location);
		endforeach;
		
		delete yaBlock;
	endforeach;
	
	
	if _passport.noErrors() then
		//epr par 27082 31/12/13
		foreach obj in allYAs discreteLock do
			yardAllocationObj:=obj.CM_YardAllocation;
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, false);
			tmpTerm	:=	yardAllocationObj.myTerminal;
			if  tmpTerm &lt;&gt; null then			
				tmpTerm.causeEvent(tmpTerm.getTerminalEvent(Event_YardAllocationUpdate), false, yardAllocationObj);
			endif;
		endforeach;
		
	endif;


epilog
	delete allYAs;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_yaBlocks" type="CM_YABlockArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
