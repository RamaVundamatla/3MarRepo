					if nad3_1Function = CM_EDIPrenoteTI::weightCertifiedName.name then
						params.weightCertifiedName := _msgHelper.currentSubItem;
						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.weightCertifiedName := _msgHelper.currentSubItem;
						endif;
					endif;
					if nad3_1Function = CM_EDIPrenoteTI::weightCertifiedReference.name then
						params.weightCertifiedReference := _msgHelper.currentSubItem;
						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.weightCertifiedReference := _msgHelper.currentSubItem;
						endif;
					endif;
				endif;	
			endif;
		endif;
		if nad1_1Function = null and
		   nad2_1Function = null and
		   nad3_1Function = null then
			if _msgHelper.currentGroup = 2 then
				if nad1_1Code = "CA" then // carrier (sea)
					_msgHelper.setNextField();
				elseif nad1_1Code = "CZ" then //consignor
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						bookingHdr.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						bookingHdr.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					
					// 27/02/2014 cnwar2 #33519 - if nothing in first field, check third
					if bookingHdr.consignor = null then
						_msgHelper.setNextField();
						_msgHelper.setNextField();
						if params.mySenderOperator &lt;&gt; null then
							bookingHdr.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
						else
							bookingHdr.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
						endif;
					endif;
					if createPrenote and prenoteEDITI &lt;&gt; null then
						prenoteEDITI.consignor := bookingHdr.consignor;
					endif;
				elseif nad1_1Code = "FW" then  //freight forward
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						//bookingHdr.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
						bookingHdr.freightForwarder := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];	// 17/07/2013 cnwar2 #31784
					else
						//bookingHdr.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
						bookingHdr.freightForwarder := _msgHelper.currentSubItem.trimBlanks()[1:30];	// 17/07/2013 cnwar2 #31784
					endif;
					if createPrenote and prenoteEDITI &lt;&gt; null then
						prenoteEDITI.freightForwarder := bookingHdr.freightForwarder;
					endif;
				elseif nad1_1Code = "SH" then  //shipper (non standard! COSCO) PAR 18716 cnwgb1 26.5.09
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						bookingHdr.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						bookingHdr.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					if createPrenote and prenoteEDITI &lt;&gt; null then
						prenoteEDITI.consignor := bookingHdr.consignor;
					endif;
				endif;
			endif;
			if createPrenote then
				if nad1_1Code = "SPC" then		// Weighter
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					_msgHelper.setNextField();	
					params.weightCertifiedReference := _msgHelper.currentSubItem;
					if prenoteEDITI &lt;&gt; null then
						prenoteEDITI.weightCertifiedReference := _msgHelper.currentSubItem;
					endif;
				elseif nad1_1Code = "AM" then		// Container operator!
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					_msgHelper.setNextField();		
					params.weightCertifiedName := _msgHelper.currentSubItem;
					if prenoteEDITI &lt;&gt; null then
						prenoteEDITI.weightCertifiedName := _msgHelper.currentSubItem;
					endif;
				endif;
			endif;
		endif;
//RFF
	elseif _msgHelper.currentTag = "RFF" then
		_msgHelper.setNextField();
		rff1_1Code := _msgHelper.currentSubItem;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, rff1_1Code, segmentValue);
/*			if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ACW then
				rff1_1Code := "ACW";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ANN then
				rff1_1Code := "ANN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_BN then
				rff1_1Code := "BN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RE then
				rff1_1Code := "RE";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_REO then
				rff1_1Code := "REO";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_SQ then
				rff1_1Code := "SQ";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_VON then
				rff1_1Code := "VON";
			endif;*/
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking then
					rff1_1Function := CM_EDIPrenoteTI::bookingRef.name;
					if _msgHelper.currentGroup = 0 then
						if bookingHdr &lt;&gt; null then //finish any previous bookingref 
							bookingHdr.rawEDIData := params.rawEDIData;
						endif;
						params.rawEDIData := null;
						// for a new line in the EDI file, we need to set this to null. Par 18495, Jan 2009
						if bookingItem = null or
						   (bookingItem &lt;&gt; null and 
						   not bookingItem.isIdDefault) then
							create bookingItem persistent;
							params.myEDIBookingItemTI := bookingItem;
							bookingItem.setForCreateNew(_ediData);
						endif;
						//reset this on each new ti	
						_msgHelper.setNextSubItem();
						bookingRefId := _msgHelper.currentSubItem[1:30];
						params.currentBrID := bookingRefId; //cnwrs1 CCMS 1882 24 May 2010
						self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
						if bookingRefId &lt;&gt; null then
							params.currentBrID := bookingRefId;
						endif;
						if bookingHdr = null or 
						   bookingHdr.isIdDefault or
						   bookingHdr.id &lt;&gt; params.currentBrID then
							if bookingHdr = null or 
							   (bookingHdr &lt;&gt; null and 
							   bookingHdr.id &lt;&gt; params.currentBrID and
							   not bookingHdr.isIdDefault) then
								create bookingHdr persistent;
							endif;
							params.myEDIBookingHeaderTI := bookingHdr;
							bookingHdr.setForCreateNew(_ediData);
							bookingHdr.myParent := bookingHdr;	//cnwrs1 CCMS POL 2122 /par 28696 08 Dec 2011  
							bookingHdr.setId(params.currentBrID);
							bookingHdr.operatorCode := params.cargoOperatorCode[1:4];
							bookingHdr.senderCode	:= params.senderCode; // tfs43425
						endif;
						bookingItem.setId(params.currentBrID); //cnwrs1 CCMS 1882 24 May 2010
						bookingHdr.messageMode := _msgHelper.currentMessageMode;  // PAR 18685 cnwgb1 19.12.08
						bookingHdr.ediFileIssueDateTime := params.ediFileIssueDateTime;	//Par 18495 (dupl 18685) Feb 2009
						bookingItem.myParent := bookingHdr;	//cnwrs1 CCMS POL 2122 /par 28696 08 Dec 2011  
					elseif _msgHelper.currentGroup = 7 then
						_msgHelper.setNextSubItem();
						bookingRefId := _msgHelper.currentSubItem[1:30];
						self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
						if bookingRefId &lt;&gt; null then
							bookingHdr.setId(bookingRefId);
							bookingItem.setId(bookingRefId);
							if prenoteEDITI &lt;&gt; null then
								prenoteEDITI.setBookingId(bookingRefId);
							endif;
						endif;
					endif;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_CustomerRef then
					rff1_1Function := CM_EDIPrenoteTI::clientRef.name;
					_msgHelper.setNextSubItem();
					params.clientRef := _msgHelper.currentSubItem[1:30];
					if prenoteEDITI &lt;&gt; null then
						prenoteEDITI.clientRef := params.clientRef;
					endif;
					if bookingHdr &lt;&gt; null then
						bookingHdr.customerRef := params.clientRef;
					endif;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_CarrierRef then
					rff1_1Function := CM_EDIBookingHeaderTI::carrierReference.name;
					_msgHelper.setNextSubItem();
					bookingHdr.carrierReference := _msgHelper.currentSubItem[1:30];
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_BOL then
					rff1_1Function := CM_EDIPrenoteTI::bol.name;
					_msgHelper.setNextSubItem();
					params.bolNumber := _msgHelper.currentSubItem[1:30];
					if prenoteEDITI &lt;&gt; null then
						prenoteEDITI.bol := params.bolNumber;
					endif;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Release then
					rff1_1Function := CM_EDIReleaseRequestTI::releaseRequestNumber.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Sequence then
					rff1_1Function := CM_EDIBookingItemTI::sequence.name;
					_msgHelper.setNextSubItem();
					bookingItem.sequence := _msgHelper.currentSubItem[1:12]; //cnwrs1 CCMS 1882 25 May 2010 ;cnwah9 PAR 32559 sequence is now 12 long for coparn bookings
				endif;
			endif;
		endif;
		if rff1_1Function = null then
			if _msgHelper.currentGroup = 0 then
				if rff1_1Code = "ACW" then
					_msgHelper.setNextSubItem();
				elseif rff1_1Code = "BN" or rff1_1Code = "ANN" then
					if bookingHdr &lt;&gt; null then //finish any previous bookingref 
						bookingHdr.rawEDIData := params.rawEDIData;
					endif;
					params.rawEDIData := null;
					// for a new line in the EDI file, we need to set this to null. Par 18495, Jan 2009
					
					create bookingItem persistent;
					params.myEDIBookingItemTI := bookingItem;
					bookingItem.setForCreateNew(_ediData);
					//reset this on each new ti	
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					params.currentBrID := bookingRefId; //cnwrs1 CCMS 1882 24 May 2010
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						params.currentBrID := bookingRefId;
					endif;
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
	/*				foreach idx in 1 to params.currentBrID.length do								
						charFounded := params.currentBrID[idx:1];
						if not charFounded.isInteger and not charFounded.toUpper.isUppercaseAlpha then
							charFounded:= charFounded;
							break;
						endif;
					endforeach;
					pos := params.currentBrID.pos(charFounded,1);
					if _ediPartyRules &lt;&gt; null then				
						ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, charFounded, segmentValue);
						if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RelNo then // Ignore Release No After Charchter
							if pos &gt; 0 then
								params.currentBrID :=_msgHelper.currentSubItem[1:30].truncatedAt(pos-1);
							else
								params.currentBrID := _msgHelper.currentSubItem[1:30];
							endif;
						endif;
					endif;*/
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351	
					
					if bookingHdr = null or 
					   bookingHdr.id &lt;&gt; params.currentBrID then
						create bookingHdr persistent;
						params.myEDIBookingHeaderTI := bookingHdr;
						bookingHdr.setForCreateNew(_ediData);
						bookingHdr.myParent := bookingHdr;	//cnwrs1 CCMS POL 2122 /par 28696 08 Dec 2011  
						bookingHdr.setId(params.currentBrID);
						bookingHdr.operatorCode := params.cargoOperatorCode[1:4];
						bookingHdr.senderCode	:= params.senderCode; // tfs43425
													
					endif;
					bookingItem.setId(params.currentBrID); //cnwrs1 CCMS 1882 24 May 2010
					bookingHdr.messageMode := _msgHelper.currentMessageMode;  // PAR 18685 cnwgb1 19.12.08
					bookingHdr.ediFileIssueDateTime := params.ediFileIssueDateTime;	//Par 18495 (dupl 18685) Feb 2009
					bookingItem.myParent := bookingHdr;	//cnwrs1 CCMS POL 2122 /par 28696 08 Dec 2011  
					
				else
				// par 12657 another undocumented command
					//Do Nothing
				endif;
			elseif _msgHelper.currentGroup = 7 then
				if rff1_1Code = "BN" or rff1_1Code = "ANN" then //booking ref
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						bookingHdr.setId(bookingRefId);
						bookingItem.setId(bookingRefId);
						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.setBookingId(bookingRefId);
						endif;
					endif;
				elseif rff1_1Code = "SQ" then //container seq number
					_msgHelper.setNextSubItem();
					bookingItem.sequence := _msgHelper.currentSubItem[1:12]; //cnwrs1 CCMS 1882 25 May 2010 ;cnwah9 PAR 32559 sequence is now 12 long for coparn bookings
					if app.myRoot.isClientJadeMaster or app.myRoot.isClientPortOtago then 
						if bookingHdr.operatorCode = "HSD" then 
							bookingItem.sequence := null;
						endif;
					endif;
				endif;
			endif;
		endif;
//SEL
    elseif _msgHelper.currentTag = "SEL" then
		if createPrenote and prenoteEDITI &lt;&gt; null then
			self.getSELData(_msgHelper, prenoteEDITI.sealNum, prenoteEDITI.sealShipper, prenoteEDITI.customsSeal, prenoteEDITI.sealTerminalOperator, prenoteEDITI.sealUnknown);
		endif;
//TDT	
	elseif _msgHelper.currentTag = "TDT" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);
		endif;
		if _msgHelper.currentGroup = 7 then
			_msgHelper.setCurrentGroup(9);
		endif;
		params.hazCommodityCodeHeader := null;					// 11/08/2011 cnwmh5 #27968
		params.hazundg := null;					// 11/08/2011 cnwmh5 #27968	
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "20" then
				if bookingHdr = null then
					create bookingHdr persistent;
					params.myEDIBookingHeaderTI := bookingHdr;
					bookingHdr.setForCreateNew(_ediData);
					bookingHdr.myParent := bookingHdr;	//cnwrs1 CCMS POL 2122 /par 28696 08 Dec 2011  			
					
					create bookingItem persistent; //cnwrs1 CCMS 1882 24 May 2010
					params.myEDIBookingItemTI := bookingItem;
					bookingItem.myParent := bookingHdr;	//cnwrs1 Par 27392  04 May 2011
					bookingItem.setForCreateNew(_ediData); //cnwrs1 CCMS 1882 24 May 2010
					bookingHdr.messageMode := _msgHelper.currentMessageMode; // PAR 18685 cnwgb1 19.12.08
					bookingHdr.operatorCode := params.cargoOperatorCode[1:4];
					bookingHdr.senderCode	:= params.senderCode; // tfs43425
				endif;	
				
				self.getVoyageDetailsFromTDT(	_msgHelper, params.voyageCode, params.voyageOperatorCode, params.myVoyageOperator, params.vesselName, params.lloydsNumber, params.callsign );
				
				// Because some port clients (ANL and COS in particular) do not send
				// through the mandatory UNB record the operator is not getting set up.
				// To cater for this we will use the first valid TDT+20 operator
				// if and only if the operator is not already set up.
				if params.mySenderOperator = null then
					params.mySenderOperator	:= params.myVoyageOperator;
					params.senderOperatorCode := params.voyageOperatorCode;
				endif;

				bookingHdr.callsign := params.callsign; // TFS 44030
				bookingHdr.lloydsNumber := params.lloydsNumber; // TFS 44030
				
				bookingHdr.operatorCode		:= params.cargoOperatorCode;
				_ediData.operatorCode	:= params.senderOperatorCode;
				
				bookingHdr.setRawVoyageCode( params.voyageCode.trimBlanks()[1:30] );
				if params.mySenderOperator &lt;&gt; null then
				//cnwrs1 par 26022 19 Oct 2010 now we have the vessel and the xlation operator try the vesselname xlation
					vesselCode := params.mySenderOperator.getXlationSystemCode(params.vesselName, XLATION_TYPE_VESSEL_BYOP, foundMatch);
					if not foundMatch then	//14 Mar 2014	cnwrs1	Par 33619 if not match the vesselName is returned
						vessel := app.myRoot.allVesselsByName[vesselCode];
					else
						vessel := app.myRoot.allVessels[vesselCode];
					endif;
					if vessel &lt;&gt; null then
						params.vesselName := vessel.name;
					endif;
					params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
					bookingHdr.setVoyageCode( params.voyageCode );
										
				else
					if bookingHdr.getVoyageCode() = null then	//14 Mar 2014	cnwrs1	Par 33619 dont overwrite any newly setup voyageCode
						bookingHdr.setVoyageCode( bookingHdr.getRawVoyageCode );
					endif;
				endif;
				
				bookingHdr.vesselName := params.vesselName; //PAR24680 - cnwsh3 28/6/2010.
			endif;
		elseif _msgHelper.currentGroup = 9 then //Tranships
			if _msgHelper.currentField = "30" then
				// par 29197 _msgHelper.setCurrentGroup(1);
				
				//If the discharge port (LOC+11) matches this port then we're a tranship.
				thisPortCode := app.myPassport.myTerminal.getConfig(PortDestCode).String; //PAR24467 cnwsh3 17/06/2010
				
				if params.dischargePort = thisPortCode then
					params.transVoyageCode := params.voyageCode;
					
					self.getVoyageDetailsFromTDT(	_msgHelper,
													params.voyageCode,
													params.voyageOperatorCode,
													params.myVoyageOperator,				// cnwrl1 26/07/2010 PAR 25093
													params.vesselName,
													params.lloydsNumber,
													params.callsign );
					
					bookingHdr.vesselName := params.vesselName; //PAR24680 - cnwsh3 28/6/2010.
					bookingHdr.setRawVoyageCode(params.voyageCode.trimBlanks()[1:30]);
					bookingHdr.receiveAsTranship := true;
					bookingHdr.setTranshipOriginalVoyage(params.transVoyageCode);
					
					if params.mySenderOperator &lt;&gt; null then
						// make sure the manual collection on CM_EDIConfig gets maintained
						params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator,
																			params.myVoyageOperator,
																			params.voyageCode,
																			params.vesselName,
																			params.lloydsNumber,
																			params.callsign );
						bookingHdr.setVoyageCode( params.voyageCode );
					else
						// make sure the manual collection on CM_EDIConfig gets maintained
						if bookingHdr.getVoyageCode() = null then	//14 Mar 2014	cnwrs1	Par 33619 dont overwrite any newly setup voyageCode
							bookingHdr.setVoyageCode( bookingHdr.getRawVoyageCode );
						endif;
					endif;
				endif;
			endif;
		endif;
//TMP
    elseif _msgHelper.currentTag = "TMP" then
        if _msgHelper.currentGroup = 7 then
			self.getTMPData(_msgHelper,bookingItem.temperature);
			if createPrenote and prenoteEDITI &lt;&gt; null then
				prenoteEDITI.temperature := bookingItem.temperature;
			endif;
		endif;
// End
    endif;
	if createPrenote and prenoteEDITI &lt;&gt; null then
		// TFS 4434 If this prenote has all VGM information required, set the 'update VGM' flag			// TFS 4434
		if _ediPartyRules &lt;&gt; null and _ediPartyRules.updateVGMForOnsiteCargo then 						// TFS 4434
			if prenoteEDITI.isWeightCertified then																	//Bug 38885 If CertifiedWeightNeedsVGM is false then we dont need to
				if	prenoteEDITI.weightCertifiedReference &lt;&gt; null or not 											//Bug 38885 check weightCertifiedReference
				app.myPassport.myTerminal.getConfig(CertifiedWeightNeedsVGM).Boolean then				// TFS 4434	//Bug 38885
					prenoteEDITI.updateVGMOnly := true;													// TFS 4434	//Bug 38885
				endif;																								//Bug 38885
			endif;																						// TFS 4434
		endif;																							// TFS 4434
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTBooking_FTX" id="787f5a6a-4a49-4a94-8ae1-e6a1fea6004c">
        <source>processEDIFACTBooking_FTX(_msgHelper: CMIF_EDIFACTHelper input; _params : CMIF_EDIFACTParams input; _bookingItem :CM_EDIBookingItemTI input; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
/*
Date		Who		Reason
04 July 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
11 Sep  2015    cnwma1  PAR #36737 COPARN Booking Commodity
*/
vars
	text010, commodityDescription, 
	text040			:String;
	ruleFunction 	:Integer;
	value : String;
begin	
	if _ediPartyRules &lt;&gt; null then
		// we could have rules for:
		// FTX1.1 Booking - Cargo Remarks
		// FTX4.1 Booking - Booking Ignore Text
		// FTX4.1 Booking - Ventilation

		if _ediPartyRules.processBookingFTXSegment (_msgHelper.currentMessage, _bookingItem) then
			// already processed		
			return;
		endif;
	endif;
	
	_msgHelper.setNextField();				// 010 Text subject qualifier
	
	text010 := _msgHelper.currentField;

	_msgHelper.setNextField();				// 020 Text function coded
	_msgHelper.setNextField();				// 030 Text reference
	_msgHelper.setNextField();				// 040 Text literal

	if text010 &lt;&gt; "AAA" and text010 &lt;&gt; "HAN" and text010 &lt;&gt; "SIN" then
		// not one we are expecting
		return;
	endif;
	
	if _msgHelper.currentGroup = 3 or _msgHelper.currentGroup = 7 then
		if text010 = "AAA" then 	// goods description
			// store 040 text literal on EDI booking item - ALWAYS
			commodityDescription := _msgHelper.currentSubItem[1:30];
			
			//self.setRawCommodityValue (_msgHelper.currentGroup, _bookingItem, commodityDescription);      // 11/09/2015 cnwma1 PAR #36737
			self.setRawCommodityValue (_msgHelper.currentGroup, _bookingItem, _msgHelper.currentSubItem);   // 11/09/2015 cnwma1 PAR #36737
			if _msgHelper.currentGroup = 3 then
				// just so we can pass it onto the next booking item
//				_params.commodityDescHeader := commodityDescription;	// 06/06/2011 cnwcs5
				global.getExtraData(_bookingItem.getAllExtraData, ETRow_CommodityDesc &amp; '3', value);	// group 3 FTX
				_params.commodityDescHeader := value;
			endif;
		endif;
	endif;
	
	if _msgHelper.currentGroup = 7 then
		if text010 = "HAN" or //Handling instructions
			text010 = "SIN" then //Special instructions			
			_bookingItem.remarks := _bookingItem.remarks &amp; _msgHelper.currentField[1:20];
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="input"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams" usage="input"/>
        <Parameter name="_bookingItem" type="CM_EDIBookingItemTI" usage="input"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTPrenote" id="ea779223-eb54-4a9e-bf97-eb2a0ba264bd">
        <source>processEDIFACTPrenote(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
/*

Date		Who		Reason
13/02/2017	cnwer1	Initial creation TFS 2744
06/06/2017	cnwdap1	TFS 4434 SNO COPARN Prenotes and VGM Updates
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
05/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 01 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 14 Dec 2017	jlgrs1	TFS 8399 - SNO - EDI Booking Ref ID in group 7 not able to strip off version
//22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
// 13 Feb 2018	jlgrs1	TFS 36945 CTA+RP not working in COPARN
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 30 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
//14/06/2018 	JLGNS1	Bug 38885: SNO - VGM Issue
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 08/04/2020	jlgdap1	TFS 49084 MSL Coparn and VGM
*/
vars
    params : CMIF_EDIFACTParams; // BGM local variable  
    isotype : String; // EQD local variable
	foundMatch : Boolean;
	cargoID : String;
	prenoteEDI : CM_EDIPrenoteTI;
	consignor : String;
	ff : String;
	segmentValue : String;
    ruleFunction : Integer; 				// DTM local variable
	disch, dest : String;
	nad1_1Code : String;
	rff1_1Code : String;
	bookingRefId : String;
	rff1_1Function : String;
begin
    params := _msgHelper.myCurrentParams;
	params.weightCertifiedName := null;			// TFS 49084 - these fields need to be cleared for each EQD level
	params.weightCertifiedReference := null;	// TFS 49084 - not just at the BGM level
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_msgHelper.currentTag;	
	if _msgHelper.currentTag = "CTA" then										// TFS 4492
		_msgHelper.setNextField();												// TFS 4492
		if _msgHelper.currentField = "RP" then									// TFS 4492
			// signature of VGM authorised person								// TFS 4492
			_msgHelper.setNextField;															// TFS 4492
			_msgHelper.setNextSubItem;														// TFS 4492
			prenoteEDI.vgmAuthSignature := _msgHelper.currentSubItem;			// TFS 4492
		elseif _msgHelper.currentField = "BN" then								// TFS 4492
			// details on subsequent COM segment								// TFS 4492
		endif;																	// TFS 4492
																				// TFS 4492
   elseif _msgHelper.currentTag = "EQD" then
		//params.myEDIItem
		_msgHelper.setCurrentGroup(7);
		params.myEDIPrenoteTI := null;
		if params.mySenderOperator &lt;&gt; null then
			params.voyageCode := self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
		endif;

		_msgHelper.setNextField();
		
		if not _msgHelper.currentField ="CN" then
			return;
		endif;
	
		_msgHelper.setNextField();

		cargoID:=_msgHelper.currentSubItem;
		if cargoID = null then
			return;
		endif;
		
		create prenoteEDI persistent;
		prenoteEDI.messageMode 		:= _msgHelper.currentMessageMode;
		prenoteEDI.setForCreateNew(_ediData);
		prenoteEDI.setId(cargoID);
		prenoteEDI.setCargoType(TI_CargoType_Container);
		prenoteEDI.destinationPort 	:= params.destination;
		prenoteEDI.dischargePort 	:= params.dischargePort;
		prenoteEDI.operatorCode 	:= params.cargoOperatorCode;
		prenoteEDI.ediFileIssueDateTime := params.ediFileIssueDateTime;
		prenoteEDI.bookingRef :=params.currentBrID;
		if params.mySenderOperator &lt;&gt; null then
			params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
		endif;
		prenoteEDI.setVoyageCode(params.voyageCode);
		
		if params.commodityDescHeader &lt;&gt; null then
			prenoteEDI.commodityDescription:=params.commodityDescHeader;			
		endif;		
		
		_msgHelper.setNextField();
		isotype := _msgHelper.currentField[1:4];
		//now use xlation CCMS 1157
		if params.mySenderOperator &lt;&gt; null then
			isotype := params.mySenderOperator.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];		
		endif;
			
		prenoteEDI.isoType := isotype;	
			
		_msgHelper.setNextField();
		_msgHelper.setNextField();
		_msgHelper.setNextField();
		
		if _msgHelper.currentField = "4" then
			//Empty
			prenoteEDI.fullOrMT := "E"; //cnwrs1 CCMS 1882 24 May 2010
		elseif _msgHelper.currentField = "5" then
			prenoteEDI.fullOrMT := "F";
			//Full
		endif;
		
		params.myEDIPrenoteTI := prenoteEDI;
	else
		if _msgHelper.currentGroup &lt;= 1 then
			if   _msgHelper.currentTag = "LOC"  then
				self.getLOCData(_msgHelper,disch, dest);
			endif;
			if   _msgHelper.currentTag = "DTM"  then
				self.getEDIFileIssueDateTime(_msgHelper);
			endif;
			
			if _msgHelper.currentTag = "TDT" then
				self.getTDTData(_msgHelper,_ediData);
			endif;
			if _msgHelper.currentTag = "RFF" then
				_msgHelper.setNextField();
				rff1_1Code := _msgHelper.currentSubItem;
				if _ediPartyRules &lt;&gt; null then
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, rff1_1Code, segmentValue);
/*					if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ACW then
						rff1_1Code := "ACW";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ANN then
						rff1_1Code := "ANN";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_BN then
						rff1_1Code := "BN";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RE then
						rff1_1Code := "RE";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_REO then
						rff1_1Code := "REO";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_SQ then
						rff1_1Code := "SQ";
					elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_VON then
						rff1_1Code := "VON";
					endif;
				endif;*/
					if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
						if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking then
							rff1_1Function := CM_EDIPrenoteTI::bookingRef.name;
							_msgHelper.setNextSubItem();
							params.currentBrID:= _msgHelper.currentSubItem[1:30];
						endif;
					endif;
				endif;
				if rff1_1Function = null then
					if rff1_1Code = "BN" or rff1_1Code = "ANN" then //booking ref
						_msgHelper.setNextSubItem();
						params.currentBrID:= _msgHelper.currentSubItem[1:30];
					endif;
				endif;
			endif;
		elseif _msgHelper.currentGroup &lt;= 2 then
			if _msgHelper.currentTag = "NAD" then
				self.getNADData(_msgHelper, _ediPartyRules, consignor, ff);
			endif;
			
		endif;
		
		if _msgHelper.currentTag = "FTX"  then
			self.getFTXCommodity(_msgHelper, _ediPartyRules);
		endif;
		
		if _msgHelper.currentGroup  &lt; 7  then
			return;
		endif;
		
	   if params.myEDIPrenoteTI = null then
		   return;
		endif;
		
//		if not params.myEDIItem.isKindOf(CM_EDIPrenoteTI) then
//			return;
//		endif;
		prenoteEDI := params.myEDIPrenoteTI;
	   //EQD without a container id skip
		if prenoteEDI = null then
			return;
		endif;
		
		//07 Jun 2017	NDL	TFS 4454
		if params.specialStowage &lt;&gt; null then
			prenoteEDI.specialStowage := params.specialStowage;
		endif;
	endif;
//DGS
    if _msgHelper.currentTag = "DGS" then
		self.getDGSData(_msgHelper,	prenoteEDI.imCodes);
			
//DIM
    elseif _msgHelper.currentTag = "DIM" then    
		self.getDIMData(_msgHelper,prenoteEDI.length,prenoteEDI.width,prenoteEDI.height);		
//DTM
    elseif _msgHelper.currentTag = "DTM" then
		self.getEDIFileIssueDateTime(_msgHelper);	
//FTX
	elseif _msgHelper.currentTag = "FTX" then
		self.getFTXCommodity(_msgHelper, _ediPartyRules);
		
		if params.commodityDescHeader &lt;&gt; null then
			prenoteEDI.commodityDescription:=params.commodityDescHeader;		
		endif;
		//07 Jun 2017	NDL	TFS 4454
		if params.specialStowage &lt;&gt; null then
			prenoteEDI.specialStowage := params.specialStowage;
		endif;
//LOC 
	elseif _msgHelper.currentTag = "LOC" then
		self.getLOCData(_msgHelper,prenoteEDI.dischargePort,prenoteEDI.destinationPort);				
//MEA
	elseif _msgHelper.currentTag = "MEA" then
			self.getMEAData(_msgHelper,prenoteEDI.weight,prenoteEDI.isWeightCertified,prenoteEDI.humidity,prenoteEDI.vent,prenoteEDI.carbonDioxide,prenoteEDI.oxygen);	
//RFF
	elseif _msgHelper.currentTag = "RFF" then
		_msgHelper.setNextField();
		rff1_1Code := _msgHelper.currentSubItem;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, rff1_1Code, segmentValue);
/*			if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ACW then
				rff1_1Code := "ACW";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ANN then
				rff1_1Code := "ANN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_BN then
				rff1_1Code := "BN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RE then
				rff1_1Code := "RE";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_REO then
				rff1_1Code := "REO";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_SQ then
				rff1_1Code := "SQ";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_VON then
				rff1_1Code := "VON";
			endif;
		endif;*/
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking then
					rff1_1Function := CM_EDIPrenoteTI::bookingRef.name;
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					prenoteEDI.bookingRef := bookingRefId;
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						prenoteEDI.bookingRef := bookingRefId;
					endif;
				endif;
			endif;
		endif;
		if rff1_1Function = null then
			if rff1_1Code = "BN" or rff1_1Code = "ANN" then //booking ref
				_msgHelper.setNextSubItem();
				bookingRefId := _msgHelper.currentSubItem[1:30];
				prenoteEDI.bookingRef := bookingRefId;
				self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
				if bookingRefId &lt;&gt; null then
					prenoteEDI.bookingRef := bookingRefId;
				endif;
	//			prenoteEDI.bookingRef:= _msgHelper.currentSubItem[1:30];
			endif;
		endif;
// NAD for the weight certified reference
	elseif _msgHelper.currentTag = "NAD" then
		//should be in group 10 
		if prenoteEDI.isWeightCertified then
			_msgHelper.setNextField();
			nad1_1Code := _msgHelper.currentSubItem;
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
			if ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_AM then
				rff1_1Code := "AM";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_SPC then
				rff1_1Code := "SPC";
			endif;
			if nad1_1Code = "SPC" then		// Weighter
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();				
				prenoteEDI.weightCertifiedReference := _msgHelper.currentSubItem;
				
			elseif nad1_1Code = "AM" then		// Container operator!
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();		
				prenoteEDI.weightCertifiedName := _msgHelper.currentSubItem;
			
			endif;
		endif;
//SEL
    elseif _msgHelper.currentTag = "SEL" then
		self.getSELData(_msgHelper, prenoteEDI.sealNum, prenoteEDI.sealShipper, prenoteEDI.customsSeal, prenoteEDI.sealTerminalOperator, prenoteEDI.sealUnknown);
//TMP
    elseif _msgHelper.currentTag = "TMP" then
		self.getTMPData(_msgHelper,prenoteEDI.temperature);
// End
    endif;
	
	// TFS 4434 If this prenote has all VGM information required, set the 'update VGM' flag				// TFS 4434	
	if _ediPartyRules &lt;&gt; null and _ediPartyRules.updateVGMForOnsiteCargo then 							// TFS 4434
		if prenoteEDI.isWeightCertified then																		//Bug 38885	If CertifiedWeightNeedsVGM is false then we dont need to 
			if  prenoteEDI.weightCertifiedReference &lt;&gt; null or not													//Bug 38885 check weightCertifiedReference
			app.myPassport.myTerminal.getConfig(CertifiedWeightNeedsVGM).Boolean then					// TFS 4434	//Bug 38885
				prenoteEDI.updateVGMOnly := true;														// TFS 4434	//Bug 38885
			endif;																						// TFS 4434	//Bug 38885
		endif;																							// TFS 4434	//Bug 38885
	endif;																						// TFS 4434
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTRelease" id="19df30bb-9774-492b-91c5-fbeaf0d316a2">
        <source>processEDIFACTRelease(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
//
// ccms 2122 cnwrs1 01 Dec 2011
/* Changes

Date		Name	TFS#		Description
============================================================================
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
14/02/2012	cnwcs5	CCMS POL 2151 / par 29137 - extra defaults for consignor voyage, release date, clean
05/03/2012	cnwcs5F	par 29210 - process NAD+CC as consignee for MSK
24/04/2012	cnwcs5	par 29480 - changes for updating request date
14/12/2012  cnwgb1  CCMS POL 2216 / 30902 Heavy Rated Rules
07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - availability grade xlations
16 Sep 2013 cnwah9 				removed error messagefs and unnecessary code
14 Mar 2014	cnwrs1	Par 33619 	if not match the vesselName is returned
09 Sep 2014 cnwma1  PAR 34855 	CCMS 2351: Hapag-Lloyd Release Request Enhancements
09 Sep 2014	cnwrs1	CCMS 2351 	att Sequence to Release request
11 Sep 2014	cnwma1	PAR#34855 	CCMS 2351: Hapag-Lloyd Release Request Enhancements
17 Mar 2015 cnwma1  PAR #35869 	CCMS 2351 - Ventilation Setting Value Query
28 Jul 2015	cnwrs1	Par 36681 - defualt availability grade not being set when isotyope translated
12 Nov 2015	cnwrs1	Par 37158 - should be able to process FTX+QQD++ and FTX+QQD+++ for the availabilityGrade
14 Jun 2016 cnwma1	TFS #2048 	POL - HSD EDI Empty Release Request
23 Mar 2017 cnwrh7  TFS 3602 	#EDI Party Enquiry FTX value not consistently used
18 Aug 2017 jlggb1  TFS 6574 	SNO - Extract more CA information from COPARN Release
21 Aug 2017	jlgrs1	TFS 6564 	add Coparn and Coreor RFF and NAD translation
28 Sep 2017 cnwma1	TFS # 6816 	POL - [Fwd: ##5406## : FW: [Request ID :##5406##] : Estimated Required Date Not Loading into Empty Release Request]
14 Dec 2017	jlgrs1	TFS 8399 - 	SNO - EDI Booking Ref ID in group 7 not able to strip off version
22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
30 May 2018	jlgrs1	TFS 38357 	SNO Fix Xlations from TFS 6797
07 Jun 2018	jlgrs1	TFS 39018 	SNO Cargo Operator in COPRAR
07 Apr 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
01/08/2019	jlgka1 	TFS 45467	SNO - Clean attribute in release request
22 Dec 2022 navra1	TFS 55813	PNL - The MEA segment was not read completely
07 May 2025 navsp1  JIRA 34750	POL | Availability Grade EDI Translation
11 Jun 2025 navsp1  JIRA 35290  POL | Temperature specific EDI translations applying incorrectly
============================================================================*/
vars
	releaseTI 		: CM_EDIReleaseRequestTI; 
    params 			: CMIF_EDIFACTParams; 	// BGM local variable
    dtCode 			: String; 				// DTM local variable
    dtString 		: String; 				// DTM local variable
    ruleFunction 	: Integer; 				// DTM local variable
    theTime 		: TimeStamp; 			// DTM local variable
    isoType 		: String; 				// EQD local variable
    port 			: String; 				// LOC local variable
    vesselCode 		: String; 				// TDT local variable
    vessel 			: CM_Vessel; 			// TDT local variable
    thisPortCode 	: String; 				// TDT local variable
    qualityCode 	: String; 				// FTX local variable
	terminal 		: CM_Terminal;
	isoTypeObj 		: CM_ISOType;
	remark			: String;				// par 29137
    meaString       : String;       // cnwgb1 30902 14.12.2012
    ftxString       : String;       // cnwgb1 30902 14.12.2012
	temperature		: Real;
	foundMatch		: Boolean;
	segmentValue	: String;
	pos				: Integer;
	repChar			: String;
	charFounded		:String;
	idx				: Integer;
	avStr    		: String;
	ftxArray 		: StringArray512;
	rule 			: CM_EDIEDIFactRule;
	specialStow 	: String;
	measurementType	: String;	// jlggb1 TFS 6574 18.8.17
	tValueStr		: String;	// jlggb1 TFS 6574 18.8.17
	tScaleStr		: String;	// jlggb1 TFS 6574 18.8.17	
	nad1_1Code : String;
	rff1_1Code : String;
	bookingRefId : String;
	releaseReqNum : String;
	reefTypeObj : CM_ISOType;
	nad1_1Function : String;
	nad2_1Function : String;
	nad3_1Function : String;
	rff1_1Function : String;
	cargoOperatorCode : String;
begin 
    temperature := NULL_TEMPERATURE;                //JIRA-35290
    params 		:= _msgHelper.myCurrentParams;
	terminal 	:= app.myPassport.myTerminal;

    if params.myEDIItem &lt;&gt; null then
        releaseTI := params.myEDIItem.CM_EDIReleaseRequestTI;
    endif;    
//DGS
    if _msgHelper.currentTag = "DGS" then
        if _msgHelper.currentGroup &lt; 6 then
            _msgHelper.setCurrentGroup( 6 );
        endif;
//DIM
    elseif _msgHelper.currentTag = "DIM" then
//DTM
    elseif _msgHelper.currentTag = "DTM" then
        if _msgHelper.currentGroup = 0 or   //28.9.2017 cnwma1 TFS #6816
		   _msgHelper.currentGroup = 1 or
		   _msgHelper.currentGroup = 7 then	
            _msgHelper.setNextField();
            dtCode := _msgHelper.currentSubItem;
            _msgHelper.setNextSubItem();
            dtString := _msgHelper.currentSubItem.trimBlanks();
            _msgHelper.setNextSubItem();
            theTime := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
            
            if _msgHelper.currentSubItem = "137" then		// date of EDI file issue
                params.ediFileIssueDateTime := theTime;
            endif;
			
            // In addition to setting the File Issue DateTime, The EDi Party Rules allow us to set some other fields.
			if _ediPartyRules &lt;&gt; null then
				ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_DTM_1_1, dtCode, segmentValue );
				
				if ruleFunction = CM_EDIEDIFactRule.Function_DTM_1_1_EstReqDT then // Estimated Required Time
					// No Request at this point in processing
					if _msgHelper.currentGroup = 7 then
						releaseTI.estimatedRequiredDate := theTime;
					else
						params.requiredDT 				:= theTime;
					endif;
				elseif ruleFunction = CM_EDIEDIFactRule.Function_DTM_1_1_ReqDT then // Requested time
				
					if _msgHelper.currentGroup = 7 then
						releaseTI.requestDate 			:= theTime;
						releaseTI.requestDateDoUpdate	:= true;		// par 29480 April 2012
					else
						params.requestDT 				:= theTime;
						params.requestDTDoUpdate		:= true;		// par 29480 April 2012
					endif;
				endif;
			endif;            
        endif; 
//EQA
    elseif _msgHelper.currentTag = "EQA" then
        if _msgHelper.currentGroup = 7 then	
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "RG" then	// generator release item
				create releaseTI persistent; 
				params.myEDIItem := releaseTI;
				
				releaseTI.setForCreateNew(_ediData);
				
				releaseTI.releaseRequestNumber 	:= params.releaseRequestNumber;
				releaseTI.statusBulkRelease 	:= BR_PENDING_STRING;			// WILL GET OVERWRITTEN BY RULES LATER
				releaseTI.setIdDefault(null);
				releaseTI.myParent 				:= releaseTI;
				releaseTI.messageMode 			:= _msgHelper.currentMessageMode;
				releaseTI.bookingRef := params.currentBrID;
				releaseTI.destinationPort 		:= params.destination;
				releaseTI.dischargePort 		:= params.dischargePort;
				releaseTI.operatorCode 			:= params.cargoOperatorCode;
				releaseTI.releaseByType 		:= true;
				releaseTI.quantity 				:= 1;
                releaseTI.estimatedRequiredDate := params.requiredDT;
                releaseTI.requestDate 			:= params.requestDT;
				releaseTI.requestDateDoUpdate	:= params.requestDTDoUpdate;	// par 29480 April 2012
				releaseTI.isGeneratorAttachment	:= true;						// par 29480 April 2012
				
				if params.vesselName &lt;&gt; null then
					releaseTI.vesselName := params.vesselName;
				endif;
				
				releaseTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
				
				releaseTI.consignor 	:= params.consignor;
				releaseTI.senderCode 	:= params.senderCode;
								
				self.setEDIPartyDefaults (_ediPartyRules, terminal, params, releaseTI, true);					// par 29137					
			endif;
		endif;
//EQD
	elseif _msgHelper.currentTag = "EQD" then
		_msgHelper.setCurrentGroup(7);
		// We've previously seen an EQD. Need to make another one for multi item cnwgb1 11.11.08
		// The first bookingRef has been created in RFF section. Before creating others multi items, need to flag the first one as multi item.  Par 18495, Jan 2009
        
		create releaseTI persistent; 
		params.myEDIItem := releaseTI;
		
		releaseTI.setForCreateNew(_ediData);
		
		releaseTI.releaseRequestNumber 	:= params.releaseRequestNumber;
		releaseTI.statusBulkRelease 	:= BR_PENDING_STRING;		// will get overritten by rules later
		releaseTI.setIdDefault(null);
		releaseTI.myParent 				:= releaseTI;
		releaseTI.messageMode 			:= _msgHelper.currentMessageMode;
		releaseTI.bookingRef := params.currentBrID;
		
		if params.mySenderOperator &lt;&gt; null then
			releaseTI.destinationPort := params.mySenderOperator.getXlationSystemCode(params.destination, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseTI.destinationPort := params.destination;
		endif;
		
		if params.mySenderOperator &lt;&gt; null then
			releaseTI.dischargePort := params.mySenderOperator.getXlationSystemCode(params.dischargePort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseTI.dischargePort := params.dischargePort;
		endif;
		
		if params.mySenderOperator &lt;&gt; null then
			releaseTI.loadPort := params.mySenderOperator.getXlationSystemCode(params.loadPort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseTI.loadPort 	:= params.loadPort;
		endif;
        
		releaseTI.operatorCode 			:= params.cargoOperatorCode;
		releaseTI.consignee 			:= params.consignee;
		releaseTI.consignor 			:= params.consignor;
		releaseTI.freightForwarder		:= params.freightForwarder;		// 11/07/2013 cnwar2 #31784
        releaseTI.estimatedRequiredDate := params.requiredDT;
        releaseTI.requestDate 			:= params.requestDT;
		releaseTI.requestDateDoUpdate	:= params.requestDTDoUpdate;	// par 29480 April 2012
		releaseTI.senderCode 			:= params.senderCode;
		releaseTI.specialStowage 		:= params.specialStowage;	//07 Jun 2017	NDL	TFS 4454

		if params.vesselName &lt;&gt; null then
			releaseTI.vesselName := params.vesselName;
		endif;
		
		releaseTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
		
		if params.mySenderOperator &lt;&gt; null then
			params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
			releaseTI.setVoyageCode(params.voyageCode[1:30]);
		else
			// make sure the manual collection on CM_EDIConfig gets maintained
			releaseTI.setVoyageCode(releaseTI.getVoyageCode);
		endif;

		self.setEDIPartyDefaults (_ediPartyRules, terminal, params, releaseTI, false);					// par 29137				
		
		releaseTI.ediFileIssueDateTime	:= params.ediFileIssueDateTime;
		releaseTI.quantity := 1; //cnwgb1 24.2.2014 PAR 33637
        params.foundEQD := true; //cnwgb1 24.2.2014 PAR 33637
		
		_msgHelper.setNextField();
		
		if _msgHelper.currentField = "CN" or _msgHelper.currentField[1:2] = "T7" then
			releaseTI.setCargoType(TI_CargoType_Container);
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = null then
				releaseTI.releaseByType := true;
			else
				releaseTI.setId(_msgHelper.currentField[1:11]); 
			endif;
			
			_msgHelper.setNextField();
			isoType := _msgHelper.currentField[1:4];
			
			//now use xlation CCMS 1157
			if params.mySenderOperator &lt;&gt; null then
				releaseTI.isoType := params.mySenderOperator.getXlationSystemCode(isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			else
				releaseTI.isoType := isoType.trimBlanks()[1:4];
			endif;
			
			isoTypeObj := app.myRoot.allISOTypes[releaseTI.isoType];
            
			if isoTypeObj &lt;&gt; null then	// par 29137 start
                if isoTypeObj.isReefer then
					if _ediPartyRules &lt;&gt; null then
						if params.availabilityGrades = null then    					//cnwma1 TFS #2048 14/06/2016 
							releaseTI.availabilityGrades := _ediPartyRules.CM_EDIPartyCoparnRules.defaultAvailabilityGradeReefer.String;
						else
							releaseTI.availabilityGrades := params.availabilityGrades;  //cnwma1 TFS #2048 14/06/2016 
						endif;
					endif;
					//jlgka1 TFS 45467 --&gt;
					if _ediPartyRules &lt;&gt; null then
						if _ediPartyRules.defaultReleaseIncludeNonClean then						
							releaseTI.clean	:= false;
						else
							releaseTI.clean	:= true;
						endif;
					else
						// default to clean for reefer					
						releaseTI.clean	:= true;
					endif;
					//jlgka1 TFS 45467 &lt;--
                else
					if _ediPartyRules &lt;&gt; null then
						if params.availabilityGrades = null then    					//cnwma1 TFS #2048 14/06/2016 
							releaseTI.availabilityGrades := _ediPartyRules.CM_EDIPartyCoparnRules.defaultAvailabilityGrade.String;
						else
							releaseTI.availabilityGrades := params.availabilityGrades;  	//cnwma1 TFS #2048 14/06/2016 
						endif;
					endif;
                endif;
            endif;						// par 29137 - end
			            
			if releaseTI.checkISOGroup then
				if isoTypeObj &lt;&gt; null and
				   isoTypeObj.myISOTypeGroup &lt;&gt; null then
					releaseTI.isoTypeGroup := isoTypeObj.myISOTypeGroup.code;
				endif;
			endif;
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = "4" then 
				releaseTI.fullOrMT := "E"; //cnwrs1 CCMS 1882 24 May 2010
				releaseTI.mtRelease := true;
			elseif _msgHelper.currentField = "5" then 
				releaseTI.fullOrMT := "F";
				releaseTI.mtRelease := false;
			endif;
		endif;
//EQN
    elseif _msgHelper.currentTag = "EQN" then
        if _msgHelper.currentGroup = 7 then
            _msgHelper.setNextField();
            if params.foundEQD = true then //cnwgb1 24.2.2014 PAR 33637
                releaseTI.quantity := _msgHelper.currentField.Integer;
            else
                releaseTI.quantity := releaseTI.quantity + _msgHelper.currentField.Integer;
                params.foundEQD := false;
            endif;
        endif; 
//FTX
	elseif _msgHelper.currentTag = "FTX" then
		_msgHelper.setNextField();					// 010 Text subject qualifier
		
		//cnwma1 TFS #2048 14/06/2016 
		if _msgHelper.currentGroup = 0 then
			if _msgHelper.currentField = "CUR" then
				if _ediPartyRules &lt;&gt; null then 
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                		//+TFS3602 Stripe off "FTX+"
							dtCode := dtCode[5 : end];
					endif;
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue );
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_EstReqDT then
						segmentValue := segmentValue.extractInteger.asStringJMT;
						theTime := segmentValue.getUNEDIFACTTimeStamp(101);
						if theTime &lt;&gt; null then
							params.requiredDT := theTime;
						endif;
					endif;
				endif;
			//endif;
			elseif _msgHelper.currentField = "AVD" then	
				if _ediPartyRules &lt;&gt; null then 
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                			//+TFS3602 Stripe off "FTX+"
							dtCode := dtCode[5 : end];
					endif;
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue );
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then
						segmentValue := segmentValue.removeString("'").removeString("+");
						if params.mySenderOperator &lt;&gt; null then
							avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(segmentValue, foundMatch ,temperature, avStr);
							params.availabilityGrades := avStr;
								
						endif;
					endif;
				endif;	
			else						//new codes here to do free text transaltion
				if _ediPartyRules &lt;&gt; null then																							//+TFS3602 For Any Free Text Translation
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                		
							dtCode := dtCode[5 : end];
					endif;
					
					//07 Jun 2017	NDL	TFS 4454
					rule := _ediPartyRules.allEDIPartyRules.getEDIEDIFactRule( CM_EDIEDIFactRule.Item_FTX_3_1 );
					if rule &lt;&gt; null then
						ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_3_1, dtCode, segmentValue);
						if ruleFunction = CM_EDIEDIFactRule.Function_FTX_3_1_Stowage then
							create ftxArray transient;
							dtCode.getTokensForDelimiter ('+', ftxArray);
							if ftxArray[1] = rule.value then
								specialStow := rule.getFTXSpecialStowage(ftxArray);
								if specialStow &lt;&gt; null then
									params.specialStowage := specialStow;
								endif;
							endif;
							delete ftxArray;
						endif;
						ruleFunction := null;
					endif;
					
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue);
					
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_EstReqDT then													//Only 2 rule functions implemented here for currentGroup 0
						segmentValue := segmentValue.extractInteger.asStringJMT;
						theTime := segmentValue.getUNEDIFACTTimeStamp(101);
						if theTime &lt;&gt; null then
							params.requiredDT := theTime;
						endif;
					elseif  ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then
						segmentValue := segmentValue.removeString("'").removeString("+");
						if params.mySenderOperator &lt;&gt; null then
							avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(segmentValue,foundMatch,temperature,avStr);
							params.availabilityGrades :=avStr;
						endif;
					endif;
				endif;
			endif;
		elseif _msgHelper.currentGroup = 3 then //or _msgHelper.currentGroup = 7 then
			if _msgHelper.currentField = "AAA" then 	// goods description
				_msgHelper.setNextField();			// 020 Text function coded
				_msgHelper.setNextField();			// 030 Text reference
				_msgHelper.setNextField();			// 040 Text literal
//				releaseTI.remarks := releaseTI.remarks&amp;_msgHelper.currentField[1:20];
			endif;
		elseif _msgHelper.currentGroup = 6 then
			if _msgHelper.currentField = "AAC" then
			elseif _msgHelper.currentField = "AAD" then
			endif;
		elseif _msgHelper.currentGroup = 7 then
			if _msgHelper.currentField = "ABS" then //Additional conditions
			elseif _msgHelper.currentField = "HAN" then //Handling instructions
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseTI.remarks = null then
					releaseTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseTI.remarks := releaseTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
			elseif _msgHelper.currentField = "SIN" then //Special instructions
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseTI.remarks = null then
					releaseTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseTI.remarks := releaseTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
			elseif _msgHelper.currentField = "AAI" then
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseTI.remarks = null then
					releaseTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseTI.remarks := releaseTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
			elseif _msgHelper.currentField = "QQD" then //Quality (Availability Grade)
                _msgHelper.setNextField();
				_msgHelper.setNextField();
				//_msgHelper.setNextField();
                qualityCode := _msgHelper.currentSubItem;
				if qualityCode = null then
					_msgHelper.setNextField();
					qualityCode := _msgHelper.currentSubItem;
				endif;
                //May need to append, but not if the only thing there is the default.
				avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(qualityCode[1:60], foundMatch, temperature, avStr);	    //MTN-34750
                releaseTI.availabilityGrades := avStr;	//qualityCode[1:60];	// par 31259										    //MTN-34750
			endif;
            
            // CCMS 2216 PAR 30902 cnwgb1 Heavy Rating
			if _ediPartyRules &lt;&gt; null then
				// strip off 'FTX+'
				ftxString := _msgHelper.currentMessage [5:end];
				// strip off "'"
				if ftxString &lt;&gt; null then
					ftxString := ftxString[1:ftxString.length()-1];
				endif;
				
				ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, ftxString, segmentValue);
				
				if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_Heavy then // Heavy Rated Min Value
					// cnwcs5 15/04/2012 - actually we need to check for a match before deciding we are heavy rated
					// segment 4.1. contains the text to use to decide whether we are heavy or not
					releaseTI.heavyDuty := true;    // NOTE if there are multiple segments - any one of them can set 
													// Heavy Duty to true - so we don't reset ever - cnwgb1
				elseif ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then
                    // segment 4.1 contains text to use as part of the MT grade xlation criteria.
                    // we need to save this off for later
                    self.setMTGradeXlatCrit_Text (releaseTI, segmentValue.String);
				endif;
			endif;
		endif;
//GID
    elseif _msgHelper.currentTag = "GID" then
        if _msgHelper.currentGroup &lt; 3 then
            _msgHelper.setCurrentGroup(3);
        endif;
//LOC
	elseif _msgHelper.currentTag = "LOC" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);	
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "9" then //place of loading
				_msgHelper.setNextField();
				params.loadPort := _msgHelper.currentSubItem[1:5].trimBlanks();
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				params.dischargePort := port;
			elseif _msgHelper.currentField = "7" or //delivery
			   _msgHelper.currentField = "8" then //destination
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				params.destination := port;
			endif;
		elseif _msgHelper.currentGroup = 7 then //par 16128 cnwrs1 Mar 2008
			if _msgHelper.currentField = "9" then //place of loading
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseTI.loadPort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseTI.loadPort := port;
					endif;
				endif;
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseTI.dischargePort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseTI.dischargePort := port;
					endif;
				endif;
			elseif _msgHelper.currentField = "88" then 
			elseif _msgHelper.currentField = "7" or //delivery
			   _msgHelper.currentField = "8" then //destination
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseTI.destinationPort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseTI.destinationPort := port;
					endif;
				endif;
			endif;
		elseif _msgHelper.currentGroup = 9 then 
			if _msgHelper.currentField = "98" then
			endif;//add end
		endif; 
//MEA
	elseif _msgHelper.currentTag = "MEA" then
		// CCMS POL 2151 / par 29137 - there is nowhere on a release request to store ventuilation, 
		// o2, co2, humidity so if we find a message included these we will include them in the remarks
		_msgHelper.setNextField;
		
		if _msgHelper.currentGroup = 7 then
		
			if _msgHelper.currentField = 'AAE' then				 
				_msgHelper.setNextField;
				measurementType := _msgHelper.currentField; 								// jlggb1 TFS 6574 18.8.17
				_msgHelper.setNextField;													// jlggb1 TFS 6574 18.8.17
				_msgHelper.setNextSubItem;													// jlggb1 TFS 6574 18.8.17
				if measurementType = 'AAS' then			// ventilation						// jlggb1 TFS 6574 18.8.17
					remark	:= 'VENTILATION ' &amp;  _msgHelper.currentSubItem &amp; ' CBM/H';		// jlggb1 TFS 6574 18.8.17
				elseif measurementType = 'AAO' then		// humidity							// jlggb1 TFS 6574 18.8.17
					remark := 'HUMIDITY ' &amp;  _msgHelper.currentSubItem &amp; '%';				// jlggb1 TFS 6574 18.8.17
				elseif 	measurementType = 'ZO' then 	// oxygen							// jlggb1 TFS 6574 18.8.17
					remark := 'OXYGEN ' &amp;  _msgHelper.currentSubItem &amp; '%';					// jlggb1 TFS 6574 18.8.17
				elseif measurementType = 'CD' then		// carbon dioxide					// jlggb1 TFS 6574 18.8.17
					remark := 'CO2 ' &amp;  _msgHelper.currentSubItem &amp; '%';					// jlggb1 TFS 6574 18.8.17
				else
					remark := null;
				endif;

				//11 Jan 2018	NDL	TFS 36400
				if remark &lt;&gt; null and releaseTI &lt;&gt; null then
					reefTypeObj := app.myRoot.allISOTypes[releaseTI.isoType];
					if reefTypeObj = null or not reefTypeObj.isReefer then
						remark := null;
					endif;
				endif;
				
				if remark &lt;&gt; null then
					if releaseTI.remarks = null then
						releaseTI.remarks := remark;
					else
						releaseTI.remarks := releaseTI.remarks &amp; CrLf &amp; remark;
					endif;	
				endif;
			endif;

            // CCMS 2216 PAR 30902 cnwgb1 Heavy Rating
			if _ediPartyRules &lt;&gt; null then
				//meaString 		:= _msgHelper.currentMessage [5:16];// "MEA+|AAE+GW+KGM:|nnnnn"										//navra1 - TFS 55813 - 22nd Dec 2022
				pos := 5;                                                                                  								//navra1 - TFS 55813 - 22nd Dec 2022 - start after AAE+, ie. 5th position 
				meaString := _msgHelper.currentMessage.scanUntil("'", pos);																//navra1 - TFS 55813 - 22nd Dec 2022 - read until end of segment
				ruleFunction 	:= _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_MEA_3_2, meaString, segmentValue);
				
				if ruleFunction = CM_EDIEDIFactRule.Function_MEA_3_2_Heavy then // Heavy Rated Min Value
					if _msgHelper.currentGroup = 7 then
						releaseTI.heavyDuty := true;    // NOTE if there are multiple segments - any one of them can set 
					endif;                              // Heavy Duty to true - so we don't reset ever - cnwgb1
				endif;
			endif;
		endif;
//NAD
	elseif _msgHelper.currentTag = "NAD" then
		if _msgHelper.currentGroup &lt; 2 then
			_msgHelper.setCurrentGroup(2);
		endif;
		_msgHelper.setNextField();
		nad1_1Code := _msgHelper.currentField;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
/*			if ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CA then
				nad1_1Code := "CA";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CC then
				nad1_1Code := "CC";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CN then
				nad1_1Code := "CN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CU then
				nad1_1Code := "CU";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CZ then
				nad1_1Code := "CZ";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_FW then
				nad1_1Code := "FW";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_SH then
				nad1_1Code := "SH";
			endif;
		endif;*/
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad1_1Function := CM_EDIReleaseRequestTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad1_1Function := CM_EDIReleaseRequestTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent then
					nad1_1Function := CM_EDIReleaseRequestTI::customsAgent.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad1_1Function := CM_EDIReleaseRequestTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
				endif;
				if nad1_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[_msgHelper.currentSubItem];
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.operatorCode := params.cargoOperatorCode[1:4];
						endif;
					else
						if params.mySenderOperator &lt;&gt; null then
							params.setPropertyValue(nad1_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
						else
							params.setPropertyValue(nad1_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.setPropertyValue(nad1_1Function, params.getPropertyValue(nad1_1Function));
						endif;
					endif;
				endif;	
			endif;
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_2_1, nad1_1Code, segmentValue);
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad2_1Function := CM_EDIReleaseRequestTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad2_1Function := CM_EDIReleaseRequestTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad2_1Function := CM_EDIReleaseRequestTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
				endif;
				if nad2_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[_msgHelper.currentSubItem];
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.operatorCode := params.cargoOperatorCode[1:4];
						endif;
					else
						if params.mySenderOperator &lt;&gt; null then
							params.setPropertyValue(nad2_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
						else
							params.setPropertyValue(nad2_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.setPropertyValue(nad2_1Function, params.getPropertyValue(nad2_1Function));
						endif;
					endif;
				endif;	
			endif;
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_3_1, nad1_1Code, segmentValue);
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad3_1Function := CM_EDIReleaseRequestTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad3_1Function := CM_EDIReleaseRequestTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad3_1Function := CM_EDIReleaseRequestTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
				endif;
				if nad3_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[_msgHelper.currentSubItem];
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.operatorCode := params.cargoOperatorCode[1:4];
						endif;
					else
						if params.mySenderOperator &lt;&gt; null then
							params.setPropertyValue(nad3_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
						else
							params.setPropertyValue(nad3_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
						endif;
						if releaseTI &lt;&gt; null then
							releaseTI.setPropertyValue(nad3_1Function, params.getPropertyValue(nad3_1Function));
						endif;
					endif;
				endif;	
			endif;
		endif;
		if nad1_1Function = null and
		   nad2_1Function = null and
		   nad3_1Function = null then
			if _msgHelper.currentGroup = 2 then
				if nad1_1Code = "CA" then // carrier (sea)
					_msgHelper.setNextField();
				//elseif _msgHelper.currentField = "CB" then 	//customs broker
				elseif nad1_1Code = "CC" then	// MSK consignee (par 29120)
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignee := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignee := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
				elseif nad1_1Code = "CZ" then //consignor
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
				elseif nad1_1Code = "FW" then  //freight forward
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						//params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
						// 11/07/2013 cnwar2 #31784
						params.freightForwarder := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						//params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
						// 11/07/2013 cnwar2 #31784
						params.freightForwarder := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
				elseif nad1_1Code = "SH" then  //shipper (non standard! COSCO) PAR 18716 cnwgb1 26.5.09
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;				
				endif;
			elseif _msgHelper.currentGroup &gt;= 7 then
				if nad1_1Code = "CN" then // MSC consignee
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignee := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignee := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					if releaseTI &lt;&gt; null then
						releaseTI.consignee := params.consignee;
					endif;
				endif;
				if nad1_1Code = "CU" then //HLCL consignee  09/09/2014 cnwma1 PAR#34855  CCMS POL 2351
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignee := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem[1:30], XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignee := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					if releaseTI &lt;&gt; null then
						releaseTI.consignee := params.consignee;
					endif;
				endif;
			endif;
		endif;
//RFF
	elseif _msgHelper.currentTag = "RFF" then
		_msgHelper.setNextField();
		rff1_1Code := _msgHelper.currentSubItem;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, rff1_1Code, segmentValue);
/*			if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ACW then
				rff1_1Code := "ACW";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ANN then
				rff1_1Code := "ANN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_BN then
				rff1_1Code := "BN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RE then
				rff1_1Code := "RE";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_REO then
				rff1_1Code := "REO";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_SQ then
				rff1_1Code := "SQ";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_VON then
				rff1_1Code := "VON";
			endif;
		endif;*/
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking then
//					if _msgHelper.currentGroup = 0 then
						rff1_1Function := CM_EDIReleaseRequestTI::bookingRef.name;
						if releaseTI &lt;&gt; null then //finish any previous bookingref 
							releaseTI.rawEDIData := params.rawEDIData;
						endif;
						params.rawEDIData := null;
						_msgHelper.setNextSubItem();
						bookingRefId := _msgHelper.currentSubItem[1:30];
						params.currentBrID := bookingRefId; //cnwrs1 CCMS 1882 24 May 2010
						self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
						if bookingRefId &lt;&gt; null then
							params.currentBrID := bookingRefId;
						endif;
						releaseTI.bookingRef := bookingRefId;
						if releaseTI.releaseRequestNumber = null then
							releaseTI.releaseRequestNumber := params.currentBrID;
						endif;
/*					elseif _msgHelper.currentGroup = 7 then
						_msgHelper.setNextSubItem();
						bookingRefId := _msgHelper.currentSubItem[1:30];
						releaseTI.releaseRequestNumber := bookingRefId;
						self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
						releaseTI.releaseRequestNumber := bookingRefId;
						releaseTI.bookingRef := bookingRefId;
					endif;*/
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Sequence then
					if _msgHelper.currentGroup = 7 then
						rff1_1Function := CM_EDIReleaseRequestTI::sequence.name;
						_msgHelper.setNextSubItem();
						releaseTI.sequence := _msgHelper.currentSubItem[1:12]; 
					endif;
				endif;
				if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_Release then
					rff1_1Function := CM_EDIReleaseRequestTI::releaseRequestNumber.name;
					_msgHelper.setNextSubItem();
					releaseReqNum := _msgHelper.currentSubItem[1:30];
					params.releaseRequestNumber := releaseReqNum;
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], releaseReqNum, _ediPartyRules);
					if releaseReqNum &lt;&gt; null and
					   releaseTI &lt;&gt; null then
						releaseTI.releaseRequestNumber := releaseReqNum;
					endif;
				endif;
			endif;
		endif;
		if rff1_1Function = null then
			if _msgHelper.currentGroup = 0 then
				if rff1_1Code = "ACW" then
					_msgHelper.setNextSubItem();
					if _msgHelper.currentSubItem = "1" then
					endif;
				elseif rff1_1Code = "BN" then
					if releaseTI &lt;&gt; null then //finish any previous bookingref 
						releaseTI.rawEDIData := params.rawEDIData;
					endif;
					params.rawEDIData := null;
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					params.releaseRequestNumber := bookingRefId; //cnwrs1 CCMS 1882 24 May 2010
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						params.releaseRequestNumber := bookingRefId;
					endif;
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
	/*				foreach idx in 1 to params.currentBrID.length do								
						charFounded := params.currentBrID[idx:1];
						if not charFounded.isInteger and not charFounded.toUpper.isUppercaseAlpha then
							//charFounded:= charFounded;
							pos := params.currentBrID.pos(charFounded,1);
							if _ediPartyRules &lt;&gt; null then				
								ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, charFounded, segmentValue);
								if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RelNo then // Ignore Release No After Charchter
									if pos &gt; 0 then
										params.currentBrID :=_msgHelper.currentSubItem[1:30].truncatedAt(pos-1);
										//pos :=0;
										break;
									else
										params.currentBrID := _msgHelper.currentSubItem[1:30];
									endif;
								endif;
							endif;
							//break;
						endif;
					endforeach;*/
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351	
				endif;
			elseif _msgHelper.currentGroup = 1 then
				if rff1_1Code = "VON" then // voyage number
				endif;
				
			elseif _msgHelper.currentGroup = 7 then
				if rff1_1Code = "BN" then //booking ref
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					releaseTI.releaseRequestNumber := bookingRefId;
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						releaseTI.releaseRequestNumber := bookingRefId;
					endif;
	//                params.currentBrID := _msgHelper.currentSubItem[1:30]; //cnwgb1 PAR 33637 24.3.2014           
	// 				releaseTI.releaseRequestNumber := params.currentBrID;
				elseif rff1_1Code = "SQ" then //container seq number
					_msgHelper.setNextSubItem();
					releaseTI.sequence := _msgHelper.currentSubItem[1:12]; 
				endif;
			endif;
		endif;
//SEL
	
//TDT	
	elseif _msgHelper.currentTag = "TDT" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);
		endif;
		if _msgHelper.currentGroup = 7 then
			_msgHelper.setCurrentGroup(9);
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "20" then
				self.getVoyageDetailsFromTDT(	_msgHelper, params.voyageCode, params.voyageOperatorCode, params.myVoyageOperator, params.vesselName, params.lloydsNumber, params.callsign );
				
				// Because some port clients (ANL and COS in particular) do not send
				// through the mandatory UNB record the operator is not getting set up.
				// To cater for this we will use the first valid TDT+20 operator
				// if and only if the operator is not already set up.
				if params.mySenderOperator = null then
					params.mySenderOperator	:= params.myVoyageOperator;
					params.senderOperatorCode := params.voyageOperatorCode;
				endif;
				
				_ediData.operatorCode	:= params.senderOperatorCode;
				
				if params.mySenderOperator &lt;&gt; null then
				//cnwrs1 par 26022 19 Oct 2010 now we have the vessel and the xlation operator try the vesselname xlation
					vesselCode := params.mySenderOperator.getXlationSystemCode(params.vesselName, XLATION_TYPE_VESSEL_BYOP, foundMatch);
					if not foundMatch then	//14 Mar 2014	cnwrs1	Par 33619 if not match the vesselName is returned
						vessel := app.myRoot.allVesselsByName[vesselCode];
					else
						vessel := app.myRoot.allVessels[vesselCode];
					endif;
					if vessel &lt;&gt; null then
						params.vesselName := vessel.name;
					endif;
					params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
				endif;
			endif;
		elseif _msgHelper.currentGroup = 9 then //Tranships
			if _msgHelper.currentField = "30" then
				_msgHelper.setCurrentGroup(1);
				
				//If the discharge port (LOC+11) matches this port then we're a tranship.
				thisPortCode := app.myPassport.myTerminal.getConfig(PortDestCode).String; //PAR24467 cnwsh3 17/06/2010
				
				if params.dischargePort = thisPortCode then
					params.transVoyageCode := params.voyageCode;
					
					self.getVoyageDetailsFromTDT(	_msgHelper,
													params.voyageCode,
													params.voyageOperatorCode,
													params.myVoyageOperator,				// cnwrl1 26/07/2010 PAR 25093
													params.vesselName,
													params.lloydsNumber,
													params.callsign );
					
					releaseTI.vesselName := params.vesselName; //PAR24680 - cnwsh3 28/6/2010.
					releaseTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
					//releaseTI.setConsignorVoyage(params.voyageCode.trimBlanks()[1:30]);
					
					if params.mySenderOperator &lt;&gt; null then
						// make sure the manual collection on CM_EDIConfig gets maintained
						params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator,
																			params.myVoyageOperator,
																			params.voyageCode,
																			params.vesselName,
																			params.lloydsNumber,
																			params.callsign );
						releaseTI.setVoyageCode( params.voyageCode );
					else
						// make sure the manual collection on CM_EDIConfig gets maintained
						releaseTI.setVoyageCode( releaseTI.getVoyageCode );
					endif;
				endif;
			endif;
		endif;
//TMP
    elseif _msgHelper.currentTag = "TMP" then // jlggb1 TFS 6574 18.8.17 This case revised to create Remark
		if _ediPartyRules &lt;&gt; null then
			_msgHelper.setNextField();
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_TMP_1_1, _msgHelper.currentField, segmentValue);
			_msgHelper.setNextField();
			
			tValueStr := _msgHelper.currentSubItem; 
            _msgHelper.setNextSubItem();
			
			tScaleStr := _msgHelper.currentSubItem;
			
			remark := 'TEMP ' &amp; tValueStr &amp; tScaleStr;
			
			//11 Jan 2018	NDL	TFS 36400
			if remark &lt;&gt; null and releaseTI &lt;&gt; null then
				reefTypeObj := app.myRoot.allISOTypes[releaseTI.isoType];
				if reefTypeObj = null or not reefTypeObj.isReefer then
					remark := null;
				endif;
			endif;
				
			if releaseTI.remarks = null then
				releaseTI.remarks := remark;
			else
				releaseTI.remarks := releaseTI.remarks &amp; CrLf &amp; remark;
			endif;	

			if  ruleFunction = CM_EDIEDIFactRule.Function_TMP_1_1_MTGradeTemp then
				// segment contains temperature to use as part of the MT grade xlation criteria.
				// we need to save this off for later
				temperature := tValueStr.asEDIReal();
                if tScaleStr = "CEL" then
                    self.setMTGradeXlatCrit_Temp (releaseTI, temperature);
                elseif tScaleStr = "FAH" then
                    self.setMTGradeXlatCrit_Temp (releaseTI, app.temperatureConversion(false,temperature));
                endif;
			endif;		
		
		endif;
	endif;
epilog

	delete ftxArray; 
	
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTReleaseMulti" id="2704c173-0f80-41a9-9263-7ea2b69bef9d">
        <source>processEDIFACTReleaseMulti(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
//
// ccms 2122 cnwrs1 01 Dec 2011
/* Changes

Date		Name	TFS#		Description
============================================================================
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
14/02/2012	cnwcs5	CCMS POL 2151 / par 29137 - extra defaults for consignor voyage, release date, clean
05/03/2012	cnwcs5F	par 29210 - process NAD+CC as consignee for MSK
24/04/2012	cnwcs5	par 29480 - changes for updating request date
14/12/2012  cnwgb1  CCMS POL 2216 / 30902 Heavy Rated Rules
07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - availability grade xlations
16 Sep 2013 cnwah9 removed error messagefs and unnecessary code
14 Mar 2014	cnwrs1	Par 33619 	if not match the vesselName is returned
09 Sep 2014 cnwma1  PAR 34855 	CCMS 2351: Hapag-Lloyd Release Request Enhancements
09 Sep 2014	cnwrs1	CCMS 2351 	att Sequence to Release request
11 Sep 2014	cnwma1	PAR#34855 	CCMS 2351: Hapag-Lloyd Release Request Enhancements
17 Mar 2015 cnwma1  PAR #35869 	CCMS 2351 - Ventilation Setting Value Query
28 Jul 2015	cnwrs1	Par 36681 - defualt availability grade not being set when isotyope translated
12 Nov 2015	cnwrs1	Par 37158 - should be able to process FTX+QQD++ and FTX+QQD+++ for the availabilityGrade
14 Jun 2016 cnwma1	TFS #2048 	POL - HSD EDI Empty Release Request
23 Mar 2017 cnwrh7  TFS 3602 	#EDI Party Enquiry FTX value not consistently used
18 Aug 2017 jlggb1  TFS 6574 	SNO - Extract more CA information from COPARN Release
21 Aug 2017	jlgrs1	TFS 6564 	add Coparn and Coreor RFF and NAD translation
28 Sep 2017 cnwma1	TFS # 6816 	POL - [Fwd: ##5406## : FW: [Request ID :##5406##] : Estimated Required Date Not Loading into Empty Release Request]
01 Nov 2017	jlgrs1	TFS 5705 - 	SNO - EDIDataBooking Prenote release Req
29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
14 Dec 2017	jlgrs1	TFS 8399 - 	SNO - EDI Booking Ref ID in group 7 not able to strip off version
22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
01 Mar 2018	jlgdap1	TFS 37308 	MEA Segment not adding to comments on the release detail line
24 Apr 2018	jlgrh7 	TFS #38149	SNO - Testing Ticket 8283 in JMT version .170
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
30 May 2018	jlgrs1	TFS 38357 	SNO Fix Xlations from TFS 6797
07 Jun 2018	jlgrs1	TFS 39018	SNO Cargo Operator in COPRAR
07 Apr 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
01/08/2019	jlgka1 	TFS 45467	SNO - Clean attribute in release request
22 Dec 2022 navra1	TFS 55813	PNL - The MEA segment was not read completely
16 Dec 2024 navsp1  MTN 23102   POL - Availability Grade EDI Translation is not working correctly for a Valid Grade
11 Jun 2025 navsp1  JIRA 35290  POL | Temperature specific EDI translations applying incorrectly
============================================================================*/
vars
	releaseHeaderTI : CM_EDIRequestHeaderTI; 
	releaseItemTI : CM_EDIRequestDetailTI; 
    params 			: CMIF_EDIFACTParams; 	// BGM local variable
    dtCode 			: String; 				// DTM local variable
    dtString 		: String; 				// DTM local variable
    ruleFunction 	: Integer; 				// DTM local variable
    theTime 		: TimeStamp; 			// DTM local variable
    isoType 		: String; 				// EQD local variable
    port 			: String; 				// LOC local variable
    vesselCode 		: String; 				// TDT local variable
    vessel 			: CM_Vessel; 			// TDT local variable
    thisPortCode 	: String; 				// TDT local variable
    qualityCode 	: String; 				// FTX local variable
	terminal 		: CM_Terminal;
	isoTypeObj 		: CM_ISOType;
	remark			: String;				// par 29137
    meaString       : String;       // cnwgb1 30902 14.12.2012
    ftxString       : String;       // cnwgb1 30902 14.12.2012
	temperature		: Real;
	foundMatch		: Boolean;
	segmentValue	: String;
	pos				: Integer;
	repChar			: String;
	charFounded		:String;
	idx				: Integer;
	avStr    		: String;
	ftxArray 		: StringArray512;
	rule 			: CM_EDIEDIFactRule;
	specialStow 	: String;
	measurementType	: String;	// jlggb1 TFS 6574 18.8.17
	tValueStr		: String;	// jlggb1 TFS 6574 18.8.17
	tScaleStr		: String;	// jlggb1 TFS 6574 18.8.17
	nad1_1Code : String;
	rff1_1Code : String;
	bookingRefId : String;
	releaseReqNum : String;
	reefTypeObj : CM_ISOType;
	nad1_1Function : String;
	nad2_1Function : String;
	nad3_1Function : String;
	rff1_1Function : String;
	cargoOperatorCode : String;
	nad1_Params : Boolean;
	nadl_Release : Boolean;
begin 
    temperature := NULL_TEMPERATURE;                //JIRA-35290
    params 		:= _msgHelper.myCurrentParams;
	terminal 	:= app.myPassport.myTerminal;

    if params.myEDIRequestHeaderTI &lt;&gt; null then
        releaseHeaderTI := params.myEDIRequestHeaderTI;
    endif;    
    if params.myEDIRequestItemTI &lt;&gt; null then
        releaseItemTI := params.myEDIRequestItemTI;
    endif;    
//DGS
    if _msgHelper.currentTag = "DGS" then
        if _msgHelper.currentGroup &lt; 6 then
            _msgHelper.setCurrentGroup( 6 );
        endif;
//DIM
    elseif _msgHelper.currentTag = "DIM" then
//DTM
    elseif _msgHelper.currentTag = "DTM" then
        if  _msgHelper.currentGroup = 0 or //28.9.2017 cnwma1 TFS #6816
			_msgHelper.currentGroup = 1 or
		   _msgHelper.currentGroup = 7 then	
            _msgHelper.setNextField();
            dtCode := _msgHelper.currentSubItem;
            _msgHelper.setNextSubItem();
            dtString := _msgHelper.currentSubItem.trimBlanks();
            _msgHelper.setNextSubItem();
            theTime := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
            
            if _msgHelper.currentSubItem = "137" then		// date of EDI file issue
                params.ediFileIssueDateTime := theTime;
            endif;
			
            // In addition to setting the File Issue DateTime, The EDi Party Rules allow us to set some other fields.
			if _ediPartyRules &lt;&gt; null then
				ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_DTM_1_1, dtCode, segmentValue );
				
				if ruleFunction = CM_EDIEDIFactRule.Function_DTM_1_1_EstReqDT then // Estimated Required Time
					// No Request at this point in processing
					if _msgHelper.currentGroup = 7 then
						releaseHeaderTI.estimatedRequiredDate := theTime;
					else
						params.requiredDT 				:= theTime;
					endif;
				elseif ruleFunction = CM_EDIEDIFactRule.Function_DTM_1_1_ReqDT then // Requested time
				
					if _msgHelper.currentGroup = 7 then
						releaseHeaderTI.requestDate 			:= theTime;
						releaseHeaderTI.requestDateDoUpdate	:= true;		// par 29480 April 2012
					else
						params.requestDT 				:= theTime;
						params.requestDTDoUpdate		:= true;		// par 29480 April 2012
					endif;
				endif;
			endif;            
        endif; 
//EQA
    elseif _msgHelper.currentTag = "EQA" then
        if _msgHelper.currentGroup = 7 then	
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "RG" then	// generator release item
//				create releaseHeaderTI persistent; 
//				params.myEDIRequestHeaderTI := releaseHeaderTI;
				
//				releaseHeaderTI.setForCreateNew(_ediData);
				create releaseItemTI persistent; 
				releaseItemTI.setForCreateNew(_ediData);
				releaseItemTI.myParent := releaseHeaderTI;
				releaseItemTI.releaseRequestNumber := releaseHeaderTI.releaseRequestNumber;
				releaseItemTI.messageMode := _msgHelper.currentMessageMode;
				params.myEDIRequestHeaderTI := releaseHeaderTI;
				params.myEDIRequestItemTI := releaseItemTI;
				releaseItemTI.setId(releaseHeaderTI.id);
//				releaseHeaderTI.releaseRequestNumber 	:= params.currentBrID;
//				releaseHeaderTI.statusBulkRelease 	:= BR_PENDING_STRING;			// WILL GET OVERWRITTEN BY RULES LATER
//				releaseHeaderTI.id 					:= null;
//				releaseHeaderTI.myParent 				:= releaseHeaderTI;
//				releaseHeaderTI.messageMode 			:= _msgHelper.currentMessageMode;
//				releaseHeaderTI.destinationPort 		:= params.destination;
//				releaseHeaderTI.dischargePort 		:= params.dischargePort;
//				releaseHeaderTI.operatorCode 			:= params.senderOperatorCode;
//				releaseHeaderTI.releaseByType 		:= true;
				releaseItemTI.quantity 				:= 1;
//                releaseHeaderTI.estimatedRequiredDate := params.requiredDT;
//                releaseHeaderTI.requestDate 			:= params.requestDT;
//				releaseHeaderTI.requestDateDoUpdate	:= params.requestDTDoUpdate;	// par 29480 April 2012
				releaseItemTI.isGeneratorAttachment	:= true;						// par 29480 April 2012
				
//				if params.vesselName &lt;&gt; null then
//					releaseHeaderTI.vesselName := params.vesselName;
//				endif;
				
//				releaseHeaderTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
				
//				releaseHeaderTI.consignor 	:= params.consignor;
//				releaseHeaderTI.senderCode 	:= params.senderCode;
								
				self.setEDIPartyDefaultsMulti(_ediPartyRules, terminal, params, releaseHeaderTI, releaseItemTI, true);					// par 29137					
			endif;
		endif;
//EQD
	elseif _msgHelper.currentTag = "EQD" then
		_msgHelper.setCurrentGroup(7);
		// We've previously seen an EQD. Need to make another one for multi item cnwgb1 11.11.08
		// The first bookingRef has been created in RFF section. Before creating others multi items, need to flag the first one as multi item.  Par 18495, Jan 2009
		if releaseHeaderTI = null then 
			create releaseHeaderTI persistent; 
			params.myEDIRequestHeaderTI := releaseHeaderTI;
			releaseHeaderTI.setForCreateNew(_ediData);
			releaseHeaderTI.releaseRequestNumber := params.releaseRequestNumber;
			if releaseHeaderTI.releaseRequestNumber  = null then
				releaseHeaderTI.releaseRequestNumber := params.currentBrID;
			endif;	
		endif;
		releaseHeaderTI.statusBulkRelease 	:= BR_PENDING_STRING;		// will get overritten by rules later
		releaseHeaderTI.setIdDefault(null);
		releaseHeaderTI.myParent 				:= releaseHeaderTI;
		releaseHeaderTI.messageMode 			:= _msgHelper.currentMessageMode;
		if params.mySenderOperator &lt;&gt; null then
			releaseHeaderTI.destinationPort := params.mySenderOperator.getXlationSystemCode(params.destination, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseHeaderTI.destinationPort := params.destination;
		endif;
		if params.mySenderOperator &lt;&gt; null then
			releaseHeaderTI.dischargePort := params.mySenderOperator.getXlationSystemCode(params.dischargePort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseHeaderTI.dischargePort := params.dischargePort;
		endif;
		if params.mySenderOperator &lt;&gt; null then
			releaseHeaderTI.loadPort := params.mySenderOperator.getXlationSystemCode(params.loadPort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		else
			releaseHeaderTI.loadPort 	:= params.loadPort;
		endif;
		releaseHeaderTI.operatorCode 			:= params.cargoOperatorCode;
		releaseHeaderTI.consignee 			:= params.consignee;
		releaseHeaderTI.consignor 			:= params.consignor;
		releaseHeaderTI.customsAgent := params.customsAgent;
		releaseHeaderTI.carrierCode := params.releaseCarrier;
		releaseHeaderTI.freightForwarder		:= params.freightForwarder;		// 11/07/2013 cnwar2 #31784
		releaseHeaderTI.estimatedRequiredDate := params.requiredDT;
		releaseHeaderTI.requestDate 			:= params.requestDT;
		releaseHeaderTI.requestDateDoUpdate	:= params.requestDTDoUpdate;	// par 29480 April 2012
		releaseHeaderTI.senderCode 			:= params.senderCode;
		releaseHeaderTI.specialStowage 		:= params.specialStowage;	//07 Jun 2017	NDL	TFS 4454
		if params.vesselName &lt;&gt; null then
			releaseHeaderTI.vesselName := params.vesselName;
		endif;
		releaseHeaderTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
		if params.mySenderOperator &lt;&gt; null then
			params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
			releaseHeaderTI.setVoyageCode(params.voyageCode[1:30]);
		else
			// make sure the manual collection on CM_EDIConfig gets maintained
			releaseHeaderTI.setVoyageCode(releaseHeaderTI.getVoyageCode);
		endif;
		releaseHeaderTI.ediFileIssueDateTime	:= params.ediFileIssueDateTime;
		create releaseItemTI persistent; 
		releaseItemTI.setForCreateNew(_ediData);
		releaseItemTI.myParent := releaseHeaderTI;
		releaseItemTI.setId(releaseHeaderTI.id);
		releaseItemTI.releaseRequestNumber := releaseHeaderTI.releaseRequestNumber;
		releaseItemTI.messageMode := _msgHelper.currentMessageMode;
		params.myEDIRequestItemTI := releaseItemTI;
		releaseItemTI.quantity := 1; //cnwgb1 24.2.2014 PAR 33637
        params.foundEQD := true; //cnwgb1 24.2.2014 PAR 33637
		self.setEDIPartyDefaultsMulti(_ediPartyRules, terminal, params, releaseHeaderTI, releaseItemTI,  false);					// par 29137				
		
		_msgHelper.setNextField();
		
		if _msgHelper.currentField = "CN" or _msgHelper.currentField[1:2] = "T7" then
			releaseHeaderTI.setCargoType(TI_CargoType_Container);
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = null then
				releaseHeaderTI.releaseByType := true;
			else
				releaseHeaderTI.setId(_msgHelper.currentField[1:11]); 
				releaseItemTI.setId(releaseHeaderTI.id);
			endif;
			
			_msgHelper.setNextField();
			isoType := _msgHelper.currentField[1:4];
			
			//now use xlation CCMS 1157
			if params.mySenderOperator &lt;&gt; null then
				releaseItemTI.isoType := params.mySenderOperator.getXlationSystemCode(isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			else
				releaseItemTI.isoType := isoType.trimBlanks()[1:4];
			endif;
			
			isoTypeObj := app.myRoot.allISOTypes[releaseItemTI.isoType];
            
			if isoTypeObj &lt;&gt; null then	// par 29137 start
                if isoTypeObj.isReefer then
					if _ediPartyRules &lt;&gt; null then
						if params.availabilityGrades = null then    					//cnwma1 TFS #2048 14/06/2016 
							releaseItemTI.availabilityGrades := _ediPartyRules.CM_EDIPartyCoparnRules.defaultAvailabilityGradeReefer.String;
						else
							releaseItemTI.availabilityGrades := params.availabilityGrades;  //cnwma1 TFS #2048 14/06/2016 
						endif;
					endif;
					//jlgka1 TFS 45467 --&gt;
					if _ediPartyRules &lt;&gt; null then
						if _ediPartyRules.defaultReleaseIncludeNonClean then						
							releaseItemTI.clean	:= false;
						else
							releaseItemTI.clean	:= true;
						endif;
					else
						// default to clean for reefer
						releaseItemTI.clean	:= true;
					endif;
					//jlgka1 TFS 45467 &lt;--					
                else
					if _ediPartyRules &lt;&gt; null then
						if params.availabilityGrades = null then    					//cnwma1 TFS #2048 14/06/2016 
							releaseItemTI.availabilityGrades := _ediPartyRules.CM_EDIPartyCoparnRules.defaultAvailabilityGrade.String;
						else
							releaseItemTI.availabilityGrades := params.availabilityGrades;  	//cnwma1 TFS #2048 14/06/2016 
						endif;
					endif;
                endif;
            endif;						// par 29137 - end
			            
			if releaseItemTI.checkISOGroup then
				if isoTypeObj &lt;&gt; null and
				   isoTypeObj.myISOTypeGroup &lt;&gt; null then
					releaseItemTI.isoTypeGroup := isoTypeObj.myISOTypeGroup.code;
				endif;
			endif;
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = "4" then 
				releaseItemTI.fullOrMT := "E"; //cnwrs1 CCMS 1882 24 May 2010
				releaseHeaderTI.mtRelease := true;
			elseif _msgHelper.currentField = "5" then 
				releaseItemTI.fullOrMT := "F";
				releaseHeaderTI.mtRelease := false;
			endif;
		endif;
//EQN
    elseif _msgHelper.currentTag = "EQN" then
        if _msgHelper.currentGroup = 7 then
            _msgHelper.setNextField();
            if params.foundEQD = true then //cnwgb1 24.2.2014 PAR 33637
                releaseItemTI.quantity := _msgHelper.currentField.Integer;
            else
                releaseItemTI.quantity := releaseItemTI.quantity + _msgHelper.currentField.Integer;
                params.foundEQD := false;
            endif;
        endif; 
//FTX
	elseif _msgHelper.currentTag = "FTX" then
		_msgHelper.setNextField();					// 010 Text subject qualifier
		
		//cnwma1 TFS #2048 14/06/2016 
		if _msgHelper.currentGroup = 0 then
			if _msgHelper.currentField = "CUR" then
				if _ediPartyRules &lt;&gt; null then 
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                		//+TFS3602 Stripe off "FTX+"
							dtCode := dtCode[5 : end];
					endif;
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue );
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_EstReqDT then
						segmentValue := segmentValue.extractInteger.asStringJMT;
						theTime := segmentValue.getUNEDIFACTTimeStamp(101);
						if theTime &lt;&gt; null then
							params.requiredDT := theTime;
						endif;
					endif;
				endif;
			//endif;
			elseif _msgHelper.currentField = "AVD" then	
				if _ediPartyRules &lt;&gt; null then 
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                										//+TFS3602 Stripe off "FTX+"
							dtCode := dtCode[5 : end];
					endif;
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue );
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then
						segmentValue := segmentValue.removeString("'").removeString("+");
						if params.mySenderOperator &lt;&gt; null then
							avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(segmentValue,foundMatch,temperature,avStr);
							params.availabilityGrades :=avStr;
								
						endif;
					endif;
				endif;	
			else						
				if _ediPartyRules &lt;&gt; null then																																	//+TFS3602 For Any Free Text Translation
					dtCode := _msgHelper.currentMessage;
					 if  dtCode[1:4].cnContains("FTX+") then                                                                		
						dtCode := dtCode[5 : end];
					endif;
					
					//07 Jun 2017	NDL	TFS 4454
					rule := _ediPartyRules.allEDIPartyRules.getEDIEDIFactRule( CM_EDIEDIFactRule.Item_FTX_3_1 );
					if rule &lt;&gt; null then
						ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_3_1, dtCode, segmentValue);
						if ruleFunction = CM_EDIEDIFactRule.Function_FTX_3_1_Stowage then
							create ftxArray transient;
							dtCode.getTokensForDelimiter ('+', ftxArray);
							if ftxArray[1] = rule.value then
								specialStow := rule.getFTXSpecialStowage(ftxArray);
								if specialStow &lt;&gt; null then
									params.specialStowage := specialStow;
								endif;
							endif;
							delete ftxArray;
						endif;
						ruleFunction := null;
					endif;
					
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, dtCode, segmentValue);
					
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_EstReqDT then																													//Only 2 rule functions implemented here for currentGroup 0
						segmentValue := segmentValue.extractInteger.asStringJMT;
						theTime := segmentValue.getUNEDIFACTTimeStamp(101);
						if theTime &lt;&gt; null then
							params.requiredDT := theTime;
						endif;
					elseif  ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then
						segmentValue := segmentValue.removeString("'").removeString("+");
						if params.mySenderOperator &lt;&gt; null then
							avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(segmentValue,foundMatch,temperature,avStr);
							params.availabilityGrades :=avStr;
						endif;
					endif;
				endif;
			endif;
		elseif _msgHelper.currentGroup = 3 then //or _msgHelper.currentGroup = 7 then
			if _msgHelper.currentField = "AAA" then 	// goods description
				_msgHelper.setNextField();			// 020 Text function coded
				_msgHelper.setNextField();			// 030 Text reference
				_msgHelper.setNextField();			// 040 Text literal
//				releaseTI.remarks := releaseTI.remarks&amp;_msgHelper.currentField[1:20];
			endif;
		elseif _msgHelper.currentGroup = 6 then
			if _msgHelper.currentField = "AAC" then
			elseif _msgHelper.currentField = "AAD" then
			endif;
		elseif _msgHelper.currentGroup = 7 then
			if _msgHelper.currentField = "ABS" then //Additional conditions
			elseif _msgHelper.currentField = "HAN" then //Handling instructions
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseHeaderTI.remarks = null then
					releaseHeaderTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseHeaderTI.remarks := releaseHeaderTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
				releaseItemTI.remarks := releaseHeaderTI.remarks;
			elseif _msgHelper.currentField = "SIN" then //Special instructions
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseHeaderTI.remarks = null then
					releaseHeaderTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseHeaderTI.remarks := releaseHeaderTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
				releaseItemTI.remarks := releaseHeaderTI.remarks;
			elseif _msgHelper.currentField = "AAI" then
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				if releaseHeaderTI.remarks = null then
					releaseHeaderTI.remarks := _msgHelper.currentField[1:60].trimBlanks;
				else
					releaseHeaderTI.remarks := releaseHeaderTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;
				endif;
				// TFS#53294 NAVSP1 31MAR2022 - START
				if releaseItemTI.remarks = null then																	
					releaseItemTI.remarks := _msgHelper.currentField[1:60].trimBlanks;														
				else																									
					releaseItemTI.remarks := releaseItemTI.remarks &amp; CrLf &amp; _msgHelper.currentField[1:60].trimBlanks;	
				endif;
				// TFS#53294 NAVSP1 31MAR2022 - END
			elseif _msgHelper.currentField = "QQD" then //Quality (Availability Grade)
                _msgHelper.setNextField();
				_msgHelper.setNextField();
				//_msgHelper.setNextField();
                qualityCode := _msgHelper.currentSubItem;
				if qualityCode = null then
					_msgHelper.setNextField();
					qualityCode := _msgHelper.currentSubItem;
				endif;
				avStr := params.mySenderOperator.getXlationSystemCode_MTGrade(qualityCode[1:60], foundMatch, temperature, avStr);	//MTN-23102
                //May need to append, but not if the only thing there is the default.
                releaseItemTI.availabilityGrades := avStr;//qualityCode[1:60];	// par 31259									    //MTN-23102
			//	releaseItemTI.remarks := releaseHeaderTI.remarks;
			endif;
            
            // CCMS 2216 PAR 30902 cnwgb1 Heavy Rating
			if _ediPartyRules &lt;&gt; null then
				// strip off 'FTX+'
				ftxString := _msgHelper.currentMessage [5:end];
				// strip off "'"
				if ftxString &lt;&gt; null then
					ftxString := ftxString[1:ftxString.length()-1];
				endif;
				
				ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_4_1, ftxString, segmentValue);
				
				if ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_Heavy then // Heavy Rated Min Value
					// cnwcs5 15/04/2012 - actually we need to check for a match before deciding we are heavy rated
					// segment 4.1. contains the text to use to decide whether we are heavy or not
					releaseItemTI.heavyDuty := true;    // NOTE if there are multiple segments - any one of them can set 
													// Heavy Duty to true - so we don't reset ever - cnwgb1
				elseif ruleFunction = CM_EDIEDIFactRule.Function_FTX_4_1_MTGradeText then					
                    // segment 4.1 contains text to use as part of the MT grade xlation criteria.
                    // we need to save this off for later
                    self.setMTGradeXlatCrit_TextMulti (releaseItemTI, segmentValue.String);
				endif;
			endif;
		endif;
//GID
    elseif _msgHelper.currentTag = "GID" then
        if _msgHelper.currentGroup &lt; 3 then
            _msgHelper.setCurrentGroup(3);
        endif;
//LOC
	elseif _msgHelper.currentTag = "LOC" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);	
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "9" then //place of loading
				_msgHelper.setNextField();
				params.loadPort := _msgHelper.currentSubItem[1:5].trimBlanks();
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				params.dischargePort := port;
			elseif _msgHelper.currentField = "7" or //delivery
			   _msgHelper.currentField = "8" then //destination
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				params.destination := port;
			endif;
		elseif _msgHelper.currentGroup = 7 then //par 16128 cnwrs1 Mar 2008
			if _msgHelper.currentField = "9" then //place of loading
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseHeaderTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseHeaderTI.loadPort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseHeaderTI.loadPort := port;
					endif;
				endif;
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseHeaderTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseHeaderTI.dischargePort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseHeaderTI.dischargePort := port;
					endif;
				endif;
			elseif _msgHelper.currentField = "88" then 
			elseif _msgHelper.currentField = "7" or //delivery
			   _msgHelper.currentField = "8" then //destination
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if releaseHeaderTI &lt;&gt; null then
					if params.mySenderOperator &lt;&gt; null then 
						releaseHeaderTI.destinationPort := params.mySenderOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						releaseHeaderTI.destinationPort := port;
					endif;
				endif;
			endif;
		elseif _msgHelper.currentGroup = 9 then 
