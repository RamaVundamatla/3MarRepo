    <JadeMethod name="setupForm" id="fd1cc871-bc24-402d-bcdf-c01f0e58590c">
        <updating/>
        <source>setupForm() updating;
//20 August 2008	cnwdw1	
//
vars
	caption	: String;
begin
	caption := self.caption;
	
	inheritMethod();
	
	self.setCaption(caption &amp; " - " &amp; self.yaBlock.getYAMDisplay(false));
	self.centreOverParent(100);
	self.populateForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="showDeckingOptions" id="85c812f1-9901-4685-b785-c8bf12910084">
        <source>showDeckingOptions();
//20 August 2008	cnwdw1	
//
vars

begin
	self.lblDeckingOptIn.caption 	:= self.yaBlock.myDeckingOptions.getDisplayStringInOut(true);
	self.lblDeckingOptOUT.caption 	:= self.yaBlock.myDeckingOptions.getDisplayStringInOut(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b92a303a-227f-4305-a74d-207035d61fb3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010171, locale);
	btnCancel.translateCaption(Xlat_0010172, locale);
	btnDecking.translateCaption(Xlat_0010173, locale);
	btnSave.translateCaption(Xlat_0010174, locale);
	lblDeckingIN.translateCaption(Xlat_0010178, locale);
	lblDeckingOUT.translateCaption(Xlat_0010179, locale);
	lblMaxHeight.translateCaption(Xlat_0010180, locale);
	lblMinHeight.translateCaption(Xlat_0010181, locale);
	lblStatus.translateCaption(Xlat_0010182, locale);
	optClosed.translateCaption(Xlat_0010183, locale);
	optOpen.translateCaption(Xlat_0010188, locale);
end;</source>
    </JadeMethod>
</GUIClass>
