        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
//-----------------------------------------
//
// Created : by cnwaer1 27 August 2008
//-----------------------------------------
vars

begin
	
	if self.btnShowBookItms.value then
		//self.doAddEditBookRequest(self.myCurrentObject.CM_BookingRefItem);				//+cnwml2 PAR20173 SFW CCMS 1091
		self.myAssistant.GTE_Assistant.doAddEditBookRequest(self.myCurrentObject.CM_BookingRefItem);	//PAR 20296 Sep 2009
	else
		//self.doAddEditBookRequest(self.myCurrentObject.CM_BookingRef);					//+cnwml2 PAR20173 SFW CCMS 1091
		if self.isEnhanced then
			self.myAssistant.GTE_Assistant.doAddEditBookRequest(self.myCurrentObject.CM_BookingRef);	//PAR 20296 Sep 2009
		else
			self.zDoEdit();
		endif;
	endif;
	
	//-cnwml2 PAR20173 SFW CCMS 1091
	/*if not self.useBookingSumView then
		return;
	endif;
	
	self.btnEditTV_click(self.btnEditTV);*/
	
end;</source>
