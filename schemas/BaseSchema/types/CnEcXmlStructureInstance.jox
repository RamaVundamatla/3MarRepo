    <JadeMethod name="getTagAttribute" id="3fe9137c-f30a-499a-a9f5-376e80afca72">
        <source>getTagAttribute(pString : String):String;

vars
	pos			: Integer;
	retValue	: String;
	
begin
	pos := 1;
	
	while pos &lt;= self.tagAttribute.length do
		if self.tagAttribute[pos:pString.length + 1].toUpper = (pString &amp; "=").toUpper then
			pos := pos + pString.length + 2;
					
			while pos &lt;= self.tagAttribute.length do
				while self.tagAttribute[pos:1] &lt;&gt; '"' do 
					retValue := retValue &amp; self.tagAttribute[pos:1];
					pos := pos + 1;
					
					if pos &gt; self.tagAttribute.length then
						break;
					endif;  
				endwhile;
				
				break; 
			endwhile;  
		else
			pos := pos + 1;
		endif;			
	endwhile;
	
	return retValue;
end;</source>
        <Parameter name="pString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="9bfa1f95-9b8c-4eea-a3bb-21b72bb38338">
        <updating/>
        <source>initializeMe(pName:String; pData:String; pAttrib:String) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	pName (String) - The tag's name.
//				pData (String) - The tag's data.
//				pAttrib (String) - The tag's attribute(s).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/02/2002	cnwdad1		Changed to no longer set the tagData property.  This
//							will now only be done by a reimplementation of this
//							method on the CnEcXmlFieldInstance subclass.
// --------------------------------------------------------------------------------
begin
	self.tagName	:= pName;
//	self.tagData	:= pData;
	self.setTagAttribute(pAttrib);
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pData" type="String"/>
        <Parameter name="pAttrib" type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeWithTagData" id="1de66387-5a40-42ad-8592-988d1237df95">
        <updating/>
        <source>initializeWithTagData(pName:String; pData:String; pAttrib:String) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2002 by cnwdad1
//
// Purpose:		Initializes the receiver's property values, including Tag Data.
//				If Tag Data is NOT to be set on Group structure instances, then
//				use the initializeMe() method instead of this one.
//
// Parameters:	pName (String) - The tag's name.
//				pData (String) - The tag's data.
//				pAttrib (String) - The tag's attribute(s).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.tagName	:=	pName;
	self.tagData	:=	pData;
	
	self.setTagAttribute(pAttrib);
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pData" type="String"/>
        <Parameter name="pAttrib" type="String"/>
    </JadeMethod>
