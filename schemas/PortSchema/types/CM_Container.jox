    <JadeMethod name="getRawMeasurementValue" id="19fdeb19-40ad-4396-90c8-82c95b9b69e6">
        <source>getRawMeasurementValue(_rowName: String): Decimal;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwdap1	Initial creation
30 October	2018	jlgrh7 TFS #41372  MSL - MGW on Cargo Enquiry
*/
vars
	volume			: Decimal [23,10];
	maxWeight		: Decimal [23,10];
	containerRange	: CM_ContRange;
	theISO : CM_ISOType;

begin
	if _rowName = ETRow_OverLengthBack then
		return self.overLengthRear;
	elseif _rowName = ETRow_ContainerVolume then
		volume := self.getMaxVolume;
		if volume &gt; NULL_VOLUME then
			return volume;
		else
			return null;
		endif;
	elseif _rowName = ETRow_VolumeMax then
		return self.getMaxVolume();
	elseif _rowName = ETRow_WeightMax then
		maxWeight := self.getMaxWeightFromTIMaster();
		if maxWeight = 0 then
			containerRange := app.myRoot.lookupContainerRange(self.id);
			if containerRange &lt;&gt; null then
				maxWeight := containerRange.maxKilos + containerRange.tareKilos;
			endif;
		endif;
		return maxWeight;
	elseif _rowName = ETRow_MaxTotalWeight then						//+TFS41372

		// TFS 45590	return self.getISOTypeObject.maxTotalWeight;
		theISO := self.getISOTypeObject();// TFS 45590
		
		if theISO &lt;&gt; null then
			return theISO.maxTotalWeight;
		endif;
		
		return 0;
	else
		return inheritMethod(_rowName);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReceivalIMEXStatus" id="c8515793-2eb1-4de0-aa2e-ccbd06e500cb">
        <source>getReceivalIMEXStatus(): Integer;
//----------------------------------------------------------------
//	Created:	09 September 2005	by Jason Chapman  (cnwjc2)
//
//	This is for on-ship ti's.  Wont return anything different for
//	ti's not on-ship.
//
//	For on-ship TI's this returns the imex status the container will be once discharged
//	For everything else it just returns the current imex status
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 18/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships. Undoes changes for CCMS 1116
// 11/04/2018	jlgsl4		TFS 37410 Import MTs IMEX status

vars
	matched  : Boolean;
begin

// This all needs to be reworked as there are very messy rules here.
	if self.site = TI_SITE_ONSHIP then // TFS 37410
//	and self.isImport // TFS 37410
	//and not self.isTranshipItem			// PAR #25021 isImport now specifically excludes tranships// PAR #23546 CCMS 1116 ignore tranships	if self.site = TI_SITE_ONSHIP then // TFS 37410
//	and self.isEmpty then // TFS 37410
		//we only have rules for empties // TFS 37410
//		if self.isStopSetToBeProcessed(StopProcessEmptyImport) // TFS 37410
//		and app.getMyTerminalConfigDO_NOT_USE(MTImportIfIntendedOffsite).Boolean then // TFS 37410
//			return TI_IMEX_STATUS_IMPORT;//(same as self.imexStatus) // TFS 37410
//		else // TFS 37410
//			return TI_IMEX_STATUS_STORAGE; // TFS 37410
//		endif; // TFS 37410
		return self.myTerminal.getMatchingIMEXTransition(self,matched); // TFS 37410
	endif;
		
	return inheritMethod();
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReeferAlert" id="ea1eb0f3-6985-43cd-a00c-23d5981d6010">
