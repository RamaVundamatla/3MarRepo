<CollClass name="CM_GeneralCCtrByordinalDict" id="1ec27e1a-6ddf-4076-9d82-e0f71e09c1af">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_GeneralCargoController"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_GeneralCargoController::ordinal"/>
    </MemberKey>
    <JadeMethod name="moveElement" id="a45a89e1-bcb8-4fc3-8c92-c655cc24298b">
        <lockReceiver/>
        <updating/>
        <source>moveElement(ordinal1, ordinal2 : Integer; _gc : CM_GeneralCargoController input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	gc1 : CM_GeneralCargoController;
	gc2 : CM_GeneralCargoController;

begin

	gc1 := self.getAtKey(ordinal1);
	gc2 := self.getAtKey(ordinal2);
	self.remove(gc1);
	self.remove(gc2);
	
	gc1.setOrdinal(ordinal2);
	gc2.setOrdinal(ordinal1);
	self.add(gc1);
	self.add(gc2);

epilog

end;</source>
        <Parameter name="ordinal1" type="Integer"/>
        <Parameter name="ordinal2" type="Integer"/>
        <Parameter name="_gc" type="CM_GeneralCargoController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rearrangeOrdinals" id="b82b558e-2d79-4416-90b0-f1ed6161502d">
        <source>rearrangeOrdinals( _allGCs :CM_GeneralCCtrByordinalDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	pxyGc,gc : CM_GeneralCargoController;
	idx, size : Integer;
	
begin

	size := self.size();
	idx := 1;
	foreach gc in self do
		if idx &gt; size then
			break;
		endif;
		gc.setOrdinal(gc.ordinal + 10000);
		idx := idx + 1;		
	endforeach;
	foreach pxyGc in _allGCs do
		gc := pxyGc.pxyGetRealObject;
		if gc &lt;&gt; null then
			gc.setOrdinal(pxyGc.ordinal);
		endif;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_allGCs" type="CM_GeneralCCtrByordinalDict" usage="input"/>
    </JadeMethod>
</CollClass>
