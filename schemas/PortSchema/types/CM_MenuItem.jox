    <JadeMethod name="setForUpdate" id="384ef98d-aaa9-4f08-b1d7-5c402c6c82e3">
        <updating/>
        <source>setForUpdate(_proxy : SelfType) updating;

vars

begin

	self.constantValue			:= _proxy.constantValue;
	self.heading				:= _proxy.heading;
	self.menuId					:= _proxy.menuId;
	self.pictureStringButton	:= _proxy.pictureStringButton;
	self.pictureStringButtonDown:= _proxy.pictureStringButtonDown;
	self.pictureStringIcon		:= _proxy.pictureStringIcon;
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="6b43b53a-bcde-449d-af23-94fd342e6fd2">
        <updating/>
        <source>setFromXML(_str : String; _root : CM_MenuRoot; _constValue : Integer; _childValues : IntegerArray; _systemOnly : Boolean; _passedInMenuId : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idPrefix	: String;
begin

	self.constantValue	:= _constValue;
	self.heading		:= _str.cnEcGetTagValueOfName(XMLTag_Heading);
	if _passedInMenuId &lt;&gt; null then
		self.menuId		:=_passedInMenuId;
	else
		self.menuId		:= _str.cnEcGetTagValueOfName(XMLTag_Id);
	endif;
/*
	// tmp code for transition from 1 system to the other for menu id
	if self.isKindOf(CM_MenuDtl) then
		idPrefix := '_dtl';
	else
		idPrefix := '_hdr';
	endif;
	if self.menuId &lt;&gt; null then
		self.menuId := idPrefix &amp; self.constantValue.String;
	else
		self.menuId := idPrefix &amp; self.constantValue.String;
	endif;
*/	
	self.pictureStringButton	:= _str.cnEcGetTagValueOfName(XMLTag_PictureButton);
	self.pictureStringButtonDown:= _str.cnEcGetTagValueOfName(XMLTag_PictureButtonDown);
	self.pictureStringIcon		:= _str.cnEcGetTagValueOfName(XMLTag_PictureIcon);
	self.toolTip				:= _str.cnEcGetTagValueOfName(XMLTag_ToolTip);
	self.myParent				:= _root;	// This may get reset later in CM_MenuHdr::setChildrenFromXML
	
	if _root &lt;&gt; null then	
		if _root.isKindOf(CM_MenuRootForRoot) then
			self.myMenuRoot := _root.CM_MenuRootForRoot;
			self.myMenuReportRoot := null;
		elseif _root.isKindOf(CM_MenuRootReportForRoot) then
			self.myMenuReportRoot := _root.CM_MenuRootReportForRoot;
			self.myMenuRoot := null;
		endif;
	endif;	
	
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_childValues" type="IntegerArray"/>
        <Parameter name="_systemOnly" type="Boolean"/>
        <Parameter name="_passedInMenuId" type="String"/>
    </JadeMethod>
