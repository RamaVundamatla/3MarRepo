    <JadeMethod name="setDefaultsCallBack" id="32b15ea4-e04d-4b20-8277-1e11402de405">
        <source>setDefaultsCallBack(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean;
/*
	Created on 22 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	rtnCode			: Boolean;
	tmpInt			: Integer;
	str 			: String;
	theRowObject	: CM_Object;
	theBookingRef	: CM_BookingRef;
begin
	if _attrName = ETRow_ConsigneeCode then // adm 260908 Par 17026
		rtnCode := true;
		theRowObject := app.getCargoFieldObject(_obj, ETRow_ConsigneeCode);
		tmpInt := cmbConsignee.findObject(theRowObject);
		if tmpInt &gt; -1 then
			cmbConsignee.listIndex := tmpInt;
			str := cmbConsignee.text;
		endif;	
	// cnwjre1 26/5/2011 par 27460
	elseif _attrName = ETRow_CarrierReference then
		rtnCode := true;
		if _obj.isKindOf(CM_BookingRef) then
			theBookingRef := _obj.CM_BookingRef;
			str := theBookingRef.operatorReferenceNumber;
		endif;
	endif;	
	
	
	if str &lt;&gt; null then
		_tbl.setValue(_row, str);
	endif;
	if rtnCode then	
		return rtnCode;
	else
		return inheritMethod(_tbl, _attrName, _row, _obj);
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBack_Old" id="43101257-27cb-4439-a021-ea05da8495f5">
        <source>setDefaultsCallBack_Old(pTbl: CM_EntryTable input; pAttrName: String; pRow: Integer; pObj: Object): Boolean;
//-----------------------------------------------------------------------
//	Created:	13 June 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	theBookingRef	: CM_BookingRef;
	theTI			: CM_TrackedItem;
	theContainer	: CM_Container;
	theConsignee	: CM_ConsigneeConsignor;
	str				: String;
	assistant		: GTE_Assistant;
	rtnCode			: Boolean;
	tmpReal			: Real;
	tmpInt			: Integer;
	tmpIntArray		: IntegerArray;
begin

	assistant := self.myAssistant.GTE_Assistant;

	if pObj.isKindOf(CM_BookingRef) then
		theBookingRef := pObj.CM_BookingRef;
	else
		theTI := pObj.CM_TrackedItem;
		if theTI.isKindOf(CM_Container) then
			theContainer := theTI.CM_Container;
		endif;
	endif;

	if pAttrName = ETRow_ConsigneeCode then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			theConsignee := theBookingRef.myConsignee;
		else
			theConsignee := app.myRoot.allConsigneeConsignors[theTI.consignee];
		endif;

		tmpInt := cmbConsignee.findObject(theConsignee);
		if tmpInt &gt; -1 then
			cmbConsignee.listIndex := tmpInt;
			str := cmbConsignee.text;
		endif;	
	endif;	
	
	if str &lt;&gt; null then
		pTbl.setValue(pRow, str);
	endif;
		
	return inheritMethod(pTbl, pAttrName, pRow, pObj);

epilog

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromObject" id="959b0e54-2a1c-4335-a511-b418e5db4184">
        <updating/>
        <source>setDefaultsFromObject(_object : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	5/6/01			AA		From booking ref, quantity defaults to 1
// ---------------------------------------------------------------------------
vars
	proxy, booking	: CM_BookingRef;
	intBRefItem 	: CMIF_BookingRefItem;
	cargoTypeId 	: Integer;
begin
	proxy 	:= _object.CM_BookingRef;
	booking := self.myCurrentObject.CM_BookingRef;

	self.loadTableFromBookingRef(proxy);

	if proxy = null then
		intBRefItem := self.myInterfaceBookingRef.createInterfaceItem(null, null);
		cargoTypeId := app.myPassport.getDefaultCargoType().id;
		
		intBRefItem.setDefaults(cargoTypeId);
		
		self.loadTableFromBRItem(intBRefItem);
		
	elseif proxy.isMultiItemBookingRef then
		self.loadBookRefItems(booking, true, true);
		
	else
		intBRefItem := self.getInterfaceItem(booking.allBookingRefItems.first);
		
		self.loadTableFromBRItem(intBRefItem);  // loads the extra table
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setDockBarMode" id="91697800-94b4-48af-b53a-04ed7834583b">
        <source>setDockBarMode();
/*
	Created on 07 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if self.mode = Mode_View then
		tblExtra.userInputEnabled := false;
		btnNextItem.visible := false;
		btnOkItem.visible := false;
		btnCancelItem.caption := '&amp;Close';
	else
		if self.itemEditMode = Mode_Update then
			btnNextItem.enabled := false;
		else
			btnNextItem.enabled := true;
		endif;
		tblExtra.userInputEnabled := true;
		btnNextItem.visible := true;
		btnOkItem.visible := true;
		btnCancelItem.caption := '&amp;Cancel';
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterBookingTypeCombo" id="fca83543-69a0-4ea4-b79d-d4ac4b519eea">
        <source>setFilterBookingTypeCombo();
//11 March 2010	cnwml2


vars

begin
	self.cmbFiltBookingTy.clear();							//+cnwml2 PAR22571
	
	self.cmbFiltBookingTy.addItem(" ");
	self.cmbFiltBookingTy.addItem("Export");
	self.cmbFiltBookingTy.addItem("Stock");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="c7df3a6a-4b29-4383-b223-49e508580363">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.filterBookingReference := null;
	self.filterOperatorCode 	:= null;
	self.filterVoyageCode 		:= null;
	self.filterStatus 			:= BOOKING_REF_ACTIVE;
	self.filterStevedoreCode    := null;               //02.10.2020 cnwma1 TFS #50112
	self.filterReconciled 		:= null;
	self.tblSearch.setValueByName(ETRow_FilterStatus, app.getString(Active));
	self.filterBookingType 		:= null;
	
end;</source>
    </JadeMethod>
