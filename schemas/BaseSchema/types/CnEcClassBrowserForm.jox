    <JadeMethod name="btnFind_click" id="51cf798b-ddca-4a35-a667-39afe610b7ad">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	findForm	: CnEcFindClassForm;

begin
	self.statusMsg("Loading find form...");
	create findForm;
	findForm.setMyForm(self);
	findForm.setMyListBox(lstClasses);
	findForm.showModal();
epilog
	self.statusMsg("");
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
