    </JadeMethod>
    <JadeMethod name="setIsRefConAgent" id="7c681bff-2082-46a5-aa3a-1ea8271db511">
        <updating/>
        <source>setIsRefConAgent( _isRefConReading: Boolean; _refConRawData: Binary ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2021	navndl1	Initial creation	TFS 51874

*/

vars

begin

	self.isRefConReading := _isRefConReading;
	self.refConRawData := _refConRawData;

epilog

end;</source>
        <Parameter name="_isRefConReading" type="Boolean"/>
        <Parameter name="_refConRawData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setTITransController" id="01d1fb79-a913-4896-84b7-c19a2503fc82">
        <source>setTITransController(_tiTransController: CMIF_TITransactionController input);
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	_tiTransController.userGenerated := false;
	_tiTransController.userId := self.userId;
	_tiTransController.noCharge := self.noCharge;
	_tiTransController.myTrackedItem := self.myTrackedItem;
	_tiTransController.type := TRANS_TYPE_TEMP_READING;
	_tiTransController.dateTime := self.dateTime;
end;</source>
        <Parameter name="_tiTransController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
</Class>
