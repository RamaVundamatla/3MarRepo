    <JadeMethod name="getIsAnyIdAnyAmt" id="6cc622be-ada3-4210-952c-f72ac8a6449d">
        <source>getIsAnyIdAnyAmt() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 October 2024	navpw1	Initial creation JIRA: MTN-33053

*/

vars
	requests	: CM_RequestSet;
	request		: CM_Request;
	
begin
	requests := self.allRequests;
	
	foreach request in requests do
		if not request.isDeliveryRequest then
			continue;
		endif;
		
		if not request.isAnyId or not request.isAnyAmount then
			continue;
		endif;
		
		return true;
		
	endforeach;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getItemised" id="b095a92b-63b7-4003-b091-bb5a108f5f2e">
        <source>getItemised():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	ti 				: CM_TrackedItem;
	req				: CM_Request;
	resDtl			: CM_ReserveDetail;
	objSet			: ObjectSet;
begin
	ti := self.getFirstTrackedItem();
	if ti &lt;&gt; null then
		return ti.itemised.getYesNo();
	endif;
	
	req := self.allRequests.first;
	if req &lt;&gt; null then
		resDtl := req.myReserveDetail;
	endif;
	if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
		return resDtl.CM_ReserveSelection.getMatchingCriteria(objSet,YACriteriaType_Itemized).Boolean.getYesNo();	
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return resDtl.myCargoGroup.itemised.getYesNo();
		endif;
	endif;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobActivity" id="13bf3607-46b4-4ec7-ae77-9abb0503406e">
        <source>getJobActivity(): String;
/*

Purpose:		This method returns a string of Job Actions timestamp
					eg.
					
					Job Start		21/03/2024 15:10
					Job Stop		21/03/2024 15:13
					Job Resume		21/03/2024 15:19
					Job Complete	21/03/2024 15:24
					
					It returns					
					21/03/2024 15:10 to 15:13
					21/03/2024 15:19 to 15:24	

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2024	navkc1 CR 62694 Task 62901: UI - WO Ops Start Stop Details
28/03/2024	navkc1 CR63258  Task 63259: Jade - Start Stop API call TRX
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
29 Nov 2024	navhl20 Bug MTN-33553: EUP - WO Ops screen job activity populated with extra line
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wo				: CM_WorkOrder;
	wodtl			: CM_WorkOrderDtl;
	woTxn			: CM_WOTransaction;
	retVal			: String;
	isStartResume	: Boolean;
	ts				: TimeStamp;
	jobID			: String;
begin
	
	wodtl := self.getMyWorkOrderDtl();
	
	if wodtl = null then
		return null;
	endif;
	
	wo := wodtl.myParent;
	
	if wo = null then
		return null;
	endif;
	
	ts := null; 											//26/03/2024	navkc1 CR62696 Task 62944
	
	jobID := self.getJobId();								//06.03.2025 navma1 #MTN-34179
	
	foreach woTxn in wo.allTransactions discreteLock do
		
		if not woTxn.isTypeOfJobActivity() then
			continue;
		endif;
		
		if  jobID &lt;&gt; woTxn.CM_WOJobDetail.jobId then				//09.10.2024 navhl20 #12389
			continue;
		endif;
		
		if woTxn.type = TRANS_TYPE_WOJOBSTART or woTxn.type = TRANS_TYPE_WOJOBRESUME then
			
			ts := woTxn.getJobStart();
			if isStartResume then
				retVal &amp;= " to ???, " &amp; ts.asStringJMT();
			else
				retVal &amp;= ts.asStringJMT();
			endif;
			
			isStartResume := true;
			continue;
		endif;
		
		if woTxn.type = TRANS_TYPE_WOJOBSTOP or woTxn.type = TRANS_TYPE_WOJOBCOMPLETE then
			ts := woTxn.getJobEnd();
			if isStartResume then
				if woTxn.type = TRANS_TYPE_WOJOBCOMPLETE then				//29.11.2024 navhl20 #33553
					retVal &amp;= " to " &amp; ts.asStringJMT();
				else
					retVal &amp;= " to " &amp; ts.asStringJMT() &amp; CrLf;
				endif;
			else
				retVal &amp;= "??? to " &amp; ts.asStringJMT() &amp; CrLf;
			endif;
			isStartResume := false;
			continue;
		endif;
	endforeach;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobCategory" id="34f5233a-9be0-49ee-a921-d9b2444db15f">
        <source>getJobCategory():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
17 Jul 2023	navma1	ChangeRequest 58342: EUP | Delivery Dispatch Screen - Rail Operation
*/

vars

begin
	if self.isRoadJob then
		return "Road";
	elseif self.isRail then				//17.07.2023 navma1 #58342
		return 'Rail';
	elseif self.isWorkOrderJob then
		return "Work Order";
	endif;
	return null;
epilog

end;</source>
