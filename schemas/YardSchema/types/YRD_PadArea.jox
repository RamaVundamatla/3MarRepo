    <JadeMethod name="doSelectDoorDirectionRule" id="3aa1521c-32f0-4c3d-ad74-a1948151d70d">
        <updating/>
        <source>doSelectDoorDirectionRule( _doorDirectionRule : CM_DoorDirectionRule ) updating;
// ---------------------------------------------------------------------------
// Created:		06/09/2007	By cnwvu1
// ---------------------------------------------------------------------------
vars
	thePoint : CMUI_GridPoint;

begin

	self.clearAllSelectedItems();

	self.paintColour := _doorDirectionRule.colour;
	foreach thePoint in self.allGridPoints do
		thePoint.YRD_PadPoint.doSelectDoorDirectionRule( _doorDirectionRule, self.myGridAreaFrame ); 
	endforeach;

end;
</source>
