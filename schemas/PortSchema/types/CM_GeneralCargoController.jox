        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWLEForTI" id="33b3fc2d-2682-4bbe-ab81-9472d60e655a">
        <source>getWLEForTI(_ti: CM_TrackedItem): CM_WorkListEntry;

 // ### TFS 53105 16JUN2022 NAVAB1
vars
	req : CM_Request;
	wle : CM_WorkListEntry;
begin

	foreach req in self.allHoldRequestsDischarge discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;
	foreach req in self.allHoldRequestsLoad discreteLock do
		wle := req.allWorkListEntries.first;
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	
	endforeach;

	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
