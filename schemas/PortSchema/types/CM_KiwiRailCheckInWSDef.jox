    <JadeMethod name="getDisplayStringForAttribute" id="d56ff2f0-5a7f-4aed-be02-3b832e4ef14f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2019	jlgsl4	NXL - KiwiRail EDI message
09 Apr 2020	jlgdap1	TFS 49003 MTN API Inline Agent
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
15 Nov 2021 navmd1	TFS 49052 Refactor ExtWSDef attributes post JADE2020 src comparison
*/

vars
	mapping : CM_ExtWebServiceEventMapping;
begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceKiwiRail;
	endif;
	
	if _attrName = ETRow_MessagePassword then
		if self.messagePassword &lt;&gt; null then
			return "******";
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPwForUse" id="3e165320-1887-48fa-8169-20c5fb7e2d40">
        <source>getPwForUse(_context: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin

	if _context = CM_KiwiRailCheckInWSDef::messagePassword.name then
		return app.pwDeCode( self, self.messagePassword );
	endif;
	
	return inheritMethod(_context);

epilog

end;</source>
        <Parameter name="_context" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e885ceed-1ffc-490a-9f5e-7e5978ecec99">
        <updating/>
        <source>setForUpdate(_extWebService: CM_KiwiRailCheckInWSDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_extWebService);
	self.railDestination := _extWebService.railDestination;
	self.replyOrganisation := _extWebService.replyOrganisation;
	self.requestOrganisation := _extWebService.requestOrganisation;
	self.messageUsername := _extWebService.messageUsername;
	self.messagePassword := _extWebService.messagePassword;
	self.senderCode := _extWebService.senderCode;
	self.freightPayerCode := _extWebService.freightPayerCode;
epilog

end;</source>
        <text>TFS 40360</text>
        <Parameter name="_extWebService" type="CM_KiwiRailCheckInWSDef"/>
