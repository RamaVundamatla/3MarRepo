    <JadeMethod name="xCheckStatusBarCorrect" id="bccf6773-ca5a-4ebc-a7ab-cdab4aac702e">
        <source>xCheckStatusBarCorrect(_mode, _modeView, _modeSubModeView : Integer;_method : String; _step : Integer);

/*

Purpose:		Check that the details of the status bar are correct

Date			Who		Reason
10/05/013		cnwmh5	Initial creation

*/

vars
	
	job 								: CM_VoyageJob;
	req 								: CM_RORORequest;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;

	idx 								: Integer;
	detailsToCheck						: String;
	detailsToCheckFromMethod			: String;
	lcStr : String;
begin

	idx := 1;
	foreach idx in 1 to self.locationArray.size do
		lcStr := self.locationArray[idx];
		if lcStr = "D4230682" then
			write "";
		endif;
		
		
		job := null;
		req := null;
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locationArray[idx]].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		detailsToCheck := self.statusArray[idx];
		detailsToCheckFromMethod := locnDefnVoyage.getCargoDetails(_mode, _modeView, _modeSubModeView);
		detailsToCheckFromMethod := locnDefnVoyage.code &amp; " " &amp; detailsToCheckFromMethod;
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if _modeView = ShpDisplayMode_ColCodeDisch then
				req := slotLC.myRORORequestDischarge ;
			elseif _modeView = ShpDisplayMode_ColCodeLoad then
				req := slotLC.myRORORequestLoad ;
			endif;
			if req &lt;&gt; null then
				job := req.myJob.CM_VoyageJob;
				break;
			endif;
		endforeach;
		if _modeSubModeView = ShpDisplayModeSub_ExportsHide and job &lt;&gt; null then
			detailsToCheckFromMethod := detailsToCheckFromMethod &amp; " " &amp; app.getErrorString(Job) &amp; ": " &amp; job.jobNum;
		endif;
		
		self.assertEqualMsg(detailsToCheckFromMethod, detailsToCheck, "Check Failed " &amp; _method &amp; " -       STEP " &amp; _step.String);
		
	endforeach;


epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeSubModeView" type="Integer"/>
        <Parameter name="_method" type="String"/>
        <Parameter name="_step" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xGCDCStatusBarStep1" id="34f967b2-2b03-483e-bb0e-f1a79a1dfaf4">
        <updating/>
        <source>xGCDCStatusBarStep1() updating;

/*

Purpose:		Create the cargo on the vaoyge and check that the status bar is correct

Date			Who		Reason
14/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UTGCDC1';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	theSlot								: CM_LocationsController;
	locnDefnVoyage						: CM_ROROLocnDefnVoyage;
	tempTI								: CM_TrackedItem;
	locnDefn							: CM_ROROLocnDefn;

	strs								: StringArray;
	tmpStrArray							: StringArray;
	
	tiArray								: CM_TIArray;
	
	idx									: Integer;
	index								: Integer;

begin

	app.writeLog("STEP 1", LogINFO);
	app.writeLog("Creating OOTL slots on ship.  Please wait...", LogINFO);
	
	create tiArray transient;
	
	// setup OOTL 20'
	//self.myDeck.myVoyageStructure.createQuickCargoOOTL(null, false, 85, -17, self.myDeck, 2); // 2 X 20
	self.createQuickCargoOOTL(self.myDeck.myVoyageStructure, locnDefn, false, 85, -17, self.myDeck, 2);
	self.assertNoTrxErrorsOrWarnings();
	locnDefnVoyage := self.myDeck.allROROLocnDefnByCode["D4339O"].CM_ROROLocnDefnVoyage;
	tiArray.clear();
	locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
	foreach tempTI in tiArray do
		self.deleteTrackedItem(tempTI, false);
	endforeach;	
	
	
	// setup OOTL 40'
	//self.myDeck.myVoyageStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myDeck.myVoyageStructure, locnDefn, true, 85, -12, self.myDeck, 1); // 1 X 40
	self.assertNoTrxErrorsOrWarnings();
	locnDefnVoyage := self.myDeck.allROROLocnDefnByCode["D4341O"].CM_ROROLocnDefnVoyage;
	tiArray.clear();
	locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
	foreach tempTI in tiArray do
		self.deleteTrackedItem(tempTI, false);
	endforeach;	
	
	
	app.writeLog("Creating containers on ship.  Please wait...", LogINFO);
	
	// setup some containers
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	
	port := app.myRoot.allPorts["NZLYT"];
		
	create strs transient;
	create tmpStrArray transient;
	strs.add("D4250282");
	strs.add("D4270282");
	strs.add("D4270284");
	strs.add("D4211182");
	strs.add("D4231182");
	strs.add("D4230782");
	strs.add("D4210782");
	strs.add("D4250382");
	strs.add("D4270382");
	strs.add("D4270682");
	strs.add("D4270684");
	strs.add("D4270686");
	strs.add("D4270688");
	strs.add("D4270690");
	strs.add("D4270692");
	strs.add("D4210682");
	strs.add("D4230682");
	strs.add("D4250982");
	strs.add("D4270982");
	strs.add("D4339O1");
	strs.add("D4339O2");
	
	
	foreach index in 1 to strs.size do
		tmpStrArray.clear();
		tmpStrArray.add(strs[index]);
		myVoyage.findLocation(tmpStrArray, false, theSlot, idx);
		self.cargoCountId := self.cargoCountId + 1;
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U20G", "MT", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
	endforeach;

	strs.clear;
	strs.add("D4211184");
	strs.add("D4210784");
	strs.add("D4250384");
	strs.add("D4210182");
	strs.add("D4210184");
	strs.add("D4210186");
	strs.add("D4210188");
	strs.add("D4210190");
	strs.add("D4210192");
	strs.add("D4250984");
	strs.add("D4250986");
	strs.add("D4341O1");
	
	foreach index in 1 to strs.size do
		tmpStrArray.clear();
		tmpStrArray.add(strs[index]);
		myVoyage.findLocation(tmpStrArray, false, theSlot, idx);
		self.cargoCountId := self.cargoCountId + 1;
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U40G", "MT", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
	endforeach;

	
	app.writeLog("Checking Status Bar (ACTUAL) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4339O");
	self.statusArray.add("D4339O D4339O | 2 x CONT NZLYT  U20G | UTGCDC10020, UTGCDC10021");
