    <JadeMethod name="cmbSoftware_click" id="cb6ce74b-8221-49f0-a235-e51987745b98">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSoftware_click(combobox: ComboBox input) updating;
// Created by cnwdvb1 on 15 August 2007
//
// Chnaged On	By			Reason
// ----------	--------	-----------------------------------------------
// 21/07/2020	jlgdap1			TFS 49764 MTN Retire Basic Authentication to Exchange Online
vars
	idx : Integer;
	defName : String;
begin

	self.tblConfig.text	:=	combobox.text;
//cnwrs1 dec 2008 Added as part of par 18653	
	idx := self.fldConfig.topSheet.index + 1;		// Add one as this sheets are zero based
	if idx &gt; self.allEntTableDefs.size then
		return;
	endif;
	defName := self.allEntTableDefs[idx];
	if defName = ETDef_EmailServerConfig then 
		self.showSheetEmailServer(self.fldConfig.topSheet.CMUI_Sheet);
		// TFS 49764 start
		if combobox.itemData[combobox.listIndex] = BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH then
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_2);
			self.tblConfig.disableRowByName(ETRow_EmailLicenseType);
		endif;
		// TFS 49764 end
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
