    <JadeMethod name="isReceipt" id="12ce8b45-4036-41a0-8368-ff0ca8ab1c97">
        <methodInvocation>mapping</methodInvocation>
        <source>isReceipt(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars

begin
	if self.job &lt;&gt; null and 
	   self.job.myWODtl &lt;&gt; null and 
	   self.job.myWODtl.isKindOf(CM_WodRelease) and
	   self.job.myWODtl.CM_WodRelease.transport = TI_TRANSMODE_SHIP then
		_value := false;
	else
		inheritMethod(set, _value);
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
