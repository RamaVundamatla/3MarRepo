<PrimType name="String">
    <JadeMethod name="containsAlphas" id="503b3c69-38d8-43f5-813e-73f06e80220b">
        <source>containsAlphas():Boolean;

vars
	i : Integer;
begin
	foreach i in 1 to length where self[i].isAlpha do
		return true;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLiterals" id="749f9f6d-4619-41bd-9157-b77d23cdf250">
        <source>findLiterals(literals : StringArray input);

// return literals in the receiver

vars
	pos1,pos2 : Integer;
begin
	while length&gt;0 do
		pos1 := pos2 + 1; scanUntil('"' &amp; "'",pos1);	// find next start
		if pos1 = 0 then return; endif;					// not found
		pos2 := pos1 + 1; scanUntil(self[pos1],pos2); 	// find next end
		if pos2 = 0 then return; endif;					// not found
		literals.add(self[pos1:pos2-pos1+1]);			// add new literal
	endwhile;		
end;</source>
        <Parameter name="literals" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="nextCsvToken" id="c66dfa89-ce23-40e5-9ea3-fa9005380f3e">
        <source>nextCsvToken(pos : Integer io):String;

vars
	token : String;
begin
	token := self.scanUntil(',' &amp; Cr &amp; Lf,pos); 
	pos := pos + 1;
	return token;
end;</source>
        <Parameter name="pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
