    <JadeMethod name="availableTransactions" id="7e8503cb-51c1-4c1e-9bdd-e53b5036e8b0">
        <source>availableTransactions(_classColl: ClassColl input);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReceiveRailInterTerminal);
	_classColl.add(CM_ReceiveRoadInterTerminal);
	_classColl.add(CM_ReleaseRail);
	_classColl.add(CM_ReleaseRailInterTerminal);
	_classColl.add(CM_ReleaseRoad);
	_classColl.add(CM_ReleaseRoadInterTerminal);
	_classColl.add(CM_ReceiveShip);
	_classColl.add(CM_ReleaseShip);
	_classColl.add(CM_Edit);
	
	_classColl.add(CM_InfoEDISent);		// cnwdad1 18/08/2010 - PAR #24065.
	_classColl.add(CM_Move);
	_classColl.add(CM_SetDown);
	_classColl.add(CM_Pickup);
	_classColl.add(CM_Pack);
	_classColl.add(CM_PackComplete);
	_classColl.add(CM_Unpack);
	_classColl.add(CM_UnpackComplete);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildFile" id="696eb052-8b75-4788-b6a9-2cfd0625f617">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _seqNumber : Integer; _unhSeqNumber : Integer io; _terminal : CM_Terminal) updating;
/*
 Changed On	Changed By	Reason
 ----------	----------	--------------------------------------------------
 6/8/09    	J Harliwich	MES1011 Added - Copy superclass method and modify
 
 27/08/2010		cnwdad1	CCMS 1903 (PAR #24065. Added file exception handler
						where CAMS file directory is being created.
 18/06/2012		cnwcs5	par 29812 - leaking transients.  Also remove code to set terminals/logo 
						as this is done in the qryTransactionsCam method		
 26/06/0212		cnwcs5	par 29601 - log excluded transactions						
 10 Jul 2012	cnwrs1	Par 29899 - write all adhoc data to single file when single transaction per file is selected
 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
 21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
 11 Dec 2012	cnwcs5	CCMS SFW 1294 / par 30855 - use CAMS timestamp instead of transaction timestamp
---------------------------------------------------------------------------
*/
vars
	transaction 	: CM_TITransaction;
	qfCam			: CMQF_CamTransactionQuery;
	allTransactions : CM_TITransactionByDateDict;	// we want in date time seq
	jrwTransient 	: CM_JRWCamTransaction;
	fileDirectory	: String;
	seqNo			: Integer;
	camTaskHistory 	: CM_CamTaskHistory;
	obj : 			 CM_Object;
	fileNameCreated : String;
begin
	seqNo			:= _seqNumber;
	// Are there any transactions. We create a query and run it to find the transactions to be extracted/reported on
	
	qfCam := _camProtocol.myQFCamTransactionTemplate.cloneSelfAs(CMQF_CamTransactionQuery, true).CMQF_CamTransactionQuery;
	
	qfCam.cloneReferences(_camProtocol.myQFCamTransactionTemplate, true);
	qfCam.setQueryFromCams(_terminal, _camProtocol, _camAgent);	// this sets daysToLookBack, works out timestamp ranges for search etc
	
	app.myQAFilter.qryTransactionsCam(qfCam, app.myPassport);	// this does the find and creates a CM_JRWCamTransaction with a collection of the objects
	
	jrwTransient := app.myQAFilter.allJRWTransients.first.CM_JRWCamTransaction;
		
	if qfCam.numFound &lt;= 0 then	// nothing found 
		app.writeLog( method.name &amp; Space &amp; _camProtocol.description &amp; ' no transactions found', LogINFO );
		return;
	endif;
	
	// Make sure the default protocl directory exists cause this is where the report output will go
	fileDirectory :=_camAgent.fileDirectory   &amp; '\' &amp; _camProtocol.getProtocolSubDirectoryName; //cnwrs1 par19312 June 2009  //_camProtocol.terminal.getConfig_FileDirectory(CamsFileDirectory).String.trimRight
	
	_camAgent.createOutputFile(_camProtocol,null,fileNameCreated);	
	// if here then we have found some transactions
	if _camProtocol.isSingleTransPerFile  then 	
		// create one file for EACH transactio
		
		create allTransactions transient;
		
		jrwTransient.allTransactions.copy(allTransactions);	
		
		foreach transaction in allTransactions do	// these are now in date seq
			jrwTransient.allTransactions.clear(); 	// we add them back one by one to report on
			jrwTransient.allTransactions.add(transaction);
						
			self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);	//10 Jul 2012	cnwrs1	Par 29899
			app.sendHeartbeatIfRequired();		// TFS 48201 jlgmd1 10/01/2020
			
			if not self.buildJRWFile(_camProtocol, _camAgent, _unhSeqNumber, seqNo, _terminal, fileDirectory, jrwTransient) then
				//epr tfs 2192 20/6/16 do not break do not pass go this will happen if the report has no output which is valid
				//should probably delete that history we just created and remove the allProcessedSeqNum	
				if  not _camAgent.isAdhoc then
					camTaskHistory := _camProtocol.taskHistoryByProtocolSeq[_camProtocol, seqNo];				
					if camTaskHistory &lt;&gt; null then
						obj:=camTaskHistory;
						app.myTrxDA.trxDeleteCMObject(obj,app.myPassport);
						if _camAgent.allProcessSeqNumbers.includes(seqNo) then
							_camAgent.allProcessSeqNumbers.remove(seqNo);
						endif;
					endif;
				endif;
			else			
				if _camAgent.isAdhoc then
					_camAgent.incrementDailySeqNumber();
					seqNo := 0;
				else
					seqNo	:= seqNo + 1;	//08 Jan 2020	NDL	TFS 48196 - moved up
					_camAgent.setProcessSeqNumber(seqNo);
				//	seqNo	:= seqNo + 1;
				endif;
			endif;
		endforeach;
	else
		// we just create one file with all the transactions
		self.buildJRWFile(_camProtocol, _camAgent, _unhSeqNumber, _seqNumber, _terminal, fileDirectory, jrwTransient);
	endif;
epilog
	delete allTransactions;
	delete qfCam;			// par 29812
	delete jrwTransient;	// par 29812 - just so that unit tests don't fail
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
