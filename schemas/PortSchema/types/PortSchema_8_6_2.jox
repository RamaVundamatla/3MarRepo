    <JadeMethod name="deleteMvmtPilotDetlsOrphans" id="30d2942c-61a9-4d85-90e2-be8a70105643">
        <updating/>
        <source>deleteMvmtPilotDetlsOrphans(_controller: CnEcReleaseController) updating;
/*

Purpose:			This will only do anything for Pelindo, other customers have the fix
					for the orphans being produced in 040...
Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2019	jlgsl4	TFS 45059 - PEL1 - tidy up orphaned movement pilot details objects

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
	pilotLaunchDesc : String;
	isOK : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Start Movement Pilot Details orphan cleanup *****", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Start Movement Pilot Details orphan cleanup");
	endif;

	beginTransaction;
	foreach movementPilotDetails in HMS_MovementPilotDetails.instances where movementPilotDetails.myMovement = null do
		if movementPilotDetails.myPilotLaunch &lt;&gt; null then // pilot launch is optional, but orphans will have pilot
			pilotLaunchDesc := movementPilotDetails.myPilotLaunch.description;
		else
			pilotLaunchDesc := "n.a.";
		endif;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " *** Deleting orphan with pilot " &amp; movementPilotDetails.myPilot.description &amp;
			", launch " &amp; pilotLaunchDesc, LogINFO);
		delete movementPilotDetails;
	endforeach;
	commitTransaction;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Finish Movement Pilot Details orphan cleanup *****", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Finish Movement Pilot Details orphan cleanup");
	endif;
	self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="encryptPassPhrases" id="b65b85cf-aa23-407a-b7b1-9286744eefc6">
        <source>encryptPassPhrases(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51165

*/

vars

	size : Integer;
	objArray : CM_ObjectArray;
	boom : CM_Boom;
	obj : Object;
	cmObj : CM_Object;
	rawPw : String;
	encryptPw : String;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Encrypt passPhrases", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Encrypt passPhrases") ;	
	endif;
	
	//Gather up the objects that we care about.
	create objArray transient;
	
	foreach obj in CM_SFTPEntity.instances do
		objArray.addExclusive(obj);
	endforeach;
	
	//ready to go
	beginTransaction;
	
	//process the collection
	foreach obj in objArray do
		cmObj := obj.CM_Object;
		rawPw := null;
		encryptPw := null;
		if cmObj.isKindOf( CM_FTPEntity ) then
			rawPw := cmObj.CM_SFTPEntity.passPhrase.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.setProxyPw( encryptPw, CM_SFTPEntity::passPhrase.name );
			
			rawPw := null;
			encryptPw := null;
			rawPw := cmObj.CM_SFTPEntity.password.trimBlanks;
			
		endif;
		
		if rawPw &lt;&gt; null then
			encryptPw := app.pwEnCode( rawPw );
		endif;
		cmObj.setProxyPw( encryptPw, null );
		size := size + 1;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; size.String &amp; " passPhrases encrypted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" " &amp; size.String &amp; " passPhrases encrypted") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete objArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="encryptPasswords" id="cffa9d0c-5731-4acb-9d3a-1fa6ebd9809e">
        <source>encryptPasswords(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	size : Integer;
	objArray : CM_ObjectArray;
	boom : CM_Boom;
	obj : Object;
	cmObj : CM_Object;
	rawPw : String;
	encryptPw : String;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Encrypt passwords", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Encrypt passwords") ;	
	endif;
	
	//Gather up the objects that we care about.
	create objArray transient;
	
	foreach obj in CM_Boom.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_DataDumpExtractDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_FTPEntity.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_SFTPEntity.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_EventStreamDefinition.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_ExternalWebServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;	
	foreach obj in CM_AllotracServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_CargoChainServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_InaportnetWebService.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_KiwiRailCheckInWSDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_NavisMACS3Service.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_OpsViewServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_SAPWebService.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_Terminal.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_Root.instances do
		objArray.addExclusive(obj);
	endforeach;
	
	//ready to go
	beginTransaction;
	
	//process the collection
	foreach obj in objArray do
		cmObj := obj.CM_Object;
		rawPw := null;
		encryptPw := null;
		//CM_Boom
		if cmObj.isKindOf( CM_Boom ) then
			rawPw := cmObj.CM_Boom.password.trimBlanks;
		
		//CM_DataDumpExtractDef
		elseif cmObj.isKindOf( CM_DataDumpExtractDef ) then
			rawPw := cmObj.CM_DataDumpExtractDef.edbPassword.trimBlanks;
		
		//CM_FTPEntity, CM_SFTPEntity
		elseif cmObj.isKindOf( CM_FTPEntity ) then
			rawPw := cmObj.CM_FTPEntity.password.trimBlanks;
			
		//CM_EventStreamDefinition
		elseif cmObj.isKindOf( CM_EventStreamDefinition ) then
			rawPw := cmObj.CM_EventStreamDefinition.authToken.trimBlanks;
			
		//CM_KiwiRailCheckInWSDef
		elseif cmObj.isKindOf( CM_KiwiRailCheckInWSDef ) then
			rawPw := cmObj.CM_KiwiRailCheckInWSDef.messagePassword.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.setProxyPw( encryptPw, CM_KiwiRailCheckInWSDef::messagePassword.name );
			
			rawPw := null;
			encryptPw := null;
			rawPw := cmObj.CM_KiwiRailCheckInWSDef.password.trimBlanks;
		
		//CM_ExternalWebServiceDef, CM_AllotracServiceDef, CM_CargoChainServiceDef, CM_InaportnetWebService
		//CM_NavisMACS3Service, CM_OpsViewServiceDef, CM_SAPWebService
		elseif cmObj.isKindOf( CM_ExternalWebServiceDef ) then
			rawPw := cmObj.CM_ExternalWebServiceDef.password.trimBlanks;
		
		//CM_Terminal
		elseif cmObj.isKindOf( CM_Terminal ) then
			rawPw := cmObj.CM_Terminal.getConfig( AutoPop3Password ).String.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.CM_Terminal.setConfig( AutoPop3Password, encryptPw );
			size := size + 1;
			continue;
			
		//CM_Root
		elseif cmObj.isKindOf( CM_Root ) then
			rawPw := cmObj.CM_Root.getConfig( AutoOutwardPassword ).String.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.CM_Root.setConfig( AutoOutwardPassword, encryptPw, false );
			size := size + 1;
			continue;
		
		endif;
		
		if rawPw &lt;&gt; null then
			encryptPw := app.pwEnCode( rawPw );
		endif;
		cmObj.setProxyPw( encryptPw, null );
		size := size + 1;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; size.String &amp; " passwords encrypted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" " &amp; size.String &amp; " passwords encrypted") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete objArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupReserveTIs" id="5c2ee4bf-d38a-4bd7-bb38-a0eadd3b4a89">
        <source>fixupReserveTIs(_controller: CnEcReleaseController);
/*

Purpose:		remove reserve TIs where getTIs returns null i.e no cargo assigned or been released	

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlger1	Initial creation 43404

*/

vars

	terminal : CM_Terminal;
	iter : Iterator;
	br 	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	invalidReserveTIs  : ObjectSet;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fixing invalid Release Request reserved cargo ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing invalid Release Request reserved cargo") ;	
	endif;
	
	create invalidReserveTIs transient;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		delete iter;
		iter := terminal.allBulkReleaseByTypeByStByCd.createIterator;
		terminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE,null,null,iter);
		
		while iter.next(br) do
			foreach reserveDetail in br.allReserveDetails do
				if not reserveDetail.isKindOf(CM_ReserveTI) then
					continue;
				endif;
				if reserveDetail.allTrackedItems.size = 0 and 
					reserveDetail.allTrackedItemsReleased.size = 0 then
				//	write terminal.code &amp; " " &amp; br.code &amp; " " &amp; reserveDetail.String;
					invalidReserveTIs.add(reserveDetail);
				endif;
			endforeach;
		endwhile;
	endforeach;
	
	beginTransaction;
	invalidReserveTIs.purge;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing invalid Release Request reserved cargo",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("  Finished fixing invalid Release Request reserved cargo complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete iter;
	delete invalidReserveTIs;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateTerminalMarkExtDict" id="b3335dd7-0084-4853-bd61-dc418b223301">
        <source>populateTerminalMarkExtDict(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/03/2021	navdap1		Initial creation TFS 50889 Yard Allocation Performance Improvement
//
vars
	term : CM_Terminal;
	ya : CM_YardAllocation;
	crit : CM_YACriteria;
	data : CM_YADataString;
	mark, markData : String;
	marks : StringArray512;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populating CM_Terminal::allYAsByMark external key dict", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_Terminal::allYAsByMark external key dict") ;	
	endif;
	
	create marks transient;
	beginTransaction;
	foreach term in CM_Terminal.instances do
		term.allYAsByMark.clear;
		foreach ya in term.allYardAllocatonsByCode do
			foreach crit in ya.allCriteria do
				if crit.code = ya.CRITERIA_MARK then
					marks.clear;
					data := crit.myYAData.CM_YADataString;
					markData := data.value;
					markData.getTokensForDelimiter(Comma, marks);
					foreach mark in marks do
						mark := mark.trimBlanks[1:100];
						if term.allYAsByMark[mark, ya.code] = null then
							term.allYAsByMark.putAtKey(mark, ya.code, ya);
						endif;
					endforeach;
				endif;
			endforeach;
		endforeach;
	endforeach;	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed populating CM_Terminal::allYAsByMark external key dict", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed populating CM_Terminal::allYAsByMark external key dict") ;
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete marks;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="renameDebtorTypeStevedore" id="67484a98-3307-40d1-a867-4e73a7ecf1ea">
        <source>renameDebtorTypeStevedore(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	debtorType : CM_DebtorType;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Renaming Stevedore Debtor Type to Stevedore for Voyage ", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Renaming Stevedore Debtor Type to Stevedore for Voyage") ;	
	endif;
	if app.myRoot.allDebtorTypes[CM_DebtorType.DT_STEVEDORE_VOYAGE] = null then
		return;
	endif;
	
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_STEVEDORE_VOYAGE];
	
	if debtorType.description &lt;&gt;  CM_DebtorType.DT_STEVEDORE_VOYAGE_DESC then
		beginTransaction;
			debtorType.setDescription(CM_DebtorType.DT_STEVEDORE_VOYAGE_DESC);
		commitTransaction;
	endif;
	app.writeLog(method.qualifiedName &amp; "Renaming Stevedore Debtor Type to Stevedore for Voyage complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Renaming Stevedore Debtor Type to Stevedore for Voyage complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="resetMenuForJMTSupportUser" id="1fe03011-a2f8-4cff-a482-c2e859854af8">
        <source>resetMenuForJMTSupportUser();
/*

Purpose:	To resolve the timing issue between the Standard Release process and 
			Post Release process relating to JMT Support User menu

Parameters:			

Return Value:		

Date		Who		TFS		Reason
25 Oct 2019	jlgdi1	46820	Reset / Regenerate menus for JMT Support user
01 Nov 2019 jlgmd1	46820	Make sure we reset the System Items menu too
*/

vars
	jmtSupportUser : CM_User;
	userTerminal : CM_UserTerminal;
	
begin
	jmtSupportUser := app.myRoot.allUsers[JMTSUPPORT_Str];
	
	if jmtSupportUser &lt;&gt; null then 	
		beginTransaction;
		foreach userTerminal in jmtSupportUser.allUserTerminals do
			userTerminal.resetNavMenuFromJMTDefault(true);
		endforeach;
		jmtSupportUser.resetSysEntMenuFromJMTDefault(true);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetZombieLocations" id="fdd27132-69c7-445e-97a0-9539fcd89910">
        <source>resetZombieLocations(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2021	navndl1	Initial creation	TFS 50796

*/

vars

	lc : CM_LocationsController;
	objArray : ObjectArray;
	lcIter : Iterator;
	lcObj : Object;
	tiIter : Iterator;
	ti : CM_TrackedItem;
	zombies : CM_TISet;
	size : Integer;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Reset Zombie Locations", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset Zombie Locations") ;	
	endif;
	
	//Start
	
	create zombies transient;
	create objArray transient;
	
	CM_YardController.allInstances( objArray, 0, true );
	
	lcIter := objArray.createIterator;
	while lcIter.next( lcObj ) do
		lc := lcObj.CM_LocationsController;
		tiIter := lc.allTrackedItems.createIterator;
		while tiIter.next( ti ) do
			if ti.hasBeenMerged then
				zombies.add( ti );
			endif;
		endwhile;
		delete tiIter;
	endwhile;
	
	size := zombies.size;

	beginTransaction;
	foreach ti in zombies do	
		ti.clearMyActualLocation();	
	endforeach;
	commitTransaction;
	
	//End
	
	app.writeLog(method.qualifiedName &amp; " Reset " &amp; size.String &amp; " Zombie Locations, Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset " &amp; size.String &amp; " Zombie Locations, Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete lcIter;
	delete tiIter;
	delete objArray;
	delete zombies;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setAuditConfigsEnabled" id="1b35b810-e47a-4343-9805-8e8aca5093a8">
        <source>setAuditConfigsEnabled(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	auditConfig : CM_AuditConfig;
	root : CM_Root;
	iterAuditConfig : Iterator;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initial enabling of original Audit Configs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of original Audit Configs") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
	
		if auditConfig.className = CM_DocketError.name
		or auditConfig.className = CM_EventRequest.name
		or auditConfig.className = CM_FileFormatEDI.name
		or auditConfig.className = "CM_TIMasterGroup"
			//these ones aren't used or are invalid classes.
		then
			continue;
		endif;
		
		//we want to turn the new 'isEnable' flag for existing audit configs, but not for the
		//ones just added that should be left for the users to decide to turn on or not.
		if not auditConfig.isEnabled and not auditConfig.canBeUserDisabled then
			//This should always be set
			app.myTrxUA.trxAuditConfigSetIsEnable( true, auditConfig, app.myPassport );
			continue;
		endif;
		
		if not auditConfig.isEnabled // So only those that are not currently set
		and auditConfig.allAuditObjectsForClass.isEmpty	// (the collection of changes to this audit config) - No audits here means it has never been set
		and not auditConfig.allAuditObjects.isEmpty// (the collection of objects of the related class that this config controls) - Audits here means is or has been in use so must be pre existing
		then
			// so its not set and never been set and was active before this release (so not just created) then enable it
			app.myTrxUA.trxAuditConfigSetIsEnable( true, auditConfig, app.myPassport );
		endif;
		
	endwhile;
	
	
	app.writeLog(method.qualifiedName &amp; " Initial enabling of original Audit Configs, Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of original Audit Configs, Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete iterAuditConfig;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setBGPMonthlyRecurUnitAndValue" id="59258014-3f94-4e7f-8baa-b3e8cd7c6298">
        <source>setBGPMonthlyRecurUnitAndValue(_controller : CnEcReleaseController);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 15 April 2019
TFS#		: 43863
Function	: Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	autoSchedule : CM_AutoSchedule;
	root		 : CM_Root;
begin	
	//Have we run it before
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;	
	
	app.writeLog( method.qualifiedName &amp; " Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals") ;	
	endif;
	// do not rely on the app.myRoot use the class itself
	root := CM_Root.firstInstance;
	
	beginTransaction;
	foreach autoSchedule in root.allAutoSchedulesByStartTs do
		if autoSchedule.selectionState = State_Date then
			app.writeLog("Setting Recurring Unit and Value for: " &amp; autoSchedule.getOidAsString, LogINFO);
			autoSchedule.setPropertyValue(CM_AutoSchedule::recurValue.name, 1);
			autoSchedule.setPropertyValue(CM_AutoSchedule::recurUnit.name,autoSchedule.RecurUnit_Monthly);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; " Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals - Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals - Complete") ;	
	endif;	
	// Log that it already ran.
	self.addScriptRun(method.name);
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setCashPaymentToMerged" id="20589b25-273d-4fef-be3d-91e8850042f5">
        <source>setCashPaymentToMerged(_controller: CnEcReleaseController);
/*

Purpose: An upgrade script as part of the Cash Review change request TFS# 45301.
         Set the status of CM_CashPayment to Status_Merged if the following conditions are met (as per Tech Specs):
		 1. CM_CashPayment status is "Void" (CM_CashPayment.status = 1)
		 2. CM_trackedItem.hasBeenMerged() = true (only means that the cash payment is linked to a 'zombie')

Parameters:			

Return Value:		

Date		Who		TFS		Reason
============================================================================
15 Jul 2019	jlgdi1	45301	Initial creation
============================================================================
*/

vars
	cashPayment : CM_CashPayment;
	message : String;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	foreach cashPayment in CM_CashPayment.instances 
		where (cashPayment.status = CM_CashPayment.Status_Void) 
			  and (cashPayment.myTrackedItem &lt;&gt; null) 
		do
			if cashPayment.myTrackedItem.hasBeenMerged() then 
				message := " Start setting the Cash Payment status to 'Status_Merged' of " &amp; cashPayment.myTrackedItem.id &amp; " with cash value " &amp; cashPayment.cashValue.asCurrencyJMT;
				self.createLogEntry(_controller, method.qualifiedName(), message);
		
				beginTransaction;
				cashPayment.setStatus(CM_CashPayment.Status_Merged);
				commitTransaction;
				
				message := " Cash Payment status has been set to 'Status_Merged'";
				self.createLogEntry(_controller, method.qualifiedName(), message);
			endif;
	endforeach;
	
	self.addScriptRun(method.name);
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setEventStreamEvtTypeObjects" id="1b515893-61fd-4883-b6a1-880fbaa560d8">
        <source>setEventStreamEvtTypeObjects(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2020	jlgndl1	Initial creation	TFS 49590

*/

vars

	objectSet : ObjectSet;
	obj : Object;
	eventStreamEventType : CM_EventStreamEventType;
	allEventTypesByName : CM_EventTypeByNameDict;
	keyObject : CM_Object;
	keyType : Integer;
	pos : Integer;
	keyObjStr : String;
	keyTypeStr : String;
	auditConfig	: CM_AuditConfig;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Add all Event Stream Event Types to Root and populate keys", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Add all Event Stream Event Types to Root and populate keys") ;	
	endif;
	
	create objectSet transient;
	CM_EventStreamEventType.instances.copy( objectSet );
	
	create allEventTypesByName transient;
	app.myRoot.allEventTypesByType.copy( allEventTypesByName );
	
	beginTransaction;
	foreach obj in objectSet do
		eventStreamEventType := obj.CM_EventStreamEventType;

		keyObject := null;
		keyType := 0;
		if eventStreamEventType.category = CM_EventStreamEventType.EVENT_TYPE_EVENT then
			keyObject := allEventTypesByName.getAtKey( eventStreamEventType.name );
			if keyObject &lt;&gt; null then
				keyType := keyObject.CM_EventType.type;
			endif;
		elseif eventStreamEventType.category = CM_EventStreamEventType.EVENT_TYPE_TRANSACTION then
			keyObject := app.myRoot.allTransactionTypesByDesc.getAtKey( eventStreamEventType.name );
			if keyObject &lt;&gt; null then
				if keyObject.CM_TransactionType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then
					continue;
				endif;
			endif;
		elseif eventStreamEventType.category = CM_EventStreamEventType.EVENT_TYPE_AUDIT then
			if eventStreamEventType.name.trimBlanks.length &lt;= 8 then //Combination of the full description plus a space and one of three words, 'Created', 'Update' or 'Deleted'
				continue;
			endif;
			pos := eventStreamEventType.name.trimBlanks.length - 6; // position the last word should start in.
			keyObjStr := eventStreamEventType.name.trimBlanks[1:pos-2]; // the description for the audit config
			keyTypeStr := eventStreamEventType.name.trimBlanks[pos:end]; // the action, i.e. Create, etc.
			foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
				if auditConfig.getDescription = keyObjStr then
					keyObject := auditConfig;
					break;
				endif;
			endforeach;
			if keyObject &lt;&gt; null then
				if keyTypeStr = 'Created' then
					keyType := AuditCreated;
				elseif keyTypeStr = 'Updated' then
					keyType := AuditUpdated;
				elseif keyTypeStr = 'Deleted' then
					keyType := AuditDeleted;
				endif;
			endif;
		endif;
		if keyObject &lt;&gt; null then
			eventStreamEventType.setRootKeys( keyObject, keyType );
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "  Add all Event Stream Event Types to Root and populate keys Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Add all Event Stream Event Types to Root and populate keys Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	abortTransaction;
	delete objectSet;
	delete allEventTypesByName;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setNSPReeferLayout" id="0647ce9f-af3e-4d4c-a2bd-e33176b5212b">
        <source>setNSPReeferLayout(_controller: CnEcReleaseController);
/*
Purpose: The reefer app layout uses EntTableDef global constants; these global constants get overridden at upgrade, 
			so save the text for the default layout to state data. 
			The users can change the layout at that save this same state data is updated.			

Date		Who		Reason
13JUL2021	NAVAB1	TFS 51361
*/

vars

	layoutText : String;
	portSchema 		: Schema;
	constantCategory : ConstantCategory;
	constDict 		: ConstantNDict;
	globalConst 	: GlobalConstant;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting Navis Smart Platform Reefer App Layout to MTN default", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Setting Navis Smart Platform Reefer App Layout to MTN default") ;	
	endif;

	layoutText := app.myRoot.getConfig(ReeferAPILayout).String; // Saved to state data so can access post upgrade to put back into ETRow text

	if layoutText = null then
	
		portSchema := rootSchema.getSchema("PortSchema");
		constantCategory := portSchema.getConstantCategory("EntTableDefs");
		create constDict transient;
		constantCategory.cnEcGetConstants.copy(constDict);

		// SET the text on the constant
		globalConst := constDict["ETDef_ReeferAPIDefault"].GlobalConstant;  
		
		layoutText := globalConst.text;
	

	
		app.myTrxUA.trxUpdateReeferAPILayout(layoutText, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.writeLog(method.qualifiedName &amp; " Reset Native Reefer API Layout to EntDef Constant Completed", LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(method.qualifiedName &amp; " Reset Native Reefer API Layout to EntDef Constant Completed") ;	
			endif;
		else
			app.writeLog(method.qualifiedName &amp; " Reset Native Reefer API Layout to EntDef Constant FAILED", LogERROR);
			app.writeLog(method.qualifiedName &amp; " Reset Native Reefer API Layout ISSUES: " &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr(), LogERROR);
			if _controller &lt;&gt; null then
				_controller.logEntry(method.qualifiedName &amp; " Reset Native Reefer API Layout to EntDef Constant FAILED") ;	
				_controller.logEntry(method.qualifiedName &amp; " Reset Native Reefer API Layout ISSUES: " &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr()) ;	
			endif;
		endif;
	endif;

	app.writeLog(method.qualifiedName &amp; "  Setting Navis Smart Platform Reefer App Layout to MTN default Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Setting Navis Smart Platform Reefer App Layout to MTN default Completed") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setNewTransResyncPerm" id="b8165084-3bd8-48d4-b9c0-66afd104aecc">
        <source>setNewTransResyncPerm(_controller: CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	user : CM_User;
	userTerminal : CM_UserTerminal;
	securityRole : CM_SecurityRole;
	pxySecurityRole : CM_SecurityRole;
	permissionAgent	: CM_PermissionAgent;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting new Transaction Resync Permissions from existing Resync Transaction Invoicing permission", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting new Transaction Resync Permissions from existing Resync Transaction Invoicing permission") ;	
	endif;
	
	foreach user in CM_User.instances do
		foreach userTerminal in user.allUserTerminals do
			// does this user have the Resync Transaction Invoicing permission?
			securityRole := userTerminal.mySecurityRole;
			if user.canDo(userTerminal.myTerminal, PmAdmResyncTrans) then
				if securityRole.permissions.size &lt; PmTiTransResyncMaint or not securityRole.permissions[PmTiTransResyncMaint] then
					// then give them the new Cargo Transaction Resync Maint and View permissions
					create permissionAgent transient;
					beginLoad;
					pxySecurityRole := securityRole.pxyCreateUpdateProxy();
					endLoad;
					pxySecurityRole.permissions[PmTiTransResyncView] := true;
					pxySecurityRole.permissions[PmTiTransResyncMaint] := true;
					app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
					delete pxySecurityRole;
					delete permissionAgent;
				endif;
			endif;
		endforeach;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Setting new Transaction Resync Permissions from existing Resync Transaction Invoicing permission Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting new Transaction Resync Permissions from existing Resync Transaction Invoicing permission Completed") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete pxySecurityRole;
	delete permissionAgent;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setNoConsolidateRoadExit" id="5a05b230-4f97-40c2-9dfe-150b4d02576d">
        <source>setNoConsolidateRoadExit( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2019	jlgndl1	Initial creation	TFS 45300

*/

vars

	terminal : CM_Terminal;
	defProc : Boolean;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; "Setting 'Do NOT Auto Consolidate at Road Exit' option ", LogINFO);

	
	foreach terminal in CM_Terminal.instances do
		if not terminal.isCashOnlyEnabled() then
			continue;
		endif;
		defProc := terminal.isUsingDefaultProcessJMT();
		if not defProc then
			beginTransaction;
			terminal.setConfig( NoConsolidateRoadExit, true );
			commitTransaction;
		endif;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; "Completed Setting 'Do NOT Auto Consolidate at Road Exit' optio ", LogINFO);
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setOrderPickingPermissions" id="da7dd17d-dcc7-462f-87c5-900dcd6477ed">
        <source>setOrderPickingPermissions(_controller : CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2021	jlier1	Initial creation TFS 51626

*/

vars
	root : CM_Root;
	termSecRole : CM_SecurityRole;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting Order Picking permissions for Systems with Cargo Groups and users who have Release Staging", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Setting Order Picking permissions for Systems with Cargo Groups and users who have Release Staging") ;	
	endif;
	
	
	
	if  app.isCargoGroupEnabled then
		root := CM_Root.firstInstance();
		termSecRole := root.mySecurityRoleTerminal;
		beginTransaction;
		termSecRole.zfixupMaintViewPermission(PmHHOrderPicking,PmHHReleaseStaging , false);
		commitTransaction;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Setting Order Picking permissions Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Setting Order Picking permissions Completed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setQueryPerformanceRatings" id="36364eaa-7019-4e1a-aa95-73a702f047cb">
        <source>setQueryPerformanceRatings( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	root : CM_Root;
	menu : CM_MenuEntity;
	muq : CM_MenuUserQuery;
	queryMode : Integer;
	clh : CM_QueryCriteriaLineHolder;
	cl : CM_SelectorCriteriaLine;
	obj : Object;
	qp : CM_QueryProperty;
	realQueryProperty : CM_QueryProperty;
	qDef : CM_QueryDefinition;
	count : Integer;
	
	objArray : ObjectArray;
	iter : Iterator;
	dynaDict : DynaDictionary;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Setting Query Property Performance Ratings ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting Query Property Performance Ratings") ;	
	endif;
	
	root := app.myRoot;
	
	if root.myQueryMenuRoot &lt;&gt; null then
		foreach menu in root.myQueryMenuRoot.allMenuUserItemsWithAMenuItem do
			if not menu.isKindOf (CM_MenuUserQuery) then
				continue;
			endif;
			muq := menu.CM_MenuUserQuery;

			queryMode := muq.queryMode;
			
			qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.TrackedItem_Query_Type, queryMode];		
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.BOL_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Snapshot_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Transaction_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Invoicing_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Cash_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Audit_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.BookRef_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Release_Query_Type, queryMode];
			endif;
				
			if qDef = null then
				continue;
			endif;
			
			foreach clh in muq.allCriteriaLineHolders discreteLock do
				foreach cl in clh.allCriteriaLines do
					obj := cl.myQueryProperty;
					if obj = null then
						continue;
					endif;
					if not obj.isKindOf( CM_QueryProperty ) then
						continue;
					endif;
					qp := cl.myQueryProperty;
					if qp.performanceRating &lt;&gt; 0 then
						continue;
					endif;
					realQueryProperty := qDef.allQueryProperties.getAtKey(qp.propertyName);
					if realQueryProperty &lt;&gt; null
					and realQueryProperty.propertyClassName = qp.propertyClassName
					and realQueryProperty.propertyName = qp.propertyName
					then
						beginTransaction;
						qp.setPerformanceRating( realQueryProperty.performanceRating );
						commitTransaction;
						count := count + 1;
					endif;
				endforeach;
			endforeach;
			
		endforeach;
	endif;
	
	// now go for everything else
	create dynaDict transient;
	dynaDict.setMembership( CM_QueryProperty );
	dynaDict.addMemberKey(CM_QueryProperty::propertyClassName.name, false, false);
	dynaDict.addMemberKey(CM_QueryProperty::propertyName.name, false, false);
	dynaDict.endKeys(true);
	
	create objArray transient;
	CM_QueryProperty.allInstances( objArray, 0, true );
	iter := objArray.createIterator;
	while iter.next( qp ) do
		if qp.performanceRating &lt;&gt; 0 then
			continue;
		endif;
		dynaDict.add( qp );
	endwhile;
	
	foreach obj in dynaDict do
		qDef := null;
		qp := obj.CM_QueryProperty;
		if qp.propertyClassName = CM_Container.name then
				qDef := CM_QDefContainer.firstInstance;
				
		elseif qp.propertyClassName = CM_TrackedItem.name then
			qDef := CM_QDefTrackedItem.firstInstance;
			
		elseif qp.propertyClassName = CM_BreakBulkGeneric.name then
			qDef := CM_QDefBreakBulkGeneric.firstInstance;
			
		elseif qp.propertyClassName = CM_Log.name then
			qDef := CM_QDefLog.firstInstance;
			
		elseif qp.propertyClassName = CM_Car.name then
			qDef := CM_QDefCar.firstInstance;
			
		elseif qp.propertyClassName = CM_TILC.name then
			qDef := CM_QDefTILC.firstInstance;
			
		elseif qp.propertyClassName = CM_TITransaction.name then
			qDef := CM_QDefCargoTransaction.firstInstance;
			
		elseif qp.propertyClassName = CM_EventTransaction.name then
			qDef := CM_QDefEventTransaction.firstInstance;
			
		elseif qp.propertyClassName = HMS_VTMISTransaction.name then
			qDef := CM_QDefHMSTransaction.firstInstance;
			
		elseif qp.propertyClassName = CM_DynamicObject_Snapshot.name then
			qDef := CM_QDef_Snapshot.firstInstance;
			
		else
			write qp.propertyClassName &amp; "::" &amp; qp.propertyName;
			continue;
		endif;
		
		realQueryProperty := qDef.allQueryProperties.getAtKey(qp.propertyName);
		
		//special case
		if realQueryProperty = null
		and ( qp.propertyName = CM_TrackedItem::weightCertifiedName.name or qp.propertyName = CM_TrackedItem::weightCertifiedReference.name )
		then
			beginTransaction;
			qp.setPerformanceRating( CM_QueryProperty.Simple );
			commitTransaction;
			count := count + 1;
			continue;
		endif;
		
		if realQueryProperty &lt;&gt; null
		and realQueryProperty.propertyClassName = qp.propertyClassName
		and realQueryProperty.propertyName = qp.propertyName
		then
			beginTransaction;
			qp.setPerformanceRating( realQueryProperty.performanceRating );
			commitTransaction;
			count := count + 1;
		endif;
		
	endforeach;
	
	
	app.writeLog( method.qualifiedName &amp; 'Completed Setting ' &amp; count.String &amp; ' Query Property Performance Ratings ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Setting ' &amp; count.String &amp; ' Query Property Performance Ratings') ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete objArray;
	delete iter;
	delete dynaDict;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setSpecialStowConfigs" id="99f6f12d-2dd4-4fe7-995b-0c9ea43dbeb0">
        <source>setSpecialStowConfigs(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	term : CM_Terminal;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting 'Consider Haz and OD as Special Stow' terminal configs", null);
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		term.setConfig( ConsiderHazAsSpecialStow, true );
		term.setConfig( ConsiderODAsSpecialStow, true );
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Setting 'Consider Haz and OD as Special Stow' terminal configs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting 'Consider Haz and OD as Special Stow' terminal configs");
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
