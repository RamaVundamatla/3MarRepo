    <JadeMethod name="resetCargoType" id="402cc2bf-17dc-422b-a646-41a114f706bc">
        <source>resetCargoType(pConstant : Constant; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     This is used as a "callBack" method from "resetCargoTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TI_CargoTypes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	13.03.24	navhn30		ChangeRequest 55213: GPHA - "Weight can be certified" config option can be deselected for ISO-Containers
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	abbr,
	className	: String;
	class		: Class;
	proxyCargoType,
	realCargoType	: CM_CargoType;
	
begin

	if pConstant.valueAsInteger &lt;= TI_CargoType_Null or
	   pConstant.valueAsInteger &gt;= TI_CargoType_Max then
	   	return;
	endif;

	text := pConstant.text;
	
	descr 	  := text.cnEcGetTagValueOfName('Descr');
	abbr  	  := text.cnEcGetTagValueOfName('Abbr');
	className := text.cnEcGetTagValueOfName('Class');
	
	if descr = null or abbr = null or className = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid format for text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	class := currentSchema.getClass(className);
	if class = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class (' &amp; className &amp; ') not found for (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	
	realCargoType := self.allCargoTypesById[pConstant.valueAsInteger];
	
	if realCargoType = null then
		// treat as a create
		create proxyCargoType transient;
		proxyCargoType.setProxyFromXML(pConstant.valueAsInteger, text, true, self);
		if pConstant.valueAsInteger = TI_CargoType_Container then					//13.03.24		navhn30		TFS #55213
			proxyCargoType.setCanWeightBeCertified(true);
		endif;
		app.myUtilityCA.utlCreateCargoType(proxyCargoType, realCargoType, null, null, app.myPassport);
	else
		proxyCargoType := app.createUpdateProxy(realCargoType).CM_CargoType;
		proxyCargoType.setProxyFromXML(pConstant.valueAsInteger, text, false, self);
		app.myUtilityUA.utlUpdateCargoType(proxyCargoType, null, null, app.myPassport);
	endif;

epilog
	delete proxyCargoType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
