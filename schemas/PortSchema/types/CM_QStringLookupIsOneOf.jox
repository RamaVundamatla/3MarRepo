	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="6454fd91-05e1-4559-a51e-d88ca34b4f73">
        <updating/>
        <source>setSearchValue(_value : Any) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.allSelectionValues.clear;
	if _value &lt;&gt; null then 
		if _value.isKindOf(StringArray) then
			_value.StringArray.copy(self.allSelectionValues);
		elseif _value.isKindOf(String) then
			self.allSelectionValues.add(_value.String);
		endif;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="1f38ba2d-b49a-4f9e-944c-83a58259faf2">
        <source>validateForRT( _queryName, _propName : String );
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	: Queries for RT must only use the operations having only one searching value.
			  A set of selected values is not valid for the RT Drivers screen. 

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	str		: String;
	strValue: String;
	
begin
	
	foreach strValue in self.allSelectionValues do
		str := str &amp; strValue &amp; ', ';
	endforeach;
	str := str[1 : str.length()-2];		
	
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null, null);
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
