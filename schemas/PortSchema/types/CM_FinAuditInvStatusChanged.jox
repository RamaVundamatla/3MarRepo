<Class name="CM_FinAuditInvStatusChanged" id="34c7b420-1431-4fd0-b80f-f5a1e41cdd81">
    <superclass name="CM_Audit"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="dateTime" id="0c8e77e0-1c2c-4cdd-82eb-ade2b96ba39e">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="invoice" id="7e7419e7-554f-45af-918e-a09ae5cce3e3">
        <embedded/>
        <type name="CM_Invoice"/>
    </ImplicitInverseRef>
    <PrimAttribute name="newStatus" id="6de8439b-2665-4f98-8afa-b1bc98908efc">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="previousStatus" id="44b91d42-fb6b-4ac4-9427-e0b3ab2aa2a6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="8236a86d-2169-4148-80f0-e1ba510be302">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDateTimeLocalTZ" id="05c17505-22a3-4858-aa4b-4bcc9bb8bd3e">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="bfffae6b-1222-4929-b487-68c0fa91d4ba">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.remarks;	
	elseif _attrName = ETRow_User  then
		return self.userId;	
	elseif _attrName = ETRow_EndDate  then
		return self.dateTime.String;	
	elseif _attrName = ETRow_Ti  then
		return null;	
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="c8edc599-aca2-448d-a5de-e3f29fc92df5">
        <source>getPropertyCol(): String;

vars
    str:    String;
begin
	str := sequenceNum.String &amp; Tab;
	str := str &amp; remarks &amp; Tab;
	str := str &amp; userId &amp; Tab;
	str := str &amp; dateTime.date.shortFormatJMT() &amp; " " &amp; dateTime.time.currentLocaleFormatJMT() &amp; Tab;
	str := str &amp; "";
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="141e5721-3df2-42ee-b5c3-57ae11ea5dca">
        <updating/>
        <source>setRemarks() updating;
//----------------------------------------------
//Created: 27 September 2001  By: cnwgd1
//----------------------------------------------
vars

begin
	
	self.remarks := "Status changed to " &amp; app.getInvoiceStatusString(invoice.getMyInvoiceProcess, newStatus); // TFS 39618

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setRemarksForReturn" id="98d23818-e3c4-4636-a02a-6bd50f31dee2">
        <updating/>
        <source>setRemarksForReturn( _returnInv : CM_Invoice ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin

	self.remarks := app.getErrorString2( Creat_with_statu_resul_retur_i, app.getInvoiceStatusString(invoice.getMyInvoiceProcess, newStatus), _returnInv.sequenceNum.String); // TFS 39618

epilog

end;</source>
        <Parameter name="_returnInv" type="CM_Invoice"/>
    </JadeMethod>
</Class>
