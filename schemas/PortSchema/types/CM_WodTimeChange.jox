    <JadeMethod name="validateForUpdate" id="f1cd1de4-0cdc-4540-a6e6-be97cbd21495">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	inheritMethod();
	
	
	if self.myWorkOrderToUpdate = null then
		app.raiseCMException(Please_select_work_order, null, null);
	endif;
	
	if not self.occursOnDT.date.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, app.getErrorString(Occurs_datetime), null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
