    <JadeMethod name="btnViewAudit_click" id="9c4307a3-41a2-403c-bcb1-1361571f618f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewAudit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2023	navkc1	Initial creation TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id

*/

vars

begin
	self.doViewAudit();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildExampleString" id="69d283f2-06b0-48e3-89fc-f99dc5f3d057">
        <source>buildExampleString(_totalLength, _totalLengthExt : Integer io; _makeUp, _makeUpExt : String io);
/*

Purpose:			
		This method builds the "Example" string
		
		This functionality was originally in checkLength method. Moving it to a separate method so that we can reuse it without having to validate the fields
Parameters:			

Return Value:		

Date				Who		Reason
18 January 2023		navkc1	Initial creation
09/02/2023			navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
11 September 2024	jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/
constants
	//CountryCode	: String = "NZ";	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
vars
	seqLength, extSeqLength : Integer; // 24 June 2022 navgm20 53898
	prefixLength, extRefPrefixLength, checkDigitLength : Integer;  // 24 June 2022 navgm20 53898
	yearLength : Integer;
	monthLength : Integer;
	dayLength : Integer;//1 Sept 2022 navmv20 TFS 54610
	style : Integer;
	businessUnitLength : Integer; 	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminalLength : Integer; 		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	countryLength : Integer; 		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	
	makeUp, makeUpExt : String;// 24 June 2022 navgm20 53898
	index : Integer;
	yearStr : String;
	monthStr : String;
	prefixStr, extRefPrefix,
	exampleSequence	: String;//24 June 2022 navgm20 53898
	seqNumString : String;
	plus : String;
	example : String;
	exampleExtRef : String; //24 June 2022 navgm20 53898
	localNow : TimeStamp;
    checkDigit  : String; //24 June 2022 navgm20 53898
	dayStr : String; //1 Sept 2022 navmv20 TFS 54610
	prefixText : String; //1 Sept 2022 navmv20 TFS 54610
	yearText : String; 			// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	countryStr : String;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminalStr : String;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	businessUnitStr : String;	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	businessUnit : CM_Bank;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminal : CM_Terminal;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	countryText : String;		// 09/02/2023	navkc1	Bug 56444
begin
	
	self.lblExample.caption := null;
	
	seqLength := self.txtSeqLength.text.Integer;
	extSeqLength := self.txtExtRefSeqLength.text.Integer; //24 June 2022 navgm20 53898
	
	yearLength := 2;
	monthLength := 2;
	checkDigitLength:=2; //04-07-2022 navmv20 53898
	dayLength :=2;//1 Sept 2022 navmv20 TFS 54610
	countryLength := 2; // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	
	businessUnit := self.myBusinessUnit;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	if businessUnit &lt;&gt; null then
		businessUnitLength := businessUnit.code.length();
	endif;
	
	terminal := self.myTerminal;				// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	if terminal &lt;&gt; null then
		terminalLength := terminal.code.length();
	endif;
	
	if cmbStyle.listIndex &gt; 0 then
		style := cmbStyle.itemData[cmbStyle.listIndex];
	endif;
	
	//Start 1 Sept 2022 navmv20 TFS 54610
	if self.typeToCreate= CM_AutoCargoIdGen and self.chkAbbreviation.value then
		prefixText := "ABC";
		prefixLength := 10; 
	elseif self.typeToCreate = CM_AutoInvoiceExtNumberGen or
			self.typeToCreate = CM_AutoCreditExtNumberGen or
			self.typeToCreate = CM_AutoIdCrdInvExtNumberGen then
			
		if style = AutoIdStyle_P_SSS then
			prefixText := self.txtPrefix.text.trimBlanks;
			prefixLength := self.txtPrefix.text.trimBlanks.length; 
		else
			prefixText := self.txtCategoryPrefix.text.trimBlanks();
			prefixLength := prefixText.length();
			yearText := self.txtYear.text;
			countryText := self.txtCountryCode.text; // 09/02/2023	navkc1	Bug 56444
		endif;
	else
		prefixText := self.txtPrefix.text.trimBlanks;
		prefixLength := self.txtPrefix.text.trimBlanks.length; 
	endif;
	//End 1 Sept 2022 navmv20 TFS 54610

	extRefPrefixLength := self.txtExtRefPrefix.text.trimBlanks.length; //24 June 2022 navgm20 53898
	yearStr := app.getErrorString(Year);
	monthStr := app.getErrorString(Month);
	prefixStr := app.getErrorString(Prefix);
	seqNumString := app.getErrorString(SequenceNumber);
	extRefPrefix := app.getErrorString(Ext_Ref_Prefix);	 //23/06/2022 navgm20 TFS 53898
    checkDigit := app.getErrorString(Check_Digit); 		 //23/06/2022 navgm20 TFS 53898
	dayStr := app.getErrorString(Day); //1 Sept 2022 navmv20 TFS 54610
	countryStr := app.getErrorString(Country);				// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminalStr := app.getErrorString(Terminal);			// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	businessUnitStr := app.getErrorString(CM_Business_Unit);// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	plus := " + ";
	
	localNow := self.systemToLocalTime(app.actualTimeServer);// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if style &lt; 1 then
	
	elseif style = AutoIdStyle_P_MM_YY_SSS then
		_totalLength := prefixLength + monthLength + yearLength + seqLength;
		_totalLengthExt := extRefPrefixLength + monthLength +yearLength+extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; monthStr &amp; "(2)" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		makeUpExt := extRefPrefix &amp; "(" &amp; extRefPrefixLength.String &amp; ")" &amp; plus &amp; monthStr &amp; "(2)" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")"
					&amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")";  //04 July 2022 navmv20 53898
		//example := txtPrefix.text.trimBlanks &amp; localNow.date.format("MM") &amp; localNow.date.format("yy");// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support //7 Sept 2022 navmv20 TFS 54610
		example := prefixText &amp; localNow.date.format("MM") &amp; localNow.date.format("yy"); //1 Sept 2022 navmv20 TFS 54610
		exampleExtRef := self.getExtRefExample(self.txtExtRefPrefix.text.trimBlanks, localNow.date.format("MM"), localNow.date.format("yy")); //24 June 2022 navmv20 53898
		
	elseif style = AutoIdStyle_P_YY_MM_SSS then // TFS 39976
		_totalLength := prefixLength + yearLength + monthLength + seqLength; // TFS 39976
		_totalLengthExt := extRefPrefixLength + monthLength+yearLength+extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; monthStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")"; // TFS 39976
		makeUpExt := extRefPrefix &amp; "(" &amp; extRefPrefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; monthStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")"
					&amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")";  //04 July 2022 navmv20 53898
		//example := txtPrefix.text.trimBlanks &amp; localNow.date.format("yy") &amp; localNow.date.format("MM"); // TFS 39976 //7 Sept 2022 navmv20 TFS 54610
		example := prefixText &amp; localNow.date.format("yy") &amp; localNow.date.format("MM"); //1 Sept 2022 navmv20 TFS 54610
		exampleExtRef := self.getExtRefExample(self.txtExtRefPrefix.text.trimBlanks, localNow.date.format("yy"), localNow.date.format("MM")); //24 June 2022 navmv20 53898
		
	elseif style = AutoIdStyle_P_YY_SSS then
		_totalLength := prefixLength + yearLength + seqLength;
		_totalLengthExt := extRefPrefixLength + yearLength+extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		makeUpExt := extRefPrefix &amp; "(" &amp; extRefPrefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")"
					&amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")"; //04 July 2022 navmv20 53898
		//example := txtPrefix.text.trimBlanks &amp; localNow.date.format("yy");
		example := prefixText &amp; localNow.date.format("yy"); //1 Sept 2022 navmv20 TFS 54610
		exampleExtRef := self.getExtRefExample(self.txtExtRefPrefix.text.trimBlanks, localNow.date.format("yy"), null); //24 June 2022 navmv20 53898
		
	elseif style = AutoIdStyle_YY_SSS then
		_totalLength := yearLength + seqLength;
		_totalLengthExt := yearLength+extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		makeUpExt := yearStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")" &amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")";  //04 July 2022 navmv20 53898
		example := localNow.date.format("yy");
		exampleExtRef := self.getExtRefExample(null, localNow.date.format("yy"), null); //24 June 2022 navmv20 53898
		
	elseif style = AutoIdStyle_P_SSS then
		_totalLength := prefixLength + seqLength;
		_totalLengthExt := extRefPrefixLength+extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		makeUpExt := extRefPrefix &amp; "(" &amp; extRefPrefixLength.String &amp; ")" &amp; plus &amp; seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")" &amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")";  //04 July 2022 navmv20 53898
		example := prefixText; //1 Sept 2022 navmv20 TFS 54610
		//example := txtPrefix.text.trimBlanks; // 1 Sept 2022 navmv20 TFS 54610
		exampleExtRef := self.getExtRefExample(self.txtExtRefPrefix.text.trimBlanks, null, null); //24 June 2022 navmv20 53898
		
	elseif style = AutoIdStyle_SSS then
		_totalLength := seqLength;
		_totalLengthExt := extSeqLength+checkDigitLength; //04 July 2022 navmv20 53898
		makeUp := seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		makeUpExt := seqNumString &amp; "(" &amp; extSeqLength.String &amp; ")" &amp; checkDigit &amp; "(" &amp;checkDigitLength.String &amp; ")";  //04 July 2022 navmv20 53898
		example := null;
		exampleExtRef := null; //24 June 2022 navmv20 53898
		
		// Start 1 Sept 2022 navmv20 TFS 54610
	elseif style = AutoIdStyle_P_YY_MM_DD_SSS then 
		_totalLength := prefixLength + yearLength + monthLength + dayLength + seqLength;  
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(2)" &amp; plus &amp; monthStr &amp; "(2)" &amp; plus &amp; dayStr &amp; "(2)" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")"; 
		example := prefixText &amp; localNow.date.format("yy") &amp; localNow.date.format("MM") &amp; localNow.date.format("dd");
		// End 1 Sept 2022 navmv20 TFS 54610
		
	elseif style = AutoIdStyle_VoyWOPelindo1 then	//16 Aug 2018	NDL	TFS 40249
		_totalLength := 16;
		makeUp := "Hard Coded Format";
		example := localNow.Date.format("yyyMM") &amp; "99999-A";
		exampleExtRef := localNow.Date.format("yyyMM") &amp; "99999-A"; //24 June 2022 navmv20 53898
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_CargoWOPelindo1 then	//16 Aug 2018	NDL	TFS 40249
		_totalLength := 12;
		makeUp := "Hard Coded Format";
		example := localNow.Date.format("yyMM") &amp; self.myTerminal.getConfig(AdditionalInfo1).String[1:3].padLeadingZeros(3);
		exampleExtRef := localNow.Date.format("yyMM") &amp; self.myTerminal.getConfig(AdditionalInfo1).String[1:3].padLeadingZeros(3); //24 June 2022 navmv20 53898
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_CC_B_L_YY_SSS then
		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		_totalLength := countryLength + businessUnitLength + prefixLength + yearLength + seqLength;
		makeUp := countryStr &amp; "(" &amp; countryLength.String &amp; ")" &amp; plus &amp; businessUnitStr &amp; "(" &amp; businessUnitLength.String &amp; ")" &amp; plus &amp; 
					prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(" &amp; yearLength.String &amp; ")" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		example := countryText &amp; businessUnit.code &amp; prefixText &amp; yearText; // 09/02/2023	navkc1	Bug 56444
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_CC_T_B_L_YY_SSS then
		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		_totalLength := countryLength + terminalLength + businessUnitLength + prefixLength + yearLength + seqLength;
		makeUp := countryStr &amp; "(" &amp; countryLength.String &amp; ")" &amp; plus &amp; terminalStr &amp; "(" &amp; terminalLength.String &amp; ")" &amp; plus &amp; businessUnitStr &amp; "(" &amp; businessUnitLength.String &amp; ")" &amp; plus &amp; 
					prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(" &amp; yearLength.String &amp; ")" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		example := countryText &amp; terminal.code &amp; businessUnit.code &amp; prefixText &amp; yearText;	 // 09/02/2023	navkc1	Bug 56444
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_CC_T_L_YY_SSS then
		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		_totalLength := countryLength + terminalLength + prefixLength + yearLength + seqLength;
		makeUp := countryStr &amp; "(" &amp; countryLength.String &amp; ")" &amp; plus &amp; terminalStr &amp; "(" &amp; terminalLength.String &amp; ")" &amp; plus &amp; 
					prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(" &amp; yearLength.String &amp; ")" &amp; plus &amp; seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		example := countryText &amp; terminal.code &amp; prefixText &amp; yearText; // 09/02/2023	navkc1	Bug 56444
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_B_L_YY_SSS then
		//17/01/2025	navkc1 JIRA Bug MTN-33813
		_totalLength := businessUnitLength + prefixLength + yearLength + seqLength;
		makeUp := businessUnitStr &amp; "(" &amp; businessUnitLength.String &amp; ")" &amp; plus &amp; prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(" &amp; yearLength.String &amp; ")" &amp; plus &amp;
					seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		example := businessUnit.code &amp; prefixText &amp; yearText;
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
		
	elseif style = AutoIdStyle_L_YY_SSSS then
		//17/01/2025	navkc1 JIRA Bug MTN-33813
		_totalLength := prefixLength + yearLength + seqLength;
		makeUp := prefixStr &amp; "(" &amp; prefixLength.String &amp; ")" &amp; plus &amp; yearStr &amp; "(" &amp; yearLength.String &amp; ")" &amp; plus &amp;
					seqNumString &amp; "(" &amp; seqLength.String &amp; ")";
		example := prefixText &amp; yearText;
		lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
	endif;
	
	if seqLength &gt; 0 then
		foreach index in 1 to seqLength do
			example := example &amp; "9";
		endforeach;
		self.lblExample.caption := app.getErrorString(Example) &amp; " = " &amp; example;
	endif;
	
	//24 June 2022 navmv20 53898 - START
	if extSeqLength &gt; 0 then
		foreach index in 1 to seqLength do
			exampleSequence &amp;= "9";
		endforeach;
		
		exampleExtRef &amp;= exampleSequence;
		self.lblExample1.caption := app.getErrorString(Example) &amp; " = " &amp; exampleExtRef &amp; self.myAutoIdGenerator.CM_AutoVehicleBookingIdGen.generateCheckDigit(exampleSequence.asInteger64JMT()).asStringJMT().padLeadingZeros(extSeqLength);
	endif;
epilog

end;</source>
        <Parameter name="_totalLength" type="Integer" usage="io"/>
        <Parameter name="_totalLengthExt" type="Integer" usage="io"/>
        <Parameter name="_makeUp" type="String" usage="io"/>
        <Parameter name="_makeUpExt" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkLength" id="455a66a5-d4e4-4bf8-8ced-3d5f30609c6d">
        <source>checkLength() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	Par 34660
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
24 June 2022   navgm20  ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
04/01/2023	navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
*/
constants
	MaxTotalLength              : Integer = 20;   
	MaxNextSequenceNumberLength : Integer = 15; // Real can only hold 15 digits accurately
	MaxTotalLengthVB            : Integer = 20; //58898
	MaxTotalLengthVBExt         : Integer = 32; //58898
	MaxNextSequenceNumberLengthVB : Integer = 15; //58898
	MaxNextExtRefSeqNumberLengthVB : Integer = 4; // ### TFS 53898 (53961) 30Jan2022 NAVPW1
	MaxTotalLengthCustDoc		: Integer = 30; //29/08/2023	navkc1	CR 59556  Task 59593
vars

	seqLength, extSeqLength : Integer; // 24 June 2022 navgm20 53898
	totalLength, totalLengthExt : Integer; // 24 June 2022 navgm20 53898
	makeUp, makeUpExt : String;// 24 June 2022 navgm20 53898
	errStr : String;

begin

	seqLength := self.txtSeqLength.text.Integer;
	extSeqLength := self.txtExtRefSeqLength.text.Integer; //24 June 2022 navgm20 53898

	if self.typeToCreate=  CM_AutoVehicleBookingIdGen then //04 July 2022 navmv20 53898
		if seqLength &gt; MaxNextSequenceNumberLengthVB then
			app.msgBox(app.getErrorString(VBSSeqNumLengthToLong), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);	//05/07/2022 navgm20 TFS 53898
			self.txtSeqLength.setFocus();
			return false;
		endif;
		
		//24 June 2022 navgm20 53898 - START
		if extSeqLength &gt; MaxNextExtRefSeqNumberLengthVB then	
			app.msgBox(app.getErrorString(ExternalSeqNumLengthToLong), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);	//05/07/2022 navgm20 TFS 53898
			self.txtExtRefSeqLength.setFocus();
			return false;
		endif;
		//24 June 2022 navgm20 53898 - END
	else //04 July 2022 navmv20 53898
		if seqLength &gt; MaxNextSequenceNumberLength then
			app.msgBox(app.getErrorString(SeqNumberLengthToLong), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.txtSeqLength.setFocus();
			return false;
		endif;
	endif;
	
	if self.txtNextSeqNum.text.trimBlanks.length &gt; seqLength then
		app.msgBox(app.getErrorString(NextSeqLengthGTRSeqLength), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.txtNextSeqNum.setFocus();
		return false;
	endif;
	
	// 18/01/2023	navkc1	TFS CR 55300 TASK 55525 UI
	self.buildExampleString(totalLength, totalLengthExt, makeUp, makeUpExt);
	
	if self.cmbIdType.listData = CM_AutoIdGenerator.VehicleBookingIdType then  //04 July 2022 navmv20 53898 -start
		if totalLength &gt; MaxTotalLengthVB then
			makeUp := makeUp &amp; " = " &amp; totalLength.String; 
			errStr := app.getErrorString(Max_length_exceeded) &amp; CrLf &amp; makeUp;	// 05/07/2022 navgm20 TFS 53898
			app.msgBox(errStr, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.txtSeqLength.setFocus();
			return false;
		endif;
		if totalLengthExt &gt; MaxTotalLengthVBExt then
			makeUpExt := makeUpExt &amp; " = " &amp; totalLengthExt.String; 
			errStr := app.getErrorString(Max_Length_Exceeded_VBExternal) &amp; CrLf &amp; makeUpExt;	// 05/07/2022 navgm20	TFS 53898
			app.msgBox(errStr, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		    self.txtExtRefSeqLength.setFocus();
			return false;
		endif;
	elseif self.cmbIdType.listData() = CM_AutoIdGenerator.CustDocNumberType then //29/08/2023	navkc1	CR 59556  Task 59593
		if totalLength &gt; MaxTotalLengthCustDoc then
			makeUpExt := makeUpExt &amp; " = " &amp; totalLengthExt.String; 
			errStr := app.getErrorString(Total_length_exceeded) &amp; CrLf &amp; makeUpExt;
			app.msgBox(errStr, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		    self.txtExtRefSeqLength.setFocus();
			return false;
		endif;
	else //04 July 2022 navmv20 53898 -end
		if totalLength &gt; MaxTotalLength then
			makeUp := makeUp &amp; " = " &amp; totalLength.String; 
			errStr := app.getErrorString(Max_length_exceeded) &amp; CrLf &amp; makeUp;
			app.msgBox(errStr, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.txtSeqLength.setFocus();
			return false;
		endif;
	endif; //04 July 2022 navmv20 53898
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkAbbreviation_click" id="a6c944b9-fdae-4007-8d23-3ad84623e619">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAbbreviation_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options

*/

vars

begin
	if self.chkAbbreviation.value then
		self.txtPrefix.enabled := false;
		self.lblPrefix.enabled :=false;
	else
		self.txtPrefix.enabled := true;
		self.lblPrefix.enabled := true;
	endif;
	self.checkLength();
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkGenExtRef_change" id="f64326ab-6382-4cd1-b72d-ba4302f02f15">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkGenExtRef_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navmv20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation

*/

vars
	chkGenExtRefVal : Boolean;
	autoIdGenerator : CM_AutoVehicleBookingIdGen;
begin
	autoIdGenerator := self.myAutoIdGenerator.CM_AutoVehicleBookingIdGen;
    chkGenExtRefVal := self.chkGenExtRef.value;
	self.lblExtRefPrefix.enabled := chkGenExtRefVal;
	self.txtExtRefPrefix.enabled := chkGenExtRefVal;
	self.lblExtRefSeqLength.enabled := chkGenExtRefVal;
	self.txtExtRefSeqLength.enabled := chkGenExtRefVal;
	self.lblTemplate1.enabled := chkGenExtRefVal;
	self.lblExample1.enabled := chkGenExtRefVal;
	if chkGenExtRefVal and self.typeToCreate = CM_AutoVehicleBookingIdGen then  
		self.txtExtRefPrefix.text := autoIdGenerator.externalRefPrefix; 
		self.txtExtRefSeqLength.text := autoIdGenerator.externalRefLength.String;
	else
	    self.txtExtRefPrefix.text := null; 
		self.txtExtRefSeqLength.text := null; 
		self.lblExample1.caption := null; 
	endif; 
	self.checkLength();
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
