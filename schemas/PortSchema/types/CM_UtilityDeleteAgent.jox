    <JadeMethod name="utlDeleteDoorDirectionRule" id="2656de17-9477-44c8-91a2-aa08838f52f2">
        <source>utlDeleteDoorDirectionRule(_rule :CM_DoorDirectionRule io; _passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_LCSet;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCM_Object(_rule, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	// 08/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - audit the location maintenance
	create coll transient;
	_rule.getLocations (coll);
	
	app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_rule.myTerminalArea, coll,CM_AuditTALocations.LocnTypeUpdate_DoorDirRules, 
										AuditDeleted, _rule.getAuditTALocationDetails);

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_rule);
	endif;

	if _passport.noErrors then
		_rule.erase(NORMAL_ERASE);
	endif;
epilog
	delete coll;
end;</source>
        <Parameter name="_rule" type="CM_DoorDirectionRule" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
