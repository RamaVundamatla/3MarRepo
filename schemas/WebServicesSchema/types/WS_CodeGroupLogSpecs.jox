    <JadeMethod name="delete" id="9a3d2e3a-065a-47ed-bc5a-fe9fe0645514">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allLogSpecies &lt;&gt; null and not self.allLogSpecies.isEmpty() then
		self.allLogSpecies.purge();
	endif;
	
	if self.allLogLengths &lt;&gt; null and not self.allLogLengths.isEmpty() then
		self.allLogLengths.purge();
	endif;
	
	if self.allLogTreatments &lt;&gt; null and not self.allLogTreatments.isEmpty() then
		self.allLogTreatments.purge();
	endif;
	
	if self.allLogTypes &lt;&gt; null and not self.allLogTypes.isEmpty() then
		self.allLogTypes.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyCodeGroupLogSpecs" id="ed01380d-547b-498c-93cf-b6b5a26dd43f">
        <source>setProxyCodeGroupLogSpecs(_codeGroup : CM_CodeGroupLogSpecs input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwmc5	Initial creation

*/

vars
	wsGrade				: WS_LogGrade;
	wsLength			: WS_LogLength;
	wsSpecies			: WS_LogSpecies;
	wsTreatment			: WS_LogTreatment;
	wsType				: WS_LogType;
	
	grade				: CM_LogGrade;
	length				: CM_LogLength;
	species				: CM_LogSpecies;
	treatment			: CM_LogTreatment;
	type				: CM_LogType;
	code				: CM_Code;
	
	allGradeTypes,
	allGradeLengths,
	allGradeTreatments	: CM_ObjectSet;
	
begin
	_codeGroup.setProxy(CodeGroup_LogSpecs,
						self.name,
						app.myRoot);

	foreach wsLength in self.allLogLengths do
		create length transient;
		length.setProxy(wsLength.code,
						wsLength.description,
						wsLength.notAvailableForEntry,
						_codeGroup);
	endforeach;
	
	foreach wsTreatment in self.allLogTreatments do
		create treatment transient;
		treatment.setProxy(	wsTreatment.code,
							wsTreatment.description,
							wsTreatment.notAvailableForEntry,
							_codeGroup);
	endforeach;
	
	foreach wsType in self.allLogTypes do
		create type transient;
		type.setProxy(	wsType.code,
						wsType.description,
						wsType.notAvailableForEntry,
						_codeGroup);
	endforeach;
	
	foreach wsSpecies in self.allLogSpecies do
		create species transient;
		species.setProxy(	wsSpecies.code,
							wsSpecies.description,
							wsSpecies.notAvailableForEntry,
							_codeGroup);
		
		create allGradeTypes transient;
		create allGradeLengths transient;
		create allGradeTreatments transient;
		
		foreach wsGrade in wsSpecies.allLogGrades do
			create grade transient;
			
			foreach wsLength in wsGrade.allLogLengths do
				length := _codeGroup.allLogLengths[wsLength.code];
				if length &lt;&gt; null then
					allGradeLengths.add(length);
				else
					app.raiseCMException1(LogLengthInvalid, wsType.code, null, null);
				endif;
			endforeach;
			
			foreach wsTreatment in wsGrade.allLogTreatments do
				treatment := _codeGroup.allLogTreatments[wsTreatment.code];
				if treatment &lt;&gt; null then
					allGradeTreatments.add(treatment);
				else
					app.raiseCMException1(LogTreatmentInvalid, wsType.code, null, null);
				endif;
			endforeach;
			
			foreach wsType in wsGrade.allLogTypes do
				type := _codeGroup.allLogTypes[wsType.code];
				if type &lt;&gt; null then
					allGradeTypes.add(type);
				else
					app.raiseCMException1(LogTypeInvalid, wsType.code, null, null);
				endif;
			endforeach;
			
			grade.setProxy(	wsGrade.code,
							wsGrade.description,
							wsGrade.notAvailableForEntry,
							species,
							allGradeLengths,
							allGradeTreatments,
							allGradeTypes,
							null,
							wsGrade.minSED,
							wsGrade.maxSED,
							wsGrade.minMeanSED,
							wsGrade.maxMeanSED);
		endforeach;
	endforeach;
	
epilog
	delete allGradeTypes;
	delete allGradeLengths;
	delete allGradeTreatments;
end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroupLogSpecs" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="5cffe7ec-1e38-472d-96fc-ba6be59fbf29">
        <updating/>
        <source>setProxyFromObject(_codeGroup: CM_CodeGroupLogSpecs) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwmc5	Initial creation

*/

vars
	wsGrade			: WS_LogGrade;
	wsLength		: WS_LogLength;
	wsSpecies		: WS_LogSpecies;
	wsTreatment		: WS_LogTreatment;
	wsType			: WS_LogType;
	
	grade			: CM_LogGrade;
	length			: CM_LogLength;
	species			: CM_LogSpecies;
	treatment		: CM_LogTreatment;
	type			: CM_LogType;
	code			: CM_Code;
	
begin
	inheritMethod(_codeGroup);
	
	foreach code in _codeGroup.allCodes do
		if not code.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		species := code.CM_LogSpecies;
		
		create wsSpecies transient;
		wsSpecies.setProxyFromObject(species);
		self.allLogSpecies.add(wsSpecies);
	endforeach;
	
	foreach code in _codeGroup.allLogLengths do
		if not code.isKindOf(CM_LogLength) then
			continue;
		endif;
		
		length := code.CM_LogLength;
		
		create wsLength transient;
		wsLength.setProxyFromObject(length);
		self.allLogLengths.add(wsLength);
	endforeach;
	
	foreach code in _codeGroup.allLogTreatments do
		if not code.isKindOf(CM_LogTreatment) then
			continue;
		endif;
		
		treatment := code.CM_LogTreatment;
		
		create wsTreatment transient;
		wsTreatment.setProxyFromObject(treatment);
		self.allLogTreatments.add(wsTreatment);
	endforeach;
	
	foreach code in _codeGroup.allLogTypes do
		if not code.isKindOf(CM_LogType) then
			continue;
		endif;
		
		type := code.CM_LogType;
		
		create wsType transient;
		wsType.setProxyFromObject(type);
		self.allLogTypes.add(wsType);
	endforeach;
	
	self.groupType	:= _codeGroup.groupType;
	self.name		:= _codeGroup.name;

epilog

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroupLogSpecs"/>
    </JadeMethod>
    <JadeMethod name="setUpdateProxyCodeGroupLogSpec" id="6098237f-d4bb-4acb-b1c0-7364a4a4678f">
        <source>setUpdateProxyCodeGroupLogSpec(_pxyCodeGroup, _realCodeGroup : CM_CodeGroupLogSpecs input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwmc5	Initial creation
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	wsGrade				: WS_LogGrade;
	wsLength			: WS_LogLength;
	wsSpecies			: WS_LogSpecies;
	wsTreatment			: WS_LogTreatment;
	wsType				: WS_LogType;
	
	pxyGrade,
	grade				: CM_LogGrade;
	pxyLength,
	length				: CM_LogLength;
	pxySpecies,
	species				: CM_LogSpecies;
	pxyTreatment,
	treatment			: CM_LogTreatment;
	pxyType,
	type				: CM_LogType;
	code				: CM_Code;
	
	allGradeTypes,
	allGradeLengths,
	allGradeTreatments	: CM_ObjectSet;
	
	realCodeGroupLS		: CM_CodeGroupLogSpecs;
	
	load				: Boolean;
	
	obj					: Object;
	
begin
	_pxyCodeGroup.setProxy(CodeGroup_LogSpecs,
						self.name,
						app.myRoot);
	
	if not _realCodeGroup.isKindOf(CM_CodeGroupLogSpecs) then
		app.raiseCMException1(Err_InvalidClass, _realCodeGroup.class.String, null, null);
		return;
	endif;
	
	realCodeGroupLS := _realCodeGroup.CM_CodeGroupLogSpecs;
	
	app.cmsBeginLoad(load);
	
	foreach wsLength in self.allLogLengths do
		//cnwmc5 - 6 Jan 2015 - PAR 35446
		//obj := wsLength.cmObjectId.asOid;	//12.08.2022 navtnr20 52451
		obj := app.myPassport.getObjectOfTypeFromOid(wsLength.cmObjectId, CM_LogLength).CM_LogLength;		//12.08.2022 navtnr20 52451
		length := realCodeGroupLS.allLogLengths[wsLength.code];
		if obj &lt;&gt; null and length = null then
			app.raiseCMException2(Cannot_change_code, "Log Length", wsLength.code, null, null);
			return;
		endif;
		
		if length = null then
			create pxyLength transient;
		else
			pxyLength := length.pxyCreateUpdateProxy();
		endif;
		
		pxyLength.setProxy(	wsLength.code,
							wsLength.description,
							wsLength.notAvailableForEntry,
							_pxyCodeGroup);
	endforeach;
	
	foreach wsTreatment in self.allLogTreatments do
		//cnwmc5 - 6 Jan 2015 - PAR 35446
		//obj := wsTreatment.cmObjectId.asOid;		//12.08.2022 navtnr20 52451
		obj := app.myPassport.getObjectOfTypeFromOid(wsTreatment.cmObjectId, CM_LogTreatment).CM_LogTreatment;		//12.08.2022 navtnr20 52451
		treatment := realCodeGroupLS.allLogTreatments[wsTreatment.code];
		if obj &lt;&gt; null and treatment = null then
			app.raiseCMException2(Cannot_change_code, "Log Treatment", wsTreatment.code, null, null);
			return;
		endif;
		
		if treatment = null then
			create pxyTreatment transient;
		else
			pxyTreatment := treatment.pxyCreateUpdateProxy();
		endif;
		pxyTreatment.setProxy(	wsTreatment.code,
								wsTreatment.description,
								wsTreatment.notAvailableForEntry,
								_pxyCodeGroup);
	endforeach;
	
	foreach wsType in self.allLogTypes do
		//cnwmc5 - 6 Jan 2015 - PAR 35446
		//obj := wsType.cmObjectId.asOid;	//12.08.2022 navtnr20 52451
		obj := app.myPassport.getObjectOfTypeFromOid(wsType.cmObjectId, CM_LogType).CM_LogType;		//12.08.2022 navtnr20 52451
		type := realCodeGroupLS.allLogTypes[wsType.code];
		if obj &lt;&gt; null and type = null then
			app.raiseCMException2(Cannot_change_code, "Log Type", wsType.code, null, null);
			return;
		endif;
		
		if type = null then
			create pxyType transient;
		else
			pxyType := type.pxyCreateUpdateProxy();
		endif;
		pxyType.setProxy(	wsType.code,
							wsType.description,
							wsType.notAvailableForEntry,
							_pxyCodeGroup);
	endforeach;
	
	foreach wsSpecies in self.allLogSpecies do
		//cnwmc5 - 6 Jan 2015 - PAR 35446
		//obj := wsSpecies.cmObjectId.asOid;	//12.08.2022 navtnr20 52451	
		obj := app.myPassport.getObjectOfTypeFromOid(wsSpecies.cmObjectId, CM_LogSpecies).CM_LogSpecies;		//12.08.2022 navtnr20 52451
		species := realCodeGroupLS.allCodes[wsSpecies.code].CM_LogSpecies;
		if obj &lt;&gt; null and species = null then
			app.raiseCMException2(Cannot_change_code, "Log Species", wsSpecies.code, null, null);
			return;
		endif;
		
		if species = null then
			create pxySpecies transient;
		else
			pxySpecies := species.pxyCreateUpdateProxy();
		endif;
		pxySpecies.setProxy(	wsSpecies.code,
								wsSpecies.description,
								wsSpecies.notAvailableForEntry,
								_pxyCodeGroup);
		
		create allGradeTypes transient;
		create allGradeLengths transient;
		create allGradeTreatments transient;
		
		foreach wsGrade in wsSpecies.allLogGrades do
			//cnwmc5 - 6 Jan 2015 - PAR 35446
			//obj := wsGrade.cmObjectId.asOid;		//12.08.2022 navtnr20 52451
			obj := app.myPassport.getObjectOfTypeFromOid(wsGrade.cmObjectId, CM_LogGrade).CM_LogGrade;		//12.08.2022 navtnr20 52451
			if species &lt;&gt; null then
				grade := species.allLogGrades[wsGrade.code].CM_LogGrade;
			endif;
			if obj &lt;&gt; null and grade = null then
				app.raiseCMException2(Cannot_change_code, "Log Grade", wsGrade.code, null, null);
				return;
			endif;
			
			if grade = null then
				create pxyGrade transient;
			else
				pxyGrade := grade.pxyCreateUpdateProxy();
			endif;
			
			foreach wsLength in wsGrade.allLogLengths do
				length := _pxyCodeGroup.allLogLengths[wsLength.code];
				if length &lt;&gt; null then
					allGradeLengths.add(length);
				else
					app.raiseCMException1(LogLengthInvalid, wsType.code, null, null);
				endif;
			endforeach;
			
			foreach wsTreatment in wsGrade.allLogTreatments do
				treatment := _pxyCodeGroup.allLogTreatments[wsTreatment.code];
				if treatment &lt;&gt; null then
					allGradeTreatments.add(treatment);
				else
					app.raiseCMException1(LogTreatmentInvalid, wsType.code, null, null);
				endif;
			endforeach;
			
			foreach wsType in wsGrade.allLogTypes do
				type := _pxyCodeGroup.allLogTypes[wsType.code];
				if type &lt;&gt; null then
					allGradeTypes.add(type);
				else
					app.raiseCMException1(LogTypeInvalid, wsType.code, null, null);
				endif;
			endforeach;
			pxyGrade.setProxy(	wsGrade.code,
								wsGrade.description,
								wsGrade.notAvailableForEntry,
								pxySpecies,
								allGradeLengths,
								allGradeTreatments,
								allGradeTypes,
								null,
								wsGrade.minSED,
								wsGrade.maxSED,
								wsGrade.minMeanSED,
								wsGrade.maxMeanSED);
		endforeach;
	endforeach;
epilog

	delete allGradeTypes;
	delete allGradeLengths;
	delete allGradeTreatments;

	app.cmsEndLoad(load);
	
end;</source>
        <Parameter name="_pxyCodeGroup" type="CM_CodeGroupLogSpecs" usage="input"/>
        <Parameter name="_realCodeGroup" type="CM_CodeGroupLogSpecs" usage="input"/>
    </JadeMethod>
</Class>
