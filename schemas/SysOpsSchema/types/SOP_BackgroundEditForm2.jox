    <JadeMethod name="loadWarnListTable" id="a6ab0ec9-d70c-4daa-86fe-12926f750c24">
        <source>loadWarnListTable() protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CMUI_BGPListTable;
	itemObj			: CM_AutoWarningItem;
	classObj		: Class;
	isSelected		: Boolean;
	rowPointer		: Integer;
	
begin
	tableObj	:=	tblWarnList;
	
	foreach classObj in self.aAllRequests do
		isSelected	:=	tableObj.allSelectedObjects.includes(classObj);
		rowPointer	:=	tableObj.addItem("");
		
		if isSelected then
			tableObj.setCellText(rowPointer, 1, TableCheckBox_Selected);
		else
			tableObj.setCellText(rowPointer, 1, TableCheckBox_NotSelected);
		endif;
		
		tableObj.setCellText(rowPointer, 2, classObj.Class.text.cnEcGetTagValueOfName('display'));
		tableObj.setCellText(rowPointer, 3, "0");
		tableObj.setCellText(rowPointer, 4, "0");
		
		create itemObj transient;
		itemObj.set(0, 0, classObj.name, null);
		tableObj.accessRow(rowPointer).itemObject	:=	itemObj;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstEmailAddress_displayRow" id="4208c00b-508a-44a4-8cc9-35d32aa6adf4">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstEmailAddress_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

	isSelected	: Boolean;
	
begin

	isSelected	:=	table.CMUI_ListTable.allSelectedObjects.includes(obj);
	
	if isSelected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CM_EmailAddress2.getDisplayDetails(false);
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_EmailAddress2.getDisplayDetails(false);
	endif;	
end;</source>
