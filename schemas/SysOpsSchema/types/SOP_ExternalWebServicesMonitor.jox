    <JadeMethod name="buildTblMessageTypes" id="1e0b8fbf-d51d-41f9-a761-82eb9ca5fbf8">
        <source>buildTblMessageTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2025	navra1	Initial creation for //navra1 - MTN-35875- 5th Sep 2025-4

*/

vars
	row : Integer;													
	allSet,															
	noneSet	: Boolean;												
begin
	allSet := true;													
	noneSet:= true;													
	
	row := 1;														
	
	if self.tblMessageType.rows &lt; 1 then
		self.tblMessageType.clear;
		self.tblMessageType.rows 				    		:= 0;
		self.tblMessageType.columns 						:= 2;
		self.tblMessageType.sortColumn[1] 					:= 2;	
		
		self.tblMessageType.addItem("1" &amp; Tab &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERCREATEUPD);
		self.tblMessageType.addItem("1" &amp; Tab &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE);
		self.tblMessageType.addItem("1" &amp; Tab &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE);		
	endif;	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildTblResponses" id="08a798f6-73b9-4550-887d-1ec9b3cf2e1c">
        <source>buildTblResponses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened
26/02/2025 	navcs2	MTN-34126 EUP |  FR - Search results Issues for Response code "0"
01/10/2025  navsp1  JIRA-35675 MTN |  Response Code '0' Handling
*/

vars
	row : Integer;													// 21/11/2024	navcs2	MTN-33423
	allSet,															// 26/02/2025 navcs2 MTN-34126
	noneSet	: Boolean;												// 26/02/2025 navcs2 MTN-34126
begin
	allSet := true;													// 26/02/2025 navcs2 MTN-34126
	noneSet:= true;													// 26/02/2025 navcs2 MTN-34126
	
	row := 1;														// 21/11/2024	navcs2	MTN-33423
	
	if self.tblResponse.rows &lt; 1 then
		self.tblResponse.clear;
		self.tblResponse.rows 				    		:= 0;
		self.tblResponse.columns 						:= 2;
		self.tblResponse.sortColumn[1] 					:= 2;	
		
		self.tblResponse.addItem(Tab &amp; self.HttpStringNull);        //JIRA-35675
        self.tblResponse.addItem(Tab &amp; self.HttpStringClientError);
		self.tblResponse.addItem(Tab &amp; self.HttpStringForbidden);
		self.tblResponse.addItem(Tab &amp; self.HttpStringNoContent);
		self.tblResponse.addItem(Tab &amp; self.HttpStringNoFound);
		self.tblResponse.addItem(Tab &amp; self.HttpStringOK);
		self.tblResponse.addItem(Tab &amp; self.HttpStringCreated); //jlier1 19/9/24 TFS 65962  
		self.tblResponse.addItem(Tab &amp; self.HttpStringUnauth);
		self.tblResponse.addItem(Tab &amp; self.HttpStringSystemError);
	endif;
	
	// 21/11/2024	navcs2	MTN-33423 Start
	while row &lt;= self.tblResponse.rows do
		if self.selectedResponses.cnContains(self.tblResponse.getCellText(row, 2)) then
			self.tblResponse.accessCell(row, 1).text := "1";
			noneSet	:= false;										// 26/02/2025 navcs2 MTN-34126
		else
			allSet := false;										// 26/02/2025 navcs2 MTN-34126
		endif;
		
		row := row + 1;
	endwhile;
	// 21/11/2024	navcs2	MTN-33423 End
	
	if allSet or noneSet then										// 26/02/2025 navcs2 MTN-34126
		self.chkAllResponses.value := true;							// 26/02/2025 navcs2 MTN-34126					
		self.doSelectUnselectAll(true, self.tblResponse);			// 26/02/2025 navcs2 MTN-34126
	endif;															// 26/02/2025 navcs2 MTN-34126

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildTblStatus" id="bfa49921-221b-48ba-8dd5-44b229e16eb2">
        <source>buildTblStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened
01/10/2025  navsp1  JIRA-35675 MTN |  Response Code '0' Handling
*/

vars
	row : Integer;			// 21/11/2024	navcs2	MTN-33423
	hasSet : Boolean;		// 21/11/2024	navcs2	MTN-33423
begin
	row := 1;				// 21/11/2024	navcs2	MTN-33423
	
	self.tblStatus.clear;
	self.tblStatus.rows 				    	:= 0;
	self.tblStatus.columns 						:= 2;
	self.tblStatus.sortColumn[1] 				:= 2;	
	
	if self.is1StopVBS then
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_NULL);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_PENDING);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_RESEND);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_DELETED);
	elseif self.isAPIENDPOINT then
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_NODATA);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_NULL);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_PENDING);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_RESEND);
	elseif self.isCams then
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_NULL);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_PENDING);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_RESEND);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_DELETED);
	elseif self.isEDBIC then
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityEdBic.Status_Unknown);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityEdBic.Status_Pending);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityEdBic.Status_Failed);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityEdBic.Status_Success);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityEdBic.Status_Resend);
	elseif self.isFinanceOne then
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityFinanceOne.Status_Success);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityFinanceOne.Status_FailureException);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityFinanceOne.Status_FailureResponse);			
	elseif self.isInvoiceAPI then
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SENT);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SUCCESS);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_ERROR);
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SEND_ERROR);							
		self.tblStatus.addItem(Tab &amp; CM_EWSActivityInvoiceAPIParts.RECEIVE_STATUS);		
	elseif self.isOpsView then
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_NULL);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_PENDING);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_RESEND);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		self.tblStatus.addItem(Tab &amp; BGP_OpsViewWSRequest.EWS_STATUS_DELETED);
	elseif self.isQships then
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Created);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Null);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Sent_Failure);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Sent_Pending);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Sent_Resend);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Sent_Success);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_Deleted);
		self.tblStatus.addItem(Tab &amp; BGP_QshipsRequest.Status_BGP_Request_Failure);
	endif;	
    
    self.tblStatus.addItem(Tab &amp; self.HttpStringNull);      //JIRA-35675
	
	if self.tblStatus.rows &gt; 0 then
		self.chkAllStatus.visible := true;
		// 21/11/2024	navcs2	MTN-33423
		while row &lt;= self.tblStatus.rows do
			if self.selectedStatuses.cnContains(self.tblStatus.getCellText(row, 2)) then
				self.tblStatus.accessCell(row, 1).text := "1";
				hasSet := true;
			endif;
			row := row + 1;
		endwhile;
		// 21/11/2024	navcs2	MTN-33423
	else
		self.chkAllStatus.visible := false;
	endif;
	
	if not hasSet then
		self.chkAllStatus.value := true;
		self.doSelectUnselectAll(true, self.tblStatus);
	else
		self.chkAllStatus.value := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildTblTerminals" id="1e7922ae-a078-4d26-86cd-e27f412de250">
        <source>buildTblTerminals();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
21/11/2024	navcs2	MTN-33423 MTN - Unable to open Searcher in the External Web Services Monitor form
*/

vars
	terminal 	: CM_Terminal;
	failedDAC	: CM_DataAccessController;
	row			: Integer;						// 21/11/2024	navcs2	MTN-33423
	hasSet		: Boolean;						// 21/11/2024	navcs2	MTN-33423
begin
	row := 0;									// 21/11/2024	navcs2	MTN-33423
	
	if self.tblTerminals.rows &lt; 1 then
		self.tblTerminals.clear;
		self.tblTerminals.rows 				    		:= 0;
		self.tblTerminals.columns 						:= 3;
		self.tblTerminals.accessColumn(3).visible 		:= true;
		self.tblTerminals.sortColumn[1] 				:= 2;
		
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if not terminal.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
				continue;
			endif;
			
			row := row + 1;																// 21/11/2024	navcs2	MTN-33423
			
			self.tblTerminals.addItem(Tab &amp; terminal.name &amp; Tab &amp; terminal.code);
			
			if self.selectedTerminals.cnContains(terminal.name) then					// 21/11/2024	navcs2	MTN-33423
				self.tblTerminals.accessCell(row, 1).text := "1";						// 21/11/2024	navcs2	MTN-33423	
				hasSet := true;
			endif;																		// 21/11/2024	navcs2	MTN-33423
		endforeach;
	endif;
	
	if not hasSet then																	// 21/11/2024	navcs2	MTN-33423
		self.chkAllTerminals.value := true;												// 21/11/2024	navcs2	MTN-33423
		self.doSelectUnselectAll(true, self.tblTerminals);								// 21/11/2024	navcs2	MTN-33423
	endif;																				// 21/11/2024	navcs2	MTN-33423
epilog 
	
end;</source>
    </JadeMethod>
