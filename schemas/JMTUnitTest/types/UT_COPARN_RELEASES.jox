	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
	releaseReq := self.getReleaseRequest(RELEASE3);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
end;
