    <JadeMethod name="trxUpdateTICheckCompleted" id="e27f3157-3d93-4ac0-a333-e269af511246">
        <updating/>
        <source>trxUpdateTICheckCompleted(_context : Integer; _complete : Boolean; _ti : CM_TrackedItem input; _effectiveDT : TimeStamp; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
24 Oct 2024 navma1	MTN-33182 SNO - 1081 Error When using using Cargo Checks Form
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate	:= true;		//24.10.2024 navma1 #MTN-33182
	_passport.useTIDictDeferUpdate			:= true;		//24.10.2024 navma1 #MTN-33182
	
	beginTransaction;
	app.myUtilityUA.utlUpdateTICheckCompleted(_context, _complete, _ti, _effectiveDT, _passport);			//20.02.2024 navhl20 #62525
	
	if _passport.noErrors then								//24.10.2024 navma1 #MTN-33182
		_passport.doDeferredUpdates();
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
