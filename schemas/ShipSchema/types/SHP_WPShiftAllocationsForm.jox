    <JadeMethod name="clearDetails" id="91fb72ba-72af-4776-bfbc-301a7e084a85">
        <updating/>
        <source>clearDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyaeg Operations Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 25/05/2018	jlgdap1		TFS 38534 Transfer Type not displaying correctly
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 15/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars

begin
	self.cmbWorkPoint.listIndex := -1;
	self.cmbShifts.listIndex := -1;
	self.cmbTransferType.listIndex := -1;		// TFS 38534
	self.txtJobId.text := null;
	self.txtJobRemarks.text := null;
	self.txtShiftStartDate.setDate(null);
	self.txtShiftStartTime.setTime(null);
	self.txtShiftEndDate.setDate(null);
	self.txtShiftEndTime.setTime(null);
	self.txtShiftRemarks.text := null;
	self.chkDLR.value := false;					// TFS 3489
	self.chkSOB.value := false;					// TFS 3489
	self.chkDirectRelease.value := false;		// TFS 47085
	self.cmbDLRDisch.listIndex := -1;			// TFS 3516
	self.chkDirectDelivery.value := false;		// TFS 52293
epilog

end;</source>
    </JadeMethod>
