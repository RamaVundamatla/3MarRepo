    <JadeMethod name="addElement" id="8fbd60cf-6c8a-4fad-9edd-766cdc735b8a">
        <updating/>
        <source>addElement(pTagName: String; pTagValue: String): JSSXmlElement updating;
/*
	The addElement() method on Document assumes that you are either:

		-	creating the root element
		-	adding an element to the root element
*/
vars
	element: JSSXmlElement;
begin
	if self.myRootElement = null then
		if self.isTransient then
			create element transient;
		else
			create element persistent;
		endif;
		element.createElement(pTagName, pTagValue, 0, self, null);
		self.myRootElement := element;
	else
		element := self.myRootElement.addElement(pTagName, pTagValue);
	endif;
	//	return the newly created element for the caller to reference
	return (element);
end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pTagValue" type="String"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="buildXmlString" id="17650278-72df-4381-994e-e8be37cff408">
        <updating/>
        <source>buildXmlString(): String updating;
/*
*/
vars
	returnString: String;
begin
	if self.myRootElement = null then
		returnString := null;
	else
		if self.prolog = null then
			self.prolog := '&lt;?xml version="1.0" standalone="yes"?&gt;' &amp; CrLf;
		endif;
		returnString := self.prolog &amp; self.myRootElement.buildXmlString();
	endif;
	return(returnString);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildXmlSubstring" id="e1d55239-8dfe-4fba-bcd5-3b54d97be8d6">
        <updating/>
        <source>buildXmlSubstring(): String updating;
/*
		Return the same as buildXmlString() but don't create the XML header

		Used to build the XML for a partial string
*/
vars
	returnString: String;
begin
	if self.myRootElement = null then
		returnString := null;
	else
		returnString := self.prolog &amp; self.myRootElement.buildXmlString();
	endif;
	return(returnString);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createSOAPResponse" id="c5e54c52-425d-4de4-a148-1c8cabcd082b">
        <updating/>
        <source>createSOAPResponse(): JSSXmlDocument updating;
/*
*/
vars
	responseDocument: JSSXmlDocument;
	rootElement: JSSXmlElement;
	xmlElement: JSSXmlElement;
	copyElement: JSSXmlElement;
	soapAttribute: JSSXmlAttribute;
begin
	if self.isTransient() then
		create responseDocument as self.class transient;
	else
		create responseDocument as self.class persistent;
	endif;
	rootElement := responseDocument.addElement(self.myRootElement.fullName(), self.myRootElement.tagValue);
	foreach soapAttribute in self.myRootElement.allAttributes do
		rootElement.addAttribute(soapAttribute.attributeName, soapAttribute.attributeValue);
	endforeach;
	foreach xmlElement in self.myRootElement.allChildElements do
		copyElement := rootElement.addElement(xmlElement.fullName(), xmlElement.tagValue);
		foreach soapAttribute in xmlElement.allAttributes do
			copyElement.addAttribute(soapAttribute.attributeName, soapAttribute.attributeValue);
		endforeach;
	endforeach;

	return (responseDocument);
end;</source>
        <ReturnType type="JSSXmlDocument"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3031b639-a3b9-4472-850d-9f07f633dc47">
        <updating/>
        <source>delete() updating;
/*
*/
begin
	delete self.myRootElement;
end;</source>
    </JadeMethod>
    <JadeMethod name="findElement" id="d27a7730-4445-4027-9f54-6d3cb91231e9">
        <updating/>
        <source>findElement(pElementName: String): JSSXmlElement updating;
/*
*/
begin
	return (self.allElementsByName[pElementName]);
end;</source>
        <Parameter name="pElementName" type="String"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="loadListbox" id="f65b2009-ac04-46b7-b295-abe049359b86">
        <source>loadListbox(pListbox: ListBox input; pIncludeAttributes: Boolean);
/*
		Recursively load the listbox starting with the root element
*/
begin
	if self.myRootElement &lt;&gt; null then
		pListbox.hasTreeLines := true;
		if not pListbox.hasPictures then
			pListbox.hasPlusMinus := true;
		endif;
		pListbox.clear;
		self.myRootElement.loadListbox(pListbox, pIncludeAttributes);
	endif;
end;</source>
        <Parameter name="pListbox" type="ListBox" usage="input"/>
        <Parameter name="pIncludeAttributes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseDocument" id="86256f7d-bdc9-4635-ab05-17ff295dc5bf">
        <updating/>
        <source>parseDocument(pXmlDocument: String): Integer updating;

vars
	xmlString: String;
	pos: Integer;
	posEnd: Integer;
	posSpace: Integer;
	nextTagName: String;
	entityPos: Integer;
	rtn: Integer;
	doEndLoad: Boolean;
begin
//	process.profilerStart();

	if not process.isInLoadState then
		beginLoad;
		doEndLoad := true;
	endif;
	//
	xmlString := pXmlDocument;
	self.replaceCrLf_WithLf(xmlString);
	pos := 1;

	//	remove any previous stuff
	self.prolog := null;
	self.allEntitiesByName.purge;
	delete self.myRootElement;
	//	check for prolog lines
	while true do
		if xmlString[pos:2] = "&lt;?" then
			posEnd := xmlString.pos("?&gt;", pos) + 2;
			self.prolog := self.prolog &amp; xmlString[pos:posEnd - pos] &amp; CrLf;
			pos := posEnd;
		elseif xmlString[pos:9] = "&lt;!DOCTYPE" then
			posEnd := xmlString.pos("&gt;", pos) + 1;
			entityPos := xmlString.pos("[", pos);
			if entityPos &gt; 0 and entityPos &lt; posEnd then
				posEnd := xmlString.pos("]&gt;", pos) + 2;
				self.parseEntities(xmlString[entityPos:posEnd - entityPos - 1]);
			endif;
			self.prolog := self.prolog &amp; xmlString[pos:posEnd - pos] &amp; CrLf;
			pos := posEnd;
		elseif xmlString[pos:4] = "&lt;!--" then
			posEnd := xmlString.pos("--&gt;", pos) + 3;
			self.prolog := self.prolog &amp; xmlString[pos:posEnd - pos] &amp; CrLf;
			pos := posEnd;
		else
			break;
		endif;
		pos := xmlString.pos("&lt;", pos);
	endwhile;

	//	parse the document elements recursively from the root element
	pos := xmlString.pos("&lt;", pos);
	if pos &gt; 0 then
		posEnd := xmlString.pos("&gt;", pos + 1);
		posSpace := xmlString.pos(" ", pos + 1);
		if posSpace &gt; 0 and posSpace &lt; posEnd then
			posEnd := posSpace;
		endif;
		nextTagName := xmlString[pos + 1:posEnd - pos - 1];
		self.addElement(nextTagName, null).parseElement(xmlString, pos);
	endif;
	if doEndLoad then
		endLoad;
	endif;
//	process.profilerStop();
//	process.profilerReport("C:\Jade52\JSSMessageSchema\JadeProf.log");

	return(rtn);
end;</source>
        <Parameter name="pXmlDocument" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="parseEntities" id="ee23fbb0-f605-424b-8206-c259e387e5c2">
        <source>parseEntities(pXmlString: String) protected;
/*
*/
vars
	entity: JSSXmlEntity;
	xmlString: String;
	pos: Integer;
	posEnd: Integer;
begin
	xmlString := pXmlString;

	pos := xmlString.pos("&lt;!ENTITY ", 1);
	while pos &gt; 0 do
		posEnd := xmlString.pos("&gt;", pos);

		if self.isTransient then
			create entity transient;
		else
			create entity persistent;
		endif;
		entity.parseEntity(xmlString[pos:posEnd - pos + 1], self);

		pos := xmlString.pos("&lt;!ENTITY ", posEnd);
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pXmlString" type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceCrLf_WithLf" id="7adde2ad-2a02-4ccd-8f98-e3e693339ab1">
        <source>replaceCrLf_WithLf(pXmlString: String io) protected;
/*
	Replace all occurrences of Cr and CrLf with Lf

	This is an XML Parser requirement as stated in the XML Recommendation
*/
vars
	prevIndex: Integer;
	indx: Integer;
	str1: String;
	str2: String;
	xmlString: String;
	xmlStringLength: Integer;
begin
	xmlStringLength := pXmlString.length;
	xmlString[xmlStringLength:1] := "X";
	xmlString := null;

	indx := pXmlString.pos(Cr, 1);
	prevIndex := 1;
	while indx &gt; 0 do
		str1 := pXmlString[prevIndex:indx-prevIndex];
		if pXmlString[indx+1:1] = Lf then
			prevIndex := indx + 2;
		else
			prevIndex := indx + 1;
		endif;
		xmlString := xmlString &amp; str1 &amp; Lf;
		indx := pXmlString.pos(Cr, prevIndex);
	endwhile;
	if prevIndex &lt; xmlStringLength then
		xmlString := xmlString &amp; pXmlString[prevIndex:end];
	endif;
	pXmlString := xmlString;
end;</source>
        <access>protected</access>
        <Parameter name="pXmlString" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setIndentation" id="c7af4708-148a-40cf-8095-63c5c067a86d">
        <updating/>
        <source>setIndentation(pIndentation: Boolean) updating;
/*
*/
begin
	self.noIndentation := pIndentation;
end;</source>
        <Parameter name="pIndentation" type="Boolean"/>
