    <JadeMethod name="mnuListboxInsertPath_click" id="9853705a-248d-44f6-8fae-6e3630b81830">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuListboxInsertPath_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: CnEcListBox;
	fullName	: String;
	objectNode	: String;
	
begin
	app.mousePointer	:=	Busy;
	
	listboxObj	:=	lstProperties;
	
	if listboxObj.listIndex = CNEC_NULL_INDEX then
		return;
	endif;
	
	objectNode	:=	listboxObj.itemText[1];
	
	fullName	:=	listboxObj.itemFullName(listboxObj.listIndex);
	fullName	:=	fullName[(objectNode.length + 2):end];
	fullName.replaceChar(listboxObj.nameSeparator.Character, ".");
	
	self.insertSource(fullName);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
