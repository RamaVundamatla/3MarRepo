    <JadeMethod name="txtTrackedItemIDLostFocus" id="9003d25e-c2d0-4d7e-9abe-6a78afba4d0f">
        <updating/>
        <source>txtTrackedItemIDLostFocus(textbox: TextBox input) updating;
//--------------------------------------------------------------
//Created: 06 March 2002 By: cnwgd1
//--------------------------------------------------------------
// 07/02/2013	cnwmh5	#31080 - Change so that if adding and ti exists close the current add down and open
//						Cargo Enquiry for editing.
vars
	tmpTI	: CM_TrackedItem;
	rowIdx	: Integer;
	cargoType : CM_CargoType;
begin

	tblMain.setValueByControlName(textbox.name, textbox.text);

	if self.hasFieldChanged and textbox.text &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;
		tmpTI := self.getPreNoteOrOnSiteTI(textbox.text);
		if tmpTI &lt;&gt; null then
			if tmpTI.site &lt;&gt; TI_SITE_ONSITE then
				/*
				// 07/02/2013 cnwmh5 #31080 - Replaced
				self.setDefaultsFromObject(tmpTI);
				self.myCurrentObject := tmpTI;
				self.mode := Mode_View;
				self.zDoEdit();
				app.raiseCMWarning1(WARN_TI_PRE_NOTIFIED, tmpTI.id, null, null, tmpTI);
				*/
				self.mode := Mode_View;
				self.myCurrentObject := tmpTI;	
				if app.msgBox(app.getErrorString1(WARNING_TI_PRE_NOTED_EDIT, tmpTI.id), "Pre Notification Error", MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
					self.tblMain.clearHasChanged();
					self.tblExtra.clearHasChanged();
					self.btnCancelBase_click(self.btnCancelBase);
					self.tblData.removeItem(2);
					self.tblData.findObjectInRow(tmpTI, rowIdx);
					if self.tblData.rows &gt; 2 then
						if rowIdx &lt; 2 then
							rowIdx := 2;
						endif;
						self.tblData.selectTheCurrentRow(rowIdx);
						self.showThumbnailData(tmpTI);
					endif;
					self.zDoEdit();
					return;
				else
					self.mode := Mode_Add;
					self.tblMain.selected := false;
					cargoType := tmpTI.myCargoType;	//19 Sep 2016	NDL	TFS 2650 / 2001
					if not self.myTerminal.getConfig( AllowDuplicatePreNotes ).Boolean	//19 Sep 2016	NDL	TFS 2650 / 2001
					or cargoType = null	//19 Sep 2016	NDL	TFS 2650 / 2001
					or not cargoType.allowDuplicates	//19 Sep 2016	NDL	TFS 2650 / 2001
					then	//19 Sep 2016	NDL	TFS 2650 / 2001
						self.tblMain.row := tblMain.getRowByControlName(textbox.name);
						self.tblMain.setValueByName('idTextBox', null);
						self.tblMain.setFocus();
					endif;	//19 Sep 2016	NDL	TFS 2650 / 2001
					if not self.tableIsPrefilled then
						self.myAssistant.GTE_Assistant.setFieldsFromContainerRange(textbox.text, tblMain, tblExtra, self.cmbISOType);
					endif;
					return;
				endif;
			else
				app.raiseCMException3(ERR_TI_ONSITE, tmpTI.cargoTypeDescr, tmpTI.id, tmpTI.myTerminal.code, null, null);
				return;
			endif;
			if not self.tableIsPrefilled then
				self.myAssistant.GTE_Assistant.setFieldsFromContainerRange(textbox.text, tblMain, tblExtra, self.cmbISOType);
				tblMain.row := tblMain.getRowByControlName(textbox.name) + 1;
			endif;
		else
			if not self.tableIsPrefilled then
				self.myAssistant.GTE_Assistant.setFieldsFromContainerRange(textbox.text, tblMain, tblExtra, self.cmbISOType);		
			endif;
		endif;
	else
		if not self.tableIsPrefilled then
			self.myAssistant.GTE_Assistant.setFieldsFromContainerRange(textbox.text, tblMain, tblExtra, self.cmbISOType);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTrackedItemID_firstChange" id="466d4c48-9e84-4991-a23b-5ab4f9d9043a">
