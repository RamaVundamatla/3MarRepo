<Class name="CM_YABlockGridArea">
    <JadeMethod name="exportPDXMLMyCollections" id="02aacf9b-7fe0-48d0-8b93-82845ef372d9">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	inheritMethod(_file, _objArray, _property, _object);
	if _property.name = CM_YABlockGridArea::allGridObjects.name then
		_file.writeLine('&lt;'&amp;CM_YABlockGridArea::allGridObjects.name&amp;'&gt;');
		_file.writeLine('&lt;'&amp;CM_YABlock::myTerminalArea.name&amp;'&gt;'&amp;self.myTerminalArea.theKey()&amp;'&lt;/'&amp;CM_YABlock::myTerminalArea.name&amp;'&gt;');
		foreach obj in self.allGridObjects do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;'&amp;CM_GridRow::myGridArea.name&amp;'&gt;'&amp;obj.getPropertyValue(CM_GridColumn::myGridArea.name).Object.theKey()&amp;'&lt;/'&amp;CM_GridRow::myGridArea.name&amp;'&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.CM_Object.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YABlockGridArea::allGridObjects.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="21d0fe3f-89e6-47e0-ac68-53d428fccfdc">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	termArea: CM_TerminalArea;
	gridObject: CM_GridObject;
begin
	if _name = CM_YABlockGridArea::allGridObjects.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_YABlockGridArea::allGridObjects.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('name', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				termArea := self.myTerminalArea;
				if aClass = CM_GridRow then
					gridObject := termArea.CM_GridArea.allGridRowsByLabel[theKey].CM_GridRow;
				elseif aClass = CM_GridColumn then
					gridObject := termArea.CM_GridArea.allGridColumnsByLabel[theKey].CM_GridColumn;
				endif;
				if gridObject &lt;&gt; null then
					self.allGridObjects.add(gridObject);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;gridObject.theKey;
				endif;				
			endif;
		endwhile;
	else
		inheritMethod(_name, _collectionsBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollectionsOLD" id="0951f5e4-6dbc-4069-a615-cfe145c6bed3">
        <updating/>
        <source>importPLXMLMyCollectionsOLD(_collectionsBlock: String) updating;

vars
	objArray: ObjectArray;
	object: Object;
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	termArea: CM_TerminalArea;
	gridObject: CM_GridObject;
begin
	inheritMethod(_collectionsBlock);
//write(class.name&amp;'::'&amp;method.name&amp;' _collectionsBlock='&amp;_collectionsBlock);
	create objArray transient;

	objBlock := _collectionsBlock.cnEcGetTagValueOfName('allGridObjects');
//write(class.name&amp;'::'&amp;method.name&amp;' allTerminalAreas');
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
////write class.name&amp;'::'&amp;method.name&amp;' allObjects='&amp;objBlock;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('name', pos);
		if pos &lt; 1 then
			break;
		endif;
		theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
//write class.name&amp;'::'&amp;method.name&amp;' theCode='&amp;theCode&amp;' theKey='&amp;theKey;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
//			objArray.clear();
//			aClass.allInstances(objArray, 0, false);
//write class.name&amp;'::'&amp;method.name&amp;' aClass='&amp;aClass.name&amp;' objArray='&amp;objArray.size.String;
			termArea := self.myTerminalArea;
			if aClass = CM_GridRow then
				gridObject := termArea.CM_GridArea.allGridRowsByLabel[theKey].CM_GridRow;
			elseif aClass = CM_GridColumn then
				gridObject := termArea.CM_GridArea.allGridColumnsByLabel[theKey].CM_GridColumn;
			endif;
			if gridObject &lt;&gt; null then
					self.allGridObjects.add(gridObject);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;gridObject.theKey;
				endif;				
//			foreach object in objArray do
//				if object.theKey = theKey then
//					self.allGridObjects.add(object.CM_GridObject);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;object.theKey;
//				endif;				
//			endforeach;
		endif;
	endwhile;
	
epilog
	delete objArray;		// PAR #27874
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
</Class>
