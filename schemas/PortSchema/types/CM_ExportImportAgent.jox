    <JadeMethod name="clearPropertyCollections" id="1924a1f1-ac91-4f32-8304-43c8151ed3ad">
        <updating/>
        <source>clearPropertyCollections() updating;
/*

Purpose:			
	// Clears all property categorization collections
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

begin
    self.attributes.clear();
    self.references.clear();
    self.referencesToExpand.clear();
    self.collections.clear();
    self.collectionsToExpand.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="escapeJsonString" id="86f4e26e-93c3-4201-ba2b-f767f6533dd3">
        <source>escapeJsonString(input: String): String protected;
/*

Purpose:			
	* Escapes special characters for JSON string values
	 * Handles quotes, backslashes, newlines, tabs, etc.
	 * 
	 * @param input String to escape
	 * @return JSON-safe string
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    result: String;
begin
    if input = null then
        return "";
    endif;
    
    result := input;
    
    // Replace backslash first (must be first to avoid double-escaping)
    result := result.replace('\', '\\');
    
    // Replace double quotes
    result := result.replace('"', '\"');

// Replace control characters
    result := result.replace(Cr, '\r');  // Carriage return
    result := result.replace(Lf, '\n');  // Line feed
    result := result.replace(Tab, '\t');   // Tab
    result := result.replace(Cn_BackSpace, '\b');   // Backspace
    result := result.replace(CN_FF_DELIMITER, '\f');  // Form feed
    
    return result;
end;
</source>
        <access>protected</access>
        <Parameter name="input" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="escapeXml" id="e3551db7-46d4-48e4-b07d-9bffd31138b9">
        <source>escapeXml(_value: String): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

begin
    if _value = null then
        return "";
    endif;
    
    // Escape XML special characters
    return _value.replace('&amp;', '&amp;amp;')
                 .replace('&lt;', '&amp;lt;')
                 .replace('&gt;', '&amp;gt;')
                 .replace('"', '&amp;quot;')
                 .replace("'", '&amp;apos;');
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
