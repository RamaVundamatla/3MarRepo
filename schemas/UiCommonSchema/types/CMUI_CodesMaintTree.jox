    <JadeMethod name="showLstData" id="be5b4d0a-bc10-4d0b-b94c-1477f3060499">
        <updating/>
        <source>showLstData() updating;
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	self.showTree(self.currentGroupType, false);


