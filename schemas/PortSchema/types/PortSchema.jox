    <JadeMethod name="convertBlobForRequest" id="5f2584b6-b97e-4d77-b482-351681711c7c">
        <source>convertBlobForRequest(_blob : Binary; _fileName : String; _isTransient : Boolean; _type : Integer) : CM_FileDataStorageHeader;
// -------------------------------------------
// Created 27 August 2003 by cnwdvb1
// -------------------------------------------
vars


	offset,
	binaryLength,
	dataLength		: Integer;
	detail			: CM_FileDataStorageDetail;
	header			: CM_FileDataStorageHeader;
	data			: Binary;
	name			: String;

begin

	// This method takes a blob and turns it into a data storage
	// header so it can be attached to an email request.
	name := _fileName;
	if name = null then
		name := 'attachment.txt';
	endif;
	binaryLength	:=	_blob.length();
	if not binaryLength &gt; 0 then
		return null;
	endif;
	dataLength	:=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;
	offset := 1;
	if _isTransient then
		create header transient;
	else
		create header persistent;
	endif;
	header.set(name, _type);
	while offset &lt;= binaryLength do
		if (binaryLength - offset) &lt; dataLength then
			dataLength	:=	(binaryLength - offset) + 1;
		endif;
		
		data		:=	_blob[offset : dataLength];
		offset		:=	offset + data.length;
// cnwdad1 25/02/2009 - PAR #18366.
//		data		:= data.compress();
		data		:= data.compressToBinary(Binary.Compression_ZLib);
		if _isTransient then
			create detail transient;
		else
			create detail persistent;
		endif;
		detail.set(name, data, null, header);
		if offset &gt;= binaryLength then
			break;
		endif;
	endwhile;
	return header;
end;</source>
        <Parameter name="_blob" type="Binary"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_isTransient" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_FileDataStorageHeader"/>
    </JadeMethod>
