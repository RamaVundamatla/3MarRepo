    <JadeMethod name="getEDITIType" id="ddafc596-1a85-49bf-b21f-1017bcee9f9a">
        <source>getEDITIType(_ediDataType : Integer): Class;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 02 May 2007
//
//----------------------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals

vars

begin
	if _ediDataType =  EDIDataType_TIHazDets then	//17 Nov 2016	NDL	TFS 2843 / 2604
		return CM_EDIHazDetailsTI;
	elseif _ediDataType =  EDIDataType_TISeal then
		return CM_EDISealTI;
	else
		return CM_EDIPrenoteTI;
	endif;

epilog

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
