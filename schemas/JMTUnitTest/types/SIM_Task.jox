    <JadeMethod name="getDisplay" id="5d11d672-92f8-449e-b9a1-7726486bce8c">
        <source>getDisplay() : String;
vars
	msg: String;
begin

	msg := self.id.String &amp; " " &amp; self.machineType &amp; " " &amp; self.getMachineId &amp; " " &amp; self.taskType &amp; 
		" " &amp; self.getCargoId &amp; 
		" Source: " &amp; self.getSourceId &amp; " Target: " &amp; self.getTargetId &amp; " Next: " &amp; self.getNextTaskId;

	if self.isCompleted then
		msg := msg &amp; " Completed";
	endif;
	
	if self.myTask = null then
		msg := msg &amp; " No RT task";
	endif;
	
	return msg;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
