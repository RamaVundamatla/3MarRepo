    <JadeMethod name="cmbHarbour_click" id="358b749c-871f-45d1-a9c8-c4fb3c0d0377">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHarbour_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	harbourObj	: HMS_Harbour;
	allObjects	: ObjectSet;
	
begin
	if combobox.listIndex = CNEC_NULL_INDEX then
		mulSelect1.setSelected(null);
	else
		harbourObj	:=	combobox.listObject.HMS_Harbour;
		create allObjects transient;
		harbourObj.getBerthsUnassignedToRegion(allObjects);
		mulSelect1.setAvailable(allObjects, true);
		//mulSelect1.setSelected(harbourObj.allBerths);
	endif;
epilog
	delete allObjects;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
