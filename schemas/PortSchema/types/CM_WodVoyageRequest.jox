    <JadeMethod name="actionForApproved" id="7106b510-17e2-450a-8510-a8b8cbed1876">
        <updating/>
        <source>actionForApproved(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2021	jlier1	Initial creation 51963
19 May 2024	navnk30	Bug 63643: MTN - Copying a voyage does not copy voyage type correctly

*/

vars
	vessel : CM_Vessel;
	pxyVoyage : CM_Voyage;
	deletePxyVoyage : Boolean;
	voyageCode,
	externalCode : String;
	voyageNum : Integer;
	conflictManager : CMIF_HMS_ConflictsManager;
begin
	inheritMethod(_voyage);
	
	if _voyage = null then
		return;
	endif;
	//From tfs 51963 it is approved  have to
		//1. create the voyage structure
		//2. change the voyage code to run throught normal voyage code creation
	

	//get the vessel
	vessel:=_voyage.myVessel;

	if vessel &lt;&gt; null then
		pxyVoyage:=app.myProxyManager.getProxyObject(_voyage).CM_Voyage;
		if pxyVoyage = null then
			pxyVoyage:=_voyage.pxyCreateUpdateProxy().CM_Voyage;
			deletePxyVoyage:=true;
		endif;	
		//if self.hasCargo then										//19.05.2024 navnk30 #63643
		if self.hasCargo and _voyage.hasNoStructureDefined then		//19.05.2024 navnk30 #63643
			pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO ,
									vessel.structureIncludesRORO ,
									vessel.structureIncludesHolds,
									vessel);	
		endif;
		
		if self.myParent.id = _voyage.code then
			voyageCode:=_voyage.myTerminal.getNextVoyageCode(vessel,voyageNum, app.myPassport);
			if _voyage.voyageCodeExternal = null then
				externalCode:=app.myPassport.myTerminal.getNextVoyageExternalCode(vessel);
			endif;
			pxyVoyage.setProxyCodeExternalCode(voyageCode,externalCode);
		endif;
		app.myUtilityUA.utlUpdateVoyage(pxyVoyage.myCellularVoyageStructure &lt;&gt; null, false,pxyVoyage,conflictManager,false,app.myPassport);
		self.voyageCode:=_voyage.code;
	endif;

epilog
	if conflictManager &lt;&gt; null then
		delete conflictManager;
	endif;
	if deletePxyVoyage then
		delete pxyVoyage;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForCancelled" id="89fe1042-1e62-4226-8cf7-45ce8da330a9">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2021	jlier1	Initial creation 51963
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	status : CM_VoyageStatus;
begin
	inheritMethod(_voyage);
	
	if _voyage.myVoyageProcess.isEUPDefaultProcess then 								// TFS 54298
		status := _voyage.myVoyageProcess.allStatusesById[Voyage_Status_EUP_Cancelled];	// TFS 54298
	else
		status := _voyage.myVoyageProcess.allStatusesById[Voyage_Status_VoyCancelled];
	endif;

	if status &lt;&gt; null  then
		_voyage.setStatusFromObject(status);
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForNotApproved" id="d3ee2d84-9921-472f-9638-7fc0508f6bf6">
        <source>actionForNotApproved(_voyage: CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2021	jlier1	Initial creation 51963
18 Aug 2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
15 Feb 2023 navma1 	ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	status				 : CM_VoyageStatus;
	voyageProcess		 : CM_VoyageProcess;
	isEupDefProcess	 	 : Boolean;
	voyage				 : CM_Voyage;
	wo					 : CM_WorkOrder;
	archiveCmif			 : CMIF_ArchiveVoyage;
begin
	inheritMethod(_voyage);
	
	voyageProcess 	:= _voyage.myVoyageProcess;											//15.02.2023 navma1 #56561
	isEupDefProcess	:= voyageProcess.isEUPDefaultProcess();								//15.02.2023 navma1 #56561
	
	if isEupDefProcess then 															// TFS 54298
		status := voyageProcess.allStatusesById[Voyage_Status_EUP_VoyReqRej]; 			// TFS 54298
	else
		status := voyageProcess.allStatusesById[Voyage_Status_VoyReqRejected];
	endif;
	
	if status &lt;&gt; null then
		_voyage.setStatusFromObject(status);
	endif;
	
	/*
	53944.020 Voyage Request approval
	15.02.2023 navma1 #56561
	*/
	create archiveCmif transient;
	if isEupDefProcess then
		archiveCmif.removeBookingRefs 				:= true;
		archiveCmif.removeEDITrackedItems			:= true;
		archiveCmif.removeNonWorkedTrackedItems		:= true;
		archiveCmif.removePreNotifiedTrackedItems   := true;
		archiveCmif.removeTBATrackedItems			:= true;
		archiveCmif.allVoyages.add(_voyage);
		app.myUtilityUA.utlUpdateVoyageArchive(archiveCmif, app.myPassport);
	endif;
	
epilog
	delete archiveCmif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
