    <JadeMethod name="initForm" id="dce9dc7f-b423-4dbb-b4a3-86ad6a17f564">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
begin
	self.toolbarStyle			:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar			:=	true;

	self.allowNext				:=	false;
	self.allowPrint				:=	false;
	self.allowExportCSV			:=	false;
	self.allowUpdate			:=	true;
	self.allowHideThumbnail		:=	false;	
	self.allowTblDataHide		:=	false;
	self.allowMultiSelectEdit	:=	true;
	self.allowAdd				:=	false;
	self.allowDelete			:=	false;
	self.showFilterOnStartup	:=	true; 	// Show the filter frame
	self.showDataOnStartup		:=	false; 	// Do not populate the data table with data
	self.useNumRowsShown		:=	true;
	self.useTblThumb			:=	false;
	self.useFloatingFilter		:=	true;
	self.allowSearch			:=	true;	// reset this here as if showWithObject this gets set to false earlier
	self.frmStatusLine.visible	:=	false;
	self.displayMode			:=	DISPLAY_MODE_ACTUAL;
// cnwdad1 19/07/2006 - Fixed during testing on 7.4.2: When restoring ththis form while starting up
// JMT, an exception was raised in CM_ContainerEnqForm::setControlsForAddEdit because the reference
// to self.myCurrentObject was null.  This form doesn't have an add/edit mode.
//	self.initialMode			:=	Mode_Add;
	self.initialMode			:=	self.Mode_View;
	self.sptThumbEdit.splitType	:=	CMUI_SplitContainer.SPLITTYPE_LOCKLEFT;
	self.initTblThumb();
	self.cmbVoyage.init(self.myTerminal.allVoyagesByCode, self.myTerminal, false);
	self.cmbDisPort.myAssistant	:=	self.myAssistant;
	
	if self.amInitialisingWithObject then
		self.initForTerminalArea(false);
	endif;
	
		
	self.btnTranship.visible := false;
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="074412ef-8d2c-4338-bc4b-fda209bd4530">
        <updating/>
        <source>initTblThumb() updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	entDef	: EntTableDef;
begin

	self.frmDetailsBottom.visible	:= false;
	self.tblInputTop.visible		:= true;
	self.tblInputTop.userInputEnabled := true;	

	entDef := app.myController.getEntTableDef(ETDef_InterSTDetails);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ' &amp; ETDef_InterSTDetails &amp; ' was not found.');
		return;
	endif;
	self.tblInputTop.setEntTableDef(entDef, null, 'entTableDefSetupWarning');

	self.sptThumbEdit.setRightControl(null);
	self.sptThumbEdit.showLeftControl(100, true);
	
	self.cmbCompany.setObject(null); //PAR11666 
	//WAS...self.myAssistant.comboBoxBusinessUnit(cmbCompany, null);	
//	self.myAssistant.comboBoxDischarge(self.cmbDisPort, null, null);	
	self.myAssistant.comboBoxIMEXStatus(self.cmbImExStatus, null);	
	self.cmbVoyage.init(self.myTerminal.allVoyagesByCode, self.myTerminal, false);			

end;</source>
    </JadeMethod>
    <JadeMethod name="saveISTParamSpecial" id="cd9b04f9-f6f3-477d-aae7-443fa6d711db">
        <source>saveISTParamSpecial(_propName, _strValue : String; _istParam : CMIF_InterStorageTransport input; _table : CM_EntryTable) : Boolean;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _propName = ETRow_ImexStatus then
		if self.cmbImExStatus.listObject &lt;&gt; null then
			_istParam.imexStatus := self.cmbImExStatus.listObject.CM_IMEXStatus.code;
			return true;
		endif;
	elseif _propName = ETRow_MyVoyage then
		if self.cmbVoyage.listObject &lt;&gt; null then
			_istParam.myVoyage := self.cmbVoyage.listObject.CM_Voyage;
			return true;
		endif;
	elseif _propName = ETRow_DischargePort then
		if self.cmbDisPort.myObject &lt;&gt; null then
			_istParam.dischargePort := self.cmbDisPort.myObject.CM_Port.code;
			return true;
		endif;						
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_istParam" type="CMIF_InterStorageTransport" usage="input"/>
        <Parameter name="_table" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="50b4b08f-5f49-428f-9ad7-572ba042417b">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars

	theBackColour 		: Integer;

begin
	inheritMethod(_colorControl);
	theBackColour := self.backColor;
	self.frmDetailsTop.backColor := theBackColour;		
	self.setColorsForEntryTable(self.tblInputTop);
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="3f162c21-5dea-47b7-ab6c-8809e06cb085">
        <updating/>
        <source>setControlsForView() updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
//	inheritMethod();
	self.btnSaveBase.enabled := true;
	self.btnCancelBase.enabled := true;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		btnSaveBase.enabled:= false;
		self.tblData.userInputEnabled := false;
		self.tblInputTop.userInputEnabled := false;
	endif;
end;</source>
    </JadeMethod>
