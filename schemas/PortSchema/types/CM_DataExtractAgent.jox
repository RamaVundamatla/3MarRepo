    </JadeMethod>
    <JadeMethod name="doExtract" id="2b1e7d71-d7f7-4cbf-adbc-d8e01272a4a4">
        <updating/>
        <source>doExtract(_terminal : CM_Terminal; _classCol : CM_DataExtractClassSet; _outputFolderName, _createDate, _createTime : String; _breakOut : Boolean output) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	#cnwdz2	 

*/

vars
	dataExtractClass : CM_DataExtractClass;
	docPath,
	filePath,
	className        : String;   
begin
	on Exception do self.extractExHandler(exception);
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	//if app &lt;&gt; null then
		//app.myDataExtractAgent := self;
		//CM_DataExtractRoot.firstInstance.getAgent();
	//endif;	
	
	foreach dataExtractClass in _classCol do		
		self.buildExtractTransientMethod(dataExtractClass);				
		className := dataExtractClass.className;
		
		docPath := self.buildOutputFilePath(_outputFolderName, _createDate, _createTime, className, true);
		self.extractDoc(dataExtractClass, docPath);
		
		filePath := self.buildOutputFilePath(_outputFolderName, _createDate, _createTime, className, false);		
		self.extractData(_terminal, dataExtractClass, filePath, _breakOut);
		
		if _breakOut then
			self.log("User has cancelled the extraction.");
			return;
		endif;
	endforeach;
epilog
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_classCol" type="CM_DataExtractClassSet"/>
        <Parameter name="_outputFolderName" type="String"/>
        <Parameter name="_createDate" type="String"/>
        <Parameter name="_createTime" type="String"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="extractData" id="423ed4da-f7c7-4150-89d0-72ed9417f07b">
        <updating/>
        <source>extractData(_terminal : CM_Terminal; _dataExtractClass : CM_DataExtractClass; _outputFilePath : String; _breakOut : Boolean output) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	#cnwdz2	 

*/

vars
	file    : File;
	field   : CM_DataExtractField;
	counter : Integer;
begin
	self.log("Extracting data of " &amp; _dataExtractClass.className &amp; " to "&amp; _outputFilePath);
	
	create file transient;
	file.fileName := _outputFilePath ;
	file.mode := File.Mode_Output;
	//file.kind := File.Kind_ANSI;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	
	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return;
	endif;
	file.purge();
	
	_dataExtractClass.doExtractData(_terminal, file, counter, _breakOut);
	self.log("Extracted " &amp; counter.String &amp; " objects of " &amp; _dataExtractClass.className);
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_dataExtractClass" type="CM_DataExtractClass"/>
        <Parameter name="_outputFilePath" type="String"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="extractDoc" id="5f8305ac-e315-4b8b-b833-5aaf5eba7d29">
        <updating/>
        <source>extractDoc(_dataExtractClass : CM_DataExtractClass; _outputFilePath : String) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	#cnwdz2	 

*/

vars
	doc     : File;
	field   : CM_DataExtractField;
	docLine : String;
begin	
	self.log("Extracting documentation of " &amp; _dataExtractClass.className &amp; " to "&amp; _outputFilePath);
	
	create doc transient;
	doc.fileName := _outputFilePath ;
	doc.mode := File.Mode_Output;
	//doc.kind := File.Kind_ANSI;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	if (not doc.tryOpen) then
		app.raiseCMException1(FileUnavailable, doc.fileName, null, null);
		return;
	endif;
	doc.purge();
			
	_dataExtractClass.doExtractDoc(doc);	
epilog
	if doc &lt;&gt; null then
		doc.close;
		delete doc;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_dataExtractClass" type="CM_DataExtractClass"/>
        <Parameter name="_outputFilePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="extractExHandler" id="0d0370bd-9978-459f-b833-a93232058cff">
        <updating/>
        <source>extractExHandler(exObj: Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
constants
	ServerMethodAborted = 1242;
	
vars
	errStr    : String;
	errorObj  : Object;
	curMethod : MethodCallDesc;
begin
	abortTransaction;
	
	if exObj.errorCode = ServerMethodAborted then
		// Already handled by server method exception handler.
		return Ex_Resume_Next;
	endif;
	
	self.errorOccurred := true;
	
	errorObj := exObj.errorObject;
	
	errStr := "Extract exception - abandoned extract of all data types" &amp; CrLf &amp;
			  "Error Code: " &amp; exObj.errorCode.String &amp; CrLf &amp;
			  "Extended Error Text: " &amp; exObj.extendedErrorText &amp; CrLf &amp;
			  "Text: " &amp; exObj.text &amp; CrLf &amp;
			  "Error Item: " &amp; exObj.errorItem;
	if errorObj &lt;&gt; null then
		errStr := errStr &amp; CrLf &amp; "Error Object: " &amp; errorObj.String;
	endif;
	
	curMethod := exObj.currentMethodDesc;
	if curMethod &lt;&gt; null then
		errStr := errStr &amp; CrLf &amp; "Current Method Name: " &amp; curMethod.getName;
	endif;
	
	self.log(errStr);

	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="finalise" id="875f94ee-39e6-40eb-a638-3423835cf5a8">
        <updating/>
        <source>finalise()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	#cnwdz2	 

*/

vars

begin
	self.log("Data extract finished");
	self.deleteLog;
	
	on Exception do null global;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="generateCodeForEtDefs" id="176f59c0-bd3a-452c-8391-9c07dc20b79c">
        <source>generateCodeForEtDefs(_etDefs	: EntTableDefSet; _className : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2011	#cnwdz2	 

*/

vars
	usedRows		: EntTableRowDictByName;
	etRow			: EntTableRow;
	etRows			: EntTableRowArray;
	etDef			: EntTableDef;
	scriptFile		: File;
	className,
	typeStr,
	valuesDesc,
	codeLine		: String;
begin
	create usedRows transient;
	
	foreach etDef in _etDefs do
		if scriptFile &lt;&gt; null then
			scriptFile.close();
			delete scriptFile;
		endif;
		create scriptFile transient;
		scriptFile.openOutput("c:\temp\script_" &amp; _className &amp; "_" &amp; etDef.name &amp; ".txt");
		
		delete etRows;
		create etRows transient;
	
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null then
				etRows.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
		
		foreach etRow in etRows do
			codeLine := Tab &amp; 'fieldName := "' &amp; etRow.name &amp; '";';
			scriptFile.writeLine(codeLine);
			
			codeLine := Tab &amp; "self.initDataExtractField(_fields, ";
			codeLine := codeLine &amp; _className &amp; '.name, "' &amp; etRow.name &amp; '", fieldName, ';
			self.getTypeFromInputType(etRow.inputType, typeStr, valuesDesc);
			codeLine := codeLine &amp; typeStr &amp; ", ";
			codeLine := codeLine &amp; '"' &amp; etRow.getPropertyValue('heading').String &amp; '", "**** fill in with field description ****", ';
			codeLine := codeLine &amp; typeStr &amp; ", ";
			codeLine := codeLine &amp; '"' &amp; valuesDesc &amp; '");';
			
			scriptFile.writeLine(codeLine);
			scriptFile.writeLine(null);
			
		endforeach;

	endforeach;
	
	if scriptFile &lt;&gt; null then
		scriptFile.close();
	endif;
epilog
	delete usedRows;
	delete scriptFile;
	delete etRows;
end;</source>
        <access>protected</access>
        <Parameter name="_etDefs" type="EntTableDefSet"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
    <JadeMethod name="generateCodeForOnsiteContainer" id="7022e8c9-cbf5-43c4-9770-930e2fb3ea8b">
        <source>generateCodeForOnsiteContainer();

/*

Purpose:			Generate a first cut of the data extract code for extracting Cargo data
					from JMT for CCMS DCT 2073

Parameters:			None

Return Value:		None

Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services

*/

vars
	etRoot			: EntTableDataRoot;
	etGroup			: EntTableGroup;
	etDefs			: EntTableDefSet;
	etDef			: EntTableDef;
begin
	etRoot := app.myRoot.myEntTableDataRoot;
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	
	create etDefs transient;
	etDef := etGroup.allEntTableDefsByName[ETDef_CargoEnqDefaultData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ContainerData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_General];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReceiveData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReleaseData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ShipOpsData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_Status];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TranshipData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReeferData];
	etDefs.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_GeneralData];
	etDefs.add(etDef);

	self.generateCodeForEtDefs(etDefs, CM_Container.name);
epilog
	delete etDefs;
end;</source>
    </JadeMethod>
