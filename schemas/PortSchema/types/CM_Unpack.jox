    <JadeMethod name="getUnpackAmount" id="edabf6b4-0c39-49f9-a908-c11f4a67d6e1">
        <source>getUnpackAmount() : String;
/*

Date		Who		Reason
27 June 2014	cnwer1	Initial creation PAR 34472
08 Dec  2014    cnwma1  PAR #35350 Error 1090 on Transaction Enquiry
11 Dec  2015    cnwma1  PAR #37305 Error 4 while try opening the cargo transactions 

*/

vars
	ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
begin
	
	if self.action = ACTION_UNPACK_CHILD then
		/*if self.otherTrackedItem &lt;&gt; null then	//08/12/2014 cnwma1 PAR #35350   //11/12/2015 cnwma1 PAR #37305
			ct:= self.otherTrackedItem.myCargoType;
			density:=self.otherTrackedItem.getDensity;
		endif;*/
		if self.getOtherTrackedItem &lt;&gt; null then	//11/12/2015 cnwma1 PAR #37305
			ct:= self.getOtherTrackedItem.myCargoType;
			density:=self.getOtherTrackedItem.getDensity;
		endif;
		
	else
		ct:= self.myTrackedItem.myCargoType;
		density:=self.myTrackedItem.getDensity;
	endif;
	if ct = null then
		return null;
	endif;

	if ct.isBreakBulkMulti then		
		return self.totalQuantity.asStringJMT ;	
	elseif ct.isBulkMulti then		
		return ct.getBulkTrackByDisplayForWeight( self.totalWeight,density,true) ;	
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
