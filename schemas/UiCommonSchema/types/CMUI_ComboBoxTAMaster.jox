    <JadeMethod name="displayEntry" id="35f17c6a-8c7e-4fd7-bcfc-2c3a92db79f6">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _taMaster: CM_TerminalAreaMaster; lstIndex: Integer): String updating, clientExecution;

// Created by cnwdvb1 on 05 September 2006

vars

begin
	return _taMaster.getID();

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="2a7d3800-a17d-49ad-9719-a4d3b8b0e566">
        <source>getCollectionJMT(): Collection protected;

// Created by cnwdvb1 on 05 September 2006

vars

begin

	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.allTerminalAreaMastersById;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
