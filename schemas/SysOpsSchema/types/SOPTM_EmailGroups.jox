    <JadeMethod name="resetGroupColl" id="c76098f6-cfff-48c5-9ccf-ea53d232210b">
        <source>resetGroupColl() protected;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	iter 	: Iterator;
	entity	: CM_EmailEntity;

begin

	self.allEmailGroups.clear();
	self.allEmailAddresses.clear();
	iter := app.myRoot.allEmailEntities.createIterator();
	while iter.next(entity) do
		if entity.type = Email_Address then
			self.allEmailAddresses.add(entity.CM_EmailAddress2);
		else
			self.allEmailGroups.add(entity.CM_EmailGroup);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="934ce81b-1b71-419a-9742-2dd468a48a64">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled	:= true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.tblInput1.disableRowByName(ETRow_CamsProtocols); //epr TFS 2227
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.mulSelect1.setSelected(null);
		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EmailGroup);

	endif;

	self.enableMulSelect1Contents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="4420c166-8078-44bf-aec3-ea9e7b64e79f">
        <updating/>
        <source>setCtrlsForView() updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	theForm	: SOP_TableMaintForm;
	count : Integer;
begin

	inheritMethod();
	self.resetGroupColl();
	theForm := self.myForm;
	theForm.mulSelect1.setSelected(null);
	theForm.tblInput1.showRowByName(ETRow_CamsProtocols, false);	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="68d03215-64cb-45eb-8b43-f6375ee21b59">
        <source>setupThumbnailDetails();
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_EmailGroupMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Title, false);
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EmailGroupMaint);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b602eef3-3e2b-4b94-8639-ef10541eb75e">
        <updating/>
        <source>showThumbnail(_group: CM_EmailGroup) updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars
	theForm	:	SOP_TableMaintForm;
begin

	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Title, _group.name);
	theForm.tblInput1.setValueByName(ETRow_CamsProtocols, _group.getDisplayStringForAttribute(ETRow_CamsProtocols, false));
	
	theForm.mulSelect1.setSelected(_group.allEmailAddresses);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="_group" type="CM_EmailGroup"/>
    </JadeMethod>
</Class>
