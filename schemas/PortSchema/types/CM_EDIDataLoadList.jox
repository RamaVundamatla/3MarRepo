    <JadeMethod name="getFieldValueForTI" id="fc7e0d87-b5c6-4026-b254-10f03b927b54">
        <source>getFieldValueForTI(_attrName: String; _ti: CM_TrackedItem):String;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediTI	: CM_EDILoadListTI;
begin
	
	ediTI := self.allEDITrackedItems[_ti.id].CM_EDILoadListTI;
	
	if _attrName = ETRow_DestinationPort then
		if ediTI = null then
			return null;
		else
			return ediTI.destinationPort;
		endif;
	elseif _attrName = ETRow_CarbonDioxide then
		if ediTI = null then
			return '0';
		else		
			return ediTI.getCarbonDioxide.asStringJMT;
		endif;
	elseif _attrName = ETRow_Oxygen then
		if ediTI = null then
			return '0';
		else		
			return ediTI.getOxygen.asStringJMT;
		endif;
	else
		if ediTI = null then
			return null;
		else
			return ediTI.getPropertyValue(_attrName).String;
		endif;
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
