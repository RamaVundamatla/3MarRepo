    <JadeMethod name="addLCsToLOLOAllocation" id="1004cd05-5626-49c2-ac07-1c4e711378f7">
        <updating/>
        <source>addLCsToLOLOAllocation(isLoad : Boolean;_voyAllocation : CM_VoyageAllocation; theSlots,theSlotsAlt : CM_SlotControllerArray) updating;
 
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	slot : CM_SlotController;
	allEditions : CM_ObjectByOidEditionDict;
	tmpObject : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn : Integer;
begin
	create allEditions transient;
	
	foreach slot in theSlots  discreteLock do
		allEditions.add(slot);
	endforeach;
	
	if theSlotsAlt &lt;&gt; null then
		foreach slot in theSlotsAlt  discreteLock do
			allEditions.add(slot);
		endforeach;
	endif;
	
	app.myTrxUA.trxUpdateSlotRequestVA(theSlots, theSlotsAlt, isLoad,	allEditions, _voyAllocation, app.myPassport);	
	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete allEditions;
end;</source>
        <Parameter name="isLoad" type="Boolean"/>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
        <Parameter name="theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="theSlotsAlt" type="CM_SlotControllerArray"/>
    </JadeMethod>
    <JadeMethod name="addLCsToROROAllocation" id="21738e07-b2ab-405e-b8d8-64da1e96d484">
        <updating/>
        <source>addLCsToROROAllocation(isLoad : Boolean;_voyAllocation : CM_VoyageAllocation; theSlots,theSlotsAlt : CM_LCArray; _qty : Integer) updating, protected;
 
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	slot : CM_VoyageROROController;
	lc : CM_LocationsController;
	allEditions : CM_ObjectByOidEditionDict;
	tmpObject : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn : Integer;
begin
	create allEditions transient;
	
	foreach lc in theSlots  discreteLock do
		allEditions.add(lc);
	endforeach;
	
	if theSlotsAlt &lt;&gt; null then
		foreach lc in theSlotsAlt  discreteLock do
			allEditions.add(lc);
		endforeach;
	endif;
	
	app.myTrxUA.trxUpdateRORORequestVA(theSlots, theSlotsAlt, isLoad,allEditions	, _voyAllocation, _qty, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete allEditions;
end;</source>
        <access>protected</access>
        <Parameter name="isLoad" type="Boolean"/>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
        <Parameter name="theSlots" type="CM_LCArray"/>
        <Parameter name="theSlotsAlt" type="CM_LCArray"/>
        <Parameter name="_qty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addLabourRestriction" id="d3f355b8-08ae-464d-b4fc-5a06a90174a1">
        <source>addLabourRestriction(_restrictID : String; _location : Any; _ignoreWarnings : Boolean) : CM_LabourRestriction;

/*

Purpose:		

Date			Who		Reason
19 February 2015	cnwmh5	Initial creation

*/

vars

	proxyLabourRestriction 			: CM_LabourRestriction;
	realLabourRestriction 			: CM_LabourRestriction;
	organisation					: CM_Organisation;
	terminalArea					: CM_TerminalArea;
	
	lcArray 						: CM_LCArray;

	
begin

	create lcArray transient;
	if _location.isKindOf(CM_TerminalArea) then
		_location.CM_TerminalArea.allLocationsControllers.copy(lcArray);
		terminalArea := _location.CM_TerminalArea;
	elseif _location.isKindOf(CM_LCArray) then
		_location.CM_LCArray.copy(lcArray);
		terminalArea := lcArray.first.myTerminalArea;
	endif;

	// delete labour restriction
	foreach realLabourRestriction in terminalArea.allRestrictionsLabour discreteLock do
		if realLabourRestriction.id = _restrictID then
			self.deleteLabourRestriction(realLabourRestriction);
		endif;
	endforeach;
	realLabourRestriction := null;

	// Organisation
	organisation := self.getRoot.allOrganisations["Jade Master Terminal"];
	self.assertNotNull(organisation);

	create proxyLabourRestriction transient;
	proxyLabourRestriction.setProxy(Red,									//_colour : Integer; 
									app.getMyUserCode,						//_userCode,
									"",										//_comment : String; 
									null,									//_durationHrs : Time;
									1,										//_durationDays : Integer;
									CM_LabourRestrictionReasonCode.firstInstance,	//_reason : CM_LabourRestrictionReasonCode;
									lcArray,								//_allLocations : CM_LCArray;
									_restrictID,								//_id : String;
									false,									//_ignoreLights : Boolean;
									organisation,							//_organisation : CM_Organisation;
									null,									//_email : CM_EmailEntity;
									null,					//_emails : CM_EmailAddressByAddressDict;
									terminalArea							//_theTerminal : CM_TerminalArea
									);
									
	while true do
		app.myTrxCA.trxCreateRestrictionLabour(proxyLabourRestriction, realLabourRestriction, app.myPassport);
		if not _ignoreWarnings then
			self.assertNoTrxErrorsOrWarnings();
		else
			if app.myPassport.trxCompletedOK then
				break;
			else
				if app.myPassport.noErrors() then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
		endif;
		break;
	endwhile;

	return realLabourRestriction;
	
epilog

	delete proxyLabourRestriction;
	delete lcArray;
	
end;</source>
        <Parameter name="_restrictID" type="String"/>
        <Parameter name="_location" type="Any"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
        <ReturnType type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="addLinkedExportBookings" id="d4bde3f0-ab9a-490e-8758-3db38235260e">
        <updating/>
        <source>addLinkedExportBookings(_booking1 : CM_BookingRef; _booking2 : CM_BookingRef)updating;

//12 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars


	pxyBooking : CM_BookingRef;
	bItem : CM_BookingRefItem;
begin
	beginLoad;
	pxyBooking := _booking2.pxyCreateUpdateProxy;
	endLoad;

	foreach bItem in _booking1.allBookingRefItems do
		pxyBooking.allLinkedStockBookingItems.add(bItem);
	endforeach;
	
	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking,	app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyBooking;
end;</source>
        <Parameter name="_booking1" type="CM_BookingRef"/>
        <Parameter name="_booking2" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addLinkedStockBookingItems" id="884582ce-b3ff-48ae-a989-b31ba3a3493d">
        <updating/>
        <source>addLinkedStockBookingItems(_stock : CM_BookingRef; _export : CM_BookingRef)updating;
//12 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyBooking : CM_BookingRef;
	bItem : CM_BookingRefItem;
begin
	beginLoad;
	pxyBooking := _stock.pxyCreateUpdateProxy;
	endLoad;
	
	foreach bItem in pxyBooking.allBookingRefItems do
		bItem.allLinkedExportBookings.add(_export);
	endforeach;
	
	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking,	app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyBooking;
end;</source>
        <Parameter name="_stock" type="CM_BookingRef"/>
        <Parameter name="_export" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addLogicalDelArea" id="e1ca6af5-4f49-4f08-b97a-bd0135f9a16c">
        <source>addLogicalDelArea(_name: String; _createDelTrx: Boolean ): CM_BlockStack;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2017	jlgndl1	Initial creation	TFS 5679

*/

vars

	pxyBlockStack : CM_BlockStack;
	realTA : CM_TerminalAreaMaster;
	pDO : CM_YADeckingOptionsTA;

begin

	self.deleteTerminalArea(_name);
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(	_name, 
							"",
							TA_TYPE_DELETE, 
							100,
							5,
							5,
							false,
							"", 
							100,
							true, 
							null,
							self.getTerminal,
							false,
							false,
							false,
							false,
							false,
							null,
							null,
							_createDelTrx
							);
							
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;

epilog

	delete pxyBlockStack;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_createDelTrx" type="Boolean"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addMTPoolingParty" id="52afd296-6d2e-4acc-88d9-88068d208cc8">
        <source>addMTPoolingParty(_code : String; _desc : String) : CM_MTPoolingParty;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/01/2017	cnwdap1		Initial creation TFS 3042 SNO Empty Container Pool Management
//
vars
	proxyPoolParty, realPoolParty : CM_MTPoolingParty;
	poolingPartners : CM_MTPoolingPartnerByOperator;

begin
	create proxyPoolParty transient;
	create poolingPartners transient;
	proxyPoolParty.setProxy(_code, _desc, self.getTerminal, poolingPartners);
	app.myTrxCA.trxCreateMTPoolParty(proxyPoolParty, realPoolParty, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	return realPoolParty;
epilog
	delete proxyPoolParty;
	delete poolingPartners;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_MTPoolingParty"/>
    </JadeMethod>
    <JadeMethod name="addMachine" id="48a944e7-16ce-40e3-84af-03bf389e7c0c">
        <source>addMachine(_type: Integer; _name: String; _deviceId: Integer; _taAccess: StringArray; _queue: String): CM_Machine;
//07 January 2009	cnwdw1	
// 12/08/2011		cnwmh5	Change to use UT_UntiTest's opts rather than passing it
// 28/10/2011		cnwmh5	Changed so can create cranes
vars
	pxyMachine,machine: CM_Machine;
	cmifMachine: CMIF_Machine;
	ta: String;
	pxyRTDevice: CM_RTDeviceVehicleMount;
	rtDevice: CM_RadioTelemetryDevice;
	canLift				: String;
	terminalArea			: CM_TerminalArea;
begin
	deleteMachine(_name);
	deleteRTDevice(_deviceId.String);
	
	create cmifMachine transient;
	cmifMachine.code := _name;
	cmifMachine.description := _name;
	cmifMachine.available := self.opts.bool("IsAvailable");
	cmifMachine.canLift40Foot := true;
//	cmifMachine.maxLiftWeight := 999999;F
		canLift := self.opts.str("CanLift");
		if canLift[1] = "1" then
			cmifMachine.canLift30Foot := true;
		endif;
		if canLift[2] = "1" then
			cmifMachine.canLift40Foot := true;
		endif;
		if canLift[3] = "1" then
			cmifMachine.canLift45Foot := true;
		endif;
		if canLift[4] = "1" then
			cmifMachine.canLift53Foot := true;
		endif;
	//endif;
	
	if self.opts.includesKey("WeightMaxLift") then
		cmifMachine.maxLiftWeight := self.opts.int("WeightMaxLift");
	else
		cmifMachine.maxLiftWeight := 999999;
	endif;
	
	cmifMachine.description := _name;
	if self.opts.includesKey("Description") then
		cmifMachine.description := self.opts.str("Description");
	endif;
	cmifMachine.machineType := app.myRoot.allMachineTypes[_type];
	cmifMachine.hasRadioTelemetry := true;
	cmifMachine.recordActivityHistory := true;
	cmifMachine.maxStackHeightFull := self.opts.real("MaxStackHeightFull");
	cmifMachine.maxStackHeightMT := self.opts.real("MaxStackHeightMT");
	cmifMachine.machineLiftType := self.opts.int("MachineLiftType");
	cmifMachine.weightDifference := self.opts.int("WeightDifference");
	cmifMachine.tareWeight := self.opts.int("TareWeight");
	//cmifMachine.maxLiftWeight := self.opts.int("WeightMaxLift");
	cmifMachine.craneJobSeed := self.opts.int("BaseJobNumber");
	cmifMachine.minItemsForTLJob := self.opts.int("MinItemsForTLJob");

	if _taAccess &lt;&gt; null then
		foreach ta in _taAccess do
			// 12/06/2014 cnwmh5
			terminalArea := self.getTerminalArea(ta);
			self.assertNotNull(terminalArea);
			cmifMachine.terminalAreas.add(terminalArea);
			//cmifMachine.terminalAreas.add(self.getTerminalArea(ta));
		endforeach;
		if _queue &lt;&gt; null then
			cmifMachine.allSelectedQueues.add(self.getQueue(_queue));
		endif;
	endif;
	
	if self.opts.includesKey("CargoTypes") then
		self.opts.obj("CargoTypes").ObjectArray.copy(cmifMachine.cargoTypes);
	else
		self.getRoot.allCargoTypesById.copy(cmifMachine.cargoTypes);
	endif;
	
	if self.opts.includesKey("ContentStatuses") then
		self.opts.obj("ContentStatuses").ObjectSet.copy(cmifMachine.allAllowableContentStatuses);
	else
		self.getRoot.allContentsStatuses.copy(cmifMachine.allAllowableContentStatuses);
	endif;
	
	if _type = MACHINETYPE_PORTAINER_CRANE then
		create pxyMachine as CM_Crane transient;
		pxyMachine.CM_Crane.setPropertyValue("transferArea", self.opts.obj("CraneTransferArea"));
	else
		create pxyMachine as CM_Machine transient;
	endif;
	
	// add colour
	if self.opts.includesKey("Colour") then
		cmifMachine.colour := self.opts.int("Colour");
	endif;
	
	
	//create pxyMachine transient;
	pxyMachine.setProxyFromCMIF_Machine(cmifMachine, app.myPassport);
	app.myTrxCA.trxCreateMachine(pxyMachine, machine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	rtDevice := addRTDevice(RTDevice_Vehicle, _deviceId.String, "UTMACHINE", "", machine, false, false,false);	// +17/08/2016 cnwrh7	TFS	2501
	self.assertNoTrxErrorsOrWarnings();
	
	///self.machineConfig(machine);
	self.machineTerminalConfig(machine);
	return machine;
	
epilog
	delete cmifMachine;
	delete pxyMachine;
	delete pxyRTDevice;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_deviceId" type="Integer"/>
        <Parameter name="_taAccess" type="StringArray"/>
        <Parameter name="_queue" type="String"/>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="addMachineRule" id="3ec4edfa-db99-49f8-8f73-9ad73dfd0240">
        <source>addMachineRule(_fromTA, _toTA: CM_TerminalArea; _moveMethod: Integer);
//15 September 2010	cnwdw1	
//
vars
	moveMethod: CM_RTMoveMethod;
	multiRule, realMultiRule: CM_RTQueueMultiRule;
	rule: CM_RTMoveMethodRule;
	queuingRule: String;
	
	addRuleMethodArray			: IntegerArray;
	
	isDefault					: Boolean;
	ruleMethod					: Integer;
	
begin
	self.deleteMachineRule(_fromTA, _toTA);

	create multiRule as CM_RTQueueMultiRuleTAMaster transient;
	multiRule.CM_RTQueueMultiRuleTAMaster.setForProxyTAMaster(_fromTA, _toTA, self.getTerminal);
	
	queuingRule := LegMoveQueuing;
	if self.opts.includesKey("FullMoveQueueing") then
		queuingRule := FullMoveQueuing;
	endif;
	
	moveMethod := getRoot.allRTMoveMethods[_moveMethod];
	create rule transient;
	rule.setProxy(multiRule,
						moveMethod,
						true,
						"",
						null,
						null,
						queuingRule);
						
	// 24/06/2014 cnwmh5
	if self.opts.includesKey("AdditionalRulesMethod") then
		addRuleMethodArray := self.opts.obj("AdditionalRulesMethod").IntegerArray;
		foreach ruleMethod in addRuleMethodArray do
			moveMethod := getRoot.allRTMoveMethods[ruleMethod];
			create rule transient;
			rule.setProxy(	multiRule,
							moveMethod,
							false,
							"",
							null,
							null,
							queuingRule	);
		endforeach;
	endif;
	
	
	app.myTrxCA.trxCreateRTQueueMultiRule(multiRule, realMultiRule, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete multiRule;
	delete addRuleMethodArray;
	
end;</source>
        <Parameter name="_fromTA" type="CM_TerminalArea"/>
        <Parameter name="_toTA" type="CM_TerminalArea"/>
        <Parameter name="_moveMethod" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMachineRuleType" id="c7b114fe-6ffd-4030-b89c-5eb80e06f6f7">
        <source>addMachineRuleType(_fromTAType, _toTAType : CM_TerminalAreaType; _moveMethod : Integer; _queuingRule : String);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/09/2011	cnwdap1	Initial creation PAR #25693 CCMS POL 2008
*/
vars
	moveMethod					: CM_RTMoveMethod;
	multiRule, realMultiRule	: CM_RTQueueMultiRule;
	rule						: CM_RTMoveMethodRule;
	
begin

	self.deleteMachineRuleType(_fromTAType, _toTAType);						// 14/08/2012 cnwmh5

	create multiRule as CM_RTQueueMultiRuleTAType transient;
	multiRule.CM_RTQueueMultiRuleTAType.setForProxyTAType(_fromTAType, _toTAType, self.getTerminal);
	
	moveMethod := getRoot.allRTMoveMethods[_moveMethod];
	create rule transient;
	rule.setProxy(	multiRule,
					moveMethod,
					true,
					"",
					null,
					null,
					_queuingRule	);
	
	
	app.myTrxCA.trxCreateRTQueueMultiRule(multiRule, realMultiRule, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete multiRule;
	
end;</source>
        <Parameter name="_fromTAType" type="CM_TerminalAreaType"/>
        <Parameter name="_toTAType" type="CM_TerminalAreaType"/>
        <Parameter name="_moveMethod" type="Integer"/>
        <Parameter name="_queuingRule" type="String"/>
    </JadeMethod>
    <JadeMethod name="addMasterTi" id="87df1182-1d8d-44d3-ab00-bc2241d46285">
        <source>addMasterTi(_id: String;_isCommunicating,_isHeavyLift : Boolean;_coolingType : Integer;_voltageType : Integer;		_tareWeight,_extHeight,	_extLength,	_extWidth,_intHeight,
			_intLength,_intWidth : Integer;_maxWeight : Decimal;_volume : Real;
			_operator,_owner : CM_Operator;_isoType : CM_ISOType;
			_stopTables: CM_StopsTableByIdDict;_toDoTaskDesc : CM_ToDoTaskDescByCode): CM_TIMasterContainer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwma1	Initial creation

*/

vars
	proxyTiMaster		: CM_TIMasterContainer;
	realTiMaster		: CM_TIMasterContainer;
begin

		create proxyTiMaster transient;
	proxyTiMaster.setForProxyMasterContainer(_id,
											_isCommunicating,
											_isHeavyLift,
											_coolingType,
											_voltageType,
											_tareWeight,
											_extHeight,	
											_extLength,	
											_extWidth,
											_intHeight,
											_intLength,
											_intWidth,
											_maxWeight,
											_volume ,
											_operator,
											_owner,
											_isoType,
											_stopTables,
											_toDoTaskDesc,
											null);

	app.myTrxCA.trxCreateTIMasterContainer(proxyTiMaster,realTiMaster,false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
		return  realTiMaster;
epilog
		delete proxyTiMaster;
end;</source>
