    <JadeMethod name="getFilterCargoType" id="ba5032a7-559b-46fa-b1ed-98e1baa1b3fd">
        <source>getFilterCargoType() : CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlger1	Initial creation  TFS 47132 

*/

vars
	cargoTypeCrit: CM_SelectorCriteriaLine;
	cargoType  : Integer;
	cargoTypeObj : CM_CargoType;
begin

	if self.myCriteriaLineHolder = null then
		return null;
	endif;
	
	cargoTypeCrit:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
	if cargoTypeCrit &lt;&gt; null then
		cargoTypeObj:=app.myRoot.allCargoTypesById[cargoTypeCrit.myQueryOperator.getSearchValue.Integer];
	endif;
	
	return cargoTypeObj;
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
