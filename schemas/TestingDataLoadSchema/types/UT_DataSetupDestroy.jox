Inbound Ship Operator						= 94
Outbound Ship Operator						= 95
Transit Status								= 96
Is Direct Delivery							= 97

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	xmlElement4				: JadeXMLElement;
	voyageTypeAttribute		: JadeXMLAttribute;
	xmlAttribute			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	colorCodeCriteriaElem	: JadeXMLElement;
	jobLoadPlanOpsElement	: JadeXMLElement;
		
	obj						: Object;
	voyage					: CM_Voyage;
	yaCriteriaType			: CM_YACriteriaType;
	
	locationsArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	location				: String;
	bayId					: String;
	craneId					: String;
	tiId					: String;
	deleteStops				: Boolean;
		
begin

	varsStr := CrLf &amp; Tab &amp; 'realAlloc					: CM_VoyageAllocation;' &amp; CrLf &amp; 
		Tab &amp; 'slot							: CM_SlotController;' &amp; CrLf &amp;
		Tab &amp; 'voyageJob					: CM_VoyageJob;' &amp; CrLf &amp;
		Tab &amp; 'voyage						: CM_Voyage;' &amp; CrLf &amp; 
		Tab &amp; 'request						: CM_Request;' &amp; CrLf &amp;
		Tab &amp; 'wle							: CM_WorkListEntry;' &amp; CrLf &amp;
		Tab &amp; 'toLocn						: CM_LocationsController;' &amp; CrLf &amp;
		Tab &amp; 'moveController				: CMIF_MoveController;' &amp; CrLf &amp;
		Tab &amp; 'terminal						: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'ti							: CM_TrackedItem;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'roroLCs						: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'altRoroLCs					: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'slots						: CM_SlotControllerArray;' &amp; CrLf &amp;
		Tab &amp; 'altSlots						: CM_SlotControllerArray;' &amp; CrLf &amp; 
		Tab &amp; 'wles 						: CM_WLEArray;' &amp; CrLf &amp;
		Tab &amp; 'tiArray						: CM_TIArray;' &amp; CrLf &amp; 
		Tab &amp; 'voyageJobArray				: CM_VoyageJobArray;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; 'create roroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create altRoroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create slots transient;' &amp; CrLf &amp;
		Tab &amp; 'create altSlots transient; ' &amp; CrLf &amp;
		Tab &amp; 'create tiArray transient;' &amp; CrLf &amp; 
		Tab &amp; 'create wles transient;' &amp; CrLf &amp;
		Tab &amp; 'create voyageJobArray transient;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'delete roroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete altRoroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete slots;' &amp; CrLf &amp;
		Tab &amp; 'delete altSlots;' &amp; CrLf &amp;
		Tab &amp; 'delete tiArray;' &amp; CrLf &amp; 
		Tab &amp; 'delete wles;' &amp; CrLf &amp;
		Tab &amp; 'delete moveController;' &amp; CrLf &amp;
		Tab &amp; 'delete voyageJobArray;' &amp; CrLf;
		
	create locationsArray transient;

	foreach obj in _colorCodeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;

		// set any opts
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		// get the terminal
		xmlAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; xmlAttribute.value &amp; '");' &amp; CrLf;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; xmlAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		// get the voyage
		xmlElement2 := xmlElement.getElementByTagName("voyage");
		voyageTypeAttribute := xmlElement2.getAttributeByName("Type");
		codeStr := codeStr &amp; Tab &amp; 'voyage := self.getVoyage(' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;
		voyage := self.getVoyage(self.returnElementText(xmlElement2).String);
	
		// get the color code criteria 
		colorCodeCriteriaElem := xmlElement.getElementByTagName("colorCodeCriteriasLocs");
		if colorCodeCriteriaElem &lt;&gt; null then
		
			foreach obj in colorCodeCriteriaElem.childNodes do
				// criteria and locations
				xmlElement2 := obj.JadeXMLElement;
				foreach obj in xmlElement2.childNodes do
					xmlElement3 := obj.JadeXMLElement;
					if xmlElement3.tagName = "criterias" then
						// get and setup the criteria
						foreach obj in xmlElement3.childNodes do
							// criteria
							xmlElement4 := obj.JadeXMLElement;
							xmlAttribute := xmlElement4.getAttributeByName("Type");
							yaCriteriaType := app.myRoot.allYACriteriaTypes[xmlAttribute.value.Integer];
							codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; yaCriteriaType.description &amp; '", ' &amp; self.returnElementText(xmlElement4).String &amp; ');' &amp; CrLf;		
						endforeach;
						
						codeStr := codeStr &amp; Tab &amp; 'realAlloc := self.addVoyageAllocation(voyage);' &amp; CrLf &amp; CrLf &amp;
							Tab &amp; 'roroLCs.clear();' &amp; CrLf &amp;
							Tab &amp; 'altRoroLCs.clear();' &amp; CrLf &amp;
							Tab &amp; 'slots.clear();' &amp; CrLf &amp;
							Tab &amp; 'altSlots.clear();' &amp; CrLf &amp; CrLf;
							
					elseif xmlElement3.tagName = "locations" then
						
						if voyageTypeAttribute.value.toUpper() = "LOLO".toUpper() then
			
							// get the slots to color code
							locationsArray.clear();
							location := self.returnElementText(xmlElement3).String;
							location.getTokensForDelimiter(";", locationsArray);
							foreach location in locationsArray do
								// get the locations
								bayId := location[1:2];
								codeStr := codeStr &amp; Tab &amp; 'slot := self.getJobLOLOControllerByID(voyage.code, "' &amp; bayId &amp; '", "' &amp; location &amp; '");' &amp; CrLf &amp;
									Tab &amp; 'slots.add(slot);' &amp; CrLf;
							endforeach;
							codeStr := codeStr &amp; Tab &amp; 'self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);' &amp; CrLf;
							
						endif;
					
					endif;
				
				endforeach;
			endforeach;
			
		endif;
	
		// get the jobs
		codeStr := codeStr &amp; Tab &amp; 'voyageJobArray.clear();' &amp; CrLf;
		
		jobLoadPlanOpsElement := xmlElement.getElementByTagName("jobs");
		if jobLoadPlanOpsElement &lt;&gt; null then
			// get the job(s) than need to be created
			foreach obj in jobLoadPlanOpsElement.childNodes do
				xmlElement2 := obj.JadeXMLElement;
				
				foreach obj in xmlElement2.childNodes do
					xmlElement3 := obj.JadeXMLElement;
					
					
					
					if xmlElement3.tagName = "trackedItems" then
					
						codeStr := codeStr &amp; Tab &amp; 'slots.clear();' &amp; CrLf;
					
						foreach obj in xmlElement3.childNodes do
							// tracked item
							xmlElement4 := obj.JadeXMLElement;
							
							tiId := self.returnElementText(xmlElement4.getElementByTagName("id")).String;
							codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem(' &amp; tiId &amp; ');' &amp; CrLf &amp;
								Tab &amp; 'tiArray.add(ti);' &amp; CrLf;
							
							// get location to plan to
							location := self.returnElementText(xmlElement4.getElementByTagName("location")).String;
							bayId := location[1:2];
							codeStr := codeStr &amp; Tab &amp; 'slot := self.getJobLOLOControllerByID(voyage.code, "' &amp; bayId &amp; '", "' &amp; location &amp; '");' &amp; CrLf &amp;
								Tab &amp; 'slots.add(slot);' &amp; CrLf;
							
						endforeach;
						
						codeStr := codeStr &amp; Tab &amp; 'voyageJob := self.addVoyageJob(voyage, ' &amp; craneId &amp; ', slots, false);' &amp; CrLf &amp;
							Tab &amp; 'voyageJobArray.add(voyageJob);' &amp; CrLf;
						
						// delete any stops
						deleteStops := (xmlElement4.getElementByTagName("deleteStops") &lt;&gt; null).Boolean;
						
						// plan the items
						codeStr := codeStr &amp; Tab &amp; 'self.planTIsLOLO(tiArray, slots, voyage, ' &amp; deleteStops.String &amp; '.Boolean);' &amp; CrLf &amp; CrLf;
					
					elseif xmlElement3.tagName = "loadToJobOps" then
						codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
							Tab &amp; 'self.opts.addAssoc("JobsToSendToOps", voyageJobArray);' &amp; CrLf &amp;
							Tab &amp; 'self.loadAllJobsToOps(voyage, true);' &amp; CrLf &amp; CrLf;
					elseif xmlElement3.tagName = "queueFromJobOps" then
						codeStr := codeStr &amp; Tab &amp; 'wles.clear();' &amp; CrLf &amp;
							Tab &amp; 'foreach voyageJob in voyageJobArray do' &amp; CrLf &amp;
							Tab &amp; '    foreach request in voyageJob.allRequests do' &amp; CrLf &amp;
							Tab &amp; '      foreach wle in request.allWorkListEntries do' &amp; CrLf &amp;
							Tab &amp; '             delete moveController;' &amp; CrLf &amp;
							Tab &amp; '             create moveController transient;' &amp; CrLf &amp;
							Tab &amp; '             moveController.setMoveMode(QUEUE_MODE);' &amp; CrLf &amp;
							Tab &amp; '             moveController.setMyToPrimaryLocation(wle.myTrackedItem.myPrimaryPlannedLocation);' &amp; CrLf &amp;
							Tab &amp; '				beginTransaction;' &amp; CrLf &amp;
							Tab &amp; '             wle.doMoveToLocn(moveController, app.myPassport);' &amp; CrLf &amp;
							Tab &amp; '             commitTransaction;' &amp; CrLf &amp;
							//Tab &amp; '			wles.add(wle);' &amp; CrLf &amp;
							//Tab &amp; '		    self.queueWLE(wle);' &amp; CrLf &amp;
							Tab &amp; '		 endforeach;' &amp; CrLf &amp;
							Tab &amp; '    endforeach;' &amp; CrLf &amp;
							Tab &amp; 'endforeach;' &amp; CrLf;
					elseif xmlElement3.tagName = "crane" then
						craneId := self.returnElementText(xmlElement3).String;
						//codeStr := codeStr &amp; Tab &amp; 'voyageJob := self.addVoyageJob(voyage, ' &amp; craneId &amp; ', slots, true);' &amp; CrLf;
					endif;		
				endforeach;
			endforeach;		
		endif;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

	delete locationsArray;

end;</source>
        <Parameter name="_colorCodeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processMachineDelays" id="618fa2f8-99b8-436d-928b-5703d9b47623">
        <source>processMachineDelays(_voyageDelayXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the voyage delays

Date			Who		Reason
15/03/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	startTS					: String;
	machineCode				: String;
	
begin

	varsStr := "machine					: CM_Machine;" &amp; CrLf &amp; 
		Tab &amp; "terminal					: CM_Terminal;" &amp; CrLf &amp; CrLf;
				
	foreach obj in _voyageDelayXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		startTS := self.returnElementText(xmlElement.getElementByTagName("startTS")).String;
		machineCode := self.returnElementText(xmlElement.getElementByTagName("Machine")).String;
				
		// get the voyage
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"];' &amp; CrLf &amp;
			Tab &amp; 'machine := self.getMachine(' &amp; self.returnElementText(xmlElement.getElementByTagName("Machine")).String &amp; ');' &amp; CrLf &amp; 
			Tab &amp; 'self.assertNotNull(machine);' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'self.createMachineDelay(' &amp; startTS &amp; '.TimeStamp, machine);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_voyageDelayXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processMachineRules" id="60a25e68-00b8-465c-bcb9-1706cf6736f3">
        <source>processMachineRules(_machineRulesElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machine rules

Date			Who		Reason
24/02/2012		cnwmh5	Initial creation

*/

vars

	ruleElement				: JadeXMLElement;
	methodElement			: JadeXMLElement;
	methodsElement			: JadeXMLElement;
	queuingRuleElement		: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	ruleTypeAttribute		: JadeXMLAttribute;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	queuingRule				: String;
	moveMethod				: String;
	isDefault				: Boolean;
	tagNumber				: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'fromTA			: CM_TerminalAreaType;' &amp; CrLf &amp;
		Tab &amp; 'toTA				: CM_TerminalAreaType;' &amp; CrLf &amp;
		Tab &amp; 'multiRule		: CM_RTQueueMultiRule;' &amp; CrLf &amp;
		Tab &amp; 'realMultiRule	: CM_RTQueueMultiRule;' &amp; CrLf &amp;
		Tab &amp; 'moveMethod		: CM_RTMoveMethod;' &amp; CrLf &amp;
		Tab &amp; 'rule			: CM_RTMoveMethodRule;' &amp; CrLf &amp;
		Tab &amp; 'fromMA			: CM_TerminalAreaMaster;' &amp; CrLf &amp;
		Tab &amp; 'toMA			: CM_TerminalAreaMaster;' &amp; CrLf &amp;
		Tab &amp; 'terminal			: CM_Terminal;' &amp; CrLf &amp; CrLf;
	
	foreach obj in _machineRulesElement.childNodes do
		
		ruleElement := obj.JadeXMLElement;
		
		terminalAttribute := ruleElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"];' &amp; CrLf;
		
		ruleTypeAttribute := ruleElement.getAttributeByName("Type");
		
		optsElement := ruleElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(ruleElement.getElementByTagName('opts'), codeStr);
		else
			codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
			
		if ruleTypeAttribute.value.toUpper() = "Master".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'fromMA := terminal.allTerminalAreaMastersById[' &amp; self.returnElementText(ruleElement.getElementByTagName("fromArea")).String &amp; '];' &amp; CrLf &amp;
				Tab &amp; 'toMA := terminal.allTerminalAreaMastersById[' &amp; self.returnElementText(ruleElement.getElementByTagName("toArea")).String &amp; '];' &amp; CrLf &amp; CrLf &amp;
				Tab &amp; 'self.deleteMachineRule(fromMA, toMA);' &amp; CrLf &amp;
				Tab &amp; 'create multiRule as CM_RTQueueMultiRuleTAMaster transient;' &amp; CrLf &amp;
				Tab &amp; 'multiRule.CM_RTQueueMultiRuleTAMaster.setForProxyTAMaster(fromMA, toMA, terminal);' &amp; CrLf &amp; CrLf;
		elseif ruleTypeAttribute.value.toUpper() = "Type".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'fromTA := app.myRoot.allTerminalAreaTypes[' &amp; self.returnElementText(ruleElement.getElementByTagName("fromArea")).String &amp; '];' &amp; CrLf &amp;
				Tab &amp; 'toTA := app.myRoot.allTerminalAreaTypes[' &amp; self.returnElementText(ruleElement.getElementByTagName("toArea")).String &amp; '];' &amp; CrLf &amp; CrLf &amp;
				Tab &amp; 'self.deleteMachineRule(fromTA, toTA);' &amp; CrLf &amp;
				Tab &amp; 'create multiRule as CM_RTQueueMultiRuleTAType transient;' &amp; CrLf &amp;
				Tab &amp; 'multiRule.CM_RTQueueMultiRuleTAType.setForProxyTAType(fromTA, toTA, terminal);' &amp; CrLf &amp; CrLf;
		endif;
		
		methodsElement := ruleElement.getElementByTagName('Methods');
		foreach obj in methodsElement.childNodes do
			methodElement := obj.JadeXMLElement;
			
			tagNumber := methodElement.tagName[methodElement.tagName.length:end];
			
			moveMethod := self.returnElementText(methodElement.getElementByTagName("method")).String;
			moveMethod.cnReplaceString('"', '');
			isDefault := self.returnElementText(methodElement.getElementByTagName("isDefault")).Boolean;
			queuingRuleElement := methodElement.getElementByTagName("queuingRule");
			if queuingRuleElement = null then
				queuingRule := "null";
			else
				queuingRule := queuingRuleElement.text;
			endif;
		
			codeStr := codeStr &amp; Tab &amp; Tab &amp; 'moveMethod := app.myRoot.allRTMoveMethods[' &amp; moveMethod &amp; '];' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'create rule transient;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'rule.setProxy(multiRule, moveMethod, ' &amp; isDefault.String &amp; ', "", null, null, ' &amp; queuingRule &amp; ');' &amp; CrLf &amp; CrLf;
		
		endforeach;
				
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'app.myTrxCA.trxCreateRTQueueMultiRule(multiRule, realMultiRule, app.myPassport);' &amp; CrLf &amp; CrLf;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_machineRulesElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processMachines" id="b9b6b053-0f63-4b68-85be-1d785bc44e27">
        <source>processMachines(_machinesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machines

Date			Who		Reason
17/10/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	machineTypeElement		: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	machineTypeAttribute	: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	updateAttribute			: JadeXMLAttribute;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'cta						: CM_CraneTransferArea;' &amp; CrLf &amp;
		Tab &amp; 'cargoType					: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'contentStatus				: CM_ContentsStatus;' &amp; CrLf &amp;
		Tab &amp; 'machine						: CM_Machine;' &amp; CrLf &amp;
		Tab &amp; 'terminal						: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'terminalArea					: CM_TerminalArea;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'tas						: StringArray;' &amp; CrLf &amp;
		Tab &amp; 'strArray					: StringArray;' &amp; CrLf &amp; 
		Tab &amp; 'cargoTypeArray			: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'contStatDict			: CM_ContentsStatusByCodeDict;' &amp; CrLf &amp;
		Tab &amp; 'contentStatSet			: ObjectSet;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'str 						: String;' &amp; CrLf &amp;
		Tab &amp; 'count					: Integer;' &amp; CrLf;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create tas transient;' &amp; CrLf &amp;
		Tab &amp; 'create strArray transient;' &amp; CrLf &amp; 
		Tab &amp; 'create cargoTypeArray transient;' &amp; CrLf &amp;
		Tab &amp; 'create contStatDict transient;' &amp; CrLf &amp;
		Tab &amp; 'create contentStatSet transient;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'app.myRoot.allContentsStatuses.copy(contStatDict);' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp;
		Tab &amp; 'delete tas;' &amp; CrLf &amp;
		Tab &amp; 'delete strArray;' &amp; CrLf;
	
	foreach obj in _machinesXMLElement.childNodes do
		machineTypeElement := obj.JadeXMLElement;
		app.writeLog("Creating Machine " &amp; machineTypeElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Machine " &amp; machineTypeElement.tagName &amp; ".  Please wait...";
		
		optsElement := machineTypeElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(machineTypeElement.getElementByTagName('opts'), codeStr);
			// change machineLiftType to correct value
			codeStr := codeStr.replaceString('"MULTI_LIFT"', 'MULTI_LIFT');
			codeStr := codeStr.replaceString('"NORMAL_LIFT"', 'NORMAL_LIFT');
			codeStr := codeStr.replaceString('"TANDEM_LIFT"', 'TANDEM_LIFT');
			codeStr := codeStr.replaceString('"TWIN_LIFT"', 'TWIN_LIFT');
		endif;
		
		terminalAttribute := machineTypeElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"];' &amp; CrLf;
		
		// check to see if update 
		updateAttribute := machineTypeElement.getAttributeByName("Update");
		if updateAttribute &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'machine := app.myRoot.allMachines["' &amp; machineTypeElement.tagName &amp; '", terminal].CM_Machine;' &amp; CrLf &amp;  
				Tab &amp; '    if machine &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; '        self.updateMachine(machine);' &amp; CrLf &amp;
				Tab &amp; '    endif;' &amp; CrLf;
			continue;
		endif;
		
		machineTypeAttribute := machineTypeElement.getAttributeByName("MachineType");
		
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'tas.purge();' &amp; CrLf &amp; 
			Tab &amp; 'cargoTypeArray.clear();' &amp; CrLf &amp;
			Tab &amp; 'contentStatSet.clear();' &amp; CrLf &amp;
			Tab &amp; 'cta := null;' &amp; CrLf;
		
		// get crane transfer area for a crane
		xmlElement := machineTypeElement.getElementByTagName("CraneTransferArea");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'strArray.clear();' &amp; CrLf &amp;
				Tab &amp; 'str := ' &amp; self.returnElementText(machineTypeElement.getElementByTagName("CraneTransferArea")).String &amp; ';' &amp; CrLf &amp;
				Tab &amp; 'cta := self.getTerminalArea(str).CM_CraneTransferArea;' &amp; CrLf &amp;
				Tab &amp; 'if cta &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; Tab &amp; '		tas.add(cta.id);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	endif;' &amp; CrLf;
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("CraneTransferArea", cta);' &amp; CrLf;
		endif;
		
		// get terminal area
		xmlElement := machineTypeElement.getElementByTagName("terminalAreas");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'strArray.clear();' &amp; CrLf &amp;
				Tab &amp; 'tas.clear();' &amp; CrLf &amp;
				Tab &amp; 'str := ' &amp; self.returnElementText(machineTypeElement.getElementByTagName("terminalAreas")).String &amp; ';' &amp; CrLf &amp;
				Tab &amp; 'str.getTokensForDelimiter(";", strArray);' &amp; CrLf &amp;
				Tab &amp; 'foreach count in 1 to strArray.size step 1 do' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	terminalArea := self.getTerminalArea(strArray[count]);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	if terminalArea &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; Tab &amp; '		tas.add(terminalArea.id);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	endif;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf;
		endif;
		
		// get Cargo types
		xmlElement := machineTypeElement.getElementByTagName("cargoTypes");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'strArray.clear();' &amp; CrLf &amp;
				Tab &amp; 'cargoTypeArray.clear();' &amp; CrLf &amp;
				Tab &amp; 'str := ' &amp; self.returnElementText(machineTypeElement.getElementByTagName("cargoTypes")).String &amp; ';' &amp; CrLf &amp;
				Tab &amp; 'str.getTokensForDelimiter(";", strArray);' &amp; CrLf &amp;
				Tab &amp; 'foreach count in 1 to strArray.size step 1 do' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	cargoType := self.getCargoType(strArray[count]);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	if cargoType &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; Tab &amp; '		cargoTypeArray.add(cargoType);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	endif;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf;
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("CargoTypes", cargoTypeArray);' &amp; CrLf;
		endif;
		
		// get Content Statuses
		xmlElement := machineTypeElement.getElementByTagName("contentStatuses");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'strArray.clear();' &amp; CrLf &amp;
				Tab &amp; 'contentStatSet.clear();' &amp; CrLf &amp;
				Tab &amp; 'str := ' &amp; self.returnElementText(machineTypeElement.getElementByTagName("contentStatuses")).String &amp; ';' &amp; CrLf &amp;
				Tab &amp; 'str.getTokensForDelimiter(";", strArray);' &amp; CrLf &amp;
				Tab &amp; 'foreach count in 1 to strArray.size step 1 do' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	contentStatus := app.myRoot.allContentsStatuses[strArray[count].Integer].CM_ContentsStatus;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	if contentStatus &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; Tab &amp; '		contentStatSet.add(contentStatus);' &amp; CrLf &amp;
				Tab &amp; Tab &amp; '	endif;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf;
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("ContentStatuses", contentStatSet);' &amp; CrLf;
		endif;
		
		if machineTypeAttribute.value.toUpper() = "Crane".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'self.addCrane("' &amp; machineTypeElement.tagName &amp; '", ' &amp;
				self.returnElementText(machineTypeElement.getElementByTagName("deviceId")).String &amp; ', tas, null);' &amp; CrLf;
		elseif machineTypeAttribute.value.toUpper() = "ForkLift".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'self.addForkLift("' &amp; machineTypeElement.tagName &amp; '", ' &amp; 
				self.returnElementText(machineTypeElement.getElementByTagName("deviceId")).String &amp; ', tas, null);' &amp; CrLf;
		elseif machineTypeAttribute.value.toUpper() = "IMV".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'self.addIMV("' &amp; machineTypeElement.tagName &amp; '", ' &amp; 
				self.returnElementText(machineTypeElement.getElementByTagName("deviceId")).String &amp; ', tas, null);' &amp; CrLf;
		elseif machineTypeAttribute.value.toUpper() = "Straddle".toUpper() then
			codeStr := codeStr &amp; Tab &amp; 'self.addStraddle("' &amp; machineTypeElement.tagName &amp; '", ' &amp; 
				self.returnElementText(machineTypeElement.getElementByTagName("deviceId")).String &amp; ', tas, null);' &amp; CrLf;
		endif;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_machinesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processMoveCargo" id="67be8a56-7b41-4e18-98dc-3b67eebdc03d">
        <source>processMoveCargo(_moveCargoElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Move cargo to a specified location

Date			Who		Reason
13/11/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	targetLocElement		: JadeXMLElement;
	targetTypeAttrib		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	id						: String;
	targetLocation			: String;
	
begin
	
	varsStr := varsStr &amp; 'ti						: CM_TrackedItem;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	foreach obj in _moveCargoElements.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		// setup up any opts values
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
	
		// set the terminal
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		id := self.returnElementText(xmlElement.getElementByTagName("id")).String;
		
		// get the target location and type
		targetLocElement := xmlElement.getElementByTagName("targetLocation");
		targetLocation := self.returnElementText(targetLocElement).String;
		targetTypeAttrib := targetLocElement.getAttributeByName("TargetType");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TargetType", "' &amp; targetTypeAttrib.value &amp; '");' &amp; CrLf;
		
		// plan / queue / move the track item
		codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem(' &amp; id &amp; ');' &amp; CrLf &amp;
			Tab &amp; 'self.assertNotNull(ti);' &amp; CrLf;
				
		// move the tracked item
		codeStr := codeStr &amp; Tab &amp; 'self.move(ti, ' &amp; targetLocation &amp; ');' &amp; CrLf &amp; CrLf;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_moveCargoElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processOperators" id="83be0832-988b-476d-985b-38fefc38ae87">
        <source>processOperators(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	elementStateData		: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	requiresImportOpPIN		: Boolean;
	requiresBooking			: Boolean;
	requiresDeliveryRelease	: Boolean;
	requiresHumidity		: Boolean;
	requiresVentilation		: Boolean;
	requiresConsigneeor		: Boolean;
	bookingUniqueByNo		: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'configOperatorCMIF		: CMIF_ConfigOperator;' &amp; CrLf &amp;
		Tab &amp; 'operator					: CM_Operator;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'codeGroupsColl			: CM_CodeGroupsByTypeDict;' &amp; CrLf &amp;	
		Tab &amp; 'emailAddresses			: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete configOperatorCMIF;' &amp; CrLf &amp;		
		Tab &amp; 'delete codeGroupsColl;' &amp; CrLf &amp;
		Tab &amp; 'delete emailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create configOperatorCMIF transient;' &amp; CrLf &amp;
		Tab &amp; 'create codeGroupsColl transient;' &amp; CrLf &amp;
		Tab &amp; 'create emailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating Operator " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Operator " &amp; xmlElement.tagName &amp; ".  Please wait...";
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		requiresImportOpPIN := self.returnElementText(xmlElement.getElementByTagName('requiresImportOpPIN')).Boolean;
		requiresBooking	:= self.returnElementText(xmlElement.getElementByTagName('requiresBooking')).Boolean;
		requiresDeliveryRelease	:= self.returnElementText(xmlElement.getElementByTagName('requiresDeliveryRelease')).Boolean;
		requiresHumidity := self.returnElementText(xmlElement.getElementByTagName('requiresHumidity')).Boolean;
		requiresVentilation := self.returnElementText(xmlElement.getElementByTagName('requiresVentilation')).Boolean;
		requiresConsigneeor := self.returnElementText(xmlElement.getElementByTagName('requiresConsigneeConsignor')).Boolean;
		bookingUniqueByNo := self.returnElementText(xmlElement.getElementByTagName('bookingsUniqueByNo')).Boolean;
		
		codeStr := codeStr &amp; Tab &amp; 'operator := self.addOperator("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; 
			'", false, ' &amp; self.returnElementText(xmlElement.getElementByTagName('colour')).String &amp; 
			'.Integer, 0, null, ' &amp; self.returnElementText(xmlElement.getElementByTagName('displayTempFahrenheit')).Boolean.String &amp;
			', ' &amp; self.returnElementText(xmlElement.getElementByTagName('requiresBooking')).Boolean.String &amp; 
			', ' &amp; self.returnElementText(xmlElement.getElementByTagName('requiresCVC')).Boolean.String &amp; 
			', ' &amp; requiresConsigneeor.String &amp; ', ' &amp; requiresDeliveryRelease.String &amp; 
			', ' &amp; requiresHumidity.String &amp; ', false, ' &amp; requiresVentilation.String &amp; 
			', ' &amp; self.returnElementText(xmlElement.getElementByTagName('requiresVoyage')).Boolean.String &amp; 
			', false, null, null, codeGroupsColl, false, false, ' &amp; requiresImportOpPIN.String &amp; ', null, 
			emailAddresses,' &amp; self.returnElementText(xmlElement.getElementByTagName('ReeferWashExpiry')).String &amp;
			'.Integer, configOperatorCMIF, false, ' &amp; bookingUniqueByNo.Boolean.String &amp; ');' &amp; CrLf;
		
		// process state data
		elementStateData := xmlElement.getElementByTagName("StateData");
		if elementStateData &lt;&gt; null then
			self.processSetConfig(elementStateData, codeStr, 'operator');
		endif;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processOrganisations" id="29847323-0143-4f31-ba10-4b6a83a2ea6e">
        <source>processOrganisations(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required organisation	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		codeStr := codeStr &amp; Tab &amp; 'self.addOrganisation("' &amp; xmlElement.tagName &amp; '", true);' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processPrenotes" id="d50a1aba-2338-43d7-9ff6-a18e2b0e361a">
        <source>processPrenotes(_prenotesElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	prenoteElement			: JadeXMLElement;
	optsElement				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	element					: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'ti						: CM_TrackedItem;' &amp; CrLf &amp; 
		Tab &amp; 'booking	: CM_BookingRef;' &amp; CrLf &amp;
		Tab &amp; 'bookingItemRef : CM_BookingRefItem;' &amp; CrLf &amp;
		Tab &amp; 'obj : Object;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'bookingId				: String;' &amp; CrLf &amp;
		Tab &amp; 'bookingItemReq			: Integer;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'count 					: Integer;' &amp; CrLf &amp;
		Tab &amp; 'pos 					: Integer;' &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	foreach obj in _prenotesElement.childNodes do
		
		prenoteElement := obj.JadeXMLElement;
		app.writeLog("Creating Prenote " &amp; prenoteElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Prenote " &amp; prenoteElement.tagName &amp; ".  Please wait...";
		
		attribute := prenoteElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
				Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; attribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
				
				
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'ti := self.getTrackedItem("' &amp; prenoteElement.tagName &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf;
		
		optsElement := prenoteElement.getElementByTagName('opts');
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(optsElement, codeStr);
			attribute := prenoteElement.getAttributeByName("Terminal");
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
			
			element := optsElement.getElementByTagName("BookingItem");
			if element &lt;&gt; null then
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'bookingId := ' &amp; self.returnElementText(element).String &amp; ';' &amp; CrLf &amp;
					Tab &amp; 'pos := 1;' &amp; CrLf &amp;
					Tab &amp; 'pos := bookingId.pos(";", pos);' &amp; CrLf &amp;
					Tab &amp; 'if pos = 0 then' &amp; CrLf &amp;
					Tab &amp; '	bookingItemReq := 1;' &amp; CrLf &amp;
					Tab &amp; 'else' &amp; CrLf &amp;
					Tab &amp; '	bookingItemReq := bookingId[pos+1:end].Integer;' &amp; CrLf &amp;
					Tab &amp; '	bookingId := bookingId[1:pos-1];' &amp; CrLf &amp;
					Tab &amp; 'endif;' &amp; CrLf &amp;
					//Tab &amp; 'bookingItemReq := bookingId[pos+1:end].Integer;' &amp; CrLf &amp;
					//Tab &amp; 'bookingId := bookingId[1:pos-1];' &amp; CrLf &amp;
					Tab &amp; 'booking := self.getBooking(bookingId);' &amp; CrLf &amp;
					Tab &amp; 'count := 0;' &amp; CrLf &amp;
					Tab &amp; 'foreach obj in booking.allBookingRefItems do' &amp; CrLf &amp;
					Tab &amp;  '	count := count + 1;' &amp; CrLf &amp;
					Tab &amp; '	if count &gt;= bookingItemReq then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '		break;' &amp; CrLf &amp;
					Tab &amp; '	endif;' &amp; CrLf &amp;
					Tab &amp; 'endforeach;' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("BookingItem", obj.CM_BookingRefItem);' &amp; CrLf;
			endif;
		
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addPrenoted("' &amp; prenoteElement.tagName &amp; '");' &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_prenotesElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processPrinterDefs" id="598f5dfd-87e1-4bff-b394-a55103d2c141">
        <source>processPrinterDefs(_printerXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the preinter defs

Date			Who		Reason
07/02/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	nameAttribute			: JadeXMLAttribute;
	isPDFPrinter			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	foreach obj in _printerXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		nameAttribute := xmlElement.getAttributeByName("Name");
		isPDFPrinter := xmlElement.getElementByTagName("isPDFPrinter");
		
		codeStr := codeStr &amp; Tab &amp; 'self.addPrinterDef("' &amp; nameAttribute.value &amp; '", ' &amp; self.returnElementText(xmlElement.getElementByTagName("logicalPrinterName")).String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName("physicalPrinterName")).String &amp; ', ' &amp; (isPDFPrinter &lt;&gt; null).String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_printerXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processProducts" id="f9cc3cb5-933a-48db-b845-5bb4f469ac53">
        <source>processProducts(_productsXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the cargo Types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	cargoTypeStr			: String;
	handlingType			: String;
	operator				: String;
	code					: String;
	description				: String;
	storageCharge			: String;
	defaultCommodity		: String;
	
begin

	varsStr := 'obj				: Object;' &amp; CrLf &amp;
		Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'operator				: CM_Operator;' &amp; CrLf;

	codeStr := CrLf;
	
	create cargoTypesArray transient;
	
	foreach obj in _productsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating Product " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Product " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;	
		code.cnReplaceString('"', '');
		description := self.returnElementText(xmlElement.getElementByTagName('Description')).String;
		description.cnReplaceString('"', '');
		if description &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Description", "' &amp; description &amp; '");' &amp; CrLf;
		endif;
		
		handlingType := self.returnElementText(xmlElement.getElementByTagName('handlingType')).String;
		handlingType.cnReplaceString('"', '');
		if handlingType &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("HandlingType", ' &amp; handlingType &amp; ');' &amp; CrLf;
		endif;
				
		operator := self.returnElementText(xmlElement.getElementByTagName('operator')).String;
		if operator &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'operator := app.myRoot.allOperators[' &amp; operator &amp; '];' &amp; CrLf;
		endif;
		
		storageCharge := self.returnElementText(xmlElement.getElementByTagName('StorageCharge')).String;
		if storageCharge &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("StorageCharge", ' &amp; storageCharge.String &amp; '.Decimal);' &amp; CrLf;
		endif;
		//04/07/2018 jlgmh5 - Add Defautl Commodity
		defaultCommodity := self.returnElementText(xmlElement.getElementByTagName('DefaultCommodity')).String;
		if defaultCommodity &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("DefaultCommodity", ' &amp; defaultCommodity.String &amp; ');' &amp; CrLf;
		endif;
		
		cargoTypeStr := self.returnElementText(xmlElement.getElementByTagName('cargoType')).String;
		if cargoTypeStr &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'cargoType := null;' &amp; CrLf &amp; 
				Tab &amp; 'foreach obj in app.myRoot.allCargoTypesById discreteLock do' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'if obj.CM_CargoType.abbreviation &lt;&gt; ' &amp; cargoTypeStr &amp; ' then' &amp; CrLf &amp; 
				Tab &amp; Tab &amp; Tab &amp; 'continue;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'cargoType := obj.CM_CargoType;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'break;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addProduct("' &amp; code &amp; '", operator, cargoType); ' &amp; CrLf &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_productsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRFIDTags" id="795817e1-c669-4c58-9113-cbe30ebf0cbb">
        <source>processRFIDTags(_rfidTagsXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the RFID Tags

Date			Who		Reason
10/11/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	termAttribute			: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	code					: String;
	description				: String;
	serialNumber			: String;
	remarks					: String;
	isAvailable				: Boolean;
	
begin

	foreach obj in _rfidTagsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		// get the terminal
		termAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp; 
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; termAttribute.value &amp; '");' &amp; CrLf;
			
		code := self.returnElementText(xmlElement.getElementByTagName("code")).String;
		description := self.returnElementText(xmlElement.getElementByTagName("description")).String;
		serialNumber := self.returnElementText(xmlElement.getElementByTagName("serialNumber")).String;
		if serialNumber.length = 0 then
			serialNumber := '""';
		endif;
		remarks := self.returnElementText(xmlElement.getElementByTagName("remarks")).String;
		if remarks.length = 0 then
			remarks := '""';
		endif;
		isAvailable := self.returnElementText(xmlElement.getElementByTagName("isAvailable")).Boolean;		
		
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("description", ' &amp; description &amp; ');' &amp; CrLf &amp;  
			Tab &amp; 'self.opts.addAssoc("remarks", ' &amp; remarks &amp; ');' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("isAvailable", ' &amp; isAvailable.String &amp; ');' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addRFIDTag(' &amp; code &amp; ', ' &amp; serialNumber &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_rfidTagsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRTDevices" id="48fbcae2-e4b9-45aa-b3a0-4218b1ab6498">
        <source>processRTDevices(_rtDevicesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machines

Date			Who		Reason
31/01/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	isPasswordCompulsary	: Boolean;
	useSerialConnection		: Boolean;
	useLocalTCP				: Boolean;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'machine				: CM_Machine;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'isPasswordCompulsary		: Boolean;' &amp; CrLf &amp;
		Tab &amp; 'useSerialConnection		: Boolean;' &amp; CrLf &amp;
		Tab &amp; 'useLocalTCP				: Boolean;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf;
	
	foreach obj in _rtDevicesXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating RT Devices " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating RT Devices " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		optsElement := xmlElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		else	
			codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
		endif;
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp; 
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		xmlElement2 := xmlElement.getElementByTagName("IsPasswordCompulsary");
		isPasswordCompulsary := xmlElement2 &lt;&gt; null;
		
		xmlElement2 := xmlElement.getElementByTagName("UseSerialConnection");
		useSerialConnection := xmlElement2 &lt;&gt; null;
		
		xmlElement2 := xmlElement.getElementByTagName("UseLocalTCP");
		useLocalTCP := xmlElement2 &lt;&gt; null;
		
		xmlElement2 := xmlElement.getElementByTagName("Machine");
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"];' &amp; CrLf &amp;
				Tab &amp; 'machine := self.getMachine(' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addRTDevice(' &amp; self.returnElementText(xmlElement.getElementByTagName("Type")).String &amp; ', "' &amp; 
			self.returnElementText(xmlElement.getElementByTagName("Id")).String &amp; '", ' &amp;
			self.returnElementText(xmlElement.getElementByTagName("Model")).String &amp; ', ' &amp;
			self.returnElementText(xmlElement.getElementByTagName("ComputerName")).String &amp; ', machine, ' &amp;
			isPasswordCompulsary.String &amp; '.Boolean, ' &amp; useSerialConnection.String &amp; '.Boolean, ' &amp;
			useLocalTCP.String &amp; '.Boolean);' &amp; CrLf &amp; CrLf;
			
		codeStr := codeStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_rtDevicesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRTQueues" id="c8869680-f575-410b-a28e-944fe30685f2">
        <source>processRTQueues(_rtQueuesElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required Radio Telemetry Queues
Date			Who		Reason
18/10/2017		jlgmh5	Initial creation

*/

vars

	element					: JadeXMLElement;
	queueElement			: JadeXMLElement;
	uniDirElement			: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
		
	obj						: Object;
	queue					: CM_RadioTelemetryQueue;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	name					: String;
	allowedMachines			: String;
	queueType				: String;
		
begin

	varsStr := CrLf &amp; Tab &amp; 'terminalArea			: CM_TerminalArea;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'voyage					: CM_Voyage;' &amp; CrLf &amp;
		Tab &amp; 'crane					: CM_Crane;' &amp; CrLf &amp;
		Tab &amp; 'queue					: CM_RadioTelemetryQueue;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'tokens					: StringArray;' &amp; CrLf &amp; 
		Tab &amp; 'toAreasArray							: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'fromAreasArray							: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'allAllowedMachineGroupTypes			: IntegerArray;' &amp; CrLf &amp;CrLf &amp;
		Tab &amp; 'str				: String;' &amp; CrLf &amp; 
		Tab &amp; 'isUniDirectional : Boolean;' &amp; CrLf &amp;
		Tab &amp; 'isVoyageSubQueue	: Boolean;' &amp; CrLf &amp;
		Tab &amp; 'count			: Integer;' &amp; CrLf &amp; CrLf;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create tokens transient;' &amp; CrLf &amp; 
		Tab &amp; 'create toAreasArray transient;' &amp; CrLf &amp;
		Tab &amp; 'create fromAreasArray transient;' &amp; CrLf &amp;
		Tab &amp; 'create allAllowedMachineGroupTypes transient;' &amp; CrLf &amp; CrLf;
	
	epilogStr := 'delete tokens;' &amp; CrLf &amp; 
		Tab &amp; 'delete toAreasArray;' &amp; CrLf &amp;
		Tab &amp; 'delete fromAreasArray;' &amp; CrLf &amp;
		Tab &amp; 'delete allAllowedMachineGroupTypes;' &amp; CrLf;

	foreach obj in _rtQueuesElement.childNodes do
		queueElement := obj.JadeXMLElement;
		
		name := self.returnElementText(queueElement.getElementByTagName("name")).String;
		app.writeLog("Creating Radio Telementry Queue " &amp; name &amp; ".  Please wait...", LogINFO);
		write "Creating Radio Telementry Queue " &amp; name &amp; ".  Please wait...";
		
		terminalAttribute := queueElement.getAttributeByName("Terminal");
		uniDirElement := queueElement.getElementByTagName("UniDirectional");
		
		codeStr := codeStr &amp; Tab &amp; 'fromAreasArray.clear();' &amp; CrLf &amp; 
			Tab &amp; 'toAreasArray.clear();' &amp; CrLf &amp; CrLf;
		
		optsElement := queueElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals[ "' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		// get From areas
		element := queueElement.getElementByTagName("fromAreasArray");
		if element &lt;&gt; null then
			self.returnArrayDetails(element, 'allTerminalAreas', 'getTerminal()', codeStr);
		endif;
				
		// get to areas
		element := queueElement.getElementByTagName("toAreasArray");
		if element &lt;&gt; null then
			self.returnArrayDetails(element, 'allTerminalAreas', 'getTerminal()', codeStr);
		endif;
		
		// get parent queue if other than Master Queue
		element := queueElement.getElementByTagName("ParentQueue");
		codeStr := codeStr &amp; Tab &amp; 'isVoyageSubQueue := false;' &amp; CrLf;
		if element &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'str := "' &amp; self.returnElementText(queueElement.getElementByTagName("ParentQueue")).String &amp; '";' &amp; CrLf &amp;
				Tab &amp; 'queue := self.getQueue(str);' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("ParentQueue", queue);' &amp; CrLf &amp; 
				Tab &amp; 'if queue.isKindOf(CM_VoyageQueue) then' &amp; CrLf &amp;
				Tab &amp; '    isVoyageSubQueue := true;' &amp; CrLf &amp;
				Tab &amp; 'endif;' &amp; CrLf;
			queue := self.getQueue(self.returnElementText(queueElement.getElementByTagName("ParentQueue")).String);
		else
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; Tab &amp; 'queue := self.getQueue("Master");' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("ParentQueue", queue);' &amp; CrLf;
			queue := self.getQueue("Master");
		endif;
	
		// allowed machine
		allowedMachines := self.returnElementText(queueElement.getElementByTagName("AllowedMachineTypeGrp")).String;
		if allowedMachines = '""' then
			allowedMachines := '';
		endif;
		if allowedMachines.length &gt; 0 then 
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("AllowedMachineTypeGrp", ' &amp; allowedMachines &amp; '.String);' &amp; CrLf &amp; CrLf;
		endif;
		
		// get the type of queue to create
		queueType := QTYPE_MASTER.String;
		if optsElement &lt;&gt; null then
			queueType := self.returnElementText(optsElement.getElementByTagName("queueType")).String;
		endif;
		
		// create the queue
		if queueType = "QTYPE_VOYAGE" then
			codeStr := codeStr &amp; Tab &amp; 'voyage := self.getVoyage(' &amp; self.returnElementText(queueElement.getElementByTagName('voyage')).String &amp; ').CM_Voyage;' &amp; CrLf &amp;
				Tab &amp; 'self.addVoyageQueue(voyage);' &amp; CrLf &amp; CrLf;
		elseif queueType = "QTYPE_CRANE" and queue &lt;&gt; null and queue.isKindOf(CM_VoyageQueue) then
			codeStr := codeStr &amp; Tab &amp; 'voyage := queue.CM_VoyageQueue.myVoyage;' &amp; CrLf &amp;
				Tab &amp; 'crane := self.getTerminal().machines["' &amp; self.returnElementText(queueElement.getElementByTagName("crane")).String &amp; '"].CM_Crane;' &amp; CrLf &amp;
				Tab &amp; 'self.addVoyageCraneQueue(voyage, queue.CM_VoyageQueue, crane);' &amp; CrLf &amp; CrLf;
		else
			codeStr := codeStr &amp; Tab &amp; 'self.addQueue(' &amp; name &amp; ', fromAreasArray, toAreasArray, ' &amp; (uniDirElement &lt;&gt; null).String &amp; ');' &amp; CrLf &amp; CrLf;		
		endif;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_rtQueuesElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processReefConDisconnect" id="ce40f539-01fb-4784-88e3-e56dd4595789">
        <source>processReefConDisconnect(_reefConDisconXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Connect / Disconnect Reefers

Date			Who		Reason
16/03/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	ts						: String;
	isDisconnect			: Boolean;
	charge					: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'cont		: CM_Container;' &amp; CrLf &amp; 
		Tab &amp; 'terminal				: CM_Terminal;' &amp; CrLf &amp; CrLf;	
	
	
	foreach obj in _reefConDisconXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		self.setupOptsAssoc(optsElement, codeStr);
	
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		isDisconnect := (xmlElement.getAttributeByName("Disconnect") &lt;&gt; null);
		charge := (xmlElement.getElementByTagName("Charge") &lt;&gt; null);
		
		ts := self.returnElementText(xmlElement.getElementByTagName("DateTime")).String;
		
		codeStr := codeStr &amp; Tab &amp; 'cont := self.getTrackedItem("' &amp; xmlElement.tagName &amp; '").CM_Container;' &amp; CrLf &amp; 
			Tab &amp; 'self.assertNotNull(cont);' &amp; CrLf &amp;
			Tab &amp; 'self.updateTIConnection(cont, ' &amp; charge.String &amp; '.Boolean, ' &amp; (not isDisconnect).String &amp; 
				'.Boolean, ' &amp; ts &amp; '.TimeStamp, null);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_reefConDisconXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processReleaseRequests" id="63815a82-5e17-4f6f-9911-f875ac2f0ebc">
        <source>processReleaseRequests(_releaseRequestXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machines

Date			Who		Reason
17/10/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	requestLineElements		: JadeXMLElement;
	releaseRequestElement	: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	releaseNo				: String;
	releaseType				: Integer;
	cargoType				: String;
	isoType					: String;
	isoGroup				: String;
	totalRequested			: String;
	operator				: String;
	tempStr					: String;
	releaseByTypeSet		: Boolean;
		
begin
	
	varsStr := varsStr &amp; 'pxyReleaseRequest		: CM_BulkRelease;' &amp; CrLf &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'delete pxyReleaseRequest;' &amp; CrLf;
	
	
	foreach obj in _releaseRequestXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		releaseNo := self.returnElementText(xmlElement.getElementByTagName("releaseNo")).String;
		
		codeStr := codeStr &amp; Tab &amp; 'delete pxyReleaseRequest;' &amp; CrLf &amp;
			Tab &amp; 'create pxyReleaseRequest transient;' &amp; CrLf &amp; CrLf;
		
		// create release line (ByType) or add cargo Id (ByID)
		releaseByTypeSet := false;
		requestLineElements := xmlElement.getElementByTagName("requestlines");
		if requestLineElements &lt;&gt; null then
			foreach obj in requestLineElements.childNodes do
				releaseRequestElement := obj.JadeXMLElement;
				
				cargoType := self.returnElementText(releaseRequestElement.getElementByTagName("CargoType")).String;
				isoType := self.returnElementText(releaseRequestElement.getElementByTagName("isoType")).String;
				if isoType.cnIsNumericAndNotNegative() then
					isoType := '"' &amp; isoType &amp; '"';
				endif;
				isoGroup := self.returnElementText(releaseRequestElement.getElementByTagName("isoGroup")).String;
				totalRequested := self.returnElementText(releaseRequestElement.getElementByTagName("totalRequested")).String;
				
				if not cargoType.isInteger() then
					cargoType := cargoType.replaceString('"', '');
					cargoType := self.getCargoType(cargoType).id.String;
				endif;
				
				codeStr := codeStr &amp; Tab &amp; 'self.addReleaseRequestByTypeLine(' &amp; releaseNo &amp; ', ' &amp; cargoType.String &amp; '.Integer, ' &amp;
					isoType &amp; ', ' &amp; isoGroup &amp; ', ' &amp; totalRequested.String &amp; '.Integer, pxyReleaseRequest);' &amp; CrLf;
			endforeach;		
			if not releaseByTypeSet then
				releaseByTypeSet := true;
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("ReleaseByType", true);' &amp; CrLf;
			endif;
		else
			// By Id
		
		endif;
		
		// create the Release Request
		tempStr := self.returnElementText(xmlElement.getElementByTagName("releaseType")).String;
		releaseType := tempStr.asIntegerJMT();
		operator := self.returnElementText(xmlElement.getElementByTagName("operator")).String;
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.addReleaseRequest(' &amp; releaseNo &amp; ', ' &amp; releaseType.String &amp; ', ' &amp; 
			operator &amp; ', pxyReleaseRequest);' &amp; CrLf &amp; CrLf;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_releaseRequestXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRootMisc" id="a7bde53b-4afa-4d16-9634-e996ae1cc4bc">
        <source>processRootMisc();

/*

Purpose:		Do any root miscellaneous stuff

Date			Who		Reason
09/03/2012		cnwmh5	Initial creation

*/

vars
	hookLink				: CM_HookLink;
begin

	beginTransaction;
	app.myRoot.setPropertyValue("myWagonClassHookCode", app.myRoot.allHookCodes["Fonterra", false]);
	
	foreach hookLink in app.myRoot.allHookLinks do
		if hookLink.hookType = 10 then
			hookLink.setPropertyValue("myRoot", app.myRoot);
		endif;
	endforeach;
	commitTransaction;

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="processSecurityRoles" id="19ee14c3-50c7-42d7-9187-ecc4f782a898">
        <source>processSecurityRoles(_secRoleXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the security roles

Date			Who		Reason
09/11/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	parentRoleElement		: JadeXMLElement;
	permissionElements		: JadeXMLElement;
	nameAttribute			: JadeXMLAttribute;
	systemSecRole			: JadeXMLAttribute;
	obj						: Object;
	
	permToSetArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	varsStr := varsStr &amp; Tab &amp; 'securityRole			: CM_SecurityRole;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'permToSetArray				: StringArray;' &amp; CrLf &amp; CrLf;

	codeStr := codeStr &amp; Tab &amp; 'create permToSetArray transient;' &amp; CrLf &amp; CrLf;
	
	epilogStr := epilogStr &amp; Tab &amp; 'delete permToSetArray;' &amp; CrLf;
	
	foreach obj in _secRoleXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		nameAttribute := xmlElement.getAttributeByName("Name");
		systemSecRole := xmlElement.getAttributeByName("SystemRole");
		
		if systemSecRole &lt;&gt; null then
			app.writeLog("Creating Terminal Security Role " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
			write "Creating Terminal Security Role " &amp; xmlElement.tagName &amp; ".  Please wait...";
		else
			app.writeLog("Creating System Security Role " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
			write "Creating System Security Role " &amp; xmlElement.tagName &amp; ".  Please wait...";
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp; CrLf;
		
		// get the parent role if specified
		parentRoleElement := xmlElement.getElementByTagName("ParentRole");
		if parentRoleElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'securityRole := app.myRoot.allRoles[' &amp; self.returnElementText(parentRoleElement).String &amp; '];' &amp; CrLf &amp;
				Tab &amp; 'self.assertNotNull(securityRole);' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("ParentRole", securityRole);' &amp; CrLf &amp; CrLf;
		endif;
		
		
		// get the permissions we want to set
		codeStr := codeStr &amp; Tab &amp; 'permToSetArray.clear();' &amp; CrLf;
		permissionElements := xmlElement.getElementByTagName("Permissions");
		if permissionElements &lt;&gt; null then
			foreach obj in permissionElements.childNodes do
				xmlElement2 := obj.JadeXMLElement;
				foreach obj in xmlElement2.childNodes do
					codeStr := codeStr &amp; Tab &amp; 'permToSetArray.add("' &amp; obj.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
				endforeach;
			endforeach;
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("PermissionsToSet", permToSetArray);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addSecurityRole(' &amp; (systemSecRole &lt;&gt; null).String &amp; ', "' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

	delete permToSetArray;

end;
</source>
        <Parameter name="_secRoleXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSetConfig" id="dcaae383-58f4-46f7-9a52-70b2da64b630">
        <source>processSetConfig(_xmlElement : JadeXMLElement; _codeStr : String io; _typeStr : String);

/*

Purpose:		Create the setConfig lines

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	element					: JadeXMLElement;
	obj						: Object;
	attribute				: JadeXMLAttribute;

	text					: String;
	
begin
	
	_codeStr := _codeStr &amp; Tab &amp; 'if ' &amp; _typeStr &amp; ' &lt;&gt; null then' &amp; CrLf &amp; 
		Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
	
	
	foreach obj in _xmlElement.childNodes do
		element := obj.JadeXMLElement;
		
		text := self.returnElementText(element).String;
		
		attribute := element.getAttributeByName("Type");
		if attribute &lt;&gt; null then
			text := text &amp; '.' &amp; attribute.value;
		endif;
		
		if element.tagName = "SpecialCharacter" or (attribute = null and text.cnIsNumeric()) then
			text := "'" &amp; text &amp; "'";
		endif;
	
		_codeStr := _codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; element.tagName &amp; '", ' &amp; text &amp; ');' &amp; CrLf;
	
	endforeach;
	
	_codeStr := _codeStr &amp; Tab &amp; Tab &amp; 
		Tab &amp; "commitTransaction;" &amp; CrLf &amp;
		Tab &amp; "endif;" &amp; CrLf;
	
epilog

end;
</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
        <Parameter name="_typeStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="processShippingLines" id="b496c970-1633-433d-a052-fe28bb9e1913">
        <source>processShippingLines(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required shipping lines	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	code					: String;
	
begin
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		codeStr := codeStr &amp; Tab &amp; 'self.addShippingLine(' &amp; code &amp; ', ' &amp; description &amp; ', false);' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSpecialStows" id="2c082366-9468-469c-972b-b3794ae0a8ef">
        <source>processSpecialStows(_specialStowElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
24/10/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin
	
	foreach obj in _specialStowElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		self.setupOptsAssoc(xmlElement.getElementByTagName("opts"), codeStr);
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.addSpecialStow("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName("description")).String &amp; ');' &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_specialStowElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processStops" id="0ad2ed90-c98d-4dbf-a59f-ef6207cadcb9">
        <source>processStops(_stopXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the stops

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	stopsTableElement		: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	selectedCargoArray		: StringArray;
	processAreasArray		: StringArray;
	stopsAreaArray			: StringArray;
	
	code					: String;	
	id	 					: Integer;
	heading					: String;
	selectedCargo			: String;
	str						: String;
	stopsArea				: String;
	processArea				: String;
	requiresInfo 			: Boolean;
	customsInfoEntry 		: String; 
	setupStopTemplate 		: Boolean; 
	allowClearanceExpiryDate : Boolean; 
	isMT					: Boolean;
	isFull					: Boolean;
	
begin

	varsStr := 'selectedTypes		: CM_CargoBOLTypeSet;' &amp; CrLf &amp;
		Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'processAreas		: IntegerArray;' &amp; CrLf &amp;
		Tab &amp; 'setStopsAreas		: IntegerArray;' &amp; CrLf &amp; 
		Tab &amp; 'opts			: CM_AssociationDict;' &amp; CrLf;

	codeStr := 'create selectedTypes transient;' &amp; CrLf &amp;
		Tab &amp; 'create processAreas transient;' &amp; CrLf &amp;
		Tab &amp; 'create setStopsAreas transient;' &amp; CrLf &amp; 
		Tab &amp; 'create opts transient;' &amp; CrLf &amp; CrLf;
		
	epilogStr := 'delete processAreas;' &amp; CrLf &amp; 
		Tab &amp; 'delete setStopsAreas;' &amp; CrLf &amp;
		Tab &amp; 'delete selectedTypes;' &amp; CrLf &amp;
		Tab &amp; 'delete opts;';
		
	create selectedCargoArray transient;
	create stopsAreaArray transient;
	create processAreasArray transient;
	
	foreach obj in _stopXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		id := self.returnElementText(xmlElement.getElementByTagName('id')).Integer;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		heading := self.returnElementText(xmlElement.getElementByTagName('heading')).String;

		codeStr := codeStr &amp; Tab &amp; 'opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.deleteStopsTable(' &amp; id.String &amp; ');' &amp; CrLf &amp; CrLf &amp;
			Tab &amp; 'selectedTypes.clear();' &amp; CrLf;
				
		selectedCargo := self.returnElementText(xmlElement.getElementByTagName('selectedCargo')).String;
		selectedCargo.cnReplaceString('"', '');
		selectedCargoArray.clear();
		selectedCargo.getTokensForDelimiter(';', selectedCargoArray);
		foreach str in selectedCargoArray do
			
			codeStr := codeStr &amp; Tab &amp; 'cargoType := self.getCargoType("' &amp; str &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'if not selectedTypes.includes(cargoType) then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; '	selectedTypes.add(cargoType);' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
			//codeStr := codeStr &amp; Tab &amp; 'if not selectedTypes.includes(app.myRoot.allCargoTypesById[' &amp; str &amp; ']) then' &amp; CrLf &amp;
			//	Tab &amp; Tab &amp; 'selectedTypes.add(self.getCargoType(' &amp; str &amp; ');' &amp; CrLf &amp; 
			//	Tab &amp; 'endif;' &amp; CrLf;
		endforeach;
		
		stopsTableElement := xmlElement.getElementByTagName('StopsTable');
		if stopsTableElement &lt;&gt; null then
	
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", ' &amp; 
				self.returnElementText(stopsTableElement.getElementByTagName('terminal')).String &amp; ');' &amp; CrLf;
		
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'setStopsAreas.clear();' &amp; CrLf;
			stopsArea := self.returnElementText(stopsTableElement.getElementByTagName('stopsArea')).String;
			stopsArea.cnReplaceString('"', '');
			stopsAreaArray.clear();
			stopsArea.getTokensForDelimiter(';', stopsAreaArray);
			foreach str in stopsAreaArray do
				codeStr := codeStr &amp; Tab &amp; 'if not setStopsAreas.includes(' &amp; str &amp; ') then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'setStopsAreas.add(' &amp; str &amp; ');' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf &amp; 
					Tab &amp; 'opts.addAssoc(ETRow_SetStopAreas, setStopsAreas);' &amp; CrLf;
			endforeach;
			
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'processAreas.clear();' &amp; CrLf;
			processArea := self.returnElementText(stopsTableElement.getElementByTagName('processArea')).String;
			processArea.cnReplaceString('"', '');
			processAreasArray.clear();
			processArea.getTokensForDelimiter(';', processAreasArray);
			foreach str in processAreasArray do
				codeStr := codeStr &amp; Tab &amp; 'if not processAreas.includes(' &amp; str &amp; ') then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'processAreas.add(' &amp; str &amp; ');' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf &amp; 
					Tab &amp; 'opts.addAssoc(ETRow_ProcessStopAreas, processAreas);' &amp; CrLf;
			endforeach;
			
			codeStr := codeStr &amp; CrLf;
			
			requiresInfo := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_RequiresInfo')).Boolean;
			if requiresInfo &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_RequiresInfo, ' &amp; requiresInfo.String &amp; ');' &amp; CrLf;
			endif;
			customsInfoEntry := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_CustomsInfoEntry')).String;
			customsInfoEntry.cnReplaceString('"', '');
			if customsInfoEntry &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_CustomsInfoEntry, ' &amp; customsInfoEntry &amp; ');' &amp; CrLf;
			endif;
			setupStopTemplate := self.returnElementText(stopsTableElement.getElementByTagName('setupStopTemplate')).Boolean;
			if setupStopTemplate &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc("SetupStopTemplate", ' &amp; setupStopTemplate.String &amp; ');' &amp; CrLf;
			endif;
			allowClearanceExpiryDate := self.returnElementText(stopsTableElement.getElementByTagName('allowClearanceExpiryDate')).Boolean;
			if allowClearanceExpiryDate &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_AllowClearanceExpiryDate, ' &amp; allowClearanceExpiryDate.String &amp; ');' &amp; CrLf;
			endif;
			isMT := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_IsMT')).Boolean;
			if isMT then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_IsMT, ' &amp; isMT.String &amp; ');' &amp; CrLf;
			endif;
			isFull := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_IsFull')).Boolean;
			if isFull then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_IsFull, ' &amp; isFull.String &amp; ');' &amp; CrLf;
			endif;
		
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addStopsTable(' &amp; id.String &amp; ', ' &amp; code &amp; ', ' &amp; heading &amp; ', selectedTypes, opts);' &amp; CrLf &amp; CrLf;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete selectedCargoArray;
	delete stopsAreaArray;
	delete processAreasArray;
end;
</source>
        <Parameter name="_stopXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSubTerminalCreate" id="7589b549-2766-4209-82aa-124193f5bcc4">
        <source>processSubTerminalCreate(_terminalXMLElement : JadeXMLElement; _codeStr : String io);

/*

Purpose:		Create / Add required sub terminals	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	
begin
	
	foreach obj in _terminalXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		text := self.returnElementText(xmlElement).String;
		text.cnReplaceString('"', '');
		_codeStr := _codeStr &amp; Tab &amp; Tab &amp; 'self.deleteSubTerminal("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf;
		_codeStr := _codeStr &amp; Tab &amp; Tab &amp; 'self.addSubTerminal("' &amp; xmlElement.tagName &amp; '", ' &amp; text &amp; ');' &amp; CrLf;	
	endforeach;
		
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSubTerminal_OLD" id="76a5f085-4589-49a7-8c0b-31ff9480e918">
        <source>processSubTerminal_OLD(_subTerminalElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal sub terminals

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	elementSubTerm			: JadeXMLElement;
	termElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	beginTWritten			: Boolean;
	description				: String;
	isSubTerminalOnSet		: Boolean;
		
begin

	varsStr := 'terminal			: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'warehouseST		: CM_SubTerminal;' &amp; CrLf &amp;
		Tab &amp; 'depotST			: CM_SubTerminal;' &amp; CrLf &amp;
		Tab &amp; 'marineST			: CM_SubTerminal;' &amp; CrLf &amp; CrLf;
	
	foreach obj in _subTerminalElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		write 'xmlElement: ' &amp; xmlElement.tagName;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp;'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf;

		foreach obj in xmlElement.childNodes do
			termElement := obj.JadeXMLElement;
			write Tab &amp; 'termElement: ' &amp; termElement.tagName;
		
			if termElement.tagName.toUpper() = 'Create'.toUpper() then
				foreach obj in termElement.childNodes do
					elementSubTerm := obj.JadeXMLElement;
					write Tab &amp; Tab &amp; 'elementSubTerm: ' &amp; elementSubTerm.tagName;
					
					description := self.returnElementText(elementSubTerm.getElementByTagName("description")).String;
					description.cnReplaceString('"', '');
					if description.length &gt; 0 then
						codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("description", "' &amp; description &amp; '");' &amp; CrLf;
					endif;
					text := self.returnElementText(elementSubTerm.getElementByTagName("type")).String;
					text.cnReplaceString('"', '');
					codeStr := codeStr &amp; Tab &amp; 'self.addSubTerminal("' &amp; elementSubTerm.tagName &amp; '", ' &amp; text &amp; ');' &amp; CrLf &amp;
						Tab &amp; 'self.opts.removeAssoc("description");' &amp; CrLf &amp; CrLf;
				endforeach;
			elseif termElement.tagName.toUpper() = 'depotST'.toUpper() or termElement.tagName.toUpper = 'warehouseST'.toUpper() or 
					termElement.tagName.toUpper = 'marineST'.toUpper() then
				if not beginTWritten then
					codeStr := codeStr &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
					beginTWritten := true;
				endif;
				codeStr := codeStr &amp; Tab &amp; termElement.tagName &amp; ' := app.myRoot.allSubTerminals[' &amp; 
					self.returnElementText(termElement).String &amp; '];' &amp; CrLf;
			elseif termElement.tagName.toUpper()[1:5] = "MySub".toUpper() then
				text := self.returnElementText(termElement).String;
				text.cnReplaceString('"', '');
				codeStr := codeStr &amp; Tab &amp; 'terminal.setConfig(' &amp; termElement.tagName &amp; ', ' &amp; 
					text &amp; ');' &amp; CrLf;
				if not isSubTerminalOnSet then
					codeStr := codeStr &amp; Tab &amp; 'terminal.setConfig(IsSubTerminalsOn, true);' &amp; CrLf;
					isSubTerminalOnSet := true;
				endif;
			endif;
			
		endforeach;
		
		if beginTWritten then
			codeStr := codeStr &amp; Tab &amp; "commitTransaction;" &amp; CrLf &amp; CrLf;
			beginTWritten := false;
		endif;
		
		isSubTerminalOnSet := false;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_subTerminalElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSubTerminals" id="ec0d3808-056e-4283-ad70-05fbed88463b">
        <source>processSubTerminals(_subTerminalElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal sub terminals

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	foreach obj in _subTerminalElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		write 'xmlElement: ' &amp; xmlElement.tagName;
		
		optsElement := xmlElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		else	
			codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
		endif;
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
	
		codeStr := codeStr &amp; Tab &amp; 'self.addSubTerminal(' &amp; self.returnElementText(xmlElement.getElementByTagName("code")).String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName("type")).String &amp; '.Integer);' &amp; CrLf &amp; CrLf;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_subTerminalElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystem" id="0f831dd0-09ff-4121-9983-6400c9ecc101">
        <source>processSystem(_systemXMLElement : JadeXMLElement);

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement		: JadeXMLElement;
	obj				: Object;
	
	methodStr		: String;
	
begin

	foreach obj in _systemXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		methodStr := self.MethodString;
		
		if xmlElement.tagName.toUpper() = "SetConfig".toUpper() then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "SystemSetConfig");
			self.processSystemSetConfig(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "CargoTypes".toUpper then   // has to be after terminal
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "SetupCargoTypes");
			self.processSystemCargoTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "UpdateCargoTypes".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "UpdateCargoTypes");
			self.processUpdateCargoTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Products".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Products");
			self.processProducts(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Ports".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Ports");
			self.processSystemPorts(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Operator".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Operator");
			self.processSystemOperators(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Carrier".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Carrier");
			self.processSystemCarriers(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "AvailabilityGrades".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "AvailabilityGrades");
			self.processSystemAvailGrades(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Commodities".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Commodities");
			self.processSystemCommodities(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ConsigneeConsignor".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ConsigneeConsignor");
			self.processSystemConsigneeors(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "CustomsAgent".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "CustomsAgent");
			self.processSystemCustomsAgents(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Debtor".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Debtor");
			self.processSystemDebtors(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "DebtorType".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "DebtorType");
			self.processSystemDebtorTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "DeliveryReasons".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "DeliveryReasons");
			self.processSystemDeliveryReasons(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "DamageCodes".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "DamageCodes");
			self.processSystemDamageCodes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "DamagePosition".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "DamagePosition");
			self.processSystemDamagePositions(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "EDIDataXlations".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "EDIDataXlations");
			self.processSystemEDIDataXlations(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "EmailAddresses".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "EmailAddresses");
			self.processSystemEmailAddresses(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "HazardClasses".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "HazardClasses");
			self.processSystemHazardClasses(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "InvoiceLineDescs".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "InvoiceLineDescs");
			self.processSystemInvoiceLineDesc(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ISOTypes".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ISOTypes");
			self.processSystemISOTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ISOGroups".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ISOGroups");
			self.processSystemISOGroups(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "JobTypes".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "JobTypes");
			self.processSystemJobTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ShippingLines".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ShippingLiness");
			self.processSystemShippingLines(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ToDoTasks".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ToDoTasks");
			self.processSystemToDoTasks(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "ToDoTaskResource".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ToDoTaskResource");
			self.processSystemToDoTaskRes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Trades".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Trades");
			self.processSystemTrades(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "TrailerType".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "TrailerType");
			self.processSystemTrailerTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "TransactionTypes".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "TransactionTypes");
			self.processSystemTransactionTypes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Stops".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Stops");
			self.processSystemStops(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "Users".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Users");
			self.processSystemUsers(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "UserHookCode".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "UserHookCode");
			self.processSystemUserHookCodes(xmlElement, methodStr);
		elseif xmlElement.tagName.toUpper() = "WagonClass".toUpper() then	
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "WagonClass");
			self.processSystemWagonClasses(xmlElement, methodStr);
		endif;

		if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
				methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
			continue;
		endif;
		
		write methodStr &amp; CrLf &amp; CrLf;
		
		// execute the transient method
		self.executeMethod(methodStr);
		
	endforeach;

	// non xml
	self.processSystemEDIUpdates();
	self.processUpdateLicense();
	self.processSystemMisc();
	
epilog

end;
</source>
        <Parameter name="_systemXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processSystemAvailGrades" id="6b4d8a45-0604-4e05-b94a-d7fb7279d37d">
        <source>processSystemAvailGrades(_availGradeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the availability grade

Date			Who		Reason
06/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: Integer;
	suitableForRelease		: Boolean;
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _availGradeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).Integer;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		suitableForRelease := self.returnElementText(xmlElement.getElementByTagName('suitableForRelease')).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addAvailabilityGrade(' &amp; code.String &amp; ', ' &amp; description &amp; 
			', ' &amp; suitableForRelease.String &amp; ', false);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_availGradeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemCargoTypes" id="ec0365a5-88e8-473e-9bf6-b1093d4c843f">
        <source>processSystemCargoTypes(_cargoTypesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the cargo Types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	hasSubCargo				: Boolean;
	handlingType			: String;
	trackAs					: String;
	
begin

	codeStr := CrLf;
	
	create cargoTypesArray transient;
	
	foreach obj in _cargoTypesXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		hasSubCargo := self.returnElementText(xmlElement.getElementByTagName('hasSubCargo')).Boolean;
						
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		handlingType := self.returnElementText(xmlElement.getElementByTagName('handlingType')).String;
		if handlingType &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("HandlingType", ' &amp; handlingType &amp; ');' &amp; CrLf;
		endif;
		trackAs := self.returnElementText(xmlElement.getElementByTagName('trackAs')).String;
		if trackAs &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrackAs", ' &amp; trackAs &amp; ');' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addCargoType("' &amp; xmlElement.tagName &amp; '", ' &amp; hasSubCargo.String &amp; '); ' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_cargoTypesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemCarriers" id="ad25985c-263e-4216-8bdb-46301ac7a13f">
        <source>processSystemCarriers(_carrierXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the carrier details

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	carrierElement			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	isRoad					: Boolean;
	isRail					: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'pinEmailAddresses	: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete pinEmailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create pinEmailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _carrierXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		isRail := self.returnElementText(xmlElement.getElementByTagName('isRail')).Boolean;
		isRoad	:= self.returnElementText(xmlElement.getElementByTagName('isRoad')).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addCarrier("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; 
			', pinEmailAddresses, false, ' &amp; isRail.String &amp; ', ' &amp; isRail.String &amp; ', null);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_carrierXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemCommodities" id="8335f9c1-6c68-4e41-afe1-aecf6db7a5fc">
        <source>processSystemCommodities(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the commodities

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType			: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	maxTemp					: String;
	minTemp					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'commodity		: CM_Commodity;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		maxTemp :=  self.returnElementText(xmlElement.getElementByTagName('MaxTemp')).String;
		if maxTemp &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("MaxTemp", ' &amp; maxTemp &amp; '.Real);' &amp; CrLf;
		endif;
		minTemp :=  self.returnElementText(xmlElement.getElementByTagName('MinTemp')).String;
		if minTemp &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("MinTemp", ' &amp; minTemp &amp; '.Real);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf &amp;
			Tab &amp; 'commodity := self.addCommodity("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes);' &amp; CrLf &amp; 
			Tab &amp; 'beginTransaction;' &amp; CrLf;
		
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach cargoType in app.myRoot.allCargoTypesById do
			if cargoTypesArray.includes(cargoType.abbreviation) then
				codeStr := codeStr &amp; Tab &amp; 'if not commodity.allCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; cargoType.id.String &amp; ')) then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'commodity.allCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; cargoType.id.String &amp; '));' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf;
			endif;
		endforeach;
	
		codeStr := codeStr &amp; Tab &amp; 'commitTransaction;' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemConfigs" id="5888d605-d211-47c5-a8ad-e01f0157adef">
        <source>processSystemConfigs(_systemXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Add required system setConfigs

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	
begin
	
	varsStr := 'root			: CM_Root;';
	codeStr := CrLf &amp; Tab &amp; 'root := app.myRoot;' &amp; CrLf;
	
	self.processSetConfig(_systemXMLElement, codeStr, 'root');
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_systemXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemConsigneeors" id="6482379e-7ebd-4b72-8989-7b41853737fb">
        <source>processSystemConsigneeors(_consigneeorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the consignee / consignor

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	isConsignee				: Boolean;
	isConsignor				: Boolean;
	isFreightForwarder		: Boolean;
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _consigneeorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		isConsignee := self.returnElementText(xmlElement.getElementByTagName('isConsignee')).Boolean;
		isConsignor := self.returnElementText(xmlElement.getElementByTagName('isConsignor')).Boolean;
		isFreightForwarder := self.returnElementText(xmlElement.getElementByTagName('isFreightForwarder')).Boolean;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addConsigneeConsignor("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; 
			'", ' &amp; isConsignee.String &amp; ', ' &amp; isConsignor.String &amp; ', ' &amp; isFreightForwarder.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_consigneeorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemCustomsAgents" id="05a291c8-9909-44e5-84dc-f1687322f393">
        <source>processSystemCustomsAgents(_customAgentXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the customs agent

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	
begin

	foreach obj in _customAgentXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'self.addCustomsAgent("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '");' &amp; CrLf; 
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_customAgentXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemDamageCodes" id="cd62c345-2581-496c-b0ff-3811c69ff649">
        <source>processSystemDamageCodes(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the commodities

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: CM_ObjectSet;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf;
		
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach str in cargoTypesArray do
			if xmlElement.tagName = "BEER" then
				foreach cargoType in app.myRoot.allCargoTypesById do
					if cargoType.abbreviation = "BARRELSOFS" then
						break;
					endif;
				endforeach;
				if cargoType &lt;&gt; null then
					str := cargoType.id.String;
				endif;
			endif;
			codeStr := codeStr &amp; Tab &amp; 'if not selectedCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; str &amp; ')) then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'selectedCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; str &amp; '));' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addDamageDefinition("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemDamagePositions" id="9a2d1c36-5a08-4fb4-9313-b33b533732a2">
        <source>processSystemDamagePositions(_damagePositionXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the damage positions

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: CM_ObjectSet;' &amp; CrLf &amp;
		Tab &amp; 'machineTypes		: CM_ObjectSet;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf &amp; 
		Tab &amp; 'create machineTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;' &amp; CrLf &amp;
		Tab &amp; 'delete machineTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _damagePositionXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
				
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf &amp;
			Tab &amp; 'machineTypes.clear();' &amp; CrLf;
			
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach str in cargoTypesArray do
			if xmlElement.tagName = "BEER" then
				foreach cargoType in app.myRoot.allCargoTypesById do
					if cargoType.abbreviation = "BARRELSOFS" then
						break;
					endif;
				endforeach;
				if cargoType &lt;&gt; null then
					str := cargoType.id.String;
				endif;
			endif;	
			codeStr := codeStr &amp; Tab &amp; 'if not selectedCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; str &amp; ')) then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'selectedCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; str &amp; '));' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf;
		endforeach;	
			
		codeStr := codeStr &amp; Tab &amp; 'self.addDamagePosition("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes, machineTypes);' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_damagePositionXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
