    <JadeMethod name="btnResetSearch_click" id="33e4b589-1fd6-407b-99c3-02d28504f2a8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnResetSearch_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	self.txtOpenDate.setDate(app.actualTimeAppServer.date.cnEcAddDays(-7));
	self.cmbCargoType.listIndex := -1;
	self.cmbOperator.listIndex := -1;
	self.cmbLocationType.listIndex := -1;
	self.setLocationCombos();
	self.setFilterDefaults();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbLocationAreaClick" id="d3c8db8d-4a70-419e-a9e8-c8f25d9be67f">
        <source>cmbLocationAreaClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS	50906

*/

vars

	obj : Object;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	lcSet : CM_LCSet;
	index : Integer;

begin

	if self.cmbLocationArea.listIndex &gt; 0 then
		obj := self.cmbLocationArea.itemObject[  self.cmbLocationArea.listIndex ];
		if obj &lt;&gt; null and obj.isKindOf( CM_TerminalArea ) then
			ta := obj.CM_TerminalArea;
		endif;
	endif;
	
	if ta = null then
		self.lblLocation.visible := false;
		self.cmbLocation.visible := false;
		self.cmbLocation.clear();
	else
		if ta.isKindOf(CM_GeneralCargoAllocRowArea) then	//15 Jun 2021	NDL	TFS 51336
			create lcSet transient;
			ta.CM_GeneralCargoAllocRowArea.getAllRowGroupControllers( lcSet );
		else
			lcSet := ta.getLCSet();
		endif;
		self.lblLocation.visible := true;
		self.cmbLocation.visible := true;
		foreach lc in lcSet discreteLock do
			index := self.cmbLocation.addItem( lc.getFullId() );
			self.cmbLocation.itemObject[index] := lc;
		endforeach;
	endif;

epilog

	if lcSet &lt;&gt; null and lcSet.isTransient then
		delete lcSet;
	endif;

end;</source>
    </JadeMethod>
