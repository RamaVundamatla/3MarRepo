    <JadeMethod name="aDPArchiveVoyage" id="0f8176b6-94c6-40de-9ace-d5ee72aa1449">
        <source>aDPArchiveVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023		navma1	Initial creation

*/

vars
	lFile      		: File;
	term            : CM_Terminal;
	voyage			: CM_Voyage;
	startDT,
	endDT			: TimeStamp;
	iter			: Iterator;
	msg				: String;
begin
	//app.initialize();
	term := app.myRoot.allTerminals["MA"];
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp; term.code &amp;"VoyageData.csv";
    lFile.open;
	
	startDT.setDate("01/01/2020".Date);
	startDT.setTime('00:00:00:000'.Time);
	
	
	startDT.setDate("31/12/2022".Date);
	startDT.setTime('23:59:59:000'.Time);
	
	lFile.writeLine(
					"Term code"       			&amp; Comma &amp;
					"Voyage Code"  	  			&amp; Comma &amp;
					"Voyage Status"  			&amp; Comma &amp;
					"ATA" 			  			&amp; Comma &amp;
					"ATD"       	 			&amp; Comma &amp;
					"Oid"    		 			&amp; Comma &amp;
					"Number Of jobs"  			&amp; Comma &amp;
					"Jobs Status"    			&amp; Comma &amp;
					"Voyage Can Br Archived" 	&amp; Comma 
					);
					
	iter := term.allVoyagesByArrivalDTCode.createIterator();
	term.allVoyagesByArrivalDTCode.startKeyGeq(startDT,null,iter);
	
	
		while iter.next(voyage) do
			if voyage.arrivedDT&gt; endDT then
				break;
			endif;
			
			msg := null;
		lFile.writeLine(term.code  							&amp; Comma &amp;
						voyage.code  						&amp; Comma &amp;
						voyage.statusDescription			&amp; Comma &amp;
						voyage.arrivedDT.asStringJMT		&amp; Comma &amp;
						voyage.departedDT.asStringJMT		&amp; Comma &amp;
						voyage.getOidAsString				&amp; Comma &amp;
						voyage.allVoyageJobs.size.String	&amp; Comma &amp;
						voyage.allVoyageJobs.listString('|',CM_Job::statusString.name) &amp; Comma &amp;
						voyage.canVoyageBeArchived(msg,true).asStringJMT  &amp; Comma &amp;
						msg
					);
		endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
