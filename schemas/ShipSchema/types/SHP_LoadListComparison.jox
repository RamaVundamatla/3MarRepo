    <JadeMethod name="initModalDialog" id="27a827d4-75e4-4633-bdc9-430c077caf51">
        <source>initModalDialog();
//----------------------------------------------------------------
//	Created:	03 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 300;
	self.frmModalDialog.centreWindow;
	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.frmProgressCtr.visible := true;
	self.lblModalMessage.height := 34;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.lblModalInfo.caption := "";
	self.frmModalDialog.visible := true;
	self.frmModalDialog.backColor := self.backColor;
	self.pbProgressBar.visible := true;
	self.btnModalDefault.visible := false;
	self.pbProgressBar.top := 38;
	self.lblModalInfo.top := self.pbProgressBar.top + self.pbProgressBar.height + 2;
	self.pbProgressBar.zOrder(0);
end;</source>
    </JadeMethod>
