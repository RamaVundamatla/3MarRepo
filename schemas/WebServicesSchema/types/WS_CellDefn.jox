<Class name="WS_CellDefn" id="b35033a3-ee41-4ee8-8480-bd047e489d10">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="alignment" id="0723d3fc-29aa-4379-82c4-954fa2a5e877">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <ImplicitInverseRef name="allLayouts" id="bb5e57db-3580-4a0a-ab43-3b0a26459382">
        <memberTypeInverse/>
        <type name="WS_LayoutArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="label" id="bd15b3af-8750-4d5f-ae22-4aaf48ab076c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="maxHeight" id="4521b91c-ae08-4f9a-b789-0fc5bcec88e8">
        <precision>10</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="maxWeight20" id="0c9835bf-ea13-4013-8127-829697674ae1">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="maxWeight40" id="653c7f61-1e5c-41ee-bb5a-ec98d850f742">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinal" id="c3a76530-9e4d-412c-8eff-bfcd84a84555">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalDeck" id="b143f1af-0dc4-4aad-8e04-9b6ba7e51db3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="oridnalBay" id="69cc484e-1a80-4909-ad49-d598d1ad3a45">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="createProxy" id="103b8432-7ccf-4453-8081-61d522bcd78d">
        <source>createProxy(_pxyBay : CM_BayDefn);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxyCell :	CM_CellDefn;
	onDeckBay,
	underDeckBay : CM_BayDefn;
	wsLayout 		: WS_Layout;
	completedOK 	: Boolean;
begin
	
	if self.ordinalDeck = DeckOnDeck then
		onDeckBay :=_pxyBay;
	else
		underDeckBay := _pxyBay;
	endif;
	
	create pxyCell transient;
	pxyCell.setProxy(self.label,
					self.alignment,
					self.ordinal,
					onDeckBay,
					underDeckBay,
					null); //maxNumHighCubesIfFull
	
	pxyCell.setMaxPileWeight20(self.maxWeight20);
	pxyCell.setMaxPileWeight40(self.maxWeight40);
	pxyCell.setMaxHeight(self.maxHeight);
	
	foreach wsLayout in self.allLayouts discreteLock do
		wsLayout.createProxy(pxyCell);
	endforeach;
	
	completedOK:=true;
epilog
	if not completedOK then
		delete pxyCell;
	endif;
end;</source>
        <Parameter name="_pxyBay" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0fb56f07-acc4-4f50-b58c-d6f5024aaade">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allLayouts.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="5f87d363-7546-4f74-a3a2-f896e8c6f747">
        <updating/>
        <source>setProxyFromObject(_cell: CM_CellDefn) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	inheritMethod(_cell);
	self.label:=_cell.id;
	self.ordinal:=_cell.ordinal;
	
	if _cell.myBayOD &lt;&gt; null then
		self.oridnalBay:=_cell.myBayOD.ordinalBay;
		self.ordinalDeck:=DeckOnDeck;
	elseif _cell.myBayUD &lt;&gt; null then
		self.oridnalBay:=_cell.myBayUD.ordinalBay;
		self.ordinalDeck:=DeckUnderDeck;
	endif;
	
	self.alignment:=_cell.alignment;
	self.maxHeight:=_cell.maxHeight;
	self.maxWeight20:=_cell.maxPileWeight20;
	self.maxWeight40:=_cell.maxPileWeight40;
	
	self.setProxyLayouts(_cell);
epilog

end;</source>
        <Parameter name="_cell" type="CM_CellDefn"/>
    </JadeMethod>
    <JadeMethod name="setProxyLayouts" id="0def4035-bbe0-46cd-8e13-237a8a9fadc1">
        <source>setProxyLayouts(_cell: CM_CellDefn) protected;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	wsLayout	: WS_Layout;
	layout 		: CM_BayItemLayout;
begin
	foreach layout in _cell.allBayItemLayouts discreteLock do
		create wsLayout transient;
		wsLayout.setProxyFromObject(layout);
		self.allLayouts.add(wsLayout);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cell" type="CM_CellDefn"/>
    </JadeMethod>
</Class>
