    <JadeMethod name="showQueues" id="dd9d21c5-e4ea-43f2-880a-029d7aa4b16b">
        <source>showQueues(buildToPurge:String);

vars
	ffBase,ff:FileFolder; fn:FileNode; f:File;
	totalQueued,i,j:Integer; qName,build,s:String;
	qBuildArray,totBuildArray:StringArray256; qCountArray,totCountArray:IntegerArray; qTimeStampArray,totTimeStampArray:TimeStampArray;
begin
	create ffBase transient;
	ffBase.usePresentationFileSystem := false;
	ffBase.fileName := "T:\jblpcre\server\c_misc\jobs";
	create ff transient;
	ff.usePresentationFileSystem := ffBase.usePresentationFileSystem;
	create qBuildArray transient;
	create qCountArray transient;
	create qTimeStampArray transient;
	create totBuildArray transient;
	create totCountArray transient;
	create totTimeStampArray transient;
	
	write "";
	foreach fn in ffBase.files reversed where fn.isKindOf(FileFolder) do // and fn.name.contains("contops") do
		ff.fileName := fn.fileName &amp; "\creatorout";
		qName := fn.name;
		qBuildArray.clear;
		qCountArray.clear;
		qTimeStampArray.clear;
		foreach fn in ff.files where fn.isKindOf(File) do
			f := fn.File;
			if not f.isAvailable then continue; endif;
			s := f.readString(f.fileLength);
			i := s.pos("-fastbuildid=", 1) + 13;
			if i = 13 then continue; endif;
			build := s.scanUntil('",', i);
			if buildToPurge &lt;&gt; null and build = buildToPurge and fn.name[1:15].toLower = "bld_allcurrent_" then  // DELETE a particular build, avoid deleting manual jobs
				f.purge; 
				continue; 
			endif;
			j := qBuildArray.indexOf(build);
			if j = 0 then
				qBuildArray.add(build);
				qCountArray.add(1);
				qTimeStampArray.add(f.lastModifiedTime);
			else
				qCountArray[j] := qCountArray[j] + 1;
			endif;
		endforeach;
	
		if qBuildArray.size &gt; 0 then
			write qName;
			foreach i in 1 to qBuildArray.size do
				write Tab &amp; qBuildArray[i].padBlanks(23) &amp; Tab &amp; qCountArray[i].String &amp; Tab &amp; qTimeStampArray[i].String;
				totalQueued := totalQueued + qCountArray[i];
				j := totBuildArray.indexOf(qBuildArray[i]);
				if j = 0 then
					totBuildArray.add(qBuildArray[i]);
					totCountArray.add(qCountArray[i]);
					totTimeStampArray.add(qTimeStampArray[i]);
				else
					totCountArray[j] := totCountArray[j] + qCountArray[i];
				endif;
			endforeach;
		endif;
	endforeach;
	
	write "Totals by build";
	foreach i in 1 to totBuildArray.size do
		write Tab &amp; totBuildArray[i].padBlanks(23) &amp; Tab &amp; totCountArray[i].String &amp; Tab &amp; totTimeStampArray[i].String;
	endforeach;
	write "totalQueued=" &amp; totalQueued.String &amp; Tab &amp; "at " &amp; app.actualTime.String;
epilog
	delete ffBase;
	delete ff;
	delete qBuildArray;
	delete qCountArray;
	delete qTimeStampArray;
	delete totBuildArray;
	delete totCountArray;
	delete totTimeStampArray;
end;
</source>
        <Parameter name="buildToPurge" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateSvnCache" id="3162fca5-b5af-4e2d-b2c6-2231ac9a55ca">
        <source>updateSvnCache():Integer;// serverExecution;

vars
	cmd,path:String;
	retCode,result:Integer;
begin
	cmd:='C:\cardinal\bin\jblsvncacheV2.exe';
	/*app.logMessage("starting "&amp;cmd);
	retCode:=node.createExternalProcess(null, cmd, null, null, false, true, result);
	app.logMessage("createExternalProcess returned "&amp;retCode.String&amp;", &lt;"&amp;cmd&amp;"&gt; returned "&amp;result.String);/**/
	result:=app.doCmdWithTimeout(cmd, 30*60*1000);
	return result;
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
