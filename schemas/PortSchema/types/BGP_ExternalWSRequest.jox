    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="myEWSActivity" id="34e2b15b-03da-421e-b201-b9398b35a78e">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_ExternalWebServiceActivity"/>
        <access>readonly</access>
        <Inverse name="CM_ExternalWebServiceActivity::myBGPRequest"/>
    </ExplicitInverseRef>
    <PrimAttribute name="nextRetryTime" id="06e200c2-4bd7-4482-b0b8-817a9ac8231a">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="retryCount" id="306dfb67-dfc1-4942-8ee4-3007539181eb">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doWebServiceTimeoutProcessing" id="fbcbe498-26a1-486e-bc64-d947499e02a7">
        <updating/>
        <source>doWebServiceTimeoutProcessing(_wsDefinition : CM_ExternalWebServiceDef) : Boolean updating, protected;
/*

Purpose:			Do the necessary processing following a timeout during the Web Service 
					processing
					
Parameters:			Web Service Definition being used

Return Value:		True if the receiver was successfully updated for retry

Date		Who		Reason
20 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	newRetryTime	: TimeStamp;
	
begin
	// First check if we have already passed the maximum number of timeouts
	if self.retryCount &gt;= _wsDefinition.maxRetries then
		app.raiseCMException1(Max_Retries_Exceeded, _wsDefinition.maxRetries.asStringJMT(), null, null);
		return false;
	endif;
	
	// Calculate the next retry time
	newRetryTime := app.actualTimeServer().addSeconds(_wsDefinition.timeBetweenRetries.min(10));
	
	// And update for retry later
	app.myTrxUA.trxUpdateBGPWSRequestRetry(self, self.retryCount + 1, newRetryTime, app.myPassport);
	
	if app.myPassport.noErrors() then
		app.writeLog(method.qualifiedName &amp; " " &amp; self.String &amp; " set for retry (" &amp; self.retryCount.asStringJMT &amp; ") at " &amp; self.nextRetryTime.asStringForWebInterface(), LogINFO);	//25 Nov 2019	NDL	TFS 47053
		return true;
	else
		app.writeLog(method.qualifiedName &amp; " " &amp; self.String &amp; " set for retry failed", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wsDefinition" type="CM_ExternalWebServiceDef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setActivityHistoryErrors" id="19d26107-3f84-4a6f-8ca1-93267e0a44c6">
        <source>setActivityHistoryErrors(_agent : CM_ExtWebServiceConsumerAgent input ) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation

*/

vars
	pxyActivityHistory : CM_ActivityHistoryExtInterface;
begin
	if not app.myPassport.hasErrors then
		return;
	endif;
	
	if _agent.myLastActivityHistory &lt;&gt; null then
		beginLoad;
			pxyActivityHistory :=_agent.myLastActivityHistory.pxyCreateUpdateProxy().CM_ActivityHistoryExtInterface;
		endLoad;
		
		pxyActivityHistory.setErrors(app.myPassport.getErrorsAsString());
		
		app.myTrxUA.trxUpdateActivityHistory(pxyActivityHistory, app.myPassport);
		
	endif;
epilog
	delete pxyActivityHistory;
end;</source>
        <Parameter name="_agent" type="CM_ExtWebServiceConsumerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1b77aad1-75b5-43b5-83c5-8fc8e06b7d4e">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input) updating;
//
// 20 Jun 2018	jlgrs1	TFS 38630 PIL1 - Perform Credit Check for Auto-Collection Customer
//
vars

begin
	self.nextRetryTime := _proxySelf.nextRetryTime;
	self.retryCount := _proxySelf.retryCount;
	self.myTerminal := _proxySelf.myTerminal;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForRetry" id="5db5afc2-743d-45c9-b79f-311534b1ed84">
        <updating/>
        <source>setForRetry(_retryCount : Integer;
			_nextRetryTime : TimeStamp) updating;
/*

Purpose:			Set the retry-related properties of the receiver

Parameters:			New retry count and time

Return Value:		None

Date		Who		Reason
20 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.retryCount := _retryCount;
	self.nextRetryTime := _nextRetryTime;
	
	self.setIsProcessed(false, self.errorCode, self.errorText);
	
epilog

end;</source>
        <Parameter name="_retryCount" type="Integer"/>
        <Parameter name="_nextRetryTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="ebea085b-3321-4a5a-ac9b-f9912e3885a1">
        <updating/>
        <source>setTerminal(_terminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations

*/

vars

begin
	inheritMethod(_terminal);
	self.myTerminal := _terminal;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
