	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::heavyRated.name, "CM_ReserveSelection", "heavyRated", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::heightSelection.name, "CM_ReserveSelection", "heightSelection", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::lengthSelection.name, "CM_ReserveSelection", "lengthSelection", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::markNumber.name, "CM_ReserveSelection", "markNumber", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::markSelection.name, "CM_ReserveSelection", "markSelection", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::productStr.name, "CM_ReserveSelection", "productStr", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::quantitySelection.name, "CM_ReserveSelection", "quantitySelection", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::remarksSelection.name, "CM_ReserveSelection", "remarksSelection", "", _features);
	create xdbFeature transient;
