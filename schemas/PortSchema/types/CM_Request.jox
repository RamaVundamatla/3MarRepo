    <JadeMethod name="getReqOperatorCode" id="caf629d4-65c6-4727-9339-d80d5f326ccd">
        <source>getReqOperatorCode(_isParent : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
*/

vars
	resDtl : CM_ReserveDetail;
	relReq	: CM_BulkRelease;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null then
		if _isParent then
			relReq := resDtl.myReserveHeader;							//25.03.2024 navhl20 #62300
			if relReq &lt;&gt; null then										//25.03.2024 navhl20 #62300
				resDtl := relReq.allReserveDetails.first;
			endif;
			if resDtl &lt;&gt; null then
				if app.myRoot.getConfig(ComboByNameOperator).Boolean then	//25.03.2024 navhl20 #62300
					return resDtl.getOperator().description;
				else
					return resDtl.getOperatorCode;
				endif;	
			endif;
		else
			if resDtl.packType = CM_ReserveDetail.PackType_Child then
				if app.myRoot.getConfig(ComboByNameOperator).Boolean then	//25.03.2024 navhl20 #62300
					return resDtl.getOperator().description;
				else
					return resDtl.getOperatorCode;
				endif;
			endif;
		endif;
	endif;
	return null;
epilog

end;</source>
