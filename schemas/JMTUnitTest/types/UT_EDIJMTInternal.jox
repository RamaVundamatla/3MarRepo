    <JadeMethod name="tCustomsStopAction" id="8fc5c3b4-3229-42ef-ae79-456c06e9a0cb">
        <source>tCustomsStopAction();
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalCustomStop";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
//	container.addStop();

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCustomStop xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCustomStop.xsd"&gt;
	&lt;AllCustomStops&gt;
		&lt;CustomStops&gt;
			&lt;isUSCustomMessage&gt;&lt;/isUSCustomMessage&gt;
			&lt;packCount&gt;&lt;/packCount&gt;
			&lt;quantity&gt;&lt;/quantity&gt;
			&lt;quantityEntered&gt;&lt;/quantityEntered&gt;
			&lt;quantityReleased&gt;&lt;/quantityReleased&gt;
			&lt;billOfLading&gt;&lt;/billOfLading&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;clientRef&gt;&lt;/clientRef&gt;
			&lt;consignee&gt;&lt;/consignee&gt;
			&lt;consignor&gt;&lt;/consignor&gt;
			&lt;customsAgent&gt;&lt;/customsAgent&gt;
			&lt;customsRef&gt;&lt;/customsRef&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;entryNumber&gt;675882&lt;/entryNumber&gt;
			&lt;fullOrMT&gt;&lt;/fullOrMT&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;mafInstructions&gt;&lt;/mafInstructions&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;quarantineInstructions&gt;&lt;/quarantineInstructions&gt;
			&lt;responseStatus&gt;'&amp;Customs_Import_Cleared.String&amp;'&lt;/responseStatus&gt;
			&lt;sequenceNum&gt;&lt;/sequenceNum&gt;
			&lt;typeString&gt;Import Cleared&lt;/typeString&gt;
			&lt;userNotes&gt;&lt;/userNotes&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;transmissionDate&gt;&lt;/transmissionDate&gt;
		&lt;/CustomStops&gt;
	&lt;/AllCustomStops&gt;
&lt;/JMTInternalCustomStop&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tCustomsStopAction"&amp;CrLf, "wrong remarks");

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCustomsStopExport" id="7755db73-1399-481a-8a7b-b05a98c2a410">
        <source>tCustomsStopExport();
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
constants
	USER_DEF_NAME : String = "JMTInternalCustomStop";
	CONTAINERID1 : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
	strArray : StringArray;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID1);
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainer(CONTAINERID1, operator, "4102", "GOLD", TI_IMEX_STATUS_EXPORT).CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	self.opts.purge;
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(container);							
//	container.addStop();

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCustomStop xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCustomStop.xsd"&gt;
	&lt;AllCustomStops&gt;
		&lt;CustomStops&gt;
			&lt;isUSCustomMessage&gt;&lt;/isUSCustomMessage&gt;
			&lt;packCount&gt;&lt;/packCount&gt;
			&lt;quantity&gt;&lt;/quantity&gt;
			&lt;quantityEntered&gt;&lt;/quantityEntered&gt;
			&lt;quantityReleased&gt;&lt;/quantityReleased&gt;
			&lt;billOfLading&gt;&lt;/billOfLading&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;clientRef&gt;&lt;/clientRef&gt;
			&lt;consignee&gt;&lt;/consignee&gt;
			&lt;consignor&gt;&lt;/consignor&gt;
			&lt;customsAgent&gt;&lt;/customsAgent&gt;
			&lt;customsRef&gt;&lt;/customsRef&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;entryNumber&gt;675882&lt;/entryNumber&gt;
			&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
			&lt;id&gt;'&amp;CONTAINERID1&amp;'&lt;/id&gt;
			&lt;mafInstructions&gt;&lt;/mafInstructions&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;quarantineInstructions&gt;&lt;/quarantineInstructions&gt;
			&lt;responseStatus&gt;'&amp;Customs_Export_Cleared.String&amp;'&lt;/responseStatus&gt;
			&lt;sequenceNum&gt;&lt;/sequenceNum&gt;
			&lt;typeString&gt;Export Cleared&lt;/typeString&gt;
			&lt;userNotes&gt;&lt;/userNotes&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;transmissionDate&gt;&lt;/transmissionDate&gt;
			&lt;allCustomsSeals&gt;CUSTSEAL1 CUSTSEAL2 CUSTSEAL3&lt;/allCustomsSeals&gt;
		&lt;/CustomStops&gt;
	&lt;/AllCustomStops&gt;
&lt;/JMTInternalCustomStop&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
//	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, errorMsg);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	create strArray transient;
	ediDataObj.allEDITrackedItems.first.CM_EDICustomStopTI.getAllCustomsSeals(strArray);
	foreach str in strArray do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "CUSTSEAL1 CUSTSEAL2 CUSTSEAL3 ", "incorrect customs seals");

	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.getAllSealNumCustoms, "CUSTSEAL3"&amp;CrLf&amp;"CUSTSEAL2"&amp;CrLf&amp;"CUSTSEAL1", "incorrect customs seals");
epilog
	delete strArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCustomsStopImport" id="a97c064f-5032-44c4-ab8a-fb7482d48659">
        <source>tCustomsStopImport();
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalCustomStop";
	CONTAINERID2 : String = "SARG1234544";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
//	str : String;
//	str2 : String;
//	strArray : StringArray;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	self.setTerminalConfig(NoImportStops, false);
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID2);
	container := self.getTrackedItem(CONTAINERID2).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID2, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
//	container.addStop();

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCustomStop xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCustomStop.xsd"&gt;
	&lt;AllCustomStops&gt;
		&lt;CustomStops&gt;
			&lt;isUSCustomMessage&gt;&lt;/isUSCustomMessage&gt;
			&lt;packCount&gt;&lt;/packCount&gt;
			&lt;quantity&gt;&lt;/quantity&gt;
			&lt;quantityEntered&gt;&lt;/quantityEntered&gt;
			&lt;quantityReleased&gt;&lt;/quantityReleased&gt;
			&lt;billOfLading&gt;&lt;/billOfLading&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;clientRef&gt;&lt;/clientRef&gt;
			&lt;consignee&gt;&lt;/consignee&gt;
			&lt;consignor&gt;&lt;/consignor&gt;
			&lt;customsAgent&gt;&lt;/customsAgent&gt;
			&lt;customsRef&gt;&lt;/customsRef&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;entryNumber&gt;675882&lt;/entryNumber&gt;
			&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
			&lt;id&gt;'&amp;CONTAINERID2&amp;'&lt;/id&gt;
			&lt;mafInstructions&gt;&lt;/mafInstructions&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;quarantineInstructions&gt;&lt;/quarantineInstructions&gt;
			&lt;responseStatus&gt;'&amp;Customs_Import_Cleared.String&amp;'&lt;/responseStatus&gt;
			&lt;sequenceNum&gt;&lt;/sequenceNum&gt;
			&lt;typeString&gt;Import Cleared&lt;/typeString&gt;
			&lt;userNotes&gt;&lt;/userNotes&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;transmissionDate&gt;&lt;/transmissionDate&gt;
		&lt;/CustomStops&gt;
	&lt;/AllCustomStops&gt;
&lt;/JMTInternalCustomStop&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
//	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, errorMsg);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");

	container := self.getTrackedItem(CONTAINERID2).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tCustomsStopImport"&amp;CrLf, "wrong remarks");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
//	delete strArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tDebtorAction" id="20012568-a052-48ac-beeb-2189ce23c7c0">
        <source>tDebtorAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalDebtor";
	DEBTOR : String = "DEBTOR01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	debtor : CM_Debtor;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteDebtor(DEBTOR);
	debtor := self.getDebtor(DEBTOR);
	self.assertIsDeleted(debtor);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDebtor xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDebtor.xsd"&gt;
	&lt;AllDebtor&gt;
		&lt;Debtor&gt;
			&lt;action&gt;A&lt;/action&gt;
			&lt;badDebtor&gt;&lt;/badDebtor&gt;
			&lt;billingAddress&gt;&lt;/billingAddress&gt;
			&lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
			&lt;decfinName&gt;&lt;/decfinName&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;externalReference&gt;&lt;/externalReference&gt;
			&lt;fullOrMT&gt;&lt;/fullOrMT&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;isPurchaseOrderMandatory&gt;&lt;/isPurchaseOrderMandatory&gt;
			&lt;isSuspended&gt;&lt;/isSuspended&gt;
			&lt;isZeroRatedTax&gt;&lt;/isZeroRatedTax&gt;
			&lt;longName&gt;Stuff&lt;/longName&gt;
			&lt;messageMode&gt;&lt;/messageMode&gt;
			&lt;myParentDebtorNode&gt;&lt;/myParentDebtorNode&gt;
			&lt;name&gt;'&amp;DEBTOR&amp;'&lt;/name&gt;
			&lt;purchaseOrderCode&gt;&lt;/purchaseOrderCode&gt;
			&lt;remarks&gt;&lt;/remarks&gt;
		&lt;/Debtor&gt;
	&lt;/AllDebtor&gt;
&lt;/JMTInternalDebtor&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	debtor := self.getDebtor(DEBTOR);
	self.assertNotNull(debtor);
	self.assertEqualMsg(debtor.longName, "Stuff", "wrong name");
return;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDebtor xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDebtor.xsd"&gt;
  &lt;AllDebtor&gt;
    &lt;Debtor&gt;
      &lt;action&gt;M&lt;/action&gt;
      &lt;badDebtor&gt;&lt;/badDebtor&gt;
      &lt;billingAddress&gt;&lt;/billingAddress&gt;
      &lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
      &lt;decfinName&gt;&lt;/decfinName&gt;
      &lt;description&gt;&lt;/description&gt;
      &lt;externalReference&gt;&lt;/externalReference&gt;
      &lt;fullOrMT&gt;&lt;/fullOrMT&gt;
      &lt;id&gt;&lt;/id&gt;
      &lt;isPurchaseOrderMandatory&gt;&lt;/isPurchaseOrderMandatory&gt;
      &lt;isSuspended&gt;&lt;/isSuspended&gt;
      &lt;isZeroRatedTax&gt;&lt;/isZeroRatedTax&gt;
      &lt;longName&gt;MoreStuff&lt;/longName&gt;
      &lt;messageMode&gt;&lt;/messageMode&gt;
      &lt;myParentDebtorNode&gt;&lt;/myParentDebtorNode&gt;
      &lt;name&gt;'&amp;DEBTOR&amp;'&lt;/name&gt;
      &lt;purchaseOrderCode&gt;&lt;/purchaseOrderCode&gt;
      &lt;remarks&gt;&lt;/remarks&gt;
    &lt;/Debtor&gt;
  &lt;/AllDebtor&gt;
&lt;/JMTInternalDebtor&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	debtor := self.getDebtor(DEBTOR);
	self.assertNotNull(debtor);
	self.assertEqualMsg(debtor.longName, "MoreStuff", "wrong name");
return;	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDebtor xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDebtor.xsd"&gt;
  &lt;AllDebtor&gt;
    &lt;Debtor&gt;
      &lt;action&gt;D&lt;/action&gt;
      &lt;badDebtor&gt;&lt;/badDebtor&gt;
      &lt;billingAddress&gt;&lt;/billingAddress&gt;
      &lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
      &lt;decfinName&gt;&lt;/decfinName&gt;
      &lt;description&gt;&lt;/description&gt;
      &lt;externalReference&gt;&lt;/externalReference&gt;
      &lt;fullOrMT&gt;&lt;/fullOrMT&gt;
      &lt;id&gt;&lt;/id&gt;
      &lt;isPurchaseOrderMandatory&gt;&lt;/isPurchaseOrderMandatory&gt;
      &lt;isSuspended&gt;&lt;/isSuspended&gt;
      &lt;isZeroRatedTax&gt;&lt;/isZeroRatedTax&gt;
      &lt;longName&gt;MoreStuff&lt;/longName&gt;
      &lt;messageMode&gt;&lt;/messageMode&gt;
      &lt;myParentDebtorNode&gt;&lt;/myParentDebtorNode&gt;
      &lt;name&gt;'&amp;DEBTOR&amp;'&lt;/name&gt;
      &lt;purchaseOrderCode&gt;&lt;/purchaseOrderCode&gt;
      &lt;remarks&gt;&lt;/remarks&gt;
    &lt;/Debtor&gt;
  &lt;/AllDebtor&gt;
&lt;/JMTInternalDebtor&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	debtor := self.getDebtor(DEBTOR);
	self.assertIsDeleted(debtor);

end;

</source>
    </JadeMethod>
    <JadeMethod name="tDeckPlan" id="c74dd20f-7af6-4211-a78d-20ec938870d4">
        <source>tDeckPlan();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
constants
	USER_DEF_NAME : String = "JMTInternalDeckPlan";
	VoyageName 				: String = 'UT_MDHROR33';
//	VoyageName1				: String = 'UT_MDHRORO1';
//	VoyageName2				: String = 'UT_MDHRORO2';
	ShipName				: String = 'JGRIG';
	TestOperator 			: String = 'MSL';
//	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
//	DeckName2 				: String = "2";   						// MAIN DECK
//	DeckName4 				: String = "4";   						
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	operatorObj : CM_Operator;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj	:=	app.myPassport;

	self.deleteContainer("LMCU0442603");
	self.deleteContainer("LMCU0442603");
	self.deleteContainer("CANN1112229");
	self.deleteContainer("CANN1112229");
	self.deleteContainer("CANN1112229");
	self.deleteContainer("CAIU4006879");
	self.deleteContainer("CANN1112229");
	self.deleteContainer("CAXU3304649");
	self.deleteContainer("CLHU4277649");
	self.deleteContainer("CLHU8553004");
	self.deleteContainer("CLHU8586055");
	self.deleteContainer("CLHU8613058");
	self.deleteContainer("CLHU8662005");
	self.deleteContainer("CANN777777Z");
//	containerObj := self.getTrackedItem(CONTAINER_ID01);
//	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
//	self.deleteVessel(VESSEL_CODE);
//	vesselObj	:=	self.getVessel(VESSEL_CODE);
//	self.assertIsDeleted(vesselObj);
	// delete the voyages
	self.deleteVoyage(VoyageName);
	voyageObj := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyageObj);
//	self.deleteVoyage(VoyageName1);
//	voyageObj := self.getVoyage(VoyageName1);
//	self.assertIsDeleted(voyageObj);
//	self.deleteVoyage(VoyageName2);
//	voyageObj := self.getVoyage(VoyageName2);
