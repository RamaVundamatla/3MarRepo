begin
	/* //- cnwmd1, Par 22803
	theDef := app.myController.getEntTableDef(ETDef_NonPlannedFilter);
	self.tblFilter.setEntTableDef(theDef, null, null);
	self.setColorsForEntryTable(self.tblFilter);
	self.frmSelector.height := self.tblFilter.height + self.frmSelectToolbar.height + 10;
	*/
	
	//+ cnwmd1 Par 22803
	combo := self.cmbVoyage;
	//combo.top := VertGap; //	navkc1	18/08/2025	JIRA MTN-35759
	combo.top := self.chkBlockStack.top + 30; //	navkc1	18/08/2025	JIRA MTN-35759
	combo.left := HorzGap;
	combo.width := combo.parent.width - (HorzGap * 2);
	sht := self.shtVoyage;
	sht.visible := true;
	sht.caption := app.getErrorString(Voyage);	
	
	//lstTable := self.lstCargoTypes;
	//lstTable.width := sht.clientWidth;
	//lstTable.height := sht.clientHeight;
