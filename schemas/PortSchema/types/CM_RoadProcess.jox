    <JadeMethod name="setForCreate" id="bd38b4fe-1811-431c-a298-6df64827a5f4">
        <updating/>
        <source>setForCreate(pProxy: CM_Code) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

begin
	inheritMethod(pProxy);
	self.setForUpdate( pProxy );
	
	self.myRoot := app.getMyRoot;

epilog

end;</source>
