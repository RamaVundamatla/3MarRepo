    <JadeMethod name="cmbFiltEdiType_click" id="185485ba-768e-4c35-ba7a-3784d9297167">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltEdiType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 04/03/2013	cnwcs5	par 31087 - clear out ETDEF for tblEDITI
// 25 February 2014	cnwah9 Par 33580 enable filtering by voyage only when Baplie is selected
// 04 Sep 2023	jlika1	TFS 59168 - 55715.060 Display of Voyage EDI data in the EDI Operations Screen
// 06 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
vars
	tbl 			: CM_DataTable;
	index 			: Integer;
	ediTypeIndex	: Integer;	//jlika1 TFS 60232
begin
	self.tblSearch.setValueByControlName(combobox.name, combobox.text);
	//cnwgb1 PAR 20320 for MES1011 7.9.09 replace
	self.setDataClassFromCombo( combobox );
	self.filterFileType := self.getFileType( self.myDataClass);
	 
	self.setFileTypeFields();
	self.tblEDIDetails.clear();
	self.tblEDITIError.clear();
	self.tblEDIDetails.rows := 0;

	self.myCurrentObject := null;	// PAR 22402 19/02/2010
	
	// Cloned data controls Messina Line MES 1011 cnwgb1 September 2009
	index := 0;
	
	while (true) do
		tbl := self.tblEDITI.getControl(index);
		
		if tbl &lt;&gt; null then
			tbl.clear();
			tbl.setMyEntTableDef (null);	// par 31087 march 2013
			
			tbl.rows 	:= 1; 				// heading
			index 		:= index+1;
		else
			break;
		endif;
	endwhile;
			
	self.fldDetail.topSheet := self.shtEDIDetails;
	self.hideVerifyErrors(); 	// par 20836
	self.setControls();		// cnwrl1 04/09/2009 PAR 20320 - MES 1011 New Messina Messages
	//cnwah9 25/02/2014 par33580
	
	//jlika1 TFS 60232 --&gt;
	self.setAddlFilterRows();
	//jlika1 TFS 60232 &lt;--
	
	//end of coding
end;</source>
