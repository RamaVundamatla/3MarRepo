    <JadeMethod name="doLogin" id="67dc0010-484d-4a20-87be-9438e3e63d7f">
        <updating/>
        <source>doLogin()updating, protected;

vars
	baseRootObj		: CnEcBaseRoot;
	
begin
	btnVeto.visible 		:= true;
	btnFormatter.visible 	:= true;
	btnRebuild.visible 		:= true;
	btnHubble.visible 		:= true;
	cmbSchemas.visible 		:= true;
	lblSelectSchema.visible	:= true;
	btnLogIn.visible 		:= false;
	baseRootObj				:=	app.myBaseRoot;
		
	if baseRootObj = null then
		btnFormatter.visible 	:= false;
		btnRebuild.visible 		:= false;
		btnHubble.visible 		:= false;
		cmbSchemas.visible		:= false;
		lblSelectSchema.visible	:= false;	
	else
		if app.myCnEcXmlSchema &lt;&gt; null then 		
			self.doCheckForDataBaseChanges();		
		endif;
	endif;
		
	self.move(1, 1, self.width, self.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRebuild" id="3729b5e9-a991-4755-990f-e3346375e83a">
        <updating/>
        <source>doRebuild()updating, protected;

vars
	formObj 	: CnEcXMLClassFormatMaint;
	
begin
	create formObj;
	formObj.createDefaultFormats();
	self.setRebuildIsRequired(false);
epilog
	delete formObj;	 		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSchemaSelect" id="bbe11275-7669-4aa7-ace7-37ef4d67320a">
        <updating/>
        <source>doSchemaSelect() updating, protected;

vars
	formObj	: Form;
	count	: Integer;
	
begin
	if cmbSchemas.listIndex &gt; 0 then
		while app.formsCount() &gt; 1 do
			formObj := app.forms(2).Form;
			
			if not formObj.isKindOf(CnEcXMLUtilityForm) then
				formObj.unloadForm();
			endif;
			
			formObj := app.forms(1).Form;
			
			if not formObj.isKindOf(CnEcXMLUtilityForm) then
				formObj.unloadForm();
			endif;
			
			count := count + 1;
			
			if count &gt; 5 then
				write "broke";
				break;
			endif;				
		endwhile;
		
		if self.aIsRebuildDefFormatsRequired then
			self.doRebuild();
		endif;
		
		app.cnEcSetXmlSchema(cmbSchemas.text);
		self.doCheckForDataBaseChanges();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUgradeFormatsWithSchemaInfo" id="e80228a7-8611-4d27-a1a0-db3c2ab8fe26">
        <source>doUgradeFormatsWithSchemaInfo()protected;

//This method should be deleted once the upgrade of Formats to include
//schemaName is live. ( &amp; populated) NDL 27/10/2000 along with CnEcBaseRoot.allXmlExcludedClasses 
 
vars
	className			: String;
	excludedClassObj	: CnEcXmlExcludedClasses;
	schemaName			: String;
	writeText			: String;
	schemaObj			: Schema;
	xmlFormatObj		: CnEcXmlFormat;
	
begin
	//upgrade code. NDL 27/10/2000
	if CnEcXmlExcludedClasses.instances.isEmpty() then
	
		beginTransaction;
		
		//create the new CnEcXmlExcludedClasses using currentSchema as the schema value.
		app.cnEcSetXmlSchema(null);
		schemaName := currentSchema.name;	// changed from "JadeHubModel" - NDL 21 Feb 01
		
		while app.myCnEcXmlSchema = null do
			write "No schema currently selected, please enter the Schema name you want to load 'excluded classes' against, and press OK.";
			writeText := "Avaialble schema names are:" &amp; CrLf;
			
			foreach schemaObj in Schema.instances do
				writeText := writeText &amp; Tab &amp; "'" &amp; schemaObj.name &amp; "'" &amp; CrLf;
			endforeach; 
			
			write writeText;
			read schemaName;
			app.cnEcSetXmlSchema(schemaName);
			
			if app.myCnEcXmlSchema = null then
				write "Couldn't set the schema to '" &amp; schemaName &amp; "', try again...";
			else
				break;
			endif; 
		endwhile;
		
		app.myBaseRoot.createCnEcXmlExcludedClasses(app.myCnEcXmlSchema.name, excludedClassObj);
		
		foreach className in app.myBaseRoot.allXmlExcludedClasses do
			excludedClassObj.addXmlExcludedClass(className);
		endforeach;
		
		foreach xmlFormatObj in CnEcXmlFormat.instances where xmlFormatObj.schemaName = "" do
			xmlFormatObj.upgrade(schemaName);
			write xmlFormatObj.formatName &amp; " schema name set to '" &amp;  xmlFormatObj.schemaName &amp; "'";
		endforeach;  
		
		//de-populate the baseRoot.allXmlExcludedClasses
		app.myBaseRoot.clearXmlExcludedClasses();
		write "Upgrade completed.";
		
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doVeto" id="9b51f2e6-31b1-4db0-b8c5-ce4dcb9ddf2b">
