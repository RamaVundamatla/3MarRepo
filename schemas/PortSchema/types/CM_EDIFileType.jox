    <JadeMethod name="rawDataToHSA" id="8dff4d35-5e5f-443f-bfe3-8833d7acac80">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines : HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
vars
	ediFile : CM_EDIFile;
	fileLine : String;
begin
	_theLines.clear;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine.getHugeTokensForDelimiter(Cr, _theLines);
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(_theLines.size);
		endif;
	endif;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToString" id="3d467b01-a7c2-47ab-aa35-c757a63db633">
        <source>rawDataToString(_ediFile : CM_EDIFile) : String;
//
//19 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	fileLine : String;
begin
	fileLine := _ediFile.getRawDataString();
	fileLine := fileLine.replaceString(CrLf, Cr);
	fileLine := fileLine.replaceString(Lf, Cr);
	return fileLine;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="reprocessFile" id="41113fd4-58e2-4622-8dd7-e2b84fd6e6f1">
        <updating/>
        <source>reprocessFile(_ediFile: CM_EDIFile input; _ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//6/07/2018 	JLGNS1	Bug 39173: MSL - Roro baplie not entirely loaded - HIGH PRIORITY
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDITrackedItem;
	ediTI2 : CM_EDITrackedItem;
	invalidEDIData : Boolean;
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
begin
	//need this here for single data files - wont hurt other
	if not _ediData.ediFileArray.includes(_ediFile) then	//Bug 39173
		_ediFile.ediData := _ediData;						//Bug 39173
	endif;													//Bug 39173

	self.processFile(_ediFile);
	//jlier1 TFS 55788 17/1/22 - for ifcsum _ediData was invalid added delete error handling and do the other stuff that was done in the trx
	on Exception do app.handleDeletedObject(exception,_ediData,invalidEDIData);
	
	if _ediData.allEDITrackedItems.size &gt; 0 then
		if not tryLock(_ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_ediData.ediConfig);
		endif;
		if not tryLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
		endif;
		create ediUserDefinedAssist transient;
		_ediData.addEDIConfigToEDITis(ediUserDefinedAssist);
		
	endif;
//	_ediFile.ediData.doTranslations();	//19 Jan 2016	NDL	Par 37413
epilog	
	delete ediUserDefinedAssist;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
