    <JadeMethod name="canAccessConsigneeConsignor" id="fe8597c7-1df1-47f6-ad24-da2a94d582ee">
        <source>canAccessConsigneeConsignor(_user : CM_User): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
//
vars
	ti : CM_TrackedItem;
	tis : CM_TISet;

begin
	create tis transient;
	self.myParent.CM_WorkOrderTI.getAllTIs(tis);
	foreach ti in tis discreteLock do
		if ti.canAccessConsigneeConsignor(_user) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete tis;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canActionTask" id="3276ab2b-b23d-4d35-92a0-ab9a5c9ad045">
        <source>canActionTask(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
16 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	parent     : CM_WorkOrderTI;
	term 	   : CM_Terminal;
	finIOClass : CM_ExtFinanceIO;
begin

	
	//10.09.2021 navma1 #51002
	/*
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	endif;

	if finIOClass &lt;&gt; null and finIOClass.isKindOf(CM_Pelindo1Interface) then
		if not self.getMyParent.allCashReceipts.isEmpty and not self.getMyParent.allCashReceiptsAre( CM_CashReceipt.PAID ) then
			return false;
		endif;
	endif;
	//10.09.2021 navma1 #51002
	
	*/
	
	if self.myParent = null then
		return false;
	endif;
	
	parent := self.myParent.CM_WorkOrderTI;
	
	if parent.taskStatus = WO_STATUS_COMPLETE then
		return false;
	endif;
		
	if parent.taskStatus = WO_STATUS_PENDING_CANCEL then
		return false;
	endif;
	
	if parent.taskStatus = WO_STATUS_PENDING_HOLD then
		return false;
	endif;
	
	if parent.taskStatus = WO_STATUS_HELD then
		return false;
	endif;	
	
	if parent.taskStatus = WO_STATUS_CANCELLED then
		return false;
	endif;
	
	
	if not parent.hasBeenApproved then
		return false;
	endif;
	
	
	//if self.getTotalActioned() &lt; parent.totalRequired  then					//08.02.2023 navma1 #56457:[56458]
	if self.allCompleteTIs.isEmpty then
		
		if self.skipTiValidation and self.status = WO_STATUS_APPROVED then		//17.04.2023 navma1 #55440:[54990]
			return true;
		else
			if self.allActionedTIs.size &lt; self.allSelectedTIs.size  then		//08.02.2023 navma1 #56457:[56458]
				return true;
			endif;
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
