<Class name="CM_ShipPort" id="c2c0d1f9-9a5a-44cb-8c34-87fd6efffccb">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="port" id="f36ef274-d745-411f-a03e-6543adc55629">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Port"/>
        <access>readonly</access>
        <Inverse name="CM_Port::shippingPorts"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="shipPortGroup" id="e65615f0-3515-4ce1-8261-77176dee13c4">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_ShipPortGroup"/>
        <access>readonly</access>
        <Inverse name="CM_ShipPortGroup::shipPorts"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayDetails" id="2ae9db75-18fe-491b-8c45-c521d68a03d8">
        <source>getDisplayDetails(_short: Boolean): String;

vars

begin
	return self.port.getDisplayDetails(_short)&amp;'  '&amp;self.shipPortGroup.getDisplayDetails(_short);
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d7bf032e-70fe-4548-9bb7-89e1918187f2">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	tmpShipPort : CM_ShipPort;
	completedOK		: Boolean;
begin
	tmpShipPort := inheritMethod();
	tmpShipPort.port := self.port;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpShipPort;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpShipPort;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="91b12861-d063-4fb9-abd9-f72ded6cbe39">
        <updating/>
        <source>setForCreate(_proxyShipPort : CM_ShipPort) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.port	:= _proxyShipPort.port;

end;</source>
        <Parameter name="_proxyShipPort" type="CM_ShipPort"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c159a40a-4589-48d5-bb9d-dd0c42ad29a4">
        <updating/>
        <source>setProxy(_port : CM_Port) updating;

vars

begin

	self.port	:= _port;
	
end;</source>
        <Parameter name="_port" type="CM_Port"/>
    </JadeMethod>
</Class>
