    <JadeMethod name="applyAdvancedDeckingRules" id="88570a4f-7218-487b-9c34-9a763d6eb2ba">
        <source>applyAdvancedDeckingRules(_rule: CM_YADeckingRule; _isIn: Boolean; _locations: CM_LCSet; _offset: Integer);

/*

Purpose:			Set up the fill order as defined by the decking rule

Parameters:			Rule, In/Out, locations and start offset

Return Value:		None


Date		Who		Reason
31 Dec 2008	cnwdw1	SFW 1032
19 Mar 2009	cnwkpd1	PAR #19164 - Setup topup tier to ensure correct sequencing when this
					option is used
19 Mar 2009	cnwkpd1	PAR #19194 - Change to use intermediate ExtKeyDict, to improve
					performance 
					PAR #19124 - Handle situation where there are no stacks, to prevent
					Division By Zero exception
					PAR #18994 - add inheritMethod to prevent 1300 exceptions on array access
					
*/

vars
	sequencer		: CMIF_DeckingSequenceService;
	rows, 
	stacks, 
	tiers			: Integer;
	row, 
	stack,
	index,
	tier, 
	firstRow, 
	seq				: Integer;
//	location: CM_LocationsController;
	gridLocation	: CM_GridController;
//	height: Integer;
	yaLocnCells		: CM_YALocationCellArray;
	yaLocnCell		: CM_YALocationCell;
//	gridColumn: CM_GridColumn;
	locationsByRowStack	: CM_MemberKeyDictionary;
	obj				: Object;
	iter			: Iterator;
	cellsBySequence	: CM_ObjectByIntegerDict;
	
begin
	// PAR #18994 - Need to check and possibly rebuild any missing allocation cells, on
	// my area
	if self.getGridArea &lt;&gt; null then
		self.getGridArea.fixupYALocationCells();
	endif;
	
	if _rule.isCustom then		// User has set a custom order 
		return;
	endif;

	self.getGridControllersForDecking(locationsByRowStack);
	
	// Find the number of rows and stacks
	foreach obj in locationsByRowStack do
		gridLocation := obj.CM_GridController;
		if gridLocation &lt;&gt; null then
			if firstRow = 0 then
				firstRow := gridLocation.row;
			endif;
			if gridLocation.row = firstRow then
				stacks := stacks + 1;
			else
				break;
			endif;
		endif;
	endforeach;
	
	// PAR 19124 - if no stacks, then do nothing
	if stacks = 0 then
		return;
	endif;
		
	rows := (locationsByRowStack.size / stacks).Integer;
	tiers := self.getHeightOfStack;

	create sequencer transient;
	sequencer.onCreate(_rule.areaRule);
	sequencer.setExtent(stacks, rows, tiers);
	sequencer.topupTier := _rule.topupTier;			// PAR #19164
	sequencer.setRules(_rule.stackRule, _rule.rowRule, _rule.patternRule);

	if _isIn then
		yaLocnCells := self.myDeckingOptions.allYALocationCellsIn;
	else
		yaLocnCells := self.myDeckingOptions.allYALocationCellsOut;
	endif;
	
	if _offset = 0 then
		yaLocnCells.clear;
	else
		// PAR #18994 - need to do this because we have changed the way the array
		// is populated below
		while yaLocnCells.size &gt; _offset do
			yaLocnCells.removeAt(_offset + 1);
		endwhile;
	endif;
	
	// PAR #18994 - use external key dictionary for performance
	create cellsBySequence transient;
	
	iter := locationsByRowStack.createIterator;

	foreach row in 1 to rows do
		foreach stack in 1 to stacks do
			index := index + 1;
			iter.next(obj);
			gridLocation := obj.CM_GridController;
			foreach tier in 1 to tiers do
				seq := sequencer.getStackingSequence(stack, row, tier);
				cellsBySequence.putAtKey(seq, gridLocation.allYAYardLocationCells[tier]);	// PAR #19194
			endforeach;
		endforeach;
	endforeach;

	// PAR #18994 - Now copy cells back into the array in sequence
	delete iter;
	iter := cellsBySequence.createIterator;
	while iter.next(yaLocnCell) do
		yaLocnCells.add(yaLocnCell);
	endwhile;
	
	
epilog
	delete sequencer;
	delete locationsByRowStack;
	delete iter;
	delete cellsBySequence;

end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_offset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatistics" id="83c0297e-01fb-42df-829f-a45c6ad477eb">
        <updating/>
        <source>buildLocationStatistics() updating;
/*

Purpose:			Build Location Statistics

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2009	cnwjk3	re-write for SFW1030

*/
vars
	lc                  : CM_LocationsController;
	locationStatistics  : CM_LocationStatistics;
	plocationStatistics : CM_LocationStatistics;
	terminal            : CM_Terminal;
	statsAgent			: CMIF_StatisticsAgent;
	locations			: CM_LCArray;
	sortedLocations		: CM_GridControllersByRowColumn;
begin
	create statsAgent transient;

	if self.myLocationStatistics = null then
		create plocationStatistics transient;
		plocationStatistics.setParent(self);
		create locationStatistics  persistent;
		locationStatistics.setupForCreate(plocationStatistics);
	endif;

	if not self.status = LC_Status_Open then
		return;
	endif;

	create locations transient;
	create sortedLocations transient;
	
	// It's important that the columns are in order for the new stats methods to work correctly
	self.allYardControllers.copy(sortedLocations);	
	sortedLocations.copy(locations);
	
	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts;
	
	// Calculate future queued/planned (unchanged from original code)
	foreach lc in locations do	
		self.myLocationStatistics.processALocationController(lc, self.getMinHeight, self.getMaxHeight);
	endforeach;

	self.myLocationStatistics.c20Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c30Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c40Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_40, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c45Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c53Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, self.getMinHeight(), self.getMaxHeight());
	//cnwjo3 par 21189
	self.myLocationStatistics.total := self.myLocationStatistics.c20Total;  //in a gridarea total = total TEUs
	
	self.myLocationStatistics.c20Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations, self.getMinHeight(), self.getMaxHeight());  //cnwjo3 par 20470
	self.myLocationStatistics.c30Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_30, locations, self.getMinHeight(), self.getMaxHeight());  //add min/max heights
	self.myLocationStatistics.c40Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_40, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c45Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_45, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c53Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_53, locations, self.getMinHeight(), self.getMaxHeight());
	//cnwjo3 par 21189
	//self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used + self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used + self.myLocationStatistics.c53Used;
		//self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used + self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used + self.myLocationStatistics.c53Used;
//	if self.allYardControllers.first &lt;&gt; null then // cnwrd1 par 34307
//		self.myLocationStatistics.used := self.allYardControllers.first.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
//	endif;
	//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
	self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used
									+ self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used
									+ self.myLocationStatistics.c53Used;
	
	self.myLocationStatistics.c20Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c30Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_30, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c40Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_40, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c45Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, self.getMinHeight(), self.getMaxHeight());
	self.myLocationStatistics.c53Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_53, locations, self.getMinHeight(), self.getMaxHeight());
	//cnwjo3 par 21189
	self.myLocationStatistics.free := self.myLocationStatistics.c20Free;  //in a gridarea free = free TEUs

	
	self.myLocationStatistics.setUpdateTimestamp;

	//
	// Now notify everyone
	//
	terminal := self.myTerminalArea.myTerminal;
	terminal.causeEvent(terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, self.myLocationStatistics);

epilog
	delete sortedLocations;
	delete locations;
	delete statsAgent;
	delete plocationStatistics;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkFreeSpaceRequired" id="cbcb931b-7fa4-4b28-bc93-e9f1c442ca60">
        <source>checkFreeSpaceRequired(_yaAgent: CM_YAAutoplanAgent input; _lcToCheck: CM_LocationsController; _numFailed: IntegerArray input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwer1	Initial creation

*/

vars
	theLC : CM_LocationsController;
	gridLCToCheck,
	theGridLC : CM_GridController;
	theCol,
	theRow 		: Integer;
begin
	if _yaAgent.numberOfFreeSpacesRequired = 0 then
		return true;
	endif;
	
	theLC:=_yaAgent.getMyCurrentTrackedItem.myPrimaryActualLocation;
	if not theLC.isKindOf(CM_GridController) then
		return true;
	endif;
	theGridLC:=theLC.CM_GridController;
	
	if not _lcToCheck.isKindOf(CM_GridController) then
		return true;
	endif;
	gridLCToCheck:=_lcToCheck.CM_GridController;
	
	
	if theGridLC.getMyGridArea.useSideAccessRules or
		theGridLC.getMyGridArea.isKindOf(CM_RTGArea) then
		theCol:=gridLCToCheck.column;
		if theCol = theGridLC.column then
			return true;
		endif;
		
		if theCol &lt;= _numFailed.size then				//+cnwml2 PAR25793
			_numFailed[theCol]:=_numFailed[theCol] + 1;
		//	write theCol.String &amp; Tab &amp; _numFailed[theCol].String;
			if _numFailed[theCol] &gt; _yaAgent.numberOfFreeSpacesRequired then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'No space in ' &amp; _lcToCheck.getFullId &amp; ' moving to next location would have broken the 20 foot free space requirement of ' &amp; _yaAgent.numberOfFreeSpacesRequired.String, false);
				return false;
			endif;	
		endif;
	else
		theRow :=gridLCToCheck.row;
		if theRow &lt;&gt; theGridLC.row then
			return true;
		endif;
		
		if theRow &lt;= _numFailed.size then			//+cnwml2 PAR25793
			_numFailed[theRow]:=_numFailed[theRow] + 1;
		//	write theRow.String &amp; Tab &amp; _numFailed[theRow].String;
			if _numFailed[theRow] &gt; _yaAgent.numberOfFreeSpacesRequired then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'No space in ' &amp; _lcToCheck.getFullId &amp; ' moving to next location would have broken the 20 foot free space requirement of ' &amp; _yaAgent.numberOfFreeSpacesRequired.String, false);
				return false;
			endif;	
		endif;
	endif;
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_lcToCheck" type="CM_LocationsController"/>
        <Parameter name="_numFailed" type="IntegerArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="e4f6a050-c9fe-4e82-8ba4-954777f196d7">
        <source>getDisplayDetails(_short: Boolean): String;
//----------------------------------------------------------------
//	Created:	09 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridRow	: CM_GridObject;
begin
	if _short then
		gridRow := self.getGridObject;
		if gridRow &lt;&gt; null then
			return self.myTerminalArea.id &amp; ", Row " &amp; self.getGridObject.label &amp; " " &amp; self.getLocationsString; 
		else
			return self.myTerminalArea.id &amp; " " &amp; self.getLocationsString; 
		endif;
	else
		return self.getYAListDisplay(true);
	endif;
	

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
