    <JadeMethod name="setControllerFromTable" id="edfde112-59d8-4fef-831c-76356b881d31">
        <updating/>
        <source>setControllerFromTable(_tbaController : CMIF_TBAContainer input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/09/2014	cnwdap1		PAR #33872 Add measurement types to TBAs
vars
	theTable : CM_EntryTable;
	theSource : String;
	idx : Integer;
	sourceLC : CM_LocationsController;
	reefer: CM_TIReeferProperties;
	isoType: CM_ISOType;
	packDetails: CM_PackTempReading;
begin
	theTable := self.tblEntry;

	_tbaController.id			:=	"TBA";

	isoType := self.cmbISOType.listObject.CM_ISOType; // TFS 45590
	if isoType &lt;&gt; null and isoType.isReefer() then // TFS 45590
		_tbaController.myReeferProperties := self.myProxyReeferDetails; // TFS 45590
	endif;

	self.lstHazardList.getSelectedStringArray(_tbaController.allHazards);
	self.lstHazardList.allSelectedObjects.copy(_tbaController.allTIHazards);
	_tbaController.height			:=	theTable.getValueByName(ETRow_TbaH).Integer;
	_tbaController.width			:=	theTable.getValueByName(ETRow_TbaW).Integer;
	_tbaController.length			:=	theTable.getValueByName(ETRow_TbaL).Integer;
	// DVB changed 30/09/04
	//_tbaController.myCommodity	:=	self.cmbCommodity.listObject.CM_Commodity;
	_tbaController.myCommodity		:=	self.cmbCommodity.myObject.CM_Commodity;
	_tbaController.myDischargePort	:=	self.cmbDischPort.listObject.CM_Port;
	_tbaController.myISOType		:=	self.cmbISOType.listObject.CM_ISOType;
	_tbaController.myLocationSource	:=	self.myLocationSource;
	_tbaController.myLocationTarget	:=	self.myLocationTarget;
	_tbaController.myOperator		:=	self.cmbOperator.listObject.CM_Operator;
	_tbaController.myTerminal		:=	self.myTerminal;
	_tbaController.mySubTerminal	:=	self.cmbSubTerminal.listObject.CM_SubTerminal;
	_tbaController.bookingReference := theTable.getValueByName(ETRow_BookingRef).String;// PAR 20122
	_tbaController.myVoyage			:=	self.myVoyage;
	
	if self.cmbReceive.listIndex &gt; 0 then
		_tbaController.receiveTransportMode	:=	self.cmbReceive.itemData[self.cmbReceive.listIndex];
	else
		_tbaController.receiveTransportMode	:=	TI_TRANSMODE_NULL;
	endif;
	
	_tbaController.state			:=	TI_STATE_TBA;
	_tbaController.weight			:=	theTable.getValueByName(ETRow_TbaWeight).Integer;
	_tbaController.planContainer	:=	self.chkPlan.value;
	
	if _tbaController.myLocationSource = null then
		theSource	:=	theTable.getValueByName(ETRow_TbaYardLocation).String;
		self.myTerminal.findLocationFromString(theSource, false, sourceLC,idx);
		
		if sourceLC = null then // PAR 33695
			app.raiseCMException1(ERR_INVALID_LOCN, theSource, app.getErrorString(Operator_GC),null); // PAR 33695
		else
			_tbaController.myLocationSource := sourceLC; // PAR 33695
		endif;
		
	endif;
	
	theTable.setProxyFromMeasureTables(_tbaController);					// PAR #33872
epilog
end;</source>
        <Parameter name="_tbaController" type="CMIF_TBAContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="122bb7c0-9034-4226-acee-940f4702fb86">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/09/2014	cnwdap1		PAR #33872 Add measurement types to TBAs
vars
	voyCode : String;
begin
//	self.usesQueryFrame := false;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.initTableEntry();

	inheritMethod();

	if self.myVoyage &lt;&gt; null then
		voyCode := " (" &amp; self.myVoyage.code &amp; ")";
	endif;
	self.setCaption(app.getErrorString(CMUI_To_Be_Advised_Container) &amp; voyCode);
	self.lstHazardList.userInputEnabled := true;
	self.resize;
	
	self.loadMeasurementTypes(self.tblEntry, self.tblEntry.myEntTableDef.name, self.tblEntry.myEntTableDef.allEntTableRows, true);	// PAR #33872
end;</source>
    </JadeMethod>
    <JadeMethod name="tblEntry_cellInputReady" id="8fa7791f-a5a5-43ea-8558-0b3d5a7fc879">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntry_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/09/2014	cnwdap1		PAR #33872 Add measurement types for TBAs
// 17/11/2016	cnwdap1		TFS 2842 STWR Hazardou Details Enhancements
vars

begin
	// TFS 2842 don't use hazards control any more, use separate form instead	// TFS 2842
	if inputControl = self.lstHazardList then
	//	table.accessRow(table.row).height := 150;								// TFS 2842
		return;																	// TFS 2842
	endif;
	
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #33872
		app.doMeasureTableCellInputReady(table, inputControl);											// PAR #33872
	endif;																								// PAR #33872
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblEntry_dblClick" id="d14885a5-fdac-421c-89f9-87bb651e0c45">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntry_dblClick(table: CM_EntryTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars
	hazards : ObjectArray;
	reeferForm: CMUI_ReeferDetailsForm;
	isotype : CM_ISOType;
begin
	if table.row = table.getRowByName(ETRow_TbaHazards) then
		create hazards transient;
		self.lstHazardList.allSelectedObjects.copy(hazards);
		self.myAssistant.showHazardousDetailsForm(self.myTerminal, null, null, null, hazards, false, self, self.myMasterMenuAction);
	elseif table.row = table.getRowByName(ETRow_TbaReefer) then			// 16/10/19 MAP TFS 45590
	
		isotype := self.cmbISOType.listObject.CM_ISOType;
		
		if isotype = null or not isotype.isReefer then
			app.msgBox(app.getErrorString(Enter_reefe_detai_reefe_item_n),"Reefer Issue",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
		
		
		if self.myProxyReeferDetails = null then
			create self.myProxyReeferDetails transient;
			self.myProxyReeferDetails .createPackTempReadingIfReqd();
		endif;
		
		self.myAssistant.showReeferDetailsForm(self.myTerminal, self.cmbOperator.listObject.CM_Operator, self.myProxyReeferDetails, self, self.myMasterMenuAction);

	endif;
	
epilog
	delete hazards;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="69e6c4ff-a359-4104-b2cd-18aefa02dd8b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008190, locale);
	chkPlan.translateCaption(Xlat_0001019, locale);
end;</source>
    </JadeMethod>
