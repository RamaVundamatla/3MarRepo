    <JadeMethod name="getGraphicalView" id="9b47dc97-d3bd-4d40-8d8e-f94fd9a64e75">
        <updating/>
        <source>getGraphicalView(optionalParam: ParamListType): WS_GraphicalViewResponse updating;
/*

Purpose: This is the REST version of machineGetGViewTIs

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
22 Feb 2021	jlika1	49429		Initial creation
16 Feb 2022 jlier1  52870		Graphical View changes
16 Feb 2023 NAVSA20 56492       Bug 56492: Error message appearing in vehicle app when overriding with a MAFI location
12 Dec 2023 navsck1 61754       ChangeRequest 61754 [61755]: SNO - The graphical view of the vehicle apps rows upgrading range up to 12 rows
10 Oct 2024	jlizm1	66303		Meaningless Invalid Task Error
============================================================================*/

constants
	 DISPLAY_AS_SLOT = 1;
	 STRADDLE_CONTROLLER = 1;

vars
	response			: WS_GraphicalViewResponse;
	task,theTask 		: CM_RTQueueTask;
	gridController,prevGC	: CM_GridController;
	targetRow, 
	gridRow 			: CM_GridRow;
	gridArea 			: CM_GridArea;
	floor, 
	ceiling, 
	range, 
	difference, 
	row, 
	index, 
	halfRange 			: Integer;
	locControllerArray 	: ObjectArray;
	allTis 				: CM_TISet;
	obj 				: Object;
	ti 					: CM_TrackedItem;
	proxyTi 			: WS_TrackedItemGraphicalView;
	proxyGcRow, 
	proxyGcColumn 		: WS_GridControllerGraphicalView;	
	locationsController : CM_LocationsController;
	gridCont 			: CM_GridController;
	includedCols 		: IntegerArray;
	stackHeight			: Integer;	
	machine	: CM_Machine;
	invalidTask: Boolean;
	locationRequest : String;
	height 			: Integer;			
	terminalArea	: CM_TerminalArea;
	nonGridFound : Boolean;	
	terminal     : CM_Terminal;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	create includedCols transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(false);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	theTask	:= machine.currentQueueTask;
			
	if theTask = null then	
		return response;
	endif;
	
	locationRequest := parseParameterList(optionalParam, 1, String).String.asStringRESTFUL;
	terminal:=app.myPassport.myTerminal;
	on Exception do app.handleDeletedObject( exception, theTask, invalidTask );
	
	theTask.edition;
	if invalidTask then
		return response;
	endif;
	
	if locationRequest = null then
		if theTask.isPickUp then
			locationsController := theTask.sourceLocation;
		else
			locationsController := theTask.targetLocation;
		endif;
	else
		//jlier1 TFS 54701 19/9/22
		if theTask.machineTypeGroup = MACHINETYPEGRP_MAFI then
			return response;
		endif;
		
		if locationRequest.pos(Space, 1) &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; locationRequest.String  &amp;   " terminal =" &amp; terminal.code, LogINFO);
			terminal.findLocationFromString(locationRequest, true, locationsController, height);
		else
			terminalArea := terminal.allTerminalAreas[locationRequest];
			
			//19.01.2021 cnwma1 #50576
			if terminalArea &lt;&gt; null then          
				if  terminalArea.isGridArea then
					locationsController := terminalArea.CM_GridArea.getNextAvailableLocation(terminalArea.CM_GridArea.allGridControllersByRowColumn.first);
				else
					nonGridFound := true;
				endif;
			else
				//jlier1 TFS 56075 23/2/23
				terminal.findLocationFromString(locationRequest, true, locationsController, height);
			endif;
			
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; locationsController.String, LogINFO);
		
		
		// check the location exists
		if locationsController = null and not nonGridFound then
			app.raiseCMException1(Err_InvalidLocation, locationRequest, null, null);       //jlier1 TFS 56075 23/2/23
			return response;
		elseif locationsController &lt;&gt; null and not machine.canMachineAccessTAObj(locationsController.getMyTerminalArea, true) then
			// check the machine is allowed to access the entered area
			app.raiseCMException2(Machine_cannot_access_TA, machine.code, locationsController.getMyTerminalArea.id, null, null);
			return response;
		endif;
	endif;
	
	if invalidTask then		
		// Just log error and return. No real need to show to user
		app.writeLog(method.qualifiedName &amp; Tab &amp; app.getErrorString1(CT_Task_completed,  app.getErrorString(Selected)), LogERROR);
		return response;
	endif;

	
	if locationsController = null or not locationsController.isGridLocation then
		return response;
	endif;
	
	gridController := locationsController.CM_GridController;
	//epr 4/5/21 tfs 49560 - don't want transfer areas with 1 location to show as graphical
	if gridController.myTerminalArea = null or not gridController.myTerminalArea.isGridArea() then
		return response;
	endif;
		
	//drawMode 1 = Straddle 0 = not Straddle
	if gridController.isStraddleController then
		response.drawMode := STRADDLE_CONTROLLER;//1
	endif;
		
	// get range of gridded rows to return
	gridArea := gridController.getMyGridArea();
	targetRow := gridController.myGridRow;
	response.terminalAreaID:=gridArea.id;
	response.terminalAreaMaxStack:=gridArea.heightOfStack;
	
	response.locationIdFormat:="AREAID";
	if gridController.hasSpaceInID then
		response.locationIdFormat:=response.locationIdFormat &amp; ",SPACE";
	endif;
	if gridArea.areLocationIdsColThenRow then
		response.locationIdFormat:=response.locationIdFormat &amp; ",COL,ROW";
	else
		response.locationIdFormat:=response.locationIdFormat &amp; ",ROW,COL";
	endif;
	
	range := 12;		//12.12.2023 navsck1 #61754	[61755]
	halfRange := 6;		//12.12.2023 navsck1 #61754 [61755]
	
	if gridArea.allGridRows.size &gt; (range + 1) then
	
		if (targetRow.row - halfRange) &lt; 1 then
			difference := targetRow.row - 1;
			floor := targetRow.row - difference;
			ceiling := floor + range;
		elseif (targetRow.row + halfRange) &gt; gridArea.allGridRows.size then
			difference := gridArea.allGridRows.size - targetRow.row;
			ceiling := gridArea.allGridRows.size - difference;
			floor := ceiling - range;
		else
			floor := targetRow.row - halfRange;
			ceiling := targetRow.row + halfRange;
		endif;			
	
	else
		floor := 1;
		ceiling := gridArea.allGridRows.size;
	endif;
	
	create locControllerArray transient;
	create allTis transient;

	
	row := floor.max(1);		
	while row &lt;= ceiling do
		gridRow := gridArea.allGridRows[row];
		if gridRow &lt;&gt; null then
			locControllerArray.clear();
			gridRow.getAllLocationsControllers(locControllerArray, false);
						
			create proxyGcRow transient;
			proxyGcRow.row := row;
			proxyGcRow.rowLabel := gridRow.label;
			response.allGridControllers.add(proxyGcRow);
			
			foreach obj in locControllerArray discreteLock do
				gridCont := obj.CM_GridController;
				if gridCont.isGap then
					create proxyTi transient;
					proxyTi.row := row;
					proxyTi.column := gridCont.column;
					proxyTi.displayAttribute := DISPLAY_AS_SLOT;//1
					response.allTrackedItems.add(proxyTi);
				endif;

				if not includedCols.includes(gridCont.column) then				
					create proxyGcColumn transient;
					proxyGcColumn.column := gridCont.column;
					if not gridCont.isGap then
						proxyGcColumn.columnLabel := gridCont.myGridColumn.label;
						proxyGcColumn.columnLabel40 := gridCont.get40ftColumnLabel;
					endif;
					response.allGridControllers.add(proxyGcColumn);
					includedCols.add(gridCont.column);
				endif;
		
				index := 1;
				while index &lt;= gridCont.allTrackedItems.size do
					ti := gridCont.allTrackedItems[index]; 
					
					if allTis.includes(ti) then
						index := index + 1;
						continue;
					endif;
					
					create proxyTi transient;
					proxyTi.setProxyFromObject(ti);
					proxyTi.row := row;
					proxyTi.column := gridCont.column;
					proxyTi.stack := index;
					proxyTi.maxStackHeight := gridCont.getMaxStackingHeight();
					response.allTrackedItems.add(proxyTi);
					
					allTis.add(ti);
					
					index := index + 1;
				endwhile;
								
				
			endforeach;
		endif;
		row := row + 1;
	endwhile;
		
	
	//add the TI that we are shifting
	if theTask.isSetDown then
		//twin lift display both
		foreach task in machine.allCurrentWorkingQueueTasks discreteLock do 
						
				
				if locationRequest = null and task.targetLocation &lt;&gt; null then	
					// TFS 53846 23/6/22
					if task.targetLocation.isKindOf(CM_GridController) then
						gridController := task.targetLocation.CM_GridController;
					endif;
				endif;	
				if gridController = null then
					continue;
				endif;
				create proxyTi transient;
				stackHeight:=gridController.allTrackedItems.size + 1;
				if machine.isTandemLift and prevGC &lt;&gt; null and prevGC = gridController then
					stackHeight:=stackHeight +1;
				endif;
				
				ti := task.ti;
				proxyTi.setProxyFromObject(ti);

				proxyTi.row := gridController.row;
				proxyTi.column := gridController.column;
				proxyTi.stack := stackHeight;
				proxyTi.maxStackHeight:=gridController.getMaxStackingHeight(); //jlier1 TFS 54532 16/8/22
				response.allTrackedItems.add(proxyTi);
				prevGC:=gridController;
		
		endforeach;
	endif;	
	
	if invalidTask then		
		// Just log error and return. No real need to show to user
		app.writeLog(method.qualifiedName &amp; Tab &amp; app.getErrorString1(CT_Task_completed,  app.getErrorString(Selected)), LogERROR);
	endif;
		
	return response;
epilog
	delete includedCols;
	delete locControllerArray;
	delete allTis;
		
	finaliseResponse(response);	
end;
	
</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_GraphicalViewResponse"/>
    </JadeMethod>
    <JadeMethod name="getHasAvailableTask" id="d20cbf98-9cf7-44a1-b53f-574ce1ac0cdc">
        <updating/>
        <source>getHasAvailableTask(): WS_MachineHasTasksResponse updating;
/*

Purpose: This is the REST version of machineHasAvailableTask

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 	: CM_Machine;	
	response	: WS_MachineHasTasksResponse;				
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	self.setIgnoreWarnings(true);	
	
	//jlier1 TFS 56004 31/1/22
	response.isWorkingTask:=machine.allCurrentWorkingQueueTasks.first &lt;&gt; null;
	response.hasAvailableTasks := app.myTrxUA.trxMachineHasAvailableTasks(machine, app.myPassport);
	
	
	
	return response;
	
epilog	
	finaliseResponse(response);
	
end;
	
</source>
        <ReturnType type="WS_MachineHasTasksResponse"/>
    </JadeMethod>
    <JadeMethod name="getHasAvailableTasksChanged" id="987d31fb-5cd3-4fa8-b877-feb50203f0ce">
        <updating/>
        <source>getHasAvailableTasksChanged(): WS_MachineListChgResponse updating;
/*

Purpose: This is the REST version of machineHasListChanged

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 		 : CM_Machine;		
	index		 	 : Integer;		
	response		 : WS_MachineListChgResponse;
	allTasks 		 : CM_RTQueueTaskArray; 	
	machineTaskState : CM_MachineTaskState;
	machineTaskStates : CM_MachineTaskStateArray;
	task 			 : CM_RTQueueTask;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	self.setIgnoreWarnings(true);
	if machine.allCurrentQueueTasks.size &gt; 0 then		
		response.listHasChanged := true;
		return response;
	endif;
	
	create allTasks transient;
	machine.getAllAvailableQueuesTasks(allTasks);			
	
	//quick test if task size is different 
	if machine.allMachineTaskStates.size &lt;&gt; allTasks.size then		
		response.listHasChanged := true;
		return response;
	endif;
	
	//jlier1 MTN-19209  7/10/24 was causing 1308 exception
	create machineTaskStates transient;
	machine.allMachineTaskStates.copy(machineTaskStates);
	index:=1;
	foreach machineTaskState in machineTaskStates discreteLock do
		task:=allTasks[index];
		if not machineTaskState.isMatch(task) then			
			response.listHasChanged := true;
			return response;
		endif;
		
		index:=index+1;
	endforeach;
	
	response.listHasChanged := false;
		
	return response;
	
epilog	
	delete allTasks;
	delete machineTaskStates;
	finaliseResponse(response);
	
end;
	
</source>
        <ReturnType type="WS_MachineListChgResponse"/>
    </JadeMethod>
    <JadeMethod name="getHasCurrentTasksChanged" id="cb545692-7ad7-4bd4-baf4-7b0b708f49c5">
        <updating/>
        <source>getHasCurrentTasksChanged(): WS_MachineListChgResponse updating;
/*

Purpose: This is the REST version of machineHasIMVTasksChanged

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 		 : CM_Machine;			
	response		 : WS_MachineListChgResponse;
	allTasks 		 : CM_RTQueueTaskArray; 
	index			 : Integer;
	machineTaskState : CM_MachineTaskState;
	machineTaskStates : CM_MachineTaskStateArray;
	task 			 : CM_RTQueueTask;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	self.setIgnoreWarnings(true);
	create allTasks transient;
	machine.allCurrentQueueTasks.copy(allTasks);			
	
	//quick test if task size is different 
	if machine.allMachineTaskStates.size &lt;&gt; allTasks.size then		
		response.listHasChanged := true;
		return response;
	endif;
	
	//jlier1 MTN-19209  7/10/24 was causing 1308 exception
	create machineTaskStates transient;
	machine.allMachineTaskStates.copy(machineTaskStates);
	index := 1;
	foreach machineTaskState in machineTaskStates discreteLock do
		task := allTasks[index];
		if not machineTaskState.isMatch(task) then			
			response.listHasChanged := true;
			return response;
		endif;
		
		index := index + 1;
	endforeach;
		
	return response;
	
epilog	
	delete allTasks;
	delete machineTaskStates;
	finaliseResponse(response);
	
	
end;
	
</source>
        <ReturnType type="WS_MachineListChgResponse"/>
    </JadeMethod>
    <JadeMethod name="getHasMessages" id="6b5a1058-bb5c-40dc-ae15-b705c195aa85">
        <updating/>
        <source>getHasMessages(): Boolean updating;
/*

Purpose: This is the REST version of machineHasControlMessages

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 		: CM_Machine;		
	iter 			: Iterator;
	history			: CM_MachineHistory;
	infoHistory		: CM_MachineInfoHistory;	
	lastMessageTS 	: TimeStamp;
	response		: Boolean;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	lastMessageTS := machine.lastGetMessagesTS;
	if lastMessageTS = null then		
		return response;
	endif;	
	
	
	iter := machine.history.createIterator;
	while iter.back(history) do
		
		if history.dateTime &lt; lastMessageTS then
			break;
		endif;
		
		if not history.isKindOf(CM_MachineInfoHistory) then
			continue;
		endif;
		
		infoHistory:= history.CM_MachineInfoHistory;
		if infoHistory.infoType = CM_MachineInfoHistory.InfoType_Status_Change or 
			infoHistory.infoType = CM_MachineInfoHistory.InfoType_Restore_Status then
			continue;
		endif;
		
		//only interested in stuff updated from JMT
		if infoHistory.appName &lt;&gt; JMTerminal then
			continue;
		endif;
		
		response := true;
		
		return response;
		
	endwhile;		
	
	return response;
	
epilog	
	delete iter;

	finaliseBooleanResponse(response);
	
	return response;
end;
	
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIMEXStatuses" id="36b22d82-4bc8-421b-83ab-81b825f78a80">
        <updating/>
        <source>getIMEXStatuses() : WS_IMEXStatusesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022

*/

vars
	response		: WS_IMEXStatusesResponse;
	imexStatus		: CM_IMEXStatus;
	proxyImexStatus	: WS_IMEXStatus;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	foreach imexStatus in app.myRoot.allImexStatuses discreteLock do
		
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);
	endforeach;
	
	return response;
epilog

	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_IMEXStatusesResponse"/>
    </JadeMethod>
    <JadeMethod name="getISOTypes" id="f8493875-2b48-4442-a017-c99e10ce8463">
        <updating/>
        <source>getISOTypes(optionalParam : ParamListType)  : WS_ISOTypesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	jlier1	Initial creation 53022

*/

vars
	response		: WS_ISOTypesResponse;
	isoType			: CM_ISOType;
	proxyISOType	: WS_ISOType;
	cargoTypeObj  : CM_CargoType;
	iter 		: Iterator;
	cargoType : String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;

	// Create the response
	create response transient;
	
	cargoType:=parseParameterList(optionalParam, 1, String).String;
	if cargoType &lt;&gt; null then
		cargoTypeObj := app.myPassport.getObjectOfTypeFromOid( cargoType,CM_CargoType).CM_CargoType;
		if app.myPassport.hasErrors then
			return response;
		endif;
		
		if cargoTypeObj = null then
			//lets try the id
			cargoTypeObj := app.myRoot.allCargoTypesById[cargoType.Integer];
		endif;
	endif;
	
	if cargoTypeObj &lt;&gt; null then
		iter:=cargoTypeObj.allISOTypes.createIterator;
	else
		iter:=app.myRoot.allISOTypes.createIterator;
	endif;
	
	while iter.next(isoType) do	
		if isoType.isNotAvailableForEntry then
			continue;
		endif;
	
		create proxyISOType transient;
		proxyISOType.setProxyFromObject(isoType);
		//proxyISOType.description:=isoType.description.asStringJSON;
		
		proxyISOType.comboboxDescription:=null;
		response.allISOTypes.add(proxyISOType);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_ISOTypesResponse"/>
    </JadeMethod>
    <JadeMethod name="getInstructionTypes" id="fabb9021-cb80-40c6-b2f6-ab5b247ed5ea">
        <updating/>
        <source>getInstructionTypes():WS_RestIntInstTypesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2023	navma1	ChangeRequest 61234: SAL - Mobile App - Unpack container throws Error code:-999

*/

vars
	response 	 		 : WS_RestIntInstTypesResponse;
	instructionType 	 : CM_InstructionType;
	wsInstructionType 	 : WS_RestIntInstructionType;
	term	 	 	 	 : CM_Terminal;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	foreach instructionType in term.allInstructionTypes do
		create wsInstructionType transient;
		wsInstructionType.setProxyFromObject(instructionType);
		response.allInstructionTypes.add(wsInstructionType);
		
	endforeach;
	return response;
epilog

	finaliseResponse(response);
end;</source>
        <ReturnType type="WS_RestIntInstTypesResponse"/>
    </JadeMethod>
    <JadeMethod name="getInterchangeAreas" id="6ffec421-f6c1-47b6-99f4-4fad08e70ec3">
        <updating/>
        <source>getInterchangeAreas() : WS_TerminalAreaMasterResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
06 August 2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
07 April 2022	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	response 	: WS_TerminalAreaMasterResponse;
	area 		: WS_TerminalAreaMaster;
	theTAs		: CM_TAByTypeIdDict;
	iter		: Iterator;
	terminalArea: CM_TerminalArea;
	failedDAC	: CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	theTAs	:=	app.myPassport.myTerminal.allTerminalAreasByTypeId;
	iter	:=	theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_YARD_INTERCHANGE, null, iter);
	
	while iter.next(terminalArea) do
		if terminalArea.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		
		if not terminalArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
			
		
		create area transient;
		area.setProxyFromObject(terminalArea);
		response.allTAMasters.add(area);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeMethod>
    <JadeMethod name="getJobDetails" id="f697cedf-07aa-477e-85aa-5862f9613995">
        <updating/>
        <source>getJobDetails(_job : String):WS_RestIntJobsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023 navhl20 ChangeRequest 60640:[60641] EUP | Mobile DD - Packing Jobs
01 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders
*/

vars
	response 		: WS_RestIntJobsResponse;
	term			: CM_Terminal;
	job,
	operJob			: CM_Job;
	wsJob			: WS_RestIntJob;
	wsRequest		: WS_RestIntJobRequest;
	class			: Class;
	request			: CM_Request;
	wsRequestArr   	: WS_RestIntJobRequestArray;
	operJobStr		: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	if not app.myPassport.isVASEnabled  then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if _job = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	job := app.myPassport.getObjectOfTypeFromOid(_job, CM_Job).CM_Job;
	
	operJobStr := self.qsData.getValue(QueryParam_operationalJobOid).asStringJMT();			//01.10.2024 navhl20 #32981
	if operJobStr &lt;&gt; null then																//01.10.2024 navhl20 #32981
		operJob := app.myPassport.getObjectOfTypeFromOid(operJobStr, CM_Job).CM_Job;
	endif;
	
	if job = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	//class := self.getWSJobClass(job);
	class := WS_RestWebServiceAgent@getWSJobClass(job);
	create wsJob as class transient  ;
	wsJob.setProxyFromObject(job);	
	
	create wsRequestArr transient;
	//self.getWSJobRequest(job,wsRequestArr);
	WS_RestWebServiceAgent@getWSJobRequest(job,operJob,wsRequestArr);						//01.10.2024 navhl20 #32981
	wsRequestArr.copy(wsJob.allRequests);
	
	response.allJobs.add(wsJob);
	
	return response;
epilog
	self.finaliseResponse(response);
	delete wsRequestArr;
end;</source>
        <Parameter name="_job" type="String"/>
        <ReturnType type="WS_RestIntJobsResponse"/>
    </JadeMethod>
    <JadeMethod name="getJobSheetsForVoyage" id="7f2a99d3-f910-4daa-a4ef-f14bbb5c2cc2">
        <updating/>
        <source>getJobSheetsForVoyage(_code : String; _type : String):WS_JobSheetResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2023 navhl20 ChangeRequest 61361:[61424] MTN - Work Hold Jobs on Job Lander [React Version]
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	response 		: WS_JobSheetResponse;
	term			: CM_Terminal;
	voyage 			: CM_Voyage;
	job				: CM_Job;
	jobSheet		: CM_JobSheet;
	pxyJobSheet		: WS_JobSheet;
	wle 			: CM_WorkListEntry;
	ti 				: CM_TrackedItem;
	type			: Integer;
	forEUP			: Boolean;
	wpJobSheet		: CM_WorkPointJobSheet;
	voyageProcess 	: CM_VoyageProcess;
	todayDT			: Date;
	jobSheetDict 	: CM_WPJobSheetByDate;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	// Create the response
	create response transient;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	type   			:= _type.Integer;
	voyage 			:= term.lookupVoyage(_code,null,false);
	
	if voyage = null then																								//25.02.2025 navma1 #MTN-34075
		return response;
	endif;
	
	if type = JOB_TYPE_DISCHARGE
	or type = JOB_TYPE_LOAD
	or type = JOB_TYPE_SOB then
		
		voyageProcess 	:= term.getDefaultVoyageProcess();													//18.12.2023 navhl20 #58400[61617]
		forEUP 			:= voyageProcess.isEUPDefaultProcess;												//18.12.2023 navhl20 #58400[61617]
		
		if not forEUP then																					//01.12.2023 navhl20 #58400[61617]
			foreach jobSheet in voyage.allJobSheets  discreteLock do										//25.02.2025 navma1 #MTN-34075
				foreach job in jobSheet.allJobsByOrder  discreteLock do										//25.02.2025 navma1 #MTN-34075
					// add jobsheet if it has at least one incomplete job of the correct type
					if job.jobType = type and not job.isJobComplete then
						create pxyJobSheet transient;
						pxyJobSheet.setProxyFromObject(jobSheet);
						response.allJobSheets.add(pxyJobSheet);
						break;
						
					elseif type = JOB_TYPE_SOB and job.jobType = JOB_TYPE_DISCHARGE and not job.isJobComplete then
						// Hold SOB jobs look like discharge jobs, but the cargo is marked as SOB
						wle := job.workListEntries.first;
						if wle &lt;&gt; null then
							ti := wle.myTrackedItem;
							if ti &lt;&gt; null and ti.isSOB then
								create pxyJobSheet transient;
								pxyJobSheet.setProxyFromObject(jobSheet);
								response.allJobSheets.add(pxyJobSheet);
								break;
							endif;
						endif;
					endif;
				endforeach;
			endforeach;
		else																										//01.12.2023 navhl20 #58400[61617]
			
			todayDT := app.actualTimeServer().date;																	//25.02.2025 navma1 #MTN-34075
			create jobSheetDict transient;
			term.allJobSheetsForWorkPoints.copy(jobSheetDict);														//25.02.2025 navma1 #MTN-34075
			
			foreach wpJobSheet in jobSheetDict discreteLock do														//25.02.2025 navma1 #MTN-34075
				if wpJobSheet.myShift.startDateTime.date &lt;&gt; todayDT then											//25.02.2025 navma1 #MTN-34075
					continue;
				endif;
				
				if wpJobSheet.myWorkPoint.myWorkPointType.type &lt;&gt; WORK_POINT_TYPE_SHIP then
					continue;
				endif;
				
				if not wpJobSheet.isMatchingForVoyage(voyage) then
					continue;
				endif;
				
				create pxyJobSheet transient;
				pxyJobSheet.setProxyFromObject(wpJobSheet);
				response.allJobSheets.add(pxyJobSheet);
			endforeach;
		endif;
		
	endif;

	return response;	
epilog
	delete jobSheetDict;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="String"/>
        <ReturnType type="WS_JobSheetResponse"/>
    </JadeMethod>
    <JadeMethod name="getJobs" id="3539a90e-c99c-41f3-8c1e-9030c2cfcce8">
        <updating/>
        <source>getJobs(_jobSheet : String):WS_RestIntJobsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1  EUP | Mobile DD - [BackEnd] Mobile App list of Jobs - Road
22 Sep 2023 navhl20 ChangeRequest 60640:[60641] EUP | Mobile DD - Packing Jobs
14 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
19 Mar 2024 navma1	Bug 62865: MTN - Error 4s During Performance Runs (getMyWagon)
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	response 		: WS_RestIntJobsResponse;
	term			: CM_Terminal;
	job		    	: CM_Job;
	wsJob			: WS_RestIntJob;
	class			: Class;
	jobSheet		: CM_JobSheet;
	jobSet			: CM_JobSet;
	passport		: CM_Passport;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	create response transient;
	
	passport := app.myPassport;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if passport.hasErrors then
		return response;
	endif;	
	
	// Create the response
	create response transient;
	
	term := passport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	if not passport.isVASEnabled  then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	create jobSet transient;													//19.03.2024 navma1 #62865
	
	if _jobSheet = app.getErrorString(All) then									//14.11.2023 navhl20 #58756[60740]
		
		term.myWOJobSheet.allJobsByRequiredDTPriority.copy(jobSet);				//19.03.2024 navma1 #62865 	//25.02.2025 navma1 #MTN-34075
		foreach job in jobSet discreteLock do									//19.03.2024 navma1 #62865
			
			if job.status = JOB_COMPLETE then
				continue;
			endif;
			
			if not job.isKindOf(CM_WOToDoTaskJob) then							//22.9.2023 navhl20 #60640[60641]
				continue;
			endif;
			
			create wsJob as WS_RestIntTodoJob transient;
			wsJob.setProxyFromObject(job);	
			response.allJobs.add(wsJob);
		endforeach;
	else
		if _jobSheet = null   then
			self.httpStatusCode := HttpResponseNotFound;
			return response;
		endif;
		
		jobSheet := passport.getObjectOfTypeFromOid(_jobSheet, CM_JobSheet).CM_JobSheet;
		
		if jobSheet = null then
			self.httpStatusCode := HttpResponseNotFound;
			return response;
		endif;
	
		jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);				//19.03.2024 navma1 #62865	//25.02.2025 navma1 #MTN-34075
		
		foreach job in jobSet discreteLock do								//19.03.2024 navma1 #62865
			
			if job.status = JOB_COMPLETE then
				continue;
			endif;
			
			if not job.canBeIncludeOnWS() then								//22.9.2023 navhl20 #60640[60641]
				continue;
			endif;			
	
			class := WS_RestWebServiceAgent@getWSJobClass(job);
			
			create wsJob as class transient;
			wsJob.setProxyFromObject(job);	
			response.allJobs.add(wsJob);
		endforeach;
	endif;
	
	return response;
epilog
	delete jobSet;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_jobSheet" type="String"/>
        <ReturnType type="WS_RestIntJobsResponse"/>
    </JadeMethod>
    <JadeMethod name="getJobsForJobSheet" id="e2ff7ec0-1a64-40ed-a4d4-fdf00bb4042a">
        <updating/>
        <source>getJobsForJobSheet(_code : String; _type : String; _voyageId : String):WS_JobResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023 navhl20 ChangeRequest 61361:[61424] MTN - Work Hold Jobs on Job Lander [React Version]
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
18 Apr 2025	navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues
*/

vars
	response 		: WS_JobResponse;
	term			: CM_Terminal;
	job				: CM_Job;
	jobSheet		: CM_JobSheet;
	pxyJob			: WS_Job;
	wle 			: CM_WorkListEntry;
	ti 				: CM_TrackedItem;
	type			: Integer;
	forEUP			: Boolean;
	recJob			: CM_WOReceiveCargoJob;
	relJob			: CM_WOReleaseCargoJob;
	voyageProcess 	: CM_VoyageProcess;
	jobArr			: CM_JobArray;
	jobSet			: CM_JobSet;
	voyage     		: CM_Voyage;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	// Create the response
	create response transient;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	jobSheet 		:= app.myPassport.getObjectOfTypeFromOid(_code, CM_JobSheet).CM_JobSheet;
	type     		:= _type.Integer;
	if _voyageId &lt;&gt; null then
		voyage     		:= term.lookupVoyage(_voyageId,null,false);								//18.04.2025 navhl20 #34624
	endif;
	voyageProcess 	:= term.getDefaultVoyageProcess();											//18.12.2023 navhl20 #58400[61617]
	forEUP 			:= voyageProcess.isEUPDefaultProcess;										//18.12.2023 navhl20 #58400[61617]
	
	if not forEUP then																			//01.12.2023 navhl20 #58400[61617]
		if jobSheet &lt;&gt; null then
			if type = JOB_TYPE_DISCHARGE or type = JOB_TYPE_LOAD then
				
				create jobArr transient;
				jobSheet.allJobsByOrder.copy(jobArr);											//25.02.2025 navma1 #MTN-34075
				
				foreach job in jobArr discreteLock  do											//25.02.2025 navma1 #MTN-34075
					if job.jobType = type and not job.isJobComplete then
						create pxyJob transient;
						pxyJob.setProxyFromObject(job);
						response.allJobs.add(pxyJob);
					endif;
				endforeach;	
				
			elseif type = JOB_TYPE_SOB then
				
				create jobArr transient;
				jobSheet.allJobsByOrder.copy(jobArr);											//25.02.2025 navma1 #MTN-34075
				
				foreach job in jobArr discreteLock do											//25.02.2025 navma1 #MTN-34075
					// First, check for regular SOB jobs
					if job.jobType = type and not job.isJobComplete then
						create pxyJob transient;
						pxyJob.setProxyFromObject(job);
						response.allJobs.add(pxyJob);
					
					// Hold SOB jobs look like discharge jobs, but the cargo is marked as SOB
					elseif job.jobType = JOB_TYPE_DISCHARGE and not job.isJobComplete then
						wle := job.workListEntries.first;
						if wle &lt;&gt; null then
							ti := wle.myTrackedItem;
							if ti &lt;&gt; null and ti.isSOB then
								create pxyJob transient;
								pxyJob.setProxyFromObject(job);
								response.allJobs.add(pxyJob);
							endif;
						endif;
					
					endif;
				endforeach;	
			endif;
		endif;
	else
		if jobSheet &lt;&gt; null then
			
			create jobSet transient;
			jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);							//25.02.2025 navma1 #MTN-34075
			
			foreach job in jobSet discreteLock do										//25.02.2025 navma1 #MTN-34075
				
				if job.jobType &lt;&gt; type then
					continue;
				endif;
				
				if not job.isVoyageWorkpointJob then									//25.02.2025 navma1 #MTN-34075
					continue;
				endif;
				
				if job.isJobComplete then
					continue;
				endif;
				
				if voyage &lt;&gt; null and job.CM_VoyageWorkPointJob.myVoyage &lt;&gt; voyage then					//18.04.2025 navhl20 #34624
					continue;
				endif;
				
				recJob := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
				relJob := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
				
				if recJob &lt;&gt; null and recJob.allTrackedItems.isEmpty() then
					continue;
				elseif relJob &lt;&gt; null and relJob.allTrackedItems.isEmpty() then
					continue;
				endif;
				
				create pxyJob transient;
				pxyJob.setProxyFromObject(job);
				response.allJobs.add(pxyJob);
			endforeach;
		endif;
	endif;
	
	return response;	
epilog
	delete jobArr;
	delete jobSet;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_voyageId" type="String"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeMethod>
    <JadeMethod name="getLoadedCargoAmount" id="7b0ea2ac-1790-469e-a605-2fb0b625a056">
        <updating/>
        <source>getLoadedCargoAmount(voyageOid : String; mode : Integer) : WS_CargoAmountResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2025 navhl20 Bug MTN-35479: STWO - Limited show of units in Truck Loader

*/

vars
	response 		: WS_CargoAmountResponse;
	voyage 			: CM_Voyage;
	tiSet			: CM_TISet;
	weight			: Decimal[12,4];
	quantity		: Integer;
	totalQuantity	: Integer;
	ti 				: CM_TrackedItem;
	term			: CM_Terminal;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;		
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	voyage := app.myPassport.getObjectOfTypeFromOid(voyageOid,CM_Voyage).CM_Voyage;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if voyage = null then
		app.raiseCMException1(Voyage_not_found, voyageOid, null, null);
		return response;
	endif;	
	
	create tiSet transient;
	
	if mode = DiscHHLander_Both or mode = DiscHHLander_ToMach or mode = SOB_MOVETYPE then
		voyage.allOnshipTIsByIdCargoType.tryCopy(tiSet);
	elseif mode = LOAD_MOVETYPE then
		voyage.allOnsiteTIsByIdCargoType.tryCopy(tiSet);
	endif;
	
	quantity := 0;
	
	foreach ti in tiSet do
		if mode = LOAD_MOVETYPE then
			if not (ti.getImExStatus = TI_IMEX_STATUS_EXPORT or ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP) then
				continue;
			endif;
		else
			if not (ti.getImExStatus = TI_IMEX_STATUS_IMPORT or ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP) then
				continue;
			endif;
		endif;
		if ti.isChild then
			continue;
		endif;
		
		quantity := quantity + 1;
		totalQuantity := totalQuantity + ti.totalQuantity;
		weight := weight + ti.totalWeight;
	endforeach;

	response.quantity := quantity;
	response.totalQuantity := totalQuantity;
	response.totalWeight := weight.asStringJMT();
	
	return response;
epilog
	delete tiSet;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="voyageOid" type="String"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="WS_CargoAmountResponse"/>
    </JadeMethod>
    <JadeMethod name="getLogTransaction" id="0dbe0757-6dea-4946-843d-cd2f8acec1c4">
        <updating/>
        <source>getLogTransaction(_code : String):WS_JobResponse updating;
/*

Purpose:			
Allow external layers to log things to JSM

Parameters:			

Return Value:		

Date		Who		Reason
03 JAN 2024 navmj1  ChangeRequest 59468: REST end point to allow logging to JSM
*/

vars
	response 		: WS_JobResponse;
	cnTrxId 		: Integer;
begin	
	// Create the response
	create response transient;	
	
	
	cnTrxId := cnStartTransaction(method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	
	return response;	
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeMethod>
    <JadeMethod name="getMAFIForLoad" id="4a015ffc-d394-41f6-bc4c-a88ba500c54e">
        <updating/>
        <source>getMAFIForLoad(mafiID : String; optionalParam : ParamListType) : WS_MAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2022	jlier1	Initial creation 54703

*/

vars
	response : WS_MAFIResponse;
	mafi : CM_TILC;
	wsTrailer : WS_Trailer;
	areaID : String;
	ta : CM_TerminalArea;
	foundHeight : Integer;
	terminal : CM_Terminal;
	lc : CM_LocationsController;
	foundTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//check permission - still to created the permission
	
	terminal:=app.myPassport.myTerminal;
	if mafiID = null then
		app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
		return response;
	endif;
	//find a trailer with mafiID 
	// if not found return error
	mafi:=terminal.lookupTrailerOnsite(mafiID, null);
	if mafi = null then
		//jlier1 TFS 61121 10/11/12
		create foundTIs transient;
		terminal.lookupAllOnsiteTrailers(null,mafiID,foundTIs,true,null);
		foreach ti in foundTIs discreteLock do
			if ti.CM_TILC.isMAFI then
				if mafi &lt;&gt; null then
					//there is more than one 
					mafi:=null;
					break;
				endif;
				mafi:=ti.CM_TILC;
			endif;
		endforeach;
		if mafi = null then
			//raise exception
			app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
			return response;
		endif;
	endif;
	
	//check it is a mafi
	// if not a mafi return error
	if mafi &lt;&gt; null and not mafi.isMAFI then
		app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
		return response;
	endif;
	
	areaID	:= parseParameterList(optionalParam, 1, String).String;
	if areaID &lt;&gt; null then
		ta := terminal.allTerminalAreas[areaID];
		//terminal.findTAFromString(locationID,true,foundLC,foundHeight);
		if ta &lt;&gt; null then
			response.locationOid:=ta.getOidAsString;
		else
			//give error
			// Can not find Terminal Area %1
			app.raiseCMException1(Not_find_termina_area,areaID,null,null);
			return response;
		endif;
	
		//check the mafi is in the current area
		if ta.getTiById(mafiID) = null then
			// Mafi %1 must be in the source area %1
			app.raiseCMException2(Mafi_must_source_area,mafiID,areaID,null,null);
			return response;
		endif;
	endif;
	
	create wsTrailer transient;
	wsTrailer.setProxyFromObject(  mafi );
	response.myMAFI:= wsTrailer;
	
	
	return response;
epilog
	delete foundTIs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="mafiID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_MAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="getMAFIForUnload" id="e8040213-2bd1-42b4-b4b4-4ac975e9c84f">
        <updating/>
        <source>getMAFIForUnload(mafiID : String; locationID : String) : WS_MAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2022	jlier1	Initial creation 54703

*/

vars
	response : WS_MAFIResponse;
	mafi : CM_TILC;
	wsTrailer : WS_Trailer;
	location : CM_LocationsController;
	foundHeight : Integer;
	terminal : CM_Terminal;
	lc : CM_LocationsController;
	tis : CM_TISet;
	foundTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//check permission - still to created the permission
	if mafiID = null then
		app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	//find a trailer with mafiID 
	// if not found return error
	mafi:=terminal.lookupTrailerOnsite(mafiID, null);
	if mafi = null then
		//jlier1 TFS 61121 10/11/12
		create foundTIs transient;
		terminal.lookupAllOnsiteTrailers(null,mafiID,foundTIs,true,null);
		foreach ti in foundTIs discreteLock do
			if ti.CM_TILC.isMAFI then
				if mafi &lt;&gt; null then
					//there is more than one 
					mafi:=null;
					break;
				endif;
				mafi:=ti.CM_TILC;
			endif;
		endforeach;
		if mafi = null then
		
			//raise exception
			app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
			return response;
		endif;
	endif;
	
	//check it is a mafi
	// if not a mafi return error
	if mafi &lt;&gt; null and not mafi.isMAFI then
		app.raiseCMException1(Not_find_mafi_onsite,mafiID,null,null);
		return response;
	endif;
	
	terminal.findLocationFromString(locationID,true,location,foundHeight);
	if location &lt;&gt; null then
		response.locationOid:=location.getOidAsString;
	else
		//give error
		app.raiseCMException1(Err_LocationNotFound,locationID,null,null);
	endif;
	
	create tis transient;
	mafi.getAllOnboardTIs(tis);
	
	if tis.first = null then
		app.raiseCMException1(Mafi_does_not_have_cargo_unloa,mafiID,null,null);
		return response;
	endif;
	
	create wsTrailer transient;
	wsTrailer.setProxyFromObject(  mafi );
	response.myMAFI:= wsTrailer;
	
	
	return response;
epilog
	delete foundTIs;
	delete tis;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="mafiID" type="String"/>
        <Parameter name="locationID" type="String"/>
        <ReturnType type="WS_MAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="getMAFITaskResources" id="8551090e-4303-4169-a8a1-150c71afcfc6">
        <updating/>
        <source>getMAFITaskResources() : WS_ResourceTypesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	jlier1	Initial creation 54703

*/

vars
	response : WS_ResourceTypesResponse;
	lashingToDoDesc : CM_ToDoTaskDesc;
	obj				: CM_Object;
	resource		: CM_ResourceType;
	wsResource		: WS_ResourceType;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	lashingToDoDesc:=app.myPassport.myTerminal.getConfig(ToDoTaskMAFILashing).CM_ToDoTaskDesc;
	
	if lashingToDoDesc = null then
		return response;
	endif;
	
	foreach obj in lashingToDoDesc.allResourceTypes discreteLock  do
		if obj.isKindOf(CM_ResourceType) then
			resource := obj.CM_ResourceType;
			if not resource.isAvailable then
				continue;
			endif;
			
			create wsResource transient;
			wsResource.setProxyFromObject(resource);
			response.allResourceTypes.add(wsResource);
		endif;
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_ResourceTypesResponse"/>
    </JadeMethod>
    <JadeMethod name="getMAFIValidForCargo" id="28ae4bd1-f1e9-46a2-bb49-e72d617376dd">
        <updating/>
        <source>getMAFIValidForCargo(_locationID : String; cargoOid : String) : WS_MAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
24 Feb 2023		jlizm1	Initial creation TFS 56720 Running weight total for MAFIs
30 Oct 2023 	jlier1 TFS 60822
*/

vars

	response 	: WS_MAFIResponse;
	terminal 	: CM_Terminal;
	foundLC		: CM_LocationsController;
	foundHeight	: Integer;
	mafi		: CM_TILC;
	cargo		: CM_TrackedItem;
	wsTrailer 	: WS_Trailer;
	foundTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
	locationID 	: String;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	locationID:=_locationID.asStringRESTFUL;
	terminal := app.myPassport.myTerminal;
	terminal.findLocationFromString(locationID, true, foundLC, foundHeight);
	
	if foundLC = null then
		//jlier1 TFS 61121 10/11/12
		if locationID &lt;&gt; null then
			create foundTIs transient;
			terminal.lookupAllOnsiteTrailers(null,locationID,foundTIs,true,null);
			foreach ti in foundTIs discreteLock do
				if ti.CM_TILC.isMAFI then
					if foundLC &lt;&gt; null then
						//there is more than one 
						foundLC:=null;
						break;
					endif;
					foundLC:=ti.CM_TILC.allLCs.first;
				endif;
			endforeach;
		endif;
	
		if foundLC = null then
			//raise exception
			app.raiseCMException1(Location_NotFound, locationID, null, null);
			return response;
		endif;
	endif;
	
	if not foundLC.isTILCController then
		return response;
	endif;
	
	mafi := foundLC.CM_TILCController.myTILC;
	
	if mafi = null or not mafi.isMAFI then
		return response;
	endif;
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	if mafi.myTILCType.maxWeight &lt;&gt; 0 then
		if cargo.totalWeight +  mafi.weightCargo &gt; mafi.myTILCType.maxWeight then
			app.raiseCMWarning2(ERR_TI_CANNOT_PLACE_WEIGHT, cargo.id, mafi.id, null, null, null);
		endif;
	endif;
	
	mafi.validateCargoMatchesVoyOpDisch(cargo);
	
	create wsTrailer transient;
	wsTrailer.setProxyFromObject(mafi);
	response.myMAFI := wsTrailer;
	
	return response;
	
epilog
	delete foundTIs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_MAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="getMAFIValidForTask" id="ba1461c9-2a01-4e81-b529-efa9151a2b26">
        <updating/>
        <source>getMAFIValidForTask(_locationID : String) : WS_MAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 October 2022		jlier1	Initial creation 54676
23 Februrary 2023	jlizm1	TFS 56720 Running weight total for MAFIs
30 October 2023		jlier1	CUX | Change mismatched operator from error to warning
30 Oct 2023 	jlier1 TFS 60822
*/
constants
	LocationOK = 0;
	LocationError = 1;
	LocationWarn = 2;
vars
	response 	: WS_MAFIResponse;
	mafi 		: CM_TILC;
	terminal 	: CM_Terminal;
	wsTrailer 	: WS_Trailer;
	task 		: CM_RTQueueTask;
	machine 	: CM_Machine;
	foundLC		: CM_LocationsController;
	foundHeight	: Integer;
	foundTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
	locationID 	: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	
	self.initialisePassportMachine();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then	
		return response;
	endif;
	
	//check permission - still to created the permission
	locationID :=_locationID.asStringRESTFUL;
	terminal := app.myPassport.myTerminal;
	terminal.findLocationFromString(locationID, true, foundLC, foundHeight);
	
	if foundLC = null then
		//jlier1 TFS 61121 10/11/12
		if locationID &lt;&gt; null then
			create foundTIs transient;
			terminal.lookupAllOnsiteTrailers(null,locationID,foundTIs,true,null);
			foreach ti in foundTIs discreteLock do
				if ti.CM_TILC.isMAFI then
					if foundLC &lt;&gt; null then
						//there is more than one 
						foundLC:=null;
						break;
					endif;
					foundLC:=ti.CM_TILC.allLCs.first;
				endif;
			endforeach;
		endif;
	
		if foundLC = null then
			//raise exception
			app.raiseCMException1(Location_NotFound, locationID.asStringRESTFUL, null, null);
			return response;
		endif;
	endif;
	
	if not foundLC.isTILCController then
		return response;
	endif;
	
	mafi := foundLC.CM_TILCController.myTILC;
	
	if mafi = null or not mafi.isMAFI then
		return response;
	endif;
	
	machine:=app.myPassport.myMachine;
	task:= machine.currentQueueTask;
	if task = null then	
		app.raiseCMException(Input_required_field_RTQue,null,null);		
		return response;
	endif;
	if task.ti = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);		
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(machine.ignoresWarnings);
	
	//check that the weight hasn't been exceeded
	if mafi.myTILCType.maxWeight &lt;&gt; 0 then
		if task.ti.totalWeight +  mafi.weightCargo &gt; mafi.myTILCType.maxWeight then
			app.raiseCMWarning2(ERR_TI_CANNOT_PLACE_WEIGHT, task.ti.id,mafi.id,null,null,null);
		endif;
	endif;
	
	mafi.validateCargoMatchesVoyOpDisch(task.ti);
	
	create wsTrailer transient;
	wsTrailer.setProxyFromObject(  mafi );
	response.myMAFI:= wsTrailer;
	
	
	return response;
epilog
	delete foundTIs;
	if app.myPassport.hasErrors then
		response.checkLocationResult:=LocationError;
		response.myMAFI:=null;
		delete wsTrailer;
	else
		if machine &lt;&gt; null and (not machine.ignoresWarnings and app.myPassport.hasWarnings) then
			response.checkLocationResult:=LocationWarn;
		endif;
	endif;
	app.myPassport.clearErrorsWarnings;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="_locationID" type="String"/>
        <ReturnType type="WS_MAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="getMachineConfig" id="b568ebd9-38d3-483f-84f6-833d5117c6ee">
        <updating/>
        <source>getMachineConfig(): WS_MachineConfigResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation TFS 52595
*/
constants
	IsGraphicalView = "isGraphicalView";
	ScrollPageHeader = "scrollPageHeader";
	DefaultGViewType = "defaultGViewType";
vars
	
	machine 		: CM_Machine;
	machineConfig 	: WS_MachineConfig;
	response   		: WS_MachineConfigResponse ;
	user			: CM_User;
	entRow			: EntTableRow;
	entTableGroup		: EntTableGroup;
	taskField     : WS_QueueTaskField;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportMachine();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	machine:=app.myPassport.myMachine;
	machine.validateForVehicleApp(false);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	user := app.getMyUser();
	
	create machineConfig transient;
	
	machineConfig.isGraphicalView := user.getStateData(ConfigGrp_Web, IsGraphicalView).String.asBooleanJMT;
	machineConfig.scrollPageHeader := user.getStateData(ConfigGrp_Web, ScrollPageHeader).String.asBooleanJMT;
	machineConfig.defaultGViewType := user.getStateData(ConfigGrp_Web, DefaultGViewType).String.asIntegerJMT;
	
	response.myMachineConfig := machineConfig;	
	
	
	if response.myMachineConfig.allPrimaryTaskFields.first = null then
		entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_MachineRTFields];
	
		if entTableGroup &lt;&gt; null then
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Id];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryTaskFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Info];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryTaskFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_SourceLocation];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryTaskFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_TargetLocation];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryTaskFields.add(taskField);		
			endif;
		endif;
	endif;
	
	if response.myMachineConfig.allPrimaryCargoFields.first = null then
		entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
		if entTableGroup &lt;&gt; null then
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Id];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryCargoFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Info];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryCargoFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Location];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryCargoFields.add(taskField);		
			endif;
		endif;
	endif;
	
	if response.myMachineConfig.allPrimaryDirectorFields.first = null then
		entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
		if entTableGroup &lt;&gt; null then
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Id];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryDirectorFields.add(taskField);		
			endif;
			entRow := entTableGroup.allEntTableRowsByName[ETRow_Info];
			if entRow &lt;&gt; null then
				create taskField transient;
				taskField.setProxyFromObject(entRow);
				machineConfig.allPrimaryDirectorFields.add(taskField);		
			endif;
		endif;
	endif;
	
	
	
	return response;
epilog	
	
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_MachineConfigResponse"/>
    </JadeMethod>
    <JadeMethod name="getMachineMessages" id="2ac9b727-62c4-4574-ae2e-04746f8ae033">
        <updating/>
        <source>getMachineMessages(): WS_MachineMessagesResponse updating;
/*

Purpose: This is the REST version of machineGetControlMessages

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars	
	response		: WS_MachineMessagesResponse;
	message 		: WS_MachineMessage;
	iter 			: Iterator;
	history			: CM_MachineHistory;
	infoHistory		: CM_MachineInfoHistory;
	machine			: CM_Machine;
	lastMessageTS 	: TimeStamp;
	gotException	: Boolean;
	
begin

	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportMachine();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	machine:=app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	lastMessageTS := machine.lastGetMessagesTS;
	
	if gotException then
		app.raiseCMException(ERR_MS_SESSION_NOMACH, null, null);		
		return response;
	endif;	
	
	app.myTrxUA.trxMachineSetGetMessageTS(machine, app.myPassport);
	
	if lastMessageTS = null then		
		return response;
	endif;
	
	iter := machine.history.createIterator;
	
	while iter.back(history) do
	
		if history.dateTime &lt; lastMessageTS then
			break;
		endif;
		
		if not history.isKindOf(CM_MachineInfoHistory) then
			continue;
		endif;
		
		infoHistory:= history.CM_MachineInfoHistory;
		if infoHistory.infoType = CM_MachineInfoHistory.InfoType_Status_Change or 
			infoHistory.infoType = CM_MachineInfoHistory.InfoType_Restore_Status then
			continue;
		endif;
		
		//only interested in stuff updated from JMT
		if infoHistory.appName &lt;&gt; JMTerminal then
			continue;
		endif;
		
		create message transient;
		message.setProxyFromObject(infoHistory);
		
		response.allMessages.insert(1,message);
		
	endwhile;
		
	return response;
epilog
	delete iter;
	
	self.finaliseResponse(response);
	

end;</source>
        <ReturnType type="WS_MachineMessagesResponse"/>
    </JadeMethod>
    <JadeMethod name="getMachines" id="f8445876-3ba7-4f40-ab7a-c241bd28c8cb">
        <updating/>
        <source>getMachines(terminalID: String): WS_MachineResponse updating;
/*

Purpose: This is the REST version of getMachinesForRT

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
04 Apr 2024	jlizm1	TFS 54886 	Error when no terminals or machines returned
============================================================================*/

vars	
	response		: WS_MachineResponse;	
	iter 			: Iterator;		
	machine			: CM_Machine;		
	passport		: CM_Passport;
	terminal 		: CM_Terminal;
	machineColl		: Collection;
	errorNumber 	: Integer;
	proxyMachine	: WS_Machine;
begin

	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportPartial();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	passport := app.myPassport;
	terminal := app.myPassport.myTerminal;
	
	if terminalID &lt;&gt; null and app.getMyRoot().allTerminals.includesKey(terminalID) then
		terminal := app.getMyRoot().allTerminals.getAtKey(terminalID);
	endif;
	
	machineColl := terminal.machines;
	
	// Populate the response
	iter := machineColl.createIterator;
	while iter.next(machine) do
		if not machine.isValidForRT() then
			continue;
		endif;

		create proxyMachine transient;
		proxyMachine.setProxyFromObject(machine);
		response.allMachines.add(proxyMachine);
	endwhile;
	
	if response.allMachines.size = 0 then
		app.writeLog(app.getErrorString(No_valid_rt_machines), LogERROR);
		app.raiseCMException(No_valid_rt_machines, null, null);
	endif;
	
	return response;
	
epilog
	delete iter;
	
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="terminalID" type="String"/>
        <ReturnType type="WS_MachineResponse"/>
    </JadeMethod>
    <JadeMethod name="getMachinesForPicking" id="696b7687-5183-4cf8-bbf2-a5b51f3c8cc2">
        <updating/>
        <source>getMachinesForPicking(): WS_MachineResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 STW Release Staging App
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	terminal : CM_Terminal;
	response : WS_MachineResponse;
	iter : Iterator;
	machine : CM_Machine;
	wsMachine : WS_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	iter := terminal.machines.createIterator;

	while iter.next( machine ) do
	
		if machine.hasRadioTelemetry then  //we don't want these showing
			continue;
		endif;
	
		if machine.isNotAvailableForEntry then
			continue;
		endif;
		
		if machine.machineType = MACHINETYPE_PORTAINER_CRANE
		or machine.machineType = MACHINETYPE_IMV
		or machine.machineType = MACHINETYPE_TRUCK_TRACTOR
		then
			continue;
		endif;
		
		create wsMachine transient;
		wsMachine.setProxyFromObject(machine);
		response.allMachines.add(wsMachine);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);


end;</source>
        <ReturnType type="WS_MachineResponse"/>
    </JadeMethod>
    <JadeMethod name="getNextTask" id="9e4a67c1-f29b-4888-9e27-41f7780ffaa0">
        <updating/>
        <source>getNextTask() : String updating;
/*

Purpose: This is the REST version of machineDoGetNext

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	response		: String;
	machine 		: CM_Machine;
	allTasks 		: CM_RTQueueTaskArray; 
	wsMachineTasks 	: WS_MachineStatus;
	allIMVTasks    	: CM_RTQueueTaskArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportMachine();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	machine:=app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineGetNext(machine, app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create allTasks transient;	

	response := machine.getTasksAsJSON(allTasks);
	
	if machine.isIMV then
		app.myTrxUA.trxMachineSetTaskStates(machine, allTasks, app.myPassport);	
	endif;
	
epilog
	delete allTasks;
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonce" id="9b5e2aa9-b019-4280-acd4-b45712dd3c9d">
        <updating/>
        <source>getNonce(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 August 2022 navam1 ChangeRequest 53986: EUP - Azure Active Directory Single Sign On - Web

*/
constants
	Nonce :String = "nonce";
	Expiry : Integer = 1 ; //minute(s)
vars
	factory	: JadeMessagingFactory;
	response : String;
	nonce	: String;
	temp : String;
	cmNonce : CM_RestAuthNonce;
	jdoNonce : JadeDynamicObject;
	expiry	: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportPartial();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create factory transient;
	nonce := factory.generateAccessPassword[1:30];
	expiry := Expiry * 60; //seconds
	
	beginTransaction;
	create cmNonce persistent;
	cmNonce.setNonce(nonce,app.actualTimeServer.addSeconds(expiry), false);
	commitTransaction;
	
	create jdoNonce transient;
	jdoNonce.addProperty(Nonce, String);
	jdoNonce.setPropertyValue(Nonce, nonce);
	jdoNonce.deserializeJSON(response);

epilog
	finaliseJSONResponse(response);
	delete jdoNonce;
	delete factory;
	return response;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperationalInstructions" id="3d4e0efe-db8e-4115-902b-520cc70e8344">
        <updating/>
        <source>getOperationalInstructions(_context: String; optionalParam : ParamListType) : WS_InstructionsResponse updating;
/*

Purpose:			

Method to return back operational internal instructions to the handheld apps based on what request is made

Parameters:		

_context 		: The context of the request to determine what objeccts to retrieve
optionalParam	: The optional parameters to give Oids for different objects that allow us to find the correct ones to return

Return Value:

String : A return string that contains an array of all the instructions as requested 		

Date		Who		Reason
29 Mar 2023	navmj1	Initial creation
12 Aor 2023	navcs2	ChangeRequest 57555: [57350]: EUP - INB/OUT - Operational Instructions - JADE
27 Apr 2023	navcs2	Defect 57787: EUP - operational instructions service failing
15 Aug 2023	navma1	ChangeRequest 59218: EUP | Handle Work order for Release Rail by Type
07 Sep 2023 navma1	Bug 60384: MTN - Internal server error on the Rail Load By Request app
19 Oct 2023	navma1 Defect 60923: MTN - Exception when selecting the Job Type as Truck Load on the Work Order Operations app
24 Oct 2023	navma1	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
01 Nov 2023	navnk30	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
04 Jan 2023 navhl20 Bug 61871:[62132] FR | 53891 - Mobile App changes for Delivery Dispatch - Issues
25 Mar 2025 navbs1  Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)
*/

constants
	InstructionString 	:	String = "instruction";
vars
	_id1				: String;
	terminal			: CM_Terminal;
	workOrder			: CM_WorkOrder;
	bulkRelease			: CM_BulkRelease;
	bulkReleaseSet		: CM_BulkReleaseSet;
	booking				: CM_BookingRef;
	bookingItem			: CM_BookingRefItem;
	trackedItem			: CM_TrackedItem;
	workOrderSet		: CM_WorkOrderSet;
	bol					: CM_BOL;
	bolDtl				: CM_BOLDtl;
	bolSet				: CM_BOLSet;
	response			: WS_InstructionsResponse;
	opInstructions		: CM_InstructionsIssued;
	pxyOpInstructions	: WS_InstructionsIssued;
	reserveDetail		: CM_ReserveDetail;
	instSet				: CM_InstructionsIssuedSet;
	obj					: CM_Object;
	isForChildCargo     : Boolean;
	workOrderDtl 		: CM_WorkOrderDtl;
	woJob 				: CM_WOToDoTaskJob;
	yardJob				: CM_YardJob;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;

	// Parse the arguments from the request
	_id1 			:= self.parseParameterList(optionalParam, 1, String).String;
	isForChildCargo := self.parseParameterList(optionalParam, 2, Boolean).Boolean;
	
	// 27/04/2023	navcs2	Defect 57787
	if _id1 = null then
		return response;
	endif;
		
	// Some initial setup to help later on
	terminal := app.myPassport.myTerminal;
	
	
	// Begin getting the correct objects and instructions based on the passed context
	
	if terminal.allInstructionTypes.isEmpty then										//13.10.2023 navma1 #60923
		return response;
	endif;
	
	obj := app.myPassport.getObjectOfTypeFromOid(_id1,CM_Object).CM_Object;
	
	if obj = null then
		return response;
	endif;
	
	create  instSet transient;
	
	if _context = Truck_Load then
		
		if obj.isKindOf(CM_ReserveDetail) then				
			reserveDetail := obj.CM_ReserveDetail;
			reserveDetail.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_BulkRelease) then
			bulkRelease := obj.CM_BulkRelease;
			bulkRelease.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_TrackedItem) then			
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_BookingRef) then				
			booking := obj.CM_BookingRef;
			booking.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_BookingRefItem) then			
			bookingItem := obj.CM_BookingRefItem;
			bookingItem.getInstructionsForContext(instSet,null,Truck_Load);
		elseif obj.isKindOf(CM_YardJob) then 						//14.04.2025 navbs1 #34396						
			yardJob := obj.CM_YardJob;
			yardJob.getJobInstructions(instSet);
		endif;
	
	elseif _context = Truck_Unload then
		if obj.isKindOf(CM_BookingRef) then
			booking := obj.CM_BookingRef;
			booking.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_BookingRefItem) then			
			bookingItem := obj.CM_BookingRefItem;
			bookingItem.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_ReserveDetail) then			
			reserveDetail := obj.CM_ReserveDetail;
			reserveDetail.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_BulkRelease) then			
			bulkRelease := obj.CM_BulkRelease;
			bulkRelease.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_TrackedItem) then			
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Truck_Unload);
		elseif obj.isKindOf(CM_YardJob) then  						//14.04.2025 navbs1 #34396
			yardJob := obj.CM_YardJob;
			yardJob.getJobInstructions(instSet);
		endif;
	
	elseif _context = Pack_by_Request then
		
		if obj.isKindOf(CM_BulkRelease) then
			bulkRelease := obj.CM_BulkRelease;
			bulkRelease.getInstructionsForContext(instSet,null,Pack_by_Request);
		elseif obj.isKindOf(CM_ReserveDetail) then			
			reserveDetail := obj.CM_ReserveDetail;
			reserveDetail.getInstructionsForContext(instSet,null,Pack_by_Request);
		elseif obj.isKindOf(CM_WorkOrder) then				
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null,Pack_by_Request);
		endif;
	
	elseif _context = Lander_Load then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Load);
		elseif obj.isKindOf(CM_BOL) then
			bol := obj.CM_BOL;
			bol.getInstructionsForContext(instSet,null,Lander_Load);
		elseif obj.isKindOf(CM_BOLDtl) then				
			bolDtl := obj.CM_BOLDtl;
			bolDtl.getInstructionsForContext(instSet,null,Lander_Load);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Load);
		endif;		
	
	elseif _context = Lander_Discharge then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Discharge);
		elseif obj.isKindOf(CM_BOL) then
			bol := obj.CM_BOL;
			bol.getInstructionsForContext(instSet,null,Lander_Discharge);
		elseif obj.isKindOf(CM_BOLDtl) then
			bolDtl := obj.CM_BOLDtl;
			bolDtl.getInstructionsForContext(instSet,null,Lander_Discharge);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Discharge);
		endif;		
	elseif _context = Lander_Job_Load then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Job_Load);
		elseif obj.isKindOf(CM_BOL) then
			bol := obj.CM_BOL;
			bol.getInstructionsForContext(instSet,null,Lander_Job_Load);
		elseif obj.isKindOf(CM_BOLDtl) then
			bolDtl := obj.CM_BOLDtl;
			bolDtl.getInstructionsForContext(instSet,null,Lander_Job_Load);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Job_Load);
		endif;			
		
	elseif _context = Lander_Job_Discharge then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Job_Discharge);
		elseif obj.isKindOf(CM_BOL) then
			bol := obj.CM_BOL;
			bol.getInstructionsForContext(instSet,null,Lander_Job_Discharge);
		elseif obj.isKindOf(CM_BOLDtl) then
			bolDtl := obj.CM_BOLDtl;
			bolDtl.getInstructionsForContext(instSet,null,Lander_Job_Discharge);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Job_Discharge);
		endif;		
		
	elseif _context = Lander_Rail_Load then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Rail_Load);
		elseif obj.isKindOf(CM_BookingRef) then
			booking := obj.CM_BookingRef;
			booking.getInstructionsForContext(instSet,null,Lander_Rail_Load);
		elseif obj.isKindOf(CM_BookingRefItem) then
			bookingItem := obj.CM_BookingRefItem;
			bookingItem.getInstructionsForContext(instSet,null,Lander_Rail_Load);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Rail_Load);
		elseif obj.isKindOf(CM_YardJob) then  						//14.04.2025 navbs1 #34396
			yardJob := obj.CM_YardJob;
			yardJob.getJobInstructions(instSet);
		endif;	

	elseif _context = Lander_Rail_Discharge then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Lander_Rail_Discharge);
		elseif obj.isKindOf(CM_BookingRef) then
			booking := obj.CM_BookingRef;
			booking.getInstructionsForContext(instSet,null,Lander_Rail_Discharge);
		elseif obj.isKindOf(CM_BookingRefItem) then
			bookingItem := obj.CM_BookingRefItem;
			bookingItem.getInstructionsForContext(instSet,null,Lander_Rail_Discharge);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Lander_Rail_Discharge);
		elseif obj.isKindOf(CM_YardJob) then  						//14.04.2025 navbs1 #34396
			yardJob := obj.CM_YardJob;
			yardJob.getJobInstructions(instSet);
		endif;	
		
	elseif _context = Rail_Load then
		
		if obj.isKindOf(CM_BulkRelease) then
			bulkRelease := obj.CM_BulkRelease;
			bulkRelease.getInstructionsForContext(instSet,null,Rail_Load);
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
			reserveDetail.getInstructionsForContext(instSet,null,Rail_Load);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Rail_Load);
		endif;			
	
	elseif _context = Rail_Unload then
		
		if obj.isKindOf(CM_BookingRef) then
			booking := obj.CM_BookingRef;
			booking.getInstructionsForContext(instSet,null,Rail_Unload);
		endif;
		
	elseif _context = Pack_Cargo then
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			trackedItem.getInstructionsForContext(instSet,null,Pack_Cargo);
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
			reserveDetail.getInstructionsForContext(instSet,null,Pack_Cargo);
		elseif obj.isKindOf(CM_BulkRelease) then
			bulkRelease := obj.CM_BulkRelease;
			bulkRelease.getInstructionsForContext(instSet,null,Pack_Cargo);
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Pack_Cargo);
		endif;
	
	elseif _context = Unpack_Cargo then		
		
		if obj.isKindOf(CM_TrackedItem) then
			trackedItem := obj.CM_TrackedItem;
			if isForChildCargo then				
				trackedItem.getInstructionsForContext(instSet,trackedItem,Unpack_Cargo);
			else
				trackedItem.getInstructionsForContext(instSet,null,Unpack_Cargo);
			endif;
		elseif obj.isKindOf(CM_WorkOrder) then
			workOrder := obj.CM_WorkOrder;
			workOrder.getInstructionsForContext(instSet,null, Unpack_Cargo);
		endif;			
	elseif _context = Todo then 											//25.03.2025 navbs1 #34396
	
		if obj.isKindOf(CM_WOToDoTaskJob) then 
			woJob := obj.CM_WOToDoTaskJob;
			woJob.getInstructionsForContext(instSet,null,Todo);
		endif;	
	endif;
	
	/*
	Generic For Cargo Item
	*/
	if  obj.isKindOf(CM_TrackedItem) then
		obj.CM_TrackedItem.getInstructionsForContext(instSet,null,null);
	endif;
	
	/*Build Response*/
	
	if instSet.isNotEmpty then
		foreach opInstructions in instSet do
			create pxyOpInstructions transient;
			pxyOpInstructions.setProxyFromObject(opInstructions);
			response.allInstructions.addExclusive(pxyOpInstructions);
		endforeach;
		
	endif;
	// Return the correct data
	return response;
epilog
	delete workOrderSet;
	delete bulkReleaseSet;
	delete bolSet;
	delete instSet;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="_context" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_InstructionsResponse"/>
    </JadeMethod>
    <JadeMethod name="getOperators" id="0ed5b675-6a57-424b-98b1-35cabfac4089">
        <updating/>
        <source>getOperators(optionalParam : ParamListType) : WS_OperatorsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	response  		: WS_OperatorsResponse;
	voyageOid 		: String;
	voyage 			: CM_Voyage;
	iter 			: Iterator;
	operator 		: CM_Operator;
	failedDAC		: CM_DataAccessController;
	proxyOperator	: WS_Operator;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	voyageOid := parseParameterList(optionalParam, 1, String).String;
	if voyageOid &lt;&gt; null then
		voyage := app.myPassport.getObjectOfTypeFromOid(voyageOid,CM_Voyage).CM_Voyage;
	endif;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if voyage &lt;&gt; null then
		iter := voyage.allOperators.createIterator;
	else
		iter := app.myRoot.allOperators.createIterator;
	endif;
	
	while iter.next(operator) do
		if operator.isNotAvailableForEntry then
			continue;
		endif;
	
		if  not operator.canUserAccessSelf(null, failedDAC, app.myPassport) then	// TFS 41305
			continue;
		endif;
	
		create proxyOperator transient;
		proxyOperator.setProxyFromObject(operator);
		response.allOperators.add(proxyOperator);
	endwhile;
	
	
	return response;
	
epilog
	delete iter;					//08.01.2026 navma1 #MTN-36897
	self.finaliseResponse(response);
end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_OperatorsResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackLoadReleaseSummaries" id="1084e6bb-828d-46ea-80d5-0270b3063cf8">
        <updating/>
        <source>getPackLoadReleaseSummaries(releaseID : String) : WS_ReleaseSummariesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Aug 2021	jlier1	Initial creation 51879
28 Oct 2021	jlier1	TFS 52263 - needed to exclude packing parent
07 Apr 2022 navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
14 Dec 2023 navma1  ChangeRequest 61092: EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response 		: WS_ReleaseSummariesResponse;
	terminal 		: CM_Terminal;
	roadRelease,
	packRelease,
	shipRelease,
	railRelease     : CM_BulkRelease;
	releaseSummary	: WS_ReleaseRequestSummary;
	theReleaseID    : String;
	forEUP			: Boolean;
	voyageProcess 	: CM_VoyageProcess;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	// if has both pack and road must return both and let user decide
	theReleaseID := releaseID.trimBlanks.toUpper.asStringRESTFUL;
	roadRelease  := terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_ROAD);
	packRelease  := terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_PACKING);
	
	voyageProcess := terminal.getDefaultVoyageProcess();											//19.12.2023 navhl20 #61092[61621]
	forEUP := voyageProcess.isEUPDefaultProcess;													//19.12.2023 navhl20 #61092[61621]
	if forEUP then																					//14.12.2023 navma1 #61092
		shipRelease  := terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_SHIP);	
	endif;
	
	
	if packRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(packRelease);
		releaseSummary.setProxyForStaging(packRelease, false, false);	// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	if roadRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(roadRelease);
		releaseSummary.setProxyForStaging(roadRelease, true, false);	// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	if railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(railRelease);
		releaseSummary.setProxyForStaging(railRelease, true, false);	// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	if shipRelease &lt;&gt; null then												//14.12.2023 navma1 #61092
		if not shipRelease.releaseByType then
			return response;
		endif;
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(shipRelease);
		releaseSummary.setProxyForStaging(shipRelease, true, false);	// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseID" type="String"/>
        <ReturnType type="WS_ReleaseSummariesResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackLoadSourceArea" id="3450edd8-f423-4a5e-89d6-e5edbbb270e5">
        <updating/>
        <source>getPackLoadSourceArea(optionalParam : ParamListType) : WS_LocationsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 August 2021	jlier1	Initial creation 51879
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
response : WS_LocationsResponse;
	firstTa : CM_TerminalArea;
	term : CM_Terminal;
	iter : Iterator;
	ta : CM_TerminalArea;
	wsLC : WS_LocationsController;
	lc,selectedStageArea  : CM_LocationsController;
	allLCs 		: CM_LCSet;
	releaseOid,  reserveOid : String;
	cmifMobile : CMIF_MobileGenericAgent;
	release : CM_BulkRelease;
	reserve : CM_ReserveDetail;
	stwRuleNum : Integer;
	allVehicles : CM_VehicleArray;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term:=app.myPassport.myTerminal;
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	if firstTa = null then
		return response;
	endif;
	create allLCs transient;
	iter := term.allTerminalAreasByTypeId.createIterator;
	iter.startAtObject( firstTa );
	while iter.next( ta ) do
		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		lc := null;
		if ta.isKindOf( CM_InterchangeArea ) then
			lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089	
		endif;
		if lc = null then
			continue;
		endif;
		allLCs.add(lc);
		create wsLC transient;
		wsLC.setProxyFromObject(lc);
		response.allLocationsControllers.add(wsLC);
	endwhile;
	
	releaseOid 			:= parseParameterList(optionalParam, 1, String).String;
	reserveOid 			:= parseParameterList(optionalParam, 2, String).String;
	if releaseOid &lt;&gt; null then
		release:= app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;
	
	if release = null then
		return response;
	endif;
	if reserveOid &lt;&gt; null then
		reserve:=app.myPassport.getObjectOfTypeFromOid(reserveOid, CM_ReserveDetail).CM_ReserveDetail;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;
	
	
	if release.isRoadType then
		create allVehicles transient;
		release.getAssociatedTrucks(allVehicles);
		if allVehicles.size = 1 then
			selectedStageArea:=null;
			release.getAllPreStagedLocations(selectedStageArea);
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
			endif;
		endif;
	endif;
	if term.getConfig(UseAltSelectRulesTL).Boolean and app.isCargoGroupEnabled then
		create cmifMobile transient;
		cmifMobile.getCargoStagingDispRuleSTW(release,reserve,selectedStageArea,stwRuleNum);
		if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
			response.selectedLocationOid:=selectedStageArea.getOidAsString;
		endif;
	else
		if selectedStageArea = null and reserve &lt;&gt; null and allLCs.first &lt;&gt; null then
			reserve.getTotalStaged(null, selectedStageArea, null);
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
			endif;
		endif;
	endif;
	
	
	return response;
	
epilog
	delete iter;
	delete cmifMobile;
	delete allLCs;
	delete allVehicles;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackingParentsForRelease" id="a9a7330d-affd-42be-a1a7-afd2be522ce5">
        <updating/>
        <source>getPackingParentsForRelease(releaseOid  : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 August 2021	jlier1	Initial creation 51879
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_CargoSummaryResponse;
	terminal : CM_Terminal;
	release 	: CM_BulkRelease;
	truckArray : CM_VehicleArray ;
	allTIs 	: CM_TIArray;
	ti : CM_TrackedItem;
	wsCargoSummary : WS_CargoSummary;
	truck : CM_Vehicle;
	failedDAC : CM_DataAccessController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create truckArray transient;
	release.getAssociatedTrucks(truckArray);
	
	create allTIs transient;
	
	foreach truck in truckArray discreteLock do
		foreach ti in truck.locationsController.allTrackedItems where not (ti.isROB or ti.isChassis) do
			allTIs.add(ti);
		endforeach; 
	endforeach;
	
	release.getProspectiveParentCargo(allTIs,false);
	
	foreach ti in allTIs discreteLock do 
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
		create wsCargoSummary transient;
		wsCargoSummary.setProxyFromObject(  ti );
		
		//jlier1 TFS 52366
		if ti.isContainer then
			wsCargoSummary.productDescription:= ti.myCargoType.description &amp; ", " &amp; ti.getISOType();
		endif;
		
		response.allCargoSummaries.add( wsCargoSummary );
	endforeach;
	
	return response;
epilog
	delete truckArray;
	delete allTIs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getPickingReleaseSummaries" id="cd3e7e60-fb54-400d-ad0f-c1f9f495b785">
        <updating/>
        <source>getPickingReleaseSummaries(releaseID : String) : WS_ReleaseSummariesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 Jul 2021		jlier1	Initial creation TFS 51626
28 Oct 2021		jlier1	TFS 52263 - needed to exclude packing parent
07 Apr 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
04 Mar 2025		navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response : WS_ReleaseSummariesResponse;
	terminal : CM_Terminal;
	roadRelease,
	packRelease,
	shipRelease,
	railRelease : CM_BulkRelease;
	releaseSummary	: WS_ReleaseRequestSummary;
	theReleaseID  : String;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	// if has both pack and road must return both and let user decide
	theReleaseID:=releaseID.trimBlanks.toUpper.asStringRESTFUL;
	roadRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_ROAD);
	packRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_PACKING);
	shipRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_SHIP);
	railRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_RAIL);
	
	if packRelease &lt;&gt; null and ( roadRelease &lt;&gt; null or shipRelease &lt;&gt; null or railRelease &lt;&gt; null ) then
		if packRelease &lt;&gt; null then
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(packRelease);
			releaseSummary.setProxyForStaging(packRelease, true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if roadRelease &lt;&gt; null then
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(roadRelease);
			releaseSummary.setProxyForStaging(roadRelease, true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if shipRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(shipRelease);
			releaseSummary.setProxyForStaging(shipRelease, true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(railRelease);
			releaseSummary.setProxyForStaging(railRelease, true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		
		
	elseif packRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(packRelease);
		releaseSummary.setProxyForStaging(packRelease, true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif roadRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(roadRelease);
		releaseSummary.setProxyForStaging(roadRelease, true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif shipRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(shipRelease);
		releaseSummary.setProxyForStaging(shipRelease, true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(railRelease);
		releaseSummary.setProxyForStaging(railRelease, true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseID" type="String"/>
        <ReturnType type="WS_ReleaseSummariesResponse"/>
    </JadeMethod>
    <JadeMethod name="getPickingTargetAreas" id="f6b265d3-fe18-4ff3-903c-11fafaecdd6f">
        <updating/>
        <source>getPickingTargetAreas(optionalParam : ParamListType) : WS_LocationsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 June 2021	jlier1	Initial creation TFS 51626 - Release Staging STW
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_LocationsResponse;
	firstTa : CM_TerminalArea;
	term : CM_Terminal;
	iter : Iterator;
	ta : CM_TerminalArea;
	wsLC : WS_LocationsController;
	lc,selectedStageArea  : CM_LocationsController;
	allLCs 		: CM_LCSet;
	releaseOid : String;
	release : CM_BulkRelease;
	reserve : CM_ReserveDetail;
	tiSet : CM_TISet; 
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term:=app.myPassport.myTerminal;
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	if firstTa = null then
		return response;
	endif;
	create allLCs transient;
	iter := term.allTerminalAreasByTypeId.createIterator;
	iter.startAtObject( firstTa );
	while iter.next( ta ) do
		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		lc := null;
		if ta.isKindOf( CM_InterchangeArea ) then
			lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
		endif;
		if lc = null then
			continue;
		endif;
		allLCs.add(lc);
		create wsLC transient;
		wsLC.setProxyFromObject(lc);
		response.allLocationsControllers.add(wsLC);
	endwhile;
	
	releaseOid 			:= parseParameterList(optionalParam, 1, String).String;
	if releaseOid &lt;&gt; null then
		release:= app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
			return response;
		endif;
	endif;
	
	if release = null or allLCs.isEmpty  then
		return response;
	endif;
	
	create tiSet transient;
	if not release.isPackingType then
		release.getTotalStaged(tiSet, selectedStageArea);
		if selectedStageArea &lt;&gt; null then
			response.selectedLocationOid:=selectedStageArea.getOidAsString;
		endif;
	endif;
	
	if selectedStageArea =  null then
		foreach reserve in release.allReserveDetails discreteLock where not reserve.isFullyStaged do
			selectedStageArea:=reserve.getFirstStagingLocation;
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
				break;
			endif;
		endforeach;
	endif;
	return response;
	
epilog
	delete tiSet;
	delete iter;
	delete allLCs;
	self.finaliseResponse(response);
end;
</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="ac49d203-2393-4cd1-8a54-a02464572997">
        <updating/>
        <source>getQueues(): WS_MachineQueuesResponse updating;
/*

Purpose: This is the REST version of machineGetQueues

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 	: CM_Machine;
	response 	: WS_MachineQueuesResponse;	
	queues 		: CM_RadioTelemQueueByIdDict;
	queue 		: CM_RadioTelemetryQueue;
	wsQueue		: WS_Queue;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	create queues transient;	
	machine.getAllAvailableQueues(queues);
	
	foreach queue in queues do
		create wsQueue transient;
		wsQueue.setProxyFromObject(queue);
		response.allQueues.add(wsQueue);
	endforeach;
		
	return response;
	
epilog
	delete queues;
	
	finaliseResponse(response);	

end;
	
</source>
        <ReturnType type="WS_MachineQueuesResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailLinePlannedWagons" id="4fbeb3ca-e406-422d-89d5-388444b9e965">
        <updating/>
        <source>getRailLinePlannedWagons(railLineOid : String ): WS_WagonsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	jlier1	Initial creation 54604
16 Oct 2023 navrv30 Bug 60883: FR | 53740 EUP - Wagon Track Planning
23 Apr 2024 navma1	Bug 63794: MTN - 1308 error from performance test 22042024
*/

vars
	response 	: WS_WagonsResponse;
	railLine 	: CM_RailLine;
	futureMove  : CM_FutureMove;
	wagon 		: CM_Wagon;
	wagonProxy  : WS_Wagon;
	currentTime : TimeStamp;
	fMoves		: CM_FutureMoveArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	railLine := app.myPassport.getObjectOfTypeFromOid(railLineOid,CM_RailLine).CM_RailLine;
	
	if railLine = null then
		return response;
	endif;	
	
	currentTime := app.actualTimeAppServer;
	
	create fMoves transient;
	railLine.allPlannedFutureMoves.copy(fMoves);					//23.04.2024 navma1 #63794
	
	foreach  futureMove in fMoves do
		wagon := futureMove.CM_FutureMoveWagonPlanned.myWagon;
		if wagon = null then
			continue;
		endif;
		
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);	
		wagonProxy.setProxyLocationCargo();
		response.allWagons.add(wagonProxy);
	endforeach;

	return response;
epilog
	delete fMoves;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="railLineOid" type="String"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailLineSummaryForTrain" id="b22ba4cb-2212-41ee-8c1c-1f3025122fca">
        <updating/>
        <source>getRailLineSummaryForTrain(railLineOid : String; trainOid : String; inward : Boolean ) : WS_RailRakeSummaryResponse updating ;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	train 			: CM_Train;
	railLine 		: CM_RailLine;
	response  		: WS_RailRakeSummaryResponse;
	details			: JadeDynamicObjectArray;
	jdo				: JadeDynamicObject;
	summaryLine		: WS_RailRakeSummary;
	obj				: Object;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	create response transient;

	railLine := app.myPassport.getObjectOfTypeFromOid(railLineOid,CM_RailLine).CM_RailLine;
	if railLine = null then
		return response;
	endif;
	
	train := app.myPassport.getObjectOfTypeFromOid(trainOid,CM_Train).CM_Train;
	if train = null then
		return response;
	endif;
	
	details := railLine.getWagonSummary(inward, train, null, null);

	if details = null then
		return response;
	endif;
	
	foreach jdo in details do
		create summaryLine transient;
		summaryLine.color := jdo.getPropertyValue("color").Integer;
		summaryLine.level := jdo.getPropertyValue("level").Integer;
		summaryLine.text  := jdo.getPropertyValue("text").String;
		obj := jdo.getPropertyValue("object").Object;
		if obj &lt;&gt; null then
			summaryLine.objectUid := obj.getOidAsString();
		endif;
		response.allSummaryLines.add(summaryLine);
	endforeach;
	
	return response;
	
epilog
	if details &lt;&gt; null then
		details.purge; 
		delete details;
	endif;

	self.finaliseResponse(response);
end;</source>
        <Parameter name="railLineOid" type="String"/>
        <Parameter name="trainOid" type="String"/>
        <Parameter name="inward" type="Boolean"/>
        <ReturnType type="WS_RailRakeSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailLineWagonsForTrain" id="56e10711-cd69-47f8-834c-c8ef734d9457">
        <updating/>
        <source>getRailLineWagonsForTrain(trainOid : String; railLineOid : String ; inward : Boolean;optionalParam : ParamListType) : WS_WagonsResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response		: WS_WagonsResponse;
	wagon			: CM_Wagon;
	wagonProxy	    : WS_Wagon;
	train			: CM_Train;
	allTis 			: CM_TIArray;
	canLoad, 
	canDischarge,
	endToStart 		: Boolean;
	railLine 		: CM_RailLine;
	idx, 
	wagonPos 		: Integer;
	wagonsAdded 	: CM_WagonByIdDict;
	iter : Iterator;
	futureMove : CM_FutureMove;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	train := app.myPassport.getObjectOfTypeFromOid(trainOid,CM_Train).CM_Train;
	if train = null then
		return response;
	endif;
		
	railLine := app.myPassport.getObjectOfTypeFromOid(railLineOid,CM_RailLine).CM_RailLine;
	if railLine = null then
		return response;
	endif;	
	endToStart 		:= parseParameterList(optionalParam, 1, Boolean).Boolean;	
	
	idx := 1;
	if endToStart then
		idx:=railLine.maximumWagons;
	endif;
	wagonPos:=1;
	create allTis transient;
	create wagonsAdded transient;
	
	while wagonPos &lt;= railLine.maximumWagons do
		wagon:=null;
		
		wagon:=railLine.getWagonAtPosition(idx);
		if wagon &lt;&gt; null then
			if inward then
				if wagon.myTrainInwards &lt;&gt; train then
					wagon:=null;
				endif;
			else
				if wagon.myTrainOutwards &lt;&gt; train then
					wagon:=null;
				endif;	
			endif;
		endif;
		
		if wagon &lt;&gt; null then
			canLoad:=false;
			canDischarge:=false;
			if train.allWagonsByIdInward[wagon.id] &lt;&gt; null then
				canLoad:=true;
			endif;
			
			allTis.clear();
			wagon.getAllTrackedItems(true, allTis, false);
			if allTis.first() &lt;&gt; null then
				canDischarge:=true;
			endif;
			
			create wagonProxy transient;
			wagonProxy.setProxyFromObject(wagon);
			wagonProxy.canLoad:=canLoad;
			wagonProxy.canDischarge:=canDischarge;		
			wagonProxy.setProxyLocationCargo();
			response.allWagons.add(wagonProxy);
			wagonsAdded.add(wagon);
		endif;
	
	
		wagonPos:=wagonPos+1;
		if endToStart then
			idx:=idx - 1;
		else
			idx:=idx + 1;
		endif;
	endwhile;
	

	return response;
epilog
	delete allTis;
	delete wagonsAdded;
	delete iter;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="trainOid" type="String"/>
        <Parameter name="railLineOid" type="String"/>
        <Parameter name="inward" type="Boolean"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailLinesForTrain" id="9a187902-a0ff-43e8-82b2-2c75142f177c">
        <updating/>
        <source>getRailLinesForTrain(trainOid : String; inward : Boolean) : WS_RailLinesResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
****************************************************/


vars
	response 		: WS_RailLinesResponse;
	wsRailLine	    : WS_RailLine;
	taTypeKey 		: Integer;
	taIdKey			: String;
	taIter			: Iterator;
	railLine		: CM_RailLine;
	taDict 			: CM_TAByTypeIdDict;
	ta				: CM_TerminalArea;
	terminal		: CM_Terminal;
	train 			: CM_Train;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	train := app.myPassport.getObjectOfTypeFromOid(trainOid,CM_Train).CM_Train;
	if train = null then
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;	
	
	taDict := terminal.allTerminalAreasByTypeId;

	taIter := taDict.createIterator;
	
	taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, taIter);
	
	while taIter.next(ta) do
		taIter.getCurrentKeys(taTypeKey, taIdKey);  //MTN-35226
		if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		
		foreach railLine in ta.CM_Rail.allRailLinesByIndex discreteLock do
			create wsRailLine transient;
			wsRailLine.setProxyFromObject(railLine);
			wsRailLine.setNotifiedConfirmedCounts(railLine,train,inward);
			response.allRakes.add(wsRailLine);
		endforeach;
		
	endwhile;	
		
	return response;
epilog
	
	delete taIter;
	
	self.finaliseResponse(response);


end;</source>
        <Parameter name="trainOid" type="String"/>
        <Parameter name="inward" type="Boolean"/>
        <ReturnType type="WS_RailLinesResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailReleaseSummary" id="5141c609-a29f-48d0-b88f-f4ac0b5b4333">
        <updating/>
        <source>getRailReleaseSummary(releaseNo : String): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 June 2019	jlger1	Initial creation TFS 45291
17 July 2019	jlgrr1	
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response 		: WS_ReleaseSummaryResponse;
	releaseSummary	: WS_ReleaseRequestSummary;
	bulkRelease		: CM_BulkRelease;
	failedDAC : CM_DataAccessController;
	releaseNumber : String;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	if releaseNo = null then
		app.raiseCMException(Input_required_field_relNum,null,null);
		return response;
	endif;
	
	//epr TFS 46632 23/9/19 
	releaseNumber:=releaseNo.trimBlanks.toUpper.asStringRESTFUL;
	
	bulkRelease := app.myPassport.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_RAIL,BR_ACTIVE,releaseNumber, null );

	if bulkRelease = null or bulkRelease.type &lt;&gt; BR_TYPE_RAIL or bulkRelease.status &lt;&gt; BR_ACTIVE or bulkRelease.code &lt;&gt; releaseNumber then
		app.raiseCMException1(Bulk_Release_Not_Found,releaseNumber ,null,null);
		return response;
	endif;
	
	if not bulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.userName,bulkRelease.code,null, null,null);
		return response;
	endif;
	
	
	create releaseSummary transient;
	releaseSummary.setProxyFromObject(bulkRelease);
	releaseSummary.setProxyReserveDetails(bulkRelease); // jlier1 26/7/21 TFS 51626 
	response.releaseRequestSummary := releaseSummary;
		
	return response;
epilog
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseNo" type="String"/>
        <ReturnType type="WS_ReleaseSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailReleaseWagons" id="26407d02-c13b-402d-accf-ca2ab391af13">
        <updating/>
        <source>getRailReleaseWagons(releaseOid: String) : WS_WagonsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2019		jlger1	Initial creation TFS 45291
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
04 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

	response : WS_WagonsResponse;
	releaseRequest : CM_BulkRelease;
	wagonArray : CM_WagonArray;
	wagon : CM_Wagon;
	wsWagon : WS_Wagon;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return response;
	endif;	
	
	releaseRequest:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if releaseRequest = null then
		app.raiseCMException1(Bulk_Release_Not_Found,releaseOid ,null,null);
		return response;
	endif;
	
	if releaseRequest.type &lt;&gt;  BR_TYPE_RAIL then
		return response;
	endif;
	
	create wagonArray transient;
	releaseRequest.getAssociatedWagons(wagonArray, true );
	
	foreach wagon in wagonArray discreteLock do
		if wagon.hasCompletedLoading then	// TFS 54118
			continue;
		endif;
		
		create wsWagon transient;
		wsWagon.setProxyFromObject(wagon);
		response.allWagons.add(wsWagon);
		
	endforeach;
	
	return response;
epilog
	delete wagonArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeMethod>
    <JadeMethod name="getReleaseSummary" id="b92a208c-6335-45b0-918b-1f2b16f817c8">
        <updating/>
        <source>getReleaseSummary(releaseOid : String ): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 Nov 2021		jlier1	Initial creation TFS 52444
07 Apr 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
04 Mar 2025		navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response 		: WS_ReleaseSummaryResponse;
	releaseSummary 	: WS_ReleaseRequestSummary;
	bulkRelease		: CM_BulkRelease;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
		
	create response transient;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
			
	if bulkRelease = null  then
		app.raiseCMException(Bulk_Release_Not_Found,null,null);
		return response;
	endif;
	
	
	create releaseSummary transient;
	releaseSummary.setProxyFromObject(bulkRelease);
	releaseSummary.setProxyForStaging(bulkRelease, true, false);		// MTN-34024
	response.releaseRequestSummary := releaseSummary;
		
	return response;
epilog
	
	self.finaliseResponse(response);


end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_ReleaseSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getReleasedTisToShip" id="f82e5368-fa93-4b5a-a5d9-fac1e6031bfb">
        <updating/>
        <source>getReleasedTisToShip(_detailOid : String): WS_CargoSummaryResponse updating;
/*

Purpose: To get the released tracked items from reserve detail for Ship			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request

*/

vars
	rrDetail 	: CM_ReserveDetail;
	wsCargo 	: WS_CargoSummary;
	response 	: WS_CargoSummaryResponse;
	cargo 		: CM_TrackedItem;
	iter  		: Iterator;
	failedDAC  	: CM_DataAccessController ;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	

	rrDetail := app.myPassport.getObjectOfTypeFromOid(_detailOid,CM_ReserveDetail).CM_ReserveDetail;
		
	if rrDetail = null then
		return response;
	endif;
	
	iter := rrDetail.allTrackedItemsReleased.createIterator;
	
	while iter.next(cargo) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);	
		response.allCargoSummaries.add(wsCargo);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_detailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getRequiredExportPermission" id="b13f3a40-1c0a-4434-bc4f-399f4396b072">
        <source>getRequiredExportPermission(_category: String): Integer;
/*

Purpose:			
	* Determines required permission for export based on category

Parameters:			
	 * @param _category Category from CM_ExportImportClass
	* @return Required permission integer
Return Value:		

Date		Who		Reason
 6 Jan 2026 naviv1     Initial creation - MTN-36582 - Create Export API

*/

vars

begin	
	 if _category.isOneOf(ExportImportSystemAdmin,ExportImportSystemScreen) then
        return PmAdmSystemExportMaint;
    elseif _category.isOneOf(ExportImportTerminalAdmin,ExportImportTerminalScreen) then
        return PmAdmTerminalExportMaint;
    else
        return null;
    endif;
epilog

end;</source>
        <Parameter name="_category" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRequiredImportPermission" id="467ac23e-be34-4953-bbf2-103fed807a19">
        <source>getRequiredImportPermission(_category: String): Integer;
/*

Purpose:			
	* Determines required permission for export based on category

Parameters:			
	 * @param _category Category from CM_ExportImportClass
	* @return Required permission integer
Return Value:		

Date		Who		Reason
 6 Jan 2026 naviv1     Initial creation - MTN-36584 - Create Import API

*/

vars

begin	
	 if _category.isOneOf(ExportImportSystemAdmin,ExportImportSystemScreen) then
        return PmAdmSystemImportMaint;
    elseif _category.isOneOf(ExportImportTerminalAdmin,ExportImportTerminalScreen) then
        return PmAdmTerminalImportMaint;
    else
        return null;
    endif;
epilog

end;</source>
