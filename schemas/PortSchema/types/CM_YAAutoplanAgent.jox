// -------------------------------------------
// Created 16 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return self.myCurrentCMIFYAAutoPlan.getMyTrackedItem();


end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getNestedAllocationLC" id="0fe4f541-e899-4211-a252-d96d05a71147">
        <updating/>
        <source>getNestedAllocationLC() : Boolean protected, updating;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

	location : CM_LocationsController;

begin

	if not self.isSingleProcessing() then
		return false;
	endif;
	
	if not self.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
		self.addLogEntry(AP_Log_YA_Default,'Using last resort location', true);
		self.addLocationToAgent(self.myCurrentCMIFYAAutoPlan.allLCsLastResort.first, Locations_Found);
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPrimeYardAllocation" id="46b4ed4f-efd9-4c7c-adfa-ad87f09de532">
        <source>getPrimeYardAllocation():CM_YardAllocation;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if self.myFirstYAFailure &lt;&gt; null then
		return self.myFirstYAFailure;
	else
		return self.getYardAllocationUsed();
	endif;

epilog

end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getRequestBestPickBOL" id="07709d24-ca14-4e52-97d4-101f86ab2ceb">
        <updating/>
        <source>getRequestBestPickBOL(_bol: CM_BOLIn; _ta: CM_TerminalArea; _request : CM_Request): CM_TrackedItem updating;
//23 December 2010	cnwdw1	
//  PAR 26671
vars
	ti: CM_TrackedItem;
	bestTi: CM_TrackedItem;
	dynaDict : DynaDictionary;
	iter : Iterator;
begin
	//jlier1 1/10/25 MTN-35633
	self.addLogEntry(AP_Log_YA_Global,'Search for best pick in BOL: ' &amp; _bol.number, true);		

	//jlier1 MTN-35637 17/9/25
	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addMemberKey(CM_TrackedItem::numOverstows.name,false,false);
	dynaDict.addMemberKey(CM_TrackedItem::bestPickDT.name,false,false);			
	dynaDict.endKeys(true);
		
	_bol.allTrackedItems.copy(dynaDict);	
	iter:=dynaDict.createIterator;

	while iter.next(ti) do
		if _ta &lt;&gt; null and ti.myTerminalArea &lt;&gt; _ta then
			continue;
		endif;
		
		if not ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
			continue;
		endif;
		self.addLogEntry(AP_Log_YA_Global,ti.id &amp; ", Best Pick Date/Time " &amp; ti.bestPickDT.asStringJMT &amp; " using " &amp; ti.getBestPickDTReason &amp; ", Overstows " &amp; ti.numOverstows.asStringJMT  , false);
		if ti.isOnSite and not ti.isAlreadyAllocated then		
			bestTi := ti;  //jlier1 MTN-35637 17/9/25 - first will now always be the least overstowed
			break;
		else	
			if not ti.isOnSite then
			
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; ", cargo not on site"  , false);
			else
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; ", cargo already allocated to release"  , false);
			endif;
		endif;
	endwhile;
	
	if bestTi &lt;&gt; null then
		self.addLogEntry(AP_Log_YA_Default,'Search for best pick in BOL found: ' &amp; bestTi.id &amp; ' in source location ' &amp; bestTi.locationId, true);		
	else
		self.addLogEntry(AP_Log_YA_Default,'Search for best pick in BOL found nothing', true);	
		self.createLoggingAlert();		
	endif;
	return bestTi;
epilog
	delete dynaDict;
	delete iter;
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRequestBestPickTI" id="a48a701a-30d7-45cb-bb29-c984b628be16">
        <updating/>
        <source>getRequestBestPickTI(_terminal : CM_Terminal; _request : CM_Request; _termArea : CM_TerminalArea; _scanTerminal : Boolean) : CM_TrackedItem updating;
// 26/02/2010	cnwjre1	CCMS 1101
// find the least-overstowed tracked item which matches the request criteria in this terminal area
// if the _scanTerminal option is true, search the given terminal area first then the whole terminal, otherwise do just the given area.
//jlier1 MTN-35637 17/9/25  - changes to how best pick gets the ti - now ordered by attributes of Ti - numOverstows &amp;  bestPickDT
//03/11/2025	navkc1 JIRA 36476 MTN - Selecting multiple areas in Select Source Locations form doesn't work with the new config set
vars
	iter	: Iterator;
	request	: CM_DeliveryRequest;
	moveRequest : CM_YardMoveRequest;
	saveTi,
	ti : CM_TrackedItem;
	cmifRequest	: CMIF_YAAutoPlan;
	cargoType : Integer;
	dynaDict : DynaDictionary;
	ta : CM_TerminalArea;
	isBestPick : Boolean;
	orderByTA : Boolean;
	taID : String;
	loc : CM_LocationsController; //28/10/2025	navkc1 JIRA 36411
	gridCont : CM_GridController; //28/10/2025	navkc1 JIRA 36411
begin
	if _request = null then
		return null;
	endif;

	self.initialiseForRequest(_terminal, _request.myJob);
	cmifRequest := self.myCurrentCMIFYAAutoPlan;
	if _request.isKindOf(CM_DeliveryRequest) then
		request := _request.CM_DeliveryRequest;
		// populate the CMIF comparison instance from the request
		cmifRequest.CMIF_YARequest.initializeFromDeliveryRequest(_terminal, request);
		// from 23023 set bestPick flag for commodity etc test in TI testAutoPlanRequestYA
		cmifRequest.CMIF_YARequest.bestPick := true;
		isBestPick:=true;
	// 23098 extend to handle internal move requests as well
	elseif _request.isKindOf(CM_YardMoveRequest) then
		moveRequest := _request.CM_YardMoveRequest;
		cmifRequest.CMIF_YARequest.initializeFromMoveRequest(_terminal, moveRequest);
	else
		return null;
	endif;
	// Clear working sets outside the loop here
	self.myCurrentCMIFYAAutoPlan.allPassedLocations.clear();
	self.myCurrentCMIFYAAutoPlan.allFailedLocations.clear();
	self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.clear(); //cnwrd1 par 29269 14.3.2012
	self.allLCsToIgnore.copy(self.myCurrentCMIFYAAutoPlan.allFailedLocations);
	self.forOutput := true;
	self.fillOptionOut := YAFillOption_BestPick;
	
	self.lastOverstowLevel := 99999;

	// read and filter tracked items for this terminal area
/*	if _termArea &lt;&gt; null then				//+cnwml2 PAR23848
		self.addLogEntry(AP_Log_YA_Default,'Testing area ' &amp; _termArea.getID(), true);		// 23676 for logging
		foreach lc in _termArea.allLocationsControllers do
			if lc.isKindOf(CM_YardController) then
				self.addLogEntry(AP_Log_YA_Default,'Testing location ' &amp; lc.getID(), true);		// 23676 for logging
				if lc.CM_YardController.testAutoPlanRequestYA(self) then
					break;
				endif;
			endif;
		endforeach;
	else
		if request &lt;&gt; null then
			self.addLogEntry(AP_Log_YA_Default,'Request ID ' &amp; request.description, true);		// 23676 for logging
		endif;
	endif;*/
	
	//jlier1 1/10/25 MTN-35633
	self.addLogEntry(AP_Log_YA_Global,'Checking Best Pick for Request  ' &amp; _request.getPlannersGroupDesc, true);
	
	
	if self.myCurrentCMIFYAAutoPlan.allFoundTis.size &gt; 0 then
		saveTi := self.myCurrentCMIFYAAutoPlan.allFoundTis.first;
	elseif self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.size &gt; 0 then
		saveTi := self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.first;	// set from block stack
	endif;

	// no non-overstowed matches have been found, then if a least-overstowed item is on the agent, use that instead
	if saveTi = null and
	   self.bestPickOverstowedTI &lt;&gt; null then
		self.addLocationToAgent(self.bestPickOverstowedTI.allLocations.first, CM_YAAutoplanAgent.Locations_Found);
		self.myCurrentCMIFYAAutoPlan.allFoundTis.add(self.bestPickOverstowedTI);
		self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(self.bestPickOverstowedTI);
		saveTi := self.bestPickOverstowedTI;
		if saveTi &lt;&gt; null then			// 23676 for logging
			self.addLogEntry(AP_Log_YA_Default,'Located item (' &amp; saveTi.id &amp; ')', false);
		endif;
	endif;
	
	// if not found, go through the whole terminal
	// ** this code is to be optimised to use alternate collections for particular cases
	if saveTi = null and
	   _scanTerminal then
		if request &lt;&gt; null and
		   request.myCargoType &lt;&gt; null then
			cargoType := request.myCargoType.id;
		endif;
		//jlier1 MTN-35637 17/9/25
		orderByTA:=request &lt;&gt; null and request.allTerminalAreas.first &lt;&gt; null and not request.isFIFO;
		create dynaDict transient;
		dynaDict.setMembership(CM_TrackedItem);
		if orderByTA then
			dynaDict.addMemberKey(CM_TrackedItem::terminalAreaId.name,false,false);	
		endif;
		if cargoType &lt;&gt; null then
			dynaDict.addMemberKey(CM_TrackedItem::cargoType.name,false,false);
		endif;
		if request &lt;&gt; null and request.operatorCode &lt;&gt; null then
			dynaDict.addMemberKey(CM_TrackedItem::operatorCode.name,false,false);
		endif;
		dynaDict.addMemberKey(CM_TrackedItem::numOverstows.name,false,false);
		dynaDict.addMemberKey(CM_TrackedItem::bestPickDT.name,false,false);		
		dynaDict.endKeys(true);
		
		if request &lt;&gt; null and request.allTerminalAreas.first &lt;&gt; null then
			foreach ta in request.allTerminalAreas discreteLock do
				ta.getAllLocationsTrackedItems(dynaDict);
			endforeach;
			
			//03/11/2025	navkc1 JIRA 36476 - only do this when there's 1 terminal area selected. Otherwise we might skip some of the TAs due to the sorting
			if request.allTerminalAreas.size() = 1 then
				taID:=request.allTerminalAreas.first.id;
			endif;
		else
			_terminal.allOnsiteTIsByCargoTypeId.copy(dynaDict);
		endif;
		
		//jlier1 1/10/25 MTN-35633
		if request &lt;&gt; null and request.allTerminalAreas.first &lt;&gt; null then
			self.addLogEntry(AP_Log_YA_Global,'Searching allocated Terminal Areas ' &amp; request.allTerminalAreas.listString(",",CM_TerminalArea::id.name), false);
		endif;
		
		iter:=dynaDict.createIterator;
		if orderByTA then
			if  request.operatorCode &lt;&gt; null then 
				dynaDict.startKeyGeq(taID,cargoType, request.operatorCode,null,null,iter);
			else
				dynaDict.startKeyGeq(taID,cargoType,null,null,iter);
			endif;
		else
			if request&lt;&gt; null then
				if  request.operatorCode &lt;&gt; null then 
					dynaDict.startKeyGeq(cargoType, request.operatorCode,null,null,iter);
				else
					dynaDict.startKeyGeq(cargoType,null,null,iter);
				endif;
			endif;
		endif;
		
		while iter.next(ti) do
			if cargoType &lt;&gt; 0 and
			   ti.cargoType &lt;&gt; cargoType then
				if orderByTA then
					continue;
				else
					break;
				endif;
			endif;
			
			if request&lt;&gt; null and request.operatorCode &lt;&gt; null then
				if ti.operatorCode &lt;&gt; request.operatorCode then
					if orderByTA then
						continue;
					else
						break;
					endif;
				endif;
			endif;
			
			self.addLogEntry(AP_Log_YA_Global,ti.id &amp; ", Best Pick Date/Time " &amp; ti.bestPickDT.asStringJMT &amp; " using " &amp; ti.getBestPickDTReason &amp; ", Overstows " &amp; ti.numOverstows.asStringJMT  , false);
			
			if ti.allLocations.isEmpty then
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not in a Yard Location", false);
				continue;
			endif;
			
			if ti.myTerminalArea = null then
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not in a Yard Location", false);
				continue;
			endif;
			
			if not ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
				//jlier1 1/10/25 MTN-35633
				self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not in a Yard Location", false);
				continue;
			endif;
			
			//28/10/2025	navkc1 JIRA 36411 -  Also check whether user has selected any row/col
			if request &lt;&gt; null and request.allTerminalAreaGridObj.first() &lt;&gt; null then
				loc := ti.myPrimaryActualLocation;
				
				if loc = null then
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " location is null", false);
					continue;
				endif;
				
				if not loc.isGridLocation() then
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not located in a grid area", false);
					continue;
				endif;
				
				gridCont := loc.CM_GridController;
				
				if not request.allTerminalAreaGridObj.includes(gridCont.myGridColumn) and not request.allTerminalAreaGridObj.includes(gridCont.myGridRow) then
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not located in a request terminal grid area", false);
					continue;
				endif;
			endif;
			
			if request &lt;&gt; null and request.allTerminalAreas.first &lt;&gt; null then
				if not request.allTerminalAreas.includes(ti.myTerminalArea) then
					//jlier1 1/10/25 MTN-35633
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " not located in a request terminal area", false);
					continue;
				endif;
			endif;
			if not ti.testAutoPlanRequestYA(self)  then
				continue;
			endif;

			//get all used cargo for terminal area
			if ti.myTerminalArea &lt;&gt; null  then
				if ti.myTerminalArea.isTIAllocatedInDirectorTask(ti,_request) then
					//jlier1 1/10/25 MTN-35633
					self.addLogEntry(AP_Log_YA_Default,ti.id &amp; " is already allocated to Director Task", false);
					continue;
				endif;
			endif;
			saveTi := ti;
			break;
			/*allOverstowedTIs.clear;
			sideAccessDirection:=null;
			ti.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null);
			thisOverstow := allOverstowedTIs.size;
			if thisOverstow = 0 then
				saveTi := ti;
				break;
			elseif thisOverstow &lt; lastOverstow then
				saveTi := ti;
				lastOverstow := thisOverstow;
			endif;*/
		endwhile;
		if saveTi &lt;&gt; null then				// 23676 for logging
			self.addLogEntry(AP_Log_YA_Global,'Located item (' &amp; saveTi.id &amp; ') in source location ' &amp; saveTi.locationId, false);
		endif;
	endif;
	
	// error code moved from searchAllocationsOut
	if saveTi = null then
		self.setHadError(true);
		self.createLoggingAlert();		// 23676
		
		if _termArea &lt;&gt; null then
			self.addLogEntry(AP_Log_YA_Default,'Cannot best-pick from area ' &amp; _termArea.id, false);	
			if not isBestPick then
				app.raiseCMException2(BestPickError, self.myCurrentCMIFYAAutoPlan.getID(), _termArea.id, null, null);
			endif;
		else
			self.addLogEntry(AP_Log_YA_Default,'Cannot best-pick from terminal ' &amp; _terminal.code, false);
			if not isBestPick then
				app.raiseCMException2(BestPickError, self.myCurrentCMIFYAAutoPlan.getID(), _terminal.code, null, null);
			endif;
		endif;
	endif;

	return saveTi;
epilog
	executeWhen JMTDevelopmentEnvironment;
		if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			app.writeStatement(self.getLoggingString);
		else
			app.writeStatement("self.myCurrentCMIFYAAutoPlan = null, nothing found.");
		endif;
	endExecuteWhen;

	self.forOutput := false;
	self.fillOptionOut := 0;
	self.lastOverstowLevel := 0;
	self.bestPickOverstowedTI := null;
	delete iter;
	delete dynaDict;
end;
</source>
