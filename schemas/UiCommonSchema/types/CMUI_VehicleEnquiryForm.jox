        <updating/>
        <source>cmbCarrier_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	carrier : CM_Carrier;

begin

	if combobox.listIndex &gt; 0 then
		carrier := combobox.listObject.CM_Carrier;
	endif;

	if carrier &lt;&gt; null then
		self.tblInput1.setValueByName(ETRow_Carrier, carrier.code &amp; "      " &amp; carrier.description);
	else
		self.tblInput1.setValueByName(ETRow_Carrier, null);
	endif;

epilog

end;</source>
