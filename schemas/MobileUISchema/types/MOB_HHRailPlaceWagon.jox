    <JadeMethod name="setReturningFromAnotherForm" id="b861a7ef-7142-48b0-a2d6-50765a342286">
        <updating/>
        <source>setReturningFromAnotherForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	rakePos : Integer;
	index : Integer;
	
begin

	if self.myMobileGenericAgent.myCurrentWagon &lt;&gt; null or self.myMobileGenericAgent.currentWagonPos &gt; 0 then
		
		wagon := self.myMobileGenericAgent.myCurrentWagon;
		rakePos := self.myMobileGenericAgent.currentWagonPos;

		if wagon &lt;&gt; null then
			index := self.cmbWagon.findObject(wagon);
			if index &gt; 0 then
				self.cmbWagon.listIndex := index;
				self.setRakePositionFromWagon(wagon);
			endif;
			
		elseif rakePos &gt; 0 and rakePos &lt;= cmbRakePos.listCount then
			self.cmbRakePos.listIndex := rakePos;
			self.cmbRakePos.click(cmbRakePos);
			
		endif;
	
		self.myMobileGenericAgent.setMyCurrentWagon(null);
		self.myMobileGenericAgent.setMyLocationsController(null);
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setCurrentRakePosition(0);
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTextOnCargoButton" id="9b26b3f6-5e82-426a-8f83-b4c2abcc4af1">
        <updating/>
        <source>setTextOnCargoButton( _btn : Button io; _text : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
APr 2010	cnwjre1	27016 ISO type also shown, allow for this when splitting the text
14 Oct 2014	NDL	Par 35040
*/

vars

	btnTextArea : Real;
	alphaText : String;
	numberText : String;
	isoText : String;
	pos : Integer;
	
begin

	if _text = null then
		_btn.caption := null;
		return;
	endif;
	
	btnTextArea := _btn.width - 4 ;	// don't print label on btn border
	_btn.fontSize := 9;	// default size
	if _btn.getTextExtent( _text ) &lt;= btnTextArea then
		_btn.caption := _text;
		return;
	endif;

	// get the individual bits in case we have to split it up.
	foreach pos in 1 to _text.length do
		if _text[pos].Character.isAlpha then
			alphaText := alphaText &amp; _text[pos];
			continue;
		endif;
		break;
	endforeach;
	if alphaText.length &lt; _text.length then
		numberText := _text[alphaText.length + 1:end];
		pos := numberText.pos(CrLf, 1);
		if pos &gt; 0 then
			if pos+2 &lt; numberText.length then
				isoText := numberText[pos+2:end];
			endif;
			if pos &gt; 1 then
				numberText := numberText[1:pos-1];
			endif;
		endif;
	endif;
	
	while true do
	/*	if _btn.getTextExtent( _text ) &lt;= btnTextArea then
			_btn.caption := _text;
			return;
		endif;
		if _btn.getTextExtent( numberText ) &lt;= btnTextArea then
			_btn.caption := isoText &amp; " " &amp; alphaText &amp; CrLf &amp; numberText;
			return;
		endif; */
		//14 Nov 2011	NDL	Par 28674
		if _btn.getTextExtent( _text ) &lt;= btnTextArea and _btn.getTextExtent( numberText ) &lt;= btnTextArea then
			_btn.caption := isoText &amp; " " &amp; alphaText &amp; CrLf &amp; numberText;
			return;
		endif;
		if _btn.getTextExtent( numberText ) &lt;= btnTextArea and  _btn.getTextHeight("H") * 3 &lt;= ( _btn.height - 4 ) then
			_btn.caption := isoText &amp; CrLf &amp; alphaText &amp; CrLf &amp; numberText;
			return;
		endif;
		
		if _btn.fontSize &lt; 6 then
			_btn.caption := null;
			return;
		endif;
		_btn.fontSize := _btn.fontSize - 1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_btn" type="Button" usage="io"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
