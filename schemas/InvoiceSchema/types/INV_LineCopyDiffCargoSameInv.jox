    <JadeMethod name="doMnuColumnOrganiserClick" id="95109bd1-e676-486f-abd9-49fe7ff9aed3">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	tbl  	: CM_DataTable;
	iter 	: Iterator;
	ti   	: CM_TrackedItem;
	count,
	idx	 	: Integer;
begin
	tbl := menuItem.userObject.CM_DataTable;

	self.tblResults.showColumnOrganiserFrm(self.myTerminal, self.tblResults.allTblDataEntRows);
	
	iter := self.allTIs.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);

	while iter.next(ti) do
		count := count + 1;
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="ce955320-714f-4efe-b993-30cca5876576">
        <updating/>
        <source>doSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/
vars
	controller   	: CMIF_InvoiceLineCopy;
	theTable 		: CM_DataTable;
	realInvLine,
	pxyInvLine 	    : CM_InvoiceLine;
	theReturn 	    : Integer;
	ls 			    : Boolean;
	tmpQty 			: Real;
	cargoId         : String;
	startTS			: TimeStamp;
	invLine         : CM_InvoiceLine;
begin
 	theTable := self.tblResults;
	
	create controller transient;
	self.allSelectedInvoiceLines.copy(controller.allSelectedInvoiceLines);
	controller.setValues(false,true,false,null,self.allTIs,null); 
	
	
	if controller.allTrackedItems.size() &gt; 0 then
		if app.msgBox(app.getErrorString2(Pleas_confi_invLines_items,(controller.allSelectedInvoiceLines.size()) .String,
						controller.allTrackedItems.size().String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			global.beep;
			return;
		endif;
	endif;
	
	while true do
		app.myTrxCA.trxCopyInvoiceLine(controller,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Copy", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	
	self.tblResults.clear();
	self.unloadForm();
	
epilog
	app.cmsEndLoad(ls);
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblSelectorContMenu" id="81daebbb-a6c3-433e-b7de-c681a62f9ea8">
        <updating/>
        <source>doTblSelectorContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganizer.visible := true;
	self.mnuColumnOrganizer.userObject := self.tblResults;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
