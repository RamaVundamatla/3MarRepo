    </JadeMethod>
    <JadeMethod name="clearProxyDetails" id="237db377-8e4e-46c4-8c80-73e3bbe6af9e">
        <updating/>
        <source>clearProxyDetails() updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if global.isValidObject(self.myProxyShift) then //no overhead for transient
		self.myProxyShift.erase(NORMAL_ERASE);
		self.myProxyShift := null;
	else
		self.myProxyShift := null;
	endif;
end;</source>
    </JadeMethod>
