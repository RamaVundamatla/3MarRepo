    <JadeMethod name="doLoadTrains" id="84ead4aa-368c-441f-aae0-505161ccc325">
        <source>doLoadTrains() protected;
// ---------------------------------------------------------------------------
// Created:     March 2010 ANDREW BISHOP
//
vars
	cmb						: ComboBox;
	tr : CM_Train;
begin
	cmb := self.cmbFilterTrain;
	cmb.clear();
	
	foreach tr in self.myTerminal.allTrainsOnTerminal do
		//cmb.itemObject[cmb.addItem(tr.description)] := tr;
