    <JadeMethod name="zTblDataResort" id="3c20c0d6-3ba6-464d-a1dd-0355e9b3a57f">
        <updating/>
        <source>zTblDataResort() updating,protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	#cnwdz2	 par19625

*/

vars
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;
	obj			: Object;
begin

	
	sortColNo := tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; tblData.columns then
		return;
	endif;
	
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	

		sortColName := tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	self.tblData.resortTableByColumn(sortColNo);

	startRow := self.tblData.fixedRows + 1;
	endRow	:= self.tblData.rows;
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
