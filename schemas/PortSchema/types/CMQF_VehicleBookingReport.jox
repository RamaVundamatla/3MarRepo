        <source>setDatesForTemplateRun(_runDate: Date) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(_runDate);
	self.dateFrom := self.setDateFromTemplate(self.getDateFromType, self.getDateFromFactor, _runDate);
	self.dateTo := self.setDateFromTemplate(self.getDateToType, self.getDateToFactor, _runDate);	

epilog

end;</source>
