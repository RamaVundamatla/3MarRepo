    <JadeMethod name="setupForm" id="86e9835e-c4c4-4906-aaad-523d9a3b937f">
        <updating/>
        <source>setupForm() updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 10/03/2016	cnwdap1		PAR #37585 Turn off context menu so it doesn't appear by default
// 04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
vars

begin
	self.caption := app.getErrorString(Future_storag_invoic_line_mapp);

	inheritMethod();
	self.btnAdd.visible := true;		// 37434
	self.btnAddSub.visible := true;	 // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
	
	self.showStorageDetail();
	self.loadCombos();
	self.loadStorageTable();
	
	self.mnuContext.visible := false;	// PAR #37585
	
	// TFS 7496
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
	
	//19 Dec 2017	NDL	TFS 8095
	self.btnAudits.enabled := self.myQuantityRangeMap &lt;&gt; null and self.myQuantityRangeMap.hasAudits;	//14 Jan 2021	NDL	TFS 50152
end;
</source>
    </JadeMethod>
    <JadeMethod name="showStorageDetail" id="4e1aff81-c95f-48f3-90d8-8dd33fb99945">
        <updating/>
        <source>showStorageDetail() updating, protected;

vars
	yac			: CM_YACriteria;
	str			: String;
begin
	if self.myStorageDetail = null then
		return;
	endif;

	foreach yac in myStorageDetail.allCriteria do
		if str = null then
			str := yac.myYACriteriaType.description &amp; " " &amp; yac.getRawDescription;
		else
			str := str &amp; ', ' &amp; yac.myYACriteriaType.description &amp; " " &amp; yac.getRawDescription;
		endif;
	endforeach;

	self.lblCriteria.caption := str;
end;
</source>
        <access>protected</access>
    </JadeMethod>
