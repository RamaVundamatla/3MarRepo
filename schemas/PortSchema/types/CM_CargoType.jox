    <JadeMethod name="isReefer" id="75eedc82-9007-4c4c-ba08-17ef130c5bc3">
        <source>isReefer(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2019 cnwma1	Bug 46793: Web Portal - Prenotes for non container cargo that has a commodity that requires temperature does not show reefer section

*/

vars
	commodity : CM_Commodity;
	product   : CM_Product;
begin
	if self.id = TI_CargoType_Container then
		return true;
	elseif self.allCommodities.isNotEmpty then                        
		foreach commodity in self.allCommodities discreteLock do 
			if commodity.hasTemp then
				return true;
			endif;
		endforeach;
	else
		if self.mySystemProductType &lt;&gt; null then
			return self.mySystemProductType.isReefer;
		elseif self.hasProductTypes() then
			foreach product in self.allProducts discreteLock do
				if product.isReefer then
					return true;
				endif;
			endforeach;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
