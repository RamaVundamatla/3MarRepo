begin
	inheritMethod();
	self.displayTable();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowButtons" id="7d3c58c8-919a-430d-ada7-b3358d33a966">
        <source>doShowButtons(_show : Boolean);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.btnEnquiry.enabled := _show;
	self.btnEditItem.enabled := _show;
	self.btnDelete.enabled := _show;
	self.btnRemarks.enabled := _show;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
		self.btnRemarks.enabled := false;
		self.btnNew.enabled:= false;

	endif;

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="0dd397c7-d0af-4003-aba7-25ae367942e0">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	idx : Integer;
	theDataLine : String;
begin
	if eventType = Object_Delete_Event  then
		self.doQuery;
		if self.tblData.rows = self.tblData.fixedRows then
			self.doShowButtons(false);
		endif;
	endif;
	if theObject = null or (not global.isValidObject(theObject)) then
		return;
	endif;

	
	if theObject.isKindOf(CM_TrackedItem) and eventType = Object_Update_Event then
		theTI := theObject.CM_TrackedItem;
		if self.tblData.findObjectInRow(theTI,idx) then
			theDataLine := theTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(idx,1).text := theDataLine;
			if self.tblInfo.userObject = theTI then
				self.doTblDataRowColChange(self.tblData);
			endif;
			if theTI.myMatchedTBA &lt;&gt; null then // PAR 35574
				self.tblData.accessRow(idx).backColor := LightGreen;
			else
				self.tblData.accessRow(idx).backColor := White;
			endif;
		endif;
	else
		inheritMethod(eventType, theObject, eventTag);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="87904f16-cd2d-43f7-98c6-2aca0e03144b">
