        <source>setSubTerminalOptions(	_isTurnedOn:Boolean;
						_stForExportFull:CM_SubTerminal;
						_stForExportMTY:CM_SubTerminal;
						_stForImportFull:CM_SubTerminal;
						_stForImportMTY:CM_SubTerminal;
						_stForStorageFull:CM_SubTerminal;
						_stForStorageMTY:CM_SubTerminal) updating;
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Updates the Terminal Config options for Sub-Terminals.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isSubTerminalsOn				:=	_isTurnedOn;
	self.mySubTerminalForExportFull		:=	_stForExportFull;
	self.mySubTerminalForExportMTY		:=	_stForExportMTY;
	self.mySubTerminalForImportFull		:=	_stForImportFull;
	self.mySubTerminalForImportMTY		:=	_stForImportMTY;
	self.mySubTerminalForStorageFull	:=	_stForStorageFull;
	self.mySubTerminalForStorageMTY		:=	_stForStorageMTY;
end;</source>
