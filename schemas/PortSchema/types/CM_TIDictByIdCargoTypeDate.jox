<CollClass name="CM_TIDictByIdCargoTypeDate" id="95708582-868f-4f43-a8df-cbbea7dd5c84">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TrackedItemDicts"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="lookupAllTIsUsingIdCargoType" id="361f6e4a-2388-45e6-ad99-193cd94d3ade">
        <source>lookupAllTIsUsingIdCargoType(pId: String; pCargoType: Integer; _set: CM_TISet input; _cmifMonitor : CMIF_Monitor input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			This can be used on the dicts that have ID and cargoType only
					as the keys.  If cargoType = TI_CargoType_Null then 
					return ALL LIKE TI with this id
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
	iter	: Iterator;
	keyId	: String;
	keyType	: Integer;
	keyTime : TimeStamp;
begin

	if _set = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TISet', null, null);
		return false;
	endif;

	iter := self.createIterator;
	self.startKeyGeq(pId, pCargoType, null, iter);
	
	while iter.next(tmpTI) do
		if _cmifMonitor &lt;&gt; null then
			if (not self.checkProgress(_cmifMonitor)) then
				return false;
			endif;
		endif;
		iter.getCurrentKeys(keyId,keyType,keyTime); //MTN-35226
		if pCargoType &gt; 0 then	//06 Nov 2015	NDL	Par 36767
			if keyType &lt;&gt; pCargoType then
				continue;	//We need to get to the correct cargo type
			endif;
			if keyType &gt; pCargoType then
				break;	//Weve passed the type we are looking for
			endif;
		endif;
		if not keyId.startsWith(pId)  then
			break;	//If the key isnt right, quit here.
		endif;
		_set.addNoDuplicates(tmpTI, false);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.numFound := _cmifMonitor.numFound + 1;
		endif;
	endwhile;
	
	return true;
	
epilog
	delete iter;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_set" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIdCargoType" id="55e9c188-2500-4c17-98c2-4d1027e7ef5e">
        <source>lookupTIUsingIdCargoType(pId: String; pCargoType: Integer): CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
	keyTime : TimeStamp;
begin

	if pCargoType = TI_CargoType_Null then
		return null;
	endif;
	
	tmpTI := self.getAtKeyGeq( pId, pCargoType, null);
//not checking key
	if tmpTI = null then
		return null;	//Make it a bit obvious
	endif;
	if tmpTI.id = pId then
		return tmpTI;
	endif;
	return null;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
