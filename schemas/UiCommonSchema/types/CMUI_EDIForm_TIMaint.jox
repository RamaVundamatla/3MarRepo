    <JadeMethod name="saveEDITIChanges" id="4b1e7f63-4886-40e6-a65b-bc0d9c035eac">
        <source>saveEDITIChanges(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
vars
	ediTIs 		: CM_EDITIById;
	ediUIAgent  : CMUI_EDIAgent;
begin
		
	create ediTIs transient;
	
	//epr TFS 2606 refactored to use this method for reuse
	create ediUIAgent transient;
	ediUIAgent.saveEDITIChangesToPxy(self.tblEDITI,ediTIs,_passport);

	app.myTrxUA.trxUpdateEDITIs(ediTIs, _passport);
epilog
	
	ediTIs.purge();	//clear proxies
	delete ediTIs;
	delete ediUIAgent;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="aba29618-425c-489a-8419-813bf19a4aaa">
        <updating/>
        <source>setTableDataFromOrganiser(_table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
begin
	table := self.tblEDITI;
	
	app.mousePointer := MP_HOURGLASS;

	self.showEDITIs(self.tblEDITI);	// par 29842 Sep 2012

	if not app.isDevelopmentSystem then
		// hide the last column (hasChanged column)
		table.accessColumn(table.columns).visible := false;	
	endif;
	
	self.ediTIDataNeedsRefresh 	:= false;
epilog
	app.mousePointer 			:= MP_DEFAULT;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="3e3ddf81-4c93-4630-9def-67c5245a3d3d">
        <updating/>
        <source>setupContextMenuItems(_conwin: Window input) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/08/2023	navmd1		TFS 59024 Handle JSON messages
// 05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
// ---------------------------------------------------------------------------
vars
	tmpMenu			: MenuItem;
	ediBayPlan		: CM_EDIDataBayPlan;
	voyage			: CM_Voyage;
	canMaintain		: Boolean;
	releaseRequest	: Boolean;		
	obj 			: Object;
	canReload		: Boolean;
	tiTable 		: CM_DataTable;
begin
	canMaintain 	:= app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	
	
	// hide everything
	self.mnuTblVShowHideData.visible 	:= false;
	self.mnuEDILineJump.visible 		:= false;
	self.mnuEdiEditAdd.visible 			:= false;
	self.mnuEdiEditDelete.visible 		:= false;
	self.mnuEdiEditFindReplace.visible 	:= false;
	self.mnuEDISortByCol.visible 		:= false;
	self.mnuExtractDB.visible 			:= false;
	self.mnuDBLoad.visible 				:= false;
	self.mnuQueuedForBGP.visible		:= false;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
	self.mnuDelete.visible 				:= false;
	self.mnuEditFile.visible 			:= false;
	self.mnuEdiXML.visible 				:= false;
	self.mnuEdiJSON.visible				:= false;
	self.mnuExtractFile.visible 		:= false;
	self.mnuVerify.visible 				:= false;
	self.mnuLoadNew.visible 			:= false;
	self.mnuReload.visible 				:= false;
	self.mnuMakeActual.visible 			:= false;
	self.mnuTranshipSummary.visible		:= false;
	self.mnuCreateCargo.visible			:= false;
	self.mnuLoadAs.visible 				:= false;
	self.mnuRemoveOthers.visible 		:= false;
	self.mnuRemoveOthers.enabled		:= false;
	self.mnuSep3.visible				:= false;		
	self.mnuSep2.visible				:= false;
	self.mnuSep1.visible				:= false;
	self.mnuEdiEditViewFile.visible		:= false;
	self.mnuEdiFindTI.visible			:= false;
	self.mnuSetStatus.visible			:= false;
	
	// just show what we need
	if _conwin = self.tblEDITI then
		self.mnuEdiEditFindReplace.visible	:= canMaintain;
		self.mnuSep2.visible				:= canMaintain;

		self.enableMnuEditFile( true );	
		
		self.mnuSep1.visible 				:= canMaintain;
		self.mnuEDISortByCol.visible 		:= true;
		
		if self.myCurrentObject.CM_EDIFileType.getEDIDataType = EDIDataType_CustomStop then
			self.mnuEdiEditViewFile.visible	:= (_conwin = self.tblEDITI);
			self.mnuEdiFindTI.visible 		:= (_conwin = self.tblEDITI);
			
		elseif self.myCurrentObject.CM_EDIFileType.getEDIDataType = EDIDataType_OperatorStop then
			self.mnuEdiFindTI.visible 		:= (_conwin = self.tblEDITI); 
		endif;
		
		tiTable := _conwin.CM_DataTable; 
		self.mnuTblVInspectObject.userObject := tiTable.accessRow(tiTable.row).itemObject;

	elseif _conwin = self.tblEDITIError then
		self.mnuEDILineJump.visible := true;
	endif;
	
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSep1, false);

	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEDISortByCol, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiEditViewFile, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiFindTI, false);

	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSep2, false);
	
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSep3, false);		
	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneTop, self.mnuLoadAs, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiXML, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiJSON, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEditFile, false);
	
	//and others
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiEditFindReplace, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiEditDelete, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEdiEditAdd, false);
	
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuEDILineJump, false);
end;</source>
        <Parameter name="_conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2a685ba3-486b-4c06-af19-4d77b5300204">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	self.setCaption (self.myCurrentObject.CM_EDIFileType.name);
	self.setNavigatorHeading(self.caption);
	
	self.showDataForCurrentObject (false); //epr TFS 2606 show with object if not in edit mode
	if self.amInitialisingInEditMode then
		
		self.doEditEDIDataDetails;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showDataForCurrentObject" id="7a8e540e-81be-4ed5-9b81-ffd44c9c1816">
        <updating/>
        <source>showDataForCurrentObject(_verifying: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData			: CM_EDIData;
	entTableName 	: String;
	ediTIClass 		: Class;
	ediTI 			: CM_EDITrackedItem;
	table 			: CM_DataTable;
	entTableNames : StringArray;
begin
	if not self.ediTIDataNeedsRefresh then 
		return;
	endif;

	self.resetNotifications;
	
	if not CM_EDIFileType.hasInstance(self.myCurrentObject) then 
		return;
	endif;
	
	if self.allEDITrackedItems.isEmpty then 
		return;
	endif;
	
	self.ediTIDataNeedsRefresh := false;
	
	if not _verifying then
		self.hideVerifyErrors();	
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	self.doWindowEvents(0);

	ediData 		:= self.allEDIData.first;
	
	create entTableNames transient;
	
	ediData.getMyTIDisplayDefNames(entTableNames);
	
	entTableName 	:= entTableNames[1];
	ediTIClass		:= ediData.getEDITIType(0);	
	table 			:= self.tblEDITI;
	table.rows 		:= 1;
	
	table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(entTableName));
	
	table.tabKey := J_key_Tab;
	
	if not table.myDynaDict.isEmpty then
		table.myDynaDict.clear;
		table.myDynaDict.clearKeys;
	else
		self.ediTIDynaDictFirstUse := false;
	endif;
	
	table.setMyDataClass(ediTIClass);
	table.myDynaDict.addMemberKey('id', false, true);
	table.myDynaDict.endKeys(true);
	
	foreach ediTI in self.allEDITrackedItems do
		self.beginNotification (ediTI, Object_Update_Event, Response_Continuous, null);
		self.beginNotification (ediTI, Object_Delete_Event, Response_Continuous, null);
		
		table.myDynaDict.addNoDuplicates (ediTI, false);
	endforeach;
	
	table.tabKey := J_key_Tab;
		
	if not app.isDevelopmentSystem then
		table.hideColumnByColName (ETRow_HasChanged);
	endif;
	
	self.showEDITIs(self.tblEDITI);	// par 29842 Sep 2012
	
	self.shtEDIData.caption := self.myAssistant.getEDIDisplayStrForType (ediData.getEDIDataType);
epilog
	app.mousePointer := MP_DEFAULT;
	delete entTableNames;
end;</source>
        <Parameter name="_verifying" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithCollection" id="4ff20e8a-105f-4d6f-aa4b-706efa85052a">
        <updating/>
        <source>showWithCollection(_coll :ObjectArray; _doEdit :Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  _coll	an array of CM_EDIData
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	data			:CM_EDIData;
	dataType,
	dataType2		:Integer;
	fileType		:CM_EDIFileType;
	obj				:Object;
	gotException 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	data	:= _coll.first.CM_EDIData;
	
	if data = null then 
		return;
	endif;
	
	// populate ediData collection on form
	foreach obj in _coll do
		data := obj.CM_EDIData;
		
		// we only handle ediData of the same data type
		dataType	:= data.getEDIDataType;
		// if data is invalid then we will resume here
		if gotException then
			gotException := false;
			continue;
		endif;
		
		if dataType2 = null then	
			// only handle 2 data types
			if dataType &lt;&gt; EDIDataType_CustomStop and
				dataType &lt;&gt; EDIDataType_OperatorStop then
				continue;
			endif;
			dataType2 := dataType;
		else
			// must be same as the rest
			if dataType &lt;&gt; dataType2 then
				continue;
			endif;
		endif;
		
		self.allEDIData.add (data);
		
		fileType := data.getEDIFileType;
	endforeach;
	
	if self.allEDIData.isEmpty then
		self.unloadForm;
		return;
	endif;
	
	// show the form using the file type as a 'dummy' object
	self.showWithObject (fileType, true, _doEdit);
epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d501a5cf-6098-49eb-ab56-4638b0d25f89">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016031, locale);
end;</source>
    </JadeMethod>
</GUIClass>
