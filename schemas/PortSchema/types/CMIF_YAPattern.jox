    <JadeMethod name="getTokens" id="baba868b-67c3-435c-a3d2-d6491d513e19">
        <source>getTokens(_str : String; _tokens: StringArray input);
//03 August 2008	cnwdw1	
//
constants
	Delimiters = ",";

vars
	pos: Integer;
	token: String;
	
begin
	if _str = null then	
		return;
	endif;
	
	while true do
		pos := pos + 1;
		
		if pos &gt; _str.length then // cnwrd1 18.3.09 gives error if string is 'xxx,'
			break;
		endif;
		token := _str.scanUntil( Delimiters, pos ).trimBlanks;
		if token &lt;&gt; null then
			_tokens.add( token );
		endif;
		if pos = 0 then
			break;
		endif;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_tokens" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasHazardous" id="8dcc1219-7df8-43db-8047-713352a53f69">
        <source>hasHazardous() : Boolean;
//28 August 2008	cnwdw1	
// Hazardous can include a L to indicate Limited Quantity
begin
	return self.pattern.containsOneOf("L");
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRange" id="92c29a57-92e1-47cf-9dc3-a59898d1aa45">
        <source>hasRange() : Boolean;
//19 August 2008	cnwdw1	
// Return true if the pattern has any range characters
vars
begin
//	return self.pattern.containsOneOf("&gt;&lt;=-");
	return self.pattern.containsOneOf("-");	// 26 Jan 2011	NDL	Par 26771
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTempRange" id="b2e01ad5-7730-4fb1-8f9f-80f736b1bd32">
        <source>hasTempRange() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	return self.pattern.containsOneOf("-");
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasWeightRange" id="a5249bfa-5dc3-44a4-bb8a-e06628250d9c">
        <source>hasWeightRange():Boolean;
//15 December 2009	cnwml2


vars

begin
//	return self.pattern.containsOneOf("&gt;&lt;=-T");
	return self.pattern.containsOneOf("-");	// 26 Jan 2011	NDL	Par 26771
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasWildcard" id="ad3aabd4-2b9b-4c75-a598-9dd9fa706bbd">
        <source>hasWildcard() : Boolean;
//03 August 2008	cnwdw1	
// Return true if the pattern has any wildcard characters
begin
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1	default case has null pattern
	if self.pattern = null then
		return false;
	endif;

	return self.pattern.containsOneOf("*!");
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPattern" id="8491fefc-cba4-4d2e-8b37-08afd736cbaf">
        <source>isPattern(): Boolean;
//14 December 2009	cnwdw1	
//
// Changed On	By			Reason
// ----------	-------		-------------------------------------------------
// 29/04/2015	cnwdap1		PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
vars

begin
	//+cnwml2 PAR23586 POL CCMS 1878
	if self.type = YAPattern_Hazardous then
		return self.hasHazardous;
	elseif self.type = YAPattern_WeightRange then
		return self.hasWeightRange;
	elseif self.type = YAPattern_Wildcard then
		return self.hasWildcard;
	elseif self.type = YAPattern_Range then
		return self.hasRange or self.hasWildcard;
	elseif self.type = YAPattern_TempRange then				// PAR #36094
		return self.hasTempRange;							// PAR #36094
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidAlpha" id="212a9a90-f986-42e3-b143-33e640768c56">
        <source>isValidAlpha(_str : String):Boolean;
//24 May 2010	cnwml2
//+cnwml2 PAR24287
//+cnwjo3 PAR23437
vars
	validAlphaChars : String;
begin
	validAlphaChars := "_-.&amp;:/ ";
	
	if _str.containsOneOf(validAlphaChars) then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="match" id="e81ac78b-8f2c-4c0f-b41e-e82dddab5a6d">
        <source>match(_value: Any): Boolean;
//14 December 2009	cnwdw1	
//+cnwml2 MSL CCMS 1017
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 23/05/2014	cnwdap1		PAR #33715 Allow for decimal places in Weight Range criteria
// 29/04/2015	cnwdap1		PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
constants
	Zeros = "00000000000";								// PAR #33715
vars
	tokens : StringArray;
	rawToken, token : String;
	valueFrom, valueTo : String;
	index, pos : Integer;
	result: Boolean;
	valueFromInt : Integer;
	valueToInt : Integer;
	valueInt : Integer;
	dotPos, tPos, nbrZeros : Integer;					// PAR #33715
	insertStr, tempToken : String;						// PAR #33715
	occurrences, first, second, third : Integer;		// PAR #36094
begin

	create tokens transient;
	
	self.getTokens(self.pattern.toUpper(), tokens);  // Par 32190
	foreach rawToken in tokens do
		token := rawToken.trimWhiteSpace;
		if token = null then
			return false;
		endif;
		
		result := false;
		if self.type = YAPattern_WeightRange then
			while token.cnContains(".") do														// PAR #33715
				dotPos := token.pos(".", 1);													// PAR #33715
				tPos := token.pos("T", 1);														// PAR #33715
				if dotPos &gt; tPos then															// PAR #33715
					tempToken := token[1:tPos-1] &amp; Zeros[1:3] &amp; token[tPos+1:end];				// PAR #33715
				else																			// PAR #33715
					nbrZeros := 4 - (tPos - dotPos);											// PAR #33715
					if nbrZeros &gt; null then														// PAR #33715
						insertStr := Zeros[1:nbrZeros];											// PAR #33715
					else																		// PAR #33715
						insertStr := null;														// PAR #33715
					endif;																		// PAR #33715
					tempToken := token[1:dotPos-1] &amp; token[dotPos+1:tPos-dotPos-1] &amp; insertStr;	// PAR #33715
					if tPos &lt; token.length then													// PAR #33715
						tempToken := tempToken &amp; token[tPos+1:end];								// PAR #33715
					endif;																		// PAR #33715
				endif;																			// PAR #33715
				token := tempToken;																// PAR #33715
			endwhile;																			// PAR #33715
			token := token.cnEcFindReplace("T", "000", false);
			if token.cnContains("-") then
				pos := token.pos("-", 1);
				valueFrom := token[1:pos - 1];
				valueTo := token[pos + 1:end];
				//26 Jan 2011	NDL Par 26771 
				if valueFrom.isInteger and valueTo.isInteger then
					valueFromInt := valueFrom.Integer;
					valueToInt := valueTo.Integer;
					if _value.Integer &gt;= valueFromInt and _value.Integer &lt;= valueToInt then
						result := true;
					else
						result := false;
					endif;
				else
					if _value.String &gt;= valueFrom and _value.String &lt;= valueTo then
						result := true;
					else
						result := false;
					endif;
				endif;
			
			else
				//26 Jan 2011	NDL Par 26771 
				if token.isInteger then
					valueInt := token.Integer;
					if valueInt = _value.Integer then				
						result := true;
					else
						result := false;
					endif;
				else
					if token = _value.String then				
						result := true;
					else
						result := false;
					endif;
				endif;
			endif;
			
		elseif self.type = YAPattern_Range then
			if token.cnContains("-") then
				pos := token.pos("-", 1);
				valueFrom := token[1:pos - 1];
				valueTo := token[pos + 1:end];
				
				if _value.String.isReal and valueFrom.isReal and valueTo.isReal then	//05 Nov 2012	NDL	Par 30518
					if _value.String.Real &gt;= valueFrom.Real and _value.String.Real &lt;= valueTo.Real then
						result := true;
					else
						result := false;
					endif;
					
				else
					if _value.String &gt;= valueFrom and _value.String &lt;= valueTo then
						result := true;
					else
						result := false;
					endif;
					
				endif;
			else
				if _value.String.startsWith(token) then		//+cnwml2 PAR23586 POL CCMS 1878
					result := true;
				else
					result := self.matchWildCard(token, _value);		//+cnwml2 PAR23586 POL CCMS 1878
				endif;
			endif;
		
		// PAR #36094 Check temperature range matching
		elseif self.type = YAPattern_TempRange then
			valueFrom := null;
			valueTo := null;
			occurrences := token.countOccurrences("-");
			if occurrences &gt; 0 then
				first := token.pos("-", 1);
				if occurrences &gt; 1 then
					second := token.pos("-", first+1);
					if occurrences &gt; 2 then
						third := token.pos("-", second+1);
					endif;
				endif;
			endif;
			if occurrences = 1 then
				if first = 1 then
					if _value.String.startsWith(token) then
						result := true;
					else
						result := self.matchWildCard(token, _value);
					endif;
				else
					valueFrom := token[1:first-1];
					valueTo := token[first+1:end];
				endif;
			elseif occurrences = 2 then
				if first = 1 then
					valueFrom := token[1:second-1];
					valueTo := token[second+1:end];
				endif;
			elseif occurrences = 3 then
				valueFrom := token[first:second-1];
				valueTo := token[second+1:end];
			endif;
			
			if valueFrom &lt;&gt; null and valueTo &lt;&gt; null then
				if _value.String.isReal then
					if _value.String.Real &gt;= valueFrom.Real and _value.String.Real &lt;= valueTo.Real then
						result := true;
					else
						result := false;
					endif;
				else
					if _value.String &gt;= valueFrom and _value.String &lt;= valueTo then
						result := true;
					else
						result := false;
					endif;
				endif;
			endif;
			// PAR #36094 end
				
		else
			result := self.matchWildCard(token, _value);				//+cnwml2 PAR23586 POL CCMS 1878
			
		endif;
		
		if result then
			return true;
		endif;
		
	endforeach;
	
	return false;
	
epilog
	delete tokens;		// PAR #18009
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchWildCard" id="4843ba37-1297-4383-a98f-ca3615de1053">
        <source>matchWildCard(_token : String input; _value : Any):Boolean;
//13 April 2010	cnwml2
//+PAR 23586 POL CCMS 1878
// from par 31221 Port Nelson have commodities with a leading '*' on their code such as *BER and *LOG.  Added code to match these as is

vars
	str : String;
	str2 : String;
	result : Boolean;
begin

	//+cnwml2 PAR24472
	if _token = _value.String then
		return true;
	endif;
	// from 31221, protect against '*' or '!' with nothing before or after (will get index of out bounds in substring code below)
	// NOTE: should '*' return true - i.e. match against anything?
	if _token = "!" or
	   _token = "*" then
		return false;
	endif;
	
	if _token[_token.length:1] = '*' then
		str := _token[1:_token.length-1];
		if _token[1] = '*' then			//+cnwml2 PAR23882
			str := str[2:_token.length];
		endif;
	endif;
	
	//+cnwml2 PAR23882
	if str = null then
		if _token[1] = '*' then
			str := _token[2:_token.length];
			str2 := _token;	// 31221
		endif;
	endif;
	
	result := true;
	if str &lt;&gt; null then
		if str[1] = '!' then
			str := str[2:str.length];
			result := false;
		endif;

	else
		if _token[1] = '!' then
			str := _token[2:_token.length];
			result := false;
		endif;
	endif;
	
	if str = null then
		result := false;
	else
		if _value.String.startsWith(str) then
			result := result;
		elseif str2 &lt;&gt; null and _value.String.startsWith(str2) then
			result := result;		// 31221
		elseif _value.String.cnContains(str) then			//+cnwml2 PAR23882
			result := result;
		else
			result := not result;
		endif;
	endif;

	return result;
epilog

end;</source>
        <Parameter name="_token" type="String" usage="input"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPattern" id="11aabdac-28d5-4946-93ff-26dc5e87deec">
        <updating/>
        <source>setPattern(_value: String; _type: Integer) updating;
//03 August 2008	cnwdw1	
//
vars

begin
	self.pattern := _value;
	self.type := _type;
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setType" id="ca461aa0-da82-4016-93e5-b068dcefcbbb">
        <updating/>
        <source>setType(_type: Integer) updating;
//28 August 2008	cnwdw1	
// Set the type of pattern - See Constants for the valid Pattern types
vars

begin
	self.type := _type;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="c3c59c24-6801-4458-83af-b0928c1d0198">
        <source>validate(_pattern : String; _term : CM_Terminal):Boolean;
//13 May 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 23/05/2014	cnwdap1		PAR #33715 Allow decimal places in Weigh Flexi criteria
// 03/06/2014	cnwdap1		PAR #34279 Ensure weight flexi pattern has a "T" at the end of each token
// 28/04/2015	cnwdap1		PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 23/04/2024   navsp1      Bug 63724: MSL- IMPOSSIBLE TO PERFORM TEST AUTOPLAN, AUTOQUEUE AND GATE IN ERRO(4031)
// 23/08/2024	navbs1		Bug 65510: PEN - Weight Flexi field no longer allows use of decimals
vars
	tokens : StringArray;
	str, rawToken, token : String;
	index : Integer;
	position : Integer;
	multiToken1, multiToken2 : String;
	capStr : String;
	nullOperator: CM_Operator;
	occurrences, first, second, third : Integer;			// PAR #36094
begin
	create tokens transient;
	self.getTokens(_pattern, tokens);

	foreach rawToken in tokens do
		token := rawToken.trimWhiteSpace;
		if token = null then
			return false;
		endif;
		
		str := token;
		if self.type = YAPattern_Wildcard then
		
			//cnwjo3 par 23437
			if _term &lt;&gt; null then
				if str = _term.getNullVoyage.getYADisplay() then  //if its a NULL VOYAGE continue to next token
					continue;
				elseif str.toUpper() = _term.getNullTrain.getYADisplay().toUpper() then //if its a Default Train continue to next token
					continue;
				else
					nullOperator := _term.getNullOperator();				// 25469
					if nullOperator &lt;&gt; null and str.toUpper() = nullOperator.code.toUpper() then  //if its a NULL Operator go to next token
						continue;
					endif;
				endif;
			endif;		
		
			if str[1] = "!" or str[1] = "*" then
				if str.length &gt; 1 then
					str := str[2:str.length];
				else
					return false;
				endif;
			endif;
			
			if str[str.length] = "*" then
				str := str[1:str.length-1];
			endif;
			
			index := 1;
			while index &lt;= str.length do
				if  not (str[index].isNumeric or str[index].isAlpha or self.isValidAlpha(str[index])) then
					return false;
				endif;
				index := index + 1;
			endwhile;
			
		elseif self.type = YAPattern_Range then
			//if a ! or * or &gt; or &lt; or &gt;= or &lt;= is at the start
			if str[1] = "!" or str[1] = "*" then
				if str.length &gt; 1 then
					str := str[2:str.length];
				else
					return false;
				endif;
//26 Apr 2011	NDL	Par 26771	- simplify validation to the values we actually use in the 'match' i.e. drop &lt;, &gt; and =
/*			elseif str[1] = "&gt;" or str[1] = "&lt;" then
				if str.length &gt; 1 then
					if str[2] = "=" then
						if str.length &gt; 2 then
							str := str[3:str.length];
						else
							return false;
						endif;
					else
						str := str[2:str.length];
					endif;
				else
					return false;
				endif; */
			endif;
			
			//if a * is at the end
			if str[str.length] = "*" then
				str := str[1:str.length-1];
			endif;
			
			//if - is in the middle
			if str.pos("-", 1) &gt; 0 then
				position := str.pos("-" , 1);
				if not position = str.length  and not position = 1 then
					if str.countOccurrences("-") = 1 then
						multiToken1 := str[1:position - 1];
						multiToken2 := str[position + 1:str.length];
						if not (self.validate(multiToken1,_term) and self.validate(multiToken2,_term)) then
							return false;
						endif;
					//	return true;
						continue;	//26 Apr 2011	NDL	Par 26771- otherwise we don't check teh next token
					endif;
				endif;
				return false;
			endif;
			
			index := 1;
			while index &lt;= str.length do
				if  not (str[index].isNumeric or str[index].isAlpha or self.isValidAlpha(str[index])) then
					return false;
				endif;
				index := index + 1;
			endwhile;
			
		elseif self.type = YAPattern_WeightRange then
//26 Apr 2011	NDL	Par 26771	- simplify validation to the values we actually use in the 'match' i.e. drop &lt;, &gt; and =
			//if a ! or * or &gt; or &lt; or &gt;= or &lt;= is at the start
	/*		if str[1] = "!" or str[1] = "*" then
				if str.length &gt; 1 then
					str := str[2:str.length];
				else
					return false;
				endif;
			elseif str[1] = "&gt;" or str[1] = "&lt;" then
				if str.length &gt; 1 then
					if str[2] = "=" then
						if str.length &gt; 2 then
							str := str[3:str.length];
						else
							return false;
						endif;
					else
						str := str[2:str.length];
					endif;
				else
					return false;
				endif; 
			endif;  
			
			//if a * is at the end
			if str[str.length] = "*" then
				str := str[1:str.length-1];
			endif;  */
			
			//if - is in the middle
			if str.pos("-", 1) &gt; 0 then
				position := str.pos("-" , 1);
				if not position = str.length  or position = 1 then
					multiToken1 := str[1:position - 1];
					multiToken2 := str[position + 1:str.length];
					if not (self.validate(multiToken1,_term) and self.validate(multiToken2,_term)) then
						return false;
					endif;
					if multiToken1[multiToken1.length:1].toUpper = "T" and not multiToken2[multiToken2.length:1].toUpper = "T" then			// PAR #34279
						return false;																										// PAR #34279
					elseif multiToken2[multiToken2.length:1].toUpper = "T" and not multiToken1[multiToken1.length:1].toUpper = "T" then		// PAR #34279
						return false;																										// PAR #34279
					endif;																													// PAR #34279
					continue;	//26 Apr 2011	NDL	Par 26771- otherwise we don't check the next token
				//	return true;
				endif;
				return false;
			endif;
			
			capStr := str.toUpper;
			if capStr.pos("T", 1) &gt; 0 then
				position := capStr.pos("T", 1);
				if not position = capStr.length then
					return false;
				endif;
			endif;
			index := 1;
			while index &lt;= str.length do
				//if  not (str[index].isNumeric or str[index].toUpper = "T") then					// PAR #33715
				if not (str[index].isNumeric or str[index].toUpper = "T" or str[index] = ".") then	// PAR #33715
					return false;
				endif;
				index := index + 1;
			endwhile;
			//23.08.2024 navbs1 #65510	
			/*if str.containsOneOf(".,") then					//TFS 63724
				return false;								//TFS 63724
			endif;											//TFS 63724
			
			//Restrict adding comma "," for the single weight range (the getToken() method will consider it as a different range).
			if tokens.size &gt; 1 and str.pos("-", 1) = 0 then	//TFS 63724
				return false;								//TFS 63724
			endif;											//TFS 63724*/
			
		// PAR #36094 Pattern type is TempRange - this can include -ve values, so a range like -10.2--5.6 is valid
		elseif self.type = self.YAPattern_TempRange then
		
			// how may '-' characters do we have? if just 1, this is a straight range
			// if 2, then one must be the first character and we must be able to find two valid decimals
			// (between each '-')
			// if 3, then two of them must be contiguous, and we must be able to find two valid decimals
			// (one between the first two '-' and one after the last
			occurrences := str.countOccurrences("-");
			if occurrences &gt; 3 then
				return false;
			endif;
			if occurrences &gt; 1 then
				if not str[1:1] = "-" then
					return false;
				endif;
			endif;
			
			//if a ! or * is at the start
			if str[1] = "!" or str[1] = "*" then
				if str.length &gt; 1 then
					str := str[2:str.length];
				else
					return false;
				endif;
			endif;
			
			//if a * is at the end
			if str[str.length] = "*" then
				str := str[1:str.length-1];
			endif;
			
			// find first, second and third '-' positions
			if occurrences &gt; 0 then
				first := str.pos("-", 1);
				if occurrences &gt; 1 then
					second := str.pos("-", first+1);
					if occurrences &gt; 2 then
						third := str.pos("-", second+1);
					endif;
					if occurrences = 3 and (third - second) &lt;&gt; 1 then
						return false;
					endif;
				endif;
			endif;
			
			// now sort out whether we have a range or a single value
			if occurrences = 2 and first = 1 then
				// two dashes together - this is invalid
				if second - first = 1 then
					return false;
				endif;
				multiToken1 := str[1:second-1];
				multiToken2 := str[second+1:end];
			elseif occurrences = 2 then
				multiToken1 := str[1:first-1];
				multiToken2 := str[second:end];
			elseif occurrences = 3 then
				multiToken1 := str[1:second-1];
				multiToken2 := str[third:end];
			endif;
			if not (self.validate(multiToken1,_term) and self.validate(multiToken2,_term)) then
				return false;
			endif;
				
			index := 1;
			while index &lt;= str.length do
				if not (str[index].isNumeric or str[index] = "-" or str[index] = ".") then
					return false;
				endif;
				index := index + 1;
			endwhile;
			
			if occurrences = 1 and first = 1 then
				multiToken1 := str;
				multiToken2 := null;
			endif;
			if multiToken1 &lt;&gt; null and not multiToken1.isReal then
				return false;
			endif;
			if multiToken2 &lt;&gt; null and not multiToken2.isReal then
				return false;
			endif;
			if multiToken1 &lt;&gt; null and multiToken2 &lt;&gt; null and multiToken1.Real &gt; multiToken2.Real then
				return false;
			endif;
		endif;
		// PAR #36094 end
	
	endforeach;
		
	return true;	

epilog
	delete tokens;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
