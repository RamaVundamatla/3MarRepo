    <JadeMethod name="getSortedTidalClasses" id="fc1cd539-b287-4c06-8990-548777c492c4">
        <source>getSortedTidalClasses(_oa : ObjectArray input);
// for CCMS 1327 Tidal Class invoicing tests, populates the parameter array with the visible tidal classes, sorted by description
vars
	root		: CM_Root;
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	obj			: Object;
	tidalClass	: HMS_TidalClass;
begin
	root := CM_Root.firstInstance;
	create dynaDict transient;
	dynaDict.setMembership(HMS_TidalClass);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach tidalClass in root.allTidalClasses where not tidalClass.isNotAvailableForEntry do
		dynaDict.add(tidalClass);
	endforeach;
	
	_oa.clear();
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		_oa.add(obj);
	endwhile;

epilog
	delete iter;
	delete dynaDict;
end;</source>
        <Parameter name="_oa" type="ObjectArray" usage="input"/>
    </JadeMethod>
