<CollClass name="StringArray">
    <JadeMethod name="populateUniqueValues" id="368421a5-c665-4f22-95ae-ce0a83a31eda">
        <lockReceiver/>
        <updating/>
        <source>populateUniqueValues(_coll : Collection;
					 _cls : Class;
					 _propName : String) updating;
/*

Purpose:			Populate the receiver with unique values of the String value of the passed in Property
					on the objects in the passed in collection

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2016	cnwkpd1	Handheld application helper

*/

vars
	dict			: DynaDictionary;
	iter			: Iterator;
	obj				: Object;
	propName		: String;
	propValue		: String;
	
begin
	create dict transient;
	dict.setMembership(_cls);
	dict.addMemberKey(_propName, false, false);
	dict.endKeys(true);
	
	_coll.copy(dict);
	iter := dict.createIterator();
	
	while iter.next(obj) do
		propValue := obj.getPropertyValue(_propName).String.trimBlanks();
		if propValue &lt;&gt; null then
			self.add(propValue);
		endif;
		
		dict.startKeyGtr(propValue, iter);
	endwhile;

epilog
	delete dict;
	
end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_cls" type="Class"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</CollClass>
