    <JadeMethod name="delete" id="2e2430e6-7dec-4496-a470-367d0975ba96">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld :CM_LaneDevice;
begin
	if not self.allVehicleMachines.isEmpty then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Attempt to delete lane (' &amp; self.getFullId &amp; ') with vehicles');
	endif;
	
	// I have included this code here just incase it has not already been done.
	// Seems we are slipping through without deletingthe lane devices when we change the number
	// of lanes 
	foreach ld in self.allLaneDevices do
		ld.erase (NORMAL_ERASE);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="e27f1d76-a841-4c25-b7fa-036841609eb0">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	:CM_LaneDevice;
begin
	foreach ld in self.allLaneDevices do
		ld.erase (_level);
	endforeach;
	
	inheritMethod(_level);

epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBoom" id="b1cd980d-fc32-4e52-ba03-9c5e5249d28b">
        <source>getBoom(_inBoom : Boolean):CM_Boom;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
