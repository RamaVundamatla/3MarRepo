    <JadeMethod name="doTblGateAreas_UpdateProxy" id="34a35af8-e788-4209-a121-646aa8efda76">
        <updating/>
        <source>doTblGateAreas_UpdateProxy(_table :CM_DataTable input):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateArea, otherGateArea	:CM_GateArea;
	row, rows				:Integer;
begin 
	if not _table.row &gt; _table.fixedRows then
		return true;
	endif;

	if _table.column &lt;&gt; _table.getColumnByRowName (ETRow_Area_id) and
		_table.column &lt;&gt; _table.getColumnByRowName (ETRow_Area_comment) and 
		_table.column &lt;&gt; _table.getColumnByRowName (ETRow_Area_laneCount) then
		return true;
	endif;

	if self.mode &lt;&gt; Mode_Add and self.mode &lt;&gt; Mode_Update then
		return true;
	endif;
	
	gateArea 	:= self.getSelected_GateArea;
	
	if _table.column = _table.getColumnByRowName (ETRow_Area_id) then
		// ID
		gateArea.setID (_table.text);
	elseif _table.column = _table.getColumnByRowName (ETRow_Area_comment) then
		// comment
		gateArea.setComment (_table.text);
	elseif _table.column = _table.getColumnByRowName (ETRow_Area_laneCount) then
		// lanes
		if _table.text &lt;&gt; '' then		//cnwmc5 - PAR 31629
			self.doUpdateNumberOfLanes (gateArea, _table.text.Integer);
		endif;
	endif;	

	// if the same gate area is used more than once we want to update all the rows
	self.refreshGateAreaRows (gateArea);
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblGateLanes_UpdateProxy" id="bb3709af-46b4-46fc-9d2a-9c7c3d6a8602">
        <source>doTblGateLanes_UpdateProxy(_table :CM_BaseTable input):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateLane	:CM_GateAreaLaneController;
	row, rows,
	colIn, colOut, colLock,
	colClosed 	:Integer;
	
begin 
	if not _table.row &gt; _table.fixedRows then
		return true;
	endif;
	
	if self.mode &lt;&gt; Mode_Add and self.mode &lt;&gt; Mode_Update then
		return true;
	endif;
	
	gateLane 	:= self.getSelected_GateLane;
	
	if gateLane = null then
		return false;
	endif;
	
	colIn 		:= tblGateLanes.getColumnByRowName (ETRow_Lane_in);
	colOut		:= tblGateLanes.getColumnByRowName (ETRow_Lane_out);
	colLock		:= tblGateLanes.getColumnByRowName (ETRow_Lane_direction_locked);
	colClosed	:= tblGateLanes.getColumnByRowName (ETRow_Lane_closed);
	
	if _table.column =  colIn then
		// In
		_table.accessCell (_table.row, colIn).text		:= 1.String;
		_table.accessCell (_table.row, colOut).text		:= 0.String;
		//_table.accessCell (_table.row, colClosed).text	:= 0.String;
		
		//gateLane.setIsUnavailable (false);
		gateLane.setLaneDirection (CM_GateAreaLaneController.Is_In_Lane);
	elseif _table.column = colOut then
		// out
		_table.accessCell (_table.row, colIn).text		:= 0.String;
		_table.accessCell (_table.row, colOut).text		:= 1.String;
		//_table.accessCell (_table.row, colClosed).text	:= 0.String;
		
		//gateLane.setIsUnavailable (false);
		gateLane.setLaneDirection (CM_GateAreaLaneController.Is_Out_Lane);
		
	elseif _table.column = colLock then
		gateLane.setLockDirection (_table.accessCell (_table.row, colLock).text.Integer.Boolean);
	elseif _table.column = colClosed then
		// Closed 
		//_table.accessCell (_table.row, colIn).text		:= 0.String;
		//_table.accessCell (_table.row, colOut).text		:= 0.String;
		//_table.accessCell (_table.row, colClosed).text	:= 1.String;
		
		gateLane.setIsUnavailable (_table.accessCell (_table.row, colClosed).text.Integer.Boolean);
		//gateLane.setLaneDirection (CM_GateAreaLaneController.Is_Undecided);
	endif;	
	
	// printers, booms, rfid tag reader, and kisok get updated in the event method 
	// for the relevant combo box
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_BaseTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateNumberOfLanes" id="fffbfc28-8861-41ee-ac64-19f51982010a">
        <updating/>
        <source>doUpdateNumberOfLanes(_gateArea :CM_GateArea input; _value :Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
//				Update proxy based on change to number of lanes
// Parameters:  _gateArea	- selected gate area
//				_value		- number of lanes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if _value = _gateArea.laneCount then
		return;	// nothing to do
	endif;
	
	_gateArea.pxyUpdateLaneCount (_value);
	
	self.setGateLaneTableNeedsRefresh (true);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gateArea" type="CM_GateArea" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
