    <JadeMethod name="doContextMenu" id="43ef02af-e94b-4d65-8036-6aac98b351c8">
        <updating/>
        <source>doContextMenu(table : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	if app.isAllowedToInspect() and self.myInvContAccumulate &lt;&gt; null then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	   
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5c5f6269-a87f-44d9-80ca-2ccb31bf27a5">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	theReturn 		: Integer;
	invContAccmulate : CM_InvoiceContractAccumulate;

begin
	
	invContAccmulate := self.myInvContAccumulate;
	
	if invContAccmulate = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, invContAccmulate.auditId()), app.getErrorString(Confirm_Delete), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	
	while true do
		
		app.myTrxDA.trxDeleteInvContractAccumulate(invContAccmulate, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Contract Accumulate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors() and theReturn = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);
			
			return;
		endif;
	endwhile;
	
	self.myInvContAccumulate := null;
	self.mode := self.Mode_Add;	
	self.doClearFields();
	
	self.doEnableAddButton();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableAddButton" id="c8317990-bcb4-4cd5-a364-f9fa0b0c4589">
        <source>doEnableAddButton();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	
	self.btnAdd.enabled := true;
	
	// If the contract detail is accumulate by Period, and it already has accumulation, disable the add button
	if self.myInvoiceContractDtlsVolBased.isAccumulateByPeriod() then
		if self.myInvoiceContractDtlsVolBased.allAccumulationsByType.getAtKey(myInvoiceContractDtlsVolBased.accumulationType, null) &lt;&gt; null then
			self.btnAdd.enabled := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateCmbVoyage" id="e20040b9-2628-48ea-b462-e10e5b2c614b">
        <source>doPopulateCmbVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	combo		: CMUI_ComboBox;
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	
begin
	combo := self.cmbVoyage;
	vessel := self.cmbVessel.listObject.CM_Vessel;
	
	combo.clear();
	
	if vessel = null then
		return;
	endif;
	
	foreach voyage in vessel.allVoyagesByTermCodeArrival discreteLock do
		combo.addItemObject(voyage.code, voyage);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateFields" id="f7ac01d5-dc76-4350-93aa-400ce625ab49">
        <updating/>
        <source>doPopulateFields(_invContAccum : CM_InvoiceContractAccumulate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	
	self.txtAccumWeight.text := _invContAccum.accumulatedWeight.asStringJMT();
	self.txtAccumVol.text := _invContAccum.accumulatedVolume.asStringJMT();
	self.txtAccumQty.text := _invContAccum.accumulatedQuantity.asStringJMT();
	self.txtAccumTEU.text := _invContAccum.accumulatedTEU.asStringJMT();
	
	self.cmbVessel.findObjectFromListCollection(_invContAccum.myVessel);
	self.doPopulateCmbVoyage();
	self.cmbVoyage.findObjectFromListCollection(_invContAccum.myVoyage);
epilog

end;</source>
        <Parameter name="_invContAccum" type="CM_InvoiceContractAccumulate"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="7dc077fb-45df-4cac-969f-3c2d5d132c47">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	pxyInvContAccumulate,
	realInvContAccumulate	: CM_InvoiceContractAccumulate;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	accumWeight				: Decimal[23,4];
	accumVol				: Decimal[23,4];
	accumTEU				: Decimal[23,4];
	accumQuantity			: Integer;
	
	invContDtlVolBased		: CM_InvoiceContractDtlsVolBased;
	
	now						: TimeStamp;
	theReturn 				: Integer;
	
begin

	if self.mode = self.Mode_Add then
		create pxyInvContAccumulate transient;
	elseif self.mode = self.Mode_Update then
		// Users have not selected accumulation to update
		if self.myInvContAccumulate = null then
			app.msgBox(app.getErrorString(SelectAccumFromList), app.getErrorString(Information), MsgBox_Information_Icon);
			return;
		endif;
		beginLoad;
		pxyInvContAccumulate := self.myInvContAccumulate.pxyCreateUpdateProxy();
		endLoad;
	endif;
	
	invContDtlVolBased := self.myInvoiceContractDtlsVolBased;
	
	vessel := self.cmbVessel.listObject.CM_Vessel;
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	accumWeight := self.txtAccumWeight.text.Decimal;
	accumVol := self.txtAccumVol.text.Decimal;
	accumTEU := self.txtAccumTEU.text.Decimal;
	accumQuantity := self.txtAccumQty.text.Integer;
	
	pxyInvContAccumulate.setProxy(accumQuantity, 
								accumTEU, 
								accumVol, 
								accumWeight, 
								invContDtlVolBased.accumulationType, 
								now, 
								self.myBusinessUnit, 
								invContDtlVolBased, 
								vessel, 
								voyage);
	
	while true do
		if self.mode = self.Mode_Add  then
			app.myTrxCA.trxCreateInvContractAccumulate(pxyInvContAccumulate, realInvContAccumulate, app.myPassport);
		elseif	self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateInvContractAccumulate(pxyInvContAccumulate, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			app.msgBox(app.getErrorString(DataSuccessfullySaved), app.getErrorString(HeadingSaved), MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Contract Accumulate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
	self.doEnableAddButton();
	self.mode := self.Mode_Update;
epilog
	delete pxyInvContAccumulate;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataRowChanged" id="23b671b4-9449-4854-a0ed-c6c282541563">
        <updating/>
        <source>doTblDataRowChanged() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	invContAccum	: CM_InvoiceContractAccumulate;
	
begin
	
	if ((self.myInvoiceContractDtlsVolBased.isAccumulateByVoyage() and not self.btnAdd.enabled))
		and self.mode = self.Mode_Add then
		if app.msgBox(app.getErrorString(UnsavedChangesInView), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	invContAccum := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractAccumulate;
	
	if invContAccum = null then
		return;
	endif;
	
	self.myInvContAccumulate := invContAccum;	
	self.doPopulateFields(invContAccum);
	
	self.mode := self.Mode_Update;
	
	self.doEnableAddButton();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="f713cfde-674a-456d-9d83-395c544d3a7b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	xmlStr	: String;
begin
	
	xmlStr := inheritMethod();
	xmlStr &amp;= self.tblData.getXmlStrForColumns(false);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleUserNote" id="e9f00db9-f2e5-466e-b414-339f626ca137">
        <updating/>
        <source>handleUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	invContAccum		: CM_InvoiceContractAccumulate;
	event				: Integer;
	line				: String;
	idx					: Integer;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceContractAccumulate) then
		invContAccum := userInfo.CM_InvoiceContractAccumulate;
	elseif theObject.isKindOf(CM_InvoiceContractAccumulate) then
		invContAccum := theObject.CM_InvoiceContractAccumulate;
	endif;
	
	if invContAccum = null then
		return;
	endif;
	
	if event = EVENT_InvContractAccumCreate then
		line := invContAccum.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.addItemObject(invContAccum, line);
		
	elseif event = EVENT_InvContractAccumUpdate then
		self.tblData.findObjectInRow(invContAccum,idx);
		
		if idx &gt; self.tblData.fixedRows then
			line := invContAccum.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(idx, 1).text := line;
		endif;
	elseif event = EVENT_InvContractAccumDelete then
		self.tblData.findObjectInRow(invContAccum,idx);
		
		if idx &gt; self.tblData.fixedRows then
			self.tblData.removeItemObject(invContAccum);
		endif;
	endif;
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initCmbVessel" id="ba741c27-b45a-475e-b249-2330453dbc49">
        <source>initCmbVessel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	root	: CM_Root;
	vessel	: CM_Vessel;
	combo	: CMUI_ComboBox;
	
begin
	combo := self.cmbVessel;
	
	combo.clear();
	
	root := app.myRoot;
	
	foreach vessel in root.allVessels discreteLock do
		combo.addItemObject(vessel.name &amp; " - " &amp; vessel.code, vessel);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblData" id="eaa5bff8-310f-4f5c-9ff0-260e33421ff7">
        <updating/>
        <source>initTblData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations
07 Apr 2024 navrv30	CR 63386: FR - 54089 - Invoice contract - Accumulations screen details.
*/

vars
	entDef		: EntTableDef;
	
begin
	entDef	:= app.myController.getEntTableDef(ETDef_VolumeBasedAccumList); //07 Apr 2024 navrv30	CR 63386
	self.tblData.setTblDataEntRowsFromDef(entDef);
	
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	
	self.initTblDataCollection();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblDataCollection" id="4ccfe818-2699-4157-92ad-5c7ef9ce0ef8">
        <updating/>
        <source>initTblDataCollection() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	invContDtl		: CM_InvoiceContractDtlsVolBased;
	invContAccum	: CM_InvoiceContractAccumulate;
	line			: String;
begin
	
	self.tblData.rows := self.tblData.fixedRows;
	
	invContDtl := self.myInvoiceContractDtlsVolBased;
	
	foreach invContAccum in invContDtl.allAccumulationsByType discreteLock do
		line := invContAccum.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.addItemObject(invContAccum, line);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
