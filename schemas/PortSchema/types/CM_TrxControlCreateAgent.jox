    <JadeMethod name="trxCreateWleCopyAssignTI" id="aa99ad9d-6572-48f9-850a-1ea9961da5b5">
        <updating/>
        <source>trxCreateWleCopyAssignTI( _templateWle : CM_WorkListEntry input; realWle : CM_WorkListEntry output; _ti : CM_TrackedItem; _targetLc : CM_LocationsController; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwndl1	Initial creation	Par 26055

*/

vars

	moveController : CMIF_MoveController;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
			
	// Start the transaction
	beginTransaction;

	// Perform the operations
	
	// first build the new wle from the template.
	app.myUtilityCA.utlCreateWLEfromTemplate(_templateWle, _ti, realWle, _passport );
	
	if _passport.noErrors then
	
		app.setContinueCMExceptions(true);
	
		create moveController transient;
		moveController.setMyWorkListEntry(realWle);
		moveController.setMyToPrimaryLocation(_targetLc); //setting to location will do the move aswell
		moveController.setMyTrackedItem(_ti);
		
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;
	
		app.myUtilityUA.utlUpdateWLEAssignTI(moveController, _passport);
		
		if _passport.noErrors then
			_passport.doDeferredUpdates();
			realWle.causeEvent(realWle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, realWle);
		endif;
	
	endif;
	
epilog

	delete moveController;
	self.finaliseActivityWithPassport(_passport);
	
	
end;</source>
        <Parameter name="_templateWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="realWle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetLc" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
