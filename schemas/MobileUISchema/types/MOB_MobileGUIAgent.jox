    <JadeMethod name="loadPackCompleteForm" id="a7b058a2-474d-4ba9-823b-27a1ad05e4b5">
        <source>loadPackCompleteForm(_ti : CM_TrackedItem):Boolean;
/*
	Created on 14 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	form : MOB_TwoEntryModalForm;
begin
	if _ti = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Tracked Item found");
		return false;
	endif;
	if _ti.isKindOf(CM_Container) then
		form := self.findOrShowForm(MOB_CompleteContainerForm, _ti, true).MOB_CompleteContainerForm;
	else
		form := self.findOrShowForm(MOB_CompleteMasterPackForm, _ti, true).MOB_CompleteMasterPackForm;
	endif;
	if form &lt;&gt; null and not form.tag = form.FormOpen then
		form.showModal;
	endif;
	return form.modalResult = ModalResultOK;
epilog
	delete form;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadPackingForm" id="92359bf2-b588-4fe7-9e29-10180eceea91">
        <source>loadPackingForm(_rels : CM_BulkReleaseSet; _ti : CM_TrackedItem; _lc : CM_LocationsController);

vars
	form : MOB_CEScanForPackRequestForm;
	
begin
	form := findExistingForm(MOB_CEScanForPackRequestForm, _ti).MOB_CEScanForPackRequestForm;
	
	if form = null then
		create form transient;
		form.setAllReleases(_rels);
		form.setMyMainObject(_ti);
		form.setLocation(_lc);
		form.show();
	endif;
end;
</source>
        <Parameter name="_rels" type="CM_BulkReleaseSet"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="loadPrevForm" id="cb1b562a-d034-4389-879c-7fd107d3bd1c">
        <updating/>
        <source>loadPrevForm(_currentClass : Class) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2008	cnwer1	Initial creation

*/

vars
	form : MOB_BaseForm;
begin
	return;
	if app.myPassport.myUser &lt;&gt; null and app.myPassport.myUser.code &lt;&gt; "CNWER1" then
		return;
	endif;
	
	if self.prevFormClass = null then
		return;
	endif;
	
	if self.prevFormClass = _currentClass then
		return;
	endif;

	
	create form as self.prevFormClass transient;
	form.setMyMainObject(null);
	form.show();

epilog

end;</source>
        <Parameter name="_currentClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="loadRecordDamageForm" id="3c160ee4-46d8-40ea-8795-693f1f601774">
        <source>loadRecordDamageForm(_tiObj:CM_TrackedItem);
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Opens the "Record Damage" form, with a Tracked Item parameter against
//				which we will record the damage.
//
// Parameters:	_tiObj - A reference to the Tracked Item.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj		: MOB_RecordDamageForm;
	
begin
	if _tiObj.myCargoType = null
	or not	_tiObj.myCargoType.showDamageCodes
	then
		app.msgBox(app.getErrorString(Cannot_record_damage), "", MsgBox_OK_Only);
		return;
	endif;
	
	self.findOrShowForm(MOB_RecordDamageForm, _tiObj, false);
end;</source>
        <Parameter name="_tiObj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadStorageAllocateForm" id="ba7ff8fc-3918-46db-80ef-82ba4a67102e">
        <source>loadStorageAllocateForm(_ti : CM_TrackedItem; loc : CM_LocationsController):Integer;
/*
	Created on 13 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	formObj	: MOB_AllocateStorageForm;
	isNew	: Boolean;
begin
	formObj := app.myMobileGUIAgent.findOrShowForm(MOB_AllocateStorageForm, loc, true).MOB_AllocateStorageForm;
	formObj.setMyTrackedItem(_ti);
	if loc &lt;&gt; null then
		formObj.txtLocation.text := loc.getFullId;
	endif;
	if not formObj.tag = formObj.FormOpen then
		return formObj.showModal;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="loc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
