    <JadeMethod name="showSelectorForm" id="ef3dc1dd-129a-421b-b408-987c76624131">
        <updating/>
        <source>showSelectorForm() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	theSelector		: CMUI_Selector;
	
begin
	theSelector	:=	app.getSelectorForm(self, self.myMasterMenuAction);
	
