end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="1933ec5e-043f-4871-af4c-3dadde70fc50">
        <updating/>
        <source>removeWLE(_wle : CM_WorkListEntry io; _reason : String) updating;
/*
Author:			steve
Date:				2 dec 99
Description:	Jadeised the cpp method
							Method on RoadJob to Delete a WorkListEntry. This is called from the
							ROAD OPERATIONS window by a Road Controller. The calling application
							is responsible for the DEALLOCATION of any TI's to the requests that
							are about to be deleted!
							param1 is the oid of the WLE to delete.
Raises:				ERR_NO_OBJECT

17/06/2013	cnwcs5	par 31670 - A little refactoring
07 Nov 2016	cnwrs1	TFS 2904 Par38378 stop 1090 dump
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
28/01/2019 	JLGNS1	Bug 43075: STWR Ticket 42865: STWR - RE: Ticket 41369
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/
vars
	num					: Integer;
	request				: CM_Request;
	total				: Decimal[14,4];
	deliveryRequest		: CM_DeliveryRequest;
	trx	, 
	mergeTrx			: CM_TITransaction;
	isByWeight, 
	moveAllCargoBack 	: Boolean;
	attachedGenerator 	: CM_Generator;
	prenotedTI,
	ti					: CM_TrackedItem;
begin
	self.exclusiveLock(self);

	if _wle = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_OBJECT, null, null);
		return;		
	endif;

	num := self.workListEntries.size;
	
	self.exclusiveLock(_wle);
	self.sharedLock(_wle.myRequest);
	
	request := _wle.myRequest;	
		
	if (num = 1) then	
		//ONLY 1 WLE in the entire JOB!, call the job delete method 
		self.erase(NORMAL_ERASE);
	elseif (num &lt;= 0) then
		//Major upset!!!!
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_INVALID_WLE, null, null);
		return;			
	else
		//OK, we are doing some tricky stuff here, check the type, and remove
    	//or decrement the total as applicable.
		//Find out what type of request this is, if a BOL or TI Request, then NUKE it
		
		ti := _wle.myTrackedItem;
		
		if request.isKindOf(CM_TIRequest)      or 
		   request.isKindOf(CM_BOLYardRequest) or 
		   request.isKindOf(CM_BOLToDoRequest) or
		   request.isKindOf(CM_ReceivalRequest) then
			
			// TFS 43796
			if ti &lt;&gt; null and ti.myCargoType &lt;&gt; null then
				prenotedTI		 := ti.myTerminal.allNotifiedTIsByCargoTypeId[ti.myCargoType.id,ti.id];
				moveAllCargoBack := ti.wasPrenotified and prenotedTI = null;
				mergeTrx 		 := ti.getLastChildSplitMergeTrans;
			endif;
		
			_wle.CM_YardWLE.deleteCurrentEntry(moveAllCargoBack, _reason);			//Bug 43075	// TFS 43075 Reason // TFS 43796 pass in moveAllCargoBack

			if mergeTrx &lt;&gt; null then
				_wle.erase(NORMAL_ERASE); //epr CCMS 2274 20/05/13 just erase the wle not the entire request			
			else
				//This is a Tracked Item Request, therefore it has ONLY 1 WLE (us)
				//We therefore delete the Request, from its relationships..
	
				// PAR5307 - AKB2003JULY if the job is deleted we logically delete the receival transaction
				//epr 6/3/13 31249
				if ti &lt;&gt; null and _wle.isReceipt then
					foreach trx in ti.allTransactions do
						if trx.type = TRANS_TYPE_REC_RAIL or 
						   trx.type = TRANS_TYPE_REC_ROAD or 
						   
						   trx.type = TRANS_TYPE_REC_ST_DEPOT_RAIL or			// CCMS 1875
						   trx.type = TRANS_TYPE_REC_ST_DEPOT_ROAD or			// CCMS 1875
						   trx.type = TRANS_TYPE_REC_ST_MARINE_RAIL or		// CCMS 1875
						   trx.type = TRANS_TYPE_REC_ST_MARINE_ROAD or		// CCMS 1875
						   trx.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL or		// CCMS 1875
						   trx.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD or		// CCMS 1875
						   
						   trx.type = TRANS_TYPE_REC_RAIL_INTER_TERM or 
						   trx.type = TRANS_TYPE_REC_ROAD_INTER_TERM then
							trx.setForDelete(null);
						endif;
					endforeach;
					
					//27.02.2018 cnwma1 ChangeRequest #36813
					if ti.isContainer() or ti.isTILC()   then			//25.02.2025 navma1 #MTN-34075
						attachedGenerator :=  ti.getGenerator();		//25.02.2025 navma1 #MTN-34075
						if attachedGenerator &lt;&gt; null then
								foreach trx in  attachedGenerator.allTransactions do
									if trx.type = TRANS_TYPE_REC_RAIL or 
									   trx.type = TRANS_TYPE_REC_ROAD or 
									   
									   trx.type = TRANS_TYPE_REC_ST_DEPOT_RAIL or			
									   trx.type = TRANS_TYPE_REC_ST_DEPOT_ROAD or			
									   trx.type = TRANS_TYPE_REC_ST_MARINE_RAIL or		
									   trx.type = TRANS_TYPE_REC_ST_MARINE_ROAD or	
									   trx.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL or		
									   trx.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD or	
									   
									   trx.type = TRANS_TYPE_REC_RAIL_INTER_TERM or 
									   trx.type = TRANS_TYPE_REC_ROAD_INTER_TERM then
										trx.setForDelete(null);
									endif;							
								endforeach;
						endif;
					endif;
					//27.02.2018 cnwma1 ChangeRequest #36813
					
				endif;
				request.erase(NORMAL_ERASE);
			endif;
			
		elseif request.isDeliveryRequest() then
  			//Is a DeliveryRequest, we have to examine it, decrement or delete as reqd..
			
			//epr 19/6/14 34406 Bulk changes
  			deliveryRequest 	:= request.CM_DeliveryRequest;
			isByWeight			:= deliveryRequest.isBulkMulti;
			if deliveryRequest.isBulkMulti then
				total := request.weightRequested;	
			else
				total  := request.getTotalRequested;
			endif;
		
			if (total &gt; 0) then
				//Decrement this
				if isByWeight then
					total 							:= total - _wle.weight;
					request.setWeightRequested(total);
				else
					if ti &lt;&gt; null then //epr 2/8/17 TFS 5597 don't - 1 if no ti could be anyid and any amount
						total 							:= total - _wle.quantity.max(1);
					endif;
					deliveryRequest.totalRequested 	:= total.Integer;
				endif; 			
				
				_wle.erase(NORMAL_ERASE);
			endif;
			
			
			if total = 0  then
				//Only 1 request here, treat as if its a TI request, and
    		    //delete it..
				request.erase(NORMAL_ERASE);
			endif;
	
			
		endif;
		
		self.causeTerminalEvent(self.Event_Mode_Update);
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateUnfinishedQEntries" id="55d0b65e-4513-4e81-8874-b4221eeb38aa">
        <source>updateUnfinishedQEntries() protected;
/*

Purpose:	for multi machine moves when cargo is receipted it is possible to 
			finish the job before the cargo has reached its target. 
			i.e. moving container via Forklift -&gt; IC Area -&gt; Straddle  
			When the move for the forklift is finished the user can do a Road Exit this deletes the job
			and the wles and q entries
			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2010	cnwer1	Initial creation PAR 25307

*/

vars
	qdFutureMove 		: CM_FutureMoveQueued;
	wle					: CM_WorkListEntry;
	newWLE 				: CM_YardWLE;
	newJob 				: CM_YardInternalJob;
	rtQueueEntry 		: CM_RTQueueEntry;
	allQEntriesToUpdate : ObjectSet;
	obj    				: Object;
	ti 	   				: CM_TrackedItem;
begin
	
	if  not self.hasReceipt then
		return;
	endif;
	
	create allQEntriesToUpdate transient;
	
	foreach wle in self.workListEntries do
		
		/*
		if wle.allRTQueueEntries.size = 1 then
			//continue;
		endif;
		
		if wle.areAllEntryTasksEqStatus(TASK_COMPLETE) then
			//continue;
		endif;
		*/
		
		ti := wle.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		if wle.allRTQueueEntries.size = 0 then
			continue;
		endif;
		
		if newJob = null then
			//epr par 25285 13/9/10 added parameter with target location can't just rely on the _future move being the first for the ti
			newJob := ti.createYardInternalQueueJob(QUEUE_MODE,wle.getTargetLocation,wle.quantity,wle.weight,false, app.myPassport);
			//will create internal yard job with a TI request for wle.myTrackedItem there will be one new wle created
			
			//+cnwml2 PAR25996 primary location contoller as already been cleared
			if newJob = null then  			
				continue;
			endif;
			
			newWLE := newJob.workListEntries.first.CM_YardWLE;
		else
		// add a new wle to the job		
			//epr par 34466 7/7/14 new quantity/weight param
			newJob.addJobRequest(ti, true,null,null,  app.myPassport); 				//cnwrd1 par 28665 9.11.11
			newWLE := newJob.allRequests.last.allWorkListEntries.first.CM_YardWLE;  //cnwrd1 par 28665 9.11.11
		endif;
		
		allQEntriesToUpdate.clear;
		foreach rtQueueEntry in wle.allRTQueueEntries do
			qdFutureMove := wle.myFutureMove.CM_FutureMoveQueued;

			if qdFutureMove &lt;&gt; null then 								//cnwrd1 par 28621 1.11.11
				qdFutureMove.setMyWorkListEntry(newWLE,false);
			endif;

			allQEntriesToUpdate.add(rtQueueEntry);			
		endforeach;
		
		foreach obj in allQEntriesToUpdate do
			obj.CM_RTQueueEntry.setProxy(newWLE);
		endforeach;
	endforeach;
epilog
	delete allQEntriesToUpdate;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
