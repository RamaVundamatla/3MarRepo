    <JadeMethod name="isTIBackEndForProposed" id="45677823-2cac-4921-8574-ae658e9f003a">
        <source>isTIBackEndForProposed(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpRequestLoad	: CM_SlotRequest;
begin

	if _ti = null then
	
	//	11 Jan 2021	NDL	TFS 50611 
	/*	//04 July 2012	NDL	Par 29316
		if not self.allTrackedItemOSBackEnds.isEmpty or not self.allTrackedItemOSBackEndsPd.isEmpty then
			return true;
		endif;  */
		return false;
	endif;
	
	//if not _ti.isAttributeTrue(TI_Attrib_IsForty) then
	if self.is20ft then					// 08/06/2010 cnwmh5 #20661
		//it's a twenty
		return false;
	endif;
	
	tmpRequestLoad := self.mySlotRequestLoad;
	
	if _ti.myPrimaryPlannedLocation &lt;&gt; self and
	   _ti.myPrimaryActualLocation &lt;&gt; self then
		if tmpRequestLoad &lt;&gt; null then
			// PAR 21746 return tmpRequestLoad.fortyBack;
			return tmpRequestLoad.getAttrIsBackend(); // PAR 21746
		else
			//no load
			if self.allTrackedItems.includes(_ti) then
				return true;
			else
				//the ti is somewhere else
				return false;
			endif;
		endif;
	endif;
	
	

	return false;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
