    <JadeMethod name="getResourcesInUse" id="7a3f7daf-55d8-4cd1-94ae-8f394b95225a">
        <source>getResourcesInUse( _resources : CM_ResourceTypeDict io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	resourceBroker : CM_TransResourceServiceBroker;
	
begin

	if _resources = null then
		return;
	endif;
	
	foreach resourceBroker in self.allResourceBrokers do
		if resourceBroker.myResourceType &lt;&gt; null then
			_resources.addNoDuplicates(resourceBroker.myResourceType,false);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
