    <JadeMethod name="notifyGotFocus" id="87529bae-8ad0-462e-92bb-42ae54685be8">
        <source>notifyGotFocus();
// ---------------------------------------------------------------------------
// Created:     15 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSheet	: GTE_Sheet;
	
begin

	tmpSheet := self.topSheet;

	if tmpSheet &lt;&gt; null and 
	   tmpSheet.visible and 
	   tmpSheet.myMenuAction &lt;&gt; null then
		app.myController.selectMenuAction(tmpSheet.myMenuAction);
	else
		app.myController.selectMenuAction(self.myMasterMenuAction);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="notifySheetDelete" id="a683a8b0-88cf-466b-9e96-9f5ec8b89411">
        <source>notifySheetDelete(pSheet : GTE_Sheet);
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuAction	: CMUI_MenuAction;
	
begin

	menuAction := pSheet.myMenuAction;
	if menuAction &lt;&gt; null and app.myController &lt;&gt; null then
		app.myController.deleteMenuAction(menuAction);
	endif;

end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="packTempC_lostFocus" id="2c362281-59fd-4abb-918a-0f3b62d3c8b4">
        <updating/>
        <source>packTempC_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
