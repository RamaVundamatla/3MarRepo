/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.setupCmdButtons( 2, app.getErrorString(Complete), BACK_BUTTON, null, null, null );

