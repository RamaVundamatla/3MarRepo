<Class name="WS_Driver" id="8b3be637-893d-41fc-9ee0-69a2732068ed">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Drivers defined for the terminal</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allVehicles" id="c21f3956-d02f-42c1-829e-a13972b8db41">
        <memberTypeInverse/>
        <type name="WS_VehicleArray"/>
        <access>readonly</access>
        <text>The list of vehicles that associated to this driver</text>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="95046e44-b31a-4bad-bcb0-61324bec47ca">
        <type name="String"/>
        <access>readonly</access>
        <text>Driver Code</text>
    </PrimAttribute>
    <PrimAttribute name="name" id="29bf5156-6177-4f84-aa65-666aa0781792">
        <type name="String"/>
        <access>readonly</access>
        <text>Driver name</text>
    </PrimAttribute>
    <PrimAttribute name="vehicleCount" id="0b70524a-652c-41d9-bc80-e47662328c65">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="cddfe30a-47fa-47e4-afdf-002bbc1366cc">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.allVehicles.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjDriverOnly" id="f16d6b25-3b81-4b9d-9c05-8592790a7f69">
        <updating/>
        <source>setProxyFromObjDriverOnly(_object: CM_DriverDetails)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021 navma1 ChangeRequest 51051: PRP - WebPortal VBS - Driver and Vehicle fields rework 

*/

vars

begin
	self.cmObjectEdition	:= _object.edition();
	self.cmObjectId			:= _object.getOidAsString();
	self.code 				:= _object.code;
	self.name 				:= _object.name;
	self.vehicleCount       := _object.allVehicleMachines.size;
epilog

end;</source>
        <Parameter name="_object" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="399d2823-eb3c-473c-88e4-987a64cc6c66">
        <updating/>
        <source>setProxyFromObject(_object: CM_DriverDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vehicle : CM_Vehicle;
	wsVehicle : WS_Vehicle;

begin

	inheritMethod(_object);

	self.code := _object.code;
	self.name := _object.name;
	
	foreach vehicle in _object.allVehicleMachines discreteLock do
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		self.allVehicles.add( wsVehicle );
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_object" type="CM_DriverDetails"/>
    </JadeMethod>
</Class>
