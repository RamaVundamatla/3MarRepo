    <JadeMethod name="getDisplayStringForAttribute" id="ff3aa34a-57ee-425f-9b31-91e891bc94c9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 21/02/2010 	cnwcs5	par22193
vars

begin

	if _attrName = ETRow_IsoType then 
		return null;
	elseif _attrName = ETRow_IsoGroup then	// 21/02/2010 	cnwcs5	par22193
		return null;						// 21/02/2010 	cnwcs5	par22193
	elseif _attrName = ETRow_Id then
		return null;
	elseif _attrName = ETRow_CargoDetails then
		return null;		
	elseif _attrName = ETRow_TransactionNum then
		if self.myGateEntity &lt;&gt; null then
			return self.myGateEntity.tranNumber.String;
		endif;
		
		return	self.myJob.getTransactionNumberByRequest(self);
	elseif _attrName = ETRow_ReleaseNumber then
		return self.deliveryNumber;
	elseif _attrName = ETRow_DischargePort then
		return null;		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirectionDescription" id="b72f29b3-8928-4cd2-b939-5b6b080d924a">
        <source>getDoorDirectionDescription(_targetLocation : CM_LocationsController; _ti : CM_TrackedItem): String;

// Created by cnwdvb1 on 20 October 2006
//22/11/2017  cnwma1 		TFS #7828 QNS - System buffering
vars
	isoTypeGroup	: CM_ISOTypeGroup;
	str				: String;
	doorDir : Integer;
begin
	if _ti = null then  			//22/11/2017 cnwma1 TFS #7828
		return  null;
	endif;
	
	if not _ti.isContainer then    //22/11/2017 cnwma1 TFS #7828	
		return null; 	
	endif;
	
	// CCMS 1572
	if _targetLocation &lt;&gt; null and _ti &lt;&gt; null then
		isoTypeGroup := _ti.getISOTypeGroup();
		if isoTypeGroup &lt;&gt; null then
			str := _targetLocation.getDoorDirectionWording(isoTypeGroup);
			if str &lt;&gt; null then
				return str;
			endif;
		endif;
	endif;

	// Par 13489
	if self.myJob &lt;&gt; null and self.myJob.isYardInternalJob() then
		return null;
	endif;

	//epr par 31704 11/6/13
	if _ti &lt;&gt; null and not _ti.isContainer then
		return  null;
	endif;
	
	doorDir := self.doorsDirection;
	if doorDir = TI_DOORSDIRN_FWD then
		return app.getErrorString(CM_Fwd);
	elseif doorDir = TI_DOORSDIRN_AFT then
		return app.getErrorString(CM_Aft);
	else
		return null;
	endif;

end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorsDirection" id="77e7071d-22dd-4af2-940d-e88d8aab1f83">
