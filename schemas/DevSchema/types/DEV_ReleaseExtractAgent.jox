    <JadeMethod name="getReleaseSchemas" id="4bd66cb2-2163-4065-9dd0-1b127700a841">
        <source>getReleaseSchemas(_schemaNames : StringArray input);

/*

Purpose:			Add the list of release schemas to the passed in StringArray

Parameters:			StringArray to be populated with the Release Schemas

Return Value:		Array populated with relevant schema names


Date		Who		Reason
24 Mar 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism
05 Jan 2017	cnwkpd1	JADE PAR #64603 - Detour unnecessary deferred DDB loads by moving Web Schemas to the end of the list
27 Nov 2023	navmd1	TFS 61519/PAR #69750 - Commented out Web Schemas due to JADE2022 extract bug
18 Mar 2024	navmd1	TFS 61519/PAR #69750 - And uncommented again now we have HF 22.0.03.011

*/

vars

begin
	_schemaNames.add("BaseSchema");
	_schemaNames.add("JACBackup");				
	_schemaNames.add("JMExternalControls");
	_schemaNames.add("PortSchema");
	_schemaNames.add("MobileServerSchema");
	_schemaNames.add("MobileUISchema");
	_schemaNames.add("UiCommonSchema");
	_schemaNames.add("GateSchema");
	_schemaNames.add("GeneralCargoSchema");
	_schemaNames.add("HmsSchema");
	_schemaNames.add("InvoiceSchema");
	_schemaNames.add("LogSchema");
	_schemaNames.add("LOGAS400LoadSchema");
	_schemaNames.add("ShipSchema");
	_schemaNames.add("SysOpsSchema");
	_schemaNames.add("WebServicesSchema");
	_schemaNames.add("XMLSchema");
	_schemaNames.add("YardSchema");
	_schemaNames.add("JMMobileClientBaseSchema");
	_schemaNames.add("JMMobileClientRTSchema");
	_schemaNames.add("JSSCoreSchema");
	_schemaNames.add("JSSChangeTrackingSchema");
	_schemaNames.add("JSSFileManagerSchema");
	_schemaNames.add("JSSLicenseKeySchema");

	// cnwkpd1 - Deliberately moved these two schemas to the end of the list to detour issue in JADE PAR #64603
	// navmd1 - TFS 61519 - And now commented out completed due to JADE 2022 bug not supporting extracting HTML Docs created in/before 6.x PAR #69750
	// navmd1 - and now enabled again
	// navmd1 - and now disabled again as *some* environments are getting 1090s when loading them (looking at you eupBjmt &gt;.&gt;)
	//_schemaNames.add("WebSchema");
	//_schemaNames.add("WebExampleSchema");
	
epilog

end;</source>
        <Parameter name="_schemaNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTimeDisplayString" id="92b98223-c8ca-4169-8864-515040ef8c0d">
        <source>getTimeDisplayString() : String;
