    <JadeMethod name="setForUpdate" id="0fcf3923-92f3-43c4-9298-44366d546dc6">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	self.description := _proxyEDITI.description[1 : CM_Commodity::description.getLengthForString];
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
epilog
	
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromEDI" id="fa759385-a2e8-4321-9029-63470911c62a">
        <source>setProxyFromEDI(_proxyCommodity : CM_Commodity input);
//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	commodityGroup : CM_CommodityGroup;
	specialStow : CM_SpecialStow;
	allCargoTypes : CM_CargoTypesByIdDict;
begin
	create allCargoTypes transient;
	if self.commodityGroupCode &lt;&gt; null then
		commodityGroup := app.myRoot.allCommodityGroups[self.commodityGroupCode];
	endif;
	
	if self.specialStowCode &lt;&gt; null then
		specialStow := app.myRoot.allSpecialStows[self.specialStowCode];
	endif;
	
	_proxyCommodity.setProxy(self.code,
							self.description,
							self.shortDescription,
							self.bayplanPrintAs,
							self.hasTemp,
							self.requiresPower,
							self.requiresMAFFields,
							false,
							self.isEmpty,
							self.colour,
							self.maxTemp,
							self.minTemp,
							commodityGroup,
							specialStow,
							self.isUsedForPacking,
							allCargoTypes,	//allCargoTypes
							false
							);		
epilog
	delete allCargoTypes;
end;
</source>
        <Parameter name="_proxyCommodity" type="CM_Commodity" usage="input"/>
    </JadeMethod>
</Class>
