    <JadeMethod name="getNumActualTIs" id="2fa3483d-839f-48df-9a57-9bd3cb88f033">
        <source>getNumActualTIs(): Integer ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwjk3	Initial creation

