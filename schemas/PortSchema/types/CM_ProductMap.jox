    <JadeMethod name="initialise" id="22776081-7b3d-4a4b-88e7-2dbd65bf6d60">
        <source>initialise(_bank : CM_Bank);

vars
	imexMap : CM_ImexServiceMap;

begin

	imexMap := self.allImExMaps[CM_ImexServiceMap.DEFAULT_IMEX_MAP];
	if imexMap = null then
		create imexMap;
		imexMap.imexStatus := CM_ImexServiceMap.DEFAULT_IMEX_MAP;
		imexMap.setMyProductMap(self);
	endif;
	imexMap.initialise(_bank);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="itemName" id="f9009b45-c721-4a5a-8c71-85145aa3c465">
        <methodInvocation>mapping</methodInvocation>
        <source>itemName(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		10 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		return;
	else
		if self.myProduct = null then
			//_value := "Default (Product)"; // - " &amp; self.myCargoTypeMap.getTIClassName();
			_value := app.getErrorString(CM_Default) &amp; " (" &amp; app.getErrorString(Cargo_subtype) &amp;")";	//PAR 20568 SEp 2009
		else
			_value := self.myProduct.code;
		endif;
	endif;




end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="60614a5c-2499-41c1-bf98-66b8fbe22301">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	imexMap		: CM_ImexServiceMap;
begin
	foreach imexMap in self.allImExMaps do
		count := count + imexMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cfe3bf3d-0857-44b6-ac0b-a7586336ceda">
        <updating/>
        <source>setForCreate(_pxyProductMap : CM_ProductMap) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	_pxyProductMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.myProduct := _pxyProductMap.myProduct;
	self.myProductGroupMap := _pxyProductMap.myProductGroupMap;
	
	self.initialise(_pxyProductMap.myProductGroupMap.myCargoTypeMap.transactionMap.bank);

end;</source>
