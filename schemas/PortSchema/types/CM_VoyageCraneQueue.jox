    <JadeMethod name="locateTaskForTI" id="a79ad674-504d-4ac4-8517-88d01a7a388f">
        <source>locateTaskForTI(tiToSearch : CM_TrackedItem; _taskType : Integer) : CM_RTQueueTask;
//Called on a Queue, searches for, and returns the current 1st task.
vars
	entry	:	CM_RTQueueEntry;
	task	:	CM_RTQueueTask;
begin
	if self.allEntries.size = 0 then
		return null;
	endif;
	foreach entry in self.allEntries discreteLock do
		task := entry.locateTaskForTI(tiToSearch,_taskType);
		if task &lt;&gt; null then
			break;
		endif;
	endforeach;
	return task;
end;</source>
        <Parameter name="tiToSearch" type="CM_TrackedItem"/>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="myVoyage" id="ef564f9f-f0c2-48eb-bccc-35e1fcb29ff4">
        <methodInvocation>mapping</methodInvocation>
        <source>myVoyage(_set: Boolean; _value: CM_Voyage io) mapping;
// ---------------------------------------------------------------------------
// Created:     09 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _set then
		return;
	endif;
	
	if self.myParentQueue &lt;&gt; null and 
	   self.myParentQueue.isKindOf(CM_VoyageQueue) then
		_value := self.myParentQueue.CM_VoyageQueue.myVoyage;
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="264ca860-eb4a-436e-9fd9-c6cb6e3db205">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	30 October 2003 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 3 Apr 2013	cnwer1		PAR 31244
vars
	proxy : SelfType;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	proxy.crane := self.crane;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
