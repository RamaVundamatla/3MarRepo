    <JadeMethod name="create" id="961db936-8010-4dbb-9325-6fcb7f0e4efd">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes

*/

vars

begin
	// Arm global exception handler to deal with connection exceptions
	on ConnectionException do self.handleConnectionException(exception) global;
	
	// Setup from ini settings
	self.setupFromInitializationFile();
	
	// Create the message processing agent
	create self.myTCPInterfaceAgent transient;
	
	// Copy any necessary options to the agent
	self.myTCPInterfaceAgent.setupFromTCPController(self);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="55366307-374f-4cf1-b727-f69d1c7069e8">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	delete self.myMultiWorkerTcpTransport;
	delete self.myTCPInterfaceAgent;
	
	on ConnectionException do null global;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDiagDescriptionForConn" id="79f88c8e-7058-473b-8f17-6ab855abc1c0">
        <source>getDiagDescriptionForConn(_conn : JadeMultiWorkerTcpConnection) : String protected;

/*

Purpose:			Get a diagnostic display string for the passed in connection

Parameters:			connection object

Return Value:		Diagnostic string


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	if _conn = null then
		return '&lt;null&gt;';
	else
		return _conn.getDiagnosticDescription;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_conn" type="JadeMultiWorkerTcpConnection"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleConnectionException" id="24e28ecf-fa32-465c-9647-85c67be8fe52">
        <updating/>
        <source>handleConnectionException(_exc : ConnectionException) : Integer updating;

/*

Purpose:			Global exception handler to deal with connection exceptions

Parameters:			Exception object

Return Value:		Exception handler return code


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; " " &amp; 
									  "errorCode=" &amp; _exc.errorCode.String &amp; " " &amp; 
									  "errorItem=" &amp; _exc.errorItem &amp; " " &amp;
									  "extendedErrorText=" &amp; _exc.extendedErrorText &amp; " " &amp;
									  "dataBuffer=" &amp; _exc.dataBuffer.display, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	return Ex_Pass_Back;
	
	
epilog

end;</source>
        <Parameter name="_exc" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeConnection" id="14a80295-1bfa-42f0-9d0b-9ff137135086">
        <updating/>
        <source>initializeConnection() updating, protected;

/*

Purpose:			Initialise the multi worker tcp connection from the current interface
					definition

Parameters:			None

Return Value:		None


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	delete self.myMultiWorkerTcpTransport;
	create self.myMultiWorkerTcpTransport;
	
	// Setup TCP parameters
	self.myMultiWorkerTcpTransport.listenHostname			:= self.myInterfaceDefinition.localAddress;
	self.myMultiWorkerTcpTransport.listenPortnumber 		:= self.myInterfaceDefinition.localPortNumber;
	
	// Setup dynamic worker pool stuff
	self.myMultiWorkerTcpTransport.workerIdleTimeout 		:= self.tcpWorkerIdleTimeout;
	self.myMultiWorkerTcpTransport.queueDepthLimit 			:= self.tcpQueueDepthLimit;
	self.myMultiWorkerTcpTransport.queueDepthLimitTimeout 	:= self.tcpQueueDepthLimitTimeout;
	
	// Start listening
	self.myMultiWorkerTcpTransport.beginListening();
	
	app.writeLog("Worker #" &amp; self.myMultiWorkerTcpTransport.workerId.String &amp; " listening" &amp;
				   ", listenHostname=" &amp; self.myMultiWorkerTcpTransport.listenHostname &amp;
				   ", listenPortnumber=" &amp; self.myMultiWorkerTcpTransport.listenPortnumber.String &amp;
				   ", listenState=" &amp; self.myMultiWorkerTcpTransport.listenState.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	// Setup asynchronous notes back to the receiver
	self.myMultiWorkerTcpTransport.notifyEventsAsync(self, JadeMultiWorkerTcpTransport.Notify_Continuous);

	// Setup diagnostic logging
	self.myMultiWorkerTcpTransport.statisticsLogInterval	:= self.tcpStatisticsLogInterval;
	
	app.writeLog("Worker #" &amp; self.myMultiWorkerTcpTransport.workerId.String &amp; 
				   ", workerIdleTimeout=" &amp; self.myMultiWorkerTcpTransport.workerIdleTimeout.String &amp;
				   ", queueDepthLimit=" &amp; self.myMultiWorkerTcpTransport.queueDepthLimit.String &amp;
				   ", queueDepthLimitTimeout=" &amp; self.myMultiWorkerTcpTransport.queueDepthLimitTimeout.String &amp;
				   ", statisticsLogInterval=" &amp; self.myMultiWorkerTcpTransport.statisticsLogInterval.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				   
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
