    <JadeMethod name="utlUpdateFutureMoveQty" id="71be137f-9ddf-4dcd-8b98-135655981f99">
        <updating/>
        <source>utlUpdateFutureMoveQty(_fm 	    	: CM_FutureMove input;
					   _newWeight 	: Decimal;
					   _newQty 		: Integer;
					   _passport 	: CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Mar 2021 cnwma1  ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount

*/

vars
	wle : CM_WorkListEntry;
begin

