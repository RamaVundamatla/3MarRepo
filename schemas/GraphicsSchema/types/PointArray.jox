	maxX, maxY, 
	height, minX,
 	diffY, diffX	: Integer;
	reachMinH		: Boolean;
	
begin
	wasOut := false;
	create bestPlace transient;
	reachMinH := false;
	
	// Starting points
	foreach point in self do	
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the smallest Y point
		if minY = null then
			minY := point.y;
		elseif minY &gt; point.y then
			minY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
