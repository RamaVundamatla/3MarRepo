    <JadeMethod name="addToKPI" id="f42ae54a-9df0-4997-817d-22f1ad252bb7">
        <source>addToKPI();
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE
//
// ---------------------------------------------------------------------------

// This process is handled by the BGP, this method is here so that scripts can be run to generate KPIstats for provious years.
vars
	kpiTrk : CM_KPITruckByCarrierDay;
	kpiDetail : CM_KPITruckDetail;
	details : CM_KPIByTypeCodeTS;
	today : TimeStamp;
	tm : Time;
	aTI : CM_TrackedItem;
	sumCode : String;
begin
	tm.setTime(0,0,0,0);
	today := self.timeIn;
	today.setTime(tm);
	create details transient;
	
	// KPI BY CARRIER
	kpiTrk := self.myTerminal.allKPIbyTypeCodeTS[KPI_Type_TruckCarrier,self.vehicle.carrierCode,today].CM_KPITruckByCarrierDay;
	if kpiTrk = null then
		create kpiTrk;
		kpiTrk.setProxyKPI(self.myTerminal, self.vehicle.carrierCode, today, KPI_Type_TruckCarrier,app.myPassport.userCode);
	endif;
	kpiTrk.updateFromVisitRecord(self);
	kpiTrk.updateCarrier(self);
	
	// KPI BY CARGO
	if self.allReceivedTrackedItems.isEmpty() 
	and self.allReleasedTrackedItems.isEmpty() then
		// KPI TRUCK Detail with no cargo
		create kpiDetail;
		kpiDetail.setProxyKPI(self.myTerminal, null, self.timeIn, KPI_Type_TruckDetail,app.myPassport.userCode);
		kpiDetail.updateFromVisitRecord(self);
		kpiDetail.setMyCarrier(kpiTrk);
	else
		self.addToKPICargo(self.allReceivedTrackedItems, today, details, kpiTrk);
		self.addToKPICargo(self.allReleasedTrackedItems, today, details, kpiTrk);
	endif;
epilog

	delete details;
end;</source>
    </JadeMethod>
    <JadeMethod name="addToKPICargo" id="60c28899-6d29-4b5b-9025-d5f96aba14b3">
        <source>addToKPICargo(_tis :  CM_TISet; _today : TimeStamp; _details : CM_KPIByTypeCodeTS input; _kpiTrk : CM_KPITruckByCarrierDay);
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	kpiCargo : CM_KPITruckByCargo;
	kpiDetail : CM_KPITruckDetail;
	aTI : CM_TrackedItem;
	imexCode, sumCode : String;
begin
	foreach aTI in _tis discreteLock do
		// KPI TRUCK Detail
		create kpiDetail;
		kpiDetail.setProxyKPI(self.myTerminal, null, self.timeIn, KPI_Type_TruckDetail,app.myPassport.userCode);
		kpiDetail.updateFromVisitRecord(self);
		kpiDetail.addTI(aTI);
		kpiDetail.setMyCarrier(_kpiTrk);

	
		// By Cargo/Day KPI
		sumCode := aTI.getPlannerReportGroupDesc();
		imexCode := aTI.getImExStatusStringDesc(false);
		sumCode := imexCode &amp; " " &amp; sumCode;
		
		kpiCargo := self.myTerminal.allKPIbyTypeCodeTS[KPI_Type_TruckCargo,sumCode, _today].CM_KPITruckByCargo;
		if kpiCargo = null then
			create kpiCargo;
			kpiCargo.setProxyKPI(self.myTerminal, sumCode, _today, KPI_Type_TruckCargo,app.myPassport.userCode);
		endif;
		kpiCargo.updateFromVisitRecord(self);
		kpiCargo.addTI(aTI);
		kpiDetail.setMyCargo(kpiCargo);

	endforeach;

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_today" type="TimeStamp"/>
        <Parameter name="_details" type="CM_KPIByTypeCodeTS" usage="input"/>
        <Parameter name="_kpiTrk" type="CM_KPITruckByCarrierDay"/>
    </JadeMethod>
