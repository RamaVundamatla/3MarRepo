    <JadeMethod name="cloneReferences" id="c6729414-fa18-4557-bfd6-fa5727c77983">
        <updating/>
        <source>cloneReferences(_testObj : CM_TrxTestController) updating;

// cnwdvb1 18 November 2002 

vars

begin

	self.myTestLockObjectA := _testObj.myTestLockObjectA;
	self.myTestLockObjectB := _testObj.myTestLockObjectB;

end;</source>
        <Parameter name="_testObj" type="CM_TrxTestController"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="2fbffe1b-f477-462f-8e5d-0c19c396a8e0">
        <source>doUpdate();
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.lockUpdateA then
		exclusiveLock(self.myTestLockObjectA);
	endif;
	if self.lockUpdateB then
		exclusiveLock(self.myTestLockObjectB);
	endif;
	
	if self.createUpdateWarnings1 then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Warning 1 during update', null, null, myTestLockObjectA);
		app.raiseCMWarning(Input_required_field_warnDurUp, null, null, myTestLockObjectA); // cnwdb2	PAR 35364
	endif;

	if self.createUpdateJadeException then
		beginTransaction;beginTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidation" id="ba01b9e3-c175-444a-9173-d8143b3fc0ba">
        <source>doValidation();
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.lockValidationA then
		exclusiveLock(self.myTestLockObjectA);
	endif;
	if self.lockValidationB then
		exclusiveLock(self.myTestLockObjectB);
	endif;
	
	if self.createValidationExceptions then
	//	app.raiseCMException1(REQUIRED_FIELD, 'err 1', null, null);
		app.raiseCMException(Input_required_field_err1, null, null); // cnwdb2	PAR 35364

	//	app.raiseCMException1(REQUIRED_FIELD, 'err 2', null, null);
		app.raiseCMException(Input_required_field_err2, null, null); // cnwdb2	PAR 35364
	endif;

	if self.createValidationWarnings1 then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'warn 1 for 1', null, null, myTestLockObjectA);
		app.raiseCMWarning(Input_required_field_warn141, null, null, myTestLockObjectA); // cnwdb2	PAR 35364

	endif;

	if self.createValidationWarnings2 then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Warning 1 for 2', null, null, myTestLockObjectA);
		app.raiseCMWarning(Input_required_field_warn142, null, null, myTestLockObjectA); // cnwdb2	PAR 35364


	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Warning 2 for 2', null, null, myTestLockObjectA);
		app.raiseCMWarning(Input_required_field_warn242, null, null, myTestLockObjectA); // cnwdb2	PAR 35364


	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Warning 3 for 2', null, null, myTestLockObjectA);
		app.raiseCMWarning(Input_required_field_warn342, null, null, myTestLockObjectA); // cnwdb2	PAR 35364


	endif;
	
	if self.createValidationJadeException then
		beginTransaction;beginTransaction;
	endif;

end;</source>
    </JadeMethod>
