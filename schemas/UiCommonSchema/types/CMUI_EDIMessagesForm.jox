    <JadeMethod name="cmbFile_click" id="5092c14d-e0a1-4c8e-8c9b-7be82799db41">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFile_click(combobox: ComboBox input) updating;
/*
Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.doShowEDIFile;
epilog

