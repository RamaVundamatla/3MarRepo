    <JadeMethod name="btnAddNew_click" id="5ac8d731-fb34-447f-a908-cc533a94c4e2">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddNew_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	20 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------


vars
	trxResult		: Boolean;
	warningsResult	: Integer;
begin
	if ( self.myCurrentTableItem.isKindOf(SOPTM_Carrier)
	or self.myCurrentTableItem.isKindOf(SOPTM_ConsigneeConsignor)
	or self.myCurrentTableItem.isKindOf(SOPTM_Operator)
	or self.myCurrentTableItem.isKindOf(SOPTM_Organisation)	//07 Jul 2015	NDL	Par 36558
	) then
		while true do
			trxResult := self.myCurrentTableItem.doAddNewEmail();
		
			if trxResult then
				self.clearErrorWarnings();
				self.txtEmailName.text := "";
				self.txtName.text := "";
				break;
			endif;

			warningsResult := app.showErrorWarningDialog(self.myCurrentTableItem.name, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
			if app.myPassport.noErrors and
			   warningsResult = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			break;
		endwhile;		
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
