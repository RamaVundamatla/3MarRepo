    <JadeMethod name="isCMIFDataMatch" id="89704f20-58ba-4f1b-a3b0-23a37d2615c4">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
//15 October 2009	cnwml2


vars

begin
	
	return _yaData.value = null or _cmifAutoPlan.isBOL_Match(_yaData);

epilog

end;</source>
