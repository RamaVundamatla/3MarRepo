    <JadeMethod name="getAllTIsForEstimate" id="bc4d959f-145c-4e7d-984a-194fcbbd1e87">
        <source>getAllTIsForEstimate(_allTis : CM_TISet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
	job : CM_Job;
	holdJob : CM_VoyageHoldJob;
	vwle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	txnParams : CMIF_WorkOrderTransController;
	ti : CM_TrackedItem;
	wodcargo : CM_WodCargoRequest;
begin
	if _allTis = null then
		return;
	endif;
	
	voyage := self.getMyVoyageObject();
	
	if voyage = null then
		return;
	endif;
	
	foreach job in voyage.allVoyageJobs do
		if job.isKindOf(CM_VoyageHoldJob) then
			if job.status &lt;&gt; JOB_COMPLETE then

				foreach wle in job.workListEntries discreteLock do
					if wle.status &lt;&gt; WLE_UNACTIONED then
						continue;
					endif;
					ti := wle.myTrackedItem;
					
					if ti &lt;&gt; null then
						_allTis.addNoDuplicates(ti,false);
					endif;
					
				endforeach;
			endif;
		endif;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_allTis" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjects" id="20a75f28-36d1-4dee-9950-34a21636d44e">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2019	jlger1	Initial creation 43546

*/

vars
	cargoDetails : CM_WodCargoRequest;
	marineDetail : CM_WodMarineServiceDetail;
begin
	inheritMethod(_childAuditSubjectNames);
	
	foreach cargoDetails in self.allCargoDetails discreteLock do
