    <JadeMethod name="getXMLSettingsForSetup" id="5de6ab84-1bf6-4959-a9b2-403d5a5f6f3a">
        <source>getXMLSettingsForSetup();
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	idx : Integer;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, true);
	endif;

	theXML := userWindow.xmlInfo;

	
	theXMLValue := theXML.cnEcGetTagValueOfName("DAYS" );
	if theXMLValue = null then
		theXMLValue := "20";
	endif;
//	self.txtDayNum.text := theXMLValue;
	
end;</source>
