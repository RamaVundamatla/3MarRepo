    <JadeMethod name="updateWorkPoint" id="da3af1f3-4aa7-4777-8998-0a1183802fd7">
        <source>updateWorkPoint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023	navhl20	ChangeRequest 57712:[54558] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	terminal 			: CM_Terminal;
	workPointType,
 	pxyWorkPointType	: CM_WorkPointType;
	workPoint			: CM_WorkPoint;
begin
	
	beginTransaction;
	
		foreach terminal in app.myRoot.allTerminals  do
			workPointType := terminal.allWorkPointTypes[WORK_POINT_TYPE_SHIP,'SHIP'];
			if workPointType = null then
				workPointType := terminal.createWorkPointTypeShip();
			endif;
			
			foreach workPoint in terminal.allWorkPointsByCode do
				if workPointType &lt;&gt; null then
					workPoint.setMyWorkPointType(workPointType);
				endif;
			endforeach;
			
		endforeach;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateYaTypeLoadPort" id="316d3b0b-6fe2-44e3-b525-c6fcb360a67f">
        <source>updateYaTypeLoadPort();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navmk20	Task 58016: UI - Storage Config - Storage Detail Attributes

*/

vars
	typeLoadPort : CM_YATypeLoadPort;
	
begin
	beginTransaction;
