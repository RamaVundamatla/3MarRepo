<GUIClass name="HMS_ConflictReport" id="38001199-4ee2-4f72-8e4d-908c5d44bd2c">
    <superclass name="HMS_ReportForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myConflictManager" id="8be742fa-a56a-457e-9072-0c8feb754de2">
        <embedded/>
        <type name="CMIF_HMS_ConflictsManager"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picIcon" id="b97bb789-4e37-44f2-ad62-522ef718f11a">
        <embedded/>
        <type name="Picture"/>
    </ImplicitInverseRef>
    <JadeMethod name="initialReportSetup" id="e56b5aa6-d70d-4252-ada7-8dac16cfc3cb">
        <updating/>
        <source>initialReportSetup() updating;

vars
	date : TimeStamp;
	usr  : String;
begin
	inheritMethod();

	if app.getMyUser &lt;&gt; null then
		usr := app.getMyUser.userName;
	else
		usr := '** User Not Defined **';
	endif;		

	lblReportTitle.caption 	:= 'CONFLICTS REPORT';
	txtUserCode.text		:= usr;
	txtReportDate.text 		:= date.String &amp; ", " &amp; date.Time.userFormat($CM_HMS_Time24Hour);

	txtFooterLeft.text 		:= 'Conflicts Report';
	txtHeaderLeft.text 		:= 'Conflicts Report';
	txtHeaderRight.text 	:= 'Printed by: ' &amp; usr;
	app.printer.setHeader(fHeader);
	app.printer.setFooter(fFooter);

	tableHeader.accessMode  := Table.AccessMode_Row;
	tableHeader.rowHeight[1]:= 34;
	tableHeader.gridLines	:= false;
	tableBody.borderStyle 	:= Table.BorderStyle_None;
	tableBody.gridLines		:= false;

	picTitleLogo.picture	:= picIcon.picture;

end;</source>
    </JadeMethod>
    <JadeMethod name="printConflictsReport" id="e312b740-e5b9-452f-99c6-66831538e31b">
        <updating/>
        <source>printConflictsReport() updating;

vars
	conflictObj		: CMIF_HMS_Conflict;
	str				: String;
	sShipName		: String;
	sMoveType		: String;
	sMoveDate		: String;
	sConflictType	: String;
	sDescription	: String;
	int				: Integer;
	managerObj		: CMIF_HMS_ConflictsManager;

begin
	managerObj	:=	self.myConflictManager;
	// print the header information
	app.printer.print(fBlank);
	app.printer.print(fTableHeader);
	txtHeading.text := headText;
	app.printer.print(fHeading);

	foreach conflictObj in managerObj.allCMIFConflicts do
		if conflictObj.myVoyageMovement &lt;&gt; null then
			// Set ship name
			sShipName	:=	conflictObj.myVoyageMovement.myHMSVoyageData.vesselName;
	
			// Load move type
			sMoveType	:=	conflictObj.myVoyageMovement.moveType;
	
			// Load move date
			sMoveDate	:=	conflictObj.myVoyageMovement.occursOnDTNEW.Date.format('dd/MM') &amp; "- " &amp; conflictObj.myVoyageMovement.occursOnDTNEW.Time.userFormat($CM_HMS_Time24Hour);
		endif;
		
 		// Load conflict type and conflict description
 		if conflictObj.conflictType = ValidateWharfLockout then
 			sConflictType	:=	app.getErrorString(ValidateWLockoutTitle);
 			sDescription	:=	app.getErrorString(ValidateWLockoutText);
			
 		elseif conflictObj.conflictType = ValidateShipPosn then
 			sConflictType	:=	app.getErrorString(ValidateShipPosnTitle);
 			sDescription	:=	app.getErrorString(ValidateShipPosnText);
			
 		elseif conflictObj.conflictType = ValidateWharfOverhang then
 			sConflictType	:=	app.getErrorString(ValidateWharfOverhangTitle);
 			sDescription	:=	app.getErrorString(ValidateWharfOverhangText);
			
 		elseif conflictObj.conflictType = ValidateTidalWindow then
 			sConflictType	:=	app.getErrorString(ValidateTidalWindowTitle);
 			sDescription	:=	app.getErrorString(OutsideTidalWindow);
			
 		elseif conflictObj.conflictType = ValidateBerthDepths then
 			sConflictType	:=	app.getErrorString(ValidateBerthDepthTitle);
 			sDescription	:=	app.getErrorString(ValidateBerthDepthText); 
			
 		elseif conflictObj.conflictType = ValidatePilotMaster then
 			sConflictType	:=	app.getErrorString(ValidatePilotMasterTitle);
 			sDescription	:=	app.getErrorString(NoMasterPilot);
			
 		elseif conflictObj.conflictType = ValidateSteamTime then
 			sConflictType	:=	app.getErrorString(ConflictTypeSteamTime);
 			sDescription	:=	app.getErrorString(ConflictDescSteamTime);
			
 		elseif conflictObj.conflictType = ValidateStockpile then
 			sConflictType	:=	app.getErrorString(ValidateStockpileTitle);
 			sDescription	:=	conflictObj.conflictTypeDescription();
			
 		elseif conflictObj.conflictType = ValidateVesselUnavail then
 			sConflictType	:=	app.getErrorString(ConflictTypeVesselUnavail);
 			sDescription	:=	app.getErrorString(ConflictDescVesselUnavail);
			
 		endif;	

 		// print the line
		str := sShipName &amp; Tab &amp; sMoveType &amp; Tab &amp; sMoveDate &amp; Tab &amp; sConflictType &amp; Tab &amp; sDescription;
		doPrinting(str,int);			

		// reset variables
		str				:=	null;
		sShipName		:=	null;
		sMoveType		:=	null;
		sMoveDate		:=	null;
		sConflictType	:=	null;
		sDescription	:=	null;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="processReport" id="80f40f30-e3c3-40c8-9dc9-4f62ee269240">
        <updating/>
        <source>processReport() updating;

vars
 	currentDT:	TimeStamp;
	
begin
	// this method drives the report
	inheritMethod();
	
	// setup the report headings etc
	initialReportSetup();

	// print the initial report header and attributes strips
	app.printer.print(fTitle);
	app.printer.print(fTitleSep);

	// print the report
	setupConflictReport();
	headText := 'Conflicts for the period ' &amp; currentDT.date.shortFormatJMT() &amp; ' - ' &amp; currentDT.Time.userFormat($CM_HMS_Time24Hour) &amp; " onwards";
	printConflictsReport();
	app.printer.print(fTitleSep);
epilog
	app.printer.close();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupConflictReport" id="8fa47c07-b540-4fa9-bbb2-0f786f48de2f">
        <updating/>
        <source>setupConflictReport() updating;

vars
	columnWidths : IntegerArray;
	columnText	 : StringArray;
	int			 : Integer;
begin

	create columnWidths transient;
	create columnText	transient;

	columnWidths[01] := 120;
	columnWidths[02] := 80;
	columnWidths[03] := 80;
	columnWidths[04] := 130;
	columnWidths[05] := 320;


	columnText[01]   := 'SHIP NAME';
	columnText[02]   := 'MOVE TYPE';
	columnText[03]   := 'MOVE DATE';
	columnText[04]   := 'CONFLICT TYPE';
	columnText[05]   := 'CONFLICT DESCRIPTION';


	// setup the header table
	setReportTables(tableHeader,columnWidths,columnText);

	// setup the body table
	columnText.clear;
	columnText[columnWidths.size] := null;
	setReportTables(tableBody,columnWidths,columnText);
epilog
	delete columnWidths;
	delete columnText;
end;</source>
    </JadeMethod>
</GUIClass>
