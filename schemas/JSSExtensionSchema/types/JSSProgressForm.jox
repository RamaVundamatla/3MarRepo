    <ImplicitInverseRef name="btnCancel" id="76da194e-f3a5-48fc-b444-dccd7f0c37d5">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <PrimAttribute name="isCancelled" id="f1624a2b-22e1-45f9-b363-f1bcc945f9c4">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="lblDescription" id="81d4e39f-636a-4b62-b18b-85e6600d8eb9">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="progressBar" id="7c789c0f-9217-4f02-8fea-39b1c89d7152">
        <embedded/>
        <type name="ProgressBar"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="576c4d19-9138-4a03-bb4f-1daa5adda970">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCancelled	:=	true;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkCancel" id="1c37adf7-3ba6-4d3f-971f-6214a27eb77b">
        <updating/>
        <source>checkCancel():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	returnValue		: Boolean;
	
begin
	self.visible	:=	false;
	userResponse	:=	app.msgBox(	"Do you wish to cancel ?",
									"Cancel",
									MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if userResponse = MsgBox_Return_Yes then
		returnValue	:=	true;
		unloadForm;
	else
		self.resetCancelFlag();
		returnValue		:=	false;
		self.visible	:=	true;
	endif;
epilog
	return returnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="e5241cd8-a0a5-4e3b-97a2-58ca952f6e94">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="resetCancelFlag" id="edef66e6-13e8-4f2b-b80d-0ad2a8e55b7c">
        <updating/>
        <source>resetCancelFlag() updating;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Resets the cancelled flag back to a value of false.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCancelled	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="startProgress" id="3614eddd-b863-450b-b806-dcb088fc7a1b">
        <updating/>
        <source>startProgress(pDescription:String; pParts:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Used to show the progress of a lengthy process.
//
// Parameters:	pDescription (String) - A description of the process.
//				pParts (Integer) - The number of parts in the process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lblDescription.caption	:=	pDescription;
	self.progressBar.partsInJob	:=	pParts;
	self.progressBar.partsDone	:=	0;
	self.refreshNow();
end;</source>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pParts" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="512552e0-0411-41b9-882a-80a64fc76731">
        <source>updateProgress(pPartsDone:Integer);
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Used to show the progress of a lengthy process.
//
// Parameters:	pPartsDone (Integer) - The number of completed parts in the process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.progressBar.partsDone	:=	pPartsDone;
	self.refreshNow();
	btnCancel.doWindowEvents(0);
end;</source>
        <Parameter name="pPartsDone" type="Integer"/>
    </JadeMethod>
</GUIClass>
