    <JadeMethod name="getPreRotatedAdjacentLocation" id="08eb63df-3a86-44fd-916d-60ebfdc2d947">
        <updating/>
        <source>getPreRotatedAdjacentLocation(_isAft  : Boolean; _isLoad : Boolean) : CM_ROROLocnDefn updating;
/*
Purpose:			
Date		Who		Reason
03 August 2012	cnwab1	Initial creation
*/

vars
	adjacentLocn, locnDefn : CM_ROROLocnDefn;
	theCode : String;
	invalidLocn : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, locnDefn, invalidLocn);
	
	if _isAft then
		locnDefn := self.myPreRotateAftLocn;
		if locnDefn &lt;&gt; null then
			theCode := locnDefn.code;
		
			if invalidLocn then
				self.myPreRotateAftLocn :=  null;
			endif;
		endif;
		
		
		
		
		if self.myPreRotateAftLocn = null then
			adjacentLocn:=  null;
		else
			if _isLoad then
				if self.myPreRotateAftLocn.myRotateDischarge &lt;&gt; null then // my pre rotated is now rotated as well
					if self.myPreRotateAftLocn.myRotateDischarge.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateAftLocn.myRotateDischarge.myPreRotateAftLocn;
					endif;
				else
					if self.myPreRotateAftLocn.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateAftLocn;
					endif;
				endif;
			else
				if self.myPreRotateAftLocn.myRotateLoad &lt;&gt; null then
					if self.myPreRotateAftLocn.myRotateLoad.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateAftLocn.myRotateLoad.myPreRotateAftLocn;
					endif;
				else
					if self.myPreRotateAftLocn.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateAftLocn;
					endif;
				endif;
			
			endif;
		endif;
	else
		locnDefn := self.myPreRotateFwdLocn;
		if locnDefn &lt;&gt; null then
			theCode := locnDefn.code;
		
			if invalidLocn then
				self.myPreRotateFwdLocn :=  null;
			endif;
		endif;
		
		if self.myPreRotateFwdLocn = null  then
			adjacentLocn:=  null;
		else
			if _isLoad then
				if self.myPreRotateFwdLocn.myRotateDischarge &lt;&gt; null then // my pre rotated is now rotated as well
					if self.myPreRotateFwdLocn.myRotateDischarge.isPlannedRotated then // my pre rotated is now rotated so ignore. (PAR 32216 changed myPreRotateAftLocn to myPreRotateFwdLocn)
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateFwdLocn.myRotateDischarge.myPreRotateFwdLocn;
					endif;
				else
					if self.myPreRotateFwdLocn.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateFwdLocn;
					endif;
				endif;
			else
				if self.myPreRotateFwdLocn.myRotateLoad &lt;&gt; null then
					if self.myPreRotateFwdLocn.myRotateLoad.isPlannedRotated then // my pre rotated is now rotated so ignore.  (PAR 32216 changed myPreRotateAftLocn to myPreRotateFwdLocn)
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateFwdLocn.myRotateLoad.myPreRotateFwdLocn;
					endif;
				else
					if self.myPreRotateFwdLocn.isPlannedRotated then // my pre rotated is now rotated so ignore
						adjacentLocn:=  null;
					else
						adjacentLocn:=  self.myPreRotateFwdLocn;
					endif;
				endif;
			
			endif;
		endif;
	endif;

	// It is possible for the original actual's pre rotation adjacent was a clone that has now been deleted
	// So we can get the new clone's adjacent position using pixels
	if _isLoad then
		if adjacentLocn = null then
			locnDefn := self.myRotateLoad;  // Get the clone
			if _isAft then
				adjacentLocn := locnDefn.myLayout.myDeckLayer.getAftLocnByPosition(locnDefn);
			else
				adjacentLocn := locnDefn.myLayout.myDeckLayer.getFwdLocnByPosition(locnDefn);
			endif;
		endif;
	endif;
	
	return adjacentLocn;
	
epilog

end;</source>
        <Parameter name="_isAft" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getRotatedLinked" id="45db13fd-474f-4610-91d2-4154933951f4">
        <source>getRotatedLinked() : CM_ROROLocnDefn;
