    <JadeMethod name="totalSelf" id="1b59d49f-a648-4ed9-a09f-7644bcc2ee1b">
        <updating/>
        <source>totalSelf(_container : CM_Container) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	task, latestTask 	: CM_ToDoTask;
	tasks				: CM_ToDoTaskArray;
	
begin
	self.total := self.total + 1;
	
	/*if _container.hasToDoTaskWithTransType(TRANS_TYPE_SURVEY, false) then
		self.totalAwaitingSurvey := self.totalAwaitingSurvey + 1;
	endif;	
	if _container.hasToDoTaskWithTransType(TRANS_TYPE_REPAIR, false) then
		self.totalAwaitingRepair := self.totalAwaitingRepair + 1;
	endif;	
	if _container.hasToDoTaskWithTransType(TRANS_TYPE_PRETRIP, false) then
		self.totalAwaitingPreTrip := self.totalAwaitingPreTrip + 1;
	endif;	
	if _container.hasToDoTaskWithTransType(TRANS_TYPE_WASH, false) then
		self.totalAwaitingWash := self.totalAwaitingWash + 1;
	endif;*/
	
	// 19/05/2008 cnwar2 #16603 - Only update todo task totals for the lastest todo task on a container
	create tasks transient;
	_container.allToDoTasksToDo.copy(tasks);
	foreach task in tasks reversed do
		if task.toDoTaskDescTransType = TRANS_TYPE_SURVEY 
		or task.toDoTaskDescTransType = TRANS_TYPE_REPAIR
		or task.toDoTaskDescTransType = TRANS_TYPE_PRETRIP
		or task.toDoTaskDescTransType = TRANS_TYPE_WASH then
			latestTask := task;
			break;
		endif;	
	endforeach;
	if latestTask &lt;&gt; null then
		if latestTask.toDoTaskDescTransType = TRANS_TYPE_SURVEY then
			self.totalAwaitingSurvey := self.totalAwaitingSurvey + 1;
		elseif latestTask.toDoTaskDescTransType = TRANS_TYPE_REPAIR then
			self.totalAwaitingRepair := self.totalAwaitingRepair + 1;
		elseif latestTask.toDoTaskDescTransType = TRANS_TYPE_PRETRIP then
			self.totalAwaitingPreTrip := self.totalAwaitingPreTrip + 1;
		elseif latestTask.toDoTaskDescTransType = TRANS_TYPE_WASH then
			self.totalAwaitingWash := self.totalAwaitingWash + 1;
		endif;
	endif;
	
	if _container.isAvailable then
		self.totalAvailable := self.totalAvailable + 1;
	endif;

epilog
	delete tasks;
end;


</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
</Class>
