*/

vars

begin
	return self.ownerTrailerID &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrenoteActioned" id="b4fc92cc-9a93-4844-8217-77030e200843">
        <source>isPrenoteActioned(_prenote : CM_TrackedItem) : Boolean;
/*

Date		Who		Reason
28 February 2017	cnwer1	Initial creation TFS 1602 

*/

vars
	entity			: CMGTE_Entity;
	cargoType		: CM_CargoType;
begin
	
	if _prenote = null then
		return false;
	endif;
	
	cargoType := _prenote.myCargoType;
	
	foreach entity in self.allGateEntities do
		if entity.isKindOf(CMGTE_Receival) and  entity.CMGTE_Receival.myTrackedItem = _prenote then
			if not cargoType.allowDuplicates then
				return true;
			else
				if cargoType.isBulkByQuantity and entity.CMGTE_Receival.totalQuantity &gt;=  _prenote.totalQuantity then
					return true;
				elseif cargoType.isBulkByWeight and entity.CMGTE_Receival.weightTotal &gt;=  _prenote.totalWeight then
					return true;
				elseif cargoType.isBulkByVolume and  entity.CMGTE_Receival.volumeTotal &gt;=  _prenote.totalVolume  then
					return true;			
				endif;
			endif;			
		endif;
	endforeach;

	return false;	   
epilog

end;</source>
        <Parameter name="_prenote" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeighBridgeWeighable" id="7a217c69-9b84-440e-b548-0bdd576c0e2f">
        <source>isWeighBridgeWeighable(_objArray : ObjectArray input; _errStr : String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	par 33268
08 Jan 2018		NDL		TFS 36437

*/

vars

	weighBridge : CM_WeighBridgeObj;

begin

	if self.myTerminal = null or self.myTerminal.allWeighBridges.isEmpty then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		if self.myTerminal = null  then
			_errStr := "Vehicle visit has no terminal!";
		else
			_errStr := "Vehicle visit terminal has no weigh bridges!";
		endif;
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
		return false;
	endif;
	
	if self.isCancelled then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		_errStr := "Vehicle visit is cancelled!";
		app.writeLog( method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
		return false;
	endif;
	
	if self.vehicle = null then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		_errStr := "Vehicle visit has no associated vehicle!";
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
		return false;
	endif;
	
	if not self.vehicle.isOnsite then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		_errStr := "Vehicle visit vehicle is off site!";
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
		return false;
	endif;
	
	if self &lt;&gt; self.vehicle.getCurrentVisit then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		_errStr := "Vehicle visit is NOT the current visit!";
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
		return false;
	endif;
	
	if not self.vehicle.isWeighBridgeWeighable( _objArray, _errStr ) then
		//04 Aug 2016	NDL	TFS 2331 - debug message
		//_errStr := method.qualifiedName &amp; " vehicle visit vehicle is NOT weighable!";
		//app.writeLog(_errStr, LogAlways);
		return false;
	endif;
	
	if _objArray &lt;&gt; null then
	
		_objArray.addExclusive( self );
	
		if self.myGateLaneController &lt;&gt; null then
			if self.myGateLaneController.isKindOf( CM_LaneController ) then
				weighBridge := self.myGateLaneController.CM_LaneController.getWeighBridge();
			endif;
			if weighBridge &lt;&gt; null then
				_objArray.addExclusive(weighBridge);
			endif;
		endif;
		
		if self.myInCMGTE_Chassis &lt;&gt; null then
			if self.myInCMGTE_Chassis &lt;&gt; null then
				_objArray.addExclusive(self.myInCMGTE_Chassis);
			endif;
		endif;
		
	endif;
	
	return true;


epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorked" id="abe073c7-51f9-4f21-a70c-dfefe6f1a9ae">
        <source>isWorked() : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myRoadJob &lt;&gt; null then
		return true;
	endif;
	return (self.status = self.Status_Complete or self.status = self.Status_Unactioned or self.status = self.Status_Yard);	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myInCMGTE_Generator" id="c45aa4c5-3787-4262-af26-0a626962413f">
        <methodInvocation>mapping</methodInvocation>
        <source>myInCMGTE_Generator(set : Boolean; _value : CMGTE_Generator io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2009	cnwjk3	Initial creation

*/

vars

begin

	if set then
	else
		if self.myInCMGTE_Chassis &lt;&gt; null and not self.myInCMGTE_Chassis.allChildren.isEmpty() then
			// The IN chassis can have only one attachment and that is a generator 
			_value := self.myInCMGTE_Chassis.allChildren.first.CMGTE_Generator;
		else
			_value := null;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CMGTE_Generator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myVehicleBookingTimeslot" id="f1e7d843-f163-40c7-9e3e-8dfd4d0a0615">
        <methodInvocation>mapping</methodInvocation>
        <source>myVehicleBookingTimeslot(set : Boolean; _value : CM_VehicleBookingTimeSlot io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2023	navpw1	Initial creation TFS: 54049 (55839)

*/

begin
	if set then
		//Do Nothing
	else
		if self.allVehicleBookingSlots.isNotEmpty then
			_value := self.allVehicleBookingSlots.first;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_VehicleBookingTimeSlot" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numAttachments" id="58ab149e-904b-46d1-961a-af8465ff6e9a">
        <source>numAttachments(_type : Integer):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	iter 			: Iterator;
	attachment 		: CM_Attachment;
	numAttachments 	: Integer;
begin
	numAttachments := 0;
	iter := self.allAttachments.createIterator();
	self.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
	while iter.next(attachment) do
		if attachment.type &lt;&gt; _type then
			break;
		endif;
		numAttachments := numAttachments + 1;
	endwhile;
	
	return numAttachments;
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="numTIsIn" id="005d281a-4230-4194-8b79-76c29b081978">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIsIn(set : Boolean; _value : Integer io) mapping;
/*

Date		Who		Reason
09 Oct 2013	cnwer1	Initial creation PAR 32717
08 Nov 2016	cnwkpd1	PAR #38402 - Performance issues in C3 due to large number of Vehicle Vist Record Details

*/

vars
	total : Integer;
	vvrd	:CM_VehicleVisitRecordDetail;
	tiID : String;
	allTIs : StringArray;
begin
	if not set then
		total	:= 0;
		create allTIs transient;
		//epr TFS 45705 23/7/19
		foreach vvrd in self.allVehicleVisitRecordDetails discreteLock, reversed where vvrd.isCargoMove  do
			tiID:= vvrd.getExtraInfo_TrackedItemId;
			if vvrd.recordType = VisitRecord_CargoRemoved then
				total:=total + vvrd.getExtraInfo_MoveTotal();
				if tiID &lt;&gt; null then
					allTIs.add(tiID);
				endif;
			elseif vvrd.recordType = VisitRecord_CargoPlaced then
				if tiID &lt;&gt; null and allTIs.includes(tiID) then
					total:=total - vvrd.getExtraInfo_MoveTotal();
				endif;
			endif;
		endforeach;	
		
		_value:=total.max(0);	//16 Sep 2020	NDL	TFS 50004

	endif;
	
epilog	
	delete allTIs;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numTIsOut" id="b7da8cb6-fd95-4b79-bc12-209fdbaf1add">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIsOut(set : Boolean; _value : Integer io) mapping;
/*

Date		Who		Reason
09 Oct 2013	cnwer1	Initial creation PAR
08 Nov 2016	cnwkpd1	PAR #38402 - Performance issues in C3 due to large number of Vehicle Vist Record Details

*/

vars
	total : Integer;
	vvrd : CM_VehicleVisitRecordDetail;
	tiID : String;
	allTIs : StringArray;
begin
	if not set then
		create allTIs transient;
		//epr TFS 45705 23/7/19
		foreach vvrd in self.allVehicleVisitRecordDetails  discreteLock where vvrd.isCargoMove  do
			tiID:= vvrd.getExtraInfo_TrackedItemId;
			if vvrd.recordType = VisitRecord_CargoPlaced  then
				total:=total + vvrd.getExtraInfo_MoveTotal();
				if tiID &lt;&gt; null then
					allTIs.add(tiID);
				endif;
			elseif vvrd.recordType = VisitRecord_CargoRemoved then
				if tiID &lt;&gt; null and allTIs.includes(tiID) then
					total:=total - vvrd.getExtraInfo_MoveTotal();
				endif;
			endif;
		endforeach;	
		
		_value:=total.max(0);
	endif;

epilog
	delete allTIs;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onSiteAt" id="4948bf72-57fa-4fa4-883d-1d89f013daf9">
        <source>onSiteAt( _ts : TimeStamp ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if not _ts.isValid then
		return false;
	endif;

	if self.timeIn.isValid then
		if _ts &lt; self.timeIn then
			return false;
		endif;
	endif;
	
	if self.timeOut.isValid then
		if _ts &gt; self.timeOut then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printGhanaWaybillReport" id="0913af99-15a0-4b52-817b-fd37ade8d446">
        <updating/>
        <source>printGhanaWaybillReport( pPrinterName : String; pPrintPreview : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	pxyWayBillDetail : CM_WaybillPrintDetail;
	realWayBillDetail : CM_WaybillPrintDetail;
	theReturn : Integer;
	reportClass : Class;
	success : Boolean;
	printerName : String;

begin

	printerName := pPrinterName.trimBlanks;

	//create the proxy and populate from the vvr.
	create pxyWayBillDetail transient;
	pxyWayBillDetail.setProxy( self );
	
	//print the report, implemented in UiCommonSchema, hence the sendmsg...
	app.printer.abort();
	if pPrinterName &lt;&gt; null then
		app.printer.setPrinter( printerName );
	endif;
	app.printer.orientation := Print_Portrait;	//05 Nov 2015	NDL	Par 36777
	app.printer.printPreview := pPrintPreview;
	
	success := pxyWayBillDetail.sendMsg("printReport").Boolean; //Method only available in UICommonSchema
	
	
	//if the print was successfull, then create the vvrd and persistant copy of the data printed.
	if success then
		while true do
			app.myTrxUA.trxAddVVRWayBillPrint(self, pxyWayBillDetail, app.myPassport);
	
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Waybill_report), app.myPassport, 20); // 20 = ErrWarnMode_Update + ErrWarnMode_CanAckWarnings
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged     := true;
					continue;
				endif;
				break;
			endif;
			break;
		endwhile;
	endif;

epilog

	delete pxyWayBillDetail;

end;</source>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pPrintPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReceiptViaBGPforHandHelds" id="6753020d-0ff5-455c-8500-cdbdcee5443e">
        <source>printReceiptViaBGPforHandHelds( _printerPhysicalName : String;
								_copies : Integer;
								_reportName : String;
								_selectedTisOnly : CM_TISet	//12 Dec 2013	NDL	Par 33184
								) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2010	cnwndl1	Initial creation
12 June 2013	NDL	Par 31562 - This version creates a temporary but persistent CM_QryReportSystem object during
								the process (with no root) and attachs it to a template for the BGP.
								When teh BGP is deleted, if it finds the CM_QryReportSystem with no root it deletes it.

22 Jul 2016		TFS 2401 - to be clear changed para name to physical printer was the logical
*/

vars

	reportName : String;
	user : CM_User;
	filterObject : CMQF_AnyDataObject;
	index : Integer;
	msg : String;

begin

	app.myPassport.setMyTerminal(self.myTerminal);
	user := app.myPassport.myUser;
	
	//07 Dec 2015	NDL	Par 36777 - Can't print direct reports via this mechanism.
	// Was generating a rogue CM_QryReportSystem with no associataed menuid/name data
	if _reportName = DefRep_GhanaWaybillReport
	or _reportName.pos("?TXT", 1) &gt; 0
	or _reportName.pos("?DOT", 1) &gt; 0
	then
		msg := app.getErrorString2(Print_from_HH_failed, _reportName, method.qualifiedName);
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.createAlert(msg, true);
		return;
	endif;
	
	create filterObject transient;
	filterObject.initialize();
	filterObject.dataClass := CM_VehicleVisitRecord.name;
	filterObject.setMyDataObject( self );
	filterObject.addCollectionData( _selectedTisOnly );	//16 Dec 2013	NDL Par 33184

	foreach index in 1 to _copies do	
	
		app.myTrxCA.trxCreateAndRunAdhocBGPReport(	_reportName,
													app.getErrorString(Road_receipt),
													_printerPhysicalName,
													JadeReportWriterReport.PRINTER,
													BGP_ReportRequest.Print,
													filterObject,
													user.code,
													app.myPassport
													);
													
		if app.myPassport.hasErrors then
			msg := app.getErrorString2(Print_from_HH_failed, reportName, app.myPassport.getErrorsAsString);
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			app.createAlert(msg, true);
			return;
		endif;
												
	endforeach;
									

epilog

	delete filterObject;

end;
</source>
        <access>protected</access>
        <Parameter name="_printerPhysicalName" type="String"/>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_selectedTisOnly" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="printReceiptviaDefaultPrinter" id="0ed07919-e182-4efc-9415-09a8744ab041">
        <updating/>
        <source>printReceiptviaDefaultPrinter(	copies : Integer;
								pPrintPreview : Boolean;
								_terminal: CM_Terminal;
								reportName : String;
								_selectedTisOnly : CM_TISet;	//12 Dec 2013	NDL	Par 33184
								_jrwReport : JadeReportWriterReport input
								) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2006 By Andrew Bishop cnwab1
//
// Changed On	Changed By  Reason
// ----------	----------	--------------------------------------------------
//							PAR-17011 - change to check ViewName is valid
// 16 Mar 2010	consw1		PAR #22886 - Leaking report transients
// 24 Nov 2011	cnwdap1		PAR #28733 CCMS SFW 1261 Allow for text file report
// 31 Oct 2019	jlgdi1		TFS 46578 Added exclusion of cancelled Received TIs in the report
// 09 Dec 2019	jlgdi1		TFS 47932 Applied exclusion of cancelled received Tis in the collection '_selectedTisOnly'
// ---------------------------------------------------------------------------
constants
	Tracked_Item_View = 'CM_TrackedItemView';

vars
	defCopies : Integer;
	docType : Integer;
	jadeReport	: JadeReport;
	jrwTrans : CM_JRWGateReceipt;
	termDict : CM_TerminalByCodeDict;
	jrwManager : JadeReportWriterManager;
	transientRep : JadeReportWriterReport;
	jrwReport : JadeReportWriterReport;
	viewName : String;
	documentType : Integer;
	orientation : Integer;
	numCopies : Integer;
	topOfPage : Integer;
	bottomOfPage : Integer;
	leftMargin : Integer;
	rightMargin : Integer;
	borderWidth : Integer;
	duplex : Integer;
	collate : Boolean;
	ti, tiClone : CM_TrackedItem;
	tiClones : CM_TISet;
	
begin

	//testing
	if copies = null or copies = 0 then
		defCopies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
		if defCopies = 0 then
			app.raiseCMException(Pleas_check_gate_confi_reque_g, null, null);	// found during testing NDL 29 May 2013
			//app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		endif;
		return;	
	endif;
	
	docType := app.printer.getDefaultDocumentType();
	app.printer.abort();
	
	if pPrintPreview then
		create jadeReport transient;
		jadeReport.description := "Road Receipt";
		jadeReport.copies:=copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWGateReceipt).CM_JRWGateReceipt;

	create termDict transient;
	termDict.add(_terminal);
	
	jrwTrans.setAllTerminals(termDict);
	jrwTrans.myVehicleVisit := self;
	jrwTrans.vehicleVisitOid := self.getOidAsString();
	
	create  tiClones transient;
	
	if _selectedTisOnly &lt;&gt; null and not _selectedTisOnly.isEmpty then
		self.copyAllRcvTIsExceptCancelled(_selectedTisOnly, jrwTrans.allTrackedItems);
	else
	//  self.allReceivedTrackedItems.copy (jrwTrans.allTrackedItems);
		self.copyAllRcvTIsExceptCancelled(self.allReceivedTrackedItems, jrwTrans.allTrackedItems);
	//	self.allReleasedTrackedItems.copy (jrwTrans.allTrackedItems);
	//	11 Sep 2013 NDl found during testing smae cargo item coming and going... was causing a 1309
	//  30 May 2014 DJW Need to handle same cargo received and released ie chassis 34252
		foreach ti in self.allReleasedTrackedItems do
			if jrwTrans.allTrackedItems.includes(ti) then
				tiClone := ti.cloneSelf(true);
				tiClones.add(tiClone);
				jrwTrans.allTrackedItems.addNoDuplicates( tiClone, false );
			else			
				jrwTrans.allTrackedItems.addNoDuplicates( ti, false );
			endif;
		endforeach;
	endif;
	 
	if _jrwReport = null then
	
		if reportName = DefRep_GhanaWaybillReport then	//27 Aug 2015	NDL	Par 36777
			self.printGhanaWaybillReport( null, pPrintPreview );
			return;
		endif;
		
		if self.printToDotmatrix( reportName ) then	// 12 June 2013	NDL	Par 31562
			return;
		endif;
		
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(reportName);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Gate Road Receipt report class not specified in terminal config (" &amp; reportName &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;

	// PAR-17011 display an error message to inform clients that they should use a receipt based on 
	//           the CM_TrackedItemView to be able to print from both Road Exit and Vehicle Visit Enq screens.
	viewName := jrwReport.getReportingViewName();
	if viewName &lt;&gt; Tracked_Item_View then
		app.raiseCMException2(Repor_does_copy_recei_canno_pr, jrwReport.name, Tracked_Item_View,null, null);
		return;
	endif;

	jrwReport.setParameter('vehicleVisitOid', jrwTrans.vehicleVisitOid);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	//PAR25837 - cnwsh3 12/10/2010 Can't assume all road receipt report designs are going to be landscape so get it from the report itself.  May need to use others but haven't added them at this stage.
	jrwReport.getPageOptions(documentType, orientation,	numCopies, topOfPage, bottomOfPage, leftMargin,	rightMargin, borderWidth, collate, duplex);		
	
	//We have passed the documentType and number of copies so DON'T use the values from jrwReport.getPageOptions
	jrwReport.setPageOptions(docType, orientation, copies, 0, 0, 0, 20, 0, false, 0);
	if pPrintPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;

	jrwReport.run;

	if pPrintPreview then
		app.printPreview(jadeReport, true);
		jadeReport := null;
	endif;		
	
epilog
    if tiClones &lt;&gt; null then
		tiClones.purge;
		delete tiClones;
	endif;
	delete jadeReport;
	delete transientRep;
	delete jrwTrans;
	delete jrwManager;
	delete termDict;
//	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
        <Parameter name="copies" type="Integer"/>
        <Parameter name="pPrintPreview" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="reportName" type="String"/>
        <Parameter name="_selectedTisOnly" type="CM_TISet"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printRoadReceipt" id="8857e28b-fd9b-4a3f-9516-930a92b753c7">
        <updating/>
        <source>printRoadReceipt(	_reqCopies : Integer;
					_printPreview : Boolean;
					_printerPhysicalName : String	//Only use when trying to print via BGP		
					) updating;
/*

Purpose:			

Parameters:			Allows users to make use of multiple format reports based on the cargo on the truck.

Return Value:		

Date		Who		Reason
12 Dec 2013	cnwndl1	Initial creation	Par 33184
22 Jul 2016 cnwer1	TFS 2401 - should be printing by printer physical name not logical 
28 Sep 2023 jlier1 	TFS 59732
*/

vars

	defReportName : String;
	copies : Integer;
	localTIs : CM_TISet;
	ti : CM_TrackedItem;
	repFormatDict : CM_ReportFormatMatchCritDict;
	repMatchCrit : CM_RoadReceiptFormat;
	iterRep : Iterator;
	matchingTis : CM_TISet;
	iterTi : Iterator;
	
	tiClone : CM_TrackedItem;	//21 Apr 2015	NDL	Par 36013
	tiClones : CM_TISet;		//21 Apr 2015	NDL	Par 36013
	v : CM_VehicleVisitRecord;
begin

	defReportName := self.myTerminal.getRoadReceiptReport();
	copies := _reqCopies;
	if copies = 0 then
		copies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
		if copies &lt; 1 then
			copies := 1;
		endif;
	endif;
	
	if self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RoadReceiptReportInt ) = 0 then
	
		if _printerPhysicalName &lt;&gt; null then	// This is a BGP print request.
			self.printReceiptViaBGPforHandHelds( _printerPhysicalName, copies, defReportName, null );
			
		else
			// these guys only use one format for Road Receipt printing.
			self.printReceiptviaDefaultPrinter(	copies,	//copies : Integer;
												_printPreview,	//pPrintPreview : Boolean;
												self.myTerminal,	//_terminal: CM_Terminal;
												defReportName,	//reportName : String;
												null,	//_selectedTisOnly : CM_TISet;
												null	//_jrwReport : JadeReportWriterReport input
												);
								
		endif;
		
		return;
		
	else	

		// find all the Tis we are going to deal with ( the format(s)
		// that we will use are based on teh tis attributes )
		create localTIs transient;
		create  tiClones transient;	//21 Apr 2015	NDL	Par 36013
		
	//	self.allReceivedTrackedItems.copy (localTIs);
		self.copyAllRcvTIsExceptCancelled(self.allReceivedTrackedItems, localTIs);	//25 Jun 2020 NDL	TFS 49604
		
		foreach ti in self.allReleasedTrackedItems do
			//localTIs.addNoDuplicates( ti, false );
			//21 Apr 2015	NDL	Par 36013 - To allow for the same cargo  or chassis being received and released.
			if localTIs.includes(ti) then
				tiClone := ti.cloneSelf(true);
				tiClones.add(tiClone);
				localTIs.addNoDuplicates( tiClone, false );
			else			
				localTIs.addNoDuplicates( ti, false );
			endif;
		endforeach;
		
		if localTIs.isEmpty then
			//no tis to check, give them the Default Road Receipt Format.
			if _printerPhysicalName &lt;&gt; null then	// This is a BGP print request.
				self.printReceiptViaBGPforHandHelds( _printerPhysicalName, copies, defReportName, null );
				
			else
				self.printReceiptviaDefaultPrinter(	copies,	//copies : Integer;
													_printPreview,	//pPrintPreview : Boolean;
													self.myTerminal,	//_terminal: CM_Terminal;
													defReportName,	//reportName : String;
													null,	//_selectedTisOnly : CM_TISet;
													null	//_jrwReport : JadeReportWriterReport input
													);
			endif;
			
			return;
			
		else
			//got one or more tis, get the Road Receipt report formats in play for this terminal.
			create repFormatDict transient;
			self.myTerminal.getAlternateFormatsByContext( repFormatDict, CM_ReportFormatMatchCriteria.RoadReceiptReportInt );
			
			//rip thru the formats in order getting and create a subset of
			// the tis matching the selected format
			iterRep := repFormatDict.createIterator;
			while iterRep.next( repMatchCrit ) do
				create matchingTis transient;
				iterTi := localTIs.createIterator;
				while iterTi.next( ti ) do
					if repMatchCrit.matches(ti) then
						matchingTis.addNoDuplicates( ti, false );
					endif;
				endwhile;
				delete iterTi;
				
				if not matchingTis.isEmpty then
					//these tis should be processed against this format
					foreach ti in matchingTis do
						// remove the tis we are printing
						// cos we only want to include them in one printout
						localTIs.remove(ti);
					endforeach;
					
					if _printerPhysicalName &lt;&gt; null  then	// This is a BGP print request.
						self.printReceiptViaBGPforHandHelds( _printerPhysicalName, copies, repMatchCrit.reportName, matchingTis );
						
					else
						self.printReceiptviaDefaultPrinter(	copies,	//copies : Integer;
															_printPreview,	//pPrintPreview : Boolean;
															self.myTerminal,	//_terminal: CM_Terminal;
															repMatchCrit.reportName,	//reportName : String;
															matchingTis,	//_selectedTisOnly : CM_TISet;
															null	//_jrwReport : JadeReportWriterReport input
															);
					endif;
				endif;
				
				delete matchingTis;
				if localTIs.isEmpty then
					// none left to process
					return;
				endif;
			endwhile;
			
			//what ever tis are left go against the default format.
			if _printerPhysicalName &lt;&gt; null then	// This is a BGP print request.
				self.printReceiptViaBGPforHandHelds( _printerPhysicalName, copies, defReportName, localTIs );
					
			else
				self.printReceiptviaDefaultPrinter(	copies,	//copies : Integer;
													_printPreview,	//pPrintPreview : Boolean;
													self.myTerminal,	//_terminal: CM_Terminal;
													defReportName,	//reportName : String;
													localTIs,	//_selectedTisOnly : CM_TISet;
													null	//_jrwReport : JadeReportWriterReport input
													);
			endif;
			
		endif;
	
	endif;
	

epilog

	//21 Apr 2015	NDL	Par 36013
	if tiClones &lt;&gt; null then
		tiClones.purge;
		delete tiClones;
	endif;

	delete localTIs;
	delete repFormatDict;
	delete iterRep;
	delete matchingTis;
	delete iterTi;
	
end;</source>
        <Parameter name="_reqCopies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_printerPhysicalName" type="String"/>
    </JadeMethod>
    <JadeMethod name="printToDotmatrix" id="d97fc63f-93c2-4e6b-8d8c-cc46c3853375">
        <source>printToDotmatrix( reportName : String ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2013	cnwndl1	Initial creation	Par 31562

*/

vars

	gteEntity : CMGTE_Entity;
	ti : CM_TrackedItem;

begin

	// PAR #28722 allow for report to be directed to text file
	
	if reportName.pos("?TXT", 1) &gt; 0 then
		app.printReportViaTextFile(reportName);
		return true;
	//12 Nov 2012	NDL	Par 30682
	elseif reportName.pos("?DOT", 1) &gt; 0 then
		// 30/03/2013 cnwmh5 #31374
		if self.allReceivedTrackedItems.isEmpty and self.allReleasedTrackedItems.isEmpty then
			foreach gteEntity in self.allGateEntities do
				app.printReportDotMatrix(reportName,gteEntity,false);
			endforeach;
			
		else
			foreach ti in self.allReceivedTrackedItems do
				if ti.isContainer then
					app.printReportDotMatrix(reportName,ti.CM_Container,false);
				endif;
			endforeach;
			foreach ti in self.allReleasedTrackedItems do
				if ti.isContainer then
					app.printReportDotMatrix(reportName,ti.CM_Container,false);
				endif;
			endforeach;
			
		endif; 
		return true;
		
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="reportName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="proceedJob" id="e2108c24-a9f8-4644-8156-2f55f2a81b43">
        <source>proceedJob();
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aJob,fndJob : CM_Job;
begin
	fndJob := self.getMyJob();
	
	if fndJob &lt;&gt; null and fndJob.status = JOB_UNVERIFIED then
		fndJob.changeStatus(JOB_UNACTIONED);
		fndJob.causeEvent(self.myTerminal.getTerminalEvent(RoadJob_Update_Event), false, fndJob);
	else
		app.raiseCMException3(ERR_Job_StatusChange, " Unactioned", "Pre-check", ". Currently the job status for '" &amp; self.vehicle.regNumber &amp; "' is " &amp; fndJob.statusString &amp; ".", null, fndJob);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9738e806-d3b8-488f-a7bc-8f32ba19fd5a">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:     06 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
------------------------------------------------------------------------------*/
vars
	pxyVVR 		: CM_VehicleVisitRecord; 
	pxyVVRD,
	realVVRD	: CM_VehicleVisitRecordDetail;
	realGTE,
	pxyGTEINChassis,
	pxyGTE	: CMGTE_Entity;	
	completedOK		: Boolean;
begin

	pxyVVR := inheritMethod();
	
	if self.myInCMGTE_Chassis &lt;&gt; null then
		pxyGTEINChassis := self.myInCMGTE_Chassis.pxyCreateUpdateProxy();
		pxyGTEINChassis.setMyVVRifPxy(pxyVVR);			// add into pxyVVR.allDetails collection
	endif;

	if self.myOutCMGTE_Chassis &lt;&gt; null then
		pxyGTE := self.myOutCMGTE_Chassis.pxyCreateUpdateProxy();
		pxyGTE.setMyVVRifPxy(pxyVVR);			// add into pxyVVR.allDetails collection
	endif;
		
	foreach realGTE in self.allGateEntities do
		
		if realGTE = self.myInCMGTE_Chassis or realGTE = self.myOutCMGTE_Chassis then
			continue;
		endif;
		
		if realGTE.myParent &lt;&gt; null then
		/*	pxyGTE := realGTE.pxyGetProxyObject;
			if 	pxyGTE &lt;&gt; null then
				pxyGTE.setMyVVRifPxy(pxyVVR);
			endif;*/
		//	continue;
		endif;
		
		pxyGTE := realGTE.pxyCreateUpdateProxy();
		pxyGTE.setMyVVRifPxy(pxyVVR);			// add into pxyVVR.allDetails collection
	endforeach;
	
	foreach realVVRD in self.allVehicleVisitRecordDetails do
		pxyVVRD := realVVRD.pxyCreateUpdateProxy();
		pxyVVRD.setMyVehicleVisitRecord(pxyVVR);
	endforeach;
	
	pxyVVR.myTerminal := self.myTerminal;
	pxyVVR.myGateLaneController := self.myGateLaneController;
	pxyVVR.myGateIn := self.myGateIn;
	self.allVehicleBookingSlots.copyNoDuplicates(pxyVVR.allVehicleBookingSlots, false);	// ### TFS 54049 (55840) 22May2023 NAVPW1
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyVVR;	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVVR;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetInChassis" id="914b0627-d3db-4185-9ae1-420aa917cc85">
        <updating/>
        <source>pxyGetInChassis() : CMGTE_TILC updating;
/* ---------------------------------------------------------------------------
Created:     06 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	chassis : CMGTE_TILC;
begin

	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'method called for non-transient');
		return null;
	endif;

	if self.myInCMGTE_Chassis = null then
		create chassis transient;
		chassis.setIsChassisIn(true);
		chassis.setJobQueueNum(1);		// Slot 1 is reserved for IN chassis
 		chassis.setMyVVRifPxy(self);  	// sets pxyVVR.myInCMGTE_Chassis
		return chassis;
	else
		return self.myInCMGTE_Chassis;
	endif;
epilog

end;</source>
        <ReturnType type="CMGTE_TILC"/>
    </JadeMethod>
    <JadeMethod name="pxyGetInGenerator" id="bd41d883-b969-4c1d-a4e2-16d786d015a0">
        <updating/>
        <source>pxyGetInGenerator() : CMGTE_Generator updating;
/* ---------------------------------------------------------------------------
Created:     06 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	generator : CMGTE_Generator;
begin

	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'method called for non-transient');
		return null;
	endif;

	if self.myInCMGTE_Generator = null then
		create generator transient;
		self.myInCMGTE_Generator := generator;
		return generator;
	else
		return self.myInCMGTE_Generator;
	endif;
epilog

end;</source>
        <ReturnType type="CMGTE_Generator"/>
    </JadeMethod>
    <JadeMethod name="pxyGetOutChassis" id="aed2f3de-b000-454c-a224-e50cf882589f">
        <updating/>
        <source>pxyGetOutChassis() : CMGTE_Release updating;
/* ---------------------------------------------------------------------------
Created:     29 May 2009 by cnwjk3

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	chassis : CMGTE_Release;
begin


	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'method called for non-transient');
		return null;
	endif;

	if self.myOutCMGTE_Chassis = null then
		create chassis transient;
		
		chassis.setIsChassisOut(true);
 		chassis.setJobQueueNum(2);		// Slot 2 is reserved for OUT chassis
		chassis.setMyVVRifPxy(self);  	// sets pxyVVR.myOutCMGTE_Chassis to chassis
		
	else
		chassis:= self.myOutCMGTE_Chassis.CMGTE_Release;
	endif;

	chassis.setIsReleaseById(true);
	return chassis;
epilog

end;</source>
        <ReturnType type="CMGTE_Release"/>
    </JadeMethod>
    <JadeMethod name="reprintDriverDetails" id="26b47977-d7d7-475e-97c4-d94a92095f72">
        <updating/>
        <source>reprintDriverDetails(_copies : Integer; _printPreview : Boolean; _terminal: CM_Terminal; _reportName : String; _jrwReport : JadeReportWriterReport input; _printer : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2011	cnwdap1	Initial creation PAR #28733 CCMS SFW 1261
// 17/08/2016 cnwrh7	TFS	2899 Cargo Attribute Filter for Driver Instructions
// 18/04/2018 jlgrh7 		TFS 37870 PKT - Reprint Driver Details Report
*/
constants
	Vehicle_Visit_View = 'CM_VehicleVisitView';

vars
	termDict 				: CM_TerminalByCodeDict;
	jadeReport			: JadeReport;
	jrwManager		: JadeReportWriterManager;
	jrwTrans 				: CM_JRWVehicleVisit;
	transientRep 		: JadeReportWriterReport;
	printerName		: String;
	docType				: Integer;
	ti 							: CM_TrackedItem;
	repFormatDict : CM_ReportFormatMatchCritDict;			//TFS2899 starts
	iterRep 				: Iterator;
	repMatchCrit		: CM_RpDriverInstructionFormat;
	localTIs 				: CM_TISet;
	tiClone 					: CM_TrackedItem;
	tiClones 				: CM_TISet;	
	matchingTis		: CM_TISet;
	iterTi 					: Iterator;
begin
	
	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;		//Exception ?
	endif;
	
	app.printer.abort();
	
	//epr par 29185 - printerName can be null that just means it will print to the default printer
	printerName:=_printer;
	app.printer.setPrinter(printerName);

	docType := app.printer.getDefaultDocumentType();
	
	if _printPreview then
		create jadeReport transient;
		jadeReport.description := "Driver Details Reprint";
		jadeReport.copies:=_copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	

	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWVehicleVisit).CM_JRWVehicleVisit;

	create termDict transient;
	termDict.add(_terminal);
	
	jrwTrans.setAllTerminals(termDict);
	//jrwTrans.allVehicleVisitRecords.add(self);									//-TFS2899
	//jrwTrans.vehicleVisitOid := self.getOidAsString();
	
	// allow for report to be directed to a text file
	if _jrwReport = null then
			if self.myTerminal &lt;&gt; null then
				if self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RpDriverCriteriaInt ) = 0 then		//+TFS2899	No Alternate Report for Criterias
					jrwTrans.allVehicleVisitRecords.add(self);
					if self.reprintDriverDetailsViaTxtDot(_reportName) then
						return;
					else
						self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;
																						_printPreview,	//pPrintPreview : Boolean;
																						_terminal, 			//_terminal: CM_Terminal;
																						_reportName,
																						null, 						//CM_TISet
																						_jrwReport,		//JadeReportWriterReport
																						_printer				//String
																						);	
					endif;
				else																													//+TFS 2899 Some Alternateve Report Criterias
					create 	localTIs transient;
					create  tiClones transient;
					create matchingTis transient;
					
					self.allReceivedTrackedItems.copy (localTIs);			//get All Received tracked items
					foreach ti in self.allReleasedTrackedItems do			//get All Released tracked items and added them in without duplication
						if localTIs.includes(ti) then
							tiClone := ti.cloneSelf(true);
							tiClones.add(tiClone);
							localTIs.addNoDuplicates( tiClone, false );
						else			
							localTIs.addNoDuplicates( ti, false );				//All tracked items done
						endif;
					endforeach;			
					if localTIs.isEmpty then
						if self.reprintDriverDetailsViaTxtDot(_reportName) then			//No TrackedItems then do as normal
								return;
						else
								self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;
																						_printPreview,	//pPrintPreview : Boolean;
																						_terminal, 			//_terminal: CM_Terminal;
																						_reportName,
																						null, 						//CM_TISet
																						_jrwReport,		//JadeReportWriterReport
																						_printer				//String
																						);	
						endif;
					else
						create  repFormatDict transient;
						self.myTerminal.getAltRpDriverInstructFormats (repFormatDict, CM_ReportFormatMatchCriteria.RpDriverCriteriaInt);
						iterRep := repFormatDict.createIterator;
						while iterRep.next( repMatchCrit ) do
								matchingTis.clear();
								iterTi := localTIs.createIterator;
								while iterTi.next( ti ) do
									if repMatchCrit.matches(ti) then
										matchingTis.addNoDuplicates( ti, false );
										localTIs.remove(ti);
									endif;
								endwhile;
								delete iterTi;
								if not matchingTis.isEmpty then
									if self.myRoadJob &lt;&gt; null then																											//+TFS37870 we will use VVR first as some reports(in this TFS37870) using exposed reference of RoadJob
										self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;																					
																										_printPreview,	//pPrintPreview : Boolean;
																										_terminal, 			//_terminal: CM_Terminal;
																										repMatchCrit.reportName,  	//reportName : String; Default one
																										null,						
																										_jrwReport,		//JadeReportWriterReport
																										_printer				//String
																										);	
										else																																																		
											self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;																					
																										_printPreview,	//pPrintPreview : Boolean;
																										_terminal, 			//_terminal: CM_Terminal;
																										repMatchCrit.reportName,  	//reportName : String; Default one
																										matchingTis,						//CM_TISet
																										_jrwReport,		//JadeReportWriterReport
																										_printer				//String
																										);	
										endif;	
								 endif;
								if localTIs.isEmpty then
									return;									//none left to process
								endif;
						endwhile;
						//whatever tis are lfet go again the default format
						self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;
																						_printPreview,	//pPrintPreview : Boolean;
																						_terminal, 			//_terminal: CM_Terminal;
																						_reportName,  	//reportName : String; Default one
																						localTIs,						//CM_TISet
																						_jrwReport,		//JadeReportWriterReport
																						_printer				//String
																						);	
						endif;
				endif;	
			endif;
	else
				self.reprintDriversviaDefPrinter(_copies,				 //copies : Integer;
																				_printPreview,	//pPrintPreview : Boolean;
																				_terminal, 			//_terminal: CM_Terminal;
																				null,
																			    null, 						//CM_TISet
																				_jrwReport,		//JadeReportWriterReport
																				_printer				//String
																				);	
		endif;
		/*		//-TFS2899 moved codes to reprintDriversviaDefPrinter
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(_reportName);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Gate Road Receipt report class not specified in terminal config (" &amp; _reportName &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;
	*/
	// PAR-17011 display an error message to inform clients that they should use a receipt based on 
	//           the CM_TrackedItemView to be able to print from both Road Exit and Vehicle Visit Enq screens.
	//the following codes copied to reprintDriversviaDefPrinter
	/*viewName := jrwReport.getReportingViewName();
	if viewName &lt;&gt; Vehicle_Visit_View then
		app.raiseCMException2(Repor_does_copy_recei_canno_pr, jrwReport.name, Vehicle_Visit_View,null, null);
		return;
	endif;

	jrwReport.setParameter('vehicleVisitOid', self.getOidString);//jrwTrans.vehicleVisitOid);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	//PAR25837 - cnwsh3 12/10/2010 Can't assume all road receipt report designs are going to be landscape so get it from the report itself.  May need to use others but haven't added them at this stage.
	jrwReport.getPageOptions(documentType, orientation,	numCopies, topOfPage, bottomOfPage, leftMargin,	rightMargin, borderWidth, collate, duplex);		
	
	//We have passed the documentType and number of copies so DON'T use the values from jrwReport.getPageOptions
	jrwReport.setPageOptions(docType, orientation, _copies, 0, 0, 0, 20, 0, false, 0);
	if _printPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;
//	app.cmsBeginLoad(ls);
	jrwReport.run;

	if _printPreview then
		app.printPreviewModal(jadeReport); //epr par 32899 1/11/13
		jadeReport := null;
	endif;		
	*/
epilog
	delete jadeReport;
	delete transientRep;
	delete jrwManager;
	delete termDict;
	delete repFormatDict; 				//+TFS2899 starts
	delete iterRep;
	delete localTIs;
	if tiClones &lt;&gt; null then
		tiClones.purge;
		delete tiClones;
	endif;
	delete matchingTis;
	delete iterTi;
//	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport" usage="input"/>
        <Parameter name="_printer" type="String"/>
    </JadeMethod>
    <JadeMethod name="reprintDriverDetailsViaTxtDot" id="e2f7fd27-6f01-4f83-b59a-d9aebaf8434f">
        <source>reprintDriverDetailsViaTxtDot(_reportString : String) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwrh7	Initial creation tidy up TXT DOT Codes

*/

vars
	gteEntity 		: CMGTE_Entity;
	ti 						: CM_TrackedItem;
begin
		if _reportString.pos("?TXT", 1) &gt; 0 then
					app.printReportViaTextFile(_reportString);
					return true;
				//12 Nov 2012	NDL	Par 30682
		elseif _reportString.pos("?DOT", 1) &gt; 0 then
				if self.allReceivedTrackedItems.isEmpty and self.allReleasedTrackedItems.isEmpty then
					foreach gteEntity in self.allGateEntities do
						app.printReportDotMatrix(_reportString,gteEntity,false);
					endforeach;
				else
					foreach ti in self.allReceivedTrackedItems do
						if ti.isContainer then
							app.printReportDotMatrix(_reportString,ti.CM_Container,false);
						endif;
					endforeach;
					foreach ti in self.allReleasedTrackedItems do
						if ti.isContainer then
							app.printReportDotMatrix(_reportString,ti.CM_Container,false);
						endif;
					endforeach;
				endif;
				return true;
		endif;
		return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reportString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reprintDriversviaDefPrinter" id="7974948c-e46e-4550-b89d-daa9d569e7e9">
        <updating/>
        <source>reprintDriversviaDefPrinter(_copies : Integer; _printPreview : Boolean; _terminal: CM_Terminal;_reportString : String;
														_selectedTisOnly : CM_TISet; 
														_jrwReport : JadeReportWriterReport;_printer : String)
														updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwrh7	Initial creation TFS2899

*/
constants
	Vehicle_Visit_View = 'CM_VehicleVisitView';
vars
	jadeReport				: JadeReport;
	jrwTrans 					: CM_JRWVehicleVisit;
	transientRep 			: JadeReportWriterReport;
	termDict 					: CM_TerminalByCodeDict;
	jrwManager 			: JadeReportWriterManager;
	jrwReport				: JadeReportWriterReport;
	pxyVehicleVisRecord : CM_VehicleVisitRecord;
	vvR							: CM_VehicleVisitRecord;
	selectedTI				 : CM_TrackedItem;
	printerName 			: String;
	docType					: Integer;
	viewName				: String;
	documentType 	: Integer;
	orientation				: Integer;
	numCopies				: Integer;
	topOfPage : Integer;
	bottomOfPage : Integer;
	leftMargin : Integer;
	rightMargin : Integer;
	borderWidth : Integer;
	duplex : Integer;
	collate : Boolean;
begin
	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;		//Exception ?
	endif;
	
	app.printer.abort();
	
	//epr par 29185 - printerName can be null that just means it will print to the default printer
	printerName:=_printer;
	app.printer.setPrinter(printerName);

	docType := app.printer.getDefaultDocumentType();
	
	if _printPreview then
		create jadeReport transient;
		jadeReport.description := "Driver Details Reprint";
		jadeReport.copies:=_copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWVehicleVisit).CM_JRWVehicleVisit;
	create termDict transient;
	termDict.add(_terminal);
	jrwTrans.setAllTerminals(termDict);
	//above is normal process
	
	//if _selectedTisOnly =  null and  _selectedTisOnly.isEmpty then
	if _selectedTisOnly&lt;&gt;  null and not  _selectedTisOnly.isEmpty then
		beginLoad;
		pxyVehicleVisRecord := self.pxyCreateUpdateProxy();					//create a Proxy Vechicle Visit Record first to be used later;
		endLoad;
		foreach selectedTI in _selectedTisOnly do
			if self.allReceivedTrackedItems.includes (selectedTI) then
				pxyVehicleVisRecord.allReceivedTrackedItems.add(selectedTI);
			else
				pxyVehicleVisRecord.allReleasedTrackedItems.add(selectedTI);
				endif;
		endforeach;
		jrwTrans.allVehicleVisitRecords.add(pxyVehicleVisRecord);
	else
		jrwTrans.allVehicleVisitRecords.add(self);
	endif;
	if _jrwReport= null then
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(_reportString);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Gate Road Receipt report class not specified in terminal config (" &amp; _reportString &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;
	viewName := jrwReport.getReportingViewName();
	if viewName &lt;&gt; Vehicle_Visit_View then
		app.raiseCMException2(Repor_does_copy_recei_canno_pr, jrwReport.name, Vehicle_Visit_View,null, null);
		return;
	endif;

	jrwReport.setParameter('vehicleVisitOid', self.getOidString);//jrwTrans.vehicleVisitOid);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	//PAR25837 - cnwsh3 12/10/2010 Can't assume all road receipt report designs are going to be landscape so get it from the report itself.  May need to use others but haven't added them at this stage.
	jrwReport.getPageOptions(documentType, orientation,	numCopies, topOfPage, bottomOfPage, leftMargin,	rightMargin, borderWidth, collate, duplex);		
	
	//We have passed the documentType and number of copies so DON'T use the values from jrwReport.getPageOptions
	jrwReport.setPageOptions(docType, orientation, _copies, 0, 0, 0, 20, 0, false, 0);
	if _printPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;
//	app.cmsBeginLoad(ls);
	jrwReport.run;

	if _printPreview then
		app.printPreviewModal(jadeReport); //epr par 32899 1/11/13
		jadeReport := null;
	endif;		
	
epilog
	delete jrwManager;
	delete jrwTrans;
	delete termDict;
	delete pxyVehicleVisRecord;
end;</source>
        <access>protected</access>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reportString" type="String"/>
        <Parameter name="_selectedTisOnly" type="CM_TISet"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_printer" type="String"/>
    </JadeMethod>
    <JadeMethod name="secondaryCode" id="2ee40446-bfc0-41c1-85e7-0d0074735690">
        <methodInvocation>mapping</methodInvocation>
        <source>secondaryCode(set: Boolean; _value: String io) mapping;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 22/06/2017	cnwdap1		TFS 4912 Expose Additional Report Attributes
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);			// TFS 4912
		return;														// TFS 4912
	else
		// get code here
		if self.myDriverDetails &lt;&gt; null then						// TFS 4912
			_value := self.myDriverDetails.secondaryCode;			// TFS 4912
		endif;														// TFS 4912
	endif;

end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="set1StopBookingsFromProxy" id="64b861b0-de65-47c0-a9ab-5667d3d1d703">
        <updating/>
        <source>set1StopBookingsFromProxy(_pxyMe : CM_VehicleVisitRecord) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars
	pxyBooking, booking : CM_1StopExtVehicleBookingSlot;

begin
	self.all1StopExtVehicleBookings.purge;
	foreach pxyBooking in _pxyMe.all1StopExtVehicleBookings do
		create booking persistent;
		booking.persistFromProxy(pxyBooking, self);
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setAutoComplete" id="c156e339-fea7-440e-b8fd-8a66b882d285">
        <updating/>
        <source>setAutoComplete(_value : Boolean) updating;
/*
Date		Who		Reason
12 August 2009	cnwas3	Initial creation

*/
begin
	self.isRoadJobAutoComplete:=_value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBookingSlots" id="00dc7065-72f8-4a6b-b3e5-5cfb59278c35">
        <updating/>
        <source>setBookingSlots(_bookingSlots : CMIF_1StopBookingDataArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navam1	Initial creation
//TFS 53107, AjitM, navam1
*/

vars
	detail : CMIF_1StopBookingData;
	bookingSlot : CM_1StopExtVehicleBookingSlot;
begin
	if _bookingSlots = null then	
		return;
	endif;
	
	self.all1StopExtVehicleBookings.purge;
	foreach detail in _bookingSlots do
		create bookingSlot persistent;
		bookingSlot.setFromCMIFDetail(self.carrierCode, self.myTerminal, self, detail);
	endforeach;
epilog

end;</source>
        <Parameter name="_bookingSlots" type="CMIF_1StopBookingDataArray"/>
    </JadeMethod>
