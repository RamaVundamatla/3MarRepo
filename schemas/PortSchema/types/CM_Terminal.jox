Parameters:			

Return Value:		

Date		Who		Reason
12 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _rowName = ETRow_DefWeightTruck then
		return self.getConfig( DefWeightTruck ).Decimal;
	elseif _rowName = ETRow_DefWeightTrailer then
