    <JadeMethod name="btnDischargeComp_click" id="8e822da6-a891-481a-b619-736fc60a583b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDischargeComp_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwas3	Initial creation
27 July		2022	navkc1	ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.
*/

vars

begin
	self.getXMLSettingsForSave();		//	27/07/2022	navkc1	#53629	Save selected fields based on comparison mode
	self.comparisonMode := DISCHARGE_COMPARISON;
	self.availableXML := self.dischargeXML;		//	27/07/2022	navkc1	#53629	Reset the availableXML to dischargeXML
	//self.initTable(ETDef_LoadListComp);
	self.hideComparisonControls(true);
	if self.myCurrentVoyage &lt;&gt; null and not self.myCurrentVoyage.isAutomaticProcess() then						//navra1 - MTN-33038 - 14th Oct 2024
		self.initiateCompare(false);
	endif;																										//navra1 - MTN-33038 - 14th Oct 2024
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExportCSV_click" id="1b8a9052-63a1-4a30-9fd7-c7b92956ee6f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExportCSV_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwas3	Initial creation

*/
vars
	fileObj		: File;
	
begin
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, app.getErrorString(Table_data), self.tblData);
		return;
	endif;
	
	create fileObj transient;
	fileObj.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	
	self.tblData.cnEcExportToCSV(fileObj, true);
	
	
epilog
	delete fileObj;
end;</source>
