    <JadeMethod name="createDelay" id="4af0eb1f-ad74-4153-82d0-eada5cff8d53">
        <source>createDelay(_startTS : TimeStamp; _machine : CM_Machine) : CM_Delay;
/*

Purpose:			
	

Date		Who		Reason
19/02/2014	cnwma1	Initial creation

*/

vars
	delayProxy 		: CM_Delay;
	delay, realDelay 			: CM_Delay;
	voy 			: CM_Voyage;
	delayType 		: CM_DelayType;
	startDT, 
	estEndDT, 
	endDT		    : TimeStamp;
	kpiShift 		: CM_KPI ;
	time 			: Time;
	//machine			: CM_Machine;

begin

	self.deleteDelay(_startTS, _machine);

	delayType := app.myRoot.allDelayTypes.first;
	self.assertTrueMsg((delayType &lt;&gt; null), "No delay types are setup!");
	voy := self.opts.obj("Voyage").CM_Voyage;
	self.assertNotNull(voy);
	
	endDT := _startTS;
	///endDT.setTime(endDT.time + (5*60000));			// Plus 5 mintue
	endDT := endDT.addMinutes(5);
	estEndDT := endDT;

	create delayProxy transient;
	delayProxy.setProxy(voy.myTerminal,
					voy,
					delayType,
					_startTS,
					estEndDT,
					endDT,
					_machine,
					app.getMyUser(),
					null,
					"Test Create");
	app.myTrxCA.trxCreateDelay(delayProxy, realDelay, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach delay in _machine.allDelays do	
		if delay.startDT = _startTS then
			break;
		endif;
	endforeach;
	
	return delay;	
	
epilog
	
	delete delayProxy;

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Delay"/>
    </JadeMethod>
