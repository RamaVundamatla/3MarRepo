    <JadeMethod name="isATARequired" id="0ec0bed5-c350-4f79-9102-20811296b653">
        <source>isATARequired():Boolean;
/*

Purpose:			
		
		Only Arrival Date is required if the Vessel of this voyage has the "Create Harbour Details = true",Other than that you can create 
		voyage without arrival date.
		
Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2019 cnwma1	Bug 47337: JMT - Can't Prenote Cargo for Future Voyages in Web Portal
09 Apr 2021	NDL	TFS 50858 - removed double de-reference, to get small performance improvement 'getAllCurrentVoyages' call
*/

vars
	vessel : CM_Vessel;
begin
	
	vessel := self.getMyVessel;
	if vessel &lt;&gt; null then
		if vessel.hasHarbourDetails then
			return true;
		endif;
	endif;
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isActiveCargoExchange" id="0f056b3a-d7b3-4c5e-ae99-fd7c1cafd403">
        <source>isActiveCargoExchange() : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.allNotifiedTIsByCargoTypeId.isEmpty
	or not self.allOffsiteTIsByCargoTypeId.isEmpty
	or not self.allOnshipTIsByCargoTypeId.isEmpty 
	or not self.allOnsiteTIsByCargoTypeId.isEmpty
	or not self.allRRPTIsByCargoTypeId.isEmpty	//16 Mar 2020	NDL	TFS 47004
	or not self.allTbaTIsByCargoTypeId.isEmpty then
		return true;
	endif;
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		return self.myCellularVoyageStructure.hasVoyageWorkStarted();
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isActiveDisplay" id="a2c8472a-f952-4404-bc88-42eef4447701">
        <source>isActiveDisplay(_checkDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	21 February 2006 By: cnwgd1 
//--------------------------------------------------
vars
	tmpCheckDT : TimeStamp;
begin
	if self.isNullVoyage then
		return true;
	endif;

	// CCMS 1423 only display active voyages in combo boxes
	if self.displayOption = VoyageDisplayAlways then
		return true;
	elseif self.displayOption = VoyageDisplayNever then
		return false;
	elseif (not self.departedDT.isValid) then
		return true;
	endif;
	
	if _checkDT.isValid then
		tmpCheckDT := _checkDT;
	else
		tmpCheckDT := app.actualTimeServer();
		tmpCheckDT := tmpCheckDT.changeByXXHours(-24); //&lt;-- the default grace period in hours 

	endif;
	
	if self.isRetrospective() then
		// It's a non planned/non worked voyage with a retrospective date/time
		if self.status = Voyage_Status_Closed
		or self.status = Voyage_Status_Archived
		then
			// Retrospective Voyage is not active PAR 11010
			return false;
			
		elseif self.nonPlannedEffectiveDT &gt;= tmpCheckDT then
			// voyage departs after the grace period
			return true;
		else
			// voyage has departed
			return false;
		endif;
		
	elseif self.departedDT &gt;= tmpCheckDT then
	
		// voyage departs after the grace period
		return true;
	else
		// voyage has departed
		return false;
	endif;

	return false;
end;</source>
        <Parameter name="_checkDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isActiveRetrospective" id="6183e02f-cda0-480e-842f-7888a8af67fc">
        <source>isActiveRetrospective():Boolean;
//--------------------------------------------------
// Created:	15 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	// PAR 11010 
	if self.isRetrospective() then
		if self.status = Voyage_Status_Closed
		or self.status = Voyage_Status_Archived then
			// retrospective voyage is NOT active		
			return false;	
		else
			// retrospective voyage is still active
			return true;
		endif;	
	endif;
	
	// this is NOT a restropective voyage
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAutomaticProcess" id="ce0bfe4f-534a-45a8-9703-daa3ff053c25">
