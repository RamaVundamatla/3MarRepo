    <JadeMethod name="loadDefaultDateRanges" id="8da7711b-12b5-46f3-a094-db39138ebb9d">
        <updating/>
        <source>loadDefaultDateRanges() updating;

vars
  	currentDateTime:	TimeStamp;
begin
	currentDateTime := self.systemToLocalTime(app.actualTimeServer());	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support

 	// This method sets default values for the date range boxes
 	txtAfterDate.setDate(currentDateTime.date);
 	txtAfterTime.setTime(currentDateTime.Time);
 	txtBeforeDate.setDate(currentDateTime.date);
 	txtBeforeTime.setTime(currentDateTime.Time);

 	txtBtwDateA.setDate(currentDateTime.date);
 	txtBtwTimeA.setTime(currentDateTime.Time);
 	txtBtwDateB.setDate(currentDateTime.date);
 	txtBtwTimeB.setTime(currentDateTime.Time);

 	// Disable 'logged before' date range selection
 	gbxLogBefore.enabled:=false;
 	txtBeforeDate.enabled:=false;
 	txtBeforeTime.enabled:=false;

 	// Enable 'logged after' date range selection
 	gbxLogAfter.enabled:=true;
 	txtAfterDate.enabled:=true;
 	txtAfterTime.enabled:=true;

 	// Disable 'logged between' date range selection
 	gbxLogBetweenA.enabled:=false;
 	txtBtwDateA.enabled:=false;
 	txtBtwTimeA.enabled:=false;
 	gbxLogBetweenB.enabled:=false;
 	txtBtwDateB.enabled:=false;
 	txtBtwTimeB.enabled:=false;

 end;</source>
    </JadeMethod>
    <JadeMethod name="loadFilterListOptions" id="3b42178c-75de-4129-929a-7cb52c417b03">
        <updating/>
        <source>loadFilterListOptions() updating;

vars
	term : CM_Terminal;
	root : CM_Root;
	user:		CM_User;
	vessel:		CM_Vessel;
	transactionSubClassColl:	ClassColl;
	class:						Class;
	transaction:	HMS_Transaction;
begin
	lbxFiltersAvail.clear();
	lbxFiltersAvail.clearAllSelected();
 	// This method sets up the filter list options
 	lbxFiltersAvail.addItem("Selected Terminals");
 	lbxFiltersAvail.itemPicture[lbxFiltersAvail.newIndex]:=picFltUsers.picture;
 	// Add "Any Terminal" option
 	lbxFiltersAvail.addItem("Any");
 	lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=CM_Terminal;
	lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
	lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false; 
	
	if self.myHarbour &lt;&gt; null then
		foreach term in self.myHarbour.allTerminalsByCode do
	 		lbxFiltersAvail.addItem(term.name);
	 		lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=term;
			lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
			lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;		
		endforeach;
	endif;								

 	// Users
 	lbxFiltersAvail.addItem("Selected Users");
 	lbxFiltersAvail.itemPicture[lbxFiltersAvail.newIndex]:=picFltUsers.picture;
 	// Add "Any User" option
 	lbxFiltersAvail.addItem("Any");
 	lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=CM_User;
	lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
	lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;
	
	root := app.myRoot;
					
 	foreach user in root.allUsers do
 		lbxFiltersAvail.addItem(user.userName);
 		lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=user;
		lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
		lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;
 	endforeach;

	// Transaction Types
 	lbxFiltersAvail.addItem("Transaction Types");
 	lbxFiltersAvail.itemPicture[lbxFiltersAvail.newIndex]:=picFltChgType.picture;
 	// Add "Any Type" option
 	lbxFiltersAvail.addItem("Any");
 	lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=HMS_Transaction;
	lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
	lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;	


	create transactionSubClassColl transient;
	HMS_Transaction.getSubclasses(transactionSubClassColl);
	foreach class in transactionSubClassColl do
		create transaction as class transient;
		lbxFiltersAvail.addItem(transaction.typeString);
 		lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=transaction;
		lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
		lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;
 		lbxFiltersAvail.itemData[lbxFiltersAvail.newIndex]:=transaction.type;
		delete transaction;				
	endforeach;

	// Transaction Types
 	lbxFiltersAvail.addItem("Ships");
 	lbxFiltersAvail.itemPicture[lbxFiltersAvail.newIndex]:=picFltVoyage.picture;
 	// Add "Any Type" option
 	lbxFiltersAvail.addItem("Any");
 	lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=CM_Vessel;
	lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
	lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;	

	foreach vessel in root.allVessels do
		if vessel.myHMSVesselData = null then
			continue;
		endif;
 		lbxFiltersAvail.addItem(vessel.name);
 		lbxFiltersAvail.itemObject[lbxFiltersAvail.newIndex]:=vessel;
		lbxFiltersAvail.itemLevel[lbxFiltersAvail.newIndex]:=2;
		lbxFiltersAvail.itemExpanded[lbxFiltersAvail.newIndex]:=false;
 	endforeach;

	// Initialise filter list
 	initialiseFilterList;

epilog
	delete transactionSubClassColl;	
end;</source>
    </JadeMethod>
