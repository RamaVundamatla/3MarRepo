<Class name="JadeScript">
    <JadeMethod name="findAllQuotes" id="53696aec-d7a6-4808-b807-cad79337924c">
        <source>findAllQuotes();
//-----------------------------------------------------------
//
// Created by cnwsh3
//
// Date: 30 March 2006
//
// Finds any quotes characters (" or ') in method source to see if we would like to change the strings in 
// the quotes to translatables.
//
// ----------------------------------------------------------

vars

	methColl 			: 	MethodNDict;
	classColl 			: 	ClassColl;
	schColl 			: 	SchemaColl;
	schem 				: 	Schema;
	meth 				: 	Method;
	objClass 			: 	Class;
	hasQuotes 			: 	Boolean;
	quotePosition 		: 	Integer;
	sourceText,
	currentSchemaName,
	className 			: 	String;
	file   				: 	File;
	found,
	knownString			:	Boolean;
begin
	
	//Create a file to put results in.
	create file transient;
	file.allowCreate := true;
	file.fileName := 'C:/temp/QuoteCheck.txt';
	//file.kind := File.Kind_Unknown_Text;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	//file.mode := File.Mode_IO;
	file.mode := File.Mode_Output;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	file.open;
	
	//Get all subschemas and put them in a collection along with the current schema
	create schColl transient;
	currentSchema.withAllSubschemas(schColl);
	
	//Look through each schema for non system classes.
	foreach schem in schColl do
	
		currentSchemaName := schem.getName();
		//Put non system classes in a collection.
		classColl := schem.getAllClasses(false);
		
		//Get all non systm methods for each class.
		foreach objClass in classColl do
		
			create methColl transient;
			objClass.getMethods(methColl);
			
			//Check each method for source.
			foreach meth in methColl do

				//reset start position for token search.
				quotePosition := 1;
				knownString := false;
				found := false;
				if meth.getSchema.getName() = currentSchemaName then
					if meth.getName = 'btnSave_click' then	
						app.writeStatement('Mehtod');
					endif;
					sourceText := meth.getSource();
					//if there is a quote in the method, write it out to file
					quotePosition := sourceText.pos('"', quotePosition);
					if quotePosition &lt;&gt; 0 then
						if not sourceText[quotePosition + 1 : 3 ] = '1.0' then
							found := true;
						endif;
						
					endif;
													
					//Check for the other type of quote
					quotePosition := 1;
					quotePosition := sourceText.pos("'", quotePosition);
					
					if quotePosition &lt;&gt; 0 then
						if not sourceText[quotePosition + 1 : 5 ] = '&lt;?xml' then
							found := true;
						endif;
						
					endif;
						
					if found then
						//There must be a quote in there somewhere so log it.
						className := objClass.getName();
						file.writeLine(currentSchemaName &amp; " &gt;&gt; " &amp; className &amp; "::" &amp; meth.getName());
					endif;
				endif;
			endforeach;
		endforeach;
		
	endforeach;
/*		if _startPosition = 0 then
		return false;
	endif;
	
	//Check if the char is a ' or a " 
	if self[_startPosition] = "'" then
		if 	self[_startPosition + 1 : 5 ] = '&lt;?xml' then
			return true;
		endif;
		
	elseif self[_startPosition] = '"' then
		if self[_startPosition + 1 : 3 ] = '1.0' then
			return true;
		endif;
	endif;
	
	return false;
*/

epilog
	delete schColl;
	delete methColl;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="findDateCasts" id="a19df3aa-93e3-4c9e-8fb3-e59085386639">
        <source>findDateCasts();
//-----------------------------------------------------------
//
// Created by cnwsh3
//
// Date: 30 March 2006
//
// Finds any quotes characters (" or ') in method source to see if we would like to change the strings in 
// the quotes to translatables.
//
// ----------------------------------------------------------

vars

	methColl 			: 	MethodNDict;
	classColl 			: 	ClassColl;
	schColl 			: 	SchemaColl;
	schem 				: 	Schema;
	meth 				: 	Method;
	objClass 			: 	Class;
	hasQuotes 			: 	Boolean;
	sourcePosition 		: 	Integer;
	sourceText,
	currentSchemaName,
	className 			: 	String;
	file   				: 	File;
	found,
	knownString			:	Boolean;
begin
	
	//Create a file to put results in.
	create file transient;
	file.allowCreate := true;
	file.fileName := 'C:/temp/' &amp; currentSchema.name &amp; '-DateCheck.txt';
	//file.kind := File.Kind_Unknown_Text;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	//file.mode := File.Mode_IO;
	file.mode := File.Mode_Output;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	file.open;
	
	//Get all subschemas and put them in a collection along with the current schema
	create schColl transient;
	currentSchema.withAllSubschemas(schColl);
	
	//Look through each schema for non system classes.
	foreach schem in schColl do
	
		currentSchemaName := schem.getName();
		//Put non system classes in a collection.
		classColl := schem.getAllClasses(false);
		
		//Get all non systm methods for each class.
		foreach objClass in classColl do
		
			create methColl transient;
			objClass.getMethods(methColl);
			
			//Check each method for source.
			foreach meth in methColl do

				//reset start position for token search.
				sourcePosition := 1;
				knownString := false;
				found := false;
				if meth.getSchema.getName() = currentSchemaName then
					if meth.getName = 'btnSave_click' then	
						app.writeStatement('Method');
					endif;
					sourceText := meth.getSource();
					//if there is a quote in the method, write it out to file
					sourcePosition := sourceText.pos('.Date', sourcePosition);
					if sourcePosition &lt;&gt; 0 then
							found := true;
					endif;
						
					if found then
						//There must be a quote in there somewhere so log it.
						className := objClass.getName();
						file.writeLine(currentSchemaName &amp; " &gt;&gt; " &amp; className &amp; "::" &amp; meth.getName());
					endif;
				endif;
			endforeach;
		endforeach;
		
	endforeach;

epilog
	delete schColl;
	delete methColl;
	delete file;
end;</source>
    </JadeMethod>
</Class>
