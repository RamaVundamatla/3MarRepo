    <JadeMethod name="validateForUpdate" id="54f3cacf-7de2-4da3-ba7f-620569d7b393">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2023 navtnr20	TFS CR 58207	Task 58210: Jade - TRX CM_OwnershipChangeDetail
07 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	reserveDetail : CM_ReserveDetail; //07/08/2023 navmv20 CR 59440 Task 59441
	reserveDetailSet : CM_ReserveDetailSet; //07/08/2023 navmv20 CR 59440 Task 59441
	myTI            : CM_TrackedItem; //07/08/2023 navmv20 CR 59440 Task 59441
begin
	ti := self.myTrackedItem;
	myTI := ti;
	if ti.isCargoGroupItem then
		ti := self.myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
	endif;
	
	if self.transferredQuantity = 0 and self.transferredWeight = 0 and self.transferredVolume = 0 then
		app.raiseCMException(TransferredQuantityweightvolum, null, self);
	endif;
	
	//07/08/2023 navmv20 CR 59440 Task 59441 - start
	if myTI.isCargoGroupItem then
		reserveDetailSet := myTI.CM_CargoGroup.allReserveDetailAssigned;
	else
		reserveDetailSet := myTI.allReserveDetails;
	endif;
	//07/08/2023 navmv20 CR 59440 Task 59441 - end
	
	if ct &lt;&gt; null then // if the cargo group is empty we cannot validate this.
	/* 07/08/2023 navmv20 CR 59440 Task 59441 - start refactored
		if ct.isBulk then

			if ct.isBulkByVolume() then
				if self.transferredVolume &lt;= 0
				or self.transferredVolume &gt; self.myTrackedItem.totalVolume then
					app.raiseCMException3(Trans_shoul_great_then_track_v,self.transferredVolume.String,self.myTrackedItem.id,self.myTrackedItem.totalVolume.String ,null,null);
				endif;
			else
				if self.transferredWeight	 &lt;= 0 
				or self.transferredWeight &gt; self.myTrackedItem.totalWeight then
					app.raiseCMException3(Trans_shoul_great_then_track_w, self.transferredWeight.String,self.myTrackedItem.id, self.myTrackedItem.totalWeight.String ,null,null);
				endif;
			endif;
		else
			if self.transferredQuantity &lt;= 0
			or self.transferredQuantity &gt; self.myTrackedItem.totalQuantity then
				app.raiseCMException3(Trans_shoul_great_then_track_q, self.transferredQuantity.String,self.myTrackedItem.id,self.myTrackedItem.totalQuantity.String ,null,null);
			endif;
		endif;
	*/
	
	
		self.validateTITotals(ct);
		self.validateReservedAmounts(ct,reserveDetailSet);
	endif;
	
	self.validateCOOEffectiveDate(); //08/12/2023	navkc1 ChangeRequest 58261 Task 58260
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReservedAmounts" id="aa2bc839-6bb9-40e2-91cc-8dcc1297c9f7">
        <source>validateReservedAmounts(_ct:CM_CargoType; _reserveDetailSet:CM_ReserveDetailSet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed

*/

vars
	totalVolume,
	totalWeight,
	reservedWeight,
	reserveVolume,
	otherTransferedWt,
	otherTransferedVol : Decimal[14,4];
	totalQuantity,
	totalRequested,
	otherTransferedQty : Integer;
	reserveDetail : CM_ReserveDetail;
	measurementType : String;
	myTI            : CM_TrackedItem;
	idStr,
	reserveHeaderCode ,
	reservedStr,
	ownershipChangeStr : String;
	transferredWtStr,
	transferredVolStr : String; //13/09/2023 navmv20 Bug 60217

begin
	if _reserveDetailSet.isNotEmpty() then
		reserveDetail := _reserveDetailSet.first;
		reserveHeaderCode := reserveDetail.myReserveHeader.code;
	endif;
	
	myTI :=self.myTrackedItem;
	if _ct.isBulk then
			if _ct.isBulkByVolume() then
				reserveVolume := myTI.getReservedVolume(null);
				otherTransferedVol := myTI.getOwnershipChangeVolume(self.getOwnershipChangeHeader()); // ### TFS BUG 60193 01SEP2023 NAVAB1
				
				totalVolume := myTI.totalVolume; //21/05/2024	navkc1 Bug 64182
				idStr := myTI.id; //21/05/2024	navkc1 Bug 64182
				
				//if (reserveVolume &gt; 0 or otherTransferedVol &gt; 0) and self.transferredVolume + reserveVolume + otherTransferedVol  &gt; myTI.totalVolume then
				if (reserveVolume &gt; 0 or otherTransferedVol &gt; 0) and self.transferredVolume + reserveVolume + otherTransferedVol  &gt; totalVolume then //21/05/2024	navkc1 Bug 64182
					if reserveVolume &lt;&gt; null then
						reservedStr := _ct.getConvertedVolumeDisplay(reserveVolume, true); //13/09/2023 navmv20 Bug 60217
					endif;
					if otherTransferedVol &lt;&gt; null then
						ownershipChangeStr := _ct.getConvertedVolumeDisplay(otherTransferedVol, true); //13/09/2023 navmv20 Bug 60217
					endif;
					//13/09/2023 navmv20 Bug 60217 - start
					transferredVolStr := _ct.getConvertedVolumeDisplay(self.transferredVolume, true);
					//self.raiseExceptionForReserved(myTI.id,reservedStr,ownershipChangeStr,transferredVolStr);
					self.raiseExceptionForReserved(idStr,reservedStr,ownershipChangeStr,transferredVolStr); //21/05/2024	navkc1 Bug 64182
					//13/09/2023 navmv20 Bug 60217 - end
				endif;
			else
				reservedWeight :=myTI.getReservedWeight(null);
				otherTransferedWt := myTI.getOwnershipChangeWeight(self.getOwnershipChangeHeader()); // ### TFS BUG 60193 01SEP2023 NAVAB1
				
				totalWeight := myTI.totalWeight; //21/05/2024	navkc1 Bug 64182
				idStr := myTI.id; //21/05/2024	navkc1 Bug 64182
				
				//if (reservedWeight &gt; 0 or otherTransferedWt &gt; 0) and self.transferredWeight + reservedWeight + otherTransferedWt &gt; myTI.totalWeight then
				if (reservedWeight &gt; 0 or otherTransferedWt &gt; 0) and self.transferredWeight + reservedWeight + otherTransferedWt &gt; totalWeight then //21/05/2024	navkc1 Bug 64182
					if reservedWeight &lt;&gt; null then
						reservedStr := _ct.getConvertedWeightDisplay(reservedWeight,true); //13/09/2023 navmv20 Bug 60217
					endif;
					if otherTransferedWt &lt;&gt; null then
						ownershipChangeStr := _ct.getConvertedWeightDisplay(otherTransferedWt, true); //13/09/2023 navmv20 Bug 60217
					endif;
					//13/09/2023 navmv20 Bug 60217 - start
					transferredWtStr := _ct.getConvertedWeightDisplay(self.transferredWeight, true);
					//self.raiseExceptionForReserved(myTI.id,reservedStr ,ownershipChangeStr,transferredWtStr);
					self.raiseExceptionForReserved(idStr,reservedStr ,ownershipChangeStr,transferredWtStr); //21/05/2024	navkc1 Bug 64182
					//13/09/2023 navmv20 Bug 60217 - end
				endif;
			endif;
	else
		totalRequested := myTI.getReserveQuantity(null);
		otherTransferedQty := myTI.getOwnershipChangeQuantity(self.getOwnershipChangeHeader()); // ### TFS BUG 60193 01SEP2023 NAVAB1
		
		totalQuantity := myTI.totalQuantity; //21/05/2024	navkc1 Bug 64182
		idStr := myTI.id; //21/05/2024	navkc1 Bug 64182
		
		//if (totalRequested &gt; 0 or otherTransferedQty &gt; 0) and self.transferredQuantity + totalRequested + otherTransferedQty &gt; myTI.totalQuantity then
		if (totalRequested &gt; 0 or otherTransferedQty &gt; 0) and self.transferredQuantity + totalRequested + otherTransferedQty &gt; totalQuantity then //21/05/2024	navkc1 Bug 64182
			if totalRequested &lt;&gt; null then	
				reservedStr := totalRequested.String &amp; " " &amp; app.getErrorString(Items);
			endif;
			if otherTransferedQty &lt;&gt; null then
				ownershipChangeStr := otherTransferedQty.String &amp; " " &amp;  app.getErrorString(Items);
			endif;
			//self.raiseExceptionForReserved(myTI.id,reservedStr ,ownershipChangeStr,self.transferredQuantity.String &amp; " " &amp; app.getErrorString(Items));
			self.raiseExceptionForReserved(idStr,reservedStr ,ownershipChangeStr,self.transferredQuantity.String &amp; " " &amp; app.getErrorString(Items)); //21/05/2024	navkc1 Bug 64182
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ct" type="CM_CargoType"/>
        <Parameter name="_reserveDetailSet" type="CM_ReserveDetailSet"/>
    </JadeMethod>
    <JadeMethod name="validateTITotals" id="4a3912a3-b6f3-4105-a391-61eda71a3a65">
        <source>validateTITotals(_ct:CM_CargoType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars

begin
	if _ct.isBulk then
		if _ct.isBulkByVolume() then
			if self.transferredVolume &lt;= 0
			or self.transferredVolume &gt; self.myTrackedItem.totalVolume then
				app.raiseCMException3(Trans_shoul_great_then_track_v,self.transferredVolume.String ,self.myTrackedItem.id,self.myTrackedItem.totalVolume.String ,null,null);
			endif;
		else
			if self.transferredWeight	 &lt;= 0 
			or self.transferredWeight &gt; self.myTrackedItem.totalWeight then
				app.raiseCMException3(Trans_shoul_great_then_track_w, self.transferredWeight.String,self.myTrackedItem.id, self.myTrackedItem.totalWeight.String ,null,null);
			endif;
		endif;
	else
		if self.transferredQuantity &lt;= 0
		or self.transferredQuantity &gt; self.myTrackedItem.totalQuantity then
			app.raiseCMException3(Trans_shoul_great_then_track_q, self.transferredQuantity.String,self.myTrackedItem.id,self.myTrackedItem.totalQuantity.String ,null,null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ct" type="CM_CargoType"/>
    </JadeMethod>
</Class>
