    <JadeMethod name="initDataTbl" id="50a753c2-4eb6-41d6-8d42-729c4f643a7a">
        <updating/>
        <source>initDataTbl(_tbl : CM_DataTable input; _entTableDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars


begin
	if _tbl = null then
		return;
	endif;
	
	if _entTableDef &lt;&gt; null then
		_tbl.setTblDataEntRowsFromDef(_entTableDef);
	endif;
	
	_tbl.selectionType := _tbl.SelectionType_Row;
end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initEntryTbl" id="b45e0634-0676-4703-9364-2cb637289c9e">
        <updating/>
        <source>initEntryTbl(_tbl : CM_EntryTable input; _entTableDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _tbl = null then
		return;
	endif;
	
	_tbl.changeMode := _tbl.ChangeMode_FirstOnly;
	_tbl.setEntTableDef(_entTableDef, null, null);
	_tbl.adjustHeight(300);
	
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
