    <JadeMethod name="getCommodityDesc" id="3a297ccf-ed91-4e91-b104-6e12664cf10f">
        <source>getCommodityDesc(): String;
//--------------------------------------------------
// Created:	27 March 2006 By: cnwgd1
// 02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
//--------------------------------------------------
vars
	desc 	: String;
	product : CM_Product;
begin
	
	product := self.myProduct;					//02.04.2024 navma1 #63302
	
	if product &lt;&gt; null then						//02.04.2024 navma1 #63302
		return product.description;
	endif;
	
	if self.description &lt;&gt; null then
		desc := self.description;
	else
		desc := inheritMethod();
	endif;

	return desc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodityDescJRW" id="30a23f72-7c17-4a17-b9fe-f0608b155f02">
        <source>getCommodityDescJRW(): String;
// 	TFS 2213 24/06/2016 copy of getCommodityDesc for which the CM_BreakBulkGeneric reimplementation uses the commodity and then the cargo subtype
//	so that the commodity is reported when present
vars
	desc : String;
begin
	// this gets the commodity description if present
	desc := inheritMethod();
	if desc = null then
		if self.myProduct &lt;&gt; null then
			desc := self.myProduct.description;
		elseif self.description &lt;&gt; null then
			desc := self.description;
		endif;
	endif;

	return desc;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedDensityIn" id="01d78c04-d022-41a3-b4e3-e2912090d7e1">
        <source>getConvertedDensityIn(_shortName: String): String;
//
// Purpose:				For JRW reports - Get density from cargo subtype and convert to the supplied unit type
//
// Parameters:			_units - the measurement units to convert to for display
//
// Return Value:		the cargo subtype density converted to the supplied units
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321
//
vars
	measureType	: CM_MeasurementType;
	value		: String;

begin
	value := self.getDensityStr;
	measureType := app.myRoot.allMeasurementTypesByShortName[_shortName];
	if measureType = null or measureType.measurementType &lt;&gt; Type_Density then
		return app.getErrorString(Invalid);
	endif;
	
	return app.convertMeasurementForDisplay(measureType.shortName, value.Decimal);
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedHeightIn" id="b569c829-f97d-464a-beca-5b9325046d6f">
        <source>getConvertedHeightIn(_shortName: String): String;
//
// Purpose:				For JRW reports - Get height from cargo subtype and convert to the supplied unit type
//
// Parameters:			_units - the measurement units to convert to for display
//
// Return Value:		the cargo subtype height converted to the supplied units
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321
//
vars
	measureType	: CM_MeasurementType;
	value		: String;

begin
	value := self.getHeightStr;
	measureType := app.myRoot.allMeasurementTypesByShortName[_shortName];
	if measureType = null or not measureType.isLinear() then
		return app.getErrorString(Invalid);
	endif;
	
	return app.convertMeasurementForDisplay(measureType.shortName, value.Decimal);
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
