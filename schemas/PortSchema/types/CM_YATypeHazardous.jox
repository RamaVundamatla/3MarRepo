    <JadeMethod name="getObjects" id="f2c85abb-9f71-47c6-8a57-6fe48264bee7">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	hazard: CM_HazardClass;
begin
	foreach hazard in app.myRoot.allHazardClasses do
		objects[hazard.getYAIdentifier] := hazard;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
