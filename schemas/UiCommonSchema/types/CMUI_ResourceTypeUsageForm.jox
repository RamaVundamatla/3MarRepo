    <JadeMethod name="doBtnAdd" id="4bee89c9-87aa-4f14-84d4-d1651d820f68">
        <updating/>
        <source>doBtnAdd() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	unsavedChanges : Boolean;
begin
	//18 Mar 2010	NDL	Par 22725
	self.checkForUnsavedTransientChgs( unsavedChanges );
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist2), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	clearGrpResource();
	grpResource.enabled := true;
	cmbResourceType.setFocus();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCancel" id="57086967-e58e-4f24-a33b-ff6ec990eb70">
        <updating/>
        <source>doBtnCancel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	proxyResourceUsage : CM_ResourceTypeUsage;
	realResourceUsage : CM_ResourceTypeUsage;
	unsavedChanges : Boolean;
	
begin
	
	//18 Mar 2010	NDL	Par 22725
	self.checkForUnsavedTransientChgs( unsavedChanges );
	
	if not unsavedChanges then
		//transients that have been added. (I.e. new ones)
		unsavedChanges := not self.allUpdProxyResourceTypeUsages.isEmpty;
	endif;
	
	if not unsavedChanges then
		if self.myTransaction &lt;&gt; null 
		or self.myToDoTransaction &lt;&gt; null then  // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
			// an existing transaction, check if any of the existing resource usages which we built proxies for when we 
			// set up the form, have been changed
			foreach proxyResourceUsage in self.allProxyResourceTypeUsages do
				realResourceUsage := proxyResourceUsage.pxyGetRealObject;
				if realResourceUsage = null then
					// should never happen as these were all created from real ones.
					continue;
				endif;
				if realResourceUsage.differsFrom(proxyResourceUsage) then
					//difference between the persistant and its proxy.
					unsavedChanges := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if unsavedChanges then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	self.modalResult := IDCANCEL;	//// 09 Mar 2010	NDL	Par 22820

	self.unloadForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDelete" id="eac05a34-6f46-4cfb-9832-acfaae449640">
        <updating/>
        <source>doBtnDelete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	proxyUsage : CM_ResourceTypeUsage;
	realUsage : CM_ResourceTypeUsage;
	
begin

	if self.tblResources.row &gt; self.tblResources.fixedRows and self.tblResources.row &lt;= self.tblResources.rows then
		proxyUsage := self.tblResources.accessRow(self.tblResources.row).itemObject.CM_ResourceTypeUsage;
	endif;
	
	if proxyUsage = null then
		return;
	endif;
	
	realUsage := proxyUsage.pxyGetRealObject();
	if realUsage &lt;&gt; null then
		// should never get here...
		// not allowed to delete a real usage once created, it can only be voided.
		return;
	//	self.allRealResourceTypeUsagesToDel.add(realUsage);
	//	self.allProxyResourceTypeUsages.remove(proxyUsage);
	else
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, app.getErrorString( Resource_usage ) ), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.allNewProxyResourceTypeUsages.remove(proxyUsage);
		endif;
	endif;
	
	delete proxyUsage;
	
	self.clearGrpResource();
	self.loadTableData();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSave" id="9e6fc754-c8b2-4998-b75d-ca36604f4f9b">
        <updating/>
        <source>doBtnSave() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
*/

vars

	proxyResourceUsage : CM_ResourceTypeUsage;
	realResourceUsage  : CM_ResourceTypeUsage;
	unsavedChanges     : Boolean;
	type			   : CM_ResourceType;
	
begin

	//18 Mar 2010	NDL	Par 22725
	self.checkForUnsavedTransientChgs( unsavedChanges );
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	if self.myTransaction &lt;&gt; null 
	or self.myToDoTransaction &lt;&gt; null then  // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
		foreach proxyResourceUsage in self.allProxyResourceTypeUsages do
			realResourceUsage := proxyResourceUsage.pxyGetRealObject;
			if realResourceUsage = null then
				// should never happen as these were all created from real ones.
				continue;
			endif;
			if realResourceUsage.differsFrom(proxyResourceUsage) then
				//something has changed on this one.  Put him in the updated collection.
				self.allUpdProxyResourceTypeUsages.add(proxyResourceUsage);
				self.allProxyResourceTypeUsages.remove(proxyResourceUsage);
			endif;
		endforeach;
	endif;	
	
	self.modalResult := IDOK;

	self.unloadForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdate" id="7dbdc7aa-48d8-4363-9ef7-cb977814c461">
        <updating/>
        <source>doBtnUpdate() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
08 Mar 2019 cnwma1	Ticket 43624: ADP - TO Resource Quantity gets truncated.
19 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/

vars

	proxy 		  	: CM_ResourceTypeUsage;
	realUsage 	  	: CM_ResourceTypeUsage;
	lResourceType 	: CM_ResourceType;
	lNoCharge 	  	: Boolean;
	lQuantity 	  	: Decimal [23,4];
	lRemarks 	  	: String;
	lStatus 	  	: Integer;
	lFromDateTime,
	lToDateTime	  	: TimeStamp;
	result		  	: Integer;
	palletType    	: CM_PalletType;
	isHeatTreated   : Boolean;
	isStoreOnPallet : Boolean;
	trn : CM_Transaction;
	autoApplyResourceType 	: CM_ResourceType;
	proxyAutoApply 		  	: CM_ResourceTypeUsage;
	resourceUsageSet        : CM_ResourceTypeUsageSet;
begin
	 // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
	trn := self.myTransaction;
	if trn = null then
		trn := self.myToDoTransaction;
	endif;
	
	// populate local variables with the data.
	lResourceType := self.cmbResourceType.listObject.CM_ResourceType;
	//lQuantity := txtUnits.text.Decimal;
	lQuantity := txtUnits.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	lNoCharge := self.chkNoCharge.value;
	lRemarks := self.txtRemarks.text;
	if not self.chkVoid.value then
		lStatus := CM_InvoiceLine.STATUS_NORMAL;
	else
		lStatus := CM_InvoiceLine.STATUS_VOIDED;
	endif;
	
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	lFromDateTime.setDate(self.txtFromDate.text.asDateJMT);
	lFromDateTime.setTime(self.txtFromTime.text.asTimeJMT);
	lToDateTime.setDate(self.txtToDate.text.asDateJMT);
	lToDateTime.setTime(self.txtToTime.text.asTimeJMT);
	
	//13 Apr 2017	NDL	TFS 3414
	if self.frmPallet.visible then
		palletType := self.cmbPalletType.listObject.CM_PalletType;
		isHeatTreated := self.chkHeatTreated.value;
		isStoreOnPallet := self.chkStoreOnP.value;
	endif;
	
	if lResourceType = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A) &amp;  " " &amp; app.getErrorString(Resource_usage), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.cmbResourceType.setFocus();
		return;
	endif;

	// if no current proxy to update, create new proxy.
	if self.myCurrentProxyUsage = null then
		create proxy transient;
		//self.allNewProxyResourceTypeUsages.add(proxy);		//cnwmc5 - 6 Oct 2015 - PAR 36920
	else
		proxy := self.myCurrentProxyUsage;
	endif;
	
	//update / populate the proxy
	proxy.setProxy(	lResourceType,	//_resourceType : CM_ResourceType;
					trn,  // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1 self.myTransaction,	//_transaction : CM_Transaction;
					lNoCharge,	//_noCharge : Boolean;
					lQuantity,	//_quantity : Decimal;
					lRemarks,	//_remarks : String;
					lStatus,	//_status : Integer
					lFromDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
					lToDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
					palletType,	//13 Apr 2017	NDL	TFS 3414
					isHeatTreated,	//13 Apr 2017	NDL	TFS 3414
					isStoreOnPallet	//13 Apr 2017	NDL	TFS 3414
					);

	autoApplyResourceType := lResourceType.myAutoApplyResourceType;									//19.12.2023 navlc30 #60748
	resourceUsageSet := self.allProxyResourceTypeUsages;											//19.12.2023 navlc30 #60748
		
	if autoApplyResourceType &lt;&gt; null then															//19.12.2023 navlc30 #60748													
		if not resourceUsageSet.hasResourceType(autoApplyResourceType) then
			create proxyAutoApply transient;
		else 
			proxyAutoApply := resourceUsageSet.getAutoApplyResourceUsage(autoApplyResourceType);
		endif;	

		proxyAutoApply.setProxy(	autoApplyResourceType,	//_resourceType : CM_ResourceType;
					trn,  // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1 self.myTransaction,	//_transaction : CM_Transaction;
					lNoCharge,	//_noCharge : Boolean;
					lQuantity,	//_quantity : Decimal;
					lRemarks,	//_remarks : String;
					lStatus,	//_status : Integer
					lFromDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
					lToDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
					palletType,	//13 Apr 2017	NDL	TFS 3414
					isHeatTreated,	//13 Apr 2017	NDL	TFS 3414
					isStoreOnPallet	//13 Apr 2017	NDL	TFS 3414
					);
	
	endif;
	
//	if not self.warningIssued then
		if self.myCurrentProxyUsage &lt;&gt; null then
			realUsage := self.myCurrentProxyUsage.pxyGetRealObject().CM_ResourceTypeUsage;
			if realUsage &lt;&gt; null then
				if not realUsage.allInvoiceLines.isEmpty then
					app.msgBox( app.getErrorString(Changing_Invoiced_Resource), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					warningIssued := true;
				endif;
			endif;
		endif;
//	endif;
	
	//cnwmc5 - 6 Oct 2015 - PAR 36920 - start
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	proxy.validateForCreate();
	
	if app.myPassport.hasErrorsOrWarnings then
		result	:= app.showErrorWarningDialog(	app.getErrorString( ToDoTaskResources ),
												app.myPassport,
												ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
		if app.myPassport.hasErrors or result &lt;&gt; IDOK then
			return;
		endif;
	endif;
	
	if self.myCurrentProxyUsage = null then
		self.allNewProxyResourceTypeUsages.add(proxy);
		if proxyAutoApply &lt;&gt; null then																			//19.12.2023 navlc30 #60748
			self.allNewProxyResourceTypeUsages.add(proxyAutoApply);
		endif;
	endif;
	//cnwmc5 - 6 Oct 2015 - PAR 36920 - end
	
	//refresh the form
	self.clearGrpResource();
	self.loadTableData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="4530e48a-0f52-4883-b210-71e788f8f01c">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars

	buttonLeft : Real;
begin

	inheritMethod();
	
	/*05.07.2024  navbs1  CR 64901 Task 64903
	//self.grpMain.width := self.width - 10;
	self.grpMain.width := self.clientWidth - 10;	// 11/01/2011 cnwar2 #26691
	self.grpMain.height := self.height - 8;
	
	buttonLeft := self.grpMain.width - self.btnSave.width - 8;
	self.btnAdd.left := buttonLeft;
	self.btnDelete.left := buttonLeft;
	self.tblResources.width := buttonLeft - 10;
	
	
	self.grpResource.width := self.grpMain.width - 8;
	self.btnUpdate.left := self.grpResource.width - self.btnUpdate.width - 6;
	self.txtRemarks.width := self.grpResource.width - self.txtRemarks.left - self.btnUpdate.width - 12; 

	
//	self.btnSave.left := buttonLeft;
	self.btnSave.top := self.grpMain.height - self.btnSave.height - 35;
	self.btnCancel.top := self.btnSave.top;
//	self.btnCancel.left := self.btnSave.left - self.btnCancel.width - 6;
	self.btnCancel.left := buttonLeft;
	self.btnSave.left := self.btnCancel.left - self.btnSave.width - 6;
	
	self.grpResource.top := self.btnSave.top - self.grpResource.height - 8;
	self.tblResources.height := self.grpResource.top - 8; */

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblResourcesClick" id="b1c991b9-45c1-4e7a-b01e-5900880396c0">
        <updating/>
        <source>doTblResourcesClick()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006
20 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

vars

	proxyUsage : CM_ResourceTypeUsage;
	decPlaces : Integer;
	realUsage : CM_ResourceTypeUsage;
	unsavedChanges : Boolean;
	
begin

	//18 Mar 2010	NDL	Par 22725
	self.checkForUnsavedTransientChgs( unsavedChanges );
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist3), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	clearGrpResource();

	if self.tblResources.row &gt; self.tblResources.fixedRows and self.tblResources.row &lt;= self.tblResources.rows then
		proxyUsage := self.tblResources.accessRow(self.tblResources.row).itemObject.CM_ResourceTypeUsage;
	endif;
	
	if proxyUsage = null then
		return;
	endif;
	
	self.myCurrentProxyUsage := proxyUsage;
	self.grpResource.enabled := true;
	//Disable grpResource for Auto applied Resource usage
	if proxyUsage.isAutoApplyResourceUsage() then							//20.12.2023 navlc30 #60748
		self.grpResource.enabled := false;
	endif;
	
	self.makePalletStuffVisible( self.myCurrentProxyUsage.myResourceType );	//13 Apr 2017	NDL	TFS 3414
	
	self.cmbResourceType.listIndex := self.cmbResourceType.findObject( self.myCurrentProxyUsage.myResourceType );
	decPlaces := self.myCurrentProxyUsage.myResourceType.decimalPlaces;
	self.setLblUnitsCaption(decPlaces);
	self.txtUnits.text := self.myCurrentProxyUsage.quantity.asStringJMTWithPrecision(decPlaces,false);
	self.txtRemarks.text := self.myCurrentProxyUsage.remarks;
	self.chkNoCharge.value := self.myCurrentProxyUsage.noCharge;
	
	if self.myCurrentProxyUsage.getStatusString = app.getErrorString(Normal) then
		self.chkVoid.value := false;
	else
		self.chkVoid.value := true;
	endif;
	
	realUsage := proxyUsage.pxyGetRealObject();
	if realUsage &lt;&gt; null then
		// no longer allowed to delete persistant usages.
		self.btnDelete.enabled := false;
		self.chkVoid.enabled := true;
	else
		self.btnDelete.enabled := true;
	endif;
	
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	self.txtToDate.setDate(self.myCurrentProxyUsage.toDateTime.date);
	self.txtToTime.setTime(self.myCurrentProxyUsage.toDateTime.time);
	self.txtFromDate.setDate(self.myCurrentProxyUsage.fromDateTime.date);
	self.txtFromTime.setTime(self.myCurrentProxyUsage.fromDateTime.time);
	
	if self.myCurrentProxyUsage.myResourceType &lt;&gt; null and self.myCurrentProxyUsage.myResourceType.isFromToDateTimeRequired then
		self.frmFromToDate.visible := true;
	else 
		self.frmFromToDate.visible := false;
	endif;
	
	//13 Apr 2017	NDL	TFS 3414
	if self.frmPallet.visible then
		self.chkHeatTreated.value := self.myCurrentProxyUsage.isHeatTreated;
		self.chkStoreOnP.value := self.myCurrentProxyUsage.isStoreOnPallet;
		self.cmbPalletType.listIndex := self.cmbPalletType.findObject(  self.myCurrentProxyUsage.myPalletType );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="680ba45d-0040-4e87-9141-adbb23309b0c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
