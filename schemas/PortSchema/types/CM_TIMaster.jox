    <JadeMethod name="convertFromEDIFleetTi" id="e1e8652b-4b3b-479e-8378-54d5e80969a0">
        <updating/>
        <source>convertFromEDIFleetTi(_ediFleet: CM_EDIFleetTI; _operator: CM_Operator) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwrd1	Initial creation

*/

vars
	operator : CM_Operator;
begin
	self.id := _ediFleet.id;
	self.cargoType := _ediFleet.cargoType;
	
	self.extHeight := _ediFleet.extHeight;
	self.extWidth := _ediFleet.extWidth;
	self.extLength := _ediFleet.extLength;
	self.intHeight := _ediFleet.intHeight;
	self.intWidth := _ediFleet.intWidth;
	self.intLength := _ediFleet.intLength;	
//	self.description := _ediFleet.description;	// cnwrl1 14/07/2009 PAR 20247 - what it was
	self.description := _ediFleet.description[ 1 : self.description.maxLength ];
	
	operator :=  app.myRoot.allOperators[_ediFleet.owner];	
	self.myOwner := operator;



	self.myOperatorNew := _operator;
	
	self.tWeight := _ediFleet.tareWeight;	
	self.volume := _ediFleet.volume;
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_ediFleet" type="CM_EDIFleetTI"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="createPxyDamageInstance" id="bc2cbca9-4490-40a2-b7e1-3a4ef14a096f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::createPxyDamageInstance"/>
        </interfaceImplements>
        <source>createPxyDamageInstance(	_code : CM_DamageDefinitionCode;
						_position : CM_DamagePosition;
						_remarks : String;
						_isNew : Boolean;
						_quantity : Integer;
						_severity : CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
						_locationStr : String;	// 01 Mar 2016	TFS 1593 The Location Controller id 
						_damagePlace	: CM_DamagePlace;	// July 1, 2022 navak20 TFS 53862
						_damageParty	: CM_DamageParty;	// July 1, 2022 navak20 TFS 53862
						_damageReason	: CM_DamageReason;	// July 1, 2022 navak20 TFS 53862
						_repairReason	: CM_RepairReason;	// July 1, 2022 navak20 TFS 53862
						_damageSize		: Decimal;			// July 1, 2022 navak20 TFS 53862
						_damageDateTime	: TimeStamp;		// July 1, 2022 navak20 TFS 53862
						_status			: Integer;		// July 1, 2022 navak20 TFS 53862
						_repairRemarks	: String;		// July 1, 2022 navak20 TFS 53862	
						_repairedDateTime : TimeStamp	//July 1, 2022 navak20 TFS 53862 
						) : CM_DamageInstance;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwer1	Initial creation

*/

vars
	damageInstance		: CM_DamageInstance;
	tiMaster			: CM_TIMaster;
begin
	//expected to be transient 
	if self.isTransient then
		tiMaster:=self;
	endif;
	
	create damageInstance transient;
	damageInstance.setProxy(	null, 
								tiMaster,
								_code, 
								_position,
								_remarks,
								_isNew,
								_quantity,
								_severity,
								//_repaired,	// July 1, 2022 navak20 TFS 53862
								null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
								_damagePlace, 	// July 1, 2022 navak20 TFS 53862
								_damageParty,	// July 1, 2022 navak20 TFS 53862
								_damageReason,	// July 1, 2022 navak20 TFS 53862
								_repairReason,	// July 1, 2022 navak20 TFS 53862
								_damageSize,	// July 1, 2022 navak20 TFS 53862
								_damageDateTime,	// July 1, 2022 navak20 TFS 53862
								_status,			// July 1, 2022 navak20 TFS 53862
								_repairRemarks,		// July 1, 2022 navak20 TFS 53862
								_repairedDateTime	// July 1, 2022 navak20 TFS 53862
								);	
	
	if self.isTransient  then
		damageInstance.setMySubject(self);
	endif;
	
	return damageInstance;


epilog

end;</source>
        <Parameter name="_code" type="CM_DamageDefinitionCode"/>
        <Parameter name="_position" type="CM_DamagePosition"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isNew" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_locationStr" type="String"/>
        <Parameter name="_damagePlace" type="CM_DamagePlace"/>
        <Parameter name="_damageParty" type="CM_DamageParty"/>
        <Parameter name="_damageReason" type="CM_DamageReason"/>
        <Parameter name="_repairReason" type="CM_RepairReason"/>
        <Parameter name="_damageSize" type="Decimal"/>
        <Parameter name="_damageDateTime" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_repairRemarks" type="String"/>
        <Parameter name="_repairedDateTime" type="TimeStamp"/>
        <ReturnType type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="createStopsBulk" id="28723bb0-e0c2-4d05-a032-7be1ea62c426">
        <updating/>
        <source>createStopsBulk(_theStop : CM_StopsTable; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/

vars
	aStop 			: Integer;
	theStop 		: CM_StopsTable;
	txnParams 		: CMIF_ConnectParams;
	stopTblDict 	: CM_StopsTableByIdDict;
	tmpStopTbl,
	tmpStopTable 	: CM_StopsTable;
	tmpUser			: CM_User;
reason : String;
begin
	if _theStop = null then
		return;
	endif;
	
	
	self.raiseExceptionIfTransient(method);

	tmpUser := _passport.myUser;
	if tmpUser = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_passport.myUser', null, null);
		return;
	endif;


// DVB CCMS 125
//	stopsTblDict := app.myRoot.allStopsTable;
	stopTblDict := app.myRoot.allAvailableStopsTables;
	// NOTE stops are only set for the cargo types specified for the stop type in sys ops

		tmpStopTbl := stopTblDict[_theStop.id];
		if tmpStopTbl = null then
			tmpStopTable := app.myRoot.allStopsTable[_theStop.id];
			if tmpStopTable &lt;&gt; null then
				if tmpStopTable.isNotAvailableForEntry then 
//					app.raiseCMWarning1(WARN_STOPS_ADD, "The stop (" &amp; tmpStopTable.heading &amp; ") is not available for entry. If you wish to use you must update the Stop in System Admin.", null, null, self);	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages - what it was
					app.raiseCMWarning1( WARN_STOPS_ADD, app.getString( Stop_NotAvailableForEntry, tmpStopTable.heading ), null, null, self );
				endif;
			else
				app.raiseCMWarning1(WARN_STOPS_ADD, 'Invalid stop id (' &amp; aStop.String &amp; ')',null, null, self);
			endif;
		endif;
/*
		if (not tmpUser.canUpdateStop(tmpTerminal, tmpStopTbl)) then
			app.raiseCMWarning1(NoPermission, app.getErrorString1(Add_The_Stop, tmpStopTbl.heading) &amp; 'for ' &amp; self.id, null, null, self);
			continue;
		endif;
	*/

		if (not tmpStopTbl.isValidForCargoType(self.cargoType)) then
			app.raiseCMWarning1(WARN_STOPS_ADD, "The stop (" &amp; tmpStopTbl.heading &amp; ") is not allowed for the cargo type of " &amp; self.id,null, null, self);
		endif;
		/*
		if not tmpStopTbl.isStopRelevant(self.cargoType, self) then //cnwrs1 May 2007 Par13378 stops
//			app.raiseCMWarning(CannotSetStop, null, null, self);
		//	reason := tmpStopTbl.getStopNotRevelantReason(self);//*** change??
//			app.raiseCMException(CannotSetStop, null, null);
			if reason &lt;&gt; null then //ccms 1100 cnwrs1 Mar 2008
				app.raiseCMException2(Full_Replacement_Message, "Stop is not relevant to " &amp; self.id &amp; ", because of " &amp; reason &amp; " on stop type '" &amp; tmpStopTbl.heading &amp; "'.", null, null, self);
				continue;
			endif;
		endif;
		*/
		if self.allStopsNew[aStop] &lt;&gt; null then
			app.raiseCMWarning1(WARN_STOPS_ADD, "The stop (" &amp; tmpStopTbl.heading &amp; ") already exists on " &amp; self.id, null, null, self);
		else
		/*
			create theStop persistent;
			theStop.setForCreate( tmpStopTbl);
			self.causeEvent(Object_Update_Event, false, self);
		*/
		
		self.allStopsNew.add (  _theStop ) ;
//		self.causeEvent(Object_Update_Event, false, self);// cnwrd1 par #18159 10.10.08
		self.updateObjectEdition(self);
	endif;


	//epr par 11947 cnwrs1 dec 2006 I dont believe this has any effect and is not neccassary 
	//self.setCustomsExportEntryNumber(self.myVoyage, self.customExportEntryNumber ,_passport);
end;</source>
        <Parameter name="_theStop" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTrackedItem" id="f04e4f2d-feec-4896-9375-bc830cb51353">
        <updating/>
        <source>createTrackedItem(_terminal : CM_Terminal input; _transient : Boolean)  : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	if _terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;

	return null;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
