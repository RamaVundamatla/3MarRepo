    <JadeMethod name="getNumLines" id="29c77136-4648-4979-9587-77cabaf4f51a">
        <source>getNumLines(lString : String) : Integer protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	j: Integer;
	k : Integer;
begin
	
	k := 1;
	foreach j in 1 to lString.length do
		if lString[j:2] = CrLf then
			k := k + 1;
		endif;
	endforeach;
	return k;
end;</source>
        <access>protected</access>
        <Parameter name="lString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="2fd6abe1-4eef-4fda-b9b9-b11d199810eb">
        <source>printReport(_transArray : CM_LockTransactionArray);
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lockTrans	: CM_LockTransaction;
	str,
	tmpStr,
	tmpDescr	: String;
begin

	self.portteclogo.picture := app.getPicLogoProduct();
	self.picLogo.picture := app.getPicLogoPort();

	foreach lockTrans in _transArray do
		self.frmLine1.caption := null;
		self.frmLine1.backColor := Gray;
		app.printer.print(self.frmDetail);			

		self.frmLine1.backColor := White;
		
		tmpDescr := lockTrans.lockTypeStr;
		if tmpDescr = null then
			tmpDescr := 'Lock(?)';
		endif;

		str := tmpDescr &amp; ' exception for ' &amp; lockTrans.lockedUser &amp; ' in ' &amp;
				lockTrans.lockedTerminalCode &amp; ' ' &amp; lockTrans.lockDT.String &amp;
				' (' &amp; lockTrans.lockTargetClass &amp; '/' &amp; lockTrans.lockTargetOid &amp; ')';
		self.frmLine1.caption := str;
		app.printer.print(self.frmDetail);			

		str := 'Locked by ' &amp; lockTrans.lockedByUser &amp; ' in ' &amp;
				lockTrans.lockedByTerminalCode &amp; '.';

		self.frmLine1.caption := str;
		app.printer.print(self.frmDetail);			

		if lockTrans.lockedByDetails &lt;&gt; null then
			str := 'Last in ' &amp; lockTrans.lockedByDetails &amp; ' started ' &amp;
					lockTrans.lockedByTrxStartTime.String &amp; ' completed ' &amp;
					lockTrans.lockedByTrxEndTime.String;
	
			self.frmLine1.caption := str;
			app.printer.print(self.frmDetail);			
		endif;
		
		if lockTrans.stackDump &lt;&gt; null then
			self.frmLine1.caption := null;
			app.printer.print(self.frmDetail);			

			self.frmLine1.caption 	:= 'Stack Dump';
			self.frmLine1.fontBold	:= true;
			app.printer.print(self.frmDetail);			

			self.frmLine1.fontBold	:= false;
			
			foreach tmpStr in lockTrans.stackDump do
				self.frmLine1.caption := tmpStr;
				app.printer.print(self.frmDetail);			
			endforeach;

		endif;
	endforeach;

	self.frmLine1.caption := null;
	self.frmLine1.backColor := Gray;
	app.printer.print(self.frmDetail);			

end;</source>
        <Parameter name="_transArray" type="CM_LockTransactionArray"/>
    </JadeMethod>
</GUIClass>
