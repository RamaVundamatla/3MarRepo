    <JadeMethod name="utlUpdateSlotControllerShuffFM" id="8aab216f-3587-4b94-bc08-1879e89a16a3">
        <source>utlUpdateSlotControllerShuffFM(_theLocation : CM_LocationsController;_theFMs : CM_FutureMoveArray; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		shuffle the FMs on a location controller. The FMs passed in must be for the same location controller.
//
// ---------------------------------------------------------------------------
vars
	theLocation : CM_LocationsController;
	theLCs : CM_LCArray;
	anFM : CM_FutureMove;
	aPFM : CM_FutureMovePlanned;
begin

	self.initialiseActivity();
	if _passport.hasErrors then
		return;
	endif;
	
	if _theFMs.isEmpty then
		return;
	endif;
	
	theLocation := _theLocation;
	if theLocation = null then
		return;
	endif;
	
	create theLCs transient;
	// DETTACH the future moves from the LCs
	foreach anFM in _theFMs do
		if anFM.isKindOf(CM_FutureMovePlanned) then
			aPFM := anFM.CM_FutureMovePlanned;
			aPFM.removeLocationController(theLocation);
		endif;
	endforeach;

	// ATTACH the future moves to the LCs
	foreach anFM in _theFMs do
		if anFM.isKindOf(CM_FutureMovePlanned) then
			aPFM := anFM.CM_FutureMovePlanned;
			aPFM.addLocationController(theLocation);
		endif;
	endforeach;
	
	if _passport.noErrors then
		// ########################
		// This will update the display on screen 
		if theLocation.isKindOf(CM_SlotController) then
			theLocation.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), 
						false, theLocation);
		endif;
	endif;
epilog
	delete theLCs;
end;</source>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
        <Parameter name="_theFMs" type="CM_FutureMoveArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotControllerShuffle" id="54896599-542f-4472-adee-367971203dc8">
        <source>utlUpdateSlotControllerShuffle(_theTIs : CM_TIArray; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theController 		: CMIF_MoveController;
	theLocation 		: CM_LocationsController;
	aTI,theTI 			: CM_TrackedItem;
//	otherTIs : CM_TISet;
begin

	self.initialiseActivity();
	if _passport.hasErrors then
		return;
	endif;
	
	if _theTIs.isEmpty then
		return;
	endif;
	
	aTI := _theTIs.first;
	theLocation := aTI.getPrimaryLocation(REAL_MODE);
	if theLocation = null then
		return;
	endif;
	
	create theController;
//	create otherTIs transient;
//	_theTIs.copy(otherTIs);

	// cnwjk3 ccms 1018 15/01/10
	// Indicate that we are just shuffling in the current location so that we can provide a more
	// meaningful move transaction message
	theController.setIsShufflingInCurrentLcn(true);
	
	theController.setMoveMode(REAL_MODE);
	theController.setMyOriginatingLocation(theLocation);
	
	// Move the TIs to no where - i.e. remove them from the slotcontroller(s)
	foreach aTI in _theTIs do
		theController.setMyTrackedItem(aTI);
		self.utlUpdateMoveTrackedItem(theController,_passport);
	endforeach;
	
	// move the TIs back to the slot controllers in the new order
	theController.setMyOriginatingLocation(null);
	theController.setMyToPrimaryLocation(theLocation);
	
	foreach aTI in _theTIs do
		theController.setMyTrackedItem(aTI);
		self.utlUpdateMoveTrackedItem(theController,_passport);
	endforeach;	
	
	if _passport.noErrors then
	endif;
epilog
	delete theController;
//	delete otherTIs;
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotControllerUnplan" id="a0250091-03ec-444c-92ac-be59ccb7ff1c">
        <updating/>
        <source>utlUpdateSlotControllerUnplan(_theMoveMode : Integer; _realSlotController : CM_SlotController input;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
begin

	self.initialiseActivity();
	if _passport.hasErrors then
		return;
	endif;

	_realSlotController.unplanAllTrackedItems(_theMoveMode);
	
epilog

end;</source>
        <Parameter name="_theMoveMode" type="Integer"/>
        <Parameter name="_realSlotController" type="CM_SlotController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotDefn" id="78bba815-df95-421e-96b8-2cf5ffbca8e1">
        <source>utlUpdateSlotDefn(_proxySlotDefn:CM_SlotDefn; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realSlotDefn:CM_SlotDefn;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_proxySlotDefn.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySlotDefn.pxyGetRealObjectAndEdition(realSlotDefn, expectedEdition);
	
	if realSlotDefn = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotDefn.name, null, null);
		return;
	endif;

	app.myValUA.valSlotDefn(realSlotDefn, _proxySlotDefn);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);



	exclusiveLock(realSlotDefn);
	
	if _passport.noErrors then
		realSlotDefn.setForUpdate(_proxySlotDefn,_passport);
	endif;

end;</source>
        <Parameter name="_proxySlotDefn" type="CM_SlotDefn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotDefnController" id="44418114-d83f-4e2d-98a6-4acdc898d736">
        <source>utlUpdateSlotDefnController(_theDefinitions:CMIF_SlotDefinitionController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		Use the controller to toggle a single attribute on the collection of slot Definitions
// ---------------------------------------------------------------------------
vars
	realSlotDefinition,proxySlotDefinition :CM_SlotDefn;
	idx : Integer;
	get20 : Boolean;
	theSlot : CM_SlotController;
	theBGPReq : BGP_VoyageDrawingDef;
	theVoyage : CM_Voyage;
begin
	self.initialiseActivity();

	if _passport.noErrors then
		foreach	proxySlotDefinition in _theDefinitions.allProxySlotDefn do
			proxySlotDefinition.setAnAttributeFromController(_theDefinitions.theAttribute);
		
			self.utlUpdateSlotDefn(proxySlotDefinition,_passport);
			// there was an update to the transient above
			// if there are warnings the transient update  is not undone, if the user says to continue the 2nd update revserses the first
			// so nothing is updated. So here we undo the update ourselves
			if _passport.hasWarnings then 
				proxySlotDefinition.setAnAttributeFromController(_theDefinitions.theAttribute);
			endif;
		endforeach;
		
		
		if _passport.noErrors then
			foreach	proxySlotDefinition in _theDefinitions.allProxySlotDefn do
				realSlotDefinition := proxySlotDefinition.pxyGetRealObject;
				if CM_SlotDefnVoyage.hasInstance(realSlotDefinition) then
					theSlot := realSlotDefinition.CM_SlotDefnVoyage.mySlotController;
					if theSlot &lt;&gt; null then
						theVoyage := theSlot.myVoyage;
						theVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, theSlot);
					endif;
				endif;
			endforeach;
			
			if theVoyage &lt;&gt; null then
				/* not used yet, but when it is used do not use the call below
				create theBGPReq transient;
				theBGPReq.initRequestForVoyageDrawingDef();
				*/
// AKB NOT NEEDED				theVoyage.setDrawingDefinition();
			endif;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_theDefinitions" type="CMIF_SlotDefinitionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotReqLinkSOBDLR2" id="60601a0f-0aa9-4f23-a92a-9b92ef75557c">
        <source>utlUpdateSlotReqLinkSOBDLR2(_loadSlot : CM_SlotController input; _dischSlot : CM_SlotController;  
			_loadSlotEdition, _dischSlotEdition : Integer;
			_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpSlotReqLoad,
	tmpSlotReqDisch	: CM_SlotRequest;
begin

	self.initialiseActivity();

	if _loadSlot = null and _dischSlot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_loadSlot and/or _dischSlot', null, null);
		return;
	endif;
	
	if _loadSlot &lt;&gt; null then
		exclusiveLock(_loadSlot);
		if _loadSlot.edition &lt;&gt; _loadSlotEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; _loadSlot.ident, null, null);
			return;
		endif;
		tmpSlotReqLoad := _loadSlot.mySlotRequestLoad;
		if tmpSlotReqLoad = null then
			app.raiseCMException2(NoColorCodeForSlot, app.getErrorString(Load), _loadSlot.ident, null, null);
			return;
		endif;
		exclusiveLock(tmpSlotReqLoad);
	endif;

	if _dischSlot &lt;&gt; null then
		exclusiveLock(_dischSlot);
		if _dischSlot.edition &lt;&gt; _dischSlotEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; _dischSlot.ident, null, null);
			return;
		endif;
		tmpSlotReqDisch := _dischSlot.mySlotRequestDischarge;
		if tmpSlotReqDisch = null then
			app.raiseCMException2(NoColorCodeForSlot, app.getErrorString(Discharge), _dischSlot.ident, null, null);
			return;
		endif;
	endif;
	
	if tmpSlotReqLoad = null then
		app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(tmpSlotReqDisch, tmpSlotReqLoad, _passport);
	else
		app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(tmpSlotReqLoad, tmpSlotReqDisch, _passport);
	endif;
												
end;</source>
        <Parameter name="_loadSlot" type="CM_SlotController" usage="input"/>
        <Parameter name="_dischSlot" type="CM_SlotController"/>
        <Parameter name="_loadSlotEdition" type="Integer"/>
        <Parameter name="_dischSlotEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequest" id="9a413ff9-45ca-4d9b-8ad6-b1488fd55862">
        <source>utlUpdateSlotRequest(_proxySlotRequest:CM_SlotRequest; _passport : CM_Passport input; _sendNote : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2010	cnwdap1		CCMS 1116 Tranship changes - don't change IMEX status on tranships
// 30/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 Release requests on ship load list
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	aftSlotRequest,
	realSlotRequest	: CM_SlotRequest;
	expectedEdition	: Integer;
	aTI, unplanTI 	: CM_TrackedItem;
	realSlotController : CM_SlotController;
	oldMoveType 	: Integer;
	oldFortyFront,
	old53Front,
	old45Front,
	aftSlotUpdated	: Boolean;
	tmpVoyage		: CM_Voyage;
	tmpEvent		: Integer;
	wle				: CM_WorkListEntry;		// PAR #26426
	tmpReserve		: CM_ReserveDetail;		// PAR #26426
begin
	self.initialiseActivity();

	_proxySlotRequest.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySlotRequest.pxyGetRealObjectAndEdition(realSlotRequest, expectedEdition);
	if realSlotRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotRequest.name, null, null);
		return;
	endif;
	app.myValUA.valSlotRequest(realSlotRequest, _proxySlotRequest);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	realSlotController := realSlotRequest.mySlotController;
	exclusiveLock(realSlotRequest);

	if _passport.noErrors and realSlotRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(SlotRequest), null, null);
		return;
	endif;

	if _passport.hasErrors then
		return;
	endif;

	// ################
	// ################
	aTI := realSlotRequest.getTrackedItem(); // PAR 6319 do this here as it gets dettached in the set for update, especially if we are erasing
	// PAR #26426 if the TI in this slot is not null, remember the wle for later so we can notify the Ship Load List of a change
	if aTI &lt;&gt; null then
		wle := realSlotRequest.allWorkListEntries.first;
		// if the TI in this slot is a TBA, clear the reference - it will be deleted in CM_SlotRequest setForUpdate/createWLEs methods
		if aTI.isTBA and _passport.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
			aTI := null;
		endif;
	endif;
	// PAR #26426 end
	unplanTI      := aTI;
	oldMoveType   := realSlotRequest.moveType;
	oldFortyFront := realSlotRequest.getAttrIs40();
	old53Front    := realSlotRequest.getAttrIs53();
	old45Front    := realSlotRequest.getAttrIs45();
	tmpReserve    := realSlotRequest.myBulkReleaseReserveDetail;	// PAR #26426
	
	realSlotRequest.setForUpdate(_proxySlotRequest);
	// this is now done in setForCreate
	//realSlotRequest.setDoorMotorDirDefault(); // NEW

	if oldFortyFront and (not realSlotRequest.getAttrIs40()) then
		// request has changed from a forty to non-forty so
		// need to delete the back end request
		aftSlotRequest := realSlotRequest.mySlotRequestAft;
		if aftSlotRequest &lt;&gt; null then
			aftSlotRequest.erase(NORMAL_ERASE);
			aftSlotUpdated := true;
		endif;
	endif;
	if old53Front and (not realSlotRequest.getAttrIs53()) then
		// request has changed from a 53 to non-53 so
		// need to delete the back end request
		aftSlotRequest := realSlotRequest.mySlotRequestAft;
		if aftSlotRequest &lt;&gt; null then
			// do aft aft 53 backend first
			aftSlotRequest := aftSlotRequest.mySlotRequestAft;
			aftSlotRequest.erase(NORMAL_ERASE);
			// do aft 53 next
			aftSlotRequest := realSlotRequest.mySlotRequestAft;
			aftSlotRequest.erase(NORMAL_ERASE);
			
			aftSlotUpdated := true;
		endif;
	endif;
	if old45Front and (not realSlotRequest.getAttrIs45()) then
		// request has changed from a 45 to non-45 so
		// need to delete the back end request
		aftSlotRequest := realSlotRequest.mySlotRequestAft;
		if aftSlotRequest &lt;&gt; null then
			// do aft  45 backend first
			aftSlotRequest.erase(NORMAL_ERASE);
			aftSlotUpdated := true;
		endif;
	endif;

	if aTI = null then // PAR 6319 if we are updating then the TI will now be attached
		aTI := realSlotRequest.getTrackedItem(); // PAR 6319 // do this here as it gets dettached in the set for update
	endif;
	if _passport.noErrors then
		// we have to set the TI status if this IS a DLR or SOB back to DLR or SOB
		if aTI = null then
			aTI := unplanTI;
		endif;
		if aTI &lt;&gt; null then
			if realSlotRequest.isRehandle then
				// if DLR do not change the IMEX - Import Export Transit etc
				aTI.setTransitStatus(TI_TransitStatusDLR, true, _passport);
			elseif realSlotRequest.isSOB then
				// if SOB do not change the IMEX - Import Export Transit etc
				aTI.setTransitStatus(TI_TransitStatusSOB, true, _passport);
			elseif realSlotRequest.moveType = DISCHARGE_MOVETYPE then
				// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: aTI.statusEvent signature changed.
				aTI.statusEvent(DIS_CCODE_STATUS_EV, true, _passport);
			elseif realSlotRequest.moveType = LOAD_MOVETYPE then
				// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: aTI.statusEvent signature changed.
				aTI.statusEvent(LOAD_CCODE_STATUS_EV, true, _passport);
			elseif realSlotRequest.moveType = NULL_MOVETYPE then
				aTI.setTransitStatus(TI_TransitStatusNull, true, _passport); // not DLR or SOB
				if aTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
					if oldMoveType = DISCHARGE_MOVETYPE then
						aTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
					elseif oldMoveType = LOAD_MOVETYPE then
						aTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					else
						aTI.setImExStatus(TI_IMEX_STATUS_NULL);
					endif;
				endif;													// PAR #23645 CCMS 1116
			endif;						
		endif;
	endif;

	// DO NOT use SETFORTY - the 40 backend has already been taken care of

	if realSlotRequest.moveType = NULL_MOVETYPE then
		if _passport.warningsAcknowledged then
			_passport.clearErrorsWarnings();
		endif;
		realSlotRequest.unPlanMyTIs(unplanTI,_passport);
	endif;
	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this slot
		if _sendNote then
			if realSlotRequest.myJob &lt;&gt; null then
				realSlotRequest.myJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
			endif;
			tmpVoyage := realSlotRequest.mySlotController.myBayVoyage.myCellularVoyageStructure.myVoyage;
			tmpEvent  := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
			tmpVoyage.causeEvent(tmpEvent, false, realSlotRequest.mySlotController);
			if aftSlotUpdated then
				tmpVoyage.causeEvent(tmpEvent, false, realSlotRequest.mySlotController.myAftSlot);
			endif;
			if not(realSlotRequest.isDischarge or realSlotRequest.getAttrIsBackend()) then // PAR 21746
				tmpVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(Event_SlotRequest_Update), false, realSlotRequest);
			endif;
			// PAR #26426 cause event on wle if we have one, and on bulk release
			if wle &lt;&gt; null then
				wle.causeEvent(_passport.myTerminal.getTerminalEvent(WLE_Update_Event), false, wle);
			endif;
			if tmpReserve &lt;&gt; null then
				tmpReserve.myReserveHeader.causeUpdateEvent;
			endif;
			// PAR #26426 end
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_sendNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestDirection" id="811e2298-8432-4d7b-be9e-40a2a1982776">
        <source>utlUpdateSlotRequestDirection(_proxySlotRequest:CM_Request; _passport : CM_Passport input);
/* ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
09 Aug 2011	cnwer1	CCMS 1033 changed so will work with SlotRequest and VoyageRequest. 
19 Mar 2018 jlgmd1	TFS #37652 CPL - Door Directions in Job Operations
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits

*/
vars
	realSlotRequest:CM_Request;
	expectedEdition:Integer;
	wle : CM_WorkListEntry;
begin
	self.initialiseActivity();

	_proxySlotRequest.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySlotRequest.pxyGetRealObjectAndEdition(realSlotRequest, expectedEdition);
	if realSlotRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotRequest.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realSlotRequest);

	if _passport.noErrors and realSlotRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'SlotRequest', null, null);
		return;
	endif;

	if _passport.noErrors then
		// ################
		// ################
		realSlotRequest.setForUpdateDirection(_proxySlotRequest);
	endif;
	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this slot
		
		//12 Jan 2012	NDL	Par 28160 - Notes weren't working on the (Voyage) Job Operations form.
		foreach wle in realSlotRequest.allWorkListEntries discreteLock do //where not wle.isCompleteForJob do													//-TFS 37652
			app.myEventManager.createSingleObjInfoNoteEvt(wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), wle);
		endforeach;
		
		if realSlotRequest.myJob &lt;&gt; null then
			realSlotRequest.myJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
		realSlotRequest.getVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),false, realSlotRequest.getVoyageController);
	endif;
epilog
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestDischRORO" id="cf05badc-0efa-4db2-b892-ce7c9950c3b5">
        <source>utlUpdateSlotRequestDischRORO(pxyReq : CM_RORORequest; _allTIs : CM_TIArray; _passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	realSlotRequest:CM_RORORequest;
	expectedEdition:Integer;
	aTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	currentTIs : CM_TIArray;
	aVWLE : CM_VoyageWLE;
begin
	self.initialiseActivity();

	
	if _passport.noErrors then

		self.utlUpdateSlotRequestRORO(pxyReq,_passport,true);
		if _passport.noErrors then
			pxyReq.pxyGetRealObjectAndEdition(realSlotRequest, expectedEdition);
			if realSlotRequest = null then	
				app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotRequest.name, null, null);
				return;
			endif;
			// this discharge may have more than 1 item of cargo in the slot so create many WLEs
			if realSlotRequest.isDischarge then //and realSlotRequest.mySlotController.allTrackedItems.size &gt; 1 then
				// all this adds all the TIs that should be on the request and then checks to see if any were removed
				create currentTIs transient;
				realSlotRequest.getAllTrackedItems(currentTIs);
				foreach aTI in _allTIs do
					if not currentTIs.includes(aTI) then
						aVWLE := null;
						realSlotRequest.addWLE(aVWLE,aTI); // this wle is IO so nullit each time, 
					endif;
				endforeach;
				aVWLE := null;
				foreach aTI in currentTIs do
					if not _allTIs.includes(aTI) then
						realSlotRequest.removeWLE(aVWLE,aTI);
					endif;

				endforeach;
			endif;
		endif;
	endif;
epilog
	delete currentTIs;
end;</source>
        <Parameter name="pxyReq" type="CM_RORORequest"/>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestDischarge" id="896647fe-b2c6-45ba-8b7b-9a49f7fb3d80">
        <source>utlUpdateSlotRequestDischarge(_dischargeRequest:CMIF_DischargeRequest; _sendNote : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realSlotRequest,proxySlotRequest:CM_SlotRequest;
	expectedEdition:Integer;
	aTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	currentTIs : CM_TIArray;
	aVWLE : CM_VoyageWLE;
begin
	self.initialiseActivity();

	
	if _passport.noErrors then
		proxySlotRequest := _dischargeRequest.proxyRequest;
		self.utlUpdateSlotRequest(proxySlotRequest,_passport,_sendNote);
		if _passport.noErrors then
			proxySlotRequest.pxyGetRealObjectAndEdition(realSlotRequest, expectedEdition);
			if realSlotRequest = null then	
				app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotRequest.name, null, null);
				return;
			endif;
			// this discharge may have more than 1 item of cargo in the slot so create many WLEs
			if realSlotRequest.isDischarge then //and realSlotRequest.mySlotController.allTrackedItems.size &gt; 1 then
				// all this adds all the TIs that should be on the request and then checks to see if any were removed
				create currentTIs transient;
				realSlotRequest.getAllTrackedItems(currentTIs);
				foreach aTI in _dischargeRequest.allTrackedItems do
					if not currentTIs.includes(aTI) then
						aVWLE := null;
						realSlotRequest.addWLE(aVWLE,aTI); // this wle is IO so nullit each time, 
					endif;
				endforeach;
				aVWLE := null;
				foreach aTI in currentTIs do
					if not _dischargeRequest.allTrackedItems.includes(aTI) then
						realSlotRequest.removeWLE(aVWLE,aTI);
					endif;

				endforeach;
			endif;
		endif;
	endif;
epilog
	delete currentTIs;
end;</source>
        <Parameter name="_dischargeRequest" type="CMIF_DischargeRequest"/>
        <Parameter name="_sendNote" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestLinkSOBDLR" id="4275c3a2-ec0d-4ac5-98a3-5e9a577eab6c">
        <source>utlUpdateSlotRequestLinkSOBDLR(_slotRequestFrom:CM_Request input;_slotRequestTo:CM_Request;  _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	theLinkSlotReq, 
	aftSlotReq,
	aftAftSlotReq, 
	pxyRequest 		: CM_Request;
	aDischargeTI 	: CM_TrackedItem;
	theLoadSlot		: CM_LocationsController;
	tmpVoyage		: CM_Voyage;
begin

	self.initialiseActivity();

	if _slotRequestFrom = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotRequestFrom', null, null);
		return;
	endif;

	exclusiveLock(_slotRequestFrom);
	
	tmpVoyage := _slotRequestFrom.getVoyage() ; // PAR 28968 mySlotController.myVoyage;
	
	if _slotRequestTo &lt;&gt; null then
		exclusiveLock(_slotRequestTo);

		if tmpVoyage &lt;&gt; _slotRequestTo.getVoyage() then // PAR 28968 mySlotController.myVoyage then
			app.raiseUnexpectedProgramError(class.name, method.name, 'loadRequest voyage (' &amp; tmpVoyage.String &amp; 
						') does not match dischargeRequest voyage (' &amp; _slotRequestTo.getVoyage().String &amp; ')');
			return;
		endif;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	if _slotRequestTo = null then
		theLinkSlotReq := _slotRequestFrom.getLinkedRequest(_slotRequestFrom.isReleaseType); // PAR 28968 getDLRSOBRequestLink();
	else
		theLinkSlotReq := _slotRequestTo;
	endif;

	_slotRequestFrom.setLinkedRequest(_slotRequestTo); // PAR 28968 setDLRSOBRequestLink(_slotRequestTo);
	
	if _slotRequestFrom.isKindOf(CM_SlotRequest) then
		// if we are linking these after an auto create of the load then 
		// we should set the load colour coding to match the TI
		// we will take it that the commodity being null means that this auto 
		// load is here for the first time and not being re-linked
		if _slotRequestFrom &lt;&gt; null and _slotRequestTo &lt;&gt; null then // we may be de linking
			aDischargeTI := _slotRequestTo.getLC().allTrackedItems.first; // PAR 28968  mySlotController.allTrackedItems.first;
			// PAR 28968 if _slotRequestFrom.getAttrCommodityGroup() = null then 
			if _slotRequestFrom.getFirstAllocation() = null then // PAR 28968 make sure we do not have any colour coding
				// get the discharge colour coding TI
				if aDischargeTI &lt;&gt; null then
					_slotRequestFrom.setFromTI(aDischargeTI); // PAR 28968 , _slotRequestTo.getAttrIs40()); // this is setting a real
					
					// if auto linking and colour coding we may need to do the CC for the 40 backends
					if _slotRequestFrom.getAttrIs40() 
					or (not _slotRequestFrom.isBackEndRequest() // PAR 28968 isBackend 
					and (_slotRequestFrom.getAttrIs30() or _slotRequestFrom.getAttrIs53() or _slotRequestFrom.getAttrIs45())) then // PAR 18823
						aftSlotReq := _slotRequestFrom.getAftRequest();  //PAR 28968 getAftSlotRequest();
						if aftSlotReq = null then
							theLoadSlot := _slotRequestFrom.getLC(); // PAR 28968 mySlotController; 
							
							if theLoadSlot.getAftLC() = null then // PAR 28968 myAftSlot = null then // PAR 20699
								app.raiseCMException3(NO_DLR_AFT_SLOT, aDischargeTI.id, aDischargeTI.getActualLength().String, theLoadSlot.getFullId(), null, theLoadSlot); // PAR 20699
							endif;
							
							theLoadSlot.CM_SlotController.createAftSlotRequest(_slotRequestFrom, _passport);
							
							// PAR 18823
							if _slotRequestFrom.getAttrIs53() then
								aftSlotReq := _slotRequestFrom.getAftRequest(); // PAR 28968 getAftSlotRequest();
								if aftSlotReq &lt;&gt; null then
									aftAftSlotReq := aftSlotReq.getAftRequest(); // PAR 28968 getAftSlotRequest();
									if aftAftSlotReq = null then
										theLoadSlot := aftSlotReq.getLC(); // PAR 28968 mySlotController; 
										theLoadSlot.CM_SlotController.createAftSlotRequest(aftSlotReq, _passport);
									endif;
								endif;
							endif;
						else
							// set the properties on the real slot request from the front end
							exclusiveLock(aftSlotReq);
							aftSlotReq.CM_SlotRequest.set40AttribsFromFrontEnd(_slotRequestFrom.CM_SlotRequest);
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this slot
		_slotRequestFrom.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),false, _slotRequestFrom.getLC());
		if theLinkSlotReq &lt;&gt; null then
			theLinkSlotReq.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),false, theLinkSlotReq.getLC()); //mySlotController);
		endif;
		if aftSlotReq &lt;&gt; null then
			aftSlotReq.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aftSlotReq.getLC());
		endif;
	endif;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_slotRequestFrom" type="CM_Request" usage="input"/>
        <Parameter name="_slotRequestTo" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestLnkControl" id="212d0ed6-f7f8-44e9-8ad0-25962ad08c0b">
        <source>utlUpdateSlotRequestLnkControl(_theRequests:CMIF_SlotRequestLinker; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	leftSlotRequest, rightSlotRequest :CM_Request;
	realLeftSlotRequest, realRightSlotRequest :CM_Request;
	expectedEdition:Integer;
	aTI : CM_TrackedItem;
	imex : Integer;
	idx : Integer;
	realSlotController : CM_LocationsController;
begin
	self.initialiseActivity();


	app.setContinueCMExceptions(true);

	if _theRequests.allProxyRequests.size &lt;&gt; _theRequests.allLinkedProxyRequests.size then
		app.raiseCMException2(ERR_INVALID_VALUE,"selected requests", "You have selected different numbers of slot requests to link.", null, null);
		return;	
	endif;
	/* PAR 32120 left is the discharge CC, right is the load CC
	foreach leftSlotRequest in _theRequests.allProxyRequests do
		idx := idx + 1;
		rightSlotRequest := _theRequests.allLinkedProxyRequests[idx];
		leftSlotRequest.validateRequestLink(rightSlotRequest);
	endforeach;
	*/
	// PAR 32120 left is the discharge CC, right is the load CC
	foreach leftSlotRequest in _theRequests.allLinkedProxyRequests do
		idx := idx + 1;
		rightSlotRequest := _theRequests.allProxyRequests[idx];
		leftSlotRequest.validateRequestLink(rightSlotRequest);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
	endif;
	
	if _passport.noErrors then
		// de link
		idx := 0;
		foreach leftSlotRequest in _theRequests.allProxyRequests do
			idx := idx + 1;
			realLeftSlotRequest := leftSlotRequest.pxyGetRealObject.CM_Request;
			self.utlUpdateSlotRequestLinkSOBDLR(realLeftSlotRequest,null,_passport);
		endforeach;
		// re link
		idx := 0;
		foreach leftSlotRequest in _theRequests.allProxyRequests do
			idx := idx + 1;
			rightSlotRequest := _theRequests.allLinkedProxyRequests[idx];
			
			realLeftSlotRequest := leftSlotRequest.pxyGetRealObject.CM_Request;
			realRightSlotRequest := rightSlotRequest.pxyGetRealObject.CM_Request;
			self.utlUpdateSlotRequestLinkSOBDLR(realLeftSlotRequest,realRightSlotRequest,_passport);
		endforeach;
	endif;
epilog
end;</source>
        <Parameter name="_theRequests" type="CMIF_SlotRequestLinker"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestRORO" id="f2ea0ad8-3d76-4e54-b46a-38d91ce64d5a">
        <source>utlUpdateSlotRequestRORO(_proxySlotRequest:CM_RORORequest; _passport : CM_Passport input; _sendNote : Boolean);
/*
Purpose:			
Date		Who			Reason
JUNE 2011	CNWAB1		Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
31 Mar 2025 navma1 		MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	realSlotRequest		: CM_RORORequest;
	expectedEdition		: Integer;
	aTI, 
	unplanTI 			: CM_TrackedItem;
	realSlotController  : CM_VoyageROROController;
	oldMoveType 		: Integer;
	tmpVoyage			: CM_Voyage;
	tmpEvent			: Integer;
	wle					: CM_WorkListEntry;		// PAR #26426
	tmpReserve			: CM_ReserveDetail;		// PAR #26426
begin
	self.initialiseActivity();

	_proxySlotRequest.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySlotRequest.pxyGetRealObjectAndEdition(realSlotRequest, expectedEdition);
	if realSlotRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SlotRequest.name, null, null);
		return;
	endif;
	app.myValUA.valSlotRequestRORO(realSlotRequest, _proxySlotRequest);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	realSlotController := realSlotRequest.myROROController;
	exclusiveLock(realSlotRequest);

	if _passport.noErrors and realSlotRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(SlotRequest), null, null);
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	// ################
	// ################
	aTI := realSlotRequest.getTrackedItem(); // PAR 6319 do this here as it gets dettached in the set for update, especially if we are erasing
	// PAR #26426 if the TI in this slot is not null, remember the wle for later so we can notify the Ship Load List of a change
	if aTI &lt;&gt; null then
		wle := realSlotRequest.allWorkListEntries.first;
		// if the TI in this slot is a TBA, clear the reference - it will be deleted in CM_SlotRequest setForUpdate/createWLEs methods
		if aTI.isTBA and _passport.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
			aTI := null;
		endif;
	endif;
	// PAR #26426 end
	unplanTI    := aTI;
	oldMoveType := realSlotRequest.moveType;
	tmpReserve  := realSlotRequest.myBulkReleaseReserveDetail;	// PAR #26426
	
	realSlotRequest.setForUpdate(_proxySlotRequest);



	if aTI = null then // PAR 6319 if we are updating then the TI will now be attached
		aTI := realSlotRequest.getTrackedItem(); // PAR 6319 // do this here as it gets dettached in the set for update
	endif;
	if _passport.noErrors then
		// we have to set the TI status if this IS a DLR or SOB back to DLR or SOB
		if aTI = null then
			aTI := unplanTI;
		endif;
		if aTI &lt;&gt; null then

			if realSlotRequest.isRehandle then
				// if DLR do not change the IMEX - Import Export Transit etc
				aTI.setTransitStatus(TI_TransitStatusDLR, true, _passport);
			elseif realSlotRequest.isSoB then
				// if SOB do not change the IMEX - Import Export Transit etc
				aTI.setTransitStatus(TI_TransitStatusSOB, true, _passport);
			elseif realSlotRequest.moveType = DISCHARGE_MOVETYPE then
				// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: aTI.statusEvent signature changed.
				aTI.statusEvent(DIS_CCODE_STATUS_EV, true, _passport);
			elseif realSlotRequest.moveType = LOAD_MOVETYPE then
				// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: aTI.statusEvent signature changed.
				aTI.statusEvent(LOAD_CCODE_STATUS_EV, true, _passport);
			elseif realSlotRequest.moveType = NULL_MOVETYPE then
				aTI.setTransitStatus(TI_TransitStatusNull, true, _passport); // not DLR or SOB
				if aTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
					if oldMoveType = DISCHARGE_MOVETYPE then
						aTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
					elseif oldMoveType = LOAD_MOVETYPE then
						aTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					else
						aTI.setImExStatus(TI_IMEX_STATUS_NULL);
					endif;
				endif;													// PAR #23645 CCMS 1116
			endif;						
		endif;
	endif;

	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this slot
		if _sendNote then
			if realSlotRequest.myJob &lt;&gt; null then
				realSlotRequest.myJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
			endif;
			tmpVoyage := realSlotRequest.myROROController.myVoyage;
			tmpEvent  := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
			tmpVoyage.causeEvent(tmpEvent, false, realSlotRequest.myROROController);
			if wle &lt;&gt; null then
				wle.causeEvent(_passport.myTerminal.getTerminalEvent(WLE_Update_Event), false, wle);
			endif;
			if tmpReserve &lt;&gt; null then
				tmpReserve.myReserveHeader.causeUpdateEvent;
			endif;
			// PAR #26426 end
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_RORORequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_sendNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSlotRequestSeqNum" id="9388025c-fe2a-4b81-ba4b-034b659a633e">
        <source>utlUpdateSlotRequestSeqNum(_theSlots:CMIF_CustomSequence; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realSlotRequest : CM_SlotRequest;
	idx				: Integer;
begin
	self.initialiseActivity();

	
	if _passport.noErrors then
		foreach realSlotRequest in _theSlots.allSlotRequests do
			
			idx := idx + 1;
			if realSlotRequest &lt;&gt; null then
				exclusiveLock(realSlotRequest);
				realSlotRequest.setCustomSeqNumber(_theSlots.allSeqNumbers[idx], _theSlots.isStarboardBerthed);
				if _passport.noErrors then
					// ################################
					// This will update the display on screen of this slot
					realSlotRequest.mySlotController.myBayVoyage.myCellularVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), 
									false, realSlotRequest.mySlotController);
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_theSlots" type="CMIF_CustomSequence"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSnapShot" id="3335ac4a-70c2-4866-89e4-1c78247e67ab">
        <source>utlUpdateSnapShot(_pxySnapShot: CM_UserTISnapShot; _realUserSnap: CM_UserTISnapShot input; _changeReason: CM_MessageUser; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	realChangeReason	: CM_MessageUser;
	voyage				: CM_Voyage;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if _realUserSnap = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_UserTISnapShot.name, null, null);
		return;
	endif;
	
	if _changeReason &lt;&gt; null
	and _changeReason.text = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Change Reason", null, null);
		app.raiseCMException(Input_required_field_changeRea, null, null); // cnwdb2	PAR 35364
	endif;
		
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realUserSnap);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realUserSnap, true);
	endif;
	
	_realUserSnap.setForUpdate(_pxySnapShot, _passport);
	
	if _passport.noErrors then
		if _changeReason &lt;&gt; null then
			create realChangeReason persistent;
			realChangeReason.setForCreateFromProxy(_changeReason);
			_realUserSnap.addChangeNote(realChangeReason);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realUserSnap, false);
	endif;
	
	if _passport.noErrors and 
	   _realUserSnap.myTISnapShot &lt;&gt; null then
	   
		self.updateObjectEdition(_realUserSnap.myTISnapShot);	// par 30292
		
		voyage := _realUserSnap.myTISnapShot.getVoyage();
		if voyage &lt;&gt; null then
			voyage.causeEvent(Event_HatchSummary_Update, false, _realUserSnap.myTISnapShot);
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' sending note  ' &amp; voyage.String);
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' no note no voyage');
		endif;
	else
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' no note xxx ');
	endif;
end;</source>
        <Parameter name="_pxySnapShot" type="CM_UserTISnapShot"/>
        <Parameter name="_realUserSnap" type="CM_UserTISnapShot" usage="input"/>
        <Parameter name="_changeReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSnapShotHide" id="2abc1fa7-5ace-471f-affc-706858503cbf">
        <source>utlUpdateSnapShotHide(_userSnap: CM_UserTISnapShot input; _setHidden : Boolean; _changeReason: CM_MessageUser; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//  RBarr 14/7/2006 Or show items currently hidden
//----------------------------------------------------------------
vars
	realChangeReason	: CM_MessageUser;
	voyage				: CM_Voyage;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if _changeReason &lt;&gt; null
	and _changeReason.text = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Change Reason", null, null);
		app.raiseCMException(Input_required_field_changeRea, null, null); // cnwdb2	PAR 35364
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_userSnap);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_userSnap, true);
	endif;
	
	if _passport.noErrors then
		_userSnap.setIgnore(_setHidden);
		if _changeReason &lt;&gt; null then
			create realChangeReason persistent;
			realChangeReason.setForCreateFromProxy(_changeReason);
			_userSnap.addChangeNote(realChangeReason);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_userSnap, false);
	endif;
	
	if _passport.noErrors and _userSnap.myTISnapShot &lt;&gt; null then
	
		self.updateObjectEdition(_userSnap.myTISnapShot);	// par 30292
		
		voyage := _userSnap.myTISnapShot.getVoyage();
		if voyage &lt;&gt; null then
			voyage.causeEvent(Event_HatchSummary_Update, false, _userSnap.myTISnapShot);
		endif;
	endif;
end;</source>
        <Parameter name="_userSnap" type="CM_UserTISnapShot" usage="input"/>
        <Parameter name="_setHidden" type="Boolean"/>
        <Parameter name="_changeReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSnapshotCharge" id="0fab391d-57c7-4190-a1a8-7de4fb553858">
        <source>utlUpdateSnapshotCharge(_snapshotBroker : CM_SnapShotServiceBroker; _snapshotData : CM_SnapshotData; _passport : CM_Passport input);
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);

	exclusiveLock(_snapshotBroker);

	if _passport.noErrors then
		_snapshotBroker.createCharge(_snapshotData);
