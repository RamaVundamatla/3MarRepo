    <JadeMethod name="setupMyVehicle" id="72c6c3c9-5542-4c58-85e3-13878ba4c987">
        <updating/>
        <source>setupMyVehicle() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
