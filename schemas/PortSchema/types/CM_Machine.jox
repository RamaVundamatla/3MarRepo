    <JadeMethod name="getWorkzoneDefault" id="5c1fa31a-3d12-4567-857c-4cfe6e5ffd99">
        <source>getWorkzoneDefault(_startCol, _endCol : CM_RTGColumn output; _taMaster : CM_TerminalAreaMaster output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myPrimaryQueue = null then
		return;
	endif;
				
	if not self.myPrimaryQueue.isKindOf(CM_SubQueue) then
		return;
	endif;
			
	self.myPrimaryQueue.CM_SubQueue.getDefaultWorkzone(_startCol, _endCol, _taMaster);
	
	
	if self.myPhysicalStartBay &lt;&gt; null and self.myPrimaryQueue.CM_SubQueue.allMoveFromTAMasters.includes(self.myPhysicalStartBay.myGridArea) then
		_startCol:=self.myPhysicalStartBay;
	endif;
	
	if self.myPhysicalEndBay &lt;&gt; null and self.myPrimaryQueue.CM_SubQueue.allMoveFromTAMasters.includes(self.myPhysicalEndBay.myGridArea) then
		_endCol:=self.myPhysicalEndBay;
	endif;
	
epilog

end;</source>
        <Parameter name="_startCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_endCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWorkzoneLocsFromColumn" id="defba7e9-499b-4b2b-8e93-010283f560b4">
        <source>getWorkzoneLocsFromColumn(_ta : CM_GridArea input; _column : CM_RTGColumn input; _allGridLocations : ObjectSet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	wzIter : Iterator;
	gridController : CM_GridController;
begin
	
	wzIter:=self.allWorkzoneLocations.createIterator;
	self.allWorkzoneLocations.startKeyGeq(_ta,_ta.allGridColumns.last.column,_ta.allGridRows.last.row,wzIter);
	while wzIter.back(gridController) do
		if gridController.getMyGridArea &lt;&gt; _ta then
			break;
		endif;
		
		if gridController.myGridColumn = _column then
			break;
		endif;
		
		if not _allGridLocations.includes(gridController) then
			_allGridLocations.add(gridController);
		endif;
			
	endwhile;
	
epilog
	delete wzIter;

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_GridArea" usage="input"/>
        <Parameter name="_column" type="CM_RTGColumn" usage="input"/>
        <Parameter name="_allGridLocations" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWorkzoneLocsUpToColumn" id="614d4e75-eb3b-4d36-86a7-cf024d0d8318">
        <source>getWorkzoneLocsUpToColumn(_ta : CM_TerminalArea input; _column : CM_RTGColumn input; _allGridLocations : ObjectSet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	wzIter : Iterator;
	gridController : CM_GridController;
begin
	
	wzIter:=self.allWorkzoneLocations.createIterator;
	self.allWorkzoneLocations.startKeyGeq(_ta,null,null,wzIter);
	while wzIter.next(gridController) do
		if gridController.getMyGridArea &lt;&gt; _ta then
			break;
		endif;
		if gridController.myGridColumn = _column then
			break;
		endif;
		if not _allGridLocations.includes(gridController) then
			_allGridLocations.add(gridController);
		endif;
	endwhile;
epilog
	delete wzIter;
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_column" type="CM_RTGColumn" usage="input"/>
        <Parameter name="_allGridLocations" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWorkzoneStartEndColumns" id="270f40c5-2aa9-4f7c-a1fc-da65dfa80c02">
        <source>getWorkzoneStartEndColumns(_startCol , _endCol : CM_RTGColumn output ; _taMaster : CM_TerminalAreaMaster output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	startGridControler,
	endGridController,
	gridController		: CM_GridController;
	taIter,
	iter				: Iterator;
	gridArea			: CM_GridArea;
	rtgArea				: CM_RTGArea;
	rtgLane				: CM_RTGLane;
	ta					: CM_TerminalArea;
begin
	if self.allWorkzoneLocations.isEmpty then
		return;
	endif;

	startGridControler:=self.allWorkzoneLocations.first;
	endGridController:=self.allWorkzoneLocations.last;
	gridArea:=startGridControler.getMyGridArea;
	if not gridArea.isKindOf(CM_RTGArea) then
		return;	
	endif;
	
	rtgArea:=gridArea.CM_RTGArea;
	
	
	//simple check is the workzone only in one RTG area if so can just 
	if endGridController.getMyGridArea = gridArea then
		_taMaster:=rtgArea;
		_startCol:=startGridControler.myGridColumn.CM_RTGColumn;
		_endCol:=endGridController.myGridColumn.CM_RTGColumn;
		
		//return we are done that was a the simple case;
		return;
	endif;
	
	rtgLane:=rtgArea.allTerminalAreaGroups.first.CM_RTGLane;
	// first and last controllers aren't in the same area we must have an RTG Lane
	
	if  rtgLane = null then
		return;	
	endif;
	
	startGridControler:=null;
	endGridController:=null;
	taIter:=rtgLane.allTAsByTypeId.createIterator;
	iter:=self.allWorkzoneLocations.createIterator;
	while taIter.next(ta) do
	
		iter.reset;
		self.allWorkzoneLocations.startKeyGeq(ta,null,null,iter);
		while iter.next(gridController) do
			if gridController.getMyGridArea &lt;&gt; ta then
				break;
			endif;
			if startGridControler = null then
				startGridControler:=gridController;
				break;
			else
				break;
			endif;
		endwhile;
		
	
		iter.reset;
		self.allWorkzoneLocations.startKeyLeq(ta,ta.CM_GridArea.allGridColumns.last.column,ta.CM_GridArea.allGridRows.last.row,iter);
		while iter.back(gridController) do
			if gridController.getMyGridArea &lt;&gt; ta then
				break;
			endif;
			//found it can break
			endGridController:=gridController;
			break;
			
		endwhile;
		
	endwhile;
	
	_taMaster:=rtgLane;
	_startCol:=startGridControler.myGridColumn.CM_RTGColumn;
	_endCol:=endGridController.myGridColumn.CM_RTGColumn;
epilog
	delete taIter;
	delete iter;
end;</source>
        <Parameter name="_startCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_endCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster" usage="output"/>
    </JadeMethod>
