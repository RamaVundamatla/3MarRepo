	self.txtPreviousNames.visible	:=	_enabled;
	self.txtRemarkGeneral.visible	:=	_enabled;
	self.txtRemarksPilot.visible	:=	_enabled;
	self.txtRemarksVoyage.visible	:=	_enabled;
	self.lblPilotRemarks.visible	:=	_enabled;
	self.lblPilotSecurity.visible	:=	_enabled;
	self.lblGeneralRemark.visible	:=	_enabled;
	self.lblPreviousNames.visible	:=	_enabled;
	self.lblVoyageComment.visible	:=	_enabled;
	self.shtHMSMoveRes.visible		:=	_enabled;

epilog

end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHoursFromDateTime" id="be01843a-07d8-4c12-a411-23c6b62e6fa1">
        <source>setHoursFromDateTime(_textbox : TextBox input; _date : CMUI_DateMask input; _time : CMUI_TimeMask input);
/*
Purpose:	

Date		Who		Reason
11 March 2025	navab1	JIRA 34233
*/

vars

	hours : Decimal[23,2];
	targetTS, newTS : TimeStamp;
begin

	if self.myProxyCutoff= null then
		return;
	endif;
	targetTS := self.getCutoffRelativeToTS(self.myProxyCutoff.defaultRelativeTo);

	newTS.setDate(_date.getDate);
	newTS.setTime(_time.getTime);
	
	hours := newTS.differenceInHoursReal(targetTS);
	if targetTS &lt; newTS then
		hours := hours * -1;
	endif;
	
	if hours &gt; 9999.99 or hours &lt; -9999.99 then
		app.msgBox("There is an issue with the date " &amp; newTS.asStringJMT() &amp; ", relative to " &amp; targetTS.asStringJMT() &amp; ", resulting in an hours value that is greater than 99 or less than -99",app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	_textbox.text := hours.asStringJMT();
epilog

end;</source>
        <Parameter name="_textbox" type="TextBox" usage="input"/>
        <Parameter name="_date" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_time" type="CMUI_TimeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVessel" id="cc205987-4892-4275-afa3-57f1914726ad">
        <updating/>
        <source> setMyCurrentVessel(_vessel: CM_Vessel) updating;
//--------------------------------------------------
// Created:	01 April 2004 By: cnwgd1
//--------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
12/06/2018	jlgrh7 	TFS 39105		LNX - RE: Ticket 38780 - Voyage Definition 'External Code' Value
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
05/03/2019	jlgka1	TFS 37102		STWR - Move isBarges Flag to setDefaultsFromVessel.
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
============================================================================*/
vars
	terminalObj			: CM_Terminal;
	realTermObj			: CM_Terminal;
	vesselTermDataObj	: CM_VesselTerminalData;
	hasHarbourDetails 	: Boolean;
	externalCode		: String;						// TFS 4050
begin
	if _vessel = self.myCurrentVessel then
		return;
	endif;
	
	self.myCurrentVessel	:=	_vessel;
	terminalObj				:=	self.myTerminal;
	
	if _vessel = null then
		// self.ckbCreateStructu.value := false;   31232
		return;
	endif;
	
	// only prefill fields when adding as can't update this field	
	if self.mode = self.Mode_View then
		return;
	endif;
	
	hasHarbourDetails := self.myCurrentVessel.hasHarbourDetails(); // PAR 36959
	// Set from vessel	
	self.setEnableHMSData(hasHarbourDetails); // PAR 36959

	if self.mode = self.Mode_Add then
		// Set from vessel	

		self.ckbCreateHMSData.value := hasHarbourDetails; // PAR 36959
		self.ckbCreateHMSData.enabled := false; // PAR 36959
		
		// Clear harbour data
		self.tblBerthPref.rows		:=	self.tblBerthPref.fixedRows;
		self.tblDelays.rows			:=	self.tblDelays.fixedRows;
		self.tblHMSMovements.rows	:=	self.tblHMSMovements.fixedRows;
		self.cmbBerthPref.clear();
		self.optBerthPref.value		:=	false;
		self.optBerth.value			:=	true;
		self.mulStevedoreDisc.setSelected(null);
		self.mulStevedoreLoad.setSelected(null);
		self.mulOperators.setSelected(null); //ccms 1058
		self.lstPortsOfCall.clear; //ccms 1058
		self.cmbTrade.listIndex:=-1;
		self.chkUseVoyageAllo.value := true; //cnwrd1 par 34233		
		
		self.setDefaultsFromVessel(_vessel);
		
		if self.myCurrentVoyage = null and terminalObj &lt;&gt; null then
			realTermObj			:=	terminalObj.getRealTerminal();
			vesselTermDataObj	:=	_vessel.allTerminalDatas[realTermObj];
			
			if vesselTermDataObj &lt;&gt; null and (not vesselTermDataObj.isUseTerminalDefaults) then
				txtWTimeInPort.cnEcSet(vesselTermDataObj.grossLoadingTime.String);
				txtWTimeInPort.cnEcSet(vesselTermDataObj.grossDischargeTime.String);
				txtWNoChargeTime.cnEcSet(vesselTermDataObj.nonChargeTime.String);
				cmbWStopCharging.cnEcSetTextIndex(vesselTermDataObj.stopChargingAt.String);
				txtWLoadRate.cnEcSet(vesselTermDataObj.vesselLoadRate.String);
				txtWDischargeRat.cnEcSet(vesselTermDataObj.vesselDischargeRate.String);
			endif;
		endif;
		
	//	externalCode := self.myTerminal.getNextVoyageExternalCode(_vessel);			// TFS 4050			//-TFS39105 Move to transaction layer
	//	self.txtExternalCode.text := externalCode;									// TFS 4050
	else
		self.ckbCreateHMSData.value := hasHarbourDetails; // PAR 36959
		self.ckbCreateHMSData.enabled := false; // PAR 36959
		// Vessel combo is enabled therefore original vessel must have been deleted	
		// populate the vessel name and vessel code fields only
		self.txtVesselCode.text := _vessel.code;
		self.txtVesselName.text := _vessel.name;		
	endif;

	if self.myHarbour &lt;&gt; null then
		self.txtImasVoyageNum.text := self.myHarbour.getVesselVisitCountStr(self.myCurrentVessel.code, null);    
	else
		self.txtImasVoyageNum.text := self.myTerminal.getVesselVisitCount(self.myCurrentVessel.code, null).String;    			
	endif;		
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="b8eb9ba0-fadc-4fb2-a769-e557688b59fd">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage)updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
begin	
	//05 Apr 2012	NDL	Par 29369
	if self.myCurrentVoyage &lt;&gt; null then
		if self.wpTableNote then
			self.wpTableNote := false;
			self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event));
			self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_CREATE));	// PAR #35397
			self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_UPDATE));	// PAR #35397
			self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_DELETE));	// PAR #35397
			self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(ROROExportAutoQueue));	 // ### TFS CR 57138 TASK 57310 28MAR2023 NAVAB1
		endif;
	endif;
	
	self.myCurrentVoyage := null;
	self.myCopyGCStruct := null;	//10 Jul 2013	NDL	Par 31965
	self.myCurrentVoyageData := null;
	self.myCurrentVessel := null;

	self.endVesselStructureNotes();

	self.allProxyCutoffs.purge(); // ### JIRA 34233 11MAR 2025 NAVAB1
	
	if global.isValidObject(_voyage) then
		self.myCurrentVoyage := _voyage;	
	else
		self.cmbVoyage.clear();
		self.cmbVoyage.initialise(false);
	endif;
	
	setupComboStatus();		//cnwmc5 - 26 July 2013 - PAR 31714

	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyageData := self.myCurrentVoyage.myHMSVoyageData;
		self.myCurrentVessel := self.myCurrentVoyage.getMyVessel();
		
		if (not self.viewModeOnly) then //&lt;&lt;-- also view move is voyage is archived
			self.viewModeOnly := (not app.myCurrentUserCan(self.myCurrentVoyage.myTerminal, PmAdmVoyageDefEdit));
			
			if self.viewModeOnly then
				// user cannot update this voyage - set to view only
				self.setToViewMode();
			else
				self.btnEditTV.enabled := (not self.myCurrentVoyage.archived);
			endif;
		endif;
		
	else
		self.setToViewMode();
	endif;

	self.displayVoyage(false); //&lt;-- data cleared here if the current voyage is null

	self.startVesselStructureNotes();
	//05 Apr 2012	NDl	Par 29369
	if self.myCurrentVoyage &lt;&gt; null and not self.wpTableNote then
		self.wpTableNote := true;
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_CREATE), Response_Continuous, null);	// PAR #35397
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_UPDATE), Response_Continuous, null);	// PAR #35397
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_DELAY_DELETE), Response_Continuous, null);	// PAR #35397
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(ROROExportAutoQueue), Response_Continuous, null);	 // ### TFS CR 57138 TASK 57310 28MAR2023 NAVAB1
	endif;
	self.btnShippingAgent.enabled	:=	self.cmbShippingAgent.listObject &lt;&gt; null;
	self.btnShippingLine.enabled	:=	self.cmbShippingLine.listObject &lt;&gt; null;
	
	// ### JIRA 34233 06MAR 2025 NAVAB1
	if self.myCurrentVoyage&lt;&gt; null then
	self.ckbPrenoteCutoffs.value := self.myCurrentVoyage.shipCutoffsForPrenotes;
	else
		self.ckbPrenoteCutoffs.value := self.myTerminal.getConfig(ShipCutoffsForPrenotes).Boolean;
	endif;
	self.frmCutoffDataEntryPN.visible := self.ckbPrenoteCutoffs.value;
	
	self.doResizeTopSheet();
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="18ff541e-673f-44f9-80e1-6e94f335a53f">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _obj: CM_Object input; _entryTable: CM_EntryTable): Boolean;
//--------------------------------------------------
// Created:	30 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _attrName = ETRow_MyTidalClassArrival then
		_obj.setPropertyValue(HMS_VoyageData::myTidalClass.name, self.cmbTidalClassAr.listObject);	
		return true;
	elseif _attrName = ETRow_HasFixedProp then
		_obj.setPropertyValue(HMS_VoyageData::hasFixedProp.name, _strValue = app.getErrorString(HMS_Fixed));	
		return true;
	elseif _attrName = ETRow_CountryCode then
		if self.cmbCountry.listObject &lt;&gt; null then
			_obj.setPropertyValue(HMS_VoyageData::countryCode.name, self.cmbCountry.listObject.CM_Country.code);
		else
			_obj.setPropertyValue(HMS_VoyageData::countryCode.name, null);							
		endif;
		return true;								

	elseif _attrName = ETRow_MyPortFrom then
		//if self.cmbPortFrom.listObject &lt;&gt; null then
		if self.cmbPortFrom.myObject &lt;&gt; null then
			_obj.setPropertyValue(HMS_VoyageData::portArrivingFromCode.name, self.cmbPortFrom.listObject.CM_Port.code);
		else
			_obj.setPropertyValue(HMS_VoyageData::portArrivingFromCode.name, null);							
		endif;
		return true;						
	
	elseif _attrName = ETRow_MyPortTo then
		//if self.cmbPortTo.listObject &lt;&gt; null then
		if self.cmbPortTo.myObject &lt;&gt; null then
			_obj.setPropertyValue(HMS_VoyageData::portDepartingToCode.name, self.cmbPortTo.listObject.CM_Port.code);
		else
			_obj.setPropertyValue(HMS_VoyageData::portDepartingToCode.name, null);							
		endif;
		return true;								
		
	endif;
	
	return false;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_entryTable" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyCutoffsPN" id="16696bfa-701b-4217-bea0-ffefe71fb2e8">
        <source>setProxyCutoffsPN(_allRecCutoffs : CM_RecCutoffVoyByCodeOp input; _pxyVoyage : CM_Voyage);

/*
Date		Who		Reason

// ### JIRA 34233 10MAR 2025 NAVAB1
*/
vars
	recCutoff	 			: CM_ReceivalCutoffVoyage;
	idx						: Integer;
	fromIDX, toIDX : Integer;
	handlePrenotes : Boolean;
begin
	 // ### JIRA 35634 12AUG2025 NAVAB1
	handlePrenotes := self.myTerminal.getConfig(ShipCutoffsForPrenotes).Boolean;
	if not handlePrenotes then
		handlePrenotes := self.ckbPrenoteCutoffs.value;
	endif;

	
	//not overriden not need to save on proxy and then on the real ti
	if not self.ckbOverrideDef.value then
		_allRecCutoffs.purge();  // ### JIRA 34524 08APR2025 NAVAB1
		return;
	endif;
	
	_allRecCutoffs.clear();
	
	fromIDX := self.tblVoyageCutoffs.fixedRows + 1;
	toIDX := self.tblVoyageCutoffs.rows;
	
	foreach idx in fromIDX to toIDX do
		recCutoff := self.tblVoyageCutoffs.accessRow(idx).itemObject.CM_ReceivalCutoffVoyage;
		
		recCutoff.setProxyVoyage(_pxyVoyage);
		
		if not handlePrenotes then
			recCutoff.nullPrenoteCutoffs();
		endif;
		
		_allRecCutoffs.add(recCutoff);
	endforeach;
end;</source>
        <Parameter name="_allRecCutoffs" type="CM_RecCutoffVoyByCodeOp" usage="input"/>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setProxyDefaultResources" id="b2a23475-ad2a-48eb-8a08-f4137d565acf">
        <source>setProxyDefaultResources(_pxyHMSVoyage : HMS_VoyageData input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	numTugs 		: Integer;
	moveType 		: String;
	coll 			: ObjectArray;
	harbour 		: HMS_Harbour;
  	moveResource 	: HMS_ResourceTypeForMovement;
begin
  
	// This method updates invoice resources set as default for a vessel
	if (not self.shtHMSMoveRes.visible) then
		return;
	endif;
	
	if self.mode = self.Mode_View then
		return;
	endif;
	
	if _pxyHMSVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy');
		return;
	endif;
	
	create coll transient;
	harbour := _pxyHMSVoyage.myHarbour;
	
	// set default resources for the arrival movement
	moveType := HMSMovementTypeArrival;
	numTugs := self.txtTugsMArrival.text.Integer;
	if self.lstResTypeArriva.allSelectedObjects &lt;&gt; null then
		self.lstResTypeArriva.allSelectedObjects.copy(coll);
	endif;

	moveResource := _pxyHMSVoyage.allDefaultMovementResources[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyHMSVoyage.allDefaultMovementResources.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, harbour, coll);
	
	// set default resources for the shift movement
	coll.clear();
	moveType := HMSMovementTypeShift;
	numTugs := self.txtTugsMShift.text.Integer;
	if self.lstResTypeShift.allSelectedObjects &lt;&gt; null then
		self.lstResTypeShift.allSelectedObjects.copy(coll);
	endif;
	
	moveResource := _pxyHMSVoyage.allDefaultMovementResources[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyHMSVoyage.allDefaultMovementResources.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, harbour, coll);

	// set default resources for the departure movement
	coll.clear();
	moveType := HMSMovementTypeDeparture;
	numTugs := self.txtTugsMDepart.text.Integer;
	if self.lstResTypeDepart.allSelectedObjects &lt;&gt; null then
		self.lstResTypeDepart.allSelectedObjects.copy(coll);
	endif;
	
	moveResource := _pxyHMSVoyage.allDefaultMovementResources[moveType];
	if moveResource = null then
		create moveResource transient;
		_pxyHMSVoyage.allDefaultMovementResources.add(moveResource);  
	endif;
	
	moveResource.setProxy(moveType, numTugs, harbour, coll);

epilog
	delete coll;  	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyHMSVoyage" type="HMS_VoyageData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyHMSVoyage" id="2bf435d2-e132-47f3-800b-c3db9cbed590">
        <source>setProxyHMSVoyage(_theProxy : CM_Voyage input);
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 14/02/2014	cnwdap1		PAR #33504 Ensure preferred berth orientation carries through to exchange details
// 16/02/2021	navdap1		TFS 50759 PNL Berth orientation specific to a berth
vars
	row,
	numFix,
	numRows : Integer;
	pxyHMSVoyage : HMS_VoyageData;
	pxyPref,
	berthPref : HMS_BerthPreferenceVoyageData;
	addMovements : Boolean;
	tmpBerth : HMS_Berth;
	tmpBerthPref : HMS_BerthPreference;	
	
begin
	
	//Note: they can't change this field if the HMSVoyageData already exists
//	14/8/19 MAP TFS45926
//	if (not self.ckbCreateHMSData.value) then
		//User does not want to create HMS data at this time
		pxyHMSVoyage := _theProxy.myHMSVoyageData;
//		if pxyHMSVoyage &lt;&gt; null then
//			_theProxy.setHMSVoyageData(null);
//			delete pxyHMSVoyage;	
//		endif;
//		return;
//	endif;	
	
	pxyHMSVoyage := _theProxy.myHMSVoyageData;

	if pxyHMSVoyage = null then
		create pxyHMSVoyage transient;
		_theProxy.setHMSVoyageData(pxyHMSVoyage);
		addMovements := true;
	else
		//31 Dec 2019	NDL	TFS 48162
		if pxyHMSVoyage.allVoyageMovements.isEmpty and self.ckbCreateHMSData.value then
			addMovements := true;
		endif;
	endif;

	pxyHMSVoyage.allStevedoresDischarge.clear();
	pxyHMSVoyage.allStevedoresLoad.clear();
	self.mulStevedoreDisc.getSelected(pxyHMSVoyage.allStevedoresDischarge);
	self.mulStevedoreLoad.getSelected(pxyHMSVoyage.allStevedoresLoad);			

	self.setProxyVoyageData(pxyHMSVoyage);

	if not self.ckbCreateHMSData.value then
		return;
	endif;

	if (not self.shtHMSHarborData.visible) then
		//Can't be Licenced for HMS 
		return;
	endif;
	
	addMovements := pxyHMSVoyage.allVoyageMovements.isEmpty;
	
	//Set commodities
	//pxyHMSVoyage.allCommodityDischarge.clear(); 	// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	//pxyHMSVoyage.allCommodityLoad.clear();		// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	
	//self.mulCommodityDisc.getSelected(pxyHMSVoyage.allCommodityDischarge);	// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	//self.mulCommodityLoad.getSelected(pxyHMSVoyage.allCommodityLoad);			// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	
	
	//Set Berth Preferences
	 // PAR 11306 this has PROXIES, later in this code it is populated with transients. 
	 //				If an error occurs during save, the proxies are left behind and the transients are deleted. 
	 //				This gives an error if the user clicks save again as it is trying to re do the proxy berth prefs.
	pxyHMSVoyage.allBerthPreferencesArray.purge();	
	numRows := self.tblBerthPref.rows;
	numFix := self.tblBerthPref.fixedRows;
	
	foreach row in numFix to numRows do
		tmpBerthPref := self.tblBerthPref.accessRow(row).itemObject.HMS_BerthPreference;
		if tmpBerthPref &lt;&gt; null then
			if (not tmpBerthPref.isTransient) then
				if HMS_BerthPreferenceVoyageData.hasInstance(tmpBerthPref) then
					berthPref := tmpBerthPref.HMS_BerthPreferenceVoyageData; 
					if berthPref.myVoyageData &lt;&gt; pxyHMSVoyage then
						//This can happen when changing HMS Voyage to Cellular voyage
						pxyPref := berthPref.cloneMySelf(true);
						self.allProxies.add(pxyPref);
						pxyHMSVoyage.allBerthPreferencesArray.add(pxyPref);
					endif;
				else
					// must be a vessel berth preference, copy it to the voyage
					create pxyPref transient;
					pxyPref.setProxy(tmpBerthPref.defaultBowMark,
									 tmpBerthPref.defaultBridgeMark, 
									 tmpBerthPref.defaultSternMark, 
									 tmpBerthPref.orientation, 
									 tmpBerthPref.getMyBerth, 									 
									 app.myPassport);
									 
					self.allProxies.add(pxyPref);
					pxyHMSVoyage.allBerthPreferencesArray.add(pxyPref);					
				endif;
			elseif (not pxyHMSVoyage.allBerthPreferencesArray.includes(berthPref)) then
				pxyHMSVoyage.allBerthPreferencesArray.add(berthPref);
			endif;
		endif;
	endforeach;

	// set default resources										// PAR #33337
	self.setProxyDefaultResources(pxyHMSVoyage);					// PAR #33337

	if addMovements then
		//add default voyage movements
		tmpBerth := pxyHMSVoyage.getMyBerth;
		tmpBerthPref := self.cmbBerthPref.listObject.HMS_BerthPreference;		
		if tmpBerth = null then
			if tmpBerthPref &lt;&gt; null then
				tmpBerth := tmpBerthPref.getMyBerth;
			else
				tmpBerth := self.cmbBerth.listObject.HMS_Berth;		
			endif;
		endif;

		// PAR #33504 If we have a preferred berth, set the voyage's exchange orientaton 		// PAR #33504
		// to the preferred berth's orientation													// PAR #33504
		if tmpBerthPref &lt;&gt; null then															// PAR #33504
			_theProxy.setStarboardBerthed(tmpBerthPref.orientation = OrientStarboardSideTo);	// PAR #33504
		endif;																					// PAR #33504
		
		pxyHMSVoyage.setProxyDefaultVoyageMovements(tmpBerth, tmpBerthPref, app.myPassport);
		
	else																						// PAR #33504
		//if tmpBerthPref &lt;&gt; null then															// PAR #33504	// TFS 50759
		if tmpBerthPref &lt;&gt; null and self.mode = self.Mode_Add then								// PAR #33504	// TFS 50759
			_theProxy.setStarboardBerthed(tmpBerthPref.orientation = OrientStarboardSideTo);	// PAR #33504
		endif;																					// PAR #33504
	endif;	
				
end;</source>
        <Parameter name="_theProxy" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyPortRotations" id="fc1f8148-9382-4249-92b0-85d8412effe4">
        <source>setProxyPortRotations(_pxyVoyage : CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2009	cnwer1	Initial creation

*/

vars
	i : Integer;
	port : CM_Port;
	pxyPortRotation : CM_PortRotation;
begin

	//epr par 20574 3/9/09
	_pxyVoyage.allPortRotations.purge;
	_pxyVoyage.allPorts.clear;
	i :=1;
	while i &lt;= self.lstPortsOfCall.listCount do
		
		if self.lstPortsOfCall.itemLevel[i] &gt; 1 then
			if pxyPortRotation &lt;&gt; null then
				pxyPortRotation.allTranshipPorts.add(self.lstPortsOfCall.itemObject[i].CM_Port);
			endif;
			i:=i+1;
			continue;
		endif;
		port:=self.lstPortsOfCall.itemObject[i].CM_Port;
		create pxyPortRotation transient;
		pxyPortRotation.setProxy(port,_pxyVoyage);
		_pxyVoyage.allPorts.add(port);
		i:=i+1;
	endwhile;

epilog

end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyage" id="b7888d43-213d-4fa2-855e-2486a8211cd9">
        <updating/>
        <source>setProxyVoyage(_pxyVoyage : CM_Voyage input) updating;
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
/****Changes

Date		Name	TFS#			Description
============================================================================
12/03/2013	PJS		PAr # 31232
22/01/2015  cnwma1  PAR # 35519 	1035 Error String Too Long
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/05/2016	cnwns1	TFS 488  		Multi Timezone Support
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
13/07/2017	cnwma1	TFS #4708:		DQM - JMT GUI Glitch - PDC#399
22/03/2018	jlgdap1	TFS 37445 		PEL1 Voyage Status Security
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
08/06/2020  cnwma1 ChangeRequest    49400: ASPA - Invoice Enhancements for Barges
============================================================================*/
vars
	pxyGCVoyage 			 : CM_GeneralCargoVoyageStructure;
	tmpTerminal 			 : CM_Terminal;
	tmpOperator 			 : CM_Operator;
	tmpTrade 				 : CM_Trade;
	tmpBank 				 : CM_Bank;
	tmpMoveMapReceivals		 : CM_MoveMap;
	tmpMoveMapReleases 		 : CM_MoveMap;
	tmpShippingLine 		 : CM_ShippingLine;
	tmpLineGroupDebtor 		 : CM_LineGroupDebtor;
	tmpVPC 					 : CM_VoyagePlanningCode;
	tmpCusresAltVoyage 		 : CM_Voyage;
	tmpLloydsNumber			 : String;
	tmpCode					 : String;
	tmpInwardCode			 : String;
	tmpRemarks				 : String;
	tmpCallSign				 : String;
	tmpVesselName			 : String;
	tmpVesselCode			 : String;
	tmpExternalRef			 : String;
	tmpGroupCode			 : String;
	tmpArchived				 : Boolean;
	tmpIsTransferable	 	 : Boolean;
	tmpStarboardBerth 		 : Boolean;
	tmpArchivedDT			 : TimeStamp;
	tmpArrivedDT			 : TimeStamp;
	tmpDepartedDT			 : TimeStamp;
	tmpNonPlannedEffectiveDT : TimeStamp;
    tmpCraneClearance		 : Integer;
	tmpColour				 : Integer;
	tmpVesselType			 : Integer;
	tmpInvStat				 : Integer;
	displayOption			 : Integer;
	tmpVoyageNumber 		 : Integer;
	tmpCutOffDateTS 		 : TimeStamp;
	allOperators 			 : CM_OperatorByCodeDict;
	tmpOverrideDefaults		 : Boolean;
	allRecRestrictions		 : CM_RecCutoffVoyByCodeOp;
	useVoyageAllocation 	 : Boolean;
	useOutOfSequenceLoadingJobs : Boolean;
	tmpVessel				 : CM_Vessel;
	airDraft				 : Decimal[6,2];
	maxVesselBeam			 : Decimal[6,2];
	draftBow				 : Decimal[6,2];
	draftStern				 : Decimal[6,2];
	draftMid				 : Decimal[6,2];
	buildingLine			 : Decimal[6,2];
	dimLOAWithRamps  		 : Decimal[6,2];
	thumbNailPic 			 : Binary;
	picWidth 				 : Integer;
	picHeight 				 : Integer;
	tmpExpArrivalDT			 : TimeStamp;				// PAR #35826
	tmpExpDepartureDT 		 : TimeStamp;				// PAR #35826
	generalLandingDate 		 : Date;
	tmpExternalCode 		 : String;							// TFS 4050
	tmpStatus 				 : Integer;				// TFS 37445
	paymentType				 : Integer;
	isBarge					 : Boolean; 	//jlgka1 TFS 37102
	ignoreCutOffs			 : Boolean;
begin
	if _pxyVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Voyage is null.');
		return;
	endif;

	// They must enter arrival/departue DT when creating HMS data
	// do before setting voyage as needed on the voyage
	
	//14 Jun 2016	NDL	TFS 2140
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(EtaEtdMandatory).Boolean then
		tmpArrivedDT.setDate(self.dateArrival.getDate());
		tmpArrivedDT.setTime(self.timeArrival.getTime());
		tmpDepartedDT.setDate(self.dateDeparture.getDate());
		tmpDepartedDT.setTime(self.timeDeparture.getTime());
		tmpExpArrivalDT.setDate(self.dateExpArrival.getDate());	
		tmpExpArrivalDT.setTime(self.timeExpArrival.getTime());
		tmpExpDepartureDT.setDate(self.dateExpDeparture.getDate());
		tmpExpDepartureDT.setTime(self.timeExpDeparture.getTime());
		if not tmpExpArrivalDT.isValid then
			app.raiseCMException1(AutoScheduleDateError, self.lblExpArrivalDT.caption, null, null);
			return;
		endif;
		if not tmpExpDepartureDT.isValid then
			app.raiseCMException1(AutoScheduleDateError, self.lblExpDeparture.caption, null, null);
			return;
		endif;
		if tmpExpArrivalDT.isValid and not tmpArrivedDT.isValid then
			self.dateArrival.setDate(tmpExpArrivalDT.Date);
			self.timeArrival.setTime(tmpExpArrivalDT.Time);
		endif;
		if tmpExpDepartureDT.isValid and not tmpDepartedDT.isValid then
			self.dateDeparture.setDate(tmpExpDepartureDT.Date);
			self.timeDeparture.setTime(tmpExpDepartureDT.Time);
		endif;
	endif;
	
	if (not self.validateDateTimes()) then
		app.raiseCMException1(AutoScheduleDateError, ' ', null, null);
		return;
	endif;
	
	if (not self.validateHoldName()) then         //  22/01/2015 cnwma1 PAR #35519
		return;
	endif;
	tmpCutOffDateTS := null;//is not in use so Ill set it to null // 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support 
	tmpArrivedDT.setDate(self.dateArrival.getDate());
	tmpArrivedDT.setTime(self.timeArrival.getTime());
	tmpDepartedDT.setDate(self.dateDeparture.getDate());
	tmpDepartedDT.setTime(self.timeDeparture.getTime());
	
	tmpExpArrivalDT.setDate(self.dateExpArrival.getDate());			// PAR #35826
	tmpExpArrivalDT.setTime(self.timeExpArrival.getTime());			// PAR #35826
	tmpExpDepartureDT.setDate(self.dateExpDeparture.getDate());		// PAR #35826
	tmpExpDepartureDT.setTime(self.timeExpDeparture.getTime());		// PAR #35826
	
	tmpArrivedDT 	 := self.localToSystemTime(tmpArrivedDT);	  // 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support 
	tmpDepartedDT	 := self.localToSystemTime(tmpDepartedDT);	  // 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support 
	tmpExpArrivalDT	 := self.localToSystemTime(tmpExpArrivalDT);  // 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support 
	tmpExpDepartureDT:= self.localToSystemTime(tmpExpDepartureDT);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support 
	
	tmpInvStat := self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.listIndex];
	tmpCode := self.txtVoyageCode.text.removeTabCrLfs; 				//13/07/2017 cnwma1 TFS #4708
	tmpShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine;
	tmpCraneClearance := self.txtCraneClearanc.text.Integer;
	tmpColour := self.pickColour.getColor();
	
	generalLandingDate := self.dateGenLanding.getDate();	//14 Mar 2016	NDL	TFS 1407

	// default to true as all non cellular voyages are non planned/non worked
	// the ship block stack will be created if voyage is non planned/non worked
// PAR 33644	tmpNonPlanned := true;
// PAR 33644	tmpNonWorked := true;
	tmpCusresAltVoyage := self.cmbCusresAltVoy.listObject.CM_Voyage;
	tmpInwardCode := self.txtInwardCode.text.removeTabCrLfs; 				//13/07/2017 cnwma1 TFS #4708// cnwdad1 08/10/2008 - PAR #18125. Moved this here from inside the condition below (grpCellulaVoyage).
	tmpExternalCode := self.txtExternalCode.text.removeTabCrLfs;    		//13/07/2017 cnwma1 TFS #4708; 			// TFS 4050
	
	if self.grpCellulaVoyage.visible then
		// set the cargo voyage stuff
// PAR 33644		tmpNonPlanned := not self.ckbPlanned.value;
// PAR 33644		tmpNonWorked := not self.ckbWorked.value;
		tmpOperator := self.cmbVoyOperator.listObject.CM_Operator;
		tmpVPC := self.cmbVoyPlanCode.listObject.CM_VoyagePlanningCode;
		tmpBank := self.cmbBank.listObject.CM_Bank;
		tmpTrade := self.cmbTrade.listObject.CM_Trade;
		tmpNonPlannedEffectiveDT.setDate(self.dateNonPlanned.getDate());
		tmpNonPlannedEffectiveDT.setTime(self.timeNonPlanned.getTime());
		tmpNonPlannedEffectiveDT := self.localToSystemTime(tmpNonPlannedEffectiveDT);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tmpLineGroupDebtor := self.cmbLineGroupDebt.listObject.CM_LineGroupDebtor;
		
		if self.optShowNever.value then
			displayOption := VoyageDisplayNever;
		elseif self.optShowAlways.value then
			displayOption := VoyageDisplayAlways;
		else
			displayOption := VoyageDisplayDefault;
		endif;
	else
		// PAR 12275 null the dates because otherwise they default to now
		tmpNonPlannedEffectiveDT := null;
	endif;

	// Cellular Structure - create proxy if needed
//	voyageTypeStr := self.cmbStructureType.text;  // 31232
	
	//epr 8/6/2011 CCMS 1116 refactor the proxy create of structures that depend on voyage type to the voyage class
	// rather than here - means i can reuse in unit tests
	tmpVessel := self.cmbVessel.myObject.CM_Vessel;
	
	if self.cmbStatus.listObject &lt;&gt; null then		// TFS 37445
		tmpStatus := self.cmbStatus.listObject.CM_VoyageStatus.id;			// TFS 37445
	endif;																	// TFS 37445
	paymentType := app.paymentTypeStringToEnum(self.cmbPaymentType.text);	// 25/6/18 MAP TFS39250
	
	// PAr # 31232  - change to individual calls for each thing
	//_pxyVoyage.setProxyForVoyageType(app.vesselStructureTypeStrToENum(voyageTypeStr),tmpVessel);
	
	
	_pxyVoyage.setProxyForVoyageType(	tblVesselStruct.getValueByName(ETRow_IncludesLOLO).Boolean,
										tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean,
										tblVesselStruct.getValueByName(ETRow_IncludesHolds).Boolean,
										tmpVessel);
	
	//10 Jul 2013	NDL	Par 31965
	if _pxyVoyage.myGeneralCargoVoyage &lt;&gt; null and self.myCopyGCStruct &lt;&gt; null then
		_pxyVoyage.myGeneralCargoVoyage.setDefaultLocationsFrom( self.myCopyGCStruct, true );
	endif;	
	
	
	
	
	// General Cargo Structure - create proxy if needed
	pxyGCVoyage := _pxyVoyage.myGeneralCargoVoyage;
	
	//CCMS1569
	tmpOverrideDefaults := ckbOverrideDef.value;			// 26/05/2009 cnwar2 CCMS1040/#19796
	ignoreCutOffs		:= ckbIgnoreCutOff.value;			// 31.Aug.2023 navsp1 TFS 57809
	// 26/05/2009 cnwar2 CCMS1040
	// ### JIRA 34223 06MAR 2025 NAVAB1
	self.setProxyCutoffsPN(self.allProxyCutoffs, _pxyVoyage);
	
	tmpVesselName := self.txtVesselName.text;
	tmpVesselCode := self.txtVesselCode.text;
	tmpCallSign := self.txtCallSign.text;
	tmpLloydsNumber := self.txtLloydsNum.text;
	tmpVesselType := app.vesselAccessTypeStrToEnum(self.cmbAccessType.text);
	tmpRemarks := self.txtRemarksVessel.text;
	tmpExternalRef	:= self.txtExternalRef.text; 					  // CCMS1952 PAR24400 cnwsh3  Customs Registration Number for SCT
	tmpGroupCode    := self.txtGroupCode.text;                        //03/06/2020 cnwma1 Tfs #49400
	tmpMoveMapReceivals := self.cmbMoveMapRec.listObject.CM_MoveMap;
	tmpMoveMapReleases  := self.cmbMoveMapRel.listObject.CM_MoveMap;
	
	if self.mode = Mode_Add then
		tmpArchived := false;
		tmpArchivedDT := null;// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tmpIsTransferable := false;
		tmpVoyageNumber := self.voyageNumber;
	else
		tmpArchived := _pxyVoyage.archived;
		tmpIsTransferable := _pxyVoyage.isTransferable;
		tmpStarboardBerth := _pxyVoyage.starboardBerthed;
		tmpArchivedDT := _pxyVoyage.archivedDT;
		tmpVoyageNumber := _pxyVoyage.voyageNumber;
	endif;

	self.setProxyVoyageGlobal(_pxyVoyage, tmpVesselName);
	
	tmpTerminal := _pxyVoyage.myTerminal;
	if tmpTerminal = null then
		tmpTerminal := self.myTerminal;
	endif;
	
	create allOperators transient;
	self.mulOperators.getSelected(allOperators); 
	
	isBarge := self.chkIsBarge.value; // jlgka1 TFS 37102
	
	//cnwjo3 CCMS 1028
	useVoyageAllocation := self.chkUseVoyageAllo.value;
	
	//cnwrd1 par 30626 ccms 2209 23.10.12
	useOutOfSequenceLoadingJobs := self.chkDefaultOOS.value;
	
	//epr ccms 1116 20/6/11 new fields for voyage roro
	airDraft := self.getDimensionValue(ETRow_AirDraft).Decimal;
	maxVesselBeam:=self.getDimensionValue(ETRow_MaxVoyageBeam).Decimal;
	draftBow:=self.getDimensionValue(ETRow_DraftBow).Decimal;
	draftStern:=self.getDimensionValue(ETRow_DraftStern).Decimal;
	draftMid:=self.getDimensionValue(ETRow_DraftMid).Decimal;
	buildingLine:=self.getDimensionValue(ETRow_BuildingLine).Decimal;
	dimLOAWithRamps:=self.getDimensionValue(ETRow_LoaWithRampsDown).Decimal;
	
	//12 Dec 2011	NDL	Par 28303	- resize voyage image so that its not too big to send to hand held tallyman..
	self.picVesselBitmap.picture.pictureSize(picWidth , picHeight);
	if picWidth &gt; 300 or picHeight &gt; 200 then //(The fixed size of the picture control)
		// the picture is being scaled down to fit, i.e. it could be resized smaller.
		self.picVesselBitmap.borderStyle := Picture.BorderStyle_None;
		self.picVesselBitmap.show3D := Picture.Show3D_Not3D;
		thumbNailPic := self.picVesselBitmap.createPictureAsType(true, false, 32, Window.PictureType_Jpeg);
		if thumbNailPic.length &gt; 100 then
			// less than this would imply that the thumbnail picture hasn't created properly...
			self.picVesselBitmap.picture := thumbNailPic;
		endif;
		self.picVesselBitmap.borderStyle := Picture.BorderStyle_Single;
		self.picVesselBitmap.show3D := Picture.Show3D_Use3D;
	endif;
	
	_pxyVoyage.setProxyVoyage(	self.picVesselBitmap.picture,
								tmpCallSign,
								tmpCode,
								tmpInwardCode,
								tmpRemarks,
								tmpVesselCode,
								tmpVesselName,
								tmpLloydsNumber,
								tmpArchived,
/* PAR 33644								tmpNonPlanned,
								tmpNonWorked, */
								tmpIsTransferable,
								tmpStarboardBerth,
								tmpCraneClearance,
								displayOption,
								tmpColour,
								//_pxyVoyage.status,				// TFS 37445
								tmpStatus,							// TFS 37445
								tmpVesselType,
								tmpArchivedDT,
								tmpArrivedDT,
								tmpDepartedDT,
								_pxyVoyage.loadStartDT,
								_pxyVoyage.loadEndDT,
								tmpNonPlannedEffectiveDT,
								tmpCutOffDateTS,
								tmpLineGroupDebtor,
								tmpBank,
								tmpOperator,
								tmpTrade,
								tmpShippingLine,
								tmpTerminal,
								_pxyVoyage.myVoyageGlobalArrival,
								tmpVPC,tmpInvStat,
								tmpMoveMapReceivals,
								tmpMoveMapReleases,
								tmpCusresAltVoyage,
								tmpVoyageNumber,
								tmpOverrideDefaults,	// 26/05/2009 cnwar2 CCMS1040/#19796
								allOperators,
								allRecRestrictions,	// 26/05/2009 cnwar2 CCMS1040/#19796
								useVoyageAllocation,
								tmpExternalRef,
								self.txtYearBuild.text.asIntegerJMT(),
								airDraft,
								maxVesselBeam,
								draftBow,
								draftMid,
								draftStern,
								buildingLine,
								dimLOAWithRamps,  //CCMS 1028
								useOutOfSequenceLoadingJobs,		//ccms 2209
								tmpExpArrivalDT,					// PAR #35826
								tmpExpDepartureDT,					// PAR #35826
								generalLandingDate,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								tmpExternalCode,						// _externalCode TFS 4050
								paymentType, 
								isBarge,		// jlgka1 TFS 37102
								tmpGroupCode,    //03/06/2020 cnwma1 Tfs #49400
								ignoreCutOffs
								);

	_pxyVoyage.setProxyPrenoteCutoff(self.ckbPrenoteCutoffs.value); // ### JIRA 34233 13MAR 2025 NAVAB1
	//ccms 1058
	self.setProxyPortRotations(_pxyVoyage);
	// set after voyage
	self.setProxyVoyageExchange(_pxyVoyage);

	//HMS data must be set after voyage as voyage data is used to set movement defaults
	self.setProxyHMSVoyage(_pxyVoyage);
	
	//cnwjo3 CCMS 1028
	self.setProxyVoyageVAConfig(_pxyVoyage);

epilog
	delete allOperators;
	delete allRecRestrictions;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageData" id="6294089b-6985-47a6-b950-7b59353d36fa">
        <source>setProxyVoyageData(_pxyVoyageData : HMS_VoyageData input)protected;
//--------------------------------------------------
// Created:	10 August 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 23/11/2018	jlgdap1		TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
vars
	fromPortCode,
	toPortCode,
	countryCode : String;
 	dim_LengthOverall : Decimal[6,2];
	dim_Beam,
	dim_DraftAft,
	dim_DraftFore : Decimal[5,1];
	berthPriority,
	dim_DeadWeight,
 	dim_GrossRegTonnes,
	dim_NetRegTonnes,
 	dist_BowToFwdContainer,
 	dist_BridgeToBow,
 	dist_BridgeToStern,
 	dist_SternToAftContainer,
 	dist_SternToBunker : Integer;
 	tmpHarbour : HMS_Harbour;
 	berth : HMS_Berth;
	numTugs : Integer;											// PAR #33337
	moveType : String;											// PAR #33337
	coll : ObjectArray;											// PAR #33337
  	moveResource : HMS_ResourceTypeForMovement;					// PAR #33337

begin

	// Always set harbour reference when creating harbour stuff
	if _pxyVoyageData.myVoyage &lt;&gt; null then
		if _pxyVoyageData.myVoyage.myTerminal &lt;&gt; null then
			tmpHarbour := _pxyVoyageData.myVoyage.myTerminal.myHarbour;
		endif;
	endif;
	if tmpHarbour = null then	
		tmpHarbour := self.myTerminal.myHarbour;
	endif;
	
	if self.cmbCountry.listObject &lt;&gt; null then
		countryCode := self.cmbCountry.listObject.CM_Country.code;
	endif;
	
	if self.cmbPortFrom.myObject &lt;&gt; null then
		fromPortCode := self.cmbPortFrom.myObject.CM_Port.code;
	endif;
	
	if self.cmbPortTo.myObject &lt;&gt; null then
		toPortCode := self.cmbPortTo.myObject.CM_Port.code;
	endif;
	
	if self.cmbBerth.listObject &lt;&gt; null then
		berth := self.cmbBerth.listObject.HMS_Berth;
	endif;

	if berth = null
	and self.cmbBerthPref.listObject &lt;&gt; null then
		berth := self.cmbBerthPref.listObject.HMS_BerthPreference.getMyBerth;
	endif;	
	
	berthPriority := self.cmbBerthPriority.listIndex;

	dim_LengthOverall := self.getDimensionValue(ETRow_LengthOverall).Decimal; //tmpTable.text.asDecimalJMT();	//01 APR 2010	NDL	Par 23556	
	dim_GrossRegTonnes := self.getDimensionValue(ETRow_GrossRegTonnes).Integer; 	
	dim_NetRegTonnes := self.getDimensionValue(ETRow_NetRegTonnes).Integer;
	dim_DeadWeight := self.getDimensionValue(ETRow_DeadWeight).Integer; 
	dim_Beam := self.getDimensionValue(ETRow_Beam).Decimal; 
	dim_DraftFore := self.getDimensionValue(ETRow_DraftFore).Decimal; 
	dim_DraftAft := self.getDimensionValue(ETRow_DraftAft).Decimal; 

	dist_BridgeToBow := self.getDimensionValue(ETRow_BridgeToBow).Integer; 	
	dist_BridgeToStern := self.getDimensionValue(ETRow_BridgeToStern).Integer; 			
	dist_BowToFwdContainer := self.getDimensionValue(ETRow_BowToFwdBay).Integer;			
	dist_SternToAftContainer := self.getDimensionValue(ETRow_SternToAftBay).Integer;
	dist_SternToBunker := self.getDimensionValue(ETRow_SternToBunker).Integer;
	
	_pxyVoyageData.setProxy(self.ckbCoastalVessel.value,
							self.ckbVisitConfiden.value,
							self.ckbBowThrusters.value,
							self.optPropFixed.value,						
							self.ckbHoldTanks.value,
							self.ckbHasRamps.value,
							self.ckbSternThruster.value,
							self.ckbPilotExempt.value,
							self.cmbPilot.listObject.HMS_Pilot,
							self.cmbMaster.listObject.HMS_Master,
							self.txtRemarkGeneral.text,
							self.txtRemarksPilot.text,
							self.txtPreviousNames.text.trimBlanks(),
							countryCode,
							fromPortCode,
							toPortCode,
							self.txtRemarksVoyage.text,
							dim_Beam,
							dim_DraftAft,
							dim_DraftFore,
							dim_LengthOverall,
							dim_DeadWeight,
							dim_GrossRegTonnes,
							dim_NetRegTonnes,
							dist_BowToFwdContainer,
							dist_BridgeToBow,
							dist_BridgeToStern,
							dist_SternToAftContainer,
							dist_SternToBunker,
							self.txtEstTieUpTime.text.Integer,
							self.txtCrewLetGo.text.Integer,
							self.txtCrewTieUp.text.Integer,
							self.txtTugsArrive.text.Integer,
							self.txtTugsDepart.text.Integer,
							_pxyVoyageData.voyageStatus,
							berthPriority,
							berth,
							tmpHarbour,
							self.cmbLineCompany.listObject.HMS_LineCompany,
							self.cmbShippingLine.listObject.CM_ShippingLine,
							self.cmbShippingAgent.listObject.CM_ShippingAgent,
							self.cmbCatArrive.listObject.HMS_VesselCategory,
							self.cmbCatDepart.listObject.HMS_VesselCategory,
							self.cmbShipType.listObject.HMS_VesselType,
							self.cmbTidalClassAr.listObject.HMS_TidalClass,
							self.cmbTidalClassDpt.listObject.HMS_TidalClass,
							self.cmbVisitType.listObject.HMS_VisitType,
							self.ckbRequiresTow.value,	//31 May 2018	NDL	TFS 38905
							self.ckbTaxExemptRes.value,	//12 Jun 2018	NDL	TFS 39141
							self.ckbTaxExemptCargo.value		// TFS 41949
							);

	// set default resources for the arrival movement						// PAR #33337
	create coll transient;													// PAR #33337
	moveType := HMSMovementTypeArrival;										// PAR #33337
	numTugs := self.txtTugsMArrival.text.Integer;							// PAR #33337
	if self.lstResTypeArriva.allSelectedObjects &lt;&gt; null then				// PAR #33337
		self.lstResTypeArriva.allSelectedObjects.copy(coll);				// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource := _pxyVoyageData.allDefaultMovementResources[moveType];	// PAR #33337
	if moveResource = null then												// PAR #33337
		create moveResource transient;										// PAR #33337
		_pxyVoyageData.allDefaultMovementResources.add(moveResource);  		// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);				// PAR #33337
																			// PAR #33337
	// set default resources for the shift movement							// PAR #33337
	coll.clear();															// PAR #33337
	moveType := HMSMovementTypeShift;										// PAR #33337
	numTugs := self.txtTugsMShift.text.Integer;								// PAR #33337
	if self.lstResTypeShift.allSelectedObjects &lt;&gt; null then					// PAR #33337
		self.lstResTypeShift.allSelectedObjects.copy(coll);					// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource := _pxyVoyageData.allDefaultMovementResources[moveType];	// PAR #33337
	if moveResource = null then												// PAR #33337
		create moveResource transient;										// PAR #33337
		_pxyVoyageData.allDefaultMovementResources.add(moveResource);  		// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);				// PAR #33337
																			// PAR #33337
	// set default resources for the departure movement						// PAR #33337
	coll.clear();															// PAR #33337
	moveType := HMSMovementTypeDeparture;									// PAR #33337
	numTugs := self.txtTugsMDepart.text.Integer;							// PAR #33337
	if self.lstResTypeDepart.allSelectedObjects &lt;&gt; null then				// PAR #33337
		self.lstResTypeDepart.allSelectedObjects.copy(coll);				// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource := _pxyVoyageData.allDefaultMovementResources[moveType];	// PAR #33337
	if moveResource = null then												// PAR #33337
		create moveResource transient;										// PAR #33337
		_pxyVoyageData.allDefaultMovementResources.add(moveResource);  		// PAR #33337
	endif;																	// PAR #33337
																			// PAR #33337
	moveResource.setProxy(moveType, numTugs, tmpHarbour, coll);				// PAR #33337
epilog																		// PAR #33337
	delete coll;															// PAR #33337
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVoyageData" type="HMS_VoyageData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageExchange" id="21a593dc-5bbb-4216-a1a3-7ed767e7cae5">
        <source>setProxyVoyageExchange(_pxyVoyage : CM_Voyage input);
//--------------------------------------------------
// Created:	04 August 2005 By: cnwgd1
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 15/03/2018	jlgdap1	TFS 37427 PEL1 Voyage Status Enhancements
//--------------------------------------------------
vars
	starboardBerthed		: Boolean;
	exchangeCompleteDT		: TimeStamp;
	exchangeCompleteDTlocal	: TimeStamp;
	pilotOnBoardDT			: TimeStamp;
	pilotOnBoardDTlocal		: TimeStamp;
	pilotReturnDT			: TimeStamp;
	pilotReturnDTlocal		: TimeStamp;
	anchorDownDT			: TimeStamp;
	anchorDownDTlocal		: TimeStamp;
	labourOB				: TimeStamp;
	labourOBlocal			: TimeStamp;
	labourOS				: TimeStamp;
	labourOSlocal			: TimeStamp;
	shipExangeDT			: TimeStamp;
	shipExangeDTlocal		: TimeStamp;
	tmpDepartTargetDT		: TimeStamp;
	tmpDepartTargetDTlocal	: TimeStamp;
	oldShipExchangeDT 		: TimeStamp;
	dateAvailable		: Date;
	nonChargeTime		: Decimal[12,2];
	totalTimeInPort		: Decimal[12,2];
	stopChargingAt		: String;
	loadRate			: Decimal[12,2];
	dischargeRate		: Decimal[12,2];
	status				: String;
	tmpStatus			: Integer;
	voyageProcess		: CM_VoyageProcess;				// TFS 37427
	voyageStatus 		: CM_VoyageStatus;
begin
	if (not self.shtExchange.visible)
	or self.mode = self.Mode_View
	then
		return;
	endif;

	if _pxyVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Voyage is null.');
		return;
	endif;
		
	//CCMS 1287
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	pilotOnBoardDTlocal.setDate(self.datePilotOnBoard.getDate());
	pilotOnBoardDTlocal.setTime(self.timePilotOnBoard.getTime());
	pilotOnBoardDT := self.localToSystemTime(pilotOnBoardDTlocal);
	
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	pilotReturnDTlocal.setDate(self.datePilotReturn.getDate());
	pilotReturnDTlocal.setTime(self.timePilotReturn.getTime());
	pilotReturnDT := self.localToSystemTime(pilotReturnDTlocal);
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	anchorDownDTlocal.setDate(self.dateAnchorDown.getDate());
	anchorDownDTlocal.setTime(self.timeAnchorDown.getTime());
	anchorDownDT := self.localToSystemTime(anchorDownDTlocal);
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	exchangeCompleteDTlocal.setDate(self.dateExchangeComp.getDate());
	exchangeCompleteDTlocal.setTime(self.timeExchangeComp.getTime());
	exchangeCompleteDT := self.localToSystemTime(exchangeCompleteDTlocal);
	
	// CCMS 1115 AKB2004JAN
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	labourOBlocal.setDate(self.dateLabourOBD.getDate());
	labourOBlocal.setTime(self.timeLabourOB.getTime());
	labourOB := self.localToSystemTime(labourOBlocal);
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support	
	labourOSlocal.setDate(self.dateLabourOSD.getDate());
	labourOSlocal.setTime(self.timeLabourOS.getTime());
	labourOS := self.localToSystemTime(labourOSlocal);
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tmpDepartTargetDTlocal.setDate(self.dateDepartTarget.getDate());
	tmpDepartTargetDTlocal.setTime(self.timeDepartTarget.getTime());
	tmpDepartTargetDT := self.localToSystemTime(tmpDepartTargetDTlocal);
		
	dateAvailable	:=	self.dateAvailable.getDate();
	
	starboardBerthed := self.optStarboard.value;
	
	//totalTimeInPort	:=	txtWTimeInPort.cnEcDecimal();
	totalTimeInPort	:=	txtWTimeInPort.text.asDecimalJMT();
	//nonChargeTime	:=	txtWNoChargeTime.cnEcDecimal();
	nonChargeTime	:=	txtWNoChargeTime.text.asDecimalJMT();
	stopChargingAt	:=	cmbWStopCharging.text.trimBlanks();
	//loadRate		:=	txtWLoadRate.cnEcDecimal();
	loadRate		:=	txtWLoadRate.text.asDecimalJMT();
	//dischargeRate	:=	txtWDischargeRat.cnEcDecimal();
	dischargeRate	:=	txtWDischargeRat.text.asDecimalJMT();
	// TFS 37427
	voyageStatus := self.cmbStatus.listObject.CM_VoyageStatus;
	if voyageStatus &lt;&gt; null then
		tmpStatus:=voyageStatus.id;
	endif;
	voyageProcess := self.cmbProcess.listObject.CM_VoyageProcess;			// TFS 37427
	
	oldShipExchangeDT := _pxyVoyage.shipExchangeDate;
	
	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	shipExangeDTlocal.setDate(self.dateExchanStart.getDate());	
	shipExangeDTlocal.setTime(self.timeExchangeStar.getTime());
	shipExangeDT := self.localToSystemTime(shipExangeDTlocal);
	
	_pxyVoyage.setProxyExchangeData(starboardBerthed,
									pilotOnBoardDT,
									labourOB,
									labourOS,
									dateAvailable,
									shipExangeDT,
									exchangeCompleteDT,
									tmpDepartTargetDT,
									totalTimeInPort,
									nonChargeTime,
									stopChargingAt,
									loadRate,
									dischargeRate,
									tmpStatus,
									pilotReturnDT,
									anchorDownDT,
									self.ckbCheckSealDish.value,
									voyageProcess	);					// TFS 37427
									
				
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageGlobal" id="9c6615be-8524-4df9-8ab7-b730502c4945">
        <source>setProxyVoyageGlobal(_pxyVoyage : CM_Voyage input; _vesselName: String);
//----------------------------------------------------------------
//	Created:	30 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//	For cellular voyages we now create a Global voyage by default
//	
vars
	tmpCode	: String;
	tmpGlobalVoyage	: CM_VoyageGlobal;
begin
	
	tmpGlobalVoyage := _pxyVoyage.myVoyageGlobalArrival;
	if tmpGlobalVoyage &lt;&gt; null then
		return;
	endif;
	
	//try to match one by code if user has selected nothing
	if tmpGlobalVoyage = null then
		tmpCode := self.txtVoyageCode.text;
		tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[tmpCode];
	endif;

	if tmpGlobalVoyage = null then
		create tmpGlobalVoyage transient;
		self.allProxies.add(tmpGlobalVoyage);
		tmpGlobalVoyage.setProxy(tmpCode, _vesselName, null, null, null, null, null, 0, null, app.myRoot);
	endif;
	
	//will check to see if it's actually compatible in validation				
	_pxyVoyage.setMyVoyageGlobalArrival(tmpGlobalVoyage);

end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageVAConfig" id="73a8dfe2-f2ea-4f0c-8cf6-099390866344">
        <source>setProxyVoyageVAConfig(_pxyVoyage : CM_Voyage);
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// Purpose:		set the proxy values for a CM_VoyageAllocationConfig/

/****Changes

Date		Name	TFS#			Description
============================================================================
07/12/2009	cnwjo3					Initial Creation
============================================================================*/

vars
	opCriteriaColl 				: CM_YACriteriaTypeArray;
	groupLabelCriteriaColl 		: CM_YACriteriaTypeArray;
	pxyVoyageAllocationConfig 	: CM_VoyageAllocationConfig;
	yardCriteriaType			: CM_YACriteriaType;
	ret 						: Integer;
begin
	if not _pxyVoyage.useVoyageAllocations then  //do create the objects if not needed
		return;
	endif;
	
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	self.getOpCriteriaColl(opCriteriaColl);
	
	if self.myVoyageAlloc &lt;&gt; null then
		pxyVoyageAllocationConfig := app.createUpdateProxy(self.myVoyageAlloc).CM_VoyageAllocationConfig;
	else
		create pxyVoyageAllocationConfig transient;
	endif;
	
	yardCriteriaType := self.getYACriteriaTypeByDescription(self.cmbDefaultColour.text);

	pxyVoyageAllocationConfig.setProxyVoyage(opCriteriaColl,groupLabelCriteriaColl,Red,yardCriteriaType,_pxyVoyage, null);
	
	// DJW Absolutely no reason for doing this, especically while setting up proxies
	//app.myTrxUA.trxUpdateYAIMEXConfig(pxyVoyageAllocationConfig,app.myPassport);   //its cool that i can use YAIMEXConfig here!
	
	self.allProxies.add(pxyVoyageAllocationConfig);  //add to allProxies so they get cleared on doSave epilog
	
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setRecCutoff" id="04991e1f-ceb8-4b39-b958-780abe59a9ce">
        <updating/>
        <source>setRecCutoff(_recCutoff : CM_ReceivalCutoffVoyage input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 10MAR025
ADO - JIRA 34233
*/

vars
	idx						: Integer;
	code, opcode					: String;
	cutoffTS, earliestTS, cutoffTSPN, earliestTSPN	: TimeStamp;

	operator				: CM_Operator;
	date					: Date;
	time					: Time;
	earlyHours, earlyHoursPN, cutoffHours, cutoffHoursPN : Decimal[23,2];
begin

	if _recCutoff= null then
		return;
	endif;
	
	code := self.lblCutoffCode.caption;
	
	if self.hasOperatorColumn then
		opcode := self.lblCutoffOpCode.caption;
		operator := app.myRoot.allOperators[opcode];
	endif;
	
	// ### NON PRENOTE
	date := self.mskNonPNCutoffDate.getDate();
	time := self.mskNonPNCutoffTime.getTime();
	if date.isValid and time.isValid() then
		cutoffTS.setDate(date);
		cutoffTS.setTime(time);
  // ### JIRA 36847 16DEC2025 NAVAB1		cutoffTS := self.localToSystemTime(cutoffTS);
	else
		cutoffTS := null;
	endif;
	date := self.mskNonPNEarlyDate.getDate();
	time := self.mskNonPNEarlyTime.getTime();
	if date.isValid and time.isValid() then
		earliestTS.setDate(date);
		earliestTS.setTime(time);
  // ### JIRA 36847 16DEC2025 NAVAB1		earliestTS := self.localToSystemTime(earliestTS);
	else
		earliestTS := null;
	endif;

	
	// ### PRENOTE
	date := self.mskPNCutoffDate.getDate();
	time := self.mskPNCutoffTime.getTime();
	if date.isValid and time.isValid() then
		cutoffTSPN.setDate(date);
		cutoffTSPN.setTime(time);
  // ### JIRA 36847 16DEC2025 NAVAB1		cutoffTSPN := self.localToSystemTime(cutoffTSPN);
	else
		cutoffTSPN := null;
	endif;
	date := self.mskPNEarlyDate.getDate();
	time := self.mskPNEarlyTime.getTime();
	if date.isValid and time.isValid() then
		earliestTSPN.setDate(date);
		earliestTSPN.setTime(time);
  // ### JIRA 36847 16DEC2025 NAVAB1		earliestTSPN := self.localToSystemTime(earliestTSPN);
	else
		earliestTSPN := null;
	endif;
	
	earlyHours := self.txtNonPNEarlyHours.text.asDecimalJMT();
	earlyHoursPN := self.txtPNEarlyHours.text.asDecimalJMT();
	cutoffHours := self.txtNonPNCutoffHours.text.asDecimalJMT();
	cutoffHoursPN := self.txtPNCutoffHours.text.asDecimalJMT();
	

	 // ### JIRA 34524 08APR2025 NAVAB1 - these must be server timestamps
	 cutoffTS := self.localToSystemTime(cutoffTS);
	 earliestTS := self.localToSystemTime(earliestTS);
	 cutoffTSPN := self.localToSystemTime(cutoffTSPN);
	 earliestTSPN := self.localToSystemTime(earliestTSPN);
	 
	 
	_recCutoff.setProxy(code, cutoffTS, earliestTS, _recCutoff.myVoyage, operator, 
						cutoffTSPN, 
						earliestTSPN,cutoffHours, cutoffHoursPN,earlyHours, earlyHoursPN, _recCutoff.defaultRelativeTo);
end;</source>
        <Parameter name="_recCutoff" type="CM_ReceivalCutoffVoyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSelectedBerthPreference" id="cc377bfc-4dca-4977-83bc-36b689b2143a">
        <source>setSelectedBerthPreference();
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpBerthPref : HMS_BerthPreference;
begin
	
	if self.tblBerthPref.row &lt;= self.tblBerthPref.fixedRows then
		return;
	endif;
	
	if self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;

	tmpBerthPref := self.tblBerthPref.accessRow(self.tblBerthPref.row).itemObject.HMS_BerthPreference;

	if tmpBerthPref = null then
		return;
	endif;

	self.cmbBerthPref.listIndex := self.cmbBerthPref.findObject(tmpBerthPref);
	self.optBerthPref.value := (self.cmbBerthPref.listIndex &gt; 0);
	self.optBerthPref.click(self.optBerthPref);
	self.doSetBerth(self.cmbBerthPref.listObject.HMS_BerthPreference); //cnwrd1 par31283 auto set exchange detail berth orientation for new voyages
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="a7e11bf3-8dec-4966-82d7-c30ef3030ba6">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	12 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _theTable = self.tblExtRamps then
		self.loadExternalRampTable;
	elseif _theTable = self.tblSections then
		self.loadSectionsTable();
	elseif _theTable = self.tblTanks then
		self.loadTankTable();
	elseif _theTable = self.tblDelays then
		self.displayHMSDelay();
	elseif _theTable = self.tblHMSMovements then
		self.displayHMSMovements();
	elseif _theTable =  self.tblHDocuments then
		self.displayVoyageFiles;
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setToViewMode" id="ff5fdeae-83bc-45b1-a147-43fa087894e7">
        <updating/>
        <source>setToViewMode() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2005 cnwgd1		
12 Mar 2020 cnwma1	Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue														
*/

vars

begin

	if self.isFirstActivateComplete	and self.mode = self.Mode_View then
		return;
	endif;
	
	self.mode := self.Mode_View;
	
	self.setEnableObjects(false);

	if not self.viewModeOnly then
		self.btnCopyVoyage.enabled  := true;
		self.btnDeleteTV.enabled    := app.myCurrentUserCan(self.myTerminal, PmShipVoyageEnquiryDel);	//29 May 2020	NDL	TFS 49417		
		self.btnEditTV.enabled      := true;
		self.btnNewTV.enabled       := true;
		self.btnWPOpHrsEdit.enabled := true;	
		
		if app.myCurrentUserCan(self.myTerminal, PmVoyageArchive) then
			if self.myCurrentVoyage &lt;&gt; null then
				self.btnArchive.enabled := not self.myCurrentVoyage.archived;
			endif;
		endif;
	else
		self.btnCopyVoyage.enabled  := false;	
		self.btnDeleteTV.enabled 	:= false;		
		self.btnEditTV.enabled 	    := false;
		self.btnNewTV.enabled 	    := false;
		self.btnArchive.enabled     := false;
		self.btnWPOpHrsEdit.enabled := false;	
	endif;

	self.cmbVoyage.enabled     := true;
	self.btnSaveBase.enabled   := false;
	self.btnCancelBase.enabled := false;		
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setVADefaultColourCombo" id="82c41a4b-cc2f-485c-92f9-cda96be0db73">
        <source>setVADefaultColourCombo(_reset : Boolean);
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
vars
	s : String;
	indx : Integer;
	myText : String;
	ct : CM_YACriteriaType;
begin
	myText := self.cmbDefaultColour.text;
	
	self.cmbDefaultColour.clear();
	
	/*foreach s in self.allSelected do
		self.cmbDefaultColour.addItem(s);
	endforeach;*/
	if self.myVoyageAlloc &lt;&gt; null then
		foreach ct in self.myVoyageAlloc.allOpCriteria where self.allSelected.includes(ct.description) and not ct.isPrimitiveValue() do			
				self.cmbDefaultColour.addItem(ct.description);		
		endforeach;
	elseif self.myVesselAllocConfig &lt;&gt; null then																									//cnwas3 ccms 1035
		foreach ct in self.myVesselAllocConfig.allOpCriteria where self.allSelected.includes(ct.description) and not ct.isPrimitiveValue() do			
				self.cmbDefaultColour.addItem(ct.description);		
		endforeach;		
	elseif self.myVoyageConfig &lt;&gt; null then
		foreach ct in self.myVoyageConfig.allOpCriteria where self.allSelected.includes(ct.description) and not ct.isPrimitiveValue() do			
				self.cmbDefaultColour.addItem(ct.description);		
		endforeach;	
	endif;


	if _reset then
		if self.myVesselAllocConfig &lt;&gt; null then																		//cnwas3 ccms 1035
			if self.myVesselAllocConfig.myYACriteriaTypeForColour &lt;&gt; null then
				myText := self.myVesselAllocConfig.myYACriteriaTypeForColour.description;
			endif;
		elseif self.myVoyageAlloc &lt;&gt; null then
			if self.myVoyageAlloc.myYACriteriaTypeForColour &lt;&gt; null then
				myText := self.myVoyageAlloc.myYACriteriaTypeForColour.description;
			endif;
		elseif self.myVoyageConfig &lt;&gt; null then
			if self.myVoyageConfig.myYACriteriaTypeForColour &lt;&gt; null then
				myText := self.myVoyageConfig.myYACriteriaTypeForColour.description;
			endif;		
		endif;
	endif;
	/*process.debugAdi();
	if self.myVoyageConfig &lt;&gt; null then
		myText := self.myVoyageConfig.myYACriteriaTypeForColour.description;
	endif;*/
	
	indx := self.cmbDefaultColour.findString(1,myText);

	if indx &gt; 0 then
		self.cmbDefaultColour.listIndex := indx;
	endif;
end;</source>
        <Parameter name="_reset" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupComboStatus" id="b4302ba6-9043-4806-8998-7828aa641508">
        <updating/>
        <source>setupComboStatus() updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
26/07/2013	cnwmc5	PAR 31714	Initial creation		
24/02/2017 	cnwrh7  TFS3464     #- Voyage definition / voyage status
15/03/2018	jlgdap1	TFS 37427 	PEL1 Voyage Status Enhancements
16/03/2018	jlgdap1	TFS 37540 	PEL1 Voyage Statuses Pelindo 1
24/04/2018	jlgdap1	TFS 38214 	PEL1 Voyage Status Changes
09/08/2019	jlgka1 	TFS 45921	PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
============================================================================*/
vars
	processStr 		: String;
	voyageProcess 	: CM_VoyageProcess;
	nextStatuses 	: CM_VoyageStatusByPriority;		// TFS 37540
	currentStatus 	: Integer;						// TFS 37540
	status 			: CM_VoyageStatus;						// TFS 37540

begin
	if self.shtPortsOfCall.visible then
		self.cmbProcess.clear;
		self.cmbProcess.listCollection(app.myRoot.allVoyageProcesses, true, 0);
		if self.myTerminal &lt;&gt; null then
			processStr := self.myTerminal.getConfig(DefaultVoyageProcess).String;
			voyageProcess := app.myRoot.allVoyageProcesses[processStr];
		else
			voyageProcess := app.myRoot.allVoyageProcesses[VoyageProcessDefault];
		endif;
		self.cmbProcess.listIndex := self.cmbProcess.findObject(voyageProcess);
		if self.myCurrentVoyage &lt;&gt; null then									// TFS 37540
			currentStatus := self.myCurrentVoyage.status;						// TFS 37540
		endif;	
		self.initComboVoyageStatus(voyageProcess,currentStatus);
		self.checkandsetCmbStatus(voyageProcess, currentStatus); // jlgka1 TFS 45921
	
	endif;	
epilog
	delete nextStatuses;		// TFS 37540
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9beaa0f5-63dc-4c59-8001-51c6b9894566">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
//Changed On   	Changed By  	Reason
vars
	tmpIntArray	: IntegerArray;

begin
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	self.myHarbour := self.myTerminal.myHarbour;
	
	// show hide sheets before calling initForm();
	self.viewModeOnly := (not app.myCurrentUserCan(self.myTerminal, PmAdmVoyageDefEdit));	
	
	create tmpIntArray transient;
	tmpIntArray.add(J_key_Tab);
	self.tblNewDimensions.registerKeys(tmpIntArray);
	
	self.showHideSheetsForView();
	self.initForm();
	
	self.shipCutoffsAutoAdjust := self.myTerminal.getConfig(ShipCutoffsAutoAdjust ).Boolean; // ### JIRA 34524 08APR2025 NAVAB1
epilog
	delete tmpIntArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideSheetsForView" id="e34d39be-0db0-4e0f-8adc-1e8bdb23df0d">
        <source>showHideSheetsForView();
//--------------------------------------------------
// Created:	21 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 30/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyge Rationalisation - Delays are now just for HMS now
//							so always display the delays table and buttons
vars
	tmpUser : CM_User;
	showHMSSheets : Boolean;
begin

	tmpUser	:=	app.getMyUser();
	showHMSSheets := tmpUser.canDo(self.myTerminal, Mod_Harbour) and (self.myCurrentVessel = null or (self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.hasHarbourDetails()));		// 20/8/19 MAP TFS45926
	self.setHMSEnabled(showHMSSheets); // PAR 36959
	
	if (tmpUser.canDo(self.myTerminal, Mod_CargoHandling)) then
		self.shtPortsOfCall.visible		:=	true;
		self.shtExchange.visible		:=	true;
		self.shtCutoffs.visible			:=	true;		// PAR 26390
		self.shtVoyageAlloc.visible		:=	true;		// PAR 26390
		self.grpCellulaVoyage.visible	:=	true;
	else
		self.shtPortsOfCall.visible	:= false;
		self.shtExchange.visible		:=	false;
		self.shtCutoffs.visible			:=	false;		// PAR 26390
		self.shtVoyageAlloc.visible		:=	false;		// PAR 26390
		self.grpCellulaVoyage.visible	:=	false;
	endif;

	
	lblWTimeInPort.visible		:=	true; // 6APR18 JLGAB1 TFS 37444
	txtWTimeInPort.visible		:=	true; // 6APR18 JLGAB1 TFS 37444
	lblWHours1.visible			:=	false;
	lblWNoChargeTime.visible	:=	false;
	txtWNoChargeTime.visible	:=	false;
	lblWHours2.visible			:=	false;
	lblWStopCharging.visible	:=	false;
	cmbWStopCharging.visible	:=	false;
	lblWLoadRate.visible		:=	false;
	txtWLoadRate.visible		:=	false;
	lblWTPH.visible				:=	false;
	lblWDischargeRat.visible	:=	false;
	txtWDischargeRat.visible	:=	false;
	lblWTPH2.visible			:=	false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showOperatorPicker" id="c11ec179-8da9-42a8-a2a7-be42d554d375">
        <source>showOperatorPicker(): CM_Operator;

/*
Date			Who		Reason
09 June 2009	cnwar2	Initial creation
08 June 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/
vars
	opPickerForm	: SHP_OperatorPicker;
	operator 		: CM_Operator;
	idx				: Integer;
	
begin
	create opPickerForm transient;
	opPickerForm.caption 			:= 'Operator Selector';
	opPickerForm.width 				:= 330;
	opPickerForm.cmbOperator.width 	:= 300;
	opPickerForm.height 			:= 150;
	
	opPickerForm.myTerminal := self.myTerminal;		// TFS 53362
	
	opPickerForm.allOperators.clear();							// 23/09/2009 cnwar2 #20674
	self.mulOperators.getSelected(opPickerForm.allOperators);	// 23/09/2009 cnwar2 #20674
	
	opPickerForm.showModal;
	if opPickerForm.modalResult = IDOK then
		operator := opPickerForm.cmbOperator.listObject.CM_Operator;
		if operator &lt;&gt; null then
		/*
			idx := 1;
			foreach idx in self.tblRecCutoffs.fixedRows + 1 to self.tblRecCutoffs.rows do
				if self.tblRecCutoffs.accessCell(idx, TblRecCutoffsCol_Code + 1).text = operator.code then
					app.msgBox("This operator has already been added.", app.getErrorString(InvalidCode), MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First);
					return null;
				endif;
			endforeach;
			*/
			return operator;
		endif;
	endif;

	return null;
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDelayForm" id="0ee761d9-2a6d-434b-841e-fc8ac00a671f">
        <source>showVoyageDelayForm(_edit : Boolean);
//--------------------------------------------------
// Created:	10 August 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 HMS_VoyageDelay objects are now CM_Delay objects
// 28/09/2016   cnwma1      TFS #2709:Voyage Maint Delay Maint no Working
vars
	//delay : HMS_VoyageDelay;			// PAR #35397
	delay : CM_Delay;					// PAR #35397
	voyage : CM_Voyage;					// PAR #35397
	menuAction : CMUI_MenuAction;
begin

 	if _edit then
		//delay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.HMS_VoyageDelay;						// PAR #35397
		delay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.CM_Delay;								// PAR #35397
		if delay = null then
			app.msgBox('Cannot perform edit as there is no delay selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
			self.tblDelays.setFocus();
			return;		
		endif;
	endif;
	
	//if self.myAssistant.showVoyageDelayForm(self.myCurrentVoyageData, delay, self.myMasterMenuAction) then	// PAR #35397
	//	self.displayHMSDelay();																					// PAR #35397
	//endif;																									// PAR #35397
	voyage := self.myCurrentVoyage;																			// PAR #35397

	create menuAction transient;   //28/09/2016 cnwma1 TFS #2709																			
	menuAction.setMyForm(self);      //28/09/2016 cnwma1 TFS #2709
	//self.myAssistant.showDelayEditForm(voyage, delay, null, false, null);										// PAR #35397 //28/09/2016 cnwma1 TFS #2709
	self.myAssistant.showDelayEditForm(voyage, delay, null, false,menuAction);								    //28/09/2016 cnwma1 TFS #2709

epilog
	delete menuAction;
end;</source>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectAndVoyageColl" id="803ebe8f-058b-4616-9504-a6216da4408e">
        <updating/>
        <source>showWithObjectAndVoyageColl(_object : CM_Object; _doMode : Boolean; _coll : Collection) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.showWithObjectMode(_object,_doMode);
	
	_coll.copy(self.allFilterVoyages);
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_doMode" type="Boolean"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectCutoffs" id="10f082af-9fcd-4502-aaaf-c5124f88e647">
        <updating/>
        <source>showWithObjectCutoffs(_object: CM_Object; _edit : Boolean) updating;
/*
Purpose:	PAR 35397		
Date				Who			Reason
JANUARY 2015		CNWAB1		Initial creation
*/
vars

	 failedDAC  :CM_DataAccessController;

begin
	if CM_Voyage.hasInstance(_object) then
		self.myCurrentVoyage := _object.CM_Voyage;
		self.myCopyGCStruct := null;	
		self.startVesselStructureNotes;
		if (not self.myCurrentVoyage.canUserAccessSelf(null, failedDAC, app.myPassport))
		or self.myCurrentVoyage.isNullVoyage then
			self.myCurrentVoyage := null;		
		endif;
	endif;	

	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyageData := self.myCurrentVoyage.myHMSVoyageData;
		self.myCurrentVessel := self.myCurrentVoyage.getMyVessel();
		
		if _edit 
		and (not self.myCurrentVoyage.archived) then
			// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected voyage
			self.mode := self.Mode_Update;
		endif;
	
	elseif _edit then
		// set to add mode. self.loadDataForFirstTime() will init form in add mode
		self.mode := self.Mode_Add;			
	endif;
	
	
	self.fldMain.topSheet := self.shtCutoffs;
	self.show();
		
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="889f19e5-3e26-499c-9ca4-bbb385adaf05">
        <updating/>
        <source>showWithObjectMode(_object: CM_Object; _doMode : Boolean) updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin
	inheritMethod(_object, _doMode);
	if CM_Voyage.hasInstance(_object) then
		self.myCurrentVoyage := _object.CM_Voyage;
		self.myCopyGCStruct := null;	//10 Jul 2013	NDL	Par 31965
		self.startVesselStructureNotes;
		if (not self.myCurrentVoyage.canUserAccessSelf(null, failedDAC, app.myPassport))
		or self.myCurrentVoyage.isNullVoyage then
			self.myCurrentVoyage := null;		
		endif;
	endif;	

	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyageData := self.myCurrentVoyage.myHMSVoyageData;
		self.myCurrentVessel := self.myCurrentVoyage.getMyVessel();
		
		if _doMode 
		and (not self.myCurrentVoyage.archived) then
			// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected voyage
			self.mode := self.Mode_Update;
		endif;
	
	elseif _doMode then
		// set to add mode. self.loadDataForFirstTime() will init form in add mode
		self.mode := self.Mode_Add;			
	endif;
	
	self.show();
		
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startVesselStructureNotes" id="18687c2c-5ab8-45d7-b8d7-b97c103000f7">
        <source>startVesselStructureNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVoyageStructure;
	structElements : CM_VoyageStructuralElements;
begin
	if self.myCurrentVoyage= null then
		return;
	endif;
	
	structElements:=self.myCurrentVoyage.myStructuralElements;
	if structElements &lt;&gt; null then
		self.beginNotification(structElements,EVENT_TANK_CREATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_TANK_UPDATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_TANK_DELETE,Response_Continuous,null);
		
		self.beginNotification(structElements,EVENT_SECTION_CREATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_SECTION_UPDATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_SECTION_DELETE,Response_Continuous,null);
		
		self.beginNotification(structElements,EVENT_DECK_ITEM_CREATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_DECK_ITEM_UPDATE,Response_Continuous,null);
		self.beginNotification(structElements,EVENT_DECK_ITEM_DELETE,Response_Continuous,null);
		
	endif;
	
	roroStructure:=self.myCurrentVoyage.myROROStructure ;
	if roroStructure &lt;&gt; null then
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_CREATE,Response_Continuous,null);
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_UPDATE,Response_Continuous,null);
		self.beginNotification(roroStructure,EVENT_DECK_ITEM_DELETE,Response_Continuous,null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="9535169c-9355-4404-9890-f9eb5e5e8b02">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	26 September 2005 By: cnwgd1
//--------------------------------------------------
vars

	event : Integer;

begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if event = Voyage_Update_Event or eventType = Voyage_Update_Event then
		self.loadTblWPOpHrs();
		self.displayHMSMovements();	//19 Nov 2018	NDL	TFS 42043
	endif;
	
	self.handleSystemNotification(eventType, theObject, eventTag);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
