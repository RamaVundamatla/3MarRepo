    <JadeMethod name="validateForCreate" id="8ab38610-ae5b-4144-bc6d-895746c6d96e">
        <source>validateForCreate();
/*
------------------------------------------------------------------------
Created:			09 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	if app.myRoot.allTransitStatuses[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	
	self.validateForUpdate();
end;</source>
    </JadeMethod>
