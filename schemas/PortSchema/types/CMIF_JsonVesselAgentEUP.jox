<Class name="CMIF_JsonVesselAgentEUP" id="eed3cbd8-7cff-446e-b698-1f57330afad1">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="code" id="f4b861cb-b960-4ed3-af39-9fc2e6a4c217">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="4f2990ad-3667-4289-868e-917065f4d553">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromVoyage" id="c1918129-5c55-4261-a0f4-670dcf0ab4eb">
        <updating/>
        <source>setFromVoyage(voyage : CM_Voyage input; _translationOperator : CM_Operator) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyageData		: HMS_VoyageData;
	shippingAgent	: CM_ShippingAgent;
	foundMatch		: Boolean;
begin
	voyageData := voyage.myHMSVoyageData;
	if voyageData &lt;&gt; null then
		shippingAgent := voyageData.myShippingAgent;
		if shippingAgent &lt;&gt; null then			
			self.code := shippingAgent.code;
			self.name := shippingAgent.description;
			if _translationOperator &lt;&gt; null then
				self.code := _translationOperator.getXlationForeignCode(self.code, XLATION_TYPE_SHIPINGAGENT_BYOP, foundMatch);
			endif;
		endif;
	endif;		
end;
</source>
        <Parameter name="voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
