    <JadeMethod name="setProxyObject" id="7e234adc-6f00-4f67-8246-aad8c0a6a6a1">
        <updating/>
        <source>setProxyObject(_any : Any) updating;

/*
Date		Who		Reason
31 Mar 2022	navra1 	TFS53028 	
*/


vars
	helper 	: CMIF_InvUnit;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName				:= helper.tableName;	
	self.gkey					:= helper.gkey;
	self.active_ufv 			:= helper.active_ufv ;
	self.category 				:= helper.category ;
	self.freight_kind 			:= helper.freight_kind ;
	self.goods_and_ctr_wt_kg 	:= helper.goods_and_ctr_wt_kg ;
	self.id 					:= helper.id ;
	self.line_op 				:= helper.line_op ;
	self.eq_gkey 				:= helper.eq_gkey ;
	self.relationship_role 		:= helper.relationship_role ;
	self.unit_combo 			:= helper.unit_combo ;
	self.visit_state 			:= helper.visit_state ;
	
	self.source_tos := helper.source_tos;	
	
	self.cargo_details := helper.cargo_details;
	self.cargo_subtype := helper.cargo_subtype;
	self.cargo_type := helper.cargo_type;
	self.cargo_supertype := helper.cargo_type;
	//navra1 - TFS-53105  - 9th Aug 2022
	self.measurement_unit_type := helper.measurement_unit_type;	
	
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
