    <JadeMethod name="doDelete" id="debef0bf-87b0-46b9-8e25-8bb1e4b46b76">
        <updating/>
        <source>doDelete(pObj: CM_WeightRange io) updating;
// -------------------------------------------
// Created 19 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	// cnwrl1 09/04/2009 PAR 19373 - was getting "old" error messages on deletion.
	app.myTrxDA.trxDeleteWeightRange( pObj, app.myPassport );
	
	/* cnwrl1 07/04/2009 PAR 19400 CCMS 1825 - what it was
	beginTransaction;
	pObj.erase(0);
	commitTransaction;
	*/
	
end;</source>
        <Parameter name="pObj" type="CM_WeightRange" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="bc524892-db3f-46a7-b77c-cf6045f6f1da">
        <updating/>
        <source>doSave(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 25 September 2003
//
// Changed On	By			Reason
//-----------------------------------------------------------------------
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	errObj			:	CM_Error;
	idx,
	lValue,
	lColour			:	Integer;
	tmpLstBox		:	ListBox;
	ignoreWarnings,
	rtnValue		:	Boolean;
	pxyWeightRange	:	CM_WeightRange;
	lLower,
	lUpper 			: Integer;
	theForm 		: SOP_TableMaintForm;
	percentage		: Integer;
	measure			: CM_MeasurementType;						// PAR #31155
begin
  theForm := self.myForm; 


//	lValue := theForm.tblInput1.getValueByName(ETRow_Value).Integer;
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	lUpper := theForm.tblInput1.getValueByName(ETRow_Upper).Integer;
	lLower := theForm.tblInput1.getValueByName(ETRow_Lower).Integer;
	percentage := theForm.tblInput1.getValueByName(ETRow_Percentage).Integer;
	measure := theForm.cmbWeightType.itemObject[theForm.cmbWeightType.listIndex].CM_MeasurementType;	// PAR #31155
	
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WeightRange transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Proxy_Object_Null_For_Update));
			return false;
		endif;
	endif;

	pxyWeightRange := theForm.myProxyObject.CM_WeightRange;
	//pxyWeightRange.setProxy(lLower, lUpper, percentage, lColour);										// PAR #31155
	pxyWeightRange.setProxy(lLower, lUpper, percentage, lColour, measure);								// PAR #31155

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateWeightRange(pxyWeightRange, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateWeightRange(pxyWeightRange, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="9b4d6692-3e31-4baa-ad7d-372fcfba6b89">
        <source>getCollection(): Collection;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 25 September 2003
//
// Changed On	By			Reason
//-----------------------------------------------------------------------
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	form 	: SOP_TableMaintForm;											// PAR #31155
	combo 	: CMUI_ComboBox;												// PAR #31155
	measure : CM_MeasurementType;											// PAR #31155

begin
	form := self.myForm;													// PAR #31155
	combo := form.cmbWeightType;											// PAR #31155
	if combo.itemObject[combo.listIndex] = null then						// PAR #31155
		return app.myRoot.allWeightRanges;
	else																	// PAR #31155
		measure := combo.itemObject[combo.listIndex].CM_MeasurementType;	// PAR #31155
		return measure.allWeightRanges;										// PAR #31155
	endif;																	// PAR #31155

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
