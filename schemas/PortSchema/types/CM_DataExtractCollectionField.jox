    </JadeMethod>
    <JadeMethod name="doExtractData" id="16e8c4fc-1145-44cd-8296-f7b39f675662">
        <source>doExtractData(_object: CM_Object; _outputFile : File): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	fileLine        : String;
	writeHeader     : Boolean;
	colRefField     : CM_DataExtractField;
	colRefFields    : CM_DataExtractFieldArray;
	outputFile      : File;
	oldFileName,
	fileName		: String;
begin
	oldFileName := _outputFile.fileName;
	
	fileName := "_" &amp; self.niceName &amp; CM_DataExtractClass.CSVOutputFileExtension;
	fileName := oldFileName.replaceString(CM_DataExtractClass.CSVOutputFileExtension, fileName);
	fileName := fileName.removeString(" ");
	
	create outputFile transient;
	outputFile.fileName := fileName;
	outputFile.mode := File.Mode_Append;
	//outputFile.kind := File.Kind_ANSI;
	outputFile.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	if not outputFile.isAvailable then
		writeHeader := true;
		app.myDataExtractAgent.logMessage("Extracting data of " &amp; self.niceName &amp; " to "&amp; fileName);
	endif;
	
	if (not outputFile.tryOpen) then
		app.raiseCMException1(FileUnavailable, outputFile.fileName, null, null);
		return null;
	endif;		
	
	colRefFields :=  self.getDataExtractClass.getCollectionRefField();
	if colRefFields &lt;&gt; null then
		foreach colRefField in colRefFields do
			fileLine := fileLine &amp; colRefField.doExtractData(_object, _outputFile) &amp; ",";
		endforeach;
	endif;
	
	if writeHeader then
		self.extractHeader(colRefFields, outputFile);
	endif;
	
	self.extractColFieldValue(_object, fileLine, outputFile);	
	return null;
epilog
	delete colRefFields;
	if outputFile &lt;&gt; null then
		outputFile.close;
		delete outputFile;
	endif;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_outputFile" type="File"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doExtractDoc" id="f32f58c5-3ddb-46bb-baac-15d9626a0d12">
        <source>doExtractDoc(_outputFile: File);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	oldFileName,
	fieldName,
	fileName     : String; 
	colRefFields : CM_DataExtractFieldArray;
	field        : CM_DataExtractField;
	doc          : File;
begin
	oldFileName := _outputFile.fileName;
	fileName := "_" &amp; self.niceName &amp; CM_DataExtractClass.DocumentationOutputFileName;
	fileName := oldFileName.replaceString(CM_DataExtractClass.DocumentationOutputFileName, fileName);
	fileName := fileName.removeString(" ");
	
	fileName := _outputFile.fileName.replaceString(oldFileName, fileName);

	app.myDataExtractAgent.logMessage("Extracting documentation of " &amp; self.niceName &amp; " to "&amp; fileName);
	
	create doc transient;
	doc.fileName := fileName;
	doc.mode := File.Mode_Output;
	//doc.kind := File.Kind_ANSI;// 2/3/16  cnwns1 PAR 36286 unicode version
	if (not doc.tryOpen) then
		app.raiseCMException1(FileUnavailable, doc.fileName, null, null);
		return;
	endif;
	doc.purge();
	
	doc.writeLine("Column Heading,Description,JMT Field Type,Possible Values");
	colRefFields := self.getDataExtractClass.getCollectionRefField();
	if colRefFields &lt;&gt; null then
		foreach field in colRefFields do
			field.doExtractDoc(doc);
		endforeach;
	endif;
	
	field := null;
	foreach fieldName in self.extractOrder do 
		field   := self.allChildFields[fieldName];
		field.doExtractDoc(doc);
	endforeach;	
	
epilog
	delete colRefFields;
	if doc &lt;&gt; null then
		doc.close;
		delete doc;
	endif;
end;</source>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="extractColFieldValue" id="e57ca088-5aaf-4762-9f88-60c58d836c55">
        <source>extractColFieldValue(_object:CM_Object; _refId : String; _outputFile : File);
vars
	fieldName    : String;
	fieldString  : String;
	fieldLine    : String;
	classNumber  : Integer;
	childField   : CM_DataExtractField;
	transMethod  : CM_DataExtractTransientMethod;
	colObject    : CM_Object;
	coll	     : Collection;
	iter	     : Iterator;
	refIdNoComma : String;
	fieldNoComma : String;
	stringArray  : StringArray;
begin 
	coll := _object.getPropertyValue(self.name).Collection;
	if coll.isKindOf(StringArray) then
		stringArray := coll.StringArray;
		foreach fieldString in stringArray do
			fieldLine := _refId;
			fieldString := self.getDataExtractClass.tidyUpStringForCSVOutput(fieldString);
			fieldLine   := fieldLine &amp; fieldString &amp; ",";
			_outputFile.writeLine(fieldLine);
		endforeach;
		return;
	endif;
	
	iter := coll.createIterator();
	while iter.next(colObject) do
		fieldLine := _refId;
		foreach fieldName in self.extractOrder do
			childField   := self.allChildFields[fieldName];
			classNumber := self.childFieldClass.number;
			transMethod := app.myDataExtractAgent.allDataExtractTransientMethods.getAtKey(classNumber, fieldName);
			fieldString := process.executeTransientMethod(transMethod.myJadeMethod, childField, colObject).String;
			fieldString := self.getDataExtractClass.tidyUpStringForCSVOutput(fieldString);
			fieldLine   := fieldLine &amp; fieldString &amp; ",";
		endforeach;
		refIdNoComma := _refId;
		fieldNoComma := fieldLine;
		if fieldNoComma.removeCommas() &lt;&gt; refIdNoComma.removeCommas() then
			_outputFile.writeLine(fieldLine);
		endif;
	endwhile;
epilog
	delete iter;		// PAR #27874
end;
</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_refId" type="String"/>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="extractHeader" id="f793347f-2464-403c-8f7f-ac4ade3ae610">
        <source>extractHeader(_colRefFields : CM_DataExtractFieldArray; _outputFile : File) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	headerLine   : String;
	headerString : String;
	fieldName    : String;
	field        : CM_DataExtractField;
begin
	if _colRefFields &lt;&gt; null then
		foreach field in _colRefFields do
			headerString := field.niceName;
			if headerString[1] &lt;&gt; '"' then // if the first two characters are uppercase ID then excel won't work correctly.
				headerLine := headerLine &amp; '"' &amp; headerString &amp; '"' &amp; ",";	
			else
				headerLine := headerLine &amp; headerString &amp; ",";	
			endif;
		endforeach;
	endif;
	
	field := null;
	foreach fieldName in self.extractOrder do
		field   := self.allChildFields[fieldName];
		headerString := self.getDataExtractClass.tidyUpStringForCSVOutput(field.niceName);
		headerLine := headerLine &amp; headerString &amp; ",";	
	endforeach;
	_outputFile.writeLine(headerLine);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_colRefFields" type="CM_DataExtractFieldArray"/>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
