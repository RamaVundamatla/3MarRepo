    <JadeMethod name="finalize" id="31b81a78-9256-4745-b095-fec699ecf137">
        <updating/>
        <source>finalize() updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	delete self.myTrxRT;
	delete self.myUtlRT;
	delete self.myEnquiryAgent;
	delete self.myValRT;
	
	// Hack because 6.1 calls finalise twice causing code 4 crash.
	if app.isValidObject(app.myCnLog) then
		inheritMethod();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getRTDeviceForSelf" id="f944c97f-6dd3-4a3a-a735-1ab23373364a">
        <source>getRTDeviceForSelf(_computerName : String) : CM_RadioTelemetryDevice;

vars
	terminal		: CM_Terminal;
	radioTelemetry	: CM_RadioTelemetry;
	device			: CM_RadioTelemetryDevice;
begin
	foreach terminal in app.myRoot.allTerminals discreteLock do
		radioTelemetry := terminal.radioTelemetry ;
		if radioTelemetry = null then
			continue;
		endif;
		foreach device in radioTelemetry.allRTDevices discreteLock do
			//if device.computerName.toUpper = app.computerName.toUpper then
			if device.computerName.toUpper = _computerName.toUpper then
				return device;
			endif;
		endforeach;
	endforeach;
	return null;
end;


</source>
        <Parameter name="_computerName" type="String"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="getTerminalRTDeviceOpenMax" id="17e035e3-ef2e-47d9-8fef-f95bd323b580">
        <updating/>
        <source>getTerminalRTDeviceOpenMax(_sectionName : String; _device : CM_RadioTelemetryDevice) updating;

/*

Purpose:		Get the details from the ini file		

Parameters:			

Return Value:		


Date			Who		Reason
30 August 2011	cnwmh5	Initial creation

*/

vars

	profileString		: String;
	iniFileName			: String;

begin

	iniFileName := app.getIniFileName();
	
	profileString := false.String;
	
	if _device = null then
		profileString := app.getProfileString(iniFileName, _sectionName, 'OpenMaximised', "&lt;not set&gt;");
		if profileString = "&lt;not set&gt;" then
			app.setProfileString(iniFileName, _sectionName, "OpenMaximised", true.String);
			profileString := true.String;
		endif;
	endif;
	
	self.openMaximised := profileString.Boolean;
	
	self.terminalIdFromIniFile := app.getProfileString(iniFileName, _sectionName, "Terminal","&lt;not set&gt;");
	
	self.rtDeviceIdFromIniFile := app.getProfileString(iniFileName, _sectionName, "RTDeviceId", "&lt;not set&gt;");
	
	//07 Dec 2015	NDL	Par 37269
	self.allowMaximiseButton := false;
	profileString := app.getProfileString(iniFileName, _sectionName, 'AllowMaximiseButton', "false");
	if profileString.toUpper = "TRUE" then
		self.allowMaximiseButton := true;
	endif;
	
epilog

end;
</source>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_device" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="initITSInterfaceApp" id="5b733f14-6282-4e49-af2b-7bf5a8c8927f">
        <updating/>
        <source>initITSInterfaceApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for ITS Interface application

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		Nothing


Date		Who		Reason
11 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.initialize();
	
	// PAR 25284 - This will make sure warnings are promoted to errors and will get displayed to the client
	app.isRTApp := true;

	create self.myInterfaceController as CM_ITSInterfaceController;
	self.myInterfaceController.start();
	
epilog

end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initITSQueueMonitorApp" id="682cb2fc-8a92-49a8-85dc-dd7300c4d725">
        <updating/>
        <source>initITSQueueMonitorApp(_interface : CM_ITSInterfaceDefinition) updating;

/*

Purpose:			Initialisation method for ITS Queue Monitor application

Parameters:			Interface definition to run

Return Value:		None


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	controller		: CM_ITSQueueMonitorController;
	
begin
	self.initialize();
	
	// PAR 25284 - This will make sure warnings are promoted to errors and will get displayed to the client
	app.isRTApp := true;

	if _interface = null then
		app.writeLog(app.name &amp; " started without an assigned " &amp; CM_TCPInterfaceDefinition.name &amp; ", terminating", LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;		

	app.writeLog(app.name &amp; " started for Terminal " &amp; _interface.myTerminal.displayForXlation(true) &amp; " using Interface  " &amp; _interface.name, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create controller;
	self.myInterfaceController := controller;
	controller.setMyInterfaceDefinition(_interface);
	
	controller.start();
	

epilog

end;</source>
        <Parameter name="_interface" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
