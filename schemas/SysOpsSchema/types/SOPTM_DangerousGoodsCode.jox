    <JadeMethod name="initModalDialog" id="bdc9b8cb-0064-47e8-bc4f-68c8fc0ee53c">
        <source>initModalDialog();
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	
	theForm.frmModalDialog.centreWindow;
	theForm.frmProgressCtr.move(0,0,theForm.frmModalDialog.clientWidth,theForm.frmModalDialog.clientHeight);
	theForm.frmModalDialog.backColor := theForm.backColor;
	theForm.btnModalDefault.visible := false;
	theForm.pbProgressBar.top := 38;
	theForm.lblModalInfo.top := theForm.pbProgressBar.top + theForm.pbProgressBar.height + 2;
	theForm.pbProgressBar.zOrder(0);
end;</source>
    </JadeMethod>
