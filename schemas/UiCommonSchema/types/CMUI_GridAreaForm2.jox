    <JadeMethod name="showPreferences" id="a3643006-9e7d-4c29-adf2-3458c361af14">
        <updating/>
        <source>showPreferences() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : Frame;
	theTable : CM_EntryTable;
	tblHeight, theTop : Integer;
begin
	theFrame := self.frmPreferences;
	theTable := self.tblPreferences;
	
	theFrame.centreWindow();
	theTable.resetHeight();
	tblHeight := theTable.clientHeight;
	if tblHeight &lt; 20 then
		tblHeight := 20;
	elseif tblHeight &gt; (self.clientHeight - 100)  then
		tblHeight := (self.clientHeight - 100);
	endif;
	theTable.height := tblHeight ;
	
	theTop := (theTable.top + tblHeight + 5).Integer;
	self.btnPreferSave.top := theTop;
	self.btnPreferCancel.top := theTop;
	theFrame.height := theTop + self.btnPreferSave.clientHeight + 15;
	
	theFrame.zOrder(1);
	theFrame.visible := true;
end;</source>
    </JadeMethod>
