        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="1e4a9e5a-a5a3-4b8c-bd7d-8ed2c668d12f">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Enables various controls based upon what list entries are selected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if lstAttributes.listIndex = CNEC_NULL_INDEX
	and lstMethods.listIndex = CNEC_NULL_INDEX then
		btnSelect.enabled	:=	false;
	else
		btnSelect.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="4e6f6950-e7cf-4212-95fe-1cd95232947d">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Performs initialization operations for the form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
	modalResult	:=	self.CNEC_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="90a7495f-43d8-451a-9860-1936c08459f3">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Performs once-off data load operations for the form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	centreWindow();
	
//	if self.aMySchema = null then
//		self.aMySchema	:=	currentSchema;
//	endif;
	
	self.populateSchemas();
	self.populateClasses();
	self.doFormInitialize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenCloseListNode" id="c708956b-a38f-4eef-918d-9edc653b056d">
        <source>doOpenCloseListNode(pListboxObj:ListBox input; pListPointer:Integer; pIsRecursive:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Purpose:		Opens/Closes the selected tree node of the specified listbox.
//
// Parameters:	pListboxObj - A reference to the listbox control.
//				pListPointer - The index if the tree node to open/close.
//				pIsRecursive - True if the entire branch is to be eopened/closed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nextPointer	: Integer;
	
begin
	if (not pListboxObj.itemExpanded[pListPointer])
	and ((pListPointer + 1) &lt;= pListboxObj.listCount)
	and (pListboxObj.itemText[pListPointer + 1] = self.DUMMY_FOLDER)
	and (pListboxObj.itemObject[pListPointer].Class.hasSubclasses)
	then
		self.populateSubclasses(pListboxObj.itemObject[pListPointer].Class, (pListboxObj.itemLevel[pListPointer] + 1));
	endif;

	pListboxObj.itemExpanded[pListPointer]	:=	(not pListboxObj.itemExpanded[pListPointer]);
	
	if pIsRecursive and pListboxObj.itemExpanded[pListPointer] then
		nextPointer	:=	pListPointer + 1;
		
		if nextPointer &lt;= pListboxObj.listCount() then
			doOpenCloseListNode(pListboxObj, nextPointer, pIsRecursive);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pListPointer" type="Integer"/>
        <Parameter name="pIsRecursive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getClassDescription" id="f12f48e8-4f50-48c4-93b0-767334126f37">
        <source>getClassDescription(pClassObj:Class):String protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Returns a display of a class name and the number of instances.
//
// Parameters:	pClassObj - The class whose display string to return.
//
// Returns:		String - The class display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classDescription	: String;

begin
	if pClassObj = null then
		classDescription	:=	null;
	else
		classDescription	:=	pClassObj.Class.name;

		if pClassObj.schema &lt;&gt; self.aMySchema then
			classDescription	:=	classDescription &amp; '      (of ' &amp; pClassObj.schema.name &amp; ')';
		endif;

		if pClassObj.abstract then
			classDescription	:=	classDescription &amp; '   (Abstract)';
		else
			// Do nothing else.
		endif;
	endif;
epilog
	return classDescription;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassForeColor" id="d9811a0a-0775-4d30-9314-1c4528cbd757">
        <source>getClassForeColor(pClassObj:Class; pListboxObj:ListBox input; pIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Sets the appropriate fore color for a class in a listbox control.
//
// Parameters:	pClassObj - The class whose fore color we're setting.
//				pListboxObj - The listbox containing the class.
//				pIndex - The index of the class in the listbox.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pClassObj.isSystemObject then
		pListboxObj.itemForeColor[pIndex]	:=	Red;
		
	elseif pClassObj.schema &lt;&gt; self.aMySchema then
		pListboxObj.itemForeColor[pIndex]	:=	Blue;
		
	elseif pClassObj.abstract then
		pListboxObj.itemForeColor[pIndex]	:=	Green;
		
	else
		pListboxObj.itemForeColor[pIndex]	:=	Black;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listFindClass" id="3b3de4e7-f9a0-447d-bf2a-84fb77214057">
        <source>listFindClass() protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Looks to a class in the hierarchical class listbox.  If the class
//				is valid but is not loaded into the listbox, the listbox hierarchy
//				will be populated down to the class's level.  When the class is
//				found in the listbox, it's hierarchy tree will be opened down to
//				the class's level, and the class will become the currently selected
//				list item.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputFormObj		: CnEcUserInputForm;
	className			: String;
	listboxObj			: ListBox;
	listPointer			: Integer;
	parentIndex			: Integer;
	classObj			: Class;
	superClassObj		: Class;
	subclassObj			: Class;
	treeClassObj		: Class;
	listClassObj		: Class;
	allClassesObj		: ClassColl;
	allSubClassesObj	: ClassColl;
	listLevel			: Integer;
	
begin
	create inputFormObj;
	inputFormObj.setProperties("Find Class", "Enter the name of the class to find:", null);
	
	if inputFormObj.showModal = CNEC_MODAL_UPDATE then
		className	:=	inputFormObj.getValue();
		listboxObj	:=	lstClasses;
		
		listPointer	:=	listboxObj.findStringExact(1, className);
	
		if listPointer = CNEC_NULL_INDEX then
			// The class is not in the listbox, so we'll look for it in the schema.
			
			classObj	:=	self.aMySchema.getClass(className);
			
			if classObj &lt;&gt; null and classObj._isSubschemaCopy() then
				classObj	:=	classObj.rootType().schema.getClass(classObj.name);
			endif;
			
			if classObj = null then
				app.msgBox(	"Class not found: " &amp; className &amp; CrLf &amp; CrLf &amp; "Note that class names are case sensitive.",
							"Find Class", MsgBox_Information_Icon + MsgBox_OK_Only);
			else
				create allClassesObj transient;
				allClassesObj.add(classObj);
				superClassObj	:=	classObj;
	
				// Load the class hierarchy into a class collection.
	
				while (not superClassObj = null) do
					superClassObj	:=	superClassObj.getSuperclass();
	
					if superClassObj &lt;&gt; null then
						if (superClassObj._isSubschemaCopy) then
							superClassObj	:=	superClassObj.cnEcGetImplementationSchema().getClass(superClassObj.name);
						endif;
	
						allClassesObj.add(superClassObj);
	
						if listboxObj.findObject(superClassObj) &lt;&gt; CNEC_NULL_INDEX then
							break;
						endif;
					endif;
				endwhile;
	
				// Now load the class hierarchy into the listbox.
				
				create allSubClassesObj transient;
				
				foreach superClassObj in allClassesObj reversed do
					listPointer	:=	listboxObj.findObject(superClassObj);
	
					if listPointer = CNEC_NULL_INDEX then
						listPointer	:=	listboxObj.findObject(superClassObj.getSuperclass());
	
						if listPointer &lt;&gt; CNEC_NULL_INDEX then
							listLevel	:=	listboxObj.itemLevel[listPointer] + 1;
	
							if listboxObj.itemText[listPointer + 1] = self.DUMMY_FOLDER then
								listboxObj.removeItem(listPointer + 1);
							endif;
	
							treeClassObj	:=	self.aMySchema.getClass(superClassObj.getSuperclass().name);
	
							if treeClassObj &lt;&gt; null then
								treeClassObj.getSubclasses(allSubClassesObj);
							endif;
	
							foreach subclassObj in allSubClassesObj do
								if (not subclassObj.isSystemObject()) then
									if subclassObj._isSubschemaCopy then
										listClassObj	:=	subclassObj.cnEcGetImplementationSchema().getClass(subclassObj.name);
									else
										listClassObj	:=	subclassObj;
									endif;
									
									listPointer		:=	listPointer + 1;
									listboxObj.addItemAt(self.getClassDescription(listClassObj), listPointer);
									listboxObj.itemObject[listPointer]	:=	listClassObj;
									listboxObj.itemLevel[listPointer]	:=	listLevel;
									self.getClassForeColor(listClassObj, listboxObj, listPointer);
									
									if subclassObj.hasSubclasses() then
										listPointer	:=	listPointer + 1;
										listboxObj.addItemAt(self.DUMMY_FOLDER, listPointer);
										listboxObj.itemLevel[listPointer]	:=	listLevel + 1;
									endif;
								endif;
							endforeach;
							
							if allSubClassesObj.cnEcIsNotEmpty() then
								allSubClassesObj.clear();
							endif;
						endif;
					endif;
				endforeach;
				
				// Now open up the folders in the class hierarchy.
				
				listPointer	:=	listboxObj.findObject(classObj);
				parentIndex	:=	listboxObj.cnEcFindParent(listPointer);
				
				while parentIndex &lt;&gt; 0 do
					if (not listboxObj.itemExpanded[parentIndex]) then
						listboxObj.itemExpanded[parentIndex]	:=	true;
					endif;
					
					parentIndex	:=	listboxObj.cnEcFindParent(parentIndex);
				endwhile;
	
				listboxObj.listIndex	:=	listPointer;
			endif;
		else
			// Now open up the folders in the class hierarchy.
	
			parentIndex	:=	listboxObj.cnEcFindParent(listPointer);
	
			while parentIndex &lt;&gt; 0 do
				if (not listboxObj.itemExpanded[parentIndex]) then
					listboxObj.itemExpanded[parentIndex]	:=	true;
				endif;
	
				parentIndex	:=	listboxObj.cnEcFindParent(parentIndex);
			endwhile;
	
			listboxObj.listIndex	:=	listPointer;
		endif;
	endif;
	
	self.populateFeatures();
epilog
	delete allClassesObj;
	delete allSubClassesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
