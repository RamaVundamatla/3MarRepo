    <JadeMethod name="allowCargoPositionSwap" id="4703eb21-d22d-4bd5-b2a2-e281fb64f68a">
        <source>allowCargoPositionSwap(_caption : String output):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars

	selectedCargo : CM_TIArray;
	dataArray : ObjectArray;
	obj : Object;
	addComma : Boolean;
	firstString : String;
	secondString : String;
	
begin

	create selectedCargo transient;
	create dataArray transient;
	self.mySDF.getAllSelectedTIs( selectedCargo );
	if not self.myAssistant.YRD_Assistant.allowCargoPositionSwap( selectedCargo, self.moveModeForm, dataArray ) then
		return false;
	endif;
	
	foreach obj in dataArray do
		if CM_TrackedItem.hasInstance(obj) then
			if firstString = null then
				firstString := obj.CM_TrackedItem.id;
			elseif not addComma then
				addComma := true;
				secondString := secondString &amp; obj.CM_TrackedItem.id;
			elseif addComma then
				secondString := secondString &amp; ", " &amp; obj.CM_TrackedItem.id;
			endif;
		endif;
	endforeach;
	_caption := app.getErrorString2(Cargo_swap_with, firstString, secondString); 
	return true;
	
epilog

	delete selectedCargo;
	delete dataArray;
	
end;</source>
        <Parameter name="_caption" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIToTransport" id="0c5c8d4a-1f1a-453a-bd81-614cb0e818b2">
        <updating/>
        <source>assignTIToTransport(_toLocationsController : CM_LocationsController)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/06/2009	consw1		PAR 20070 - Move multiple containers
// 10/07/2009	consw1		PAR 20213 - Unable to plan outward rail while inward cargo still on wagon
// 16/07/2009	consw1		Par 20293 - UE 1090
// 27/08/2009	consw1		PAR 20538 - Unable to select containers following drag/drop from another form
// ---------------------------------------------------------------------------
vars
	tiColl : CM_TIArray;
	tmpTi : CM_TrackedItem;
	result : Integer;
	moveController : CMIF_MoveController;
	tranArea : String;
	wagon : CM_Wagon;
	wagons : CM_WagonArray;
begin

	if _toLocationsController = null then
		return;
	endif;
	
	if app.myMoveController = null then
		return;
	endif;
	
	if not _toLocationsController.isWagon() then
		app.raiseCMException(VB_MOVE_INVALID, null, null);
		return;	
	endif;

	wagon := _toLocationsController.CM_WagonController.myWagon;

	moveController := app.myMoveController;
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;

	if tmpTi.myTerminal &lt;&gt; self.myTerminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, tmpTi.myTerminal.code, self.myTerminal.code, null, null);
		return;	
	endif;

	if moveController.allOtherTrackedItems.size = 1 and moveController.allOtherTrackedItems.includes(tmpTi) then
		moveController.allOtherTrackedItems.clear();
	endif;

	if moveController.allOtherTrackedItems.isEmpty() then
		moveController.setMyToPrimaryLocation(_toLocationsController);
	else
		create tiColl transient;
		moveController.allOtherTrackedItems.copy(tiColl);
		moveController.allOtherTrackedItems.clear();
		if not tiColl.includes(tmpTi) then
			tiColl.insert(1,tmpTi);
		endif;
		// CCMS 1067 PAR 19913
		create wagons transient;
		self.getSelectedWagons(wagons, null);
		if wagons.isEmpty() then
			wagons.add(wagon);
		endif;
	endif;	
	// PAR 20681
	if tmpTi.myPrimaryPlannedLocation &lt;&gt; null 
	and self.moveModeForm = PLANNING_MODE then
		moveController.isReplan := true;
		moveController.setMoveIndex(tmpTi.allPlannedFutureMoves.indexOf(tmpTi.getFMforLC(tmpTi.myPrimaryPlannedLocation, PLANNING_MODE)));
		moveController.setMyOriginatingLocation(tmpTi.myPrimaryPlannedLocation);
	endif;	

	while true do
		if tiColl = null then
			app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveTrackedItemsNewRailJob(wagons, tiColl, moveController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Assign_Transport), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		break;
	endwhile;
	
epilog
	delete tiColl;
	app.isDragging := false;
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;	
	
	delete wagons;
end;</source>
        <Parameter name="_toLocationsController" type="CM_LocationsController"/>
    </JadeMethod>
