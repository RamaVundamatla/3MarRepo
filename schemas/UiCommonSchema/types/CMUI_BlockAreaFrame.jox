    <JadeMethod name="getZoomFactor" id="0c046843-b1af-48ac-827b-5137a44a20ec">
        <source>getZoomFactor() : Real;

/*

Purpose:			Get the current zoom factor of the receiver

Parameters:			None

Return Value:		Current zoom scale factor


Date		Who		Reason
27 May 2008	cnwkpd1	Initial creation - PAR #16753

*/

vars

begin
	if self.myDrawingController &lt;&gt; null then
		return self.myDrawingController.scaleFactor;
	endif;
	
	return CMUI_GridDrawingController.ScaleFactor_1;		// default to 1
		

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
