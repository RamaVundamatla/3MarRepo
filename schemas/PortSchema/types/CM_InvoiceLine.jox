        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityInventoryCalcType" id="e1d7ab98-0dc2-4e77-9861-8691edaf15a9">
        <source>quantityInventoryCalcType(_theCalcType : CM_CalculationType) : Real;
/*
Purpose:			

Date		Who		Reason
01JUN2021	NAVAB1	TFS 51219
TFS BUG 61892 29DEC2023 NAVAB1 changed to pass in the calc type
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	value,
	valueOut, convRate, amount, blockvalue 	: Real;
	blockUnit	: Integer;
	chargedDaysWorking	: Boolean;
	theBank : CM_Bank;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	tran : CMEVT_LocationActivity;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	tran := self.myTransactionEvent.CMEVT_LocationActivity;
	
	if _theCalcType = null then // default
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; ": Inventory quantity 1 for DEFAULT", LogINFO.String);
		endif;
		return 1; // default;
	endif;
	theBank := self.getBank();
	blockUnit := _theCalcType.theCalcTypeUnit;

	if tran &lt;&gt; null then 
		if _theCalcType.calculationType = INV_CALC_TYPE_INVENT_VALUE1 then
			value := 1.0;
		elseif _theCalcType.calculationType = INV_CALC_TYPE_INVENT_QUANTITY 
		or _theCalcType.calculationType = INV_CALC_TYPE_INVENT_VOLUME 
		or _theCalcType.calculationType = INV_CALC_TYPE_INVENT_WEIGHT then
		
			if _theCalcType.calculationType = INV_CALC_TYPE_INVENT_QUANTITY then
				value := tran.quantity;
				convRate := 1;
			else
			
				// ### MEASUREMENT TYPE
				if _theCalcType.myMeasurementType &lt;&gt; null then
					convRate := _theCalcType.myMeasurementType.conversionRate;
				else
					convRate := 1;
				endif;
						
				// ### AMOUNT
				if _theCalcType.calculationType = INV_CALC_TYPE_INVENT_WEIGHT then 
					amount := tran.weight; // KG
				elseif _theCalcType.calculationType = INV_CALC_TYPE_INVENT_VOLUME then 
					amount := tran.volume;
				else
					amount := 1;
				endif;
				
				// ### CONVERT
				value := (amount / convRate);
			endif;
			
			blockvalue := 1; // default
			
			// ### BLOCK UNIT
			if blockUnit = INV_CALC_TYPE_INVENT_QUANTITY 
			or blockUnit = INV_CALC_TYPE_INVENT_VOLUME 
			or blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then
				if blockUnit = INV_CALC_TYPE_INVENT_QUANTITY then
					blockvalue := tran.quantity;
				elseif blockUnit = INV_CALC_TYPE_INVENT_VOLUME 
				or blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then
				
					// ### AMOUNT
					if blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then 
						blockvalue := tran.weight; // KG
					elseif blockUnit = INV_CALC_TYPE_INVENT_VOLUME then 
						blockvalue := tran.volume;
					else
						blockvalue := 1;
					endif;
				endif;
			endif;
			
			if blockvalue= 0 then
				blockvalue := 1;
			endif;
			
			value := value * blockvalue;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " - TRANSACTION QUANTITY -  blockUnit=" &amp; blockUnit.String &amp; " amount=" &amp; amount.String 
									&amp; " convRate=" &amp; convRate.String &amp; ", convValue=" &amp; (amount / convRate).String &amp; ", quantity=" &amp; value.String, LogTRACE.String);
			endif;
			value := self.adjustQuantityForRange(value);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " - ADJUST FOR RANGE QUANTITY -  " &amp; value.String, LogTRACE.String);
			endif;

		endif;
	endif;

	if _theCalcType &lt;&gt; null and _theCalcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := tran;
		cmifHook.origQty := value;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, _theCalcType, _theCalcType, cmifHook).Real;
		value := valueOut;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Inventory quantity " &amp; value.String &amp; " for calculation type " &amp; _theCalcType.description, LogINFO.String);
	endif;
	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_theCalcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityVOYAGE" id="e98fe265-d13a-4f63-82d4-75588d32593f">
        <updating/>
        <source>quantityVOYAGE() : Real updating;
 // ### TFS BUG 61892 29DEC2023 NAVAB1 - for JRW All code moved to quantityVOYAGECalcType()
vars
	theCalcType : CM_CalculationType;
begin
	theCalcType := self.invoiceLineDesc.getCalcType();
	return self.quantityVOYAGECalcType(theCalcType);

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityVOYAGECalcType" id="7f1f12dd-3e57-48a1-b30c-ceda34526d9b">
        <updating/>
        <source>quantityVOYAGECalcType(_theCalcType : CM_CalculationType) : Real updating;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_QuantityMap::getQuantityForTransactionVTMIS
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
TFS BUG 61892 29DEC2023 NAVAB1 changed to pass in the calc type
*/

vars
	value : Real;
	valueOut	: Real;
	theVoyage : CM_Voyage;
	theUnits : Integer;
	blockUnit : Integer;
	theHMSData : HMS_VoyageData;
	theResUsed : HMS_ResourceUsed;
	hmsTran : HMS_VTMISTransaction;
	stTS,endTS : TimeStamp;
	diffMin	: Integer;
	numHours : Integer;
	numHourBlocks : Real;
	invalid : Boolean;
	cmifHook	: CMIF_CalcTypeQuantityHook;		// cnwmc5 - 8 Oct 2015 - PAR 36920
	hoursDec : Decimal[23,2];
begin
	if self.hasMinMaxTotal then
		return self.quantity;
	endif;
	
	hmsTran := self.myTransactionHMS;

	if hmsTran &lt;&gt; null then
		theVoyage := hmsTran.myVoyage;
		if theVoyage = null then
			return 0;
		endif;
		if _theCalcType = null then
			return 0;
		endif;
		blockUnit := _theCalcType.theCalcTypeUnit;
		on Exception do app.handleDeletedObject(exception, theVoyage, invalid);
		theHMSData := theVoyage.myHMSVoyageData;
		if invalid then
			return 0;
		endif;
		on Exception do null;
		theResUsed := hmsTran.myResourceUsed;
		
		if theResUsed = null then
			return 0;
		endif;
		theUnits := _theCalcType.calculationType;
		stTS := theResUsed.fromDateTime;
		endTS := theResUsed.toDateTime;
		
		//19 Feb 2019	NDL	TFS 43374
		if theUnits = INV_CALC_TYPE_RESOURCE_DAYS then
			if theResUsed.myWorkOrderVoyageDtl &lt;&gt; null
			and theResUsed.myWorkOrderVoyageDtl.isKindOf(CM_WodMarineServiceDetail)
			then
				//12/3/19 tfs 43374
				if not stTS.isValid() then 
					stTS := theResUsed.myWorkOrderVoyageDtl.CM_WodMarineServiceDetail.getCalcResourceDaysStart();  // when the extension has been actioned 'oldDepartureDT' will have been set		
				endif;
				if not endTS.isValid() then
					endTS := theResUsed.myWorkOrderVoyageDtl.CM_WodMarineServiceDetail.getCalcResourceDaysEnd();
				endif;
			else
				if not stTS.isValid() then
					stTS:=theVoyage.getArrivalDT;
				endif;
				if not endTS.isValid() then
					endTS:=theVoyage.getDepartureDT;
				endif;				
			endif;
		endif;
		
		if _theCalcType.requiresADate() 
		and not stTS.isValid() then
			return 0;	
		endif;

		if _theCalcType.requiresDateRange 
		and (not stTS.isValid() or not endTS.isValid()) then
			return 0;
		endif;
		
		if theUnits = INV_CALC_TYPE_BUSINESS_HRS_QTY then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		elseif theUnits = INV_CALC_TYPE_BUSHRSVESELVALUE then // PAR 30681
			if theHMSData = null then
				value := 1;
			endif;
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, theResUsed);
			if value = 0 then
				value := 1;
			endif;
			
		elseif theUnits = INV_CALC_TYPE_RESOURCE_QTY then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		elseif (theUnits = INV_CALC_TYPE_QUOTED_RATE or theUnits = INV_CALC_TYPE_VESSEL_TON_QTY1) then // PAR 10672
			value := 1;
		elseif (theUnits = INV_CALC_TYPE_TIMEBLCK_HRS 
			or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_UNT
			or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_ONE) then

			numHourBlocks := theResUsed.unitsUsed; // PAR 13208. Use this as it has already been worked out
			if numHourBlocks = 0 then
				numHourBlocks := 1;
				if _theCalcType.requiresDateRange then		// 35339 date range processing
					diffMin := (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer;
					numHourBlocks := _theCalcType.getNumHourBlocks(diffMin, true, null);
				endif;
			endif;
			
			if theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_UNT  or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_ONE then
				value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, theResUsed);
				value := value * numHourBlocks;
			else
				value := numHourBlocks;
			endif;
		elseif theUnits = INV_CALC_TYPE_TIME_PERIOD_HRS then
			numHours := stTS.differenceInHours(endTS);
			value := numHours;
		// ### TFS CR 65326 TASK 65327 06AUG2024 NAVAB1
		elseif theUnits = INV_CALC_TYPE_TIME_PERIOD_HRMN then
			hoursDec := stTS.differenceInHoursReal(endTS);
			
			// ### TFS BUG 65780 23AUG2024 NAVAB1
			if hoursDec &lt; _theCalcType.hoursMin then
				hoursDec := _theCalcType.hoursMin;
			elseif _theCalcType.hoursMax &gt; 0 	// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
			and hoursDec &gt; _theCalcType.hoursMax then
				hoursDec := _theCalcType.hoursMax;
			endif;
			value := hoursDec;
		elseif theUnits = INV_CALC_TYPE_VESSEL_TON then
			// 30680 CCMS QNS 2178 use theCalcTypeUnit instead of hard-coded GRT
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, theResUsed);
			if theResUsed &lt;&gt; null and theResUsed.unitsUsed &gt; 0 then
				value := value * theResUsed.unitsUsed;
			endif;
		// 34489 Tidal Class
		elseif theUnits = INV_CALC_TYPE_TIDAL_CLASS then
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, theResUsed);

		elseif theUnits = INV_CALC_TYPE_VESSEL_TON_RANGE then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
			
		elseif theUnits = INV_CALC_TYPE_RESOURCE_DAYS then	//19 Feb 2019	NDL	TFS 43374
			if endTS.Date.isValid and stTS.Date.isValid then
				value := (endTS - stTS).inDaysAndPartOf();
			endif;
		endif;
		
	endif;

	value := self.adjustQuantityForRange(value);
	
	// 34489 CCMS 1327 Tidal Class adds quantity hook code for HMS calculation types
	if _theCalcType &lt;&gt; null and _theCalcType.myHookCodeQuantity &lt;&gt; null then
		// cnwmc5 - 8 Oct 2015 - PAR 36920
		create cmifHook transient;
		cmifHook.myTransaction := hmsTran;
		cmifHook.origQty := value;
		cmifHook.myResourceTypeUsage := self.myResourceTypeUsage;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_HMSInvoiceQuantity, _theCalcType, _theCalcType, cmifHook).Real;

		value := valueOut;
	endif;

	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_theCalcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityVoyageBlockUnits" id="afaf9e68-0fa1-4e99-acd1-df986d51a5cc">
        <source>quantityVoyageBlockUnits(_blockUnit : Integer; _hmsData : HMS_VoyageData; _voyage : CM_Voyage; _resourceUsed : HMS_ResourceUsed) : Real protected;
// from 34489 CCMS 1327 refactor out the block unit code to one place
vars
	value	: Real;
	towingHMSData : HMS_VoyageData;
	towingVoyage : CM_Voyage;
begin
	
	if _blockUnit = INV_CALC_TYPE_UNITY then
		value := 1;
	elseif _blockUnit = INV_CALC_TYPE_WO_UNITS then // TFS 39236
		value := 1;
	elseif _blockUnit = INV_CALC_TYPE_RESOURCE_QTY then
		if _resourceUsed&lt;&gt; null then // TFS 39237
			value := _resourceUsed.unitsUsed;
		endif;
		if value = 0 then
			value := 1;
		endif;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_GRT then
		value := _hmsData.dim_GrossRegTonnes; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_NRT then
		value := _hmsData.dim_NetRegTonnes;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
		value := _hmsData.dim_LengthOverall; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_BEAM then
		value := _hmsData.dim_Beam; 
	elseif _blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
		value := _hmsData.dim_DeadWeight;
	elseif _blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
		value := _voyage.draftMid;
	else // DEFAULT
		value := _hmsData.dim_GrossRegTonnes; 
	endif;

	// TFS 39198 include the towing voyage's value
	/* TFS 42161 SAURABH SAID TO REMOVE ALL OF THIS
	towingVoyage := _hmsData.myTowingVoyage;
	if towingVoyage &lt;&gt; null then
		towingHMSData :=towingVoyage.myHMSVoyageData;
		if towingHMSData&lt;&gt; null then
			if  _blockUnit = INV_CALC_TYPE_UNIT_GRT then
				value := value + towingHMSData.dim_GrossRegTonnes; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_NRT then
				value := value + towingHMSData.dim_NetRegTonnes;
			elseif _blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
				value := value + towingHMSData.dim_LengthOverall; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_BEAM then
				value := value + towingHMSData.dim_Beam; 
			elseif _blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
				value := value + towingHMSData.dim_DeadWeight;
			elseif _blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
				value := value + towingVoyage.draftMid;
			else // DEFAULT
				value := value + towingHMSData.dim_GrossRegTonnes;
			endif;
		endif;
	endif;
	*/
	
	
	return value;
end;
</source>
        <access>protected</access>
        <Parameter name="_blockUnit" type="Integer"/>
        <Parameter name="_hmsData" type="HMS_VoyageData"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resourceUsed" type="HMS_ResourceUsed"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityWorkOrder" id="a96837e6-0bc8-4d80-8ba7-95fdb68f16b2">
        <updating/>
        <source>quantityWorkOrder() : Real updating;
 // ### TFS BUG 61892 29DEC2023 NAVAB1 -quantityWorkOrderCalcType
vars
	theCalcType : CM_CalculationType;
begin
	theCalcType := self.invoiceLineDesc.getCalcType();
	return self.quantityWorkOrderCalcType(theCalcType);

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="quantityWorkOrderCalcType" id="aa833cc2-1d4f-41d2-8b06-81c8052e9efb">
        <updating/>
        <source>quantityWorkOrderCalcType(_theCalcType : CM_CalculationType) : Real updating;
/*
Purpose:	// TFS 39237	ANY CHANGES HERE NEED TO BE DONE IN CM_QuantityMap::getQuantityForTransactionWO	

		INV_CALC_TYPE_WO_UNITS
		INV_CALC_TYPE_WO_VALUEOF1
		INV_CALC_TYPE_WO_ETMAL_DAYS
		INV_CALC_TYPE_WO_ETMAL_HOURS
		INV_CALC_TYPE_WO_ETMAL_MINUTES
		INV_CALC_TYPE_WO_PERMIT
		INV_CALC_TYPE_WO_CARGOQUANTITY
		INV_CALC_TYPE_WO_CARGOREVTONS
		INV_CALC_TYPE_WO_CARGOVOLUME
		INV_CALC_TYPE_WO_CARGOWEIGHT

		Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
25-05-2023 navtnr20	CR 54345	Task 54266: 54253.130 - Calculation Types
TFS BUG 61892 29DEC2023 NAVAB1 changed to pass in the calc type

*/


vars
	theVoyage : CM_Voyage;
	theHMSData : HMS_VoyageData;
	theUnits : Integer;
	stTS, endTS : TimeStamp;
	value, buValue, diffTS : Real;
	tran : CM_WOTransaction;
	lengthOfStay : Decimal[12,2];
	theWorkOrder : CM_WorkOrder;
	blockUnit : Integer;
	tiSet : CM_TISet;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	valueOut : Real;	
	diffDays		: Integer;
begin
	tran := self.myTransactionWO;
	
	if tran &lt;&gt; null then

		theWorkOrder := tran.getMyWorkOrder();
		if theWorkOrder = null then
			return 0;
		endif;
		
		//Start 25-05-2023 		54266
		if self.myResourceTypeUsage &lt;&gt; null then 
			stTS := self.myResourceTypeUsage.fromDateTime;
			endTS := self.myResourceTypeUsage.toDateTime;
		else
			stTS := tran.getStartTS();
			endTS := tran.getEndTS();
		endif;
		
		diffTS := stTS.differenceInHoursReal(endTS);
		//End	25-05-2023		54266
		lengthOfStay := theWorkOrder.getInvLengthOfStay();
		
		theUnits := _theCalcType.calculationType;
		
		if theUnits = INV_CALC_TYPE_WO_UNITS then
			value := tran.getInvUnitsUsed(); 
			if value = 0 then
				value := 1;
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_CARGOREVTONS  // TFS 39236 
		or theUnits = INV_CALC_TYPE_WO_CARGOWEIGHT  // TFS 39236 
		or theUnits = INV_CALC_TYPE_WO_CARGOQUANTITY  // TFS 39236 
		or theUnits = INV_CALC_TYPE_WO_CARGOVOLUME then // TFS 39236 
			value := theWorkOrder.getValueForCargoCalcType(theUnits); // TFS 39236 
			
		elseif theUnits = INV_CALC_TYPE_WO_PERMIT then
			// this calc type was designed for the CM_WOCargoRequest transaction
			// the calc type allows 5 rates to be maintained and the quantity will be a cargo quantity via the block unit on the calc type
			
			if _theCalcType &lt;&gt; null then
				blockUnit := _theCalcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			value := theWorkOrder.getValueForCargoCalcType(blockUnit); // TFS 39236 
			
		elseif theUnits = INV_CALC_TYPE_WO_VALUEOF1 then
			value := 1;
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_DAYS then
			value := lengthOfStay;
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_HOURS then
			if lengthOfStay = 0 then
				return 0;
			endif;
			value := (lengthOfStay * 24);
			
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_MINUTES then
			if lengthOfStay = 0 then
				return 0;
			endif;
			
			value := ((lengthOfStay * 24) * 60);
		// Start 24-05-2023 navtnr20 54266
		elseif theUnits = INV_CALC_TYPE_WO_RES_UNIT then
			value := tran.getInvUnitsUsed();
			if value = 0 then
				if self.myResourceTypeUsage &lt;&gt; null then 
					value := self.myResourceTypeUsage.quantity; 
				else
					value := 1;
				endif;
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_TIME_DAYS then
			value :=  (diffTS / 24) ;
		elseif theUnits = INV_CALC_TYPE_WO_DAYS_FULL then
			diffDays := stTS.differenceInHoursFullDay(endTS);
			value :=  diffDays ;
		elseif theUnits = INV_CALC_TYPE_WO_TIME_HOURS then 
			value := diffTS ;
		elseif theUnits = INV_CALC_TYPE_WO_TIME_MINUT then
			value := (diffTS * 60) ;
		elseif theUnits = INV_CALC_TYPE_WO_RES_WEIGHT then
			value := tran.myWorkOrderDetail.getTotalWeight();
		elseif theUnits = INV_CALC_TYPE_WO_RES_VOLUME then
			tran.myWorkOrderDetail.getTotalVolume();
		elseif theUnits = INV_CALC_TYPE_WO_RES_QUANTITY then
			tran.myWorkOrderDetail.getTotalQuantity();
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYWGT then
			if self.myResourceTypeUsage &lt;&gt; null then 
				value := (self.myResourceTypeUsage.quantity) * (tran.myWorkOrderDetail.getTotalWeight());
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYQTY then
			if self.myResourceTypeUsage &lt;&gt; null then 
				value := (self.myResourceTypeUsage.quantity) * (tran.myWorkOrderDetail.getTotalQuantity);
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYVOL then
			if self.myResourceTypeUsage &lt;&gt; null then 
				value := (self.myResourceTypeUsage.quantity) * (tran.myWorkOrderDetail.getTotalVolume);
			endif;
		// End 24-05-2023 navtnr20 54266
		endif;
		
		if theUnits &lt;&gt; INV_CALC_TYPE_WO_PERMIT then
			theVoyage := tran.getMyVoyageObject();
			if theVoyage &lt;&gt; null then
				// the block unit for all WO calc types are vessel dimensions like GRT,  except INV_CALC_TYPE_WO_PERMIT which are cargo based.
				if _theCalcType &lt;&gt; null then
					blockUnit := _theCalcType.theCalcTypeUnit;
				else
					blockUnit := INV_CALC_TYPE_UNITY; // value of 1
				endif;
				
				theHMSData := theVoyage.myHMSVoyageData;
				if theHMSData &lt;&gt; null then
					buValue := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
					value := value * buValue;
				endif;
			endif;
		endif;
		
		if _theCalcType &lt;&gt; null and _theCalcType.myHookCodeQuantity &lt;&gt; null then
			create cmifHook transient;
			cmifHook.myTransaction := tran;
			cmifHook.origQty := value;
			
			valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, _theCalcType, _theCalcType, cmifHook).Real;
	
			value := valueOut;
		endif;
		
	endif;
	
	
	return value;
	
epilog

	delete tiSet;	//28 Jun 2018	NDL	TFS 39246

end;</source>
        <Parameter name="_theCalcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="recalculate" id="c0e2aaaa-d923-4919-8922-d1b85e87df3b">
        <updating/>
        <source>recalculate() updating;
// CCMS 1264 recalculate the rate and quantity on demand and not on each access
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 24/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Miniumum Charge changes
// 16/05/2017	cnwdap1		TFS 3042 Don't recalculate quantity if debtor type is Empty Pool Party
// 21/07/2017	cnwdap1		TFS 5449 LNX Invoice Line Type not available for entry
// 22/05/2024 	navma1		Bug 64224: MTN - DeadLocks Caused by Future Actors
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	minMaxUsed,
	minMaxDisplayed,
	minMaxTotalReset	: Boolean;
	charge				: CM_Charge;
	debtorType 			: CM_DebtorType;				
	debtorTypeCode 		: String;				
	theCalcType 		: CM_CalculationType;
	canLogExtra			: Boolean;
begin
	if self.manual then
		return;
	endif;

	canLogExtra :=	app.canLogExtraDetail;				//22.05.2024 navma1 #64224
	
	if self.isVTMISInvoiceLine 
	   and not self.invoice.isPostedOrReversal			//04 Sep 2017	NDL	TFS 6759	
	   and self.overriddenChargeCount = 0 then
		minMaxTotalReset			:= true;
		self.hasMinMaxTotal 		:= false;
		self.displayMinMaxApplied 	:= false;
		self.quantity 				:= self.getActualQuantityNoMinMax();
		self.quantityNoMinMax 		:= self.quantity;
	endif;

	// ### TFS BUG 61096 21NOV2023 NAVAB1 - if volume based from contract then just get the rate
	if self.isVolumeBased() then
		if canLogExtra then									//22.05.2024 navma1 #64224
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.updateFromVBContractResync", LogINFO.String);
		endif;
		self.updateFromVBContractResync();
		return;
	else
		foreach charge in self.charges do
			if canLogExtra then								//22.05.2024 navma1 #64224
				app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
			endif;
			charge.evaluateRate();
		endforeach;
	endif;
	
	if minMaxTotalReset and   not self.hasMinMaxTotal then
		self.getMinMaxDisplayed(minMaxUsed, minMaxDisplayed);
		self.hasMinMaxTotal 	  := minMaxUsed;
		self.displayMinMaxApplied := minMaxDisplayed;
		theCalcType 			  := self.invoiceLineDesc.getCalcType(); 		// ### TFS BUG 61892 29DEC2023 NAVAB1
		self.quantity 			  := self.quantityVOYAGECalcType(theCalcType);	//16 May 2019	NDL	TFS 44787
	endif;
	
	// PAR #36909 - don't recalculate if I'm a minimum charge line
	// TFS 3042 or if I'm an Empty Pool Party line													// TFS 3042
	debtorType := self.invoiceLineDesc.myDebtorType;												// TFS 3042
	if debtorType &lt;&gt; null then																		// TFS 3042
		debtorTypeCode := debtorType.code;															// TFS 3042
	endif;																							// TFS 3042

	if self.myInvoiceLineOriginal = null and debtorTypeCode &lt;&gt; debtorType.DT_EMPTY_POOL_PARTY then	// TFS 3042
		self.calculateQuantity();
	endif;													// PAR #36909
	
	self.recalculateMinimumCharge();						// PAR #36909

end;</source>
    </JadeMethod>
    <JadeMethod name="recalculateMinimumCharge" id="5cbcf984-7fcd-4e96-ae03-129fcb55c85b">
        <source>recalculateMinimumCharge();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 17/03/2016	cnwdap1		PAR #37624 Correct recalculation of minimum charge to bring it in line with normal creation
//							Correct handling of voided invoice line with a minimum charge
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	invType : CM_InvoiceLineDesc;
	newTotal : Real;
	invoiceLine : CM_InvoiceLine;
	now : TimeStamp;
	seqNum : Integer;
	charge : CM_Charge;
	voidStatus : CMIF_InvoiceStatus;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
	ti : CM_TrackedItem; //29/09/2025	navkc1 JIRA 35917
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	// check whether we still need a minimum charge invoie line, or if the minimum charge line total needs changing
	invType := self.invoiceLineDesc;
	if invType.minimumChargeGroupBy &lt;&gt; CM_InvoiceLineDesc.GROUP_BY_INVOICELINE or invType.minimumChargeAmount = null then
		if self.myInvoiceLineAdditional &lt;&gt; null then
			// invoice line type is not minimum charge, but we have a minimum charge line - void it
			self.myInvoiceLineAdditional.status := self.invoice.INVOICE_VOID;
		endif;
		return;
	endif;
	
	newTotal := invType.minimumChargeAmount - self.lineTotal;
	if self.myInvoiceLineAdditional &lt;&gt; null and newTotal = self.myInvoiceLineAdditional.lineTotal then
		// no change - nothing to do
		return;
	endif;
	///epr par 36958 30/9/15
	create voidStatus transient;
	voidStatus.newStatus:=CM_InvoiceLine.STATUS_VOIDED;
	// if newTotal is negative or zero, void the minimum charge line (new charge is no longer less than the minimum charge)
	//if newTotal &lt;= 0 then													// PAR #37624
	if newTotal &lt;= 0 or self.status = self.STATUS_VOIDED then				// PAR #37624
		if self.myInvoiceLineAdditional &lt;&gt; null 
		and self.myInvoiceLineAdditional.status &lt;&gt; self.STATUS_VOIDED then // TFS 44275
			//self.myInvoiceLineAdditional.setForUpdateStatus(voidStatus);	// PAR #37624
			self.myInvoiceLineAdditional.status := self.STATUS_VOIDED;		// PAR #37624
		endif;
	else
		// newTotal is not negative, and not what was originalyl specified - update my associated minimum charge line
		// (or create if we don't already have one)
		if self.myInvoiceLineAdditional &lt;&gt; null then
			self.myInvoiceLineAdditional.resetMinimumCharge(newTotal, invType.minimumChargeAmount);
		else
			// if this re-evaluation resultedin a minimum charge needing to be created, do it here
			/*//29/09/2025	navkc1 JIRA 35917 Change to use the standard CMIF_InvoiceLineManual
			create invoiceLine persistent;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			//invoiceLine.setForCreate(seqNum, false, null, invType.minimumChargeInvoiceLineType, self.invoice, self.debtor, self.bank, newTotal, now);	// PAR #37624
			//invoiceLine.setForCreate(seqNum, false, null, invType.minimumChargeInvoiceLineType, self.invoice, self.debtor, self.bank, 1, now);			// PAR #37624 
			invoiceLine.setForCreate(seqNum, false, null, invType.minimumChargeInvoiceLineType, self.invoice, self.debtor, self.bank, 1, now);			// PAR #37624 
			invoiceLine.setMyTransaction(self.myTransactionTI);
			if self.myTransactionTI &lt;&gt; null then	//14 Jun 2017	NDL	TFS 4816
				invoiceLine.setTrackedItem(self.myTransactionTI.myTrackedItem);
			endif;
			invoiceLine.setMyTransactionHMS(self.myTransactionHMS);	//14 Jun 2017	NDL	TFS 4816
			invoiceLine.setMyTransactionEvent(self.myTransactionEvent);	//14 Jun 2017	NDL	TFS 4816
			invoiceLine.setMyInvoiceLineOriginal(self);
			invoiceLine.createCharges();
			foreach charge in invoiceLine.charges do
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
				endif;
				charge.evaluateRate();
				//charge.overrideRate(invType.minimumChargeAmount);			// PAR #37624
				charge.total := newTotal;
// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
				charge.setOverriden(); // TFS 42084
				charge.setRateForMinMax(newTotal);							// PAR #37624
			endforeach;
			*/
			
			//29/09/2025	navkc1 JIRA 35917
			create theController transient;
			theController.myInvoice := self.invoice;
			theController.quantity := 1;
			theController.isManual := false;
			theController.chargeTime := now;
			theController.isOverridden := true;
			theController.totalAmount := newTotal;
			theController.rate := newTotal;
			if self.myTransactionTI &lt;&gt; null then
				theController.myTransaction := self.myTransactionTI;
				ti := self.myTransactionTI.myTrackedItem;
				theController.myTrackedItem := ti;
			elseif self.myTransactionEvent &lt;&gt; null then
				theController.myTransaction := self.myTransactionEvent;
			elseif self.myTransactionHMS &lt;&gt; null then
				theController.myTransaction := self.myTransactionHMS;
			endif;
			
			invoiceLine := invType.minimumChargeInvoiceLineType.createManualInvoiceLine(theController, ti, false);
			invoiceLine.setMyInvoiceLineOriginal(self);
			
		endif;
	endif;
	
epilog
	delete voidStatus;
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
    </JadeMethod>
    <JadeMethod name="reevaluate" id="ae11f445-95c0-44ed-bd37-a1a1fc588e1b">
        <updating/>
        <source>reevaluate() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		20 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1005 - Move invoice lines where their debtor or voyage has changed.
//				Apr 2012 CCMS 1264 non-virtual fields, extended to recalculate rate and quantity
//					also add logging of activity
// Changed On	By			Reason
//08/06/2020 	cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
//23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
// ---------------------------------------------------------------------------

vars
	debtorChanged,
	result			: Boolean;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if self.manual and
	   self.myTransactionTI = null then		// TFS 1990 do this for split invoice lines to get new debor from cash receipt
		return false;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Invoice " &amp; self.invoice.sequenceNum.String &amp; " line " &amp; self.sequenceNum.String, LogTRACE.String);
	endif;
	//03/06/2020 cnwma1 TFS #49400
	if self.myTransactionTI &lt;&gt; null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("TITransaction Reevaluate Debtor", LogTRACE.String); // ### TFS 51219 18JUN2021 NAVAB1
		endif;
		result := self.reevaluateDebtor(debtorChanged);
	elseif self.myTransactionEvent &lt;&gt; null then
		if self.myTransactionEvent.isLocationActivityEvent() then // ### TFS 51219 18JUN2021 NAVAB1
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Inventory Reevaluate Debtor", LogTRACE.String); // ### TFS 51219 18JUN2021 NAVAB1
			endif;
			result := reevaluateDebtorInventory(debtorChanged); // ### TFS 51219 18JUN2021 NAVAB1
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Event Reevaluate Debtor", LogTRACE.String); // ### TFS 51219 18JUN2021 NAVAB1
			endif;
			result := self.reevaluateDebtorEvent(debtorChanged);
		endif;
	elseif self.myTransactionWO &lt;&gt; null then //20/11/2024	navkc1 JIRA Story MTN-33012
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("WO Reevaluate Debtor", LogTRACE.String);
		endif;
		result := self.reevaluateDebtorWO(debtorChanged);
	endif;

	// CCMS 1264 recalculate the rate and quantity on demand and not on each access
	self.recalculate();

	// 35356 handle change of debtor for cash after redoing the rate for the new debtor
	if app.isCashOnlyEnabled and
	   debtorChanged then
		self.reevaluateCashPayments();
	endif;
	
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reevaluateCashPayments" id="56bd5e06-8fac-41e6-bdb9-eb77ff2f21ff">
        <updating/>
        <source>reevaluateCashPayments() updating, protected;
/*

Purpose:			
	35356 if debtor has changed [tested before calling this], new debtor is cash-only, tracked item is off-site, this invoice line has no existing payments
	but the tracked item has a non-invoice line payment then use this payment (which is an unallocated overpayment) to pay off this line.
Parameters:			

Return Value:		

Date		Who		Reason
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed

*/

vars
	newDebtor			: CM_Debtor;
	debtorTerminal		: CM_DebtorTerminal;
	terminal			: CM_Terminal;
	unallocatedPayment	: CM_CashPayment;
	cashPayment			: CM_CashPayment;
	pxyCashPayment		: CM_CashPayment;
	now					: TimeStamp;
	invCashPayment		: Decimal[23,6];
begin
	newDebtor := self.debtor;
	terminal := self.getTerminal();
	if not newDebtor.isCashOnlyDebtor(terminal) then
		return;
	endif;
	if self.trackedItem = null then
		return;
	endif;
	if not self.trackedItem.isOffSite() then
		return;
	endif;
	if not self.allCashPayments.isEmpty() then
		return;
	endif;
	foreach cashPayment in self.trackedItem.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		if cashPayment.myInvoiceLine = null then
			unallocatedPayment := cashPayment;
			break;
		endif;
	endforeach;
	if unallocatedPayment = null or 
	   unallocatedPayment.cashValue = 0 then
		return;
	endif;
	
	debtorTerminal := newDebtor.allDebtorTerminals.getAtKey( terminal );
	now := app.serverTimestampAtTrxStart;

	create pxyCashPayment transient;
	invCashPayment := self.lineTotal;
	if invCashPayment &gt; unallocatedPayment.cashValue then
		invCashPayment := unallocatedPayment.cashValue;
	endif;
			
	pxyCashPayment.setProxy(invCashPayment,				//_cashValue : Decimal;
							0,							//_taxAmount : Decimal;
							now,						//_dateTime : TimeStamp;
							null,						//_proformaDesc : String;
							false,						//_manual : Boolean;
							0,							//_status : Integer;
							false,						//_voided : Boolean;	
							debtorTerminal,				//_myDebtorTerminal : CM_DebtorTerminal;
							self.trackedItem,			//_myTrackedItem : CM_TrackedItem;
							self.invoice,				//_myInvoice : CM_Invoice;
							null,						//_vvr : CM_VehicleVisitRecord;
							unallocatedPayment.myUser	//_myUser : CM_User;
							);
	pxyCashPayment.setInvoiceLine(self);
	pxyCashPayment.setPropertyValue("myCarrier", unallocatedPayment.myCarrier);
	pxyCashPayment.setPropertyValue("myDriver", unallocatedPayment.myDriver);
	pxyCashPayment.setCashReceipt(unallocatedPayment.myCashReceipt);
	app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
	
	// if paid in full delete the unallocated payment
	if unallocatedPayment.cashValue = invCashPayment then
		delete unallocatedPayment;
	//	otherwise reduce it's value
	else
		unallocatedPayment.setCashValue(unallocatedPayment.cashValue - invCashPayment);
	endif;
	
epilog
	delete pxyCashPayment;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reevaluateDebtor" id="1f103ec5-c1ee-4efe-a1a6-771d0a884fae">
        <updating/>
        <source>reevaluateDebtor(_hasChanged : Boolean output) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		Apr 2012 cnwjre1	CCMS 1264, check for changed debtor/voyage from reevaluate
//
// Purpose:		CCMS 1005 - Move invoice lines where their debtor or voyage has changed.
//				Apr 2012 CCMS 1264 non-virtual fields, extended to recalculate rate and quantity,
//					done in the calling method
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/11/2015	cnwdap1		PAR #36909 Minimum Charges 
// 13/06/2017	cnwdap1		TFS 3042 SNO Empty Pool Party Invoicing
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	msg		: String;
	inv, newInvoice : CM_Invoice;
	invType : CM_InvoiceDesc;
	invLineType : CM_InvoiceLineDesc;
	theTI : CM_TrackedItem;
	theDebtor : CM_Debtor;
	theBank : CM_Bank;
	theTran : CM_TITransaction;
	diffVoy : Boolean;
	storageConfig	: CM_StorageConfig;
	debtorType : CM_DebtorType;						// TFS 3042
	cooWasUsed : Boolean;
begin
	if self.myTransactionTI = null then // CARGO INVOICING ONLY
		return false;
	endif;
	if self.isPaidFor then
		return false;
	endif;
	// PAR #36909 if I'm the minimum charge line for an invoice line, don't re-evaluate	// PAR #36909
	if self.myInvoiceLineOriginal &lt;&gt; null then											// PAR #36909
		return false;																	// PAR #36909	
	endif;																				// PAR #36909
	// TFS 3042 if I'm an invoice line associated with an empty pool party invoice 		// TFS 3042
	// type, don't re-evaluate. We need to keep the debtors from the pool parties		// TFS 3042
	debtorType := self.invoiceLineDesc.myDebtorType;									// TFS 3042
	if debtorType &lt;&gt; null and debtorType.code = debtorType.DT_EMPTY_POOL_PARTY then		// TFS 3042
		return false;																	// TFS 3042
	endif;																				// TFS 3042

	theTran := self.myTransactionTI;

	theTI := self.trackedItem;
	if theTI = null then
		theTI := theTran.myTrackedItem;
		if theTI = null then
			return false;
		endif;
	endif;

	
	theBank := self.bank;
	inv := self.invoice;
	invType := inv.invoiceType;
	invLineType := self.invoiceLineDesc;
	
	if theTran.isKindOf(CM_WorkOrderExtraTI) then // TFS 42221 always get the debtor from the cago request.
		theDebtor := theTran.getDebtorForInvoiceLine(invLineType); // TFS 42221
	else
		// ### TFS CR 58263 TASK 58264 08FEB2024 NAVAB1
		theDebtor := theTran.getDebtorForInvLineUsedCOO(invLineType,cooWasUsed);
		if not cooWasUsed then
			// We are reevaluating the invoice line based on the data on the CARGO so must use this TI method
			theDebtor := invLineType.getDebtorFromTI(theTI, null);
		endif;
	endif;

	// if this if a voyage invoice then check if the TIs voyage has changed
	if (inv.invoiceType.invoiceKey = CM_InvoiceDesc.Key_Voyage  
				or inv.invoiceType.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup) // ### TFS 51219 25MAY2021 NAVAB1
	and theTI.myVoyage &lt;&gt; null then
		if inv.voyageCode &lt;&gt; theTI.myVoyage.code then
			diffVoy := true;
		endif;
	endif;
	
	if theDebtor &lt;&gt; null then
		// 35356 handle change of debtor for cash
		if theDebtor &lt;&gt; self.debtor then
			_hasChanged := true;
		endif;
		if theDebtor &lt;&gt; self.debtor or diffVoy then

			newInvoice := theBank.getAutoInvoice(invType, invLineType, theTran, theDebtor, null); 
	
			if newInvoice &lt;&gt; inv then
				if app.getLogger &lt;&gt; null then
					if theDebtor &lt;&gt; self.debtor then
						msg := "Debtor change from '" &amp; self.debtor.name &amp; "' to '" &amp; theDebtor.name &amp; "'";
					endif;
					if diffVoy then
						msg := msg &amp; " Voyage change from '" &amp; inv.voyageCode &amp; "' to '" &amp; theTI.myVoyage.code &amp; "'";
					endif;
					msg := msg &amp; " New invoice " &amp; newInvoice.sequenceNum.String;
					app.invLog(msg, LogTRACE.String);
				endif;
				
				self.moveLineToInvoice(newInvoice);
				return true;
			else
				self.debtor := theDebtor;
			endif;
		endif;
	endif;
	
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_hasChanged" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reevaluateDebtorEvent" id="d2346f78-ab65-4273-bdc7-90bb89854562">
        <updating/>
        <source>reevaluateDebtorEvent(_hasChanged : Boolean output):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 	cnwma1 	ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars
	theDebtor   : CM_Debtor;
	eventTrans  : CM_EventTransaction;
	theBank 	: CM_Bank;
	invLineType : CM_InvoiceLineDesc;
	invType     : CM_InvoiceDesc;
	newInvoice,
	invoice     : CM_Invoice;
	msg         : String;
begin
	if self.myTransactionEvent = null then
		return false;
	endif;
	
	eventTrans 	:= self.myTransactionEvent;
	theDebtor   := eventTrans.getDebtor(); // TFS 51219 myDebtor;
	
	if theDebtor &lt;&gt; null then
		if theDebtor &lt;&gt; self.debtor then
			_hasChanged := true;
		endif;
	endif;
	
	theBank 	:= self.bank;
	invoice		:= self.invoice;
	invType     := invoice.invoiceType;
	invLineType := self.invoiceLineDesc;
	
	if theDebtor &lt;&gt; null // TFS 51219
	and theDebtor &lt;&gt; self.debtor  then

		newInvoice :=  theBank.getAutoInvoiceEvent(invType, invLineType, eventTrans, theDebtor );

		if newInvoice &lt;&gt; invoice then
			if app.getLogger &lt;&gt; null then
				if theDebtor &lt;&gt; self.debtor then
					msg := "Debtor change from '" &amp; self.debtor.name &amp; "' to '" &amp; theDebtor.name &amp; "'";
				endif;
				
				msg := msg &amp; " New invoice " &amp; newInvoice.sequenceNum.String;
				app.invLog(msg, LogTRACE.String);
			endif;
			
			self.moveLineToInvoice(newInvoice);
			return true;
		else
			self.debtor := theDebtor;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_hasChanged" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reevaluateDebtorInventory" id="f2619975-57f8-4c3e-930c-d3357ec218d2">
        <updating/>
        <source>reevaluateDebtorInventory(_hasChanged : Boolean output) : Boolean updating, protected;
/*
Purpose:			

Date		Who		Reason
18JUN2021	NAVAB1	TFS 51219
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	msg		: String;
	inv, newInvoice : CM_Invoice;
	invType : CM_InvoiceDesc;
	invLineType : CM_InvoiceLineDesc;
	theTI : CM_TrackedItem;
	theDebtor : CM_Debtor;
	theBank : CM_Bank;
	theTran : CMEVT_LocationActivity;
	diffVoy : Boolean;
	storageConfig	: CM_StorageConfig;
	debtorType : CM_DebtorType;
	tranvoyage : CM_Voyage;
begin
	if self.myTransactionEvent = null then // EVENT INVOICING ONLY
		return false;
	endif;
	if not self.myTransactionEvent.isLocationActivityEvent then // INVENTORY INVOICING ONLY
		return false;
	endif;
	if self.isPaidFor then
		return false;
	endif;

	if self.myInvoiceLineOriginal &lt;&gt; null then
		return false;
	endif;		

	theTran := self.myTransactionEvent.CMEVT_LocationActivity;

	theTI := self.trackedItem;
	if theTI = null then
		theTI := theTran.myTrackedItem;
		if theTI = null then
			return false;
		endif;
	endif;

	
	theBank := self.bank;
	inv := self.invoice;
	invType := inv.invoiceType;
	invLineType := self.invoiceLineDesc;
	tranvoyage := theTran.getMyVoyage();
	
	// We are reevaluating the invoice line based on the data on the transaction
	theDebtor := invLineType.getDebtorFromLocationEvent(theTran, null);

	// if this if a voyage invoice then check if the TIs voyage has changed
	if (inv.invoiceType.invoiceKey = CM_InvoiceDesc.Key_Voyage  
				or inv.invoiceType.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup)
	and tranvoyage &lt;&gt; null then
		if inv.voyageCode &lt;&gt; tranvoyage.code then
			diffVoy := true;
		endif;
	endif;
	
	if theDebtor &lt;&gt; null then
		if theDebtor &lt;&gt; self.debtor then
			_hasChanged := true;
		endif;
		if theDebtor &lt;&gt; self.debtor or diffVoy then

			newInvoice := theBank.getAutoInvoiceEvent(invType, invLineType, theTran, theDebtor); 
	
			if newInvoice &lt;&gt; inv then
				if app.getLogger &lt;&gt; null then
					if theDebtor &lt;&gt; self.debtor then
						msg := "Debtor change from '" &amp; self.debtor.name &amp; "' to '" &amp; theDebtor.name &amp; "'";
					endif;
					if diffVoy then
						msg := msg &amp; " Voyage change from '" &amp; inv.voyageCode &amp; "' to '" &amp; theTI.myVoyage.code &amp; "'";
					endif;
					msg := msg &amp; " New invoice " &amp; newInvoice.sequenceNum.String;
					app.invLog(msg, LogINFO.String);
				endif;
				
				self.moveLineToInvoice(newInvoice);
				return true;
			else
				self.debtor := theDebtor;
			endif;
		endif;
	endif;
	
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_hasChanged" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reevaluateDebtorWO" id="b17800f7-6ae1-43aa-92e4-63df2289618a">
        <updating/>
        <source>reevaluateDebtorWO(_hasChanged : Boolean output): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	currentInvoice,
	newInvoice		: CM_Invoice;
	invType			: CM_InvoiceDesc;
	invLineType		: CM_InvoiceLineDesc;
	newDebtor		: CM_Debtor;
	msg				: String;
begin
	if self.myTransactionWO = null then
		return false;
	endif;
	
	currentInvoice := self.invoice;
	invType := currentInvoice.invoiceType;
	invLineType := self.invoiceLineDesc;
	newDebtor := self.myTransactionWO.getMyDebtor();
	
	if newDebtor &lt;&gt; self.debtor then
		_hasChanged := true;
		newInvoice := currentInvoice.getBank().getAutoInvoiceWO(invType, invLineType, self.myTransactionWO, newDebtor); 
		if newInvoice &lt;&gt; currentInvoice then
			
			if app.getLogger() &lt;&gt; null then
				msg := "Debtor change from '" &amp; self.debtor.name &amp; "' to '" &amp; newDebtor.name &amp; "'";
			endif;
			
			app.invLog(msg, LogTRACE.String);			
			
			self.moveLineToInvoice(newInvoice);
			return true;
		else
			self.debtor := newDebtor;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_hasChanged" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetContractData" id="cb2b52da-5812-4624-b314-084754b29f7b">
        <updating/>
        <source>resetContractData() updating;
/*
Purpose:	

Date		Who		Reason
19 November 2024	navab1	JIRA 33347
*/

vars

begin
	self.usedContractCalcType := false;
	self.usedContractRate := false;
	self.contractId := null;
	self.myInvoiceContractDetail := null;
	self.myInvoiceContract := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetMinimumCharge" id="7535be74-219f-458b-8e12-9f85f486bbfc">
        <updating/>
        <source>resetMinimumCharge(_newTotal : Real; _newMinimumRate : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	charge : CM_Charge;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	foreach charge in self.charges do
		charge.overrideRate(_newMinimumRate);
		charge.total := _newTotal;
		charge.isTotalSetExplicitly := true;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Setting TOTAL Explicitly To " &amp; _newTotal.String, LogINFO.String);
		endif;
	endforeach;
	
	self.setTotalAndTaxForResync();  // ### JIRA 35213 01JUL2025 NAVAB1
	
epilog

end;</source>
        <Parameter name="_newTotal" type="Real"/>
        <Parameter name="_newMinimumRate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resetTotalOnCharge" id="d3b971ba-e8da-4d50-ae43-8ca1e3347b99">
        <updating/>
        <source>resetTotalOnCharge() updating;
/*
Purpose:			

Date		Who		Reason
22JUN2023	NAVAB1	 BUG 58785
*/

vars
	charge : CM_Charge;

begin
	if not self.manual then
		return;
	endif;
	
	foreach charge in self.charges do
		charge.resetTotal();
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setChargeTime" id="5aa889f4-4d01-4aad-b42f-1b3204652040">
        <updating/>
        <source>setChargeTime(value: TimeStamp) updating;

begin
	if self.invoice &lt;&gt; null then
		//if self.invoice.status = CM_Invoice.INVOICE_POSTED then
		if self.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
			if app.activeForm &lt;&gt; null and app.activeForm.class.name = "INV_CashConsolidation" then		//12 Aug 2019	NDL	TFS 44261
				// special case for TFS 44261
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_CHANGE_POSTED_NOTALLOWED, null, null);
				return;
			endif;
		endif;
	endif;

	self.chargeTime := value;

end;</source>
        <Parameter name="value" type="TimeStamp"/>
    </JadeMethod>
