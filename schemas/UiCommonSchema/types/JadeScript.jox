    <JadeMethod name="rjsCheckTableViewControls" id="7381d454-a157-4449-95a0-f35c3c4c1ecd">
        <source>rjsCheckTableViewControls();
// ---------------------------------------------------------------------------
// Created:     22 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	classCol	: ClassColl;
	tmpClass	: Class;
	tmpForm		: Form;
	numControls,
	idx			: Integer;
	tmpControl	: Control;	
begin

	app.writeStatement( '=========== checking ===============');

	create classCol transient;

	CM_TableViewForm.allSubclasses(classCol);
//	CM_TableViewForm.allSubclassesInSubschemas(classCol);
	
	foreach tmpClass in classCol do
		//write tmpClass.name;
		create tmpForm as tmpClass transient;
		numControls := tmpForm.controlCount;
		foreach idx in 1 to numControls do
			tmpControl := tmpForm.controls(idx);
//			if tmpControl.parent.name = 'frmFilter' then
//				write 'frmFilter child control = ' &amp; tmpClass.name &amp; '::' &amp; tmpControl.name;
//			endif;
			if tmpControl.isKindOf(Button) then
				app.writeStatement( 'button control = ' &amp; tmpClass.name &amp; '::' &amp; tmpControl.name);
			endif;
		endforeach;		
		delete tmpForm;
	endforeach;

	app.writeStatement( '=========== checking complete ===============');
	
epilog
	delete tmpForm;
	delete classCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="rol002" id="2ee44ae2-2b73-46ce-9df4-4bea530ad936">
        <source>rol002();

vars
	tempStr			: String;
	startTS			: TimeStamp;
	endTS			: TimeStamp;
	interval		: TimeStampInterval;
	
begin
	startTS		:= app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= CrLf &amp; 'Starting ' &amp; class.getName &amp; '::' &amp; method.getName &amp; Tab &amp; startTS.display;
	write tempStr;
	
	app.initialize;
	app.myCnCntrl.setExceptionHandlerType( CnCntrl.Exception_Handler_Jade_Debug );
	
epilog
	endTS		:= app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	interval	:= endTS - startTS;
	tempStr		:=	CrLf &amp; 'Approximate time taken' &amp; Tab &amp; interval.display &amp;
					CrLf &amp; 'Finished ' &amp; class.name &amp; '::' &amp; method.name &amp; Tab &amp; endTS.display;
	write tempStr;
	
end;
</source>
    </JadeMethod>
