    <JadeMethod name="getConstantTextXML" id="a24b7168-e1b1-4f0f-a065-d81e7f925d89">
        <source>getConstantTextXML(_constText, _tagName : String) : String;
// ---------------------------------------------------------------------------
// Created:     12 May 2004 by cnwrs2
//
// Purpose:     The constant text may contain other non-xml stuff
//				so use this to get only the xml stuff we want before
//				sending to the xml parser
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;

begin

	xmlStr := _constText.cnEcGetTagValueOfName(_tagName);
	if xmlStr = null then
		return null;
	endif;
	
	// now add the header row back in so we can parse as xml
	return self.formatAsXML(_tagName, xmlStr);

end;</source>
        <Parameter name="_constText" type="String"/>
        <Parameter name="_tagName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="showAddGlobalConstantMsg" id="44afa633-f465-42f1-b9ed-3fe5f8a0dfb4">
        <source>showAddGlobalConstantMsg(pType, pName : String);
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePrefix,	
	theCategory,
	msgStr		: String;
begin

	if pType = GroupType then
		thePrefix := GroupPrefix;
		theCategory := self.myEntTableDataRoot.groupCategory;
		
	elseif pType = RowType then
		thePrefix := RowPrefix;
		theCategory := self.myEntTableDataRoot.rowCategory;

	elseif pType = DefType then
		thePrefix := DefPrefix;
		theCategory := self.myEntTableDataRoot.defCategory;

	else
		self.writeLogMessage(method.qualifiedName &amp; '  Invalid type (' &amp; pType &amp; ')');
		return;
	endif;
	
	msgStr := 'If you have not already done so you will need to' &amp; CrLf &amp;
			  'add a global constant (' &amp; thePrefix &amp; pName &amp; ') in' &amp; CrLf &amp;
			  'the (' &amp; theCategory &amp; ') category.' &amp; CrLf &amp;
			  CrLf &amp;
			  'Failure to do this will result in your changes being' &amp; CrLf &amp;
			  'lost when the system is deployed!' &amp; CrLf &amp;
			  CrLf &amp;
			  'After saving the group, def or view and adding the global' &amp; CrLf &amp;
			  'constant you should press the "Save to Global Constants"' &amp; CrLf &amp;
			  'button.  This will store the data in the text of the global' &amp; CrLf &amp;
			  'constant.  If the constant name is &gt; 30 chars then you may' &amp; CrLf &amp;
			  'need to alter the "translateConstantName" method on your' &amp; CrLf &amp;
			  'EntTableDataRoot sub-class to shorten the name.';
	
	app.msgBox(msgStr, 'Note', MsgBox_OK_Only);
	
end;</source>
        <Parameter name="pType" type="String"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="testUpdateFromGlobalConstants" id="1e889b29-97c4-46f6-b57a-acee57c111d2">
        <source>testUpdateFromGlobalConstants() : Boolean;
/*

Purpose:			Test the update from the Global constants

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues

*/

vars
	dataRoot		: EntTableDataRoot;
	baseScm 		: Schema;
	category 		: ConstantCategory;
	const 			: Constant;
	constDict		: ConstantNDict;
	xmlDoc			: JadeXMLDocument;
	group			: EntTableGroup;
	toDeleteArray	: EntTableArray;
	entitiesAccessed	: ObjectSet;
	iter			: Iterator;
	rowHeader		: EntTableRowHeader;
	row				: EntTableRow;
	def				: EntTableDef;		
	xlatCategory 	: XLAT_Category;
	translatableText : XLAT_EntityTableText;
	
begin
	if self.myEntTableDataRoot = null then
		return false;
	endif;
	
	dataRoot := self.myEntTableDataRoot;

	baseScm := rootSchema.getSchema(dataRoot.schemaName);

	xmlDoc := self.myXMLDoc;

	create toDeleteArray transient;
	create entitiesAccessed transient;
				
	beginTransaction;

	// Update the Groups first
	category := baseScm.getCategory(dataRoot.groupCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateGroupFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;
	
	iter := dataRoot.allEntTableGroups.createIterator;
	while iter.next(group) do
		if not entitiesAccessed.includes(group) then
			self.writeLogMessage(' Deleting group --&gt;&gt; ' &amp; group.name);				
			toDeleteArray.add(group);
		endif;
	endwhile;
	
	// clear and re-use coll
	entitiesAccessed.clear();
	
	// Update the Rows
	category := baseScm.getCategory(dataRoot.rowCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateRowsFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	// PAR #22559 - add in delete of unused rows
	foreach rowHeader in dataRoot.allEntTableRowHeadersByName do 
		if not entitiesAccessed.includes(rowHeader) then
			self.writeLogMessage(' Deleting rowHeader --&gt;&gt; ' &amp; rowHeader.name);		
			toDeleteArray.add(rowHeader);
		else
			foreach row in rowHeader.allEntTableRows do
				if not entitiesAccessed.includes(row) then
					self.writeLogMessage(' Deleting row --&gt;&gt; ' &amp; row.String &amp; ' ' &amp; rowHeader.name &amp; ' ' &amp; row.number.String);
					toDeleteArray.add(row);
				endif;
			endforeach;
		endif;
	endforeach;
	
	// clear and re-use coll
	entitiesAccessed.clear();
	
	// Update the Defs
	category := baseScm.getCategory(dataRoot.defCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateDefFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	delete iter;
	iter := dataRoot.allEntTableDefs.createIterator;
	while iter.next(def) do
		if not entitiesAccessed.includes(def) then
			self.writeLogMessage(' Deleting def --&gt;&gt; ' &amp; def.name);
			toDeleteArray.add(def);
		endif;
	endwhile;
	entitiesAccessed.clear();
	
	// Delete entities no longer required;
	self.writeLogMessage('--&gt;&gt; ' &amp; toDeleteArray.size.String &amp; ' &lt;&lt;-- entities deleted');
	toDeleteArray.purge;
	
	// PAR #22559 - Now need to scan all the translations in the EntTableRows category, and delete any
	// that are "hanging"
	xlatCategory := app.myRoot.allXLAT_Categories[EntTableRows];
	
	delete iter;
	iter := xlatCategory.allTranslatableText.createIterator();
	
	while iter.next(translatableText) do
		if translatableText.myEntTableRow = null then
			self.writeLogMessage('Deleting translation --&gt;&gt; ' &amp; translatableText.String &amp; " " &amp; translatableText.number.String);
			
			delete translatableText;
		endif;
	endwhile;
	
	abortTransaction;
	return true;

	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete toDeleteArray;
	delete entitiesAccessed;
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxCreateDataRoot" id="bc267005-2a25-45e9-b020-9b94029449aa">
        <source>trxCreateDataRoot(pClassToCreate : Class; pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory : String;
				  pErrStr : String output; pDataRoot : EntTableDataRoot output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Feb 2002	Kevin Alcock	move code to utl... method.
// ---------------------------------------------------------------------------
vars
begin
	beginTransaction;
	
	if self.utlCreateDataRoot(pClassToCreate, pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory, pErrStr, pDataRoot ) then
		commitTransaction;
	else
		abortTransaction;
		return false;
	endif;

	return true;
	
end;</source>
        <Parameter name="pClassToCreate" type="Class"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pSchema" type="String"/>
        <Parameter name="pGroupCategory" type="String"/>
        <Parameter name="pDefCategory" type="String"/>
        <Parameter name="pRowCategory" type="String"/>
        <Parameter name="pErrStr" type="String" usage="output"/>
        <Parameter name="pDataRoot" type="EntTableDataRoot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxLoadFromGlobalConstants" id="71c96561-fa73-43e3-a15e-4b7ef90940c6">
        <updating/>
        <source>trxLoadFromGlobalConstants() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Log to file as well as writing message
*/

vars
	dataRoot	: EntTableDataRoot;
	baseScm 	: Schema;
	const 		: Constant;
	xmlDoc		: JadeXMLDocument;
	allETGroups	: EntTableGroupDictByName;
	allETRowHds : EntTableRowHeaderDictByName;
	
begin

	dataRoot := myEntTableDataRoot;
	if dataRoot = null then
		return false;
	endif;

	baseScm := rootSchema.getSchema(dataRoot.schemaName);

	xmlDoc := myXMLDoc;
		
	beginTransaction;

	// track existing refs as they are updated - any remaining can be deleted
// cnwdad1 14/09/2006 - These aren't used.
	dataRoot.allEntTableGroups.copy(allETGroups);
	dataRoot.allEntTableRowHeadersByName.copy(allETRowHds);

	// Load the Groups first
	
	foreach const in baseScm.getCategory(dataRoot.groupCategory).getConstants do
		if const.text = null then
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
			continue;
		endif;

		self.utlCreateGroupFromXML(const.name, const.text, xmlDoc);

	endforeach;

	// Load the Rows

	foreach const in baseScm.getCategory(dataRoot.rowCategory).getConstants do
		if const.text = null then
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
			continue;
		endif;
		
		utlCreateRowsFromXML(const.name, const.text, xmlDoc);
	endforeach;

	// Load the Defs
	
	foreach const in baseScm.getCategory(dataRoot.defCategory).getConstants do
		if const.text = null then
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
			continue;
		endif;
		utlCreateDefFromXML(const.name, const.text, xmlDoc);
	endforeach;

	commitTransaction;
	return true;
	
end;
/* Workspace required to run

vars
	a	: EntTableAgent;
	
begin

	create a transient;
	a.myEntTableDataRoot := CM_EntTableDataRoot.firstInstance;
	a.trxLoadFromGlobalConstants();
	
epilog
	delete a;
end;
*/</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxLoadFromGlobalConstantsOLD" id="ecf0c245-aeec-4fa0-bb36-9f4a167aadb9">
        <updating/>
        <source>trxLoadFromGlobalConstantsOLD() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
// Replaced:	Aug 2006 RBarr - need to update the collection, rather than purge and recreate
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues

*/

vars
	dataRoot	: EntTableDataRoot;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	entTableConst	: EntTableGlobalConstant;
	constDict	: ConstantNDict;
	xmlDoc		: JadeXMLDocument;

begin

/* Workspace required to run

vars
	a	: EntTableAgent;
	
begin

	create a transient;
	a.myEntTableDataRoot := CM_EntTableDataRoot.firstInstance;
	a.trxLoadFromGlobalConstants();
	
epilog
	delete a;
end;
*/
	self.allGlobalConstants.purge;

	if self.myEntTableDataRoot = null then
		return false;
	endif;
	
	dataRoot := self.myEntTableDataRoot;

	baseScm := rootSchema.getSchema(dataRoot.schemaName);

	xmlDoc := self.myXMLDoc;
		
	beginTransaction;
	
	dataRoot.clearAllData();		// Clear out existing data

	// Load the Groups first
	
	category := baseScm.getCategory(dataRoot.groupCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlCreateGroupFromXML(const.name, const.text, xmlDoc);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	// Load the Rows

	category := baseScm.getCategory(dataRoot.rowCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlCreateRowsFromXML(const.name, const.text, xmlDoc);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	// Load the Defs
	
	category := baseScm.getCategory(dataRoot.defCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlCreateDefFromXML(const.name, const.text, xmlDoc);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	commitTransaction;
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxSaveDataToGlobalConstants" id="3c4a40bb-76ca-4068-bdaa-61e5e6e5ee75">
        <updating/>
        <source>trxSaveDataToGlobalConstants( _hasWarnings : Boolean output; _user : String ) updating;

// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 25/10/2006 Add periodic commit to reduce locking 
// R Barr 25/10/2006 Update constant text only if changed (reduce notification flood)
// 01 Mar 2010	cnwkpd1		PAR #22559 - Ent Table Row upgrade issues
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 July 2022	navpw1	Added usercode so we can see who modified the ent table data
// ---------------------------------------------------------------------------
constants
	PeriodicCommitFrequency = 10;
vars
	etRoot		: EntTableDataRoot;
	etGroup		: EntTableGroup;
	etRow		: EntTableRowHeader;
	etDef		: EntTableDef;
	etRowGrp	: EntTableRow;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	entTableConst	: EntTableGlobalConstant;
	constDict	: ConstantNDict;
	constName	: String;
	
	// Strings to hold details for constants that we need to create
	rtnStr,
	termBlockStr,
	grpConstantStr,
	rowConstantStr,
	defConstantStr,
	viewConstantStr	: String;
	result			: Integer;	
	deleteHeaders	:CM_ObjectSet;
	obj				:Object;
	//tempDict	:ConstantNDict;
	xlatCategory : XLAT_Category;
	trxStateCounter	: Integer;
	newText	: String;
begin

/* Workspace required to run

vars
	a	: EntTableAgent;
	
begin

	create a transient;
	a.myEntTableDataRoot := CM_EntTableDataRoot.firstInstance;
	a.trxSetGlobalConstantsFromData();
	
epilog
	delete a;
end;
*/
	create deleteHeaders transient;
	self.allGlobalConstants.purge;

	if self.myEntTableDataRoot = null then
		self.writeLogMessage('Error - myEntTableDataRoot is null');
		_hasWarnings := true;
		return;
	endif;
	
	etRoot := self.myEntTableDataRoot;

	baseScm := rootSchema.getSchema(etRoot.schemaName);
	
	beginTransaction;
	
	sharedLock(self.myEntTableDataRoot);
	
	// Handle the Groups first
	
	category := baseScm.getCategory(etRoot.groupCategory);
	constDict := category.getConstants();
	//tempDict := constDict.cloneSelf(true);
	foreach etGroup in etRoot.allEntTableGroups do
		sharedLock(etGroup);
		if etGroup.constantName = null then
			etGroup.setConstantName();
		endif;
		constName := etGroup.constantName;
		const := constDict[constName];
		//if tempDict.includes(const) then
		//	tempDict.remove(const);
		//endif;
		if const &lt;&gt; null then
			newText := etGroup.outputAsXML;
			if newText &lt;&gt; const.text then	// R Barr 25/10/2006 Update only if changed
				const.setText(newText);
				const.cnEcSetModifiedBy(_user);
			endif;
		else
			self.addConstantDefToString(grpConstantStr, etGroup.constantName, etGroup.name, etGroup.outputAsXML(), _user);
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; Group constant not found (' &amp; constName &amp; ')');
		endif;
		
		// use periodic commit to reduce locking 
		trxStateCounter := trxStateCounter + 1;
		if trxStateCounter mod PeriodicCommitFrequency = 0 then
			commitTransaction; beginTransaction;
		endif;
	endforeach;
	
	// Handle the Rows

	category := baseScm.getCategory(etRoot.rowCategory);
	constDict := category.getConstants();

	foreach etRow in etRoot.allEntTableRowHeadersByName do
		sharedLock(etRow);
		if etRow.allEntTableRows.isEmpty then
			// This row is not in any groups so ca
			deleteHeaders.add(etRow);
			if etRow.constantName &lt;&gt; null then				
				const := constDict[etRow.constantName];
				if const &lt;&gt; null then
					_hasWarnings := true;
					self.writeLogMessage(method.qualifiedName &amp; '  WARNING &gt;&gt; Row constant not used - can check/delete (' &amp; etRow.constantName &amp; ')');
					if const.text.pos(CrLf &amp; 'DOES NOT APPEAR TO BE USED - CHECK AND DELETE',1) &lt; 1 then
						const.setText(CrLf &amp; 'DOES NOT APPEAR TO BE USED - CHECK AND DELETE ' &amp; process.getComputerName &amp; ' ' &amp; 'App Name: ' &amp; app.name &amp; ' ' &amp; app.actualTimeServer.String);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
						const.cnEcSetModifiedBy(_user);
					endif;
				endif;		
			endif;
			continue;
		endif;

		if etRow.constantName = null then
			etRow.setConstantName();
		endif;
		constName := etRow.constantName;
		const := constDict[constName];
		if const &lt;&gt; null then
			newText := etRow.outputAsXML;
			if newText &lt;&gt; const.text then	// R Barr 25/10/2006 Update only if changed
				const.setText(newText);
				const.cnEcSetModifiedBy(_user);
			endif;
		else
			self.addConstantDefToString(rowConstantStr, etRow.constantName, etRow.name, etRow.outputAsXML(), _user);
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; Row constant not found (' &amp; constName &amp; ')');
		endif;

				// use periodic commit to reduce locking 
		trxStateCounter := trxStateCounter + 1;
		if trxStateCounter mod PeriodicCommitFrequency = 0 then
			commitTransaction; beginTransaction;
		endif;
	endforeach;
	

	// Load the Defs
	
	category := baseScm.getCategory(etRoot.defCategory);
	constDict := category.getConstants();

	foreach etDef in etRoot.allEntTableDefs do
		sharedLock(etDef);
		if etDef.constantName = null then
			etDef.setConstantName();
		endif;
		constName := etDef.constantName;
		const := constDict[constName];
		if const &lt;&gt; null then
			newText := etDef.outputAsXML;
			if newText &lt;&gt; const.text then	// R Barr 25/10/2006 Update only if changed
				const.setText(newText);
				const.cnEcSetModifiedBy(_user);
			endif;
		else
			self.addConstantDefToString(defConstantStr, etDef.constantName, etDef.name, etDef.outputAsXML(), _user);
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; Def constant not found (' &amp; constName &amp; ')');
		endif;

		// use periodic commit to reduce locking 
		trxStateCounter := trxStateCounter + 1;
		if trxStateCounter mod PeriodicCommitFrequency = 0 then
			commitTransaction; beginTransaction;
		endif;
	endforeach;

	
	if deleteHeaders.size &gt;0 then
		foreach obj in deleteHeaders do
			delete obj;
		endforeach;
	endif;
	
	commitTransaction;
	
	if grpConstantStr &lt;&gt; null or
	   rowConstantStr &lt;&gt; null or
	   defConstantStr &lt;&gt; null or
	   viewConstantStr &lt;&gt; null then

		self.writeLogMessage(method.qualifiedName &amp; '  attempting to load missing global constants');	   	
	   	result := self.addConstantsServer(defConstantStr, grpConstantStr, rowConstantStr, viewConstantStr, rtnStr);

		if result &lt;&gt; 0 then
			self.writeLogMessage(method.qualifiedName &amp; ' ERROR in loading new global constants (' &amp; result.String &amp; ')');
			self.writeLogMessage(rtnStr);
			self.writeLogMessage('&lt;end of error text&gt;');
		else
			self.writeLogMessage(method.qualifiedName &amp; '  load of missing global constants appears to be successful');	   	
		endif;
	endif;
	
	// 28/8/2006 RBarr Localisation changes

	// now ensure that each EntTableRow has a linked TranslatableText object
	// this is in a separate transaction because the global constant must be created first
	category := baseScm.getCategory(etRoot.rowCategory);
	constDict := category.getConstants();

	xlatCategory := app.myRoot.allXLAT_Categories[EntTableRows];
	exclusiveLock(xlatCategory);
	
	beginTransaction;
	foreach etRow in etRoot.allEntTableRowHeadersByName do
		sharedLock(etRow);
		foreach etRowGrp in etRow.allEntTableRows do
			constName := etRow.constantName;
			const := constDict[constName];
			if const &lt;&gt; null then
				// create XLAT_EntityTableText, and set ref to new constant
				etRowGrp.setTranslatableText();
			else
				self.writeLogMessage('ERROR &gt;&gt; ETRow constant not found (' &amp; constName &amp; ') - Translatable Text object not created');
			endif;
			// use periodic commit to reduce locking 
			trxStateCounter := trxStateCounter + 1;
			if trxStateCounter mod PeriodicCommitFrequency = 0 then
				commitTransaction; beginTransaction;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	
	
	self.writeLogMessage(method.qualifiedName &amp; ' -updating terminology objects');
	app.myRoot.resetTerminologyTypes();
	//tempDict.inspectModal();
epilog
	delete deleteHeaders;
	if process.isInTransactionState then
		// Must have been an error further up so abort
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_hasWarnings" type="Boolean" usage="output"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateFromConstant" id="4110eb3d-3c89-4cf2-bd78-53b4c9f73588">
        <updating/>
        <source>trxUpdateFromConstant(_strArray : StringArray) : Boolean updating;
//-----------------------------------------
// Created: 04 July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Change Array to Set for performance

*/

vars
	tmpCat,
	tmpGroupCat,
	tmpRowCat,
	tmpDefCat,
	tmpContStr	: String;
	pos			: Integer;
	baseScm		: Schema;
	dataRoot	: EntTableDataRoot;
	const 		: Constant;
	xmlDoc		: JadeXMLDocument;
	entitiesAccessed	: ObjectSet;
	committran : Boolean;
begin

	if self.myEntTableDataRoot = null then
		return false;
	endif;
	
	dataRoot := self.myEntTableDataRoot;
	baseScm := rootSchema.getSchema(dataRoot.schemaName);
	xmlDoc := self.myXMLDoc;

	create entitiesAccessed transient;
				
	if not process.isInTransactionState then // ### TFS 51361 05JUL2021 NAVAB1
		beginTransaction;
		committran := true;
	endif;
	
	foreach tmpContStr in _strArray do
		
		const := baseScm.getConstant(tmpContStr);

		if const = null then
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant is null for ' &amp; tmpContStr);
			continue;		
		elseif const.text = null then
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; tmpContStr);
			continue;
		endif;
		
		pos := 1;
		tmpCat := const.text.cnEcGetNextWord(pos);

		if tmpCat = XMLTag_EntTableGroup then
			self.utlUpdateGroupFromXML(const.name, const.text, xmlDoc, entitiesAccessed);

		elseif tmpCat = XMLTag_EntTableDef then
			self.utlUpdateDefFromXML(const.name, const.text, xmlDoc, entitiesAccessed);

		elseif tmpCat = XMLTag_EntTableRow then
			self.utlUpdateRowsFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
					
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant category not handled for ' &amp; tmpContStr);
			continue;		
		endif;

	endforeach;
	
	if committran then // ### TFS 51361 05JUL2021 NAVAB1
		commitTransaction;
	endif;
	return true;

epilog
	delete entitiesAccessed;
end;</source>
        <Parameter name="_strArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateFromGlobalConstants" id="a6d6b518-1140-4eb8-9439-6ee46571ff80">
        <updating/>
        <source>trxUpdateFromGlobalConstants() : Boolean updating;
//-----------------------------------------
// Created: 04 July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Changed Array to Set for performance during upgrade
					Added cleanup of any unattached XLAT_EntityTableText translations at completion
					Also Added cleanup of unaccessed rows
					
*/

vars
	dataRoot		: EntTableDataRoot;
	baseScm 		: Schema;
	category 		: ConstantCategory;
	const 			: Constant;
	constDict		: ConstantNDict;
	xmlDoc			: JadeXMLDocument;
	group			: EntTableGroup;
	toDeleteArray	: EntTableArray;
	entitiesAccessed	: ObjectSet;
	iter			: Iterator;
	rowHeader		: EntTableRowHeader;
	row				: EntTableRow;
	def				: EntTableDef;		
	xlatCategory 	: XLAT_Category;
	translatableText : XLAT_EntityTableText;
	
begin

	if self.myEntTableDataRoot = null then
		return false;
	endif;
	
	dataRoot := self.myEntTableDataRoot;

	baseScm := rootSchema.getSchema(dataRoot.schemaName);

	xmlDoc := self.myXMLDoc;

	create toDeleteArray transient;
	create entitiesAccessed transient;
				
	beginTransaction;

	// Update the Groups first
	category := baseScm.getCategory(dataRoot.groupCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateGroupFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;
	
	iter := dataRoot.allEntTableGroups.createIterator;
	while iter.next(group) do
		if not entitiesAccessed.includes(group) then
			self.writeLogMessage(' Deleting group --&gt;&gt; ' &amp; group.name);				
			toDeleteArray.add(group);
		endif;
	endwhile;
	
	// clear and re-use coll
	entitiesAccessed.clear();
	
	// Update the Rows
	category := baseScm.getCategory(dataRoot.rowCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateRowsFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	// PAR #22559 - add in delete of unused rows
	foreach rowHeader in dataRoot.allEntTableRowHeadersByName do 
		if not entitiesAccessed.includes(rowHeader) then
			self.writeLogMessage(' Deleting rowHeader --&gt;&gt; ' &amp; rowHeader.name);		
			toDeleteArray.add(rowHeader);
		else
			foreach row in rowHeader.allEntTableRows do
				if not entitiesAccessed.includes(row) then
					self.writeLogMessage(' Deleting row --&gt;&gt; ' &amp; row.String &amp; ' ' &amp; rowHeader.name &amp; ' ' &amp; row.number.String);
					toDeleteArray.add(row);
				endif;
			endforeach;
		endif;
	endforeach;
	
	// clear and re-use coll
	entitiesAccessed.clear();
	
	// Update the Defs
	category := baseScm.getCategory(dataRoot.defCategory);
	constDict := category.getConstants();

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlUpdateDefFromXML(const.name, const.text, xmlDoc, entitiesAccessed);
		else
			self.writeLogMessage(method.qualifiedName &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	delete iter;
	iter := dataRoot.allEntTableDefs.createIterator;
	while iter.next(def) do
		if not entitiesAccessed.includes(def) then
			self.writeLogMessage(' Deleting def --&gt;&gt; ' &amp; def.name);
			toDeleteArray.add(def);
		endif;
	endwhile;
	entitiesAccessed.clear();
	
	// Delete entities no longer required;
	self.writeLogMessage('--&gt;&gt; ' &amp; toDeleteArray.size.String &amp; ' &lt;&lt;-- entities deleted');
	toDeleteArray.purge;
	
	// PAR #22559 - Now need to scan all the translations in the EntTableRows category, and delete any
	// that are "hanging"
	xlatCategory := app.myRoot.allXLAT_Categories[EntTableRows];
	
	delete iter;
	iter := xlatCategory.allTranslatableText.createIterator();
	
	while iter.next(translatableText) do
		if translatableText.myEntTableRow = null then
			self.writeLogMessage('Deleting translation --&gt;&gt; ' &amp; translatableText.String &amp; " " &amp; translatableText.number.String);
			
			delete translatableText;
		endif;
	endwhile;
	
	commitTransaction;
	return true;

	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete toDeleteArray;
	delete entitiesAccessed;
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateGroupName" id="f98d65bb-87f3-4668-b701-8bc433223d00">
        <updating/>
        <source>trxUpdateGroupName(_oldName, _newName : String) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dataRoot	: EntTableDataRoot;
	theGroup	: EntTableGroup;
begin

	dataRoot := self.myEntTableDataRoot;

	if dataRoot = null then
		self.writeLogMessage('Error - myEntTableDataRoot is null');
		return;
	endif;
	
	if _newName = null then
		self.writeLogMessage('Error - the new name cannot be null');
		return;
	endif;

	if dataRoot.allEntTableGroups.includesKey(_newName) then
		self.writeLogMessage('Error - New Name is already in use (' &amp; _newName &amp; ')');
		return;
	endif;

	theGroup := dataRoot.allEntTableGroups[_oldName];
	
	beginTransaction;
	
	theGroup.setForUpdate(_newName);
	
	commitTransaction;

end;</source>
        <Parameter name="_oldName" type="String"/>
        <Parameter name="_newName" type="String"/>
    </JadeMethod>
    <JadeMethod name="unloadAsSchemaFile" id="168013a3-5100-4fe1-b995-7b201f7f4f24">
        <source>unloadAsSchemaFile();
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myEntTableDataRoot = null then
		self.writeLogMessage('Error - myEntTableDataRoot is null');
		return;
	endif;

	self.myEntTableDataRoot.unloadAsSchemaFile('c:\tmp\enttable.scm');

end;</source>
    </JadeMethod>
    <JadeMethod name="utlCreateDataRoot" id="14fe5c36-0e7a-4e97-81fb-57a343c448b0">
        <source>utlCreateDataRoot(pClassToCreate : Class; pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory : String;
				  pErrStr : String output; pDataRoot : EntTableDataRoot output) : Boolean;
// -----------------------------------------------------------------------------
// Created:		11 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	rtnCode	: Boolean;
	newRoot	: EntTableDataRoot;
	class	: Class;
	
begin

	if pName = null then
		pErrStr := 'Name is required';
		return false;
	endif;
	
	if pGroupCategory = null then
		pErrStr := 'Constant Group Category is required';
		return false;
	endif;

	if pDefCategory = null then
		pErrStr := 'Constant Def Category is required';
		return false;
	endif;

	if pRowCategory = null then
		pErrStr := 'Constant Row Category is required';
		return false;
	endif;
	
	if pClassToCreate = null then
		class := EntTableDataRoot;
	else
		class := pClassToCreate;
	endif;

	
	create newRoot as class persistent;
	
	if (not newRoot.isKindOf(EntTableDataRoot)) then
		pErrStr := 'Class to create must be a kind of EntTableDataRoot';
		return false;
	else
		newRoot.setForCreate(pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory);
	endif;
	
	pDataRoot := newRoot;

	rtnCode := true;
	
epilog
	return rtnCode;
end;</source>
        <Parameter name="pClassToCreate" type="Class"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pSchema" type="String"/>
        <Parameter name="pGroupCategory" type="String"/>
        <Parameter name="pDefCategory" type="String"/>
        <Parameter name="pRowCategory" type="String"/>
        <Parameter name="pErrStr" type="String" usage="output"/>
        <Parameter name="pDataRoot" type="EntTableDataRoot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDefFromXML" id="0cef55b1-bcda-4d07-aa56-36f8d98d5817">
        <source>utlCreateDefFromXML(_constName, pStr : String; _xmlDoc : JadeXMLDocument input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     Text is XML in following format
/*
&lt;EntTableDef&gt;
	&lt;DefName&gt;BlahDef&lt;/DefName&gt;
	&lt;GroupName&gt;GateReceivals&lt;/GroupName&gt;
	&lt;Rows&gt;
		&lt;RowName&gt;id&lt;/RowName&gt;
		&lt;RowName&gt;blah&lt;/RowName&gt;
		..
		&lt;RowName&gt;LastOne&lt;/RowName&gt;
	&lt;/Rows&gt;
	&lt;View&gt;
		&lt;ViewName&gt;BlahView1&lt;/ViewName&gt;
		&lt;Rows&gt;
			&lt;RowName&gt;id&lt;/RowName&gt;
			&lt;RowName&gt;blah&lt;/RowName&gt;
			..
			&lt;RowName&gt;LastOne&lt;/RowName&gt;
		&lt;/Rows&gt;
	&lt;/View&gt;
	&lt;View&gt;
		&lt;ViewName&gt;BlahView2&lt;/ViewName&gt;
		&lt;Rows&gt;
			&lt;RowName&gt;id&lt;/RowName&gt;
			&lt;RowName&gt;blah&lt;/RowName&gt;
			..
			&lt;RowName&gt;LastOne&lt;/RowName&gt;
		&lt;/Rows&gt;
	&lt;/View&gt;

&lt;/EntTableDef&gt;
*/
// ---------------------------------------------------------------------------
vars
	rtnCode	: Boolean;
	defStr,
	grpName	: String;
	group	: EntTableGroup;
	def		: EntTableDef;
	xmlRootElement,
	xmlGroup		: JadeXMLElement;


begin

	defStr := self.getConstantTextXML(pStr, XMLTag_EntTableDef);
	if defStr = null then
		self.addError('XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;

	_xmlDoc.parseString(defStr);
	xmlRootElement := _xmlDoc.rootElement;
	grpName := xmlRootElement.getTagValueOfName(XMLTag_GroupName);
	
	if grpName = null then
		self.addError('Group name is null for (' &amp; pStr &amp; ')');
		return rtnCode;
	endif;
	
	group := self.myEntTableDataRoot.allEntTableGroups[grpName];
	if group = null then
		self.addError('No group found for (' &amp; grpName &amp; ')');
		return rtnCode;
	endif;
	
	create def persistent;
	def.setFromXMLElement(xmlRootElement, group, self.myEntTableDataRoot);

	rtnCode := true;
	
epilog
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="pStr" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateGroupFromXML" id="156f7e10-b941-4130-a63a-a308f1dabfd2">
        <source>utlCreateGroupFromXML(_constName, _constText : String; _xmlDoc : JadeXMLDocument input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     Text is XML in following format
/*
&lt;EntTableGroup&gt;
	&lt;GroupName&gt;Blah&lt;/GroupName&gt;
	&lt;Text&gt;Some Text&lt;/Text&gt;
&lt;/EntTableGroup&gt;
*/
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnCode	: Boolean;
	grpStr,
	grpName,
	grpText	: String;
	group	: EntTableGroup;
	xmlRootElement	: JadeXMLElement;

begin

	grpStr := self.getConstantTextXML(_constText, XMLTag_EntTableGroup);
	if grpStr = null then
		self.addError('Group XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	_xmlDoc.parseString(grpStr);
	xmlRootElement := _xmlDoc.rootElement;
	grpName := xmlRootElement.getTagValueOfName(XMLTag_GroupName);

	
	if grpName = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  ERROR GroupName is null');
		self.addError('Group name is null for (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	grpText := xmlRootElement.getTagValueOfName(XMLTag_Text);
	
	create group persistent;
	group.set(grpName, grpText, self.myEntTableDataRoot);
	
	rtnCode := true;
	
epilog
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="_constText" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRowsFromXML" id="8026da36-93f8-4718-ba1c-102f68228f71">
        <source>utlCreateRowsFromXML(_constName, pStr : String; _xmlDoc : JadeXMLDocument input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     Text is XML in following format
/*
&lt;EntTableRow&gt;
	&lt;RowName&gt;id&lt;/RowName&gt;	This is not present but is the implied constant value
	&lt;GroupRow&gt;
		&lt;GroupName&gt;GateReceivals&lt;/GroupName&gt;
		&lt;Heading&gt;Container No&lt;/Heading&gt;
		&lt;InputType&gt;3&lt;/InputType&gt;
		&lt;LostFocus&gt;&lt;/LostFocus&gt;
		&lt;GotFocus&gt;&lt;/GotFocus&gt;
		&lt;Click&gt;&lt;/Click&gt;
		&lt;Visible&gt;&lt;/Visible&gt;
		&lt;ControlName&gt;&lt;/ControlName&gt;
		&lt;ErrorReturnStr&gt;&lt;/ErrorReturnStr&gt;
		&lt;CellControl&gt;
			&lt;Decimals&gt;3&lt;/Decimals&gt;
			&lt;Case&gt;3&lt;/Case&gt;
			&lt;MaxLength&gt;12&lt;/MaxLength&gt;
		&lt;/CellControl&gt;
	&lt;/GroupRow&gt;
	&lt;GroupRow&gt;
	...
	&lt;/GroupRow&gt;
	...
&lt;/EntTableRow&gt;
*/
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnCode		: Boolean;
	rowStr,
	rowName,
	grpRowStr,
	grpName		: String;
	root		: EntTableDataRoot;
	group		: EntTableGroup;
	row			: EntTableRow;
	rowHeader	: EntTableRowHeader;
	pos			: Integer;
	xmlGroupArray	: JadeXMLElementArray;
	xmlRootElement,
	xmlGroup		: JadeXMLElement;

begin

	rowStr := self.getConstantTextXML(pStr, XMLTag_EntTableRow);
	if rowStr = null then
		self.addError('XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	_xmlDoc.parseString(rowStr);
	xmlRootElement := _xmlDoc.rootElement;
	rowName := xmlRootElement.getTagValueOfName(XMLTag_RowName);
	
	if rowName = null then
		self.addError('Row name is null for (' &amp; pStr &amp; ')');
		return rtnCode;
	endif;

	root := self.myEntTableDataRoot;
	
	create rowHeader persistent;
	rowHeader.set(_constName, rowName, root);
	
	create xmlGroupArray transient;
	xmlRootElement.getElementsByTagName(XMLTag_GroupRow, xmlGroupArray);
	
	foreach xmlGroup in xmlGroupArray do
		grpName := xmlGroup.getTagValueOfName(XMLTag_GroupName);
		if grpName = null then
			self.addError('grpName is null (' &amp; rowName &amp; ')');
			app.writeStatement( '****** ERROR &gt;&gt;&gt; grpName is null for ' &amp; rowName);
			continue;
		endif;
		group := root.allEntTableGroups[grpName];
		if group = null then
			self.addError('No group found for (' &amp; grpName &amp; ')');
			app.writeStatement( '****** ERROR &gt;&gt;&gt; No group found for ' &amp; rowName &amp; ' (' &amp; grpName &amp; ')');
			continue;
		endif;

		create row persistent;
		row.setFromXMLElement(rowHeader, xmlGroup, group);
	endforeach;
	
	/*
	
	pos := 1;
	while (pos &gt; 0) do
		grpRowStr := rowStr.cnEcGetNextTagValueOfName(XMLTag_GroupRow, pos);
		if grpRowStr &lt;&gt; null then
			grpName := grpRowStr.cnEcGetTagValueOfName(XMLTag_GroupName);
		
			// validate groupName
			group := root.allEntTableGroups[grpName];
			if group = null then
				self.addError('No group found for (' &amp; grpName &amp; ')');
				write '****** ERROR &gt;&gt;&gt; No group found for ' &amp; rowName &amp; ' (' &amp; grpName &amp; ')';
				continue;
			endif;

			create row persistent;
			row.setFromXML(rowHeader, grpRowStr, group);
		endif;
		
	endwhile;
	*/
	
	rtnCode := true;
	
epilog
	delete xmlGroupArray;
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="pStr" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDefFromXML" id="6cb63179-3888-4bb5-bf3d-48539230fe40">
        <source>utlUpdateDefFromXML(_constName, pStr : String; _xmlDoc : JadeXMLDocument input; _entitiesAccessed : Collection input) : Boolean protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Signature change, to allow set to be used for performance during upgrade

*/

vars
	rtnCode			: Boolean;
	defStr,
	grpName			: String;
	group			: EntTableGroup;
	def				: EntTableDef;
	xmlRootElement,
	xmlGroup		: JadeXMLElement;
	
begin

	defStr := self.getConstantTextXML(pStr, XMLTag_EntTableDef);
	if defStr = null then
		self.addError('XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;

	_xmlDoc.parseString(defStr);
	xmlRootElement := _xmlDoc.rootElement;
	grpName := xmlRootElement.getTagValueOfName(XMLTag_GroupName);
	
	if grpName = null then
		self.addError('Group name is null for (' &amp; pStr &amp; ')');
		return rtnCode;
	endif;
	
	group := self.myEntTableDataRoot.allEntTableGroups[grpName];
	if group = null then
		self.addError('No group found for (' &amp; grpName &amp; ')');
		return rtnCode;
	endif;
	
	def := group.allEntTableDefsByName[xmlRootElement.getTagValueOfName(XMLTag_DefName)];
	if def = null then
		create def persistent;
	endif;
	def.setFromXMLElement(xmlRootElement, group, self.myEntTableDataRoot);
	
	if not _entitiesAccessed.includes(def) then		// PAR #22559
		_entitiesAccessed.add(def);
	endif;

	rtnCode := true;
	

epilog
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="pStr" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_entitiesAccessed" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGroupFromXML" id="f5a27640-0418-41f6-9325-ac1264d3f51a">
        <source>utlUpdateGroupFromXML(_constName, _constText : String; _xmlDoc : JadeXMLDocument input; _entitiesAccessed : Collection input) : Boolean protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Changed signature to allow set top be used for performance during upgrade

*/

vars
	rtnCode			: Boolean;
	grpStr,
	grpName,
	grpText			: String;
	group			: EntTableGroup;
	xmlRootElement	: JadeXMLElement;

begin

	grpStr := self.getConstantTextXML(_constText, XMLTag_EntTableGroup);
	if grpStr = null then
		self.addError('Group XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	_xmlDoc.parseString(grpStr);
	xmlRootElement := _xmlDoc.rootElement;
	grpName := xmlRootElement.getTagValueOfName(XMLTag_GroupName);

	
	if grpName = null then
		app.writeStatement(method.qualifiedName &amp; '  ERROR GroupName is null');
		self.addError('Group name is null for (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	grpText := xmlRootElement.getTagValueOfName(XMLTag_Text);
	
	group := self.myEntTableDataRoot.allEntTableGroups[grpName];
	if group = null then
		create group persistent;
	endif;
	
	group.set(grpName, grpText, self.myEntTableDataRoot);
	
	if not _entitiesAccessed.includes(group) then		// PAR #22559
		_entitiesAccessed.add(group);
	endif;
	
	rtnCode := true;
	
	
epilog
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="_constText" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_entitiesAccessed" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRowsFromXML" id="3560e58a-ad9d-4c19-bc16-7ce068fc0af5">
        <source>utlUpdateRowsFromXML(_constName, pStr : String; _xmlDoc : JadeXMLDocument input; _entitiesAccessed : Collection input) : Boolean protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Changed signature to allow set for performance during upgrade
					Changed find code to always find existing row by nunmber, and to
					clean up any duplicates before they cause upgrade issues
					Also add individual rows into the collection of accessed entities
					
*/

vars
	rtnCode			: Boolean;
	rowStr,
	rowName,
	grpRowStr,
	grpName			: String;
	root			: EntTableDataRoot;
	group			: EntTableGroup;
	row,
	existingRow		: EntTableRow;
	rowHeader		: EntTableRowHeader;
	pos				: Integer;
	xmlGroupArray	: JadeXMLElementArray;
	xmlRootElement,
	xmlGroup		: JadeXMLElement;
	rowErrorReturnStr : String;
	rowNumber		: Integer;
	
begin

	rowStr := self.getConstantTextXML(pStr, XMLTag_EntTableRow);
	if rowStr = null then
		self.addError('XML Tag is null (' &amp; _constName &amp; ')');
		return rtnCode;
	endif;
	
	_xmlDoc.parseString(rowStr);
	xmlRootElement := _xmlDoc.rootElement;
	rowName := xmlRootElement.getTagValueOfName(XMLTag_RowName);
	
	if rowName = null then
		self.addError('Row name is null for (' &amp; pStr &amp; ')');
		return rtnCode;
	endif;

	root := self.myEntTableDataRoot;
	
	rowHeader := root.allEntTableRowHeadersByName[rowName];

	if rowHeader = null then	
		create rowHeader persistent;
	endif;
	rowHeader.set(_constName, rowName, root);
	
	if not _entitiesAccessed.includes(rowHeader) then
		_entitiesAccessed.add(rowHeader);
	endif;
	
	create xmlGroupArray transient;
	xmlRootElement.getElementsByTagName(XMLTag_GroupRow, xmlGroupArray);
	
	foreach xmlGroup in xmlGroupArray do
		grpName := xmlGroup.getTagValueOfName(XMLTag_GroupName);
		if grpName = null then
			self.addError('grpName is null for (' &amp; rowName &amp; ')');
			app.writeStatement( '****** ERROR &gt;&gt;&gt; grpName is null for ' &amp; rowName);
			continue;
		endif;
		group := root.allEntTableGroups[grpName];
		if group = null then
			self.addError('No group found for (' &amp; grpName &amp; ')');
			app.writeStatement( '****** ERROR &gt;&gt;&gt; No group found for ' &amp; rowName &amp; ' (' &amp; grpName &amp; ')');
			continue;
		endif;

		// PAR #22559 - Reworked code here to find existing row by number instead of name
		rowNumber := xmlGroup.getTagValueOfName(XMLTag_Number).Integer;
		if rowNumber = 0 then
			self.addError('number is null for (' &amp; rowName &amp; ')');
			app.writeStatement( '****** ERROR &gt;&gt;&gt; number is null for ' &amp; rowName &amp; ' (' &amp; grpName &amp; ')');
			continue;
		endif;
		
		// Find existing row by number (if there is one)
		row := root.allEntTableRowsByNumber[rowNumber];
		if row = null then
			create row persistent;
		endif;

		// Now need to check for any other row in the same group which currently clashes with this one
		// before it is populated.  If there are any clashes, then delete them, because they must be invalid
		// now, because the new one will override them
		
		// First check for match by name
		existingRow := group.allEntTableRowsByName[rowName];
		if existingRow &lt;&gt; null and existingRow &lt;&gt; row then
			self.writeLogMessage('****** WARNING &gt;&gt;&gt; Duplicate name found for ' &amp; rowName &amp; ' (' &amp; grpName &amp; ')');
			self.writeLogMessage('               &gt;&gt;&gt; Deleting ' &amp; existingRow.String &amp; ' ' &amp; existingRow.name &amp; ' ' &amp; existingRow.number.String);

			delete existingRow;
		endif;
		
		// Then check for match by errorReturnString
		rowErrorReturnStr := xmlGroup.getTagValueOfName(XMLTag_ErrorReturnStr);
		existingRow := group.allEntTableRowsByErrorRtn[rowErrorReturnStr];
		if existingRow &lt;&gt; null and existingRow &lt;&gt; row then
			self.writeLogMessage('****** WARNING &gt;&gt;&gt; Duplicate errorReturnString found for ' &amp; rowErrorReturnStr &amp; ' (' &amp; grpName &amp; ')');
			self.writeLogMessage('               &gt;&gt;&gt; Deleting ' &amp; existingRow.String &amp; ' ' &amp; existingRow.name &amp; ' ' &amp; existingRow.number.String);

			delete existingRow;
		endif;

		// Should be OK to update row without errors now
		row.setFromXMLElement(rowHeader, xmlGroup, group);
		
		if not _entitiesAccessed.includes(row) then
			_entitiesAccessed.add(row);
		endif;

	endforeach;

	rtnCode := true;

	
epilog
	delete xmlGroupArray;
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <Parameter name="pStr" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_entitiesAccessed" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeLogMessage" id="9f1dc5e3-1f30-4f3f-877c-a6bcf2022482">
        <source>writeLogMessage(_msg : String) protected;

/*

Purpose:			Write the passed in message to the Interpreter window and the application
					log

Parameters:			message to write

Return Value:		None


Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues

*/

vars

begin
	app.writeStatement(_msg);
	app.writeLog(_msg, 0);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
