    <JadeMethod name="translateForm" id="0ea658bf-48c7-41ec-a1d7-ac8affe25d81">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2023 14:28:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008238, locale);
	btnExportCSV.translateCaption(Xlat_0008239, locale);
	btnPrint.translateBubbleHelp(Xlat_0001119, locale);
	btnPrint.translateCaption(Xlat_0001127, locale);
	btnProcessCnt.translateBubbleHelp(Xlat_0001120, locale);
	btnProcessCnt.translateCaption(Xlat_0001128, locale);
	btnQueryToday.translateBubbleHelp(Xlat_0001121, locale);
	btnQueryToday.translateCaption(Xlat_0001129, locale);
	btnRefresh.translateBubbleHelp(Xlat_0001122, locale);
	btnRefresh.translateCaption(Xlat_0001130, locale);
	btnTermNode.translateBubbleHelp(Xlat_0001123, locale);
	btnTermNode.translateCaption(Xlat_0001131, locale);
	btnTermProcess.translateBubbleHelp(Xlat_0001124, locale);
	btnTermProcess.translateCaption(Xlat_0001132, locale);
	btnViewLocks.translateBubbleHelp(Xlat_0001125, locale);
	btnViewLocks.translateCaption(Xlat_0001133, locale);
	btnViewUsers.translateBubbleHelp(Xlat_0001126, locale);
	btnViewUsers.translateCaption(Xlat_0001134, locale);
	frmPrint.translateCaption(Xlat_0001135, locale);
	frmViewMode.translateCaption(Xlat_0001136, locale);
	lblDateFrom.translateCaption(Xlat_0001137, locale);
	lblDateTo.translateCaption(Xlat_0001138, locale);
	lblPrint.translateCaption(Xlat_0001139, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026451, locale);
	mnuSetLogLevel.translateCaption(Xlat_0023837, locale);
	mnuSetLogLvlApp.translateCaption(Xlat_0023879, locale);
	mnuTblLocksPrintAll.translateCaption(Xlat_0008240, locale);
	mnuTblLocksPrintSelect.translateCaption(Xlat_0008241, locale);
	mnuTblNodesContext.translateCaption(Xlat_0008242, locale);
	mnuTblNodesSendReq.translateCaption(Xlat_0008243, locale);
	mnuTblNodesShowScreen.translateCaption(Xlat_0008244, locale);
end;</source>
