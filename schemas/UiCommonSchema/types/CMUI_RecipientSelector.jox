    <JadeMethod name="addAddressToList" id="a5f24359-6dc4-4ab7-8837-bdd47ae5a3ad">
        <source>addAddressToList(_lstBox : CMUI_ListBox);
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	numRows,
	row : Integer;
	emailEntity : CM_EmailEntity;
	tbl : CM_DataTable;
begin
	if _lstBox = null then
		return;
	endif;
	
	tbl := self.tblContacts;
	numRows := tbl.rows;
	foreach row in 2 to numRows do
		if tbl.accessRow(row).selected then
			emailEntity := tbl.accessedRow.itemObject.CM_EmailEntity;
			str := emailEntity.getDisplayStringForAttribute(ETRow_Title, false);
			_lstBox.addTreeObjectIfNotPresent(str, emailEntity, 1, false);
		endif;
	endforeach;

end;</source>
        <Parameter name="_lstBox" type="CMUI_ListBox"/>
    </JadeMethod>
