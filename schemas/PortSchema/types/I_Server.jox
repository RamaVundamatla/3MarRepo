    <JadeMethod name="asynchObjectRegister" id="de4b702e-8091-4736-977d-c30ae58877bb">
        <updating/>
        <source>asynchObjectRegister(asynchObject:IDispatch io; objectType:Integer io; config:Integer io; reserved:Any io) updating;
	// Registers an asynchronous notification object.

vars
	_p1 : IDispatch;

begin

	_p1 := asynchObject;


	_jadeActiveXMethodio('AsynchObjectRegister', '', 1, _p1, objectType, config, reserved);
	if _p1 = null then
		asynchObject := null;
	else
		asynchObject := _p1._morph(IDispatch).IDispatch;
	endif;

end;
</source>
        <Parameter name="asynchObject" type="IDispatch" usage="io"/>
        <Parameter name="objectType" type="Integer" usage="io"/>
        <Parameter name="config" type="Integer" usage="io"/>
        <Parameter name="reserved" type="Any" usage="io"/>
    </JadeMethod>
    <JadeMethod name="asynchObjectUnregister" id="a077eba7-24c8-4af0-b287-7dae919de4ae">
        <updating/>
        <source>asynchObjectUnregister(asynchObject:IDispatch io; objectType:Integer io) updating;
	// Unregisters an asynchronous notification object.

vars
	_p1 : IDispatch;

begin

	_p1 := asynchObject;


	_jadeActiveXMethodio('AsynchObjectUnregister', '', 1, _p1, objectType);
	if _p1 = null then
		asynchObject := null;
	else
		asynchObject := _p1._morph(IDispatch).IDispatch;
	endif;

end;
</source>
        <Parameter name="asynchObject" type="IDispatch" usage="io"/>
        <Parameter name="objectType" type="Integer" usage="io"/>
    </JadeMethod>
