		foreach ti in self.allAssignedTrackedItems discreteLock do
			retStr.addStringToList(ti.getCOOOperatorStorageDesc(), ", ");
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			valueStr := cgd.cooOpStoDescs;
			/*
			if valueStr &lt;&gt; null then
				if retStr.pos(valueStr, 1) = 0 then
					if retStr = null then
						retStr := valueStr;
					else
						retStr := retStr &amp; ", " &amp; valueStr;
					endif;
				endif;
			endif;
			*/
			
			retStr.addStringToList(valueStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endforeach;
	endif;
	
	return retStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoCount" id="f3b636ba-5db6-4fcd-9a2c-4ebbb9d95a83">
        <source>getCargoCount(_scanned : Boolean; _mode : String; _entity : Object):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2024 navhl20 ChangeRequest 62406:[62534] EUP | Scanning App Cargo Group Overview Changes
24 Apr 2024 navbk1  Bug 63811: EUP | Scanning App Cargo Group Overview Changes - Part 2
12 Aug 2024 navbk1  Bug 65344: FR | 53856 - New Scanning App - Cargo Group Overview - Cargo groups not found

*/

vars
	ti,
	childTi	: CM_TrackedItem;
	count	: Integer;
	vehicle	: CM_Vehicle;
	wagon	: CM_Wagon;
	voyage	: CM_Voyage;
	wo		: CM_WorkOrderTI;
	txn		: CM_Transaction;
	quantity: Integer;
begin
	if _mode = "ship" then
		voyage := _entity.CM_Voyage;																//03.05.2024 navbk1 #63811
	elseif _mode = "road" then
		vehicle := _entity.CM_Vehicle;																//03.05.2024 navbk1 #63811
	elseif _mode = "rail" then
		wagon := _entity.CM_Wagon;																	//03.05.2024 navbk1 #63811
	elseif _mode = "unpack" then
		wo := _entity.CM_WorkOrderTI;																//03.05.2024 navbk1 #63811
	endif;
	
	foreach ti in self.allAssignedTrackedItems do
		quantity := ti.totalQuantity;
		if _scanned then
			if _mode = "ship" then
				if ti.getLastTransOfClass(CM_ReceiveShip) &lt;&gt; null 
				and ti.myVoyage = voyage then
					count := count + quantity;														//03.05.2024 navbk1 #63811	
				endif;
			elseif _mode = "road" then
				if ti.getLastTransOfClass(CM_ReceiveRoad) &lt;&gt; null 
				and ti.vehicle = vehicle.regNumber and not ti.isOnVehicle(vehicle) 
				and ti.getVehicleVisitNumber() = vehicle.getCurrentVisit().visitNumber then 		//12.08.2024 navbk1 #65344
					count := count + quantity;														//03.05.2024 navbk1 #63811						
				endif;		
			elseif _mode = "rail" then
				if ti.getLastTransOfClass(CM_ReceiveRail) &lt;&gt; null 
				and ti.wagon = wagon.id and not ti.isOnWagon() then
					count := count + quantity;														//03.05.2024 navbk1 #63811
				endif;
			elseif _mode = "unpack" then
				//START 12.08.2024 navbk1 #65344
				if wo.allTIs.includes(ti.getMyUnpackedFromContainer()) then
					count := count + quantity;
				endif;
				/*if wo.allTIs.includes(ti) then
					foreach txn in ti.allTransactions reversed do
						if txn.isKindOf(CM_Unpack) then
							count := count + quantity;												//03.05.2024 navbk1 #63811
						elseif txn.isKindOf(CM_Pack) then	
							break;
						endif;
					endforeach;
				endif;*/
				//END 12.08.2024 navbk1 #65344
			endif;
		else
			if _mode = "ship" then
				if ti.state = TI_STATE_ONSHIP and not ti.receivedDT.isValid 
				and ti.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and ti.myVoyage = voyage then
					count := count + quantity;														//03.05.2024 navbk1 #63811
				endif;
			elseif _mode = "road" then
				if ti.isOnVehicle(vehicle) then
					count := count + quantity;														//03.05.2024 navbk1 #63811
				endif;
			elseif _mode = "rail" then
				if ti.isOnWagon and ti.wagon = wagon.id then
					//count := count + ti.quantity;													//12.08.2024 navbk1 #65344
					count := count + quantity;														//12.08.2024 navbk1 #65344
				endif;
			elseif _mode = "unpack" then
				//START 12.08.2024 navbk1 #65344
				if wo.allTIs.includes(ti.getParent()) then
					count := count + quantity;
				endif;
				/*if wo.allTIs.includes(ti) and ti.allChildren.isNotEmpty() then
					foreach childTi in ti.allChildren do
						count := count + childTi.totalQuantity;										//03.05.2024 navbk1 #63811
					endforeach;
				endif;*/
				//END 12.08.2024 navbk1 #65344
			endif;
		endif;
	endforeach;
	return count;
epilog

end;</source>
        <Parameter name="_scanned" type="Boolean"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_entity" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
