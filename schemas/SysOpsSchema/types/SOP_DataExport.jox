        <source>initTableExtractHistory() updating, protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.initTableDataCommon(self.tblExtractHist, ETDef_ExtractHistory);
	self.tblExtractHist.leftColumn := 1;
	self.zClearSortColumns();
//	self.tblExtractHist.sortColumn[3] := 0;
//	self.tblExtractHist.sortColumn[2] := 0;
//	self.tblExtractHist.sortColumn[1] := 0;
//	self.tblExtractHist.zAddSortColumn('startDateTime', false);
	self.tblExtractHist.zAddSortColumn('endDateTime', false);
	self.tblExtractHist.zAddSortColumn('extractedUpToDateTime', false);
	self.tblExtractHist.zAddSortColumn('classAlias', false);
	self.tblExtractHist.zAddSortColumn('extractedFromDateTime', false);
end;</source>
