    <JadeMethod name="utlUpdateLogon" id="85269935-57c7-4d44-aeda-6078a4773d14">
        <source>utlUpdateLogon(	_userCode: String;
				_userPassword : String;
				_machine,
				_machineToIgnore: CM_Machine;
				_passport : CM_Passport input) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Feb 2009	cnwer1	Initial creation par 18256
 8 Feb 2011 cnwer1  PAR 26908 - now passing in _machine to validateUserIdPassword method signature changed to include machine
// 21 June 2011	cnwrs1		CCMS1150 - Change JMT to enable logon SDS Secondary database
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 30 Nov 2017  cnwma1	TFS #7995 STWO - Maximum Password Attempts - not matching security setup - system fault
05 Mar 2024 jlier1 TFS 62428
*/
vars
	result : Integer;
	terminal : CM_Terminal;
	excOccurred		: Boolean;
	cmifEventCtrl : CMIF_EventTransactionCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin	
	self.initialiseActivity();
	result	:=	app.myRoot.validateUserIdPassword(_userCode, _userPassword,_machine,_machineToIgnore, _passport);

	if result = 0 then
		if app.isSDSSecondaryDB() then		// CCMS1150 cnwrs1 21 June 2011
			return result;
		endif;
		//epr TFS 995 22/5/17 set the terminal from machine otherwise got 1090 
		if _machine &lt;&gt; null then
			terminal:=_machine.getMyTerminal();
		endif;
		
		/*//17/02/2025	navkc1 JIRA Bug MTN-33582
		_passport.myEventLogin := app.createEvent(EVT_UserLogin, app.serverTimestampAtTrxStart,terminal , _userCode, false, false,0).CMEVT_Login;
		
		if _passport.noErrors() and _passport.myEventLogin &lt;&gt; null  then
			on CM_Exception do app.handleTransactionMapError(exception, excOccurred);   // 30.11.2017 cnwma1 TFS #7995
			//_passport.myEventLogin.createCharge(_passport);
			_passport.addEventTransactionForDeferUpd(_passport.myEventLogin,_passport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			on CM_Exception do null;
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts		
		if app.myPassport.context &lt;&gt; Context_Pass_NoEventRecord then							//navra1 - MTN-36928 - 8th Jan 2026-1
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_UserLogin;
			cmifEventCtrl.dateTime := app.serverTimestampAtTrxStart;
			cmifEventCtrl.myTerminal := terminal;
			cmifEventCtrl.userCode := _userCode;
			
			_passport.myEventLogin := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_Login; //17/02/2025	navkc1 JIRA Bug MTN-33582
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends			
		else																					//navra1 - MTN-36928 - 8th Jan 2026-1
			app.writeLog("Skipping creating event for API call", LogDEBUG);						//navra1 - MTN-36928 - 8th Jan 2026-1
		endif;																					//navra1 - MTN-36928 - 8th Jan 2026-1
	endif;
	
	if _passport.noErrors() then
		// 25 Jun 2021	NDL	TFS 51310
	//	if result = 0 and _userCode = SUPERUSER_Str then
	//		app.setSpecial('31/12/3000'.TimeStamp);
	//	else
			app.setSpecial(app.actualTimeServer);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	//	endif;
	endif;
	
	return result;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userPassword" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLogonJMTSSO" id="d614f010-d5f0-40d3-9e4f-0ec287946c35">
        <source>utlUpdateLogonJMTSSO(_user : CM_User; _machine, _machineToIgnore : CM_Machine; _passport : CM_Passport input) : Integer;
/*

Purpose:			
	Implements logon for Cargo applications using a JWT token generated by Vehicle applications.
Parameters:			

Return Value:		

Date		Who		Reason
27 May 2025	navnk30	JIRA 34707: SSO Implementation for Mobile App - Jade Portion

*/

vars
	result			: Integer;
	terminal		: CM_Terminal;
	cmifEventCtrl	: CMIF_EventTransactionCtrl;
begin
	//Not validating user here as JMT token has already been validated at WS_WebServiceAgent::validateJWT()
	self.initialiseActivity();
	
	if app.isSDSSecondaryDB() then
		return result;
	endif;
	
	if not app.myRoot.concurrentAppSignonCheck(_user, result, _machine, _machineToIgnore, _passport) then
		return result;
	endif;
	
	_passport.setForLogon(_user);
	terminal := _machineToIgnore.getMyTerminal();
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_UserLogin;
	cmifEventCtrl.dateTime := app.serverTimestampAtTrxStart;
	cmifEventCtrl.myTerminal := terminal;
	cmifEventCtrl.userCode := _user.code;
	
	_passport.myEventLogin := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_Login;
	
	if _passport.noErrors() then
		app.setSpecial(app.actualTimeServer);
	endif;
	
	return result;
epilog
	delete cmifEventCtrl;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLogonSSO" id="e102c388-8d00-4ff5-9b65-4ca92c8746bc">
        <source>utlUpdateLogonSSO(_upn, _uid : String; _machine : CM_Machine;
				_passport : CM_Passport input ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
*/

vars
	result : Integer;
	terminal : CM_Terminal;
	excOccurred		: Boolean;
	cmifEventCtrl : CMIF_EventTransactionCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	self.initialiseActivity();
	result	:=	app.myRoot.validateUserUpnUid(_upn, _uid,_machine, _passport);

	if result = 0 then
		if app.isSDSSecondaryDB() then		
			return result;
		endif;

		if _machine &lt;&gt; null then
			terminal:=_machine.getMyTerminal();
		endif;
		
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		_passport.myEventLogin := app.createEvent(EVT_UserLogin, app.serverTimestampAtTrxStart,terminal , _passport.userCode, false, false,0).CMEVT_Login;
		
		if _passport.noErrors() and _passport.myEventLogin &lt;&gt; null  then
			on CM_Exception do app.handleTransactionMapError(exception, excOccurred);
			//_passport.myEventLogin.createCharge(_passport);
			_passport.addEventTransactionForDeferUpd(_passport.myEventLogin,_passport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			on CM_Exception do null;
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_UserLogin; 
		cmifEventCtrl.dateTime := app.serverTimestampAtTrxStart;
		cmifEventCtrl.myTerminal := terminal;
		cmifEventCtrl.userCode := _passport.userCode;
		
		_passport.myEventLogin := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_Login; 
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
	endif;
	
	if _passport.noErrors() then
			app.setSpecial(app.actualTimeServer);
	endif;
	
	return result;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
