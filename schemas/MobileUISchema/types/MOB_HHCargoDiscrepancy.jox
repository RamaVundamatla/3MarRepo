    <JadeMethod name="translateForm" id="c751f8c5-4c2e-42c7-ac95-84035433b961">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 January 2018 11:13:32.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019371, locale);
	lblCargoId.translateCaption(Xlat_0019372, locale);
	lblCargoWeight.translateCaption(Xlat_0022185, locale);
	lblQuantity.translateCaption(Xlat_0019373, locale);
	lblReason.translateCaption(Xlat_0019374, locale);
	lblTareWeight.translateCaption(Xlat_0022186, locale);
	lblTotalWeight.translateCaption(Xlat_0019375, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="4c710012-c5af-4f70-86d8-c8d8fe0f59e7">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="05d559cd-fdc4-40e6-9073-246f0c18374b">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtNewQuantity_change" id="c37c6170-39b0-42cc-ae68-5f3cdd040e5a">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtNewQuantity_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	strValue : String;
	int : Integer;
	qty : Integer;
	msg : String;

begin

	if textbox.text.trimBlanks = null or self.myTrackedItem = null then
		self.lblQuantityChg.caption := null;
		return;
	endif;

	qty := self.myTrackedItem.totalQuantity;
	
	//24 Jul 2017	NDL	TFS 5322
	strValue := textbox.text;
	if strValue.isInteger then
		int := strValue.Integer;
	else
		msg := app.getErrorString(Numeric_value_large);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.btnOne.enabled := false;
		return;	
	endif;
	self.btnOne.enabled := true;
	
//	int := textbox.text.Integer;
	
	self.lblQuantityChg.caption := (int - qty).String;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="c92b0b81-e1df-4810-beb6-1a3c1b6b4061">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	option			: Integer; 
	timeRemaining	: Integer;

begin

	if self.getTimerStatus(WeightChange, option, timeRemaining) then
		self.endTimer(WeightChange);
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
