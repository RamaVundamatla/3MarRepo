<Class name="HMS_PSD_Vessel" id="74b2d372-135f-4940-ad4d-ff08f910b966">
    <superclass name="HMS_PathSegmentDuration"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="myVessel" id="f1153106-e134-4513-8df4-7b1b8f884943">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Vessel"/>
        <access>readonly</access>
        <Inverse name="CM_Vessel::allPathSegmentDurations"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="2bcb0748-d5d7-4b23-b718-b7bcfdaa0995">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj			:=	inheritMethod();
	proxyObj.myVessel	:=	self.myVessel;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="48bfc177-1e00-4d00-a4fe-06f947bcfd72">
        <updating/>
        <source>setProxy(	_estimatedTime:Integer;
			_minimumTime:Integer;
			_pathSegmentObj:HMS_PathSegment;
			_vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Sets the proxy receiver's property values.
//
// Parameters:	_estimatedTime - 
//				_minimumTime - 
//				_pathSegmentObj - 
//				_voyageObj - 
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	self.estimatedTime	:=	_estimatedTime;
	self.minimumTime	:=	_minimumTime;
	self.myPathSegment	:=	_pathSegmentObj;
	self.myVessel		:=	_vesselObj;
end;</source>
        <Parameter name="_estimatedTime" type="Integer"/>
        <Parameter name="_minimumTime" type="Integer"/>
        <Parameter name="_pathSegmentObj" type="HMS_PathSegment"/>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setVessel" id="7f2d63d5-4169-4286-a844-30552930e8d9">
        <updating/>
        <source>setVessel(_vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		29 August 2006 by cnwdad1
//
// Purpose:		Sets the reference to the receiver's Vessel object.
//
// Parameters:	_vesselObj - The referencew to the Vessel.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myVessel	:=	_vesselObj;
end;</source>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="59a08568-29cd-4296-9bae-bb86e3610b31">
        <source>validateMe(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Validates the receiver (as a proxy).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_passport);
	
	if self.estimatedTime = 0 then
//		app.raiseCMException1(REQUIRED_FIELD, "Estimated Time", null, null);
		app.raiseCMException(Input_required_field_estTime, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.minimumTime = 0 then
//		app.raiseCMException1(REQUIRED_FIELD, "Minimum Time", null, null);
		app.raiseCMException(Input_required_field_minTime, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myVessel = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Vessel", null, null);
		app.raiseCMException(Input_required_field_vessel, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
