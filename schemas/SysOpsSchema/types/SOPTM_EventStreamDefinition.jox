	theForm.shtSingleSelect2.visible := false;

	theForm.mulSelect3.visible := true;
	theForm.shtMultiSelect3.visible := true;
	theForm.shtSingleSelect2.visible := false;
	
	//14 Jul 2020	NDL TFS 49747
	theForm.mulSelect6.visible := true;
	theForm.shtMultiSelect6.visible := true;
	
epilog

end;</source>
    </JadeMethod>
