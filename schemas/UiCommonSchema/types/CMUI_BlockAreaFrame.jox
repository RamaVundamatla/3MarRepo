        <source>doZoomIncrement( _factor : Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2008	cnwrd1	Initial creation par #17137	

*/

vars

begin
 doZoom( self.getZoomFactor() + _factor );

epilog

