    <JadeMethod name="displayTemperature" id="b163fe2a-7421-4fbd-b02f-4498a6fd7d92">
        <updating/>
        <source>displayTemperature() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 04/10/2017	jlgdao1		TFS 7204 STWR Correct real handling for non-standard locales
//
vars
	temp : Real;

begin
	if self.myTrackedItem &lt;&gt; null then
		temp := self.myTrackedItem.getReleasedTemperature;
		if temp &lt;&gt; NULL_TEMPERATURE then
			//self.txtTemperature.text := temp.String;			// TFS 7204
			self.txtTemperature.text := temp.asStringJMT;		// TFS 7204
		endif;
	endif;
	self.txtTemperature.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="02c40714-0131-4965-be38-13b2eb6cb9db">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCM SSFW 1413 TFS 313 Cold Store Enahancements
//
vars
	stdHeight : Real;
	stdWidth : Real;
	thirdWidth : Real;
	vTop : Real;
	vLeft : Real;

begin
	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	thirdWidth := ( stdWidth - self.resizedMargin ) * 1/3 ;
	vTop := stdHeight;

	self.chkToDo.top := self.txtTemperature.top + self.txtTemperature.height + self.resizedMargin;
	
	self.lblTemperature.move(	self.resizedMargin,
								vTop,
								thirdWidth + 10,
								stdHeight	);
	
	vLeft := thirdWidth + self.resizedMargin + 10;
    self.txtTemperature.move(	vLeft,
								vTop,
								thirdWidth,
								stdHeight	);
	
	vLeft := self.txtTemperature.left + self.txtTemperature.width + self.resizedMargin;
	self.lblCelFahr.move(	vLeft,
							vTop,
							self.lblCelFahr.width,
							stdHeight	);
	
	vTop := self.txtTemperature.top + self.txtTemperature.height + (5 * self.resizedMargin);					   
	self.chkToDo.alignment := self.txtTemperature.Alignment_Left;
	self.chkToDo.move(	vLeft,
						vTop,	
						2 * thirdWidth,
						stdHeight	);	

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="3805dab2-aa41-47ad-a18f-66919cf77056">
        <updating/>
        <source>doSave() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 04/10/2017	jlgdao1		TFS 7204 STWR Correct real handling for non-standard locales
//
vars
	sessionAgent	: CM_MobileAgent;
	errors			: String;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	addingToDo		: Boolean;
	temperature		: Real;

begin
	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent := self.getSessionAgent;
	if sessionAgent.getMyProxyObject = null then
		return false;
	endif;
	
	addingToDo := self.chkToDo.value;
	if self.myCargoCheckItem &lt;&gt; null then
		toDoTaskDesc := self.myCargoCheckItem.myToDoTaskDesc;
	endif;
	
	//temperature := self.txtTemperature.text.Real;				// TFS 7204
	temperature := self.txtTemperature.text.asRealJMT;			// TFS 7204
	if self.lblCelFahr.caption = Degrees_F then
		temperature := app.temperatureConversion(false, temperature);
	endif;
	if sessionAgent.updateTemperatureReading(	temperature,	
												toDoTaskDesc, 
												addingToDo	) then
		if errors &lt;&gt; null then
			self.msgBox(errors,"Error",MsgBox_OK_Only, false);
		endif;
		return true;
	else
		return false;
	endif;
	
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="55c7998d-e874-46d2-be39-c6dc72635a14">
        <updating/>
        <source>handleBtnOne() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	if self.doSave() then
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
