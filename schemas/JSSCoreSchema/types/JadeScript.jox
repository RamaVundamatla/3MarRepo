<Class name="JadeScript">
    <JadeMethod name="cnwdad1_SetFont" id="dad95473-8ee6-4ab4-b914-bd3d441ee3b6">
        <source>cnwdad1_SetFont() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2006 by cnwdad1
//
// Purpose:     Sets the default font on all instances of the Application class for
//				apps that are in JSSCoreSchema and below.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	applicationObj	: Application;
	schemaObj		: Schema;

begin
	foreach applicationObj in Application.instances do
		schemaObj	:=	applicationObj.getPropertyValue(Application::schema.name).Schema;
		
		if schemaObj = currentSchema or schemaObj.jssIsSubschemaOf(currentSchema) then
			write applicationObj.name &amp; Tab &amp; applicationObj.getPropertyValue(Application::schema.name).Schema.name;
			beginTransaction;
			applicationObj.fontName	:=	'Verdana';
			commitTransaction;
		endif;	

	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_TestMessageLog" id="6074f0da-192b-4a9a-824b-259e02dae0a3">
        <source>cnwdad1_TestMessageLog();
// --------------------------------------------------------------------------------
// Created:		22 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.writeLog("This is a log message test by Darrell.", false);
	app.writeLog("This is another log message test by Darrell.", false);
	app.writeLog("This is yet another log message test by Darrell.", false);
end;</source>
    </JadeMethod>
    <JadeMethod name="purgeProcessObjectDict" id="2a1b2004-044f-4a20-9214-de03d1c4d2e8">
        <source>purgeProcessObjectDict();
/*
*/
begin
	beginTransaction;
	JSSProcessObjectDict.firstInstance.purge;
	delete JSSProcessObjectDict.firstInstance;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="test1" id="f03864d6-11f8-47f0-a05e-6b3eeb8a849c">
        <source>test1() protected;
// --------------------------------------------------------------------------------
// Created:		08 October 2004 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars
	s: Schema;
	c: Class;
	st: String;
begin
//	self.test2();

	s := rootSchema.getSchema("JSSCoreSchema");
	
	c := s.getClass("System");
	
	st := sendMsg("jssGetCPUInfo()").String;

	write st;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="test2" id="e152966e-775c-4530-bfe4-e98c47462075">
        <source>test2() protected;
// --------------------------------------------------------------------------------
// Created:		08 October 2004 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	o	: Object;
	p	: Node;
	p2	: Node;
	
begin
	on Exception do self.testEx(exception, o);
	
	create p transient;
	p2	:=	p;
	delete p;
	
	write p2.name;
	
	write "Exception has returned.";
epilog
	delete p;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="testEx" id="f4a624ae-5ef9-4e9f-a2cf-16b58dd6c672">
        <source>testEx(pException : Exception; pTheObject : Object io) : Integer;

begin
	write pException.errorCode.String;
	
	if pException.errorCode = 4 then
		pTheObject := null;
//self.monitor("$$$$$$$$$$ Exception 1266 has been ignored");
		return( Ex_Resume_Next );
	endif;
	
	return( Ex_Pass_Back );
end;</source>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pTheObject" type="Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
