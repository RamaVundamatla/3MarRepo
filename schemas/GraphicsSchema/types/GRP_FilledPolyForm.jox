<GUIClass name="GRP_FilledPolyForm" id="20e7907f-319e-4b2d-8149-b4f2f38db6aa">
    <superclass name="CnForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="button1" id="8036dd3b-9a8e-4d0f-a8e0-8a0f64f148f7">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frmTop" id="d1d5fce3-3ea3-46d6-9aa1-affb5ee3c191">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <CompAttribute name="polly" id="3b3b9848-babc-4a1d-80fe-57c28359ff33">
        <type name="RealArray"/>
        <access>protected</access>
    </CompAttribute>
    <JadeMethod name="button1_click" id="b6ae4b27-7984-41bc-86e8-2a7338947497">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY, x,y : Integer;
begin
	self.frmTop.clearGraphics();
	self.frmTop.drawWidth := 1;


	self.frmTop.drawFillColor := White;
	
//	self.frmTop.drawFillColor := Blue;

	foreach y in 1 to 5 do
		tmpY := tmpY + 72;
		tmpX := 0;
		foreach x in 1 to 6 do
			tmpX := tmpX + 72;
			
			self.drawPoly(tmpX,tmpY);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawPoly" id="62d0399b-3b37-4a39-ba6b-0cef7a3a66af">
        <source>drawPoly(_offsetX, _offsetY : Integer);
// ---------------------------------------------------------------------------
// Created:		10 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1,x2,y1,y2,idx : Integer;
begin

	foreach idx in 1 to self.polly.size do
		if idx mod 2 = 0 then
			self.polly[idx]  := self.polly[idx] + _offsetY;
			if y1 = 0 then
				y1 := self.polly[idx].Integer;
			endif;
			y2 := y2.max(self.polly[idx].Integer);
			
		else
			self.polly[idx]  := self.polly[idx] + _offsetX;
			if x1 = 0 then
				x1 := self.polly[idx].Integer;
			endif;
			x2 := x2.max(self.polly[idx].Integer);
		endif;
	endforeach;

	self.frmTop.autoRedraw := true;
	self.frmTop.backColor := White;
	
	self.frmTop.drawStyle := Frame.DrawStyle_Dash;
	self.frmTop.drawLine(10,10,300,10,Red);
	self.frmTop.drawStyle := Frame.DrawStyle_DashDot;
	self.frmTop.drawLine(10,20,300,20,Red);
	self.frmTop.drawStyle := Frame.DrawStyle_DashDotDot;
	self.frmTop.drawLine(10,30,300,30,Red);
	self.frmTop.drawStyle := Frame.DrawStyle_Dot;
	self.frmTop.drawLine(10,40,300,40,Red);
	self.frmTop.drawStyle := Frame.DrawStyle_Solid;
	self.frmTop.drawLine(10,60,300,60,Red);
	
	self.frmTop.drawFillColor := White;
	self.frmTop.drawFilledRectangle(x1- 10,y1 - 10,x2 + 10,y2 + 10,Black);
	
	self.frmTop.drawFillColor := Red;
	self.frmTop.drawFilledPolygon(self.polly,Red);

	foreach idx in 1 to self.polly.size do
		if idx mod 2 = 0 then
			self.polly[idx]  := self.polly[idx] - _offsetY;
		else
			self.polly[idx]  := self.polly[idx] - _offsetX;
		endif;
	endforeach;

epilog
end;</source>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="323216a3-4ba7-44dc-926c-edc71b156fe7">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:		10 July 1006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rArray : RealArray;
begin
	self.frmTop.autoRedraw := true;

	rArray := self.polly;
	rArray.add(50);
	rArray.add(50);

	rArray.add(100);
	rArray.add(50);
	
	rArray.add(100);
	rArray.add(100);

	rArray.add(50);
	rArray.add(100);
//	rArray.add(50);
//	rArray.add(50);

end;</source>
    </JadeMethod>
</GUIClass>
