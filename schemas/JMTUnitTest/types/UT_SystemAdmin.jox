    <JadeMethod name="tWeightRange" id="e7c8e246-822b-454a-bf75-79b079dbf267">
        <source>tWeightRange();

/*

Purpose:		

Date			Who		Reason
22 June 2015	cnwmh5	Initial creation

*/

vars

	pxyWeightRange					: CM_WeightRange;
	weightRange						: CM_WeightRange;
	mesType							: CM_MeasurementType;

begin

	self.deleteMeasurementType("UTMWeightZ");
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTMWeightZ", Type_Weight, "UT MDH Weight UnitsZ");
	
	weightRange := app.myRoot.allWeightRanges[mesType, 21];
	if weightRange &lt;&gt; null then
		app.myTrxDA.trxDeleteWeightRange(weightRange, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyWeightRange transient;
	pxyWeightRange.setProxy(0, 21, 99, 0, mesType);
	
	app.myTrxCA.trxCreateWeightRange(pxyWeightRange, weightRange, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyWeightRange;
	beginLoad;
	pxyWeightRange := weightRange.pxyCreateUpdateProxy();
	pxyWeightRange.setMyMeasurementType(weightRange.myMeasurementType);
	endLoad;
	
	pxyWeightRange.setPropertyValue('colour', 2763519);
	app.myTrxUA.trxUpdateWeightRange(pxyWeightRange, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(weightRange.colour, 2763519);

epilog

	delete pxyWeightRange;

end;</source>
    </JadeMethod>
    <JadeMethod name="uSFTPEntity_35646" id="383bb12f-a777-451a-bbbe-491cc7ff6ef3">
