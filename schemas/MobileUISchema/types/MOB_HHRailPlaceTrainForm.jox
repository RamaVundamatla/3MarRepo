    <JadeMethod name="clickBtnBack" id="d5e5428b-c267-43c6-b5dc-d7ac0765de45">
        <updating/>
        <source>clickBtnBack() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	app.mousePointer :=	Busy;
	
	self.myMobileGenericAgent.setMyCurrentRailLine( null  );

	app.mousePointer :=	Busy;
	self.goBackToFirst( MOB_HHRailPlaceIOForm );
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnNext" id="fdf91d6f-69d4-4ddc-830f-d379a0ea4e5c">
        <updating/>
        <source>clickBtnNext() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	train : CM_Train;
	railLine : CM_RailLine;
	errorMess : String;
	
	
begin

	app.mousePointer :=	Busy;

	train := cmbTrain.listObject.CM_Train;
	if train = null then
		app.mousePointer :=	Idle;
		errorMess := app.getErrorString(Please_select_train);
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	railLine := lstRailRake.listObject.CM_RailLine;
	if railLine = null then
		app.mousePointer :=	Idle;
		errorMess := app.getErrorString(Please_select_rail_rake_view);
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	if not optForward.value and not optReversed.value then
		app.mousePointer :=	Idle;
		errorMess := app.getErrorString(Please_select_forward_reverse);
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;

	self.myMobileGenericAgent.setMyCurrentTrain( train );
	self.myMobileGenericAgent.setMyCurrentRailLine( railLine  );
	self.myMobileGenericAgent.setForward( optForward.value );
	
	if self.myMobileGenericAgent.inward then
		self.gotoForm( MOB_HHRailPlaceWagonIn, false );
	else
		self.gotoForm( MOB_HHRailPlaceWagonOut, false );
	endif;
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="1d242eb2-1fb3-4760-ba5e-edbc5ed8e1a1">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	str : String;
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	left : Real;
	height : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	if _initialSetup then
		if self.myMobileGenericAgent.inward then
			str := app.getErrorString(Inward_train);
		else
			str := app.getErrorString(Outward_train);
		endif;
		
		self.caption := str;
	endif;

	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.cmbTrain.setAndIncrementTabIndex( tabIndex );
		self.cmbTrain.visible := true;
	endif;
	self.cmbTrain.move(	stdLeft,
						top,
						stdWidth,
						stdHeight );
						
	if _initialSetup then
		self.populateTrains();
	endif;
	
	left := self.clientWidth / 3;
	width := self.clientWidth / 2;
	top := cmbTrain.top + cmbTrain.height + self.resizedMargin;
	if _initialSetup then
		self.lblRailRake.setAndIncrementTabIndex( tabIndex );
		self.lblRailRake.visible := true;
	endif;
	self.lblRailRake.move(	stdLeft,
							top,
							width,
							stdHeight );
	
	top := top + 8;
	// total form height - height of button area at bottom - height above already used - room for to opt buttons below - 10 for good luck + offset.
	//height := ( self.height - self.getCMDHeight() - top - ( stdHeight * 2 ) - ( margin * 2 ) - 10 ) +  self.getSessionAgent().deviceHeightOffset;
	// 27011 04/2011 last option button was hidden under Next and Back buttons
	height := ( self.clientHeight - self.getCMDHeight() - top - ( stdHeight * 2 ) - ( self.resizedMargin * 2 ) - 5 ) +  self.getSessionAgent().deviceHeightOffset;
	if _initialSetup then
		self.lstRailRake.setAndIncrementTabIndex( tabIndex );
		self.lstRailRake.visible := true;
	endif;
	self.lstRailRake.move(	left,
							top,
							width,
							height );
						
	if _initialSetup then
		self.populateRailLines();
	endif;
	
	top := lstRailRake.top + lstRailRake.height + ( stdHeight / 2 );
	if _initialSetup then
		self.optForward.setAndIncrementTabIndex( tabIndex );
		self.optForward.visible := true;
	endif;
	self.optForward.move(	left,
							top,
							stdWidth,
							stdHeight );
							
	if _initialSetup then
		self.optForward.value := self.myMobileGenericAgent.forward;
	endif;
						
	top := optForward.top + optForward.height + self.resizedMargin;
	if _initialSetup then
		self.optReversed.setAndIncrementTabIndex( tabIndex );
		self.optReversed.visible := true;
	endif;
	self.optReversed.move(	left,
							top,
							stdWidth,
							stdHeight );
							
	top := optReversed.top + optReversed.height + self.resizedMargin;
	if _initialSetup then
		self.chkAutoPlan.setAndIncrementTabIndex( tabIndex );
		self.chkAutoPlan.visible := true;
	endif;
	self.chkAutoPlan.move(	left,
							top,
							stdWidth,
							stdHeight );

							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="cb0027e3-6706-40c9-8dc2-85b9b59cb09b">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	return app.getErrorString(RAILHHHELP_TRN001) &amp; CrLf &amp; CrLf &amp;
			//Choose a train, a rail rake and the direction that you are walking the rake and press Next.
			app.getErrorString(RAILHHHELP_TRN003) &amp; CrLf &amp; CrLf &amp;
			//Forward works lowest numerical rake position to highest, Reversed starts from highest position. 
			app.getErrorString(RAILHHHELP_TRN002);
			//Press Back to end current session.
			
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
