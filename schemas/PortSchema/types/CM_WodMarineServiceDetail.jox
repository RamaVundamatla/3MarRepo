    <JadeMethod name="createPxyHMSResourceProforma" id="67db5ae2-8acd-471a-986b-81d8c00c1b4a">
        <source>createPxyHMSResourceProforma(_movement : HMS_VoyageMovement input) : HMS_ResourceUsed;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgab1	Initial creation

*/

vars
	pxyResUsed : HMS_ResourceUsed;
	resourceType 	: HMS_ResourceType;
	unitsUsed : Real;	//28 Feb 2019	NDL	TFS 43577
begin
		if _movement= null then
			return null;
		endif;
		
		if self.myHMSResource = null then
			return null;
		endif;
		
		//28 Feb 2019	NDL	TFS 43577
		unitsUsed := self.unitsUsed;
		if unitsUsed = 0 then
			unitsUsed := 1;
		endif;
		
		create pxyResUsed transient;
		pxyResUsed.setProxy(_movement.myHarbour,resourceType,self.myHMSResource,
							null, self.fromDateTime, self.toDateTime, unitsUsed, false,	//_poc : Boolean;
							self,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
							self.myDebtor	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
							);
		pxyResUsed.setMyVoyageMovement(_movement);
	
	return pxyResUsed;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="doMarineServiceTimingsUpdate" id="173c78cf-0da4-463c-9a76-225909568a6c">
        <source>doMarineServiceTimingsUpdate(_arrival, _requestedDT, _approvedDT, _actualDT : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/06/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
// 02/10/2019   cnwma1		Bug 46853: PEL1 - (TOP URGENT) Pindah| Caught exception:
//
vars
	voyage : CM_Voyage;
	movement, move : HMS_VoyageMovement;
	timings, pxyTimings : HMS_MarineServicesTimings;
	dateFromForUpdate, dateToForUpdate : TimeStamp;
	resource : HMS_Resource;
	hmsObj : HMS_ResourceForObject;

begin

	//20 Sep 2018	NDL	TFS 39741
	resource := self.myHMSResource;
	hmsObj := resource.allHMSObjectsWithResources.first;
	if _arrival then
		if not hmsObj.myArrivalResource = resource then
			return;
		endif;
	elseif self.myShiftMovement &lt;&gt; null then
		if not hmsObj.myShiftResource = resource then
			return;
		endif;
	else
		if not hmsObj.myDepartResource = resource then
			return;
		endif;
	endif;

	if _arrival then
		// get arrival movement
		voyage := self.myMarineServiceInitial.getMyVoyageObject;
		movement := voyage.getMovementArrival();
	elseif self.myShiftMovement &lt;&gt; null then
		voyage := self.myShiftMovement.getMyVoyageObject;
		foreach move in voyage.myHMSVoyageData.allVoyageMovements do
			if move.occursOnDTNEW = self.myShiftMovement.occursOnDT then
				movement := move;
				break;
			endif;
		endforeach;
	else
		// get departure movement
		if self.myMarineServiceDepart &lt;&gt;  null then                  //02.10.2019 cnwma1 #46853
			voyage := self.myMarineServiceDepart.getMyVoyageObject;
			if voyage &lt;&gt; null then                                  
				movement := voyage.getMovementDeparture();
			endif;
		endif;
	endif;
	if movement = null then
		return;
	endif;
	
	timings := movement.myMarineServiceTimings;
	if timings = null then
		create timings persistent;
		create pxyTimings transient;
		timings.setMyVoyageMovement(movement);
	else
		pxyTimings := app.createUpdateProxy(timings).HMS_MarineServicesTimings;
	endif;
	
	// update the timings
	dateFromForUpdate := self.fromDateTime;
	dateToForUpdate := self.toDateTime;
	// when we update the requested date/time, we need to check for an original date/time and use that instead
	if _requestedDT then
		if self.originalFromDateTime.isValid then
			dateFromForUpdate := self.originalFromDateTime;
		endif;
		if self.originalToDateTime.isValid then
			dateToForUpdate := self.originalToDateTime;
		endif;
	endif;
	if self.myHMSResource.isResourceForClass(HMS_ResourceForPilot) then
		pxyTimings.setPilotDateTimes(dateFromForUpdate, _requestedDT, _approvedDT, _actualDT);
	elseif self.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
		pxyTimings.setTugFromToDateTimes(dateFromForUpdate, dateToForUpdate, _requestedDT, _approvedDT, _actualDT);
	endif;
	
	timings.setForUpdate(pxyTimings, app.myPassport);
epilog
	delete pxyTimings;
end;</source>
        <Parameter name="_arrival" type="Boolean"/>
        <Parameter name="_requestedDT" type="Boolean"/>
        <Parameter name="_approvedDT" type="Boolean"/>
        <Parameter name="_actualDT" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBerthForPaymentType" id="04cdfd27-d28b-4ed7-a33e-dfb8c49fbab9">
        <source>getBerthForPaymentType(): HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

begin
	if self.myMarineServiceDepart &lt;&gt; null then
		return self.myMarineServiceDepart.getBerthForPaymentType;
	elseif self.myMarineServiceInitial &lt;&gt; null then
		return self.myMarineServiceInitial.getBerthForPaymentType;
	elseif self.myShiftMovement &lt;&gt; null then
		return self.myShiftMovement.getBerthForPaymentType;
	elseif self.myExtension &lt;&gt; null then	//19 Feb 2019	NDL	TFS 43374
		return self.myExtension.getMyBerth;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getCalcResourceDaysEnd" id="6b90fa9d-51dd-4203-879e-7c39f2feff10">
        <source>getCalcResourceDaysEnd() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2019	jlger1	Initial creation 43374
25 Mar 2019 jlger1	Issues with not working with IMSR and DMSR 
*/

vars
	lengthOfTime : Decimal[12,2];
	startTS : TimeStamp;
	voyage  : CM_Voyage;
	 departMovement : HMS_VoyageMovement;
begin
	if self.myExtension &lt;&gt; null then
		if  app.isInProformaMode then
			return self.myExtension.occursOnDT;
		else
			voyage:= self.myExtension.getMyVoyageObject;
			//43374
			if voyage &lt;&gt; null then
				departMovement:=voyage.getMovementDeparture;
				if departMovement.moveStatus = MovementStatus_Actual then
					return voyage.departedDT;
				endif;
			endif;
		endif; 
	elseif self.myShiftMovement &lt;&gt; null then
		
		return self.myShiftMovement.getNewDepartureTS;
		
	elseif self.myMarineServiceInitial &lt;&gt; null then
		
		lengthOfTime:= self.myMarineServiceInitial.getCurrentLengthOfTime;
		startTS := self.getCalcResourceDaysStart;
		if startTS.isValid then
			return startTS + lengthOfTime.daysAsTimeStampInterval();
		endif;
	elseif self.myMarineServiceDepart &lt;&gt; null then
		return self.myMarineServiceDepart.getOccursDT;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCalcResourceDaysStart" id="ff066df2-ce50-44f6-908a-b45c698930a9">
        <source>getCalcResourceDaysStart() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlger1	Initial creation
25 Mar 2019 jlger1	Issues with not working with IMSR and DMSR
*/

vars
	startTS : TimeStamp;
	voyage : CM_Voyage;
	departMovement : HMS_VoyageMovement;
	iter : Iterator;
	resUsed : HMS_ResourceUsed;
	calcType : CM_CalculationType;
begin
	startTS:=null;
	voyage:= self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		departMovement:=voyage.getMovementDeparture;
	endif;
	if self.myExtension &lt;&gt; null then
		if  app.isInProformaMode then
			startTS:=self.myExtension.oldDepartureDT;
			if not startTS.isValid() then // if its proforma (i.e. pre-actioning) use the real voyages departure movement
				startTS := self.getMyVoyageObject.getDepartureDT;
			endif;
		else	
			//43374

			if departMovement &lt;&gt; null and departMovement.myPreviousMovement &lt;&gt; null then
				startTS:= departMovement.myPreviousMovement.occursOnDTNEW;
			endif;
		
		endif;
	elseif self.myShiftMovement &lt;&gt; null then
		startTS:= self.myShiftMovement.occursOnDT;

	elseif self.myMarineServiceInitial &lt;&gt; null then
		startTS:= self.myMarineServiceInitial.getOccursDT;
	elseif self.myMarineServiceDepart &lt;&gt; null then
		voyage:= self.myMarineServiceDepart.getMyVoyageObject;
		if voyage &lt;&gt; null then
			startTS:= voyage.arrivedDT;
		endif;
	endif;

	return startTS;
epilog
	delete iter;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="a66c5480-bae7-4529-b8f7-1db638598ff5">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	if _useShortDesc then
		return app.getErrorString(Voyage_marine_service);
	else
		return "(" &amp; self.taskID.String &amp; ") " &amp; app.getErrorString(Voyage_marine_service);
	endif;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
