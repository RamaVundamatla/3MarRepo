        <updating/>
        <source>setAutoResequenceJobs(_value: Boolean) updating;
//10 February 2011	cnwdw1	
//
vars

begin
	self.autoResequenceJobs := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="6cfb479b-ebad-4430-ba68-db7c2ce1c673">
        <updating/>
        <source>setDetails(	_taskViewMode,
			_defaultTaskViewMode  : Integer;
			_automaticGetNextTask : Boolean;
			_allowEnquiry,
			_allowNonRTMoves,
			_useSeperatePickupSetdown,
			_allowChangeSetdown,
			_allowChangeQueue,
			_autoResequence: Boolean;
			_overstowMoveMode : Integer;
			_highlightHeight : Integer;
			_ignoreWarnings : Boolean;
			_limitEnquiryToCurrentQ : Boolean;
			_maxNumberOverstowForDriver : Integer;
			_maxNumberQueryResults : Integer;
			_maxNumberQueueEntries : Integer;
			_maxNumberSearchResults : Integer;
			_allAvailableGraphicViews :IntegerArray;
			_defaultGraphicView : Integer;
			_columnLabelsPlacement : Integer;
			_rowLabelsPlacement : Integer;
			_myQueriesForDrivers :  CM_SelectorQueryAccess;
			_myNightScreenConfig : CM_RTScreenConfig;
			_myDayScreenConfig : CM_RTScreenConfig;
			_fontSize,
			_selectedFontSize : Integer;
			_myVisibleCargoFields,
			_myVisibleDirectorFields,
			_myVisibleTaskFields  : EntTableView input;
			_showSecondaryQueues,
			_useDetailsViewForPickup,
			_useDetailsViewForSetdown,
			_displayAcceptOnLeft  : Boolean;
			_removeSplitScreen 	: Boolean;
			_locationHookCode:String;
			_isoHookCode:String;
			_doorDirHookCode:String;
			_acceptTimerInterval,
			_picupTimerInterval  	  :Integer;
			_autoSearchDirector 	  : Boolean;		  //10 Nov 2017	NDL	TFS 7427
			_allowTandemToDiffTargets : Boolean;		  // 20/11/19 MAP TFS47394
			_allowDriverQueuedMoves   : Boolean;		  // TFS 51409
			_warnQueuedSetdown 		  : Boolean;		  // TFS 51409
			_allowDriverMultiMove     : Boolean;           //01.09.2021 navma1 #51485
			_retainCargoIdDriverMode : Boolean;			// ### JIRA: MTN-34259 18Mar2025 NAVPW1
			_doSwapChangeCargo : Boolean				//29/10/2025	navkc1 JIRA 36186
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwer1	Initial creation
14 Feb 2014 cnwer1	PAR 33425
01 Jul 2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
01 Sep 2021 navma1  ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
18 Mar 2025	navpw1	JIRA: MTN-34259 - Added a config option to be set on a vehicle basis to Retain Cargo Id in Driver Mode for Overstowed containers
//29/10/2025	navkc1 JIRA 36186 PNL | Vehicle App Swap behaviour with Release Requests - DB Changes / Jade / Form
*/

vars

begin
	self.allowNonRTMoves:=_allowNonRTMoves;
	self.allowCargoSearch:=_allowEnquiry;
	self.useSeperatePickupSetdown:=_useSeperatePickupSetdown;
	self.allowChangeSetdown:=_allowChangeSetdown;
	self.allowChangeQueue:=_allowChangeQueue;
	self.autoResequenceJobs:=_autoResequence;
	self.overstowMoveMode:=_overstowMoveMode;
	
	self.autoSearchDirector := _autoSearchDirector;	//10 Nov 2017	NDL	TFS 7427
	
	self.acceptTimerInterval:=_acceptTimerInterval;
	self.pickupTimerInterval:=_picupTimerInterval;
	
	self.highlightHight := _highlightHeight;//07/03/2011 cnwdz2 25644
	
	self.ignoreWarnings:=_ignoreWarnings;
	self.limitEnquiryToCurrentQ:=_limitEnquiryToCurrentQ;
	self.showSecondaryQueues:=_showSecondaryQueues;
	
	self.defaultGraphicView:=_defaultGraphicView;
	//09/11/2010 cnwdz2 26196
	self.columnLabelsPlacement := _columnLabelsPlacement;
	self.rowLabelsPlacement := _rowLabelsPlacement;
	self.tableFontSize:=_fontSize;
	self.tableSelectedFontSize:=_selectedFontSize;
	
	self.taskViewMode:=_taskViewMode;
	self.defaultTaskViewMode:= _defaultTaskViewMode;
	self.automaticGetNextTask:=_automaticGetNextTask;
	
	self.maxNumberOverstowForDriver:=_maxNumberOverstowForDriver;
	self.maxNumberQueryResults:=_maxNumberQueryResults;
	self.maxNumberQueueEntries:=_maxNumberQueueEntries;
	self.maxNumberSearchResults:=_maxNumberSearchResults;

	self.allAvailableGraphicViews.clear;
	_allAvailableGraphicViews.copy(self.allAvailableGraphicViews);

	self.myQueriesForDrivers:= _myQueriesForDrivers;
	self.myNightScreenConfig := _myNightScreenConfig;
	self.myDayScreenConfig:= _myDayScreenConfig;
	
	self.myVisibleCargoFields:=_myVisibleCargoFields;
	self.myVisibleTaskFields:=_myVisibleTaskFields;
	self.myVisibleDirectorFields:=_myVisibleDirectorFields;
	
	self.useDetailsViewForPickup := _useDetailsViewForPickup; 		//+ cnwmd1 Par 25509
	self.useDetailsViewForSetdown := _useDetailsViewForSetdown;		//+ cnwmd1 Par 25509
	self.allowTandemToDiffTargets := _allowTandemToDiffTargets;		// 21/11/19 MAP TFS47394
	self.doSwapChangeCargo := _doSwapChangeCargo; //29/10/2025	navkc1 JIRA 36186
	
	self.displayAcceptOnLeftHandSide := _displayAcceptOnLeft;  //cnwjo3 par 26026
	self.removeSplitScreen:=_removeSplitScreen;
	
	self.allowChangeQSetdown	:= _warnQueuedSetdown;			// TFS 51409
	self.allowNonRTQMoves 		:= _allowDriverQueuedMoves;		// TFS 51409
	self.allowDriverMultiMoves	:= _allowDriverMultiMove;       //01.09.2021 navma1 #51485
	self.retainCargoIdDriverMode := _retainCargoIdDriverMode;	// ### JIRA: MTN-34259 18Mar2025 NAVPW1
	
	if self.myTerminal &lt;&gt; null then
		if self.myLocationHookCode = null then
			create self.myLocationHookCode transient;
		endif;
		self.myLocationHookCode.setForProxy(self.getUniqueViewName, app.myRoot.allHookTypes[HookType_RTConfigLocation]);
		self.myLocationHookCode.setJadeCodeForProxy(_locationHookCode, app.myPassport.userCode);
		self.myLocationHookCode.createProxyHookLinkForParent(HookType_RTConfigLocation, self.myTerminal);
		
		if self.myDoorDirectionHookCode = null then
			create self.myDoorDirectionHookCode transient;
		endif;
		self.myDoorDirectionHookCode.setForProxy(self.getUniqueViewName, app.myRoot.allHookTypes[HookType_RTConfigDoorDir]);
		self.myDoorDirectionHookCode.setJadeCodeForProxy(_doorDirHookCode, app.myPassport.userCode);
		self.myDoorDirectionHookCode.createProxyHookLinkForParent(HookType_RTConfigDoorDir, self.myTerminal);
		
		if self.myIsoTypeHookCode = null then
			create self.myIsoTypeHookCode transient;
		endif;
		self.myIsoTypeHookCode.setForProxy(self.getUniqueViewName, app.myRoot.allHookTypes[HookType_RTConfigIsoType]);
		self.myIsoTypeHookCode.setJadeCodeForProxy(_isoHookCode, app.myPassport.userCode);
		self.myIsoTypeHookCode.createProxyHookLinkForParent(HookType_RTConfigIsoType, self.myTerminal);
	endif;
epilog

end;</source>
        <Parameter name="_taskViewMode" type="Integer"/>
        <Parameter name="_defaultTaskViewMode" type="Integer"/>
        <Parameter name="_automaticGetNextTask" type="Boolean"/>
        <Parameter name="_allowEnquiry" type="Boolean"/>
        <Parameter name="_allowNonRTMoves" type="Boolean"/>
        <Parameter name="_useSeperatePickupSetdown" type="Boolean"/>
        <Parameter name="_allowChangeSetdown" type="Boolean"/>
        <Parameter name="_allowChangeQueue" type="Boolean"/>
