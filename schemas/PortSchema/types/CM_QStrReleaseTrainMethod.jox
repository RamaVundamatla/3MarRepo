    <JadeMethod name="setComboValues" id="ad4e2690-7938-4fe0-823e-ddc6428ba535">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

constants
	Max_Entries = 200;
vars
	count			: Integer;
	trainCode,
	queryTrainCode	: String;
	qrl				: CM_QReferenceLookup;
	trainDict		: CM_TrainByDepatureDTDict;
	currentTrain,
	train			: CM_Train;
	tmpTerm 		: CM_Terminal;
begin

	_combo.clear;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	if _queryOperator.isKindOf(CM_QStringLookup) then
		queryTrainCode := _queryOperator.CM_QStringLookup.selectionValue;
	elseif _queryOperator.isKindOf(CM_QStringLookupNotEqual) then
		queryTrainCode := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	create trainDict transient;
	foreach train in tmpTerm.allTrainsOnTerminal do
		if train.isNullTrain() then
			continue;
		endif;
		trainDict.add(train);
	endforeach;
	foreach train in tmpTerm.allTrainsDepartedReversed do
		if train.isNullTrain() then
			continue;
		endif;
		// don't show older trains past an arbitrary limit
		count := count + 1;
		if count &gt; Max_Entries then
			break;
		endif;
		trainDict.add(train);
	endforeach;
	
	foreach train in trainDict do
		trainCode := train.getCodeDate();
		_combo.itemObject[_combo.addItem(trainCode)] := train;
		if trainCode = queryTrainCode then
			currentTrain := train;
		endif;
	endforeach;
	_combo.listObject := currentTrain;
	
epilog
	delete trainDict;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1b7d5553-a603-4b05-a9f4-9b615610a06b">
        <source>translateToDisplayValue(_value: Any): String;

vars

begin
	if _value.isKindOf (CM_Train) then	
		if _value &lt;&gt; null then
			return _value.CM_Train.getCodeDate();
		else
			return null;
		endif;
	endif;
	
	return _value.String;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="f2436721-6b9b-4fd9-9d82-6e025297ec95">
        <source>translateToSearchValue(_value: Any): Any;

vars
	invalidObj 		: Boolean;
	object			: CM_Train;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_Train) then
			object := _value.CM_Train;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getCodeDate();
	endif;
	
	return returnVal;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="9519f011-a8c0-4a47-a7a6-fd874326dbf3">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT web Portal selector query parameters
//
vars
	pos : Integer;

begin
	if _value.isKindOf(CM_Train) then
		return _value.CM_Train.getCodeDate;
		
	elseif _value.isKindOf(String) then
		pos := _value.String.pos(Space, 1);
		if pos &lt;&gt; null then
			return _value.String[1:pos-1];
		else
			return _value.String;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
