    <JadeMethod name="create" id="06e6f638-df07-4d3f-a00c-24c9608a7be1">
        <updating/>
        <source>create() updating;

vars

begin

	self.myAS400Root := CM_AS400Root.firstInstance;
	if self.myAS400Root = null then
		// This is OK as this is a temporary method for loading initial data
		beginTransaction;
		create self.myAS400Root persistent;
		commitTransaction;
	endif;
	
	// Set up dyna dict for sorting of locations.
	self.allLocations.setMembership(CM_AS400Log);
	self.allLocations.addMemberKey("block", false, false);
	self.allLocations.addMemberKey("row", false, false);
	self.allLocations.addMemberKey("subRow", false, false);
	self.allLocations.endKeys(false);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="createBatNumbers" id="9d742331-1f7e-4697-9b49-e2a2362b2127">
        <updating/>
        <source>createBatNumbers(_fileLoad : CM_AS400FileLoad; _terminal : CM_Terminal) protected, updating;

vars
	batNumber	: CM_BatNumber;
	count		: Integer;
	idx,
	needed, 
	startFrom	: Integer;
	prefix,
	newCode		: String;
	term		: CM_Terminal;
	
begin

	// BAT NUMBERS ARE GOING TO BE REWORKED SO THIS IS ONLY A
	// TEMPORARY SOLUTION.

	term := _terminal;
	
	startFrom := term.batNumbers.size + 1;
	needed := _fileLoad.allDockets.size;
	needed := (needed * 1.2).Integer;		// add 20% as a fudge
	// Temporary method until bat numbers are revisited.
	beginTransaction;
	idx := startFrom;
	foreach count in startFrom to needed do
		idx := idx + 1;
		newCode := prefix &amp; idx.String;
		if newCode.length &gt; 4 then
			idx := 0;
			if prefix = null then
				prefix := 'A';
			elseif prefix = 'Z' then
				prefix := 'AA';
			elseif prefix = 'ZZ' then
				prefix := 'AAA';
			elseif prefix.length = 1 then
				prefix := (prefix[1].Character.Integer + 1).Character;
			elseif prefix.length = 2 then
				if prefix[2] = 'Z' then
					prefix := (prefix[1].Character.Integer + 1).Character &amp; 'A';
				else
					prefix[2] := (prefix[2].Character.Integer + 1).Character;
				endif;
			elseif prefix.length = 3 then
				if prefix = 'ZZZ' then
					app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to generate sufficient bat numbers (' &amp; needed.String &amp; ')');
					break;
				elseif prefix[2:end] = 'ZZ' then
					prefix := (prefix[1].Character.Integer + 1).Character &amp; 'AA';
				elseif prefix[3] = 'Z' then
					prefix := prefix[1] &amp; (prefix[2].Character.Integer + 1).Character &amp; 'A';
				else
					prefix[3] := (prefix[3].Character.Integer + 1).Character;
				endif;
			endif;
			newCode := prefix &amp; idx.String;
		endif;

		create batNumber persistent;
		batNumber.code := newCode;
		term.batNumbers.add(batNumber);
	endforeach;
	commitTransaction;

end;</source>
        <access>protected</access>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="createCarrier" id="614fbb32-8d54-4dff-bfe2-ded1711e8e1e">
        <source>createCarrier(_docket : CM_AS400Docket; _default : String; _carrier : CM_Carrier output) : Boolean protected;
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars

	proxyCarrier	: CM_Carrier;
	newCarrier		: CM_Carrier;
	carrier			: String;

begin

	// Get carrier name.
	carrier := _docket.carrier;
	if carrier = null then
		// We don't have a carrier on the docket. Do we have a default.
		if _default = null then
			return false;
		else
			carrier := _default;
		endif;
	endif;
	
	// Has this carrier been created.
	newCarrier := app.myRoot.allCarriers[carrier];
	if newCarrier = null then
		// We need to create new carrier.
		create proxyCarrier transient;
		//proxyCarrier.setProxy(carrier, carrier, null, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
		proxyCarrier.setProxy(carrier, carrier, null, false, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
 		app.myTrxCA.trxCreateCarrier(proxyCarrier, newCarrier, app.myPassport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating carrier (' &amp; carrier &amp; ')');
 			return false;
 		endif;
	endif;
	_carrier := newCarrier;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_default" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCodeGroupLogSpec" id="68e557ab-678e-449c-8995-963f05ba8148">
        <updating/>
        <source>createCodeGroupLogSpec(_code : String; _logSpec : CM_CodeGroup output) : Boolean protected, updating;

vars

	proxySpecs		: CM_CodeGroup;
	newLogSpecs 	: CM_CodeGroup;
	

begin

	newLogSpecs := app.myRoot.allCodeGroups[CodeGroup_LogSpecs, _code];
	if newLogSpecs = null then
		create proxySpecs as CM_CodeGroupLogSpecs transient;
				
		proxySpecs.setProxy( CodeGroup_LogSpecs, 
								_code,
								app.myRoot);
									
		app.myTrxCA.trxCreateCodeGroup(proxySpecs, newLogSpecs,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating code group log spec (' &amp; _code &amp; ')');
			return false;
		endif;
	endif;
	_logSpec := newLogSpecs;
	return true;
epilog
	delete proxySpecs;
end;</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <Parameter name="_logSpec" type="CM_CodeGroup" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCodeGroupSourceLocn" id="f2b6df8d-a9b1-41fe-83ad-9964156edc27">
        <updating/>
        <source>createCodeGroupSourceLocn(_codeGroup : CM_CodeGroup output) : Boolean protected, updating;

vars
	proxyCodeGroup,
	realCodeGroup 	: CM_CodeGroup;
	

begin

	realCodeGroup := app.myRoot.allCodeGroups.getAtKeyGeq(CodeGroup_SourceLocation, null);
	if realCodeGroup = null or realCodeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
		create proxyCodeGroup transient;
		proxyCodeGroup.setProxy(CodeGroup_SourceLocation, 'Source Locations', app.myRoot);
									
		app.myTrxCA.trxCreateCodeGroup(proxyCodeGroup, realCodeGroup,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating code group source locn');
			return false;
		endif;
	endif;
	_codeGroup := realCodeGroup;
	return true;
epilog
	delete proxyCodeGroup;
end;</source>
        <access>protected</access>
        <Parameter name="_codeGroup" type="CM_CodeGroup" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCompartment" id="ce914c3b-d515-4c3c-b455-f443f8c9553d">
        <source>createCompartment(_docket : CM_AS400Docket input; _compartment : CM_SourceSubLocation output; _forest : CM_SourceLocation ) : Boolean protected;

vars

	proxySubLocation	: CM_SourceSubLocation;
	compartment			: String;

begin

	if _forest = null then
		beginTransaction;
		_docket.setCompartment(null);
		commitTransaction;
		return true;
	endif;
	compartment := _docket.compartment;	
	if compartment = null then
		return true;
	endif;
	_compartment := _forest.allSubLocations[compartment].CM_SourceSubLocation;
	if _compartment = null then
		create proxySubLocation transient;
		proxySubLocation.setForProxy(compartment,
								     compartment,
								     false,
								     false,
								    _forest);
	
		app.myTrxCA.trxCreateSourceSubLocation(proxySubLocation, _compartment, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating compartment (' &amp; compartment &amp; ')');
			return false;
		endif;
	endif;
	return true;
epilog
	delete proxySubLocation;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket" usage="input"/>
        <Parameter name="_compartment" type="CM_SourceSubLocation" usage="output"/>
        <Parameter name="_forest" type="CM_SourceLocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDocket" id="941e9c9c-46c9-462d-a1d4-e4efa5df9748">
        <updating/>
        <source>createDocket(_tempDocket : CM_AS400Docket input) : Boolean protected, updating;

vars
	intFaceArray	: CMIF_TIObjectArray;
	intFaceCommon	: CMIF_InOutCommon;
	intFaceBOLIn	: CMIF_BOLIn;
	intFaceAttach	: CMIF_InOutAttachment;
	carrierCode		: String;
	terminal		: CM_Terminal;
	batNumber		: CM_BatNumber;
	vtaCode			: String;
	ta				: CM_TerminalArea;
	controller		: CM_LocationsController;
	operator		: CM_Operator;
	opTerm			: CM_OperatorTerminal;
	bol				: CM_BOL;
	theTime			: TimeStamp;
	tempLog			: CM_AS400Log;
	truck			: String;
	trailer			: String;
	logArea			: CM_LogArea;
	weighBridge,
	nightShift,
	backLoad,
	chhSupplier		: String;

begin

	on Exception do agtPassportExHandler(exception, app.myPassport);
	
	operator :=  app.myRoot.allOperators[_tempDocket.supplier];		
	if operator = null then
		app.raiseCMException1(AS400TransferError, 'Supplier code ' &amp; _tempDocket.supplier &amp; ' not set up for docket ' &amp; _tempDocket.docket , null, null);
		setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
		return false;
	endif;
	
	opTerm := operator.getOperatorTerminal(self.myCurrentTerminal, false);
	if opTerm = null then
		// A quick hack to create the operator/terminal if necessary
		beginTransaction;
		opTerm := operator.getOperatorTerminal(self.myCurrentTerminal, true);
		commitTransaction;
	endif;
	
	bol := opTerm.allBOLByTypeNumber.getAtKeyLeq(BOLType_Log, _tempDocket.docket, theTime).CM_BOL;
	// We don't want duplicates.
	if bol = null or bol.number &lt;&gt; _tempDocket.docket then
		if _tempDocket.carrier = null then
			if self.defaultCarrier &lt;&gt; null then
				carrierCode := self.defaultCarrier;
			else
				app.raiseCMException1(AS400TransferError, 'No carrier code supplier. Need to specify default carrier', null, null);
				setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
				return false;
			endif;
		else
			carrierCode := _tempDocket.carrier;
		endif;
	
		if _tempDocket.truck = null then
			if self.defaultVehicle &lt;&gt; null then
				truck := self.defaultVehicle;
			else
				app.raiseCMException1(AS400TransferError, 'No truck code supplier. Need to specify default truck' , null, null);
				setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
				return false;
			endif;
		else
			truck := _tempDocket.truck;
			trailer := _tempDocket.trailer;
		endif;	
		terminal := self.myCurrentTerminal;
		/*
		batNumber := terminal.getNextBatNumber();
		if batNumber = null then
			app.raiseCMException1(AS400TransferError, 'No bat code found' , null, null);
			setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
			return false;
		endif;
		*/
	
		foreach ta in terminal.allTerminalAreas where
				ta.type = TA_TYPE_ROAD_TRANS do
			vtaCode := ta.id;
			break;
		endforeach;
	
		if _tempDocket.allLogs.size &gt; 0 then
			tempLog := _tempDocket.allLogs.first;
			logArea := self.myCurrentTerminal.allTerminalAreas[tempLog.block].CM_LogArea;
			if logArea &lt;&gt; null then
				controller := logArea.allRowControllersById[tempLog.block &amp; tempLog.row &amp; tempLog.subRow];
			endif;
		endif;
		if controller = null then
			app.raiseCMException1(AS400TransferError, 'Location not set up for docket ' &amp; _tempDocket.docket , null, null);
			setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
			return false;
		endif;

		create intFaceArray transient;
		create intFaceCommon transient;
		intFaceCommon.carrierCode 		:= carrierCode;
		intFaceCommon.myTerminal 		:= terminal;
		intFaceCommon.autoComplete 		:= false;
		intFaceCommon.hasAttachments 	:= false;
		intFaceCommon.batNumber			:= null;	//batNumber.code;
		intFaceCommon.regNumber 		:= truck;
		intFaceCommon.roadTransAreaId 	:= vtaCode;
		
		create intFaceBOLIn transient;
		intFaceBOLIn.setMyInOutCommon(intFaceCommon);
		intFaceArray.add(intFaceBOLIn);
		intFaceBOLIn.bolNumber 			:= _tempDocket.docket;
		intFaceBOLIn.bolType 			:= BOLType_Log;
		intFaceBOLIn.carrierCode 		:= carrierCode;
		intFaceBOLIn.consignorCode 		:= null;
		intFaceBOLIn.myOperator			:= operator;
		intFaceBOLIn.myPlannedLocation 	:= controller;
		intFaceBOLIn.myTerminal 		:= terminal;
		intFaceBOLIn.numItems 			:= _tempDocket.allLogs.size;
		intFaceBOLIn.operatorCode 		:= operator.code;
		intFaceBOLIn.truckNumber	 	:= truck;
		intFaceBOLIn.trailerNumber 		:= trailer;
		intFaceBOLIn.transportMode 		:= TI_TRANSMODE_ROAD;
		intFaceBOLIn.fellDate 			:= _tempDocket.getFellDate;
		intFaceBOLIn.loggingOperation	:= _tempDocket.logOperation[1:10];
		intFaceBOLIn.jasScaled 			:= true;
		intFaceBOLIn.lengthRandom 		:= _tempDocket.length.asStringMeasurementJMT();
		intFaceBOLIn.logGradeCode 		:= _tempDocket.grade;
		intFaceBOLIn.logSpeciesCode 	:= _tempDocket.species;
		intFaceBOLIn.logTypeCode 		:= _tempDocket.type;
		intFaceBOLIn.numberOfLifts 		:= 1;
		intFaceBOLIn.percentScaled 		:= 100;
		intFaceBOLIn.ticketedAll 		:= true;
		intFaceBOLIn.logTreatmentCode 	:= null;
		intFaceBOLIn.forest				:= _tempDocket.forest;
		intFaceBOLIn.sourceLocation		:= _tempDocket.forest;
		intFaceBOLIn.compartment		:= _tempDocket.compartment;
		intFaceBOLIn.sourceSubLocation	:= _tempDocket.compartment;
		intFaceBOLIn.stand				:= _tempDocket.stand;
		intFaceBOLIn.sourceSubSubLocation:= _tempDocket.stand;
		intFaceBOLIn.weightGrossTonnes	:= _tempDocket.grossWeight;
		intFaceBOLIn.weightNetTonnes	:= _tempDocket.netWeight;
		intFaceBOLIn.weightTareTonnes	:= _tempDocket.tareWeight;
		intFaceBOLIn.remarks			:= _tempDocket.comments;
		if _tempDocket.supplier = 'CH' then
			if _tempDocket.buyer.length &gt;= 2 then
				weighBridge := _tempDocket.buyer[1:2];
				intFaceBOLIn.weighbridge := weighBridge;
			endif;
			if _tempDocket.buyer.length &gt;= 3 then
				nightShift := _tempDocket.buyer[3:1];
				intFaceBOLIn.nightshift := (nightShift.toUpper = 'Y');
			endif;
			if _tempDocket.buyer.length &gt;= 4 then
				backLoad := _tempDocket.buyer[4:1];
				intFaceBOLIn.backload := backLoad;
			endif;
			if _tempDocket.comments.length &gt; 12 then
				intFaceBOLIn.remarks := _tempDocket.comments[1:12];
				intFaceBOLIn.chhSupplier := _tempDocket.comments[13:end];
			endif;
		endif;
		
		intFaceBOLIn.scalerCode				:= _tempDocket.scaler;
		if _tempDocket.logGang.isInteger then
			intFaceBOLIn.gangNumber				:= _tempDocket.logGang;
		endif;
		intFaceBOLIn.handlingContractor1	:= _tempDocket.logContractor;
		intFaceBOLIn.handlingContractor2	:= _tempDocket.loadContractor;
		intFaceBOLIn.loaderNumber			:= _tempDocket.loadLoader;
		
		//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, app.myPassport, null);  //TFS 53107, AjitM, navam1
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
			return false;
		endif;
		
		bol := opTerm.allBOLByTypeNumber.getAtKeyGeq(BOLType_Log, _tempDocket.docket, null).CM_BOL;
		// We don't want duplicates.
		if bol &lt;&gt; null and bol.number = _tempDocket.docket then
			app.myTrxUA.trxUpdateBolDateTime(bol, _tempDocket.getDateIn().TimeStamp, app.myPassport);
		endif;
			
		// Set road job reference.
		app.myTrxUA.trxUpdateAS400DocketRoadJob(_tempDocket, intFaceCommon.myRoadJob, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating docket (' &amp; _tempDocket.docket &amp; ') ' &amp; _tempDocket.String);
			return false;
		endif;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_tempDocket" type="CM_AS400Docket" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createForest" id="cfcd2187-455b-4dbb-a0c6-ebbd12fa3e97">
        <source>createForest(_docket : CM_AS400Docket; _forest : CM_SourceLocation output; _codeGroup : CM_CodeGroup ) : Boolean protected;

vars

	proxyLocation	: CM_SourceLocation;
	forest			: String;

begin

	forest := _docket.forest;	
	if forest = null then
		return true;
	endif;
	_forest := _codeGroup.allCodes[forest].CM_SourceLocation;
	if _forest = null then
		create proxyLocation transient;
		proxyLocation.setForProxy(forest,
								  forest,
								  false,
								  false,
								  _codeGroup);
	
		app.myTrxCA.trxCreateSourceLocation(proxyLocation, _forest, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating forest (' &amp; forest &amp; ')');
			return false;
		endif;
	endif;
	return true;
epilog
	delete proxyLocation;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_forest" type="CM_SourceLocation" usage="output"/>
        <Parameter name="_codeGroup" type="CM_CodeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createGrade" id="180a4888-dd8f-4d15-8302-e6cf868e0cb6">
        <source>createGrade(_docket : CM_AS400Docket; _species : CM_LogSpecies; _type : CM_LogType; _length : CM_LogLength; _grade : CM_LogGrade output) : Boolean protected;

vars

	grade		: String;
	proxyGrade	: CM_LogGrade;
	newGrade	: CM_LogGrade;
	doUpdate	: Boolean;
	cmObjSet	: CM_ObjectSet;
begin

	grade := _docket.grade;	
	if grade = null then
		return false;
	endif;

	create cmObjSet transient;
	lengthSet.clear;
	treatmentSet.clear;
	typeSet.clear;
		
	newGrade := _species.allLogGrades[grade].CM_LogGrade;
	if  newGrade = null then
		if _length &lt;&gt; null then
			lengthSet.add(_length);
		endif;
		if _type &lt;&gt; null then
			typeSet.add(_type);
		endif;
		create proxyGrade transient;
		lengthSet.copy(cmObjSet);
		proxyGrade.setProxy(grade,
							grade &amp; ' Grade',
							false,
							_species,
							cmObjSet,
							treatmentSet,
							typeSet,
							0,0,0,0,0);
		app.myTrxCA.trxCreateLogGrade(proxyGrade, newGrade,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating grade (' &amp; grade &amp; ')');
			return false;
		endif;
	else
		if _type &lt;&gt; null then
			if newGrade.allLogTypes[_type.code] = null then
				typeSet.add(_type);
				doUpdate := true;	
			endif;		
		endif;
		if _length &lt;&gt; null then
			if  newGrade.allLogLengths[_length.code] = null then
				lengthSet.add(_length);
				doUpdate := true;
			endif;
		endif;
		if doUpdate then
			newGrade.allLogTypes.copy(typeSet);
			newGrade.allLogLengths.copy(lengthSet);
			proxyGrade := app.createUpdateProxy(newGrade).CM_LogGrade;
			lengthSet.copy(cmObjSet);
			proxyGrade.setProxy(grade,
								grade &amp; ' Grade',
								false,
								_species,
								cmObjSet,
								treatmentSet,
								typeSet,
								0,0,0,0,0);
			app.myTrxUA.trxUpdateLogGrade(proxyGrade,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				setAllErrors('Updating grade (' &amp; grade &amp; ')');
				return false;
			endif;
		endif;
	endif;
	_grade := newGrade;
	return true;
	
epilog
	delete proxyGrade;
	delete cmObjSet;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_species" type="CM_LogSpecies"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_grade" type="CM_LogGrade" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLength" id="a182a912-ba20-4bcc-bb24-250eae4b64b8">
        <source>createLength(_docket : CM_AS400Docket; _logSpec : CM_CodeGroupLogSpecs; _length : CM_LogLength output) : Boolean protected;

vars
	proxyLength : CM_LogLength;
	newLength	: CM_LogLength;
	length		: String;

begin

	length := _docket.length.asStringMeasurementJMT();	
	if length = null then
		return false;
	endif;
	newLength := _logSpec.allLogLengths[length];
	if newLength = null then
		create proxyLength transient;
		proxyLength.setProxy(	length,
							 	length,
							 	false,
							 	_logSpec);
	
		app.myTrxCA.trxCreateLogLength(proxyLength, newLength,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating length (' &amp; length &amp; ')');
			return false;
		endif;
	endif;
	_length := newLength;
	return true;
epilog
	delete proxyLength;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_logSpec" type="CM_CodeGroupLogSpecs"/>
        <Parameter name="_length" type="CM_LogLength" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLocations" id="54a4ceed-aa1f-4018-b8ea-22e7a5b3e78f">
        <updating/>
        <source>createLocations() protected, updating;

vars

	cmif			: CMIF_LogRowRestriction;
	logArea			: CM_LogArea;
	previous		: String;
	logController	: CM_LogController;
	log				: CM_AS400Log;
	iter			: Iterator;
	id				: String;
	
begin

	on Exception do agtPassportExHandler(exception, app.myPassport);
	create cmif transient;
	iter := self.allLocations.createIterator;
	while iter.next(log) do
		
		id := log.block &amp; log.row &amp; log.subRow;
		if not createLogArea(log.block, logArea) then
			app.raiseCMException1(AS400TransferError, 'Unable to create log area', null, null);
			setAllErrors('Creating logArea (' &amp; log.block &amp; ')(' &amp; logArea.String &amp; ')');
			return;
		endif;
		if logArea.allRowControllersById[id] = null then
			cmif.myRowArea := logArea;
			cmif.estimatedMaxVolume := 0;
			cmif.isMixedRow := false;
			cmif.transport := 1;
			cmif.id := id.toUpper;
			cmif.width := Max_Width;
			cmif.isSplit := false;
			cmif.user := app.getMyUserCode;
			cmif.comment := "AS400 Transfer";
			cmif.previousRow := previous;
			cmif.distanceFromPrevious := 0;
			app.myTrxCA.trxCreateLogRow(cmif, logController, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				setAllErrors('Creating log row (' &amp; id &amp; ')');
			endif;
		endif;
		previous := cmif.id;
	endwhile;

epilog

	delete iter;
	delete cmif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLog" id="f729e1a0-1196-43dc-9dc9-d9ebba7cd74c">
        <updating/>
        <source>createLog(_docket : CM_AS400Docket) : Boolean protected, updating;

vars
	operator				: CM_Operator;
	opTerm					: CM_OperatorTerminal;
	bol						: CM_BOL;
	theTime					: TimeStamp;
	logScaleHdrPxy,
	header					: CM_LogScalingHdr;
	
	logDetailPxy, newDtl	: CM_LogScalingDtl;
	log						: CM_AS400Log;
	roadJob					: CM_RoadJob;

begin

	on Exception do agtPassportExHandler(exception, app.myPassport);
	
	operator := app.myRoot.allOperators[_docket.supplier];
	if operator = null then
		app.raiseCMException1(AS400TransferError, 'Unable to locate supplier for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Creating log from docket (' &amp; _docket.docket &amp; ') ' &amp; _docket.String);
		return false;
	endif;
	
	opTerm := operator.getOperatorTerminal(self.myCurrentTerminal, false);
	if opTerm = null then
		beginTransaction;
		operator.getOperatorTerminal(self.myCurrentTerminal, true);
		commitTransaction;
	endif;
	
	// We must have a docket at this stage.
	bol := opTerm.allBOLByTypeNumber.getAtKeyGeq(BOLType_Log, _docket.docket, null).CM_BOL;

	if bol &lt;&gt; null and bol.number = _docket.docket then
		// Is our docket and unmatched docket.
		if self.myCurrentTerminal.allLogBOLsUnmatched.includes(bol.myExtension.CM_BOLExtLogIn) then
			header := self.myCurrentTerminal.allLogScalingHdrsUnmatched.getAtKeyLeq(bol.myOperator.code, bol.number, theTime);
			// If we can't find a header this means we haven't tried to match. Only want to match once so we don't get duplicates.
			if header = null or header.bolNumber &lt;&gt; bol.number then
				// Set up header from docket details.
				create logScaleHdrPxy transient;
				logScaleHdrPxy.setProxy(_docket.docket, operator.code, _docket.scaler, theTime, self.myCurrentTerminal);
				// Create detail for each log.
				foreach log in _docket.allLogs do
					create logDetailPxy transient;
					logDetailPxy.setProxy(log.logNumber, log.conditionCode, log.minimumSED, log.maximumSED, logScaleHdrPxy, _docket.scaler);
				endforeach;
				// Try and match dockets and logs.
				app.myTrxCA.trxCreateLogScalingData(logScaleHdrPxy, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					app.raiseCMException1(AS400TransferError, 'Unmatched docket - ' &amp; _docket.docket, null, null);
					self.setAllErrors('Creating scaling data from docket (' &amp; _docket.docket &amp; ') ' &amp; _docket.String);
					return false;
				endif;
				// If we get this far we can move the logs into their locations.
				roadJob := _docket.myRoadJob;
				// Par 7417 Check for processed road job.
				if global.isValidObject(roadJob) then
					if not doMoveIn(roadJob) then
						return false;
					endif;
				endif;
			else
				// Catch anything unusual.
				if header.allLogScalingDtls.size &lt;&gt; _docket.allLogs.size then
					app.raiseCMException1(AS400TransferError, 'Unmatched docket - ' &amp; _docket.docket, null, null);
					self.setAllErrors('Creating scaling data from docket (' &amp; _docket.docket &amp; ') ' &amp; _docket.String);
					return false;
				endif;
			endif;
		endif;
		return true;
	else
		app.raiseCMException1(AS400TransferError, 'Unable to locate Jade Master docket ' &amp; _docket.docket , null, null);		
		self.setAllErrors('Creating scaling data from docket (' &amp; _docket.docket &amp; ') ' &amp; _docket.String);
		return false;
	endif;
epilog
	delete logScaleHdrPxy;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLogArea" id="ddc07d55-c1dc-4d60-a4d6-69de9cceeeb5">
        <source>createLogArea(_logAreaID : String; _logArea : CM_LogArea output) : Boolean protected;

vars
	
	proxyLogArea	: CM_LogArea;
	pxyTerminalArea	: CM_TerminalArea;
	newLogArea		: CM_TerminalArea;
	type			: Integer;
	length			: Integer;
	isMarked		: Boolean;
	rel				: Boolean;
	labels			: String;
	isGapManaged	: Boolean;
	width			: Integer;
	iter			: Iterator;
	log				: CM_AS400Log;
	area			: CM_TerminalArea;
	controller : CMIF_TerminalArea;
	newTAMaster	   : CM_TerminalAreaMaster;
begin
	area := self.myCurrentTerminal.allTerminalAreas[_logAreaID];
	if area &lt;&gt; null and not area.isKindOf(CM_LogArea) then
		app.raiseCMException1(AS400TransferError, 'Request area - ' &amp; _logAreaID &amp; ' already exists and is not a log area', null, null);
		setAllErrors('Creating Log Area (' &amp; _logAreaID &amp; ')');
		return false;
	endif;
	newLogArea := area.CM_LogArea;
	if newLogArea = null then
		create proxyLogArea transient;
		type := TA_TYPE_LOGAREA;
		rel  := true;
		length := self.allLocations.size * Max_Width;
		isMarked := false;
		width := Max_Width;
		isGapManaged := true;
		iter := self.allLocations.createIterator;		
		while iter.next(log) do
			if log.block = _logAreaID then 
				labels :=  labels &amp; ',' &amp; log.block &amp; log.row &amp; log.subRow;
			endif;
		endwhile;
		if labels.length &gt; 1 then
			labels := labels[2 : end];
		endif;
		proxyLogArea.setProxy(_logAreaID, null, type, length, width, rel, self.myCurrentTerminal, isGapManaged, isMarked, labels, false, true, false, null, null);
		proxyLogArea.setIsStockControlled(true);
//		app.myTrxCA.trxCreateTerminalArea(pxyTerminalArea, newLogArea, false, app.myPassport);
		app.myTrxCA.trxCreateTerminalArea(proxyLogArea,newTAMaster, app.myPassport);
		newLogArea := newTAMaster.CM_TerminalArea;
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Creating Log Area (' &amp; _logAreaID &amp; ')');
			return false;
		endif;
	endif;
	_logArea := newLogArea.CM_LogArea;
	return true;		

epilog
	
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_logAreaID" type="String"/>
        <Parameter name="_logArea" type="CM_LogArea" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLogTransfer" id="3dec5a77-0671-4efa-a2d1-252d5b1b3ebc">
        <updating/>
        <source>createLogTransfer(_tempLog : CM_AS400Log) : Boolean protected, updating;

vars

	realLog 		: CM_Log;
	controller		: CM_LocationsController;
	tempLocation	: String;
	cmif			: CMIF_LogRegrade;
	
begin

	on Exception do agtPassportExHandler(exception, app.myPassport);

	realLog := self.myCurrentTerminal.lookupTrackedItem(_tempLog.logNumber, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
	if realLog = null then
		app.raiseCMException1(AS400TransferError, 'Unable to locate Jade Master Log ' &amp; _tempLog.logNumber , null, null);
		setAllErrors('Create Log Transfer (' &amp; _tempLog.logNumber &amp; ') ' &amp; _tempLog.String);
		return false;
	endif;

	tempLocation := _tempLog.block &amp; _tempLog.row &amp; _tempLog.subRow;
	controller := realLog.getPrimaryLocation(REAL_MODE);
	if not controller.isKindOf(CM_LogController) then	
		app.raiseCMException1(AS400TransferError, 'Log ' &amp; realLog.id &amp; ' has not been moved into yard' , null, null);
		setAllErrors('Create Log Transfer (' &amp; _tempLog.logNumber &amp; ') ' &amp; _tempLog.String);
		return false;
	endif;
	if  controller.CM_LogController.id = tempLocation then
		return true;
	endif;
	
	foreach cmif in self.allCMIF_Transfers do
		if cmif.id = tempLocation then
			break;
		endif;
		cmif := null;
	endforeach;	
		
	if cmif = null then
		create cmif transient;
		cmif.id := tempLocation;
		cmif.location := _tempLog.block;
		self.allCMIF_Transfers.add(cmif);
	endif;
	
	cmif.allTrackedItems.add(realLog);
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_tempLog" type="CM_AS400Log"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createOperatorGroup" id="8bee8206-b22e-4b84-9c1a-ec23a9bcbc77">
        <source>createOperatorGroup(_operator : CM_Operator) : Boolean protected;

vars
	
	proxyOperatorGroup	: CM_OperatorGroup;
	newOperatorGroup	: CM_OperatorGroup;

begin
	
	if _operator = null then
		return false;
	endif;
	
	newOperatorGroup := app.myRoot.allOperatorGroups['TRFR'];
	if newOperatorGroup = null then
		create proxyOperatorGroup transient;
		proxyOperatorGroup.allOperators.add(_operator);
		proxyOperatorGroup.setProxy('TRFR', 'AS400 Transfer', null, true);
		app.myTrxCA.trxCreateOperatorGroup(proxyOperatorGroup, newOperatorGroup,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Create Operator Group (' &amp; 'TRFR' &amp; ')');
			return false;
		endif;
	else
	
	//	proxyOperatorGroup := newOperatorGroup.pxyCreateUpdateProxy();
		proxyOperatorGroup := app.createUpdateProxy(newOperatorGroup).CM_OperatorGroup;
		proxyOperatorGroup.allOperators.add(_operator);	
		app.myTrxUA.trxUpdateOperatorGroup(proxyOperatorGroup, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Update Operator Group (' &amp; 'TRFR' &amp; ')');
			return false;
		endif;			
	endif;

	return true;

epilog
	delete proxyOperatorGroup;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSpecies" id="f842a805-bcac-4c54-a1dd-67d859f3bd41">
        <source>createSpecies(_docket : CM_AS400Docket; _logSpec : CM_CodeGroupLogSpecs; _species : CM_LogSpecies output) : Boolean protected;

vars

	proxySpecies	: CM_LogSpecies;
	newSpecies		: CM_LogSpecies;
	species			: String;

begin

	species := _docket.species;	
	if species = null then
		return false;
	endif;
	newSpecies := _logSpec.allCodes[species].CM_LogSpecies;
	if newSpecies = null then
		create proxySpecies transient;
		proxySpecies.setProxy(	species,
								species, 
								false,
								_logSpec);
		app.myTrxCA.trxCreateLogSpecies(proxySpecies, newSpecies, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Create species (' &amp; species &amp; ')');
			return false;
		endif;
	endif;
	_species := newSpecies;
	return true;
epilog
	delete proxySpecies;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_logSpec" type="CM_CodeGroupLogSpecs"/>
        <Parameter name="_species" type="CM_LogSpecies" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createStand" id="e4e6dc33-3d3e-440b-a944-014af32545a2">
        <source>createStand(_docket : CM_AS400Docket input; _stand : CM_SourceSubSubLocation output; _compartment : CM_SourceSubLocation ) : Boolean protected;

vars

	proxySubSubLocation	: CM_SourceSubSubLocation;
	stand				: String;

begin

	if _compartment = null then
		beginTransaction;
		_docket.setStand(null);
		commitTransaction;
		return true;
	endif;
	stand := _docket.stand;	
	if stand = null then
		return true;
	endif;
	_stand := _compartment.allSubSubLocations[stand].CM_SourceSubSubLocation;
	if _stand = null then
		create proxySubSubLocation transient;
		proxySubSubLocation.setForProxy(stand,
								        stand,
								        false,
								        false,
								    	_compartment);
	
		app.myTrxCA.trxCreateSourceSubSubLocation(proxySubSubLocation, _stand, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Create stand (' &amp; stand &amp; ')');
			return false;
		endif;
	endif;
	return true;
epilog
	delete proxySubSubLocation;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket" usage="input"/>
        <Parameter name="_stand" type="CM_SourceSubSubLocation" usage="output"/>
        <Parameter name="_compartment" type="CM_SourceSubLocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSupplier" id="324d2776-e008-4ba7-9be9-4a3eb1f20cb8">
        <updating/>
        <source>createSupplier(_docket : CM_AS400Docket input) : Boolean protected, updating;
//
vars

	supplierCode	: String;
	logSpecs		: CM_CodeGroupLogSpecs;
	codeGroup		: CM_CodeGroup;
	newSupplier		: CM_Operator;
	proxySupplier	: CM_Operator;
	type			: CM_LogType;
	length			: CM_LogLength;
	species			: CM_LogSpecies;
	grade			: CM_LogGrade;
	carrier			: CM_Carrier;
	vehicle			: CM_Vehicle;
	forest			: CM_SourceLocation;
	compartment		: CM_SourceSubLocation;
	stand			: CM_SourceSubSubLocation;
	
begin

	on Exception do agtPassportExHandler(exception, app.myPassport);
	supplierCode := _docket.supplier;	
	if supplierCode = null then
		app.raiseCMException1(AS400TransferError, 'Supplier code not found for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; _docket.String &amp; ')');
		return false;
	endif;

	if not createCodeGroupLogSpec(supplierCode, codeGroup) then
		app.raiseCMException1(AS400TransferError, 'Unable to create log code group ' &amp; supplierCode &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;	
	endif;
	
	logSpecs := codeGroup.CM_CodeGroupLogSpecs;
	
	if not self.createCodeGroupSourceLocn(codeGroup) then
		app.raiseCMException1(AS400TransferError, 'Unable to create code group ' &amp; supplierCode &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;	
	endif;
	
	newSupplier := app.myRoot.allOperators[supplierCode];
	if newSupplier = null then
		if self.setProxyForSupplier(logSpecs, _docket, proxySupplier) then
			app.myTrxCA.trxCreateOperator(proxySupplier, null, newSupplier, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
				return false;
			endif;
		endif;
		if not createOperatorGroup(newSupplier) then
			app.raiseCMException1(AS400TransferError, 'Unable to set operator group for docket ' &amp; _docket.docket , null, null);
			setAllErrors('Create Supplier (' &amp; _docket.supplier &amp; ')');
			return false;
		endif;		
	else
		if newSupplier.allCodeGroups[CodeGroup_LogSpecs] = null then
			proxySupplier := app.createUpdateProxy(newSupplier).CM_Operator;
			if self.setProxyForSupplier(logSpecs, _docket, proxySupplier) then
				app.myTrxUA.trxUpdateOperator(proxySupplier, null, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					setAllErrors('Update Supplier (' &amp; supplierCode &amp; ')');
					return false;
				endif; 
			endif;
		endif;
	endif;
		
	if not createType(_docket, logSpecs, type) then
		app.raiseCMException1(AS400TransferError, 'Unable to create log type ' &amp; _docket.type &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
	
	if not createLength(_docket, logSpecs, length) then
		app.raiseCMException1(AS400TransferError, 'Unable to create log length ' &amp; _docket.length.asStringMeasurementJMT() &amp; ' for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
	
	if not createSpecies(_docket, logSpecs, species) then
		app.raiseCMException1(AS400TransferError, 'Unable to create log species ' &amp; _docket.species &amp; ' for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
	
	if not createGrade(_docket, species, type, length, grade) then
		app.raiseCMException1(AS400TransferError, 'Unable to create log grade ' &amp; _docket.grade &amp; ' for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;	
	
	if not createCarrier(_docket, self.defaultCarrier, carrier) then
		app.raiseCMException1(AS400TransferError, 'Unable to create carrier for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
	
	if not createTruckTrailer(_docket, self.defaultVehicle, carrier, vehicle, true) then
		app.raiseCMException1(AS400TransferError, 'Unable to create vehicle for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
	
	if not createTruckTrailer(_docket, self.defaultVehicle, carrier, vehicle, false) then
		app.raiseCMException1(AS400TransferError, 'Unable to create trailer for docket ' &amp; _docket.docket , null, null);	
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;
	endif;
		
	if not createForest(_docket, forest, codeGroup) then
		app.raiseCMException1(AS400TransferError, 'Unable to create forest code ' &amp; _docket.forest &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;	
	endif;
	
	if not createCompartment(_docket, compartment, forest) then
		app.raiseCMException1(AS400TransferError, 'Unable to create compartment ' &amp; _docket.compartment &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;	
	endif;
	
	if not createStand(_docket, stand, compartment) then
		app.raiseCMException1(AS400TransferError, 'Unable to create stand ' &amp; _docket.stand &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; supplierCode &amp; ')');
		return false;	
	endif;

	return true;
	
epilog
	
	delete proxySupplier;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTruckTrailer" id="84861fe3-8b5d-42e8-aeaa-8b8086facc9d">
        <source>createTruckTrailer(	_docket		: CM_AS400Docket;
					_default	: String;
					_carrier	: CM_Carrier;
					_vehicle	: CM_Vehicle output;
					_isTruck		: Boolean) : Boolean protected;

vars

	proxyVehicle	: CM_Vehicle;
	newVehicle		: CM_Vehicle;
	regNumber			: String;

begin

	if _isTruck then
		regNumber  := _docket.truck;
	else
		regNumber := _docket.trailer;
	endif;
	if regNumber = null then
		if _default = null then
			return false;
		else
			regNumber := _default;
		endif;
	endif;
	
	newVehicle := self.myCurrentTerminal.vehicles[regNumber, ""];
	if newVehicle = null then
		create proxyVehicle transient;
		proxyVehicle.setProxy(regNumber, '0', null, 0, _carrier, null, false, self.myCurrentTerminal);
 		app.myTrxCA.trxCreateVehicle(proxyVehicle, newVehicle, app.myPassport);
 		if not app.myPassport.trxCompletedOK then
 			setAllErrors('Create vehicle (' &amp; regNumber &amp; ')');
 			return false;
 		endif;
	endif;
	_vehicle := newVehicle;
	return true;
epilog
	delete proxyVehicle;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_default" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="output"/>
        <Parameter name="_isTruck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createType" id="11e46806-f91f-42c9-a1c8-87db5aa13128">
        <source>createType(_docket : CM_AS400Docket; _logSpec : CM_CodeGroupLogSpecs; _type : CM_LogType output) : Boolean protected;

vars

	proxyType	: CM_LogType;
	newType		: CM_LogType;
	type		: String;

begin


	type := _docket.type;	
	if type = null then
		return true;
	endif;
	newType := _logSpec.allLogTypes[type];
	if newType = null then
		create proxyType transient;
		proxyType.setProxy(	type,
							type,
							false,
							_logSpec);
		app.myTrxCA.trxCreateLogType(proxyType, newType,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Create type (' &amp; type &amp; ')');
			return false;
		endif;
	elseif newType.notAvailableForEntry then
		proxyType := app.createUpdateProxy(newType).CM_LogType;
		proxyType.setProxy(newType.code, newType.description, false, newType.myCodeGroupLogSpecs);
		app.myTrxUA.trxUpdateLogType(proxyType, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			setAllErrors('Update type (' &amp; type &amp; ')');
			return false;
		endif;
	endif;
	_type := newType;
	return true;
epilog
	delete proxyType;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_logSpec" type="CM_CodeGroupLogSpecs"/>
        <Parameter name="_type" type="CM_LogType" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="694165e4-fbfa-4324-9b0d-c67075e55cac">
        <updating/>
        <source>delete() updating;

vars

begin

	self.allCMIF_Transfers.purge;
	self.allErrors.purge;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCompleteYardMove" id="08662228-cc9a-4ba4-a44c-ec24826dd332">
        <source>doCompleteYardMove() protected;

/*

Date		Who		Reason
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars

	job		: CM_RoadJob;
	sheet	: CM_RoadJobSheet;
	iter	: Iterator;
	array	: CM_JobArray;

begin

	app.writeLog('START &gt;&gt; doCompleteYardMove', LogINFO);

	create array transient;
	sheet := self.myCurrentTerminal.myRoadJobSheet;
	sheet.allJobsByOrder.copy(array);
	iter := array.createIterator;
	while iter.next(job) do
		if job.status = JOB_COMPLETE then
			//app.myTrxDA.trxRoadExit(job, app.myPassport);			//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(job, null, app.myPassport);		//16.02.2024 navnk30 #62414
			if (not app.myPassport.trxCompletedOK) then
				setAllErrors('complete yard move (' &amp; job.String &amp; ')');
			endif;
		endif;
	endwhile;	
epilog
	delete iter;
	delete array;

	app.writeLog('END &gt;&gt; doCompleteYardMove', LogINFO);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDocketLoad" id="dd2e9030-a0d9-41e9-ba9a-d91e5e711914">
        <updating/>
        <source>doDocketLoad(_fileLoad : CM_AS400FileLoad input; _defaultCarrier, _defaultTruck : String; _progress : ProgressBar io) updating;

vars
	tempDocket	: CM_AS400Docket;
	iter		: Iterator;
	totalDkts,
	numDkts		: Integer;

begin

	app.writeLog('START &gt;&gt; doDocketLoad', LogINFO);

	self.allErrors.purge;
	self.defaultCarrier := _defaultCarrier;
	self.defaultVehicle := _defaultTruck;
	self.myCurrentTerminal := app.myRoot.allTerminals[_fileLoad.terminalName];
	if self.myCurrentTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal' , null, null);
		app.raiseCMException(Input_required_field_terminal, null, null);// cnwdb2	PAR 35364
		return;
	endif;
	app.myPassport.setMyTerminal(self.myCurrentTerminal);
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, true, CM_AS400FileLoad.File_DocketsLoaded, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_DocketsLoaded.String &amp; ')', LogINFO);
	endif;	
	createBatNumbers(_fileLoad, self.myCurrentTerminal);
	totalDkts := _fileLoad.allDockets.size;
	_progress.partsInJob := totalDkts;

	app.writeLog('INFO &gt;&gt; doDocketLoad  numDockets to process = ' &amp; totalDkts.String, LogINFO);

	iter := _fileLoad.allDockets.createIterator;
	while iter.next(tempDocket) do
		sharedLock(tempDocket);
		if tempDocket.isLoaded then
			continue;
		endif;
		if self.createDocket(tempDocket) then
			beginTransaction;
			tempDocket.isLoaded := true;
			commitTransaction;
		endif;
		numDkts := numDkts + 1;

		if (numDkts mod 100) = 0 then
			_progress.partsDone := _progress.partsDone + 100;
			app.writeLog('INFO &gt;&gt; doDocketLoad  ' &amp; numDkts.String &amp; ' of ' &amp; totalDkts.String &amp; ' processed', LogINFO);
		endif;
	endwhile;
	app.myTrxUA.trxUpdateAS400FileLoad(_fileLoad, CM_AS400FileLoad.File_DocketsLoaded, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; File Status not updated - end (' &amp; CM_AS400FileLoad.File_DocketsLoaded.String &amp; ')', LogINFO);
	endif;	
	
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, false, CM_AS400FileLoad.File_DocketsLoaded, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - end (' &amp; CM_AS400FileLoad.File_DocketsLoaded.String &amp; ')', LogINFO);
	endif;	
	
epilog
	delete iter;
	_progress.partsDone := 0;
	app.writeLog('END &gt;&gt; doDocketLoad', LogINFO);

end;</source>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad" usage="input"/>
        <Parameter name="_defaultCarrier" type="String"/>
        <Parameter name="_defaultTruck" type="String"/>
        <Parameter name="_progress" type="ProgressBar" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doFileLoad" id="07f10abc-8881-4ac0-87d3-59a39df8a9cd">
        <updating/>
        <source>doFileLoad(_id, docketFile, logFile, terminal : String) updating;

vars

	fileLoad : CM_AS400FileLoad;	

begin

	app.writeLog('START &gt;&gt; doFileLoad for ' &amp; _id, LogINFO);

	self.allErrors.purge;
	app.myTrxCA.trxCreateAS400FileLoad(_id, docketFile, logFile, terminal, fileLoad, self.myAS400Root, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		setAllErrors('doFileLoad (' &amp; _id);
		return;
	endif;
	app.myTrxUA.trxUpdateAS400FileLoadAudit(fileLoad, true, CM_AS400FileLoad.File_Loaded, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_Loaded.String &amp; ')', LogINFO);
	endif;	

	if self.loadDocketsFromFile(fileLoad) then
		if self.loadLogsFromFile(fileLoad) then
			app.myTrxUA.trxUpdateAS400FileLoad(fileLoad, CM_AS400FileLoad.File_Loaded, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				app.writeLog('ERR &gt;&gt; File Status not updated - end (' &amp; CM_AS400FileLoad.File_Loaded.String &amp; ')', LogINFO);
			endif;	
			app.myTrxUA.trxUpdateAS400FileLoadAudit(fileLoad, false, CM_AS400FileLoad.File_Loaded, app.myPassport);	
			if (not app.myPassport.trxCompletedOK) then
				app.writeLog('ERR &gt;&gt; Audit not updated - end (' &amp; CM_AS400FileLoad.File_Loaded.String &amp; ')', LogINFO);
			endif;	
		endif;
	endif;

epilog
	app.writeLog('END &gt;&gt; doFileLoad for ' &amp; _id &amp; ')', LogINFO);

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="docketFile" type="String"/>
        <Parameter name="logFile" type="String"/>
        <Parameter name="terminal" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFileLoadDelete" id="3e961fe2-4e19-4fe9-85f4-c95732e4ba84">
        <source>doFileLoadDelete(_fileLoad : CM_AS400FileLoad io) : Boolean;



begin

	self.allErrors.purge;
	if _fileLoad &lt;&gt; null then
		app.myTrxDA.trxDeleteAS400FileLoad(_fileLoad, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
		endif;
	endif;
	return false;

end;</source>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogLoad" id="80a0876d-c078-4267-827e-c5e5c9c81157">
        <updating/>
        <source>doLogLoad(_fileLoad : CM_AS400FileLoad input; _progress : ProgressBar io) updating;
//
vars
	iter			: Iterator;
	docket			: CM_AS400Docket;
	totalDkts,
	numDkts,
	count			: Integer;
	stageStr		: String;
begin

	stageStr := 'Start';

	app.writeLog('START (' &amp; _fileLoad.id &amp; ') &gt;&gt; doLogLoad', LogINFO);

	self.allErrors.purge;
	self.myCurrentTerminal := app.myRoot.allTerminals[_fileLoad.terminalName];
	if self.myCurrentTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal' , null, null);
		app.raiseCMException(Input_required_field_terminal , null, null); // cnwdb2	PAR 35364

		setAllErrors('doLogLoad (' &amp; _fileLoad.String &amp; ')');
		return;
	endif;
	
	app.myPassport.setMyTerminal(self.myCurrentTerminal);

	//epr par 36229 22/7/15 radio telemetry enabled removed
	
//process.profilerStart();
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, true, CM_AS400FileLoad.File_LogsLoaded, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_LogsLoaded.String &amp; ')', LogINFO);
		return;
	endif;	

	totalDkts := _fileLoad.allDockets.size;
	_progress.partsInJob := totalDkts;

	app.writeLog('INFO (' &amp; _fileLoad.id &amp; ') &gt;&gt; doLogLoad numDockets to process = ' &amp; totalDkts.String, LogINFO);

	iter := _fileLoad.allDockets.createIterator;
	stageStr := 'beginWhile';

	while iter.next(docket) do
		stageStr := 'handling docket (' &amp; docket.docket &amp; ')';
		if self.createLog(docket) then
			count := count + docket.allLogs.size;
		endif;
		numDkts := numDkts + 1;
		if (numDkts mod 200) = 0 then
			_progress.partsDone := _progress.partsDone + 200;
			app.writeLog('INFO (' &amp; _fileLoad.id &amp; ') &gt;&gt; doLogLoad ' &amp; numDkts.String &amp; ' of ' &amp; totalDkts.String &amp; ' processed ' &amp;
						'numLogs = ' &amp; count.String, LogINFO);
		endif;

	endwhile;
	stageStr := 'endWhile';
	
	if app.myPassport.noErrors then
		stageStr := 'doCompleteYardMove';
		self.doCompleteYardMove();
	endif;
	if app.myPassport.noErrors then
		stageStr := 'trxUpdateAS400FileLoad';
		app.myTrxUA.trxUpdateAS400FileLoad(_fileLoad, CM_AS400FileLoad.File_LogsLoaded, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			app.writeLog('ERR &gt;&gt; File Status not updated - end (' &amp; CM_AS400FileLoad.File_DocketsLoaded.String &amp; ')', LogINFO);
		endif;	
	endif;
	if app.myPassport.noErrors then
		stageStr := 'trxUpdateAS400FileLoadAudit';
		app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, false, CM_AS400FileLoad.File_LogsLoaded, app.myPassport);	
		if (not app.myPassport.trxCompletedOK) then
			app.writeLog('ERR &gt;&gt; Audit not updated - end (' &amp; CM_AS400FileLoad.File_LogsLoaded.String &amp; ')', LogINFO);
		endif;	
	endif;
	
	
	if count &lt;&gt; _fileLoad.allLogs.size then
		app.raiseCMException1(AS400TransferError, 'Unmatched logs exist ' &amp; _fileLoad.id, null, null);
	endif;
	
epilog
	if app.myPassport.hasErrors then
		self.setAllErrors(stageStr);
	endif;

	delete iter;
	_progress.partsDone := 0;
	app.writeLog('END (' &amp; _fileLoad.id &amp; ') &gt;&gt; doLogLoad', LogINFO);

end;</source>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad" usage="input"/>
        <Parameter name="_progress" type="ProgressBar" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLogTransfer" id="8024965f-d537-40f8-8371-2814a3c4f2cf">
        <updating/>
        <source>doLogTransfer() protected, updating;

vars
	
	moveController	: CMIF_MoveController;
	rtnValue		: Boolean;
	cancelSave		: Boolean;
	cmif			: CMIF_LogRegrade;
	location		: CM_LocationsController;
	logArea			: CM_LogArea;
	userCode		: String;
begin

	on Exception do agtPassportExHandler(exception, app.myPassport);

	if self.allCMIF_Transfers.size &gt; 0 then
		create moveController transient;
		userCode := app.getMyUserCode;
		foreach cmif in self.allCMIF_Transfers do
			logArea := self.myCurrentTerminal.allTerminalAreas[cmif.location].CM_LogArea;
			if logArea &lt;&gt; null then	
				location := logArea.allRowControllersById[cmif.id];
			endif;
			if location = null then
				app.raiseCMException1(AS400TransferError, 'Jade Master Location ' &amp; cmif.id &amp; ' is not set up. Unable to transfer', null, null);
				setAllErrors('doLogTransfer');
			endif;
			moveController.setMoveMode(REAL_MODE);
			moveController.isSystemMove := true;
			moveController.setMyToPrimaryLocation(location);
			app.myTrxUA.trxMoveTrackedItems(cmif.allTrackedItems, moveController, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				self.setAllErrors('doLogTransfer');
			endif;
		endforeach;
	endif;
epilog
	delete moveController;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveIn" id="61ddf9f7-556e-45b1-9a82-fd9498db324d">
        <source>doMoveIn(_roadJob : CM_RoadJob io) : Boolean protected;


		
begin

	app.myTrxUA.trxUpdateJobDoMove(_roadJob, REAL_MODE, true, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		self.setAllErrors('doMoveIn');
		return false;
	endif;
	return true;



end;</source>
        <access>protected</access>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPostLoad" id="d12a5f03-5802-41a6-96c7-a0bcda837a98">
        <updating/>
        <source>doPostLoad(_fileLoad : CM_AS400FileLoad io; _progress : ProgressBar io) updating;

vars

	log		: CM_AS400Log;
	iter	: Iterator;
	count	: Decimal[12,0];

begin

	app.writeLog('START &gt;&gt; doPostLoad', LogINFO);

	self.allErrors.purge;
	self.allCMIF_Transfers.purge;
	self.myCurrentTerminal := app.myRoot.allTerminals[_fileLoad.terminalName];
	if self.myCurrentTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal' , null, null);
		app.raiseCMException(Input_required_field_terminal , null, null); // cnwdb2	PAR 35364

		return;
	endif;
	app.myPassport.setMyTerminal(self.myCurrentTerminal);
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, true, CM_AS400FileLoad.File_PostLoad, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_PostLoad.String &amp; ')', LogINFO);
	endif;	

	iter := _fileLoad.allLogs.createIterator;	
	_progress.partsInJob := _fileLoad.allLogs.size;
	while iter.next(log) do
		count := count + 1;
		createLogTransfer(log);
		if count mod 1000 = 0 then
			_progress.partsDone := _progress.partsDone + 1000;
		endif;
	endwhile;
	doLogTransfer();
	app.myTrxUA.trxUpdateAS400FileLoad(_fileLoad, CM_AS400FileLoad.File_PostLoad, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; File Status not updated - end (' &amp; CM_AS400FileLoad.File_PostLoad.String &amp; ')', LogINFO);
	endif;
	
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, false, CM_AS400FileLoad.File_PostLoad, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - end (' &amp; CM_AS400FileLoad.File_PostLoad.String &amp; ')', LogINFO);
	endif;	
		
epilog
	delete iter;
	_progress.partsDone := 0;

	app.writeLog('END &gt;&gt; doPostLoad', LogINFO);

end;</source>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad" usage="io"/>
        <Parameter name="_progress" type="ProgressBar" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPreLoad" id="d3fc234f-9684-4e40-82a2-4ba84ebb84a0">
        <updating/>
        <source>doPreLoad(_fileLoad : CM_AS400FileLoad io; _defaultCarrier, _defaultTruck : String; _progress : ProgressBar io) updating;

vars

	iter1, iter2	: Iterator;
	docket			: CM_AS400Docket;
	log				: CM_AS400Log;
	

begin

	self.allErrors.purge;
	self.myCurrentTerminal := app.myRoot.allTerminals[_fileLoad.terminalName];
	if self.myCurrentTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal' , null, null);
		app.raiseCMException(Input_required_field_terminal , null, null); // cnwdb2	PAR 35364
		return;
	endif;
	app.myPassport.setMyTerminal(self.myCurrentTerminal);
	self.defaultCarrier := _defaultCarrier;
	self.defaultVehicle := _defaultTruck;
	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, true, CM_AS400FileLoad.File_Preloaded, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_Preloaded.String &amp; ')', LogINFO);
	endif;	

	_progress.partsInJob := 2;
	iter1 := _fileLoad.allDockets.createIterator;
	while iter1.next(docket) do
		self.createSupplier(docket);
	endwhile;
	_progress.partsDone := 1;
	iter2 := _fileLoad.allLogs.createIterator;
	self.allLocations.clear;
	while iter2.next(log) do
		self.getUniqueLocations(log);
	endwhile;
	_progress.partsDone := 2;
	self.createLocations();
	app.myTrxUA.trxUpdateAS400FileLoad(_fileLoad, CM_AS400FileLoad.File_Preloaded, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; File STatus not updated - start (' &amp; CM_AS400FileLoad.File_Preloaded.String &amp; ')', LogINFO);
	endif;	

	app.myTrxUA.trxUpdateAS400FileLoadAudit(_fileLoad, false, CM_AS400FileLoad.File_Preloaded, app.myPassport);	
	if (not app.myPassport.trxCompletedOK) then
		app.writeLog('ERR &gt;&gt; Audit not updated - start (' &amp; CM_AS400FileLoad.File_Preloaded.String &amp; ')', LogINFO);
	endif;	
	
epilog

	delete iter1;
	delete iter2;
	_progress.partsDone := 0;

end;</source>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad" usage="io"/>
        <Parameter name="_defaultCarrier" type="String"/>
        <Parameter name="_defaultTruck" type="String"/>
        <Parameter name="_progress" type="ProgressBar" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getUniqueLocations" id="f7c70333-11e9-477a-b1df-1e23bdedbb15">
        <source>getUniqueLocations(_log : CM_AS400Log) protected;

begin

	if self.allLocations.getAtKey(_log.block, _log.row, _log.subRow) = null then
		self.allLocations.add(_log);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_log" type="CM_AS400Log"/>
    </JadeMethod>
    <JadeMethod name="loadDocketsFromFile" id="59bdecae-0199-4e8c-bc7c-9bbcf4e9e85a">
        <source>loadDocketsFromFile(_fileLoad : CM_AS400FileLoad) : Boolean protected;

vars

	docketFile	: File;

begin

	create docketFile transient;
	docketFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	docketFile.mode := File.Mode_Input;
	docketFile.shareMode := File.Share_Read;
	docketFile.fileName := _fileLoad.docketFileName;
	if not docketFile.isAvailable then 
		app.raiseCMException1(FileUnavailable, docketFile.fileName, null, null);
		setAllErrors(method.name);
		return false;
	endif;
	
	app.myTrxCA.trxCreateAS400Docket(docketFile, _fileLoad, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		setAllErrors(method.name);
		return false;
	endif;
	return true;


epilog

	delete docketFile;
end;</source>
        <access>protected</access>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadLogsFromFile" id="a26a7172-1200-4c98-b98a-d4f9ac6ca2e6">
        <source>loadLogsFromFile(_fileLoad : CM_AS400FileLoad) : Boolean protected;

vars

	logFile		: File;


begin

	create logFile transient;
	logFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	logFile.mode := File.Mode_Input;
	logFile.shareMode := File.Share_Read;
	logFile.fileName := _fileLoad.logFileName;
	if not logFile.isAvailable then 
		app.raiseCMException1(FileUnavailable, logFile.fileName, null, null);
		setAllErrors(method.name);
		return false;
	endif;
			
	app.myTrxCA.trxCreateAS400Log(logFile, _fileLoad, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		setAllErrors(method.name);
		return false;
	endif;
	return true;
	

epilog

	delete logFile;
end;</source>
        <access>protected</access>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllErrors" id="0c04dcca-fc75-4686-80f5-0afdfd270145">
        <source>setAllErrors(_heading : String);

vars
	err	: CM_Error;
	
begin

//	if self.allErrors.size &gt; 200 then
//		return;
//	endif;

	app.writeLog('HEADING &gt;&gt; ' &amp; _heading, LogINFO);

	self.newErrors.clear;	
	foreach err in app.myPassport.allWarnings do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('WARNING &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;

	foreach err in app.myPassport.allErrors do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('ERROR &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;
	
	foreach err in self.newErrors do
		err.removeFromPassport();
	endforeach;
	
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForSupplier" id="d0b86b8c-475a-4be4-b88b-8c94d98cfc4a">
        <source>setProxyForSupplier(_logSpecs : CM_CodeGroupLogSpecs; _docket : CM_AS400Docket; _proxySupplier	: CM_Operator io) : Boolean protected;

// cnwdvb1 21 November 2002 
vars

	allCodeGroups	: CM_CodeGroupsByTypeDict;
	operatorGroup	: CM_OperatorGroup;

begin

	create allCodeGroups transient;
	allCodeGroups.add(_logSpecs);
	/*if not createOperatorGroup(operatorGroup) then
		app.raiseCMException1(AS400TransferError, 'Unable to create operator group ' &amp; operatorGroup.code &amp; ' for docket ' &amp; _docket.docket , null, null);
		setAllErrors('Create Supplier (' &amp; _docket.supplier &amp; ')');
		return false;
	endif;*/
	if _proxySupplier = null then
		create _proxySupplier transient;
	endif;
	_proxySupplier.setProxy(	_docket.supplier, 
								_docket.supplier,
								false,
								0,
								0,
								null,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false, // adm 210708 CCMS 1738
								null,
								null,
						    	allCodeGroups,
								false, false, false, null, null, //cnwrd1 4.11.08 CCMS JMT 1743/1764 
								0, //cnwjo3 CCMS 1892, par 23587
								false,	// 14/03/2011 cnwcs5 par 26909 
								false);	// 20/10/2011 cnwdap1 PAR #28524 CCMS POL 2096

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_logSpecs" type="CM_CodeGroupLogSpecs"/>
        <Parameter name="_docket" type="CM_AS400Docket"/>
        <Parameter name="_proxySupplier" type="CM_Operator" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
