<Class name="CMIF_KPICounterCargoType" id="53f3fed7-1a22-42a7-b1d1-08c4d98db464">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allKPICounterMonths" id="c40dbc7e-c7be-41fb-b0c9-8cef2cdc3cfa">
        <kind>parent</kind>
        <type name="CMIF_KPICounterMonthDict"/>
        <Inverse name="CMIF_KPICounterMonth::myKPICounterCargoType"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myCargoType" id="959749a6-21fb-41e8-95c4-948a284297de">
        <embedded/>
        <type name="CM_CargoType"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myKPICounter" id="49ca42d0-2b4c-4606-ba1c-5b35644b8340">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_KPICounter"/>
        <Inverse name="CMIF_KPICounter::allKPICounterCargoTypes"/>
    </ExplicitInverseRef>
    <JadeMethod name="getTotalQuantity" id="269519bd-9425-42cd-bfc2-56c08a6067c0">
        <source>getTotalQuantity() : Integer;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR

*/

vars
	kpiMonth : CMIF_KPICounterMonth;
	total : Integer;
begin
	
	foreach kpiMonth in self.allKPICounterMonths discreteLock do
		total := total + kpiMonth.totalQuantity;
	endforeach;
	
	return total;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTEU" id="e65d3da9-b704-4317-85fc-bf63b12c78a6">
        <source>getTotalTEU() : Decimal;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR

*/

vars
	kpiMonth : CMIF_KPICounterMonth;
	total : Decimal[16,4];
begin
	
	foreach kpiMonth in self.allKPICounterMonths discreteLock do
		total := total + kpiMonth.getTotalTEU();
	endforeach;
	
	return total;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
