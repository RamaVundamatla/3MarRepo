    <JadeMethod name="setupForm" id="216a4a99-4c94-466b-89ee-43fd938526d2">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
31 July 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
begin	
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;
	
	self.getXMLSettingsForSetup;

	inheritMethod();
	
	self.showToolbar 			:= true;
	self.frmBase.top:=self.frmToolbar.clientHeight;
	self.frmBase.height :=self.clientHeight - self.frmToolbar.clientHeight - self.staStatusBar.clientHeight;
	self.frmBase.width:=self.clientWidth;
	self.frmBase.parentAspect := Frame.ParentAspect_StretchBoth;
	self.frmError.visible:=false;
	self.frmError.width:=self.frmData.clientWidth;
	self.btnSaveBase.enabled:=false;
	self.btnSaveVerify.enabled:=false;
	self.btnEdit.enabled:=false;
	self.btnCancelBase.enabled:=false;
	
	self.initTableData (self.getEntTableDefName);
	self.initTableErrors();
		
	self.frmQueryToolbar.height	:= 27;
	// position multi-select groupbox
	self.grpSelect.move (10, self.frmQueryToolbar.height + 10, self.frmQuery.width - 20, self.frmQuery.clientHeight -  self.frmQueryToolbar.height - 10);
	
	self.grpSelect.formDisplayEntryMethodName	:= CMUI_EDIComparisonForm::displayEntrySelectFields.name;
	
	self.frmQuery.visible	:= false;
	
	self.loadAvailableAndSelectedFields;
	
	self.loadDataTable;

	// need to know if edidata is changed or deleted
	self.doNotableAdd (self.myEDIData);
	
	self.doResize(); // ### TFS 52525 09DEC2021 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showChangesEDITrackedItem" id="75ca41bf-3626-4f6a-809f-2962f42d512a">
        <source>showChangesEDITrackedItem(_table :CM_DataTable input; _ediTI :CM_EDIReleaseRequestTI; _detail	:CM_ReserveDetail) : Boolean;
/*

Date		Who		Reason
15 September 2016	cnwer1	Initial creation TFS 2606
19 Oct       2017   cnwma1  TFS #7475 POL - Missing functions under EDI Comparison
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/
constants
	EMPTY_CELL = '???';
vars
	release : CM_BulkRelease;
	col,
	ediRow, 
	dbRow : Integer;
	isCoparn : Boolean;
	ediText : String;
	dbText : String;
	etRow				:EntTableRow;
	coll				:CM_ObjectSet;	
	rowName				:String;
	highlight : Boolean;
begin
	// find out where in the table our edi and db data is displayed
	if _ediTI &lt;&gt; null then
		_table.findObjectInRow (_ediTI, ediRow);
	endif;
	
	if _detail &lt;&gt; null then
		_table.findObjectInRow (_detail, dbRow);
		release := _detail.myReserveHeader;
	endif;
	
	if dbRow  = 0  or ediRow = null then
		return false;
	endif;
	
	create coll transient;
	
	self.grpSelect.getSelected (coll);
	
	_table.accessCell (dbRow, 1).text 	:= CM_EDITrackedItem.EDI_ACTION_UPDATE;
	_table.accessCell (ediRow, 1).text 	:= CM_EDITrackedItem.EDI_ACTION_UPDATE;
	
	isCoparn	:= _ediTI.myEDIData.isCoparnFile;
	// we are going to highlight differences in the EDI row
	foreach col in _table.fixedColumns + 1 to _table.columns do
		ediText := _table.getCellText (ediRow, col);
		dbText	:= _table.getCellText (dbRow, col);
		
		if ediText = dbText then
			// no change in value - so simple !!
			continue;
		endif;
		// something has changed - do we care
		etRow := _table.getEntTableRowAtColumn (col);
		
		if etRow = null then
			continue;
		endif;
		
		// some columns we don't care about for the purposes of comparison
		if coll.includes (etRow) then				// user selected to ignore this one
			continue;
		endif;
		
		rowName := etRow.name;

		// some things never get stored on the release so no point comparing
		if rowName = ETRow_CheckISOGroup or 
			rowName = ETRow_MessageMode or 
			rowName = ETRow_HasChanged or
			rowName = ETRow_SenderCode then
			continue;
		endif;
		

		// for coparn files we don't update EDI Party defaults for an update (this is stuff that was not in original file) 
		if isCoparn then
			if rowName = ETRow_CarrierCode or
				rowName = ETRow_DeliveryReason or
				rowName = ETRow_ReleaseTypeStr or
				rowName = ETRow_StatusBulkRelease or
				rowName = ETRow_SubTerminalCode	then 
				continue;
			endif;
		endif;		
		// some values appear different when they are really the same
		if ediText &lt;&gt; null or dbText &lt;&gt; null then 
			if rowName = ETRow_DischargePort or rowName = ETRow_LoadPort or rowName = ETRow_DestinationPort then
				// edi and db display some ports in different format
				if self.doComparePorts (rowName, release, _ediTI) then
					// just a display thing
					continue;
				endif;
			elseif rowName = ETRow_DeliveryReason then
				if _ediTI.deliveryReason = release.deliveryReasonCode then
					// just a display thing
					continue;
				endif;
			elseif rowName = ETRow_MtRelease then
				if _ediTI.mtRelease = (not release.fullRelease) then
					// just a display thing
					continue;
				endif;
			elseif rowName = ETRow_AvailabilityGrades and _detail.isKindOf (CM_ReserveSelection) then
				if _detail.CM_ReserveSelection.isEDIMatch_MTGrade (_ediTI) then
					// just a display thing
					continue;
				endif;
			elseif rowName = ETRow_EstimatedRequiredDate then 
				// stored as timestamp - ediTI shows both together, release just shows date for it
				if _ediTI.estimatedRequiredDate = null and release.dateEstimatedRequired = null then
					// both null
					continue;
				endif;
				
				/*//19.10.2017 cnwma1 TFS #7475 
				if dbText &lt;&gt; null then     
					// just for 8.1.2 - will add new ET_Row for 8.2.1
					dbText := release.dateEstimatedRequired.asStringJMT;
					
					_table.accessCell (dbRow, col).text	:= dbText;
				endif;*/
				
				if ediText = dbText then
					continue;
				endif;			
			
			elseif rowName = ETRow_RequestDate then
				if _ediTI.requestDate = null and release.dateRequested = null then
					// both null
					continue;
				endif;
				
				/* //19.10.2017 cnwma1 TFS #7475 *
				if dbText &lt;&gt; null then
					// just for 8.1.2 - will add new ET_Row for 8.2.1
					dbText := release.dateRequested.asStringJMT;
					
					_table.accessCell (dbRow, col).text	:= dbText;
				endif;
				*/
				if ediText = dbText then
					continue;
				endif;
			endif;
		endif;
		
		// we have a difference - highlight it in the EDI row
		if ediText = null then	
			// give us something to hightlight
			_table.accessCell (ediRow, col).text	:= EMPTY_CELL;
		endif;
		
		// something different - highlightit
		self.highlightJadeTableElement (_table.accessCell (ediRow, col));

		highlight:=  true;
	endforeach;
	
	return highlight;
epilog
	delete coll;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <Parameter name="_detail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
