    <JadeMethod name="createWOJobs" id="e919d239-2606-4b54-9671-9c928280372e">
        <source>createWOJobs( _woActionIF     : CMIF_WorkOrderAction;
			  _jobParams  	   : CMIF_WorkOrderJobParams input; 
			  _realJob         : CM_Job io;
			  _passport        : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
17 Feg 2022 navma1	Bug 52884: MTN - Work Order - Should Allow Multiple Tasks to be Added to a Cargo Work Order
28 September navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
12 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	toDotaskDesc 	: CM_ToDoTaskDesc;
	count		 	: Integer;
	term		 	: CM_Terminal;
	pxyMoveJob	 	: CM_YardInternalJob;
	pxyMoveRequest	: CM_WOMoveRequest;
	moveRequest		: CM_WOMoveRequest;
	moveTargetLoc   : String;
	ti				: CM_TrackedItem;
begin
	
	term						 := self.myParent.myTerminal;										//27.03.2023 navma1 #56614:[56615]	
	_jobParams.jobId 			 := getJobId();
	_jobParams.myWorkOrderDtl 	 := self.CM_WorkOrderDtl; 											// 28 September navcs2 #54344
	if _woActionIF &lt;&gt; null then																		//12.5.2023 navhl20 #56631[56185]
		_jobParams.numberToQueue	 := _woActionIF.numberFromKnownCargo;
	endif;
	_jobParams.requiredByDT 	 := self.requiredByDT;
	

	if self.isKindOf(CM_WodPack) then
		_jobParams.isPackParentJob   := self.CM_WodPack.isSelectedItemsPackingChild; 
	elseif self.isKindOf(CM_WodUnpack) then
		
	elseif self.isKindOf(CM_WodToDo) then
		//_jobParams.myToDoTaskDesc := self.CM_WodToDo.myToDoTaskDesc;							    //15.3.2023 navhl20	#56614:[56615]
		count := 1;
		foreach toDotaskDesc in self.CM_WodToDo.allToDoTasksDescs do
			_jobParams.myToDoTaskDesc := toDotaskDesc;
			_jobParams.jobId 		  := self.getJobId()&amp; Hyphen &amp; count.String;
			app.myUtilityCA.utlCreateInternalWorkOrderJob(self,_jobParams, _realJob, _passport );
			count := count +1;
		endforeach;
		return;																					    //15.3.2023 navhl20	#56614:[56615]
	elseif self.isKindOf(CM_WodMove) then
	
		if self.CM_WodMove.myTargetLocation &lt;&gt; null then
			moveTargetLoc := self.CM_WodMove.myTargetLocation.getFullId; 
		else
			moveTargetLoc := self.CM_WodMove.targetLocation;
		endif;
	
		create pxyMoveJob transient;
		pxyMoveJob.setProxyYardDelivery(self.getJobId, self.myParent.myTerminal);
		pxyMoveJob.setMyWODtl( self.CM_WorkOrderTIDtl ); 

		create pxyMoveRequest transient;
		pxyMoveRequest.set(self.requiredByDT, moveTargetLoc, self.CM_WodMove.allSelectedTIs.size );
		app.myUtilityCA.utlCreateYardInternalDelivery(pxyMoveJob, _realJob , _passport);
		
		if _passport.noErrors() then
	
			foreach ti in self.CM_WodMove.allSelectedTIs do
				_realJob.updateTICollections(ti, null);
			endforeach;
			
			pxyMoveRequest.setJob(_realJob);		
			app.myUtilityCA.utlCreateWOMoveRequest(pxyMoveRequest,moveRequest, _passport);
			return;
		endif;	
		
		
	elseif self.isKindOf(CM_WorkOrderToDoDtl) then
		if not self.CM_WorkOrderToDoDtl.allToDoTasksDescs.isEmpty then
			foreach toDotaskDesc in self.CM_WorkOrderToDoDtl.allToDoTasksDescs do
				_jobParams.myToDoTaskDesc := toDotaskDesc;
				app.myUtilityCA.utlCreateInternalWorkOrderJob(self,_jobParams, _realJob, _passport );
			endforeach;
		endif;
		
		return;
	endif;
	// 28 September navcs2	ChangeRequest 54344 End
	
	app.myUtilityCA.utlCreateInternalWorkOrderJob(self,_jobParams, _realJob, _passport );

epilog
	delete pxyMoveRequest;
	delete pxyMoveJob;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_jobParams" type="CMIF_WorkOrderJobParams" usage="input"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createWOTransaction" id="413bba08-6528-4332-baf9-da000aaf9c72">
        <source>createWOTransaction(_transType : Integer; _resourceUsageProxys : CM_ResourceTypeUsageSet; _task : CM_ToDoTask): CM_WOTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022	navcs2	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Apr 2023 navhl20 Bug 57453: EUP - Duplicate Complete Transaction when completing ToDo &amp; Cargo Work Orders
// ### JIRA 14793
*/

vars
	woTrans			: CM_WOTransaction;
	transType,
	woTranstype		: Integer;
	class 			: Class;
	parent			: CM_WorkOrder;
	isAdvWOTransType: Boolean; //14/03/2024	navkc1 CR 62896 Task 62898
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	businessUnit : CM_Bank;
begin
	
	if self.isWorkOrderVoyageDtl then									//19.01.2023 navma1 #56141 Task#56147
		return null;
	endif;
	
	isAdvWOTransType := self.isToGetAdvWOTransType(_transType); //14/03/2024	navkc1 CR 62896 Task 62898
	
	//14/03/2024	navkc1 CR 62896 Task 62898
	if isAdvWOTransType then
		woTranstype := self.getTransTypeByMode();							//06.4.2023 navhl20	#57453
		woTrans := self.getLastTransOfType(woTranstype);					//06.4.2023 navhl20	#57453
		
		if woTrans &lt;&gt; null then												//06.4.2023 navhl20	#57453

			// ### JIRA 23013 16OCT2024 NAVAB1
			resourceUsageProxys := _resourceUsageProxys;
			woTrans.addResourcesFromProxys(resourceUsageProxys);
			woTrans.setToDoTask(_task); 
			businessUnit := woTrans.getMyBank();
			
			if not app.myPassport.useWOTransactionDeferUpdate then //17/02/2025	navkc1 JIRA Bug MTN-33582
				businessUnit.createChargeWOResync(woTrans);
			endif;
			
			return woTrans;
		endif;
		
		transType := self.getAdvWOTransactionType(_transType);
	else
		transType := _transType;
	endif;
	
	class 	  := global.getTiTxnClassForType(transType, false);
	parent    := self.myParent;
	
	create woTrans as class persistent;
	woTrans.setBaseAttributes( app.serverTimestampAtTrxStart, parent, transType, parent.getMyTerminal()); 
	woTrans.setMyWodtl(self);	

	// ### JIRA 23013 16OCT2024 NAVAB1
	resourceUsageProxys := _resourceUsageProxys;
	woTrans.addResourcesFromProxys(resourceUsageProxys);
	woTrans.setToDoTask(_task); 
	
	// ### TFS DEFECT 59150 17JUL2023 NAVAB1
	if woTrans &lt;&gt; null then
		woTrans.createCharge();
	endif;
	
	return woTrans;

epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="createWOTransactionUserDefined" id="0196aace-51fd-477d-b622-acff7e4ea3d3">
        <source>createWOTransactionUserDefined(_transType : Integer; _resourceUsageProxys : CM_ResourceTypeUsageSet; _task : CM_ToDoTask): CM_WOTransaction;
// ### JIRA 14793 30OCT2024 NAVAB1  use the user defined transaction type for the transaction
vars
	woTrans			: CM_WOTransaction;
	tranTypeForClass		: Integer;
	class 			: Class;
	parent			: CM_WorkOrder;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	className : String;
begin
	if _transType &lt;= TransactionTypeJMTMax then // user defined WO transaction
		return null;
	endif;
	
	if _task = null then
		return null;
	endif;
		
	if self.isWorkOrderVoyageDtl then	
		return null;
	endif;
	
	if _task.toDoTaskDesc &lt;&gt; null then
		// get the transaction class from user defined transaction type on the to do desc
		className := _task.toDoTaskDesc.getTrxTypeOnCompleteClassName(); // this will be the 'complete' transaction class for the to do task type e.g. voyage, truck, train etc.
		tranTypeForClass := global.getTiTxnTypeForClassName(className);
	endif;
		
	if className = null then
		return null;
	endif;
	
	class 	  := global.getTiTxnClassForType(tranTypeForClass, false);
	parent    := self.myParent;
	
	create woTrans as class persistent;
	woTrans.setBaseAttributes( app.serverTimestampAtTrxStart, parent, _transType, parent.getMyTerminal()); 
	woTrans.setMyWodtl(self);	

	resourceUsageProxys := _resourceUsageProxys;
	woTrans.addResourcesFromProxys(resourceUsageProxys);
	woTrans.setToDoTask(_task); 
	
	if woTrans &lt;&gt; null then
		woTrans.createCharge();
	endif;
	
	return woTrans;

epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
