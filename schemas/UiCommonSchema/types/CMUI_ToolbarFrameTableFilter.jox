    <JadeMethod name="buildSelf" id="4aff4397-1b36-4701-a0ee-a38515373f14">
        <updating/>
        <source>buildSelf()  updating;
/*

Purpose: 		General set up for this table filter control. At the time of design, this control is to be used in CMUI_Toolbar, and as an ordinary control in the form.
				"self.init()" method is used for setting the control to fit in CMUI_Toolbar.

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars
	baseForm : CM_BaseForm;
begin
	
	self.width := 200;
	self.height := 35;
	
	self.caption := null;
	//self.parentAspect := ParentAspect_None;
	self.borderStyle := BorderStyle_None;
	self.bevelInner := Bevel_None;
	self.bevelOuter := Bevel_None;
	self.boundaryWidth := 0;
	
	// For creating the control in the actual form, not painter.
	if form.isKindOf(CM_BaseForm) then
		baseForm := form.CM_BaseForm;
	endif;
	
	if self.txtFilterBox = null then
		create self.txtFilterBox transient;
		self.form.addControl(self.txtFilterBox);
		self.txtFilterBox.parent := self;
		self.txtFilterBox.setMyParent(self);
		self.txtFilterBox.visible := true;
		self.txtFilterBox.top := 10;
		self.txtFilterBox.left := 5;
		self.txtFilterBox.width := 160;
		self.txtFilterBox.parentAspect := ParentAspect_StretchRight;
		self.txtFilterBox.maxLength := null;
		self.txtFilterBox.scrollHorizontal := true;
		if baseForm &lt;&gt; null then
			self.txtFilterBox.bubbleHelp := app.getErrorString(TableFilterTextBoxHelp);
		endif;
	endif;
	
	if self.btnClearFilter = null then
		create self.btnClearFilter transient;
		form.addControl(self.btnClearFilter);
		self.btnClearFilter.parent := self;
		self.btnClearFilter.setMyParent(self);
		self.btnClearFilter.visible := true;
		self.btnClearFilter.caption := null;
		self.btnClearFilter.top := 3;
		self.btnClearFilter.left := self.txtFilterBox.left + self.txtFilterBox.width + 3;
		self.btnClearFilter.width := 32;
		self.btnClearFilter.height := 32;
		self.btnClearFilter.parentAspect := ParentAspect_AnchorRight;
		// When creating the control in actual form, set the picture
		if baseForm &lt;&gt; null then
			self.btnClearFilter.picture := baseForm.picClear.picture;
		endif;
	endif;
	
	// Start notification to do table filter.
	if not self.isInPainter() then
		self.beginNotification(form, self.ShowCaptionEvent, Response_Continuous, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e2e316ef-8308-42ab-98ad-a4f6e0e5ad4b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if not self.isInPainter() then
		self.endNotification(form, self.ShowCaptionEvent);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCallBackMethod" id="619254b0-c363-4c60-87c4-142c669a9fb8">
        <source>doCallBackMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if self.callbackMethod &lt;&gt; null then
		self.form.sendMsg(self.callbackMethod);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearFilter" id="8f72596c-6823-4c12-bef8-6b79a59da26b">
        <updating/>
        <source>doClearFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars
	numOfVisibleRows,
	row,
	start,
	totalRows	: Integer;
	theTable	: CM_DataTable;
	allText 	: HugeStringArray;
	filterText	: String;
begin
	self.txtFilterBox.text := null;

	// ### JIRA 35966 08DEC2025 NAVAB1
	app.mousePointer := MousePointer_HourGlass;	 
	if self.myDataTable.isPaginated then
		self.myDataTable.refreshEntries(null);
		return;
	endif;	

	//15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
	//self.doTableFilter();
	
	//15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784 Do clear filter here
	create allText transient;
	
	filterText := self.txtFilterBox.text;
	filterText.parseCSV(allText);
	theTable := self.myDataTable;
	
	theTable.filterRowHasAllText(allText, numOfVisibleRows);
	self.numOfRowVisible := numOfVisibleRows;
	
	self.doCallBackMethod();
	
epilog
	app.mousePointer := MousePointer_Default; // ### JIRA 35966 08DEC2025 NAVAB1

	delete allText;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableFilter" id="3855ff10-7b1d-4cea-be9e-9c998e7ec608">
        <updating/>
        <source>doTableFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars
	filterText : String;
	allText		: HugeStringArray;
begin

 // ### JIRA 35966 08DEC2025 NAVAB1
	app.mousePointer := MousePointer_HourGlass;
	if self.myDataTable.isPaginated then
		self.myDataTable.refreshEntries(null);
		return;
	endif;
	
	create allText transient;
	
	filterText := self.txtFilterBox.text;
	filterText.parseCSV(allText);
	
	//02/08/2024	navkc1 Defect 65489
	if not self.skipControlFilter then
		self.myDataTable.filterRowHasAllText(allText, self.numOfRowVisible);
	endif;
	
	self.doCallBackMethod();
	
epilog
	app.mousePointer := MousePointer_Default; // ### JIRA 35966 08DEC2025 NAVAB1
	
	delete allText;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="82d5d558-0b87-469f-b942-b7a0024e0151">
        <updating/>
        <source>init(_showCaptions: Boolean) updating;
/*

Purpose:			This is called when we add the frame to CMUI_Toolbar. So, customized settings for Toolbar to be done in this method.

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1	CR 63736 Task 63737: Jade - New Filter Control
12/07/2024	navmd1	Make the clear button follow the same alignment as the rest of the frame

*/

vars
	frameAlignment : Integer;
begin
	inheritMethod(_showCaptions);
	
	// Do this so the Toolbar has a standard Toolbar Button.
	if self.btnClearFilter &lt;&gt; null then
		self.btnClearFilter.caption := "Clear";
		self.btnClearFilter.parent := self.myToolbar;
		self.btnClearFilter.top := -10000; // Hacky way to make the btn disappear
	endif;
	
	if self.txtFilterBox &lt;&gt; null then
		self.txtFilterBox.top := 3;
		// Increase the width of the textbox to utilize the space as the btn will not be visible (*in toolbar we display the toolbar button)
		self.txtFilterBox.width += self.btnClearFilter.width;
	endif;
	
	// For reasons that are a bit beyond me, the button isn't included in the frame ...
	// so make sure we add it with the same alignment as the frame itself, so it always appears on the right of the textbox
	if self.myToolbar.allLeftControls.includes(self) then
		frameAlignment := CMUI_Toolbar.Control_Alignment_Left;
	else
		frameAlignment := CMUI_Toolbar.Control_Alignment_Right;
	endif;
	
	self.myToolbar.addButton(self.btnClearFilter, frameAlignment);
	
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCallbackMethod" id="d983fddc-21d8-42f4-8b11-9c6d5ced4a3d">
        <updating/>
        <source>setCallbackMethod(_methodName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

