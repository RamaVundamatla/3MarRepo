    <JadeMethod name="pxyCreateUpdateProxy" id="689684e3-2d66-40fc-b892-2fd1364c8191">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 23 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyStateData : CM_StateData;
	completedOK		: Boolean;
	
begin
	pxyStateData := inheritMethod();
	pxyStateData.myBOL := self.myBOL;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyStateData;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyStateData;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="set" id="810405db-3fb5-4026-906a-d495d6d848b5">
        <updating/>
        <source>set(_key : String; _value : Any; _parent : Object) updating;

vars

begin

	self.key := _key;
	self.setValue(_value);

	if _parent.isKindOf(CM_StateObject) then
		self.myStateObject := _parent.CM_StateObject;
	elseif _parent.isKindOf(CM_BOL) then
		self.myBOL := _parent.CM_BOL;
	elseif _parent.isKindOf(CM_TrackedItem) then
		//Soon to be implemented
		self.myTrackedItem := _parent.CM_TrackedItem;
	elseif _parent.isKindOf(CM_RTVehicleConfig) or
	    _parent.isKindOf(CM_StorageDetail) or 
		 _parent.isKindOf(CM_CashReceipt) or //03 Feb 2014	NDL	Par 33181
		_parent.isKindOf(CM_StorageConfig) then
		// oops forgot to inverse or not inversed to avoid a reorg at the time
	elseif _parent.isKindOf(CM_Object) then
		self.myParent := _parent.CM_Object;
	else
		// no error here as used in sub-schemas where we cannot inverse
	endif;
	
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_parent" type="Object"/>
    </JadeMethod>
