    <JadeMethod name="auditIdDisplay" id="3be0f34e-d4dc-4ef5-8347-f1e9229c03a9">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin
	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Currency_rate) &amp; " - " &amp; self.auditId();
	else
		return app.getErrorString(Currency_rate);
	endif;

epilog

end;</source>
