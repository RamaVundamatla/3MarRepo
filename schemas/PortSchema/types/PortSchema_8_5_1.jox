    <JadeMethod name="fixInvoiceReportTemplates" id="c9dca2aa-2483-4a4e-bd6f-52094ef4035e">
        <source>fixInvoiceReportTemplates();
/*

Purpose:			Fix any Invoice Report Templates which have been corrupted by the Report
					Runner UI bug reported in PARs #36903 &amp; 36755

Parameters:			None

Return Value:		None

Date		Who		Reason
02 Dec 2015	cnwkpd1	PAR #36903 - Templated invoice reports not working correctly

*/

vars
	ci				: CMQF_Invoice;
	oa				: ObjectArray;
	iter			: Iterator;
	firstBank		: CM_Bank;
	firstTerminal	: CM_Terminal;
	msg				: String;
	templates,
	badCount		: Integer;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " checking Invoice Report Templates", null);
	
	create oa transient;
	CMQF_Invoice.allInstances(oa, 0, true);

	beginTransaction;
	
	iter := oa.createIterator();
	while iter.next(ci) do
		if ci.myBGPRequest &lt;&gt; null and ci.myBGPRequest.myReportTemplate &lt;&gt; null then
		
			templates := templates + 1;
			
			// Can only have one company, but checking anyway
			if ci.allCompaniesByCode.size() = 1 and ci.allTerminals.size() = 1 then
			
				firstBank := ci.allCompaniesByCode.first();
				firstTerminal := ci.allTerminals.first();
			
				msg := "No company";
				if app.isValidObject(firstBank) then
					if firstBank.terminal = firstTerminal then
						msg := "Company matches first Terminal";
					else
						msg := "&gt;&gt;&gt;&gt; Company does not match first Terminal, updated";
						ci.allCompaniesByCode.clear();
						ci.allCompaniesByCode.add(firstTerminal.companies.first());
						badCount := badCount + 1;
					endif;
				endif;
			
				app.writeLog(ci.myBGPRequest.myReportTemplate.name &amp; " " &amp; firstBank.String &amp; " " &amp; firstTerminal.String &amp; " " &amp; msg, 0);
			endif;
		endif;	
	endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; templates.String &amp; " templates checked, " &amp; badCount.String &amp; " errors found and fixed", 0);
	
	self.addScriptRun(method.name);

		
epilog
	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="fixMachTypesThatDontSuppRT" id="b4da6f77-b03b-40a4-9e59-24777e3ecfdc">
        <source>fixMachTypesThatDontSuppRT(_controller: CnEcReleaseController);
/*

Purpose:			Portainer Cranes are not currently allowed VMTs, and should not have been allowed to be setup as one

Parameters:			

Return Value:		


Date			Who		Reason
14 May 2018		jlgmd1	Initial creation TFS #38555 MSL PORTAINER CRANE IN RT

*/

vars
	root : CM_Root;
	machine : CM_Machine;
	machineType : CM_MachineType;
	iter : Iterator;
	auditAgent : CM_UpdateTransactionAuditAgent;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fix Machines being incorrectly allowed to support RT when they shouldn't", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fix Machines being incorrectly allowed to support RT when they shouldn't") ;	
	endif;
	
	create auditAgent transient;
	
	root := CM_Root.firstInstance;
	iter := root.allMachines.createIterator;
	
	beginTransaction;
	
	while iter.next(machine) do
		if not app.isValidObject(machine) then
			continue;
		endif;
		
		machineType := null;
		machineType := app.myRoot.allMachineTypes[machine.machineType];
		
		if machineType &lt;&gt; null and not machineType.supportsRT then
			auditAgent.audUpdateGeneric(machine, true);
			machine.setPropertyValue('hasRadioTelemetry', false);
			machine.setPropertyValue('myRTDevice', null);
			machine.setPropertyValue('canWeighCargo', false);
			machine.setPropertyValue('canCertifyWeight', false);
			auditAgent.audUpdateGeneric(machine, false);
		endif;
	endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing Machines being incorrectly allowed to support RT when they shouldn't",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished fixing Machines being incorrectly allowed to support RT when they shouldn't");
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete iter;
	delete auditAgent;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixMergedCargoBolRef" id="6792da9a-f4e7-4d21-9f2a-2a90fa8c7a88">
        <source>fixMergedCargoBolRef(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 01 Feb	  2017  cnwma1	TFS #3269 PAR38601 STWO - Duplicate cargo lines being created in Voyage BOL maintenance screen
*/

vars
	ti : CM_TrackedItem ;
	count :Integer;
	objArr : ObjectArray;
	obj : Object;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	
	app.writeLog(method.qualifiedName &amp; "Fixing BOL Refrences from Merged Tracked Items", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fixing BOL Refrences from Merged Tracked Items");
	endif;
	
	create objArr transient;
	CM_Cargo.allInstances(objArr,0,true);
	beginTransaction;
	foreach obj in objArr where obj.CM_Cargo.myBOLDtl &lt;&gt; null do 
		if obj.CM_Cargo.state = TI_STATE_MERGED  then
			count := count+1;
			obj.CM_Cargo.setBOLDtl(null);				//01/02/2016 cnwma1 TFS #3269
			obj.CM_Cargo.setMyReceivalBOL(null);		//01/02/2016 cnwma1 TFS #3269
			obj.CM_Cargo.setBOL(null);					//01/02/2016 cnwma1 TFS #3269
		endif;
	endforeach;
	commitTransaction;
	app.writeLog(method.qualifiedName &amp; "Completing Fixing :" &amp;count.asStringJMT&amp;" BOL Refrences from Merged Tracked Items ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(count.asStringJMT&amp; "Completing Fixing :" &amp;count.asStringJMT&amp;" BOL Refrences from Merged Tracked Items ");
	endif;
	self.addScriptRun(method.name);
epilog
	delete objArr;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixReportTemplatePrinters" id="b5233ae8-3594-498a-984d-c0112fedc043">
        <source>fixReportTemplatePrinters(_controller: CnEcReleaseController);

/*

Purpose:			Check to see if the wrong (logical) printer name has been associated to any report templates
					and if it has, swap it with the physical printer name by just updating/re-saving the report template
	
Parameters:			

Return Value:		


Date				Who		Reason
12 October 2017		jlgmd1	TFS 7140 DPH - message box in bgp process
27 October 2017		jlgmd1	Added check for users who no longer have access to a report
09 November 2017 	jlgmd1	Rewrote method to use its own updating trx/utl method to update printer names
							without affecting other data. (eg, users who no longer have access to the report)
15 May 2018			jlgmd1	Moved 'finished' log out of the epilog so it doesn't say it finishes running every release (oops!)

*/

vars
	isOk 				: Boolean;
	request				: BGP_ReportRequest;
	requestsToFix,
	reqArray			: ObjectArray;
	obj					: Object;
	correctPrinters 	: HugeStringArray;	// Just in case we have a long printer name
	printerName 		: String;
	printer 			: CM_PrinterDef;
	reqNum 				: Integer;
	msg 			: String;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fixing BGP Report Requests printers", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fixing BGP Report Requests printers");
	endif;
	
	create reqArray transient;
	create requestsToFix transient;
	create correctPrinters transient;
	
	// Get all our BGP requests
	BGP_ReportRequest.allInstances(reqArray, 0, true);
	
	foreach obj in reqArray discreteLock do
		
		request := obj.BGP_ReportRequest;
		if request = null then
			continue;
		endif;
		
		printerName := request.printerName;
		printer := app.myRoot.getPrinter(printerName);
	
		// If printer is not null then we've found a printer based on its logical name. This is not what we want.
		// Only change to the physical name if its actually different from the logical one!
		if printer &lt;&gt; null and printerName &lt;&gt; printer.physicalPrinterName then
			// Change from logical to physical printer name (even if the physical printer name is blank)
			printerName := printer.physicalPrinterName;
		else
			// We (hopefully) already have the correct printer name, so lets go to the next one
			continue;
		endif;
		
		requestsToFix.add(request);
		correctPrinters.add(printerName);
	
	endforeach;
	
	isOk := requestsToFix.size = correctPrinters.size;
	reqNum := 1;
	
	if not isOk then
		msg := "Request object array size [" &amp; requestsToFix.size.String &amp; "] does not match printer array size [" &amp; correctPrinters.size.String &amp; "]";
	endif;
	
	while reqNum &lt;= requestsToFix.size and isOk do
		
		// Grab our request
		request := requestsToFix[reqNum].BGP_ReportRequest;
		// Log what we are changing
		msg := "Changing printer [" &amp; request.printerName &amp; "] to [" &amp; correctPrinters[reqNum] &amp; "] for " &amp; request.getOidAsString;
		app.writeLog(method.qualifiedName &amp; " " &amp; msg, LogINFO);
		
		// Update the printer name
		app.myTrxUA.trxUpdateBGPReqPrinterName(request, correctPrinters[reqNum], app.myPassport);
		
		if app.myPassport.hasErrorsOrWarnings then
			isOk := false;
			msg := app.myPassport.getAllErrorsWarningsAsString();
		endif;
			
		reqNum := reqNum + 1;	// next
	endwhile;
	
	if isOk then
		self.addScriptRun(method.name);
	else
		app.writeLog(method.qualifiedName &amp; " " &amp; msg, LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg);
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing BGP Report Requests printers", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished fixing BGP Report Requests printers");
	endif;
	
epilog
	delete requestsToFix;
	delete correctPrinters;
	delete reqArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupEDIJMTInternalLicense" id="8159fac4-cbcf-40a2-9abd-e03b24ecb056">
        <source>fixupEDIJMTInternalLicense();
//
//08 Jun 2014	cnwrs1	change number from 117 to 116
//
vars
	ediFileType116 : CM_EDIFileTypeXMLJMTInternal;
	ediFileType117 : CM_EDIFileTypeXMLJMTInternal;
	jmtInternal : CM_EDIFileTypeXMLJMTInternal;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Fixc up EDI JMT License", LogINFO);
	if CM_EDIFileTypeXMLJMTInternal.instances.size &gt; 1 then
		ediFileType116 := app.myRoot.allEDIFileTypes[116, "JMT Internal"].CM_EDIFileTypeXMLJMTInternal;
		ediFileType117 := app.myRoot.allEDIFileTypes[117, "JMT Internal"].CM_EDIFileTypeXMLJMTInternal;
		if ediFileType116 &lt;&gt; null and 
		   ediFileType117 = null then
			self.addScriptRun(method.name);
			return;
		endif;
		if ediFileType116 &lt;&gt; null and 
		   ediFileType117 &lt;&gt; null then
			beginTransaction;
			delete ediFileType117;
			commitTransaction;
		endif;
	endif;
	
	jmtInternal := CM_EDIFileTypeXMLJMTInternal.firstInstance;
	
	if jmtInternal &lt;&gt; null then
		beginTransaction;
		CM_EDIFileTypeXMLJMTInternal.firstInstance.setPropertyValue(CM_EDIFileType::type.name, EDIFileType_JMTInternal);
		commitTransaction;
	endif;
	app.writeLog(method.qualifiedName &amp; " Fixc up EDI JMT License - Complete", LogINFO);
	self.addScriptRun(method.name);

end;
</source>
    </JadeMethod>
    <JadeMethod name="fixupEntTableRow" id="e6577e29-d7ec-4981-b673-3d92c680ab5c">
        <source>fixupEntTableRow();
//
// Purpose:			Rename an ent table row's heading
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/10/2016	cnwdap1		Initial creation TFS 2791
//
vars
	row : EntTableRow;
	root : CM_EntTableDataRoot;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Correcting ETRow_ForceUEMoveAmountAtGate's heading", LogINFO);
	
	root := CM_EntTableDataRoot.firstInstance;
	if root = null then
		return;
	endif;
	row := root.allEntTableRowsByNumber[260588];
	if row = null then
		return;
	endif;
	beginTransaction;
	row.setPropertyValue(EntTableRow::heading.name, "Force User entry of 'Amount' at Gate In for Bulk/Break-Bulk");
	commitTransaction;

	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Correcting ETRow_ForceUEMoveAmountAtGate's heading complete", LogINFO);	
epilog

end;</source>
    </JadeMethod>
