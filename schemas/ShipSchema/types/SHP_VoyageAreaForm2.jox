    <JadeMethod name="initSelectorControlsForVoyage" id="ecb64422-8896-4231-a08c-45af3bffdb2b">
        <source>initSelectorControlsForVoyage(_voyage : CM_Voyage;
	_resetBaySelector, _resetHoldSelector : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aBay : CM_BayVoyage;
begin
	if _resetBaySelector then
		self.cmbBays.clear;
	endif;
	
	if _voyage = null then
		if _resetHoldSelector then
			self.msgHolds.setAvailable(null, true);
			self.msgHolds.setSelected(null);
		endif;
		return;
	endif;
	
	// setup controls for bay selector
	
	if _resetBaySelector then
		self.cmbBays.sorted := false;
	
		foreach aBay in _voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal do
			self.cmbBays.addItemObject(aBay.id, aBay);
		endforeach;
	endif;

	if _resetHoldSelector then
		// setup controls for Hold selector
		if self.selectMode = self.SelectModeHold then
			self.msgHolds.setAvailable(_voyage.myCellularVoyageStructure.allHolds, true);
			self.msgHolds.setSelected(null);
		else
			self.msgHolds.setAvailable(_voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal, true);
			self.msgHolds.setSelected(null);
		
		endif;
		self.btnSelectVoyOK.bubbleHelp := "Show " &amp; self.cmbVoyage.text;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resetBaySelector" type="Boolean"/>
        <Parameter name="_resetHoldSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initWithObject" id="db3a7a2e-0d4a-489c-bf7a-bf9bd5146273">
        <updating/>
        <source>initWithObject() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 9032 - show new form with same bay.
//
// ---------------------------------------------------------------------------
vars
	aHold : CM_Hold;
	aBay : CM_Bay;

begin
	if not self.allSelectedHolds.isEmpty then
		// PAR 10518. This is being called from another Planning form. i.e. then NEW planning window has been clicked. 
		//				So the default is actual. If the original screen is in actual then switch to proposed, so that the switchDisplayMode called below sets the toolbars correctly
		if self.displayMode = ShpDisplayMode_Actual then // PAR 10518
			self.switchDisplayMode(ShpDisplayMode_Proposed,false);	// PAR 10518	
		endif;
		self.top := self.top + 20;
		self.left := self.left + 20;
		self.cmbBayVoyage.listObject := self.myCurrentVoyage;
		self.cmbVoyage.listObject := self.myCurrentVoyage;
		self.myCurrentVoyage := null;
//		if self.myBayDrawingController.myConfig.shipSelectByHolds then
		if self.selectMode = self.SelectModeHold then
			self.cmbVoyage.click(self.cmbVoyage);
			self.msgHolds.setSelected(self.allSelectedHolds);
			self.btnSelectVoyOK.click(self.btnSelectVoyOK);
		elseif self.selectMode = self.SelectModeMulti then
			self.cmbVoyage.click(self.cmbVoyage);
			self.msgHolds.setSelected(self.allSelectedBays);
			self.btnSelectVoyOK.click(self.btnSelectVoyOK);
		elseif self.selectMode = self.SelectModeOne then
			// Par14046 Mohammad 17/5/2007
			aHold := self.allSelectedHolds.first;
			self.cmbBayVoyage.click(self.cmbBayVoyage);
			if aHold &lt;&gt; null then
				if self.myStartUpBay &lt;&gt; null then
					aBay := self.myStartUpBay;
				else
					aBay := aHold.allBays.first;
				endif;
				self.cmbBays.listObject := aBay;
				self.cmbBays.click(self.cmbBays);
			endif;	
		endif;
		self.switchDisplayMode(self.displayModeHistory,true);		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="451be881-27f6-4b47-81a2-79022c553bce">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if keyCode = CMUI_Key_F5 then
		// a menu has the F5 key defined as a hot-key so ignore here
		return;
	endif;
	
	if keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		self.myDrawingFrame.clearUpDragDrop();
		self.myBayDrawingController.clearUpDragDrop();
		return;
	endif;
	
	if keyCode = J_key_P then 
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			if self.frmPrintConfirm.visible then
				self.frmPrintConfirm.visible := false;
			else
				self.showPrintFrame(null,null);
			endif;
		endif;
		
		return;
	endif;
	
	if keyCode = CMUI_Key_F9 and app.isSpecial() then
		if self.displayMode = ShpDisplayMode_Actual or self.displayMode = ShpDisplayMode_Proposed then
			self.showMagnifyFrame();
		else
			app.msgBox("Magnify Mode only for Actual and Proposed display modes.","Problem", MsgBox_Information_Icon);
		endif;
		
		
	endif;
	
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm();
		else
//			if self.myBayDrawingController.myConfig.shipSelectByHolds then
			if self.selectMode = self.SelectModeHold or self.selectMode = self.SelectModeMulti then
				if self.frmSelectVoyage.visible then
					self.frmSelectVoyage.visible := false;
				else
					self.showHoldSelector(self.selectMode);
				endif;
			else
				if self.frmSelectBay.visible then
					self.frmSelectBay.visible := false;
				else
					self.showSelectBays(0,0);
				endif;
			endif;
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="layoutRedraw" id="32f1834d-ff26-451a-80cd-d6a8ffd21809">
        <updating/>
        <source>layoutRedraw(_evenIfHidden : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	msg			: String;
	theX1,theX2,theY1,theY2 : Integer;
	theWidth, theHeight, theTop, theLeft : Integer;
	theMainFrame, theViewFrame : Frame;
	theScale, numCol, numRow : Integer;
	thePCWidth, thePCHeight, thePCHScroll, thePCVScroll : Real;
	aReal : Real;
	tmpDkbPos	: CMUI_JadeDockBar;
	saveVisible	: Boolean;
begin
	tmpDkbPos := self.dkbPosition;

	if (not tmpDkbPos.visible) and
	   (not _evenIfHidden) then
		return;
	endif;

	theMainFrame := self.frmPosition;
	theViewFrame := self.frmPositionView;
	
	if self.myCurrentDrawingController.scaleFactor =1 then
		self.positionScale := 4;
	elseif self.myCurrentDrawingController.scaleFactor = 1.5 then
		self.positionScale := 5;
	elseif self.myCurrentDrawingController.scaleFactor = 2 then
		self.positionScale := 7;
	elseif self.myCurrentDrawingController.scaleFactor = 3 then
		self.positionScale := 10;
	elseif self.myCurrentDrawingController.scaleFactor = 4 then
		self.positionScale := 13;
	elseif self.myCurrentDrawingController.scaleFactor = 6 then
		self.positionScale := 19;
	elseif self.myCurrentDrawingController.scaleFactor = 9 then
		self.positionScale := 28;
	else
		self.positionScale := 10;
	endif;
	theScale := self.positionScale;
	
	theTop := (self.frmToolbar2.top + self.frmToolbar2.height + 1).Integer;
	theLeft := 100;

	tmpDkbPos.zOrder(1);
	
	// save and reset visible status so that
	// the floating frame is resized
	saveVisible := tmpDkbPos.visible;
	if saveVisible then
		tmpDkbPos.visible := false;
	endif;

//	tmpDkbPos.width := ((self.myDrawingFrame.width / theScale) + 15).max(self.frmPosToolbar.getMinWidth() + 20);
	tmpDkbPos.width := ((self.myDrawingFrame.width / theScale) + 15);
	tmpDkbPos.height := (self.myDrawingFrame.height / theScale) + 15 + 25;

	tmpDkbPos.visible := saveVisible;

	self.frmPosToolbar.width := tmpDkbPos.clientWidth;
	self.frmPosToolbar.repositionAfterResize();

	// Draw the new view
	theMainFrame.clearGraphics;
	self.myBayDrawingController.drawMinature(theMainFrame, theScale);
	
	self.scrollPositionFrame();
	/*
	theViewFrame.move((self.dkbGridArea.myScrollableFrame.getHScrollValue / theScale),
					  (self.dkbGridArea.myScrollableFrame.getVScrollValue / theScale),
					  (self.dkbGridArea.myScrollableFrame.width / theScale), 
					  (self.dkbGridArea.myScrollableFrame.height / theScale));
	*/
	theMainFrame.refreshNow();

	theViewFrame.clearGraphics;
	theViewFrame.drawRectangle(0, 0, theViewFrame.clientWidth, theViewFrame.clientHeight, Red);

end;</source>
        <access>protected</access>
        <Parameter name="_evenIfHidden" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="35626b4e-97d3-46a0-bbf9-c9fa8f6bb654">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	COMBOTOP = 1;
vars
	shipSLiftIfTLWgtExced, shipSLiftIfDiffHeights : Boolean;
begin
	if self.myBayDrawingController.myConfig.shipSelectByHolds then
		self.selectMode := self.SelectModeHold;
		self.showHoldSelector(self.selectMode);
		self.mnuGridLayout.visible := true;
		self.mnuWorkDisplayLayout.visible := true;
		self.mnuBaySelHolds.checked := true;
	elseif self.myBayDrawingController.myConfig.shipSelectByBayMulti then
		self.selectMode := self.SelectModeMulti;
		self.showHoldSelector(self.selectMode);
		self.mnuGridLayout.visible := true;
		self.mnuWorkDisplayLayout.visible := true;
		self.mnuBaySelMulti.checked :=true;
	// ### DEFAULT, for first time
	else //if self.myBayDrawingController.myConfig.shipSelectByBayOne then 
		self.selectMode := self.SelectModeOne;
		self.showSelectBays(0,0);
		self.mnuGridLayout.visible := false;
		self.mnuWorkDisplayLayout.visible := false;
		self.mnuBaySelOne.checked := true;
		self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayOne := true;
		app.myTrxUA.trxUpdateUserConfig(app.getMyUser, self.myConfig, app.myPassport);
	endif;

	self.positionScale := 10;
	inheritMethod();

	self.cmbPortDis.move(2, COMBOTOP, ComboWidth_Max, self.cmbPortDis.height);
	self.cmbCommodity.move(self.cmbPortDis.left + self.cmbPortDis.width + 2, COMBOTOP, ComboWidth_Max, self.cmbCommodity.height);
	self.cmbCrane.move(self.cmbPortDis.left, COMBOTOP, ComboWidth_Max, self.cmbCrane.height);
	self.cmbJob.move(self.cmbCommodity.left, COMBOTOP, ComboWidth_Max, self.cmbJob.height);
	self.cmbCargoType.move(self.cmbCommodity.left + ComboWidth_Max + 2, COMBOTOP, ComboWidth_Max, self.cmbCargoType.height);
	self.txtJobLinkLoad.move(self.cmbCargoType.left, COMBOTOP, TxtJobLinkLoad_Width, self.txtJobLinkLoad.height);
	self.txtWeight.move(self.cmbCargoType.left + cmbCargoType.width + 2, cmbCargoType.top, self.txtWeight.width, self.txtWeight.height);	// cnwdad1 30/07/2010 - PAR #24045.

	self.initCmbCrane();
	self.initCmbSeqAppliesTo();

	if self.displayModeHistory &lt;&gt; null then
		self.switchDisplayMode(self.displayModeHistory,false);		
	else
		self.switchDisplayMode(ShpDisplayMode_Actual, false);
	endif;
	//self.setMyCurrentVoyage(app.myCurrentVoyage, true, true);
	//cwnjo3 par 23105
	self.setMyCurrentVoyage(app.getMyCurrentVoyage(), true, true);
	
	//par14046 Mohammad 17/5/2007
	//if self.myStartUpBay &lt;&gt; null then
	if self.myStartUpBay &lt;&gt; null and not self.allSelectedBays.includes(self.myStartUpBay.CM_BayVoyage) then
		self.allSelectedBays.add(self.myStartUpBay.CM_BayVoyage);
		self.allSelectedHolds.add(self.myStartUpBay.myHold);
	endif;
	// init with object ?????
	self.initWithObject();// PAR 9032
	shipSLiftIfTLWgtExced := self.myTerminal.getConfig(ShipSLiftIfTLWgtExced).Boolean; // 'Make S/Lift if crane twin lift weight exceeded'
	shipSLiftIfDiffHeights := self.myTerminal.getConfig(ShipSLiftIfDiffHeights).Boolean;
	self.chkShipTLHeight.value := shipSLiftIfDiffHeights;
	self.chkShipTLWeight.value := shipSLiftIfTLWgtExced;

end;</source>
        <access>protected</access>
    </JadeMethod>
