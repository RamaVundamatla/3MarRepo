    <JadeMethod name="dataDumpExtractTestVolume" id="85fcd505-0743-465a-9980-00f94ced0e4d">
        <source>dataDumpExtractTestVolume();
// ---------------------------------------------------------------------------
// Created:     24 July 2003 by cnwsb1
//
// Purpose:		Allows for a volume test extract.  Updates the last 100
//				objects in each relevant class, then extracts them.
//				NB: Must be running Change Tracker app at same time in order
//				for this to work.
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
	NumPerClass = 100;

vars
	agent : CM_DataDumpExtractionAgent;
	def : CM_DataDumpExtractDef;
	defEdition : Integer;
	ts : TimeStamp;

begin
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	ts := app.actualTimeServer;
	
	create agent transient;
	agent.initialise("", false, false);
	agent.doExtractTestVolume(
			DDxDefDescription,
			null, ts, NumPerClass);
	agent.finalise;
	
epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpFeatureUpdate" id="543cf6ce-efcf-430f-8b95-1174a0ad12cf">
        <source>dataDumpFeatureUpdate();
//PAR19114 DSS speed up cnwrs1 apr 2009
constants
	DDxDefDescription = "RS SQL NATIVE";
vars
	ddExClass : CM_DataDumpExtractClass;
	aClass : Class;
	ddFeature : CM_DataDumpFeature;
	feature: Feature;
//	property : Property;
	featureAlias : String;
	typeString : String;
	object : CM_Object;
	type, newType : Type;
	length, newLength : Integer;
	ddExDict : CM_DataDumpExtractClassDict;
	_def: CM_DataDumpExtractDef;
	newTypeName : String;
begin
	app.initialize;
	_def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	create ddExDict transient;
	foreach ddExClass in _def.allDataDumpExtractClasses do
		ddExDict.add(ddExClass);
	endforeach;
	foreach ddExClass in ddExDict do
		aClass := ddExClass.myDataDumpClass.myClass;
		beginTransaction;
		foreach ddFeature in ddExClass.allDataDumpFeatures do
			featureAlias := ddFeature.getExternalDatabaseFeatureName(aClass, newType, newLength);
			if newType &lt;&gt; null or
			   newLength &lt;&gt; null or
			   featureAlias &lt;&gt; ddFeature.featureName then
				newTypeName := null;
				if newType &lt;&gt; null then
					newTypeName := newType.name;
				endif;
write aClass.name&amp;'::'&amp;ddFeature.featureName&amp;' '&amp;featureAlias&amp;' '&amp;newTypeName.String&amp;' '&amp;newLength.String;
				ddFeature.setupFeatureChanges(featureAlias, newTypeName, newLength);
				endif;
		endforeach;
		commitTransaction;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpFindChageTrackerRecord" id="249a4220-0b21-40ed-b176-5ff02880871d">
        <source>dataDumpFindChageTrackerRecord();

vars
	schema : Schema;
	class : Class;
	obj : Object;
	iter : Iterator;
	value : String;
	outputStr : String;
	count : Integer;
begin
	schema := rootSchema.getSchema("JSSChangeTrackingSchema");
	class := schema.getClass("JSSCTChangeTrackingObject");
	obj := class.lastInstance;
	
	iter := class.instances.createIterator;
	while iter.back( obj ) do
		count := count + 1;
//		if count &gt; 20 then
//			break;
//		endif;
		outputStr := obj.String;
		value := obj.getPropertyValue("changeObjectID").String;
		if value = "2367.8256851" then
			obj.inspect;
			break;
		endif;
//		outputStr := outputStr &amp; " " &amp; value;
//		write outputStr;
	endwhile;
epilog
	delete iter;
end;
</source>
    </JadeMethod>
