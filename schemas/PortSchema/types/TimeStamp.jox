    <JadeMethod name="asStringTimeDayDate" id="b885d809-c8a1-434d-93ee-97e972cfcd60">
        <source>asStringTimeDayDate() : String;

/*

Purpose:			Return the receiver as a String in the format HH:MM ddd DD
					Available for specialised Report Writer reports


Return Value:		String as described, or null if the receiver is invalid


Date		Who		Reason
17 Apr 2008	cnwkpd1	PAR #16521 - Initial creation

*/

vars
	tmpTime			: Time;
	tmpDate			: Date;
	
begin
	if self.isValid() then
		tmpTime := self.time;
		tmpDate := self.date;
		return tmpTime.hour().padLeadingWith("0", 2) &amp; ":" &amp;
			   tmpTime.minute().padLeadingWith("0", 2) &amp; ' ' &amp; 
			   tmpDate.dayName()[1:3] &amp; ' ' &amp;
			   tmpDate.day.String;
				  
	else 
		return null;
	endif;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
