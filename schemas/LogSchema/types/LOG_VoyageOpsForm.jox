    <JadeMethod name="tblVoyTermDtlIncludesTerm" id="5f80cbcf-c951-4f1d-a420-631c95083db7">
        <source>tblVoyTermDtlIncludesTerm(_terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 April 2005	cnwhjg1
//
// Purpose:     Par 9608 
// ----------   ----------  --------------------------------------------------
vars
	row		: Integer;
	tblTerminal	: CM_Terminal;
	
begin
	tblTerminal := _terminal; 
	row := 2;			// items in table start at row 2 
	
	while row &lt;= tblVoyTermDtl.rows do	
		if tblTerminal = tblVoyTermDtl.accessCell(row, 1).itemObject then
			return true;	
		endif;
		row := row + 1;
	endwhile;
	
	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblVoyTermDtl_dblClick" id="ea83413b-cc6b-44ff-a8f7-daf4b20cd277">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblVoyTermDtl_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRow,
	tmpCol	: Integer;
begin
	// need to validate that this is date column
	tmpRow := table.row;
	tmpCol := table.column;
	if tmpRow &gt; table.fixedRows and
	   (tmpCol = 4 or tmpCol = 6 or tmpCol = 8 or tmpCol = 10) then
		table.showCalenderForm(tmpRow, tmpCol);
	endif;
end;</source>
