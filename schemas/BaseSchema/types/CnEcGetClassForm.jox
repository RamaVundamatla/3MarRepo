begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formLoad" id="9207902e-f0ff-4114-9950-b21606be8fe8">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnBrowse.enabled	:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="6eeffe7a-e8ef-42fb-82df-357372e9d6b1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg("");
end;</source>
    </JadeMethod>
    <JadeMethod name="txtClassName_change" id="0f0b1c9b-ce1c-41f2-8dca-212b3681dacc">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtClassName_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	position	: Integer;

begin
	if (textbox.text.trimBlanks.length = 0) then
		btnBrowse.enabled	:=	false;
	else
		position			:=	textbox.selStart;
		textbox.text.firstCharToUpper;
		textbox.selStart	:=	position;
		btnBrowse.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="viewClass" id="82296388-2427-4b14-b591-29641bd5d4b1">
        <source>viewClass():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Gets the requested class, and loads the object browser with it.
//
// Parameters:	None
// Returns:		Boolean - Indicates whether the requestion class is valid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	browserForm	: CnEcObjectBrowserForm;
	className	: String;
	theClass	: Class;

begin
	className	:=	txtClassName.text.trimBlanks;
	theClass	:=	currentSchema.getClass(className);

	if (theClass = null) or (theClass.isSystemObject) then
		app.msgBox(	"Class name not found.  The class name is case sensitive, and system classes are ignored.",
					"Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	else
		create browserForm;
		browserForm.setMyClass(theClass);
		browserForm.show();
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
