    <JadeMethod name="createDetailObjects" id="2e70e98b-c39e-4e2f-be0a-321bd29f3970">
        <source>createDetailObjects() : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	orderLinePxy	: CM_StockOrderLine;
	tbl, tblDetail 	: CM_DataTable;
	currentRow, row,
	lineType		: Integer;
	classToCreate	: Class;
	goToRow			: String;
	blnReturn : Boolean;
begin
		
	// clear objectss in here as will store newly created proxies in here. 
	self.allDetailObjects.clear();
	
	tblDetail := self.tblDataDetail;

	// go through each line and create order line	
	foreach row in tblDetail.fixedRows + 1 to tblDetail.rows do  
		currentRow := row;
		if not self.createPrxyOrderLineFrmTableRow(currentRow)then 
			blnReturn := true;
			break;
		endif;
	endforeach;
	
	if blnReturn  then 
		// have had a validation error so delete all proxies and return
		self.allDetailObjects.purge();
		return false;
	endif;
	
	return true;
epilog
//	self.tblDetailEnt.setFocus();
//	self.tblDetailEnt.goToRowByName(goToRow);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDetailOrderLineItem" id="47e29d6e-c1d2-4d9f-8455-73ede2223a68">
        <source>createDetailOrderLineItem(_row : Integer) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	ti,ti2			: CM_TrackedItem;
	tbl				: CM_DataTable;
	currentRow,
	row,
	numRows			: Integer;
	hitDuplicate	: Boolean;
	orderLinePxy 	: CM_StockOrderTILine;
begin

	
	tbl := self.tblDataDetail;
	
	currentRow := _row;
	ti := self.getTblDataDetailTI(currentRow);
	
	if ti = null then
		app.msgBox('You must assign a general cargo item to row ' &amp; (currentRow - tbl.fixedRows).String, 'No item selected', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	tbl := self.tblDataDetail;
	numRows := tbl.rows;

	// check each row to see if duplicate TI;s	
	foreach row in currentRow + 1 to numRows do
		// if row is a Item Allocation do check else dont worry about checking.
		if self.getTblDataDetailRowLineType(row) = StockOrderLine_TI then
			ti2 := getTblDataDetailTI(row);
			
			//if same then break and return error
			if ti2 = ti then
				hitDuplicate := true;
				break;
			endif;
		endif;
	endforeach;

	if hitDuplicate then
		app.msgBox('There is already an order line added for this item (' &amp; ti2.id &amp; ')','Duplicate order line', MsgBox_Exclamation_Mark_Icon);
//		_goToRow := ETRow_Id;
		return false;
	endif;

	create orderLinePxy as CM_StockOrderTILine transient;
	orderLinePxy.CM_StockOrderTILine.setProxy(ti);
	
	tbl.accessRow(_row).itemObject := orderLinePxy; // add to table incase edit fails and save is attempted again. 
	self.allDetailObjects.add(orderLinePxy);

	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDetailOrderLineProduct" id="05dbb015-e1f9-433e-b661-717994146d9a">
        <source>createDetailOrderLineProduct(_row : Integer) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	product,
	product2		: CM_Product;
	tbl				: CM_DataTable;
	reqdQuantity,
	row,
	numRows,
	currentRow		: Integer;
	hitDuplicate	: Boolean;
	orderLine		: CM_StockOrderLine;
	txtQuantity		: CMUI_TextBox;
	orderLinePxy 	: CM_StockOrderProductLine;
begin

	currentRow := _row;
	tbl := self.tblDataDetail;
	numRows := tbl.rows;
	
	product := self.getTblDataDetailProduct(currentRow);
	reqdQuantity := self.getTblDataDetailQuantity(currentRow);

	if product = null and reqdQuantity = null then
		// ignore this line
		return true;
	endif;

	if product = null then
		app.msgBox(app.getErrorString(Select_cargo_subtype_for_row) &amp;' ' &amp; (currentRow - tbl.fixedRows).String, app.getErrorString(No_cargo_subtype_selected), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if reqdQuantity &lt; 1 then
		app.msgBox('You must specify a required quantity for row ' &amp; (currentRow - tbl.fixedRows).String, 'No quantity specified', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	// check no dupilcate order lines for products. 
	foreach row in currentRow + 1 to numRows do
		// check products
		if self.getTblDataDetailRowLineType(row) = StockOrderLine_Product then	
			product2 := self.getTblDataDetailProduct(row);
	
			if product2 = product then
				hitDuplicate := true;
				break;
			endif;
		endif;
	endforeach;

	if hitDuplicate then
		app.msgBox( app.getErrorString1(AlreadyOrderLineForCargoSubtyp,product2.code), app.getErrorString(Duplicate_cargoSub_allocation), MsgBox_Exclamation_Mark_Icon);
		//		_goToRow := ETRow_MyProduct;
		return false;
	endif;
	
	create orderLinePxy as CM_StockOrderProductLine transient;
	orderLinePxy.CM_StockOrderProductLine.setProxyForOrderLine(product,reqdQuantity,
												null, null, null, null, null, null);
	
	tbl.accessRow(_row).itemObject := orderLinePxy;
	self.allDetailObjects.add(orderLinePxy);
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDetailProxies" id="a1dd35c9-d2f9-4461-9407-806dd8af7cf5">
        <updating/>
        <source>createDetailProxies() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyOrderLine,
	orderLine			: CM_StockOrderLine;
	stkOrd				: CM_StockOrderHeaderGeneric;
	tbl					: CM_DataTable;
	entDef				: EntTableDef;
begin
	stkOrd := self.myCurrentMasterPxy.CM_StockOrderHeaderGeneric;
	if stkOrd = null then
		return;
	endif;
	
	self.allDetailObjects.clear();
	stkOrd.allStockOrderLines.copy(self.allDetailObjects);
	tbl := self.tblDataDetail;
	tbl.rows := tbl.fixedRows;
	entDef := self.tblDetailEnt.myEntTableDef;

	foreach orderLine in stkOrd.allStockOrderLines do
		self.addObjectToDetailTable(orderLine);
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createPrxyOrderLineFrmTableRow" id="c28837fb-bd68-4c54-a60c-9f17efabe9bd">
        <source>createPrxyOrderLineFrmTableRow(_row : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	row 				: Integer;
	tbl					: CM_DataTable;
	tmpCmbProd			: CMUI_ComboProduct;
	tmpCmb 				: CMUI_ComboBox;
	lineType,theRow 	: Integer;
	tmpCell 			: JadeTableCell;
	beforeTxt			: String;
	tmpProduct			: CM_Product;
	orderLinePxy 		: CM_StockOrderTILine;
begin
	tbl	:= self.tblDataDetail;
	row	:= _row;

	// get Line Type
	lineType := self.getTblDataDetailRowLineType(_row);
	
	if lineType = 0 then
		// create nothing and ignore row
		return true;
	endif;
	
	if lineType = StockOrderLine_TI then
		if not self.createDetailOrderLineItem(row) then
			return false;
		endif;
	elseif lineType = StockOrderLine_Product then
		if not self.createDetailOrderLineProduct(row) then
			return false;
		endif;		
	else 
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeDetailEntryView" id="0917392a-e9a5-478b-9ccb-f4d68b35cb53">
        <source>doChangeDetailEntryView();
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx,
	lineType			: Integer;	

begin

	idx := self.cmbLineType.listIndex; 
