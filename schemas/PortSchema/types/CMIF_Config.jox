    <JadeMethod name="addConstant" id="16468097-1295-4216-977a-dd24dfc86a38">
        <source>addConstant(_const : Constant; _passport : CM_Passport) protected;
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     Callback method for setAllGlobalConstantValues
//
// Parameters:  None
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars 
	valueStr	: String;

begin
	valueStr := _const.text.cnEcGetTagValueOfName(self.xmlTagForType).String;

	if valueStr = null then
		return;
	endif;

	if (not valueStr.Boolean) then
		return;
	endif;

	valueStr := _const.valueAsString;
	
	if valueStr = null then
		return;
	endif;
	
	self.allGlobalConstantValues.add(valueStr);
end;</source>
        <access>protected</access>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="create" id="590929b0-2304-437b-a5ed-0e78753622ea">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setXMLTagForType();
	self.setAllGlobalConstantValues();

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyStringForProperty" id="dbccc75b-fb33-43d2-b03b-399133475514">
        <source>getKeyStringForProperty(_propName : String) : String protected;
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	keyStr	: String;
	
begin

	keyStr := _propName;
	
	if (not self.allGlobalConstantValues.includes(keyStr)) then
		keyStr[1] := keyStr[1].toUpper;
		
		if (not self.allGlobalConstantValues.includes(keyStr)) then
			keyStr := null; 
		endif;
	endif;

	return keyStr;

end;</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
