    <JadeMethod name="doCmbLocationClick" id="8ff7e0f3-ee8d-4ae9-8507-4c869194e5b6">
        <updating/>
        <source>doCmbLocationClick() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.filtLocationType = LocationType_LC then
		self.myFiltLC := cmbLocation.listObject.CM_LocationsController;
	elseif self.filtLocationType = LocationType_TA then
		self.myFiltTA := cmbLocation.listObject.CM_TerminalArea;
	elseif self.filtLocationType = LocationType_Terminal then
		self.myFiltTerminal := cmbLocation.listObject.CM_Terminal;
	elseif self.filtLocationType = LocationType_Voyage then
		self.myFiltVoyage := cmbLocation.listObject.CM_Voyage;
		cmbVoyageLocn.listCollection(self.myFiltVoyage.allVoyageLocations, false, 0);
		tblEntQuery.setValueByName(ETRow_VoyageLocation, null);		
		self.myFiltLC := null;		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbLocationTypeClick" id="242a37ff-8bab-494f-a713-70410737e028">
        <updating/>
        <source>doCmbLocationTypeClick(_locType : String) updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.tblEntQuery.hideRowByName(ETRow_VoyageLocation, false);

	self.btnValidate.enabled := true;
	self.btnFixupStock.enabled := true;			
			
	if _locType = LocationType_LC then
		self.filtLocationType := LocationType_LC;
		self.loadLocations();

	elseif _locType = LocationType_TA then
		self.filtLocationType := LocationType_TA;
		self.loadTermAreas();

	elseif _locType = LocationType_Terminal then
		self.filtLocationType := LocationType_Terminal;
		self.loadTerminals();

	elseif _locType = LocationType_Voyage then
		self.filtLocationType := LocationType_Voyage;
		self.tblEntQuery.showRowByName(ETRow_VoyageLocation, false);
		//self.btnValidate.enabled := false;
		//self.btnFixupStock.enabled := false;	
		self.loadVoyages();
	endif;
	tblEntQuery.cnEcResizeContents();

end;</source>
        <Parameter name="_locType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doOperatorClick" id="df89a2d4-ed32-4266-b94d-9267001e7d01">
        <updating/>
        <source>doOperatorClick() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
