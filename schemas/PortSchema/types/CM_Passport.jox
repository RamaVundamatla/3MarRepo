	endif; 
	
	if pxyTI.receivedDT &lt;&gt; _realTI.receivedDT then
		isChanged := true;
		old := pxyTI.receivedDT.asStringJMT();
		new := _realTI.receivedDT.asStringJMT();
		self.createLogForStateChange(LOGSTATE,oIdString,'receivedDT',old,new,LOGLEVEL);
