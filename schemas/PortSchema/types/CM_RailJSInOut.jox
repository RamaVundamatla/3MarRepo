//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	return app.railRakeTypeEnumToString(self.outwards);
	/*if self.outwards = Rail_JSIO_Type_In then
		return "Inward Rail";
	elseif self.outwards = Rail_JSIO_Type_Out then
		return  "Outward Rail";
	elseif self.outwards = Rail_JSIO_Type_Build then
		//return "Build Priority Entry";
		return "Rail Release Request";		
	elseif self.outwards = Rail_JSIO_Type_Transit then
		return "Transit Rail";
	endif;
	*/

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="344bef90-b5b7-4ff4-94c2-8bcbbddf5890">
        <source>init();

constants
	Transit = "Transit";
	BuildP = "Build Priority";
vars
	ta : CM_TerminalArea;
	rjsioRake : CM_RailJSInOutRake;
	term				: CM_Terminal;
	termDict			: CM_TerminalByCodeDict;
begin

	//Do the special cases first and then the bulk
	if outwards = Rail_JSIO_Type_Build then
		rjsioRake := inoutRakes[BuildP];
		if rjsioRake = null then
			create rjsioRake;
			rjsioRake.rake := BuildP;
			rjsioRake.inOut := self;
		endif;		
		rjsioRake.init;
		return;
	endif;
	
	termDict := app.myRoot.allTerminals;
	foreach term in termDict do
		foreach ta in term.allTerminalAreas do
			sharedLock(ta);
			if ta.type = TA_TYPE_RAILWAY_TRACK then
				rjsioRake := inoutRakes[ta.id];
				if rjsioRake = null then
					create rjsioRake;
					rjsioRake.rake := ta.id;
					ta.CM_Rail.allRailJSInOut.add(rjsioRake);
					rjsioRake.inOut := self;
				endif;		
				rjsioRake.init;
			endif;
		endforeach;
	
		foreach rjsioRake in inoutRakes do
			ta := term.allTerminalAreas[rjsioRake.rake];
			//check to see this the terminal area has been deleted!
			if ta = null then
				rjsioRake.erase(NORMAL_ERASE);
			endif;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="c9dd9cef-afc1-487d-8f98-519e7ec43f42">
        <source>/*
Author:      cnwspg1
Date:        12 January 2000
Description: Method to setup any rakes that are necessary
						 Assumed to be in transaction state

--------------------
Fixes
*/

initialise(_terminal: CM_Terminal);

//constants
	//Transit = "Transit";
	//BuildP = "Build Priority";
vars
	ta : CM_TerminalArea;
	rjsioRake : CM_RailJSInOutRake;
	term : CM_Terminal;
begin

	//Do the special cases first and then the bulk
	if self.outwards = Rail_JSIO_Type_Build then
		rjsioRake := self.inoutRakes.first; 
		//rjsioRake := inoutRakes[BuildP]; there has been a name change, get the first one as it will be the BuildP
		//currenty only one for each terminal				
		if rjsioRake = null then
			create rjsioRake;
			rjsioRake.rake := app.railRakeTypeEnumToString(Rail_JSIO_Type_Build);
			//rjsioRake.rake := BuildP;			
			rjsioRake.inOut := self;
		endif;		
		//rjsioRake.initialise;
		return;
	endif;
	
//	term := self.jobSheet.myTerminal;
//	term := app.getMyTerminal();
	term := _terminal;

	if term = null then
		return;
	endif;
	
	foreach ta in term.allTerminalAreas do
		sharedLock(ta);
		if ta.type = TA_TYPE_RAILWAY_TRACK then
			rjsioRake := inoutRakes[ta.id];
			if rjsioRake = null then
				create rjsioRake;
				ta.CM_Rail.allRailJSInOut.add(rjsioRake);
				rjsioRake.rake := ta.id;
				rjsioRake.inOut := self;
			endif;		
		endif;
	endforeach;

	foreach rjsioRake in self.inoutRakes do
		ta := term.allTerminalAreas[rjsioRake.rake];
		//check to see this the terminal area has been deleted!
		if ta = null then
			rjsioRake.erase(NORMAL_ERASE);
		endif;
	endforeach;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isRakeJobSheet" id="c9142deb-46e3-4ac6-9f68-36962648081a">
        <source>isRakeJobSheet() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		If this return TRUE it means that each CM_Rail area should be in the self.inoutRakes collection
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.outwards = Rail_JSIO_Type_Build then
		return false;
	else
		return true;
	endif;



end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
