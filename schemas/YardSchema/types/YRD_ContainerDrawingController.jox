    <JadeMethod name="notableObjectArmNotes" id="ee1c2583-510f-44c4-aad2-6001c96afe64">
        <source>notableObjectArmNotes(_obj: Object);
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	aTA : CM_TerminalAreaMaster;
begin
	inheritMethod(_obj);
	if CM_TerminalAreaMaster.hasInstance(_obj) then
		aTA := _obj.CM_TerminalAreaMaster;
		self.beginNotification(aTA, self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update), Response_Continuous, null);
		self.beginNotification(aTA, self.noteTAMove, Response_Continuous, null);

		//self.beginNotification(aTA, self.noteTALocationUpdate, Response_Continuous, null);		//-cnwml2 PAR21465
		self.beginNotification(aTA, self.noteTALocationCreate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationDelete, Response_Continuous, null);
//		self.beginNotification(aTA, self.noteTAReverseDecking, Response_Continuous, null);		//SFW1030
		self.beginNotification(aTA, self.noteTIUpdate, Response_Continuous, null);
		
		self.beginNotification(aTA, self.noteTAUpdate, Response_Continuous, null);				// TFS 49453
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
