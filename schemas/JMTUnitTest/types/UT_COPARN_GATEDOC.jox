    </JadeMethod>
    <JadeMethod name="zInvConsignorDataCleanUp" id="d3bc5549-7758-40bc-90dc-e8d9d409157c">
        <source>zInvConsignorDataCleanUp(_consignorCode : String;
						 _prenote1 : String;
						 _prenote2 : String;
						 _bookingNo : String;
						 _vesselCode : String;
						 _voyageCode : String;
						 _ediPartyName : String;
						 _fileName : String);
/*
Purpose:  Data Clean up after running the unit test for tCoparnInvalidConsignorWarning (Invalid Consignor)		

Date		Who		Reason
07 Aug 2019	jlgdi1	Initial creation
*/

vars
	consigneeConsignor : CM_ConsigneeConsignor;
	booking : CM_BookingRef;
	prenote : CM_TrackedItem;
	objArray : ObjectArray;
	object : Object;
	ediFile : CM_EDIFile;
	
begin
	consigneeConsignor := app.myRoot.allConsigneeConsignors[_consignorCode];
	if consigneeConsignor &lt;&gt; null then 
		beginTransaction;
		foreach booking in consigneeConsignor.allBookingRefsByRef do
			booking.setPropertyValue("myConsignor", null);
		endforeach;
		commitTransaction;
	endif;
	self.deleteConsigneeConsignor(_consignorCode);
	
	prenote := self.getTrackedItem(_prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(_prenote2);
	self.deleteTrackedItem(prenote, true);	
	self.deleteBooking(_bookingNo);
	self.deleteVessel(_vesselCode);
	self.deleteVoyage(_voyageCode);
	self.deleteEDIParty(_ediPartyName);
	
 	create objArray transient;
	CM_EDIFile.allInstances(objArray, 0, true);
 	foreach object in objArray do
		ediFile := object.CM_EDIFile;
		
		if not ediFile.fileName = _fileName then
			continue;
		endif;
		
		self.zInvConsignorDeleteEDI(ediFile);
 	endforeach; 
	objArray.clear;
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_prenote1" type="String"/>
        <Parameter name="_prenote2" type="String"/>
        <Parameter name="_bookingNo" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_ediPartyName" type="String"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="zInvConsignorDeleteEDI" id="ba71f5f3-dabb-4ea9-abf0-35fe5e5f073a">
        <source>zInvConsignorDeleteEDI(_ediFile : CM_EDIFile io);
/*
Purpose: Delete EDI File

Date		Who		Reason
07 August 2019	jlgdi1	Initial creation
*/

begin
	beginTransaction; 
	if tryLock(_ediFile, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		if _ediFile &lt;&gt; null then
			if _ediFile.ediData &lt;&gt; null then
				_ediFile.ediData.unload;
			endif;
			_ediFile.unload;
			delete _ediFile;
		endif;
	endif;
	if isLockedByMe(_ediFile) then
		unlock(_ediFile);
	endif;
	app.cmsCommitTransaction((app.myPassport));
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
    </JadeMethod>
</Class>
