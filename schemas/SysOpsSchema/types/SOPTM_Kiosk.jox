    <JadeMethod name="showThumbnail" id="3d2b8cdd-b22d-485c-b90e-1cebeba8d039">
        <updating/>
        <source>showThumbnail(_kiosk : CM_Kiosk) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation
07 August 2023	jlizm1	TFS 59548 Kiosk maintenance locales
11 August 2023	jlizm1	TFS 59549 Kiosk maintenance terms and conditions
18 August 2023	jlizm1	TFS 59550 Kiosk PPE Questions
28 August 2023	jlizm1	TFS 59551 Kiosk Additional Question

*/
vars
	theForm 	: SOP_TableMaintForm;
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
	idx			: Integer;
	tmpLocale 	: CM_Locale;
	invalidObject : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, tmpLocale, invalidObject);
	
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	entTableDef := app.myController.getEntTableDef(ETDef_Kiosk);
		
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, _kiosk.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;
	
	
	
	if _kiosk.noPassengersEnabled then
		theForm.tblInput1.showRowByName(ETRow_NoPassengersEnabled,false);
		theForm.tblInput1.showRowByName(ETRow_MaxPassengersAllowed,false);
		theForm.tblInput1.showRowByName(ETRow_SecurityEmailAddresses,false);
	else
		theForm.tblInput1.showRowByName(ETRow_NoPassengersEnabled,false);
		theForm.tblInput1.hideRowByName(ETRow_MaxPassengersAllowed,false);
		theForm.tblInput1.hideRowByName(ETRow_SecurityEmailAddresses,false);
	endif;
	
	theForm.mulSelect1.setSelected(_kiosk.allLocales);
	
	
	self.allSelectedLocales.clear();
	foreach tmpLocale in _kiosk.allLocales do
		self.allSelectedLocales.addNoDuplicates(tmpLocale, false);
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
	endforeach;
	if _kiosk.myPrimaryLocale &lt;&gt; null and not self.allSelectedLocales.includes(_kiosk.myPrimaryLocale) then
		self.allSelectedLocales.add(_kiosk.myPrimaryLocale);
	endif;
	
	theForm.cmbLocale2.listCollection(self.allSelectedLocales, false, 0);
	
	if _kiosk.myPrimaryLocale &lt;&gt; null then
		idx := theForm.cmbLocale2.findObject(_kiosk.myPrimaryLocale);
		theForm.cmbLocale2.listIndex := idx;
	endif;
	self.displayTermsAndConditions;
	
	theForm.lstSingleSelect1.clear;
	theForm.lstSingleSelect1.listCollection(_kiosk.allPPEQuestions, false, 0);	
	
	theForm.lstSingleSelect3.clear();
	theForm.lstSingleSelect3.listCollection(_kiosk.allAdditionalQuestions, false, 0);
	
end;</source>
        <Parameter name="_kiosk" type="CM_Kiosk"/>
    </JadeMethod>
    <JadeMethod name="termsAndConditionsChanged" id="0cef7e9d-406c-4e13-ab84-0f97300488c4">
        <source>termsAndConditionsChanged() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	theForm 	: SOP_TableMaintForm;
	pxyKiosk	: CM_Kiosk;
	pxyTC 		: CM_KioskTermsAndConditions;
	pxyXlat		: CM_KioskTranslation;
	oldValue	: String;
	
begin
	theForm := self.myForm;
	
	if self.selectedLocale = null then
		return false;
	endif;
	
	if theForm.myProxyObject &lt;&gt; null then
		pxyKiosk := theForm.myProxyObject.CM_Kiosk;
		pxyTC := pxyKiosk.myTermsAndConditions;
	endif;
	
	if pxyTC &lt;&gt; null then
		pxyXlat := pxyTC.allTermsAndConditions[self.selectedLocale.localeId];
		if pxyXlat &lt;&gt; null then
			oldValue := pxyXlat.text;
		endif;
	endif;
	
	if oldValue = theForm.txtTranslation.text then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
