<Class name="JtdDumpStack" id="dc6753ff-89c2-48ea-a014-5169f507e6da">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Jtd"/>
    <Constant name="Max_String_Length" id="65a2c21c-14d8-48bd-9ec8-33f702835fd3">
        <source>100000</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="currentIndent" id="2df925dd-4147-4698-95e8-0b30cbd37374">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="hadException" id="7995af37-b28c-4867-8f23-33abf6839aaa">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myDumpFile" id="3e2ae3bb-9b21-410a-8ccf-727b4a9f1d13">
        <embedded/>
        <type name="JadeLog"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <CompAttribute name="objectsDumpedArray" id="f6d0e8d8-4d8b-4531-a224-69a87890f4b7">
        <type name="StringArray"/>
        <access>protected</access>
    </CompAttribute>
    <CompAttribute name="objectsDumpedByArray" id="c6470a3f-b750-433b-ae24-a591a0257b54">
        <type name="StringArray"/>
        <access>protected</access>
    </CompAttribute>
    <PrimAttribute name="stackStartIndex" id="0f86ec3a-11bd-44c0-a642-0b4741a8e0c8">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="closeDumpLog" id="ff4afd04-a894-4582-940e-4b7a009c1f4e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>closeDumpLog() clientExecution, updating, protected;

vars

begin
	if myDumpFile &lt;&gt; null then
		myDumpFile.logClient(" ");
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="dumpArray" id="26f5f11b-b3ae-459c-9d9c-e8cab2dfd33b">
        <updating/>
        <source>dumpArray(array : Array; name : String; level : Integer) updating, protected;

vars
 	indent				: Integer;
 	indx				: Integer;
 	line, str			: String;
	pos					: Integer;
	len					: Integer;
	rem					: Integer;
	any					: Any;
	arrayClass			: Class;
	arrayIsObjectArray	: Boolean;
	maxElements			: Integer;
begin
	maxElements	:= 100;
 	indent 		:= level * 5;

	line := name &amp; " (" &amp; array.class.name &amp; ", size=" &amp; array.size.String &amp; ")  ";
 	if array.size = 0 then
 		line := line &amp; " . . . . . (empty)";
 	endif;

 	while line.length &lt; (115 - indent) do
 		line := line &amp; " .";
 	endwhile;

 	writeLine(line, indent);
 	indx 				:= 1;
 	line				:= null;
	arrayClass			:= array.class;
	arrayIsObjectArray	:= array.isKindOf(ObjectArray);

 	foreach any in array do
 		if arrayClass = StringArray 	or	 							// these first, for performance
 		   arrayClass = DecimalArray 	or
 		   arrayClass = IntegerArray	then
 			str := any.String &amp; "~~";

 		elseif arrayIsObjectArray then									// ObjectArray
 			str := app.jtdGetClassAndOid(any.Object) &amp; "~~";				// avoid touching object ... reference may be invalid

 		elseif arrayClass = HugeStringArray then						// HugeStringArray
 			str := any.String;
 			pos := 1;
 			len := str.length;
 			if len &gt; 0 then
 				while true do
 					rem := len - (pos-1);
 					if rem &gt; 0 then
 						if rem &gt; (115 - indent) then
 							line := str[pos : 115 - indent] &amp; "\";
 						else
 							line := str[pos : rem] &amp; "~~";
 						endif;

 						writeLine(line, indent);
 						line := null;
 					else
 						break;
 					endif;

 					pos := pos + 115 - indent;
 				endwhile;

 				line := null;
 				str	 := null;
 			endif;

 		else
    		str := any.String &amp; "~~";							// Other Arrays
    	endif;

        if (line.length + str.length) &gt; 100 then
       		writeLine(line, indent);
       		line := str;
       	else
       		line := line &amp; str;
       	endif;

        indx := indx + 1;

        if indx &gt; maxElements then
        	line := line &amp; "(truncated)";
        	break;
        endif;
   	endforeach;

   	writeLine(line, indent);
   	line := null;
   	while line.length &lt; (115 - indent) do
   		line := line &amp; ". ";
   	endwhile;
   	writeLine(line, indent);
   	line := null;
end;</source>
        <access>protected</access>
        <Parameter name="array" type="Array"/>
        <Parameter name="name" type="String"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dumpObjVars" id="89e16538-ee78-460a-93da-12e2707a933a">
        <updating/>
        <source>dumpObjVars(dumpParent	: String;					// description of method or object that called this procedure
			obj 		: Object;					// object to be dumped
			level 		: Integer 			 		// drill-down level
			) updating, protected;

vars
 	class 	: Class;
 	classNo	: Integer;
 	str		: String;
 	str2	: String;
 	line	: String;
 	prop	: Property;
 	indent  : Integer;
 	value	: Any;
 	oidStr	: String;
 	indx	: Integer;
 	coll	: PropertyColl;
begin
 	indent				:= level * 5;
 	self.currentIndent 	:= indent;								// used by exceptionHandler

	classNo	:= currentSchema.getClassNumberForObject(obj);		// avoid touching the object
	class	:= currentSchema.getClassByNumber(classNo);
	oidStr 	:= getOidStringForObject(obj);

	if class = null then
		writeLine(line &amp; " &lt;No class for object, oid=" &amp; oidStr &amp; "&gt;", indent);
		return;
	endif;

	oidStr 	:= class.name &amp; "/" &amp; oidStr;
	indx 	:= objectsDumpedArray.jtdFind(oidStr);
	if indx &gt; 0 then
		writeLine(line &amp; oidStr &amp; " already dumped : refer to " &amp; objectsDumpedByArray[indx], indent);
		return;
	endif;

	if level &lt; 3 then
		objectsDumpedArray.add(oidStr);
		objectsDumpedByArray.add(dumpParent);
	endif;
	
	str := "[Object edition=" &amp; obj.edition.String;
	if obj.isKindOf(Collection) then
		str	:= str &amp; ", size=" &amp; obj.Collection.size.String;
	endif;
	writeLine(str &amp; "]", indent);
	
	coll	:= class.allProperties;	

    foreach prop in coll do
    	if prop.name[1:1] &lt;&gt; "_" then							// Jade system class properties

	    	value := obj.getPropertyValue(prop.name);

	    	if value = null then
	    		writeLineC(prop.name &amp; " = null", line, indent);

	    	elseif prop.getType.isKindOf(PrimType) then					// Primitives

	    		if value.String.length &gt; 75 then
	    			str2 := value.String[1:75] &amp; " .....";				// leave off anything that's really long, at least for now
	    		else
	    			str2 := value.String;
	    		endif;

	    		str := prop.name &amp; " = " &amp; str2;
	   	 		writeLineC(str, line, indent);

	   	 	elseif prop.getType.inheritsFrom(Array) then				// arrays
	   	 		writeLine(line, indent);
	   	 		line := null;
	   	 		if app.isValidObject(value.Array) then
	   	 			dumpArray(value.Array, prop.name, level);
	   	 		else
	   	 			writeLine(prop.name  &amp; " &lt;Not used&gt;", indent);
	   	 		endif;
	   	 		
	   	 	elseif prop.getType.inheritsFrom(Collection) then				// arrays
	   	 		writeLine(line, indent);
	   	 		line := null;
	   	 		if app.isValidObject(value.Collection) then
	   	 			writeLine(prop.name &amp; " [Size=" &amp; value.Collection.size.String &amp; "]", indent);
	   	 		else
	   	 			writeLine(prop.name  &amp; " &lt;Not used&gt;", indent);
	   	 		endif;

	   	 	else														// other classes
	   	 		writeLine(line, indent);
	   	 		line := null;
	   	 		str := prop.name &amp; " = " &amp; app.jtdGetClassAndOid(value.Object) &amp; " ------------&gt; (" &amp; (level + 1).String &amp; ")";
	   	 		writeLine(str, indent);
	   	 		if level &lt; 2 then
	   	 			on Exception do exceptionHandler(exception);
	   	 			dumpObjVars("object dump for " &amp; oidStr, value.Object, level + 1);
	   	 			on Exception do null;
	   	 		endif;
	   	 	endif;
	   	 endif;
    endforeach;

    writeLine(line, indent);
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="dumpParent" type="String"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dumpStack" id="f4c53702-161b-4fb1-8601-87525ccdcf96">
        <updating/>
        <source>dumpStack(exObj : Exception) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
 	md 				: MethodCallDesc;
	pc 				: ProcessStackArray;
	le				: LockException;
	targetLockedBy	: Process;
	i 				: Integer;
	stackSize		: Integer;
	localvar 		: JadeLocalVar;
	str, str2, str3	: String;
	value			: Any;
	bool			: Boolean;
	param			: Parameter;
	obj				: Object;
	line			: String;
	hyphens			: String;
	miniDump		: Boolean;
	oidStr			: String;
	meth			: Method;
	noteStr			: String;			// notification string 'array'
	//pid				: Integer;
	now				: TimeStamp;
	dumpFileName	: String;
	dumpFile		: JadeLog;
	level			: Integer;
	int				: Integer;
	obtained		: String;
	heldBy			: Process;
	target			: String;
	file			: File;
	osVersion		: String;
	osPlatform		: Integer;
	osArchitecture	: Integer;
	nodeInfo		: String;
	role			: Integer;
	logDirectory	: String ;
	fileFolder		: FileFolder;
begin
 	//
	//   The logged output of this method will be correctly formatted when printed using a fixed-pitch font.
	//   The output was designed to be printed using Notepad with Courier New, font pitch = 7, portrait.
	//   The starting point in the call stack can be (optionally) defined by the user prior to calling this
	//   method.
	//
	//   Note that this method now makes the decisions as to whether to (a) report the exception to JSM, and
	//   (b) actually take a stack dump.  Formerly, these decisions were made in the ::cnGlobalExceptionHandler.
   	//
   	//	 Class version 3.1 September 03, 2003, for JADE 6.0 or higher. 
   	//	 R. W. Mitchell, Systems Management Development Centre,
   	//   (c) 2003 Jade Software Corporation Limited, New Zealand.

	hyphens := "=====================================================================================================";
	now		:= app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create pc transient;
	process.currentStack(pc);
	stackSize	:= pc.size;
	dumpFileName 		:= "_jtd_" &amp; now.date.format("yyyyMMdd") &amp; "_" &amp; now.time.format("HHmmss") &amp;
					   	   now.time.milliSecond.String.padLeadingZeros(3) &amp; "_" &amp; getInstanceIdForObject( process ).String;
	if process.isUsingThinClient then
		dumpFileName	:= dumpFileName &amp; "_" &amp; app.jtdComputerName;
	endif;
	
	dumpFileName		:= dumpFileName &amp; ".log";

	// Setup a log directory so that the JTD Dumps are in their own folder to make it easier
	// to zip and copy them back to a local machine and to make it quicker to look at other
	// files in the /logs directory if there have been a large number of dumps
	logDirectory		:= app.getProfileStringAppServer( app.getIniFileNameAppServer, "JadeLog", "LogDirectory", null );
	if logDirectory &lt;&gt; null then
//		logDirectory	:= logDirectory &amp; "/jtdDumps";
		create fileFolder transient ;
		fileFolder.usePresentationFileSystem	:= false;
		fileFolder.fileName	:= logDirectory ;
		if not fileFolder.isAvailable then
			fileFolder.make();
		endif;
		delete fileFolder ;
	endif;
	app.logMessage("------------------------------------------------------------");
	app.logMessage("ex "&amp;exObj.errorCode.String&amp;" "&amp;exObj.text&amp;" see "&amp;dumpFileName&amp;" "&amp;method.qualifiedName);

	//////////////////////////////   Take call stack dump, if required  //////////////////////////////////////
	create dumpFile;
	if logDirectory &lt;&gt; null then
		dumpFile.filePath	:= logDirectory ;
	endif;
	dumpFile.fileName		:= dumpFileName;
	dumpFile.versionFile	:= false;
	dumpFile.formatOutput	:= false;
	dumpFile.bufferOutput	:= true;
	myDumpFile				:= dumpFile;

	writeLine(hyphens, 0);
	str			:= "";
	str[32:110] := "S T A C K    D U M P                       S T A C K    D U M P                       S T A C K    D U M P";
	writeLine(str, 0);
	writeLine(hyphens, 0);

	writeLine("Application : " &amp; app.name &amp; "           Computer : " &amp; app.jtdComputerName &amp; "          Error : " &amp; exObj.errorCode.String &amp;
			  "         Time : " &amp; now.date.String &amp; ", " &amp; now.time.String &amp; "." &amp; now.time.milliSecond.String.padLeadingZeros(3) &amp; " (local)", 0);
	writeLine(hyphens, 0);
	writeLine(" ", 0);
	str 	:= "Exception " &amp; exObj.errorCode.String &amp; "  (" &amp; exObj.text &amp; ")  in application " &amp; app.name &amp;
		  	   " (application type = " &amp; app.jtdGetApplicationType &amp; "), extendedErrorText=" &amp; exObj.extendedErrorText;
	writeLine(str, 0);
	str		:= "Exception occurred at " &amp; now.String &amp; "  (GMT=" &amp; now.jtdGMT.String &amp; ") ";
	if node.isServerNode then
		str	:= str &amp; " by database server clock.";
	elseif process.isUsingThinClient then
		str := str &amp; " by app server clock.";
	else
		str := str &amp; " by fat client clock.";
	endif;
	writeLine(str, 0);
	str		:= "Local times for participants : database server=" &amp; app.actualTimeServer.String;
	if process.isUsingThinClient then
		str	:= str &amp; ", app server=" &amp; now.String;
	endif;
	str := str &amp; ", client=" &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	writeLine(str, 0);
	writeLine("Application version is " &amp; app.appVersion, 0);

	if node.isServerNode then
		nodeInfo	:= "server node, computer=" &amp; app.jtdComputerName;
	elseif node.isApplicationServer then
		nodeInfo	:= "application server node, computer=" &amp; app.jtdComputerNameAppServer;
	else
		nodeInfo	:= "fat client node (JADE.EXE), computer=" &amp; app.jtdComputerName;
	endif;
	 	
	str				:= "Database is not an SDS system";
	role			:= system.getDatabaseRole();
	if role = SDS_RolePrimary then
		str			:= "Database is an SDS primary system.";
	elseif role = SDS_RoleSecondary then
		str			:= "Database is an SDS sedcondary system.";
	endif;
	writeLine(str, 0);	 	

	osPlatform	:= node.getOSPlatform(osVersion, osArchitecture);
	str	:= "Platform type for this node=";
	if osPlatform = Node.OSWindows 				or
	   osPlatform = Node.OSWindowsEnterprise 	or
	   osPlatform = Node.OSWindowsHome 			then
		str	:= str &amp; "Windows";
	elseif osPlatform = Node.OSUnixLinux 		then
		str	:= str &amp; "Linux ";
	elseif osPlatform = Node.OSUnixAIX			then
		str := str &amp; "AIX";
	else
		str	:= str &amp; "&lt;unknown OS platform&gt;";
	endif;
	
	str	:= str &amp; ", OS version=" &amp; osVersion &amp; ", platform architecture=";
	if osArchitecture = Node.Architecture_32Big_Endian then
		str	:= str &amp; "Architecture_32Big_Endian";
	elseif osArchitecture = Node.Architecture_32Little_Endian then
		str	:= str &amp; "Architecture_32Little_Endian";
	elseif osArchitecture = Node.Architecture_Gui then
		str	:= str &amp; "Architecture_Gui (currently Windows 32 bit little endian)";
	endif;
	
	writeLine(str, 0);	
	writeLine("process=" &amp; process.String &amp; ", process usercode=" &amp; process.userCode &amp; ".", 0);	
	writeLine("Database path=" &amp; app.dbPath &amp; ", app.userName=" &amp; app.userName &amp; ".", 0);
	writeLine("Only the first 100 elements of any arrays will be dumped.", 0);

	str := "JADE version " &amp; app.getSystemVersion;
	if app.isUnicode then
		str := str &amp; " (Unicode)";
	else
		str := str &amp; " (ANSI)";
	endif;
	writeLine(str, 0);
	
	miniDump	:= false;									// Always do full stack dump for CardSchema apps

	if exObj.errorCode = 4021 or								// method needs compilation - can't access some method stuff
	   exObj.errorCode = 4035 or								// user interrupted method execution
	   exObj.errorCode = 1201 or								// kernel stack overflow
	   exObj.errorCode = 1018 or								// no memory for buffers
	   exObj.errorCode = 14135 or								// app server stack overflow
	   exObj.errorCode = 14063 then								// GDI Resource shortage
		miniDump := true;
		writeLine("Stack dumper won't provide stack analysis for this exception type : method calls only will be displayed.", 0);
	endif;
	
	if exObj.errorCode = 1081 then								// deadlock
		obtained:= app.jtdGetClassAndOid(exObj.DeadlockException.obtainedLock);
 		heldBy	:= exObj.DeadlockException.targetLockedBy;
		target	:= app.jtdGetClassAndOid(exObj.DeadlockException.lockTarget);
		
 		if heldBy &lt;&gt; null then													// JADE can't always report all the details
		 	str :=  "Deadlock Exception : locktype=" &amp; exObj.DeadlockException.lockType.String &amp;
				    ", locktarget=" &amp; target &amp; ", " &amp;
				    "currently held by " &amp;  heldBy.String &amp; " " &amp;
				    "(app=" &amp; heldBy.persistentApp.name &amp; ", " &amp;
				    "ipAddress=" &amp; heldBy.networkAddress &amp; ", " &amp;
				    "usercode=" &amp; heldBy.userCode &amp; ")  " &amp;
				    "who is trying to lock " &amp; obtained &amp; " (which this process already has locked).";

		else
		 	str := "Deadlock exception : no targetLockedBy information available from JADE, " &amp;
		 		   ", locktype=" &amp; exObj.DeadlockException.lockType.String &amp;
	 			   ", target=" &amp; target &amp;
	 			   ", other user is trying to lock " &amp; obtained &amp; " (which this process already has locked)."; 
		endif;

		writeLine(str, 0);
	endif;
	
	if exObj.isKindOf(LockException) and exObj.errorCode = 1027 then					// lock exception
		le				:= exObj.LockException;
		targetLockedBy	:=	le.targetLockedBy;
		str				:= "Exception=" &amp; le.errorCode.String &amp; " : " &amp; le.text &amp; ", lockTarget=" &amp;
						    le.lockTarget.String;
		if targetLockedBy &lt;&gt; null and app.isValidObject(targetLockedBy) then
			str			:= str &amp; ", locked by " &amp; targetLockedBy.userCode &amp; " on node " &amp;
						    targetLockedBy.node.name &amp; " (locking process app name=" &amp; targetLockedBy.persistentApp.name &amp;  
						    ", process=" &amp; targetLockedBy.String &amp; ") : aborted after multiple retries.";
						    
		elseif targetLockedBy &lt;&gt; null then
			str			:= str &amp; ", targetLockedBy was an invalid reference : locking process must have gone away.";
			
		else
			str			:= str &amp; ", targetLockedBy is null : possible JADE problem.";
		endif;
		
		writeLine(str, 0);
		
	endif; 
	
	if exObj.isKindOf(FileException) then
		file	:= exObj.FileException.file;
		if file &lt;&gt; null then 
			str := "file in error is '" &amp; file.fileName &amp; "'.";
		else
			str := "file in error not known.";
		endif;
		
		writeLine("File Exception " &amp; exObj.errorCode.String &amp; " (" &amp; exObj.text &amp; ") :" &amp; str, 0);
	endif;

	on Exception do exceptionHandler(exception);

	//// Now get the call stack history ////

    writeLine (" ", 0);
    writeLine("======================================  Exception Summary  ===============================================", 0);
	writeLine(" ", 0);
	str	:= "Exception Type: " &amp; exObj.class.name &amp; " (" &amp; exObj.errorCode.String &amp; " : " &amp; exObj.text &amp; ")";
	if not exObj.continuable then
		str2	:= "  (Not continuable, ";
	else
		str2	:= "  (Continuable, ";
	endif;
	if not exObj.resumable then
		str2	:= str2 &amp; "not resumable)";
	else
		str2	:= str2 &amp; "resumable)";
	endif;
	
	writeLine(str &amp; str2, 0);
	if exObj.extendedErrorText &lt;&gt; null then
		writeLine("Extended Text : " &amp; exObj.extendedErrorText, 0);
	endif;
	str	:= "Error Item: ";
	if exObj.errorItem &lt;&gt; null then
     	writeLine(str &amp; exObj.errorItem, 0);
    else
    	writeLine(str &amp; "&lt;Not available&gt;", 0);
    endif;

	str := "Error Object: " &amp; app.jtdGetClassAndOid(exObj.errorObject);
	if not app.isValidObject(exObj.errorObject) then
		str := str &amp; " (Invalid object reference)";			
	endif;

	writeLine(str, 0);

	writeLine("Caused By:", 0);
	str := "     Receiver: ";
	bool := app.isValidObject(exObj.currentMethodDesc);
	if bool then 
		oidStr	:= getOidStringForObject(exObj.currentMethodDesc.getReceiver);
		str := str &amp; exObj.currentMethodDesc.receiverAsString &amp; "/" &amp; oidStr;
	else
		str := str &amp; "&lt;No currentMethodDesc, receiver details not available&gt;";
	endif;
	writeLine(str, 0);
	
	str := "     Method: ";
	if bool then 
		str := str &amp; exObj.currentMethodDesc.display;
	else
		str := str &amp; "&lt;No currentMethodDesc, method details not available&gt;";
	endif;
	writeLine(str, 0);
		
	writeLine("Reported By: ", 0);
	bool := app.isValidObject(exObj.reportingMethodDesc);
	str := "     Receiver: ";
	if bool then 
		str := str &amp; exObj.reportingMethodDesc.receiverAsString &amp; "/" &amp; getOidStringForObject(exObj.reportingMethodDesc.getReceiver);
	else
		str := str &amp; "&lt;No reportingMethodDesc, receiver details not available&gt;";
	endif;
	writeLine(str, 0);
	
	str := "     Method: ";
	if bool then 
		str := str &amp; exObj.reportingMethodDesc.display;
	else
		str := str &amp; "&lt;No reportingMethodDesc, method details not available&gt;";
	endif;
	writeLine(str, 0);

	writeLine(" ", 0);
	writeLine("Call Stack History:", 0);
	
	////  Start building notification string for unhandled exception note  ////

	noteStr := app.jtdComputerName &amp; "^" &amp;
			   app.name &amp; "^" &amp;
			   exObj.errorCode.String &amp; "^" &amp;
			   exObj.text &amp; "^";

   	if exObj.extendedErrorText &lt;&gt; null then
   		noteStr := noteStr &amp; exObj.extendedErrorText &amp; "^";
   	else
   		noteStr := noteStr &amp; "No extended error text" &amp; "^";
   	endif;
   	
   	if stackSize &lt; 4 then
   		writeLine("############ Unexpectedly short call stack : stack size = " &amp; stackSize.String &amp; ", will list entire stack  ##########", 0);
   		i := 1;								
   	elseif self.stackStartIndex &gt; 0 then
   		i	:= self.stackStartIndex;				// application programmer specified stack start position
   	else
   		i := 4;								// leave out process.currentStack, self.dumpStack, globalExceptionHandler
   	endif;           

    while i &lt;= stackSize do
		md := pc[i];
		if app.isValidObject(md) then
			meth := md.method;
			if app.isValidObject(meth) then
				writeLine("     " &amp; md.display &amp; " (" &amp; meth.class.name &amp; ")", 0);
				if i = 4 then
					noteStr	:= noteStr &amp; md.display &amp; "^"; 
				endif;
				str 	:= "         ++ Source line:  ";

				writeLine(str &amp; meth.jtdGetSourceLine(md.position), 0);
				if i = 4 then
					noteStr := noteStr &amp; meth.jtdGetSourceLine(md.position) &amp; "^";
				endif;

			else
				writeLine("Bad method object ..... can't analyse", 0);
				if i = 4 then
					noteStr	:= noteStr &amp; "Method not available^Source line not available^"; 
				endif;
			endif;

		else
			writeLine("Bad MethodCallDesc object ...... can't analyse", 0);
		endif;

		i := i + 1;
	endwhile;

	if noteStr = null then												// indicates we had a problem with methodcalldesc 
		noteStr := app.jtdComputerName &amp; "^" &amp;
				   app.name &amp; "^" &amp;
				   exObj.errorCode.String &amp; "^" &amp;
				   exObj.text &amp; "^" &amp; 
				   "Extended error text not available^" &amp;
				   "Method name not available^" &amp;
				   "Source line not available^";
	endif;  

	if not miniDump then
		writeLine(" ", 0);
		writeLine("==========   APP   =======  APP   =======  APP   =======  APP   =======  APP   =======  APP   =======  APP   =======", 0);
		writeLine(app.jtdGetClassAndOid(app) &amp; " -----------&gt; (1)", 0);				// dump app and global
		dumpObjVars("APP", app, 1);
		writeLine(" ", 0);

	    writeLine("===============================  Detailed Call Stack Analysis   ================================================", 0);
	    
    	if stackSize &lt; 4 then
   			writeLine("############ Unexpectedly short call stack : stack size = " &amp; stackSize.String &amp; ", will list entire stack  ##########", 0);
   			i := 1;								
   		else
   			i := 4;								// leave out process.currentStack, self.dumpStack, globalExceptionHandler
   		endif; 
	    
		while i &lt;= stackSize do
			md:= pc[i];

			if app.isValidObject(md) then
				writeLine(" ", 0);
				meth := md.method;
				level := 0;
                if meth.isKindOf(JadeMethod) then			// find my level if method exists elsewhere in stack					
                	foreach int in 1 to i - 1 do
                		if pc[int].method = meth then		
                			level := level + 1;
                		endif;
                	endforeach;	
                endif;

				if app.isValidObject(meth) then
					writeLine("****************  Method call = " &amp; md.display &amp; " (" &amp; meth.class.name &amp; ")  ***********************", 0);
					if i = 4 then
						str := "Source position = " &amp; md.position.String &amp; ", error object = " &amp; app.jtdGetClassAndOid(exObj.errorObject);
						if not app.isValidObject(exObj.errorObject) and exObj.errorObject &lt;&gt; null then
							str := str &amp; " (invalid object reference)";
						endif;

						writeLine("Method position=" &amp; md.position.String, 0);
						str := "&gt;&gt;&gt;&gt; Source code line &gt;&gt;&gt;&gt;&gt;  " &amp; meth.jtdGetSourceLine(md.position);
						writeLine(str, 0);

					else 
						str := "&gt;&gt;&gt;&gt; Source code line &gt;&gt;&gt;&gt;&gt;   " &amp; meth.jtdGetSourceLine(md.position);
			          	writeLine(str, 0);
					endif;

					line := null;

			        if meth.class = JadeMethod and not miniDump then

			        	writeLine("====================  Parameters for method " &amp; meth.name &amp; " (" &amp; meth.class.name &amp; ")  ===============================", 0);

				        foreach param in meth.jtdGetParameters do
				        	value := null;
				        	if level = 0 then
								bool := meth.JadeMethod.getValue(param.name, value);
							else
								bool := meth.JadeMethod._getValue(level, param.name, value);
							endif;

							if not bool or value.isKindOf(Any) then
								writeLineC(param.name &amp; " = &lt;Not used&gt;", line, 0);

							elseif value = null then										
								writeLineC(param.name &amp; " = null", line, 0);

					       	elseif param.type.isKindOf(PrimType) then 					// Primitives
				            	str := value.String;
				            	if str.length &gt; Max_String_Length then
				            		str2 := str[1:Max_String_Length] &amp; "...[truncated : actual length=" &amp; str.length.String &amp; "]";
				            		writeLineC(param.name &amp; " = " &amp; str2, line, 0);
				            	else
					            	writeLineC(param.name &amp; " = " &amp; str, line, 0);
					            endif;

				            elseif param.type.isKindOf(Class) then						// we don't handle PseudoType yet, does it matter ?
				            	//
				            	obj := value.Object;

				            	if app.isValidObject(obj) then
					            	if obj.isKindOf(Array) then							// Arrays
					            		dumpArray(obj.Array, param.name, 0);

						        	else												// all other objects
						        		writeLine(line, 0);
						        		line := null;
						  				str := param.name &amp; " = " &amp; app.jtdGetClassAndOid(value.Object) &amp; " -------------&gt; (1)";
						           		writeLine(str, 0);
						           		dumpObjVars("parameters for " &amp; meth.name, obj, 1);
						        	endif; 

						        else
						        	str := app.jtdGetClassAndOid(obj);
						        	if str &lt;&gt; null and str &lt;&gt; "&lt;null&gt;" then 
						        		writeLine(str &amp; " &lt;Invalid or null object reference&gt;", 0);
						        	endif;
						        endif;
					        endif;   

				        endforeach;

				        writeLine(line, 0);
				       	line := null;

						writeLine("=============================  Local Vars for method " &amp; meth.name &amp; " ===============================", 0);
						foreach localvar in meth.JadeMethod.jtdGetLocalVars do
							value := null;
							if level = 0 then
								bool := meth.JadeMethod.getValue(localvar.name, value);
							else
								bool := meth.JadeMethod._getValue(level, localvar.name, value);
							endif;

				 			if not bool or value.isKindOf(Any) then 
				      			str := localvar.name &amp; " = &lt;unused&gt;";
				      			writeLineC(str, line, 0);

							elseif value.isKindOf(Object) then
								if app.isValidObject(value.Object) then
						      		if value.isKindOf(Array) then
						      			writeLine(line, 0);
						      			line := null;
					                	dumpArray(value.Array, localvar.name, 0);
						           	else													// other classes
						           		writeLine(line, 0);
						           		line := null;
						           		str := localvar.name &amp; " = " &amp; app.jtdGetClassAndOid(value.Object) &amp; " ----------&gt; (1)";
						           		writeLine(str, 0);
						           		dumpObjVars("local vars for " &amp; meth.name, value.Object, 1);
						           	endif;

					           	else
					         		writeLineC(localvar.name &amp; " = " &amp; app.jtdGetClassAndOid(value.Object) &amp; " (Invalid object reference)", line, 0);
					         	endif;
				            else
				            	str	:= value.String;										// must be Primitive 
				            	if str.length &gt; Max_String_Length then
				            		str2 := str[1:Max_String_Length] &amp; "...[truncated : actual length=" &amp; str.length.String &amp; "]";
				           			writeLineC(localvar.name &amp; " = " &amp; str2, line, 0);
				           		else
				           			writeLineC(localvar.name &amp; " = " &amp; str, line, 0);
				           		endif;				           		
				        	endif;
						endforeach;
						
						if line &lt;&gt; null then
							writeLine(line, 0);
							line	:= null;
						endif;
						
						if i &gt;= (stackSize -1) then
							obj	:= md.getReceiver();
							if obj.isKindOf(Form) or not (obj.isKindOf(Form) and i = stackSize) then
								writeLine(" ", 0);
								writeLine("=============================  Receiver details for method " &amp; meth.name &amp; " ===============================", 0);
								writeLine("Receiver = " &amp; app.jtdGetClassAndOid(obj) &amp; " -------------&gt; (1)", 0);
								dumpObjVars("Receiver details for method " &amp; meth.name, obj, 1);
							endif;
						endif;

					elseif not miniDump then										// external method
						writeLine(meth.jtdGetSourceLine(md.position), 0);
			        endif;

					writeLine(line, 0);
					line := null;
				endif;
				
			else
				writeLine("Invalid MethodCallDesc object .... can't analyse", 0);
			endif;
			
			i := i + 1;
		endwhile;
		
	else
		writeLine(" ", 0);
		writeLine("Mini-dump only was requested, or full stack dump not applicable to exception type.", 0);
	endif;		

	writeLine(" ", 0);
	writeLine("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  End of Stack Dump  %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%", 0);
	
epilog
	app.logMessage("------------------------------------------------------------");
	if pc &lt;&gt; null then
		pc.purge();
		delete pc;
	endif;
	closeDumpLog;									// clientExecution
	delete dumpFile;
	delete fileFolder;
end;</source>
        <Parameter name="exObj" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="exceptionHandler" id="f34bb25e-0199-4caf-aafa-7c4659f55881">
        <updating/>
        <source>exceptionHandler(exObj : Exception) : Integer updating, protected;

vars
	errorObj 	: Object;
	oidStr		: String;
begin
	hadException := true;
	errorObj := exObj.errorObject;
	if errorObj &lt;&gt; null then
		oidStr := app.jtdGetClassAndOid(errorObj);
		writeLine(oidStr &amp; " &lt;Object not valid or not available, error=" &amp; exObj.errorCode.String &amp; "&gt;", currentIndent);
	else
		writeLine("In JtdStackDump::exceptionHandler, exObj.errorObject was null", currentIndent);
	endif; 

	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeLine" id="94074799-87f7-4ea3-9bff-d27b4bea391f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeLine(str : String; indent : Integer) clientExecution, updating, protected;

vars
 	log	: JadeLog;								// This method used when dumping stack to log file	
 	line : String;	
 	ind	: Integer;	
begin
	if str = null then
		return;
	endif;

	log := myDumpFile;
	ind := indent + 1;
	line[ind : str.length + 2] := str &amp; CrLf;

	log.infoClient(line);
end;</source>
        <access>protected</access>
        <Parameter name="str" type="String"/>
        <Parameter name="indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeLineC" id="bf2d9cab-550d-4b7f-997b-ca8692fb3c5b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeLineC(str : String; line : String io; indent : Integer) clientExecution, updating, protected;

	//  Conditionally writes dump line to log  ////

vars
 	slen, llen	: Integer;
begin
	slen 	:= str.length;
	llen  	:= line.length;

	if llen = 0 then
		line := str;
		slen := 0;
	elseif llen &lt; 33 and slen &lt; 70 then
		line[35:slen] := str;
		slen := 0;
	elseif llen &lt; 68 and slen &lt; 35 then
		line[70:slen] := str;
		slen := 0;
	else
		writeLine(line, indent);
		line := null;

		if slen &gt; 0 then
			line := str;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="str" type="String"/>
        <Parameter name="line" type="String" usage="io"/>
        <Parameter name="indent" type="Integer"/>
    </JadeMethod>
</Class>
