    <JadeMethod name="getMatchingAllocations" id="4af8f51f-1477-4f0d-92cf-1e7a758529d1">
        <source>getMatchingAllocations(_criteria : CM_YACriteria; _terminal : CM_Terminal; _allocationDict : CM_YardAllocationSet input);
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars



begin

	if not self.myYardAllocation.myTerminal = _terminal then
		return;
	endif;

	if _criteria.myYAData.doDataComparison(self.myYAData) then
		if not _allocationDict.includes(self.myYardAllocation) then
			_allocationDict.add(self.myYardAllocation);
		endif;
	endif;
	

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allocationDict" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="9b7d6aa3-b4e3-4e6b-b093-8fb66d515590">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     01 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpYardAlloc	: CM_YardAllocation;
begin
	tmpYardAlloc := self.myYardAllocation;
	if tmpYardAlloc &lt;&gt; null then
		return tmpYardAlloc.myTerminal;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getRawDescription" id="e15ecb74-2d2a-4849-b15f-3141114cedee">
        <source>getRawDescription():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2009	cnwndl1	Initial creation

*/

vars
	str : String;
begin

	on Exception do self.xHandler(exception, false); 
	
	str := self.myYACriteriaType.getDataDisplay(self.myYAData);
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1  default values are null
	if str = null then
		str := '(Default)';
	endif;
	
	if str.length &gt; 200 then
		str := str[1:200] &amp; ' ...';
	endif;
	
	return str;

	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectorEquivalentValues" id="1ccfbc56-b035-4bf1-891e-3ce166ce3d09">
        <source>getSelectorEquivalentValues( 	className : String;
								useDefMeasure : Boolean;
								queryProp : CM_QueryProperty output;
								operClass : Class output;
								dataValue : Any output
								):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2015	cnwndl1	Initial creation	Par 36525
12 Oct 2023	navdap1	TFS 58928 EUP | Calloff Zimmer DB Load
*/

vars

	yaTypeKey : Integer;
	hazClass : CM_HazardClass;
	strArray : StringArray;
	str : String;
	hazClassColl : CM_HazardClassByCodeDict;

begin

	if self.myYACriteriaType = null then
		return "No associated YA Type found";
	endif;
	
	if self.myYAData = null then
		return "'" &amp; self.myYACriteriaType.description &amp; "' had no YA criteria data value!";
	endif;

	yaTypeKey := self.myYACriteriaType.type;
	if yaTypeKey = 0 then
		return "'" &amp; self.myYACriteriaType.description &amp; "' no YA key found";
	endif;
	
	if className = CM_TrackedItem.name then
		// TFS 58928 coming from reserve selection criteria building, we want default measurement types
		if useDefMeasure then
			queryProp := CM_QDefTrackedItem.firstInstance.getPropertyFromYATypeDefMeas( yaTypeKey );
		else
			queryProp := CM_QDefTrackedItem.firstInstance.getPropertyFromYAType( yaTypeKey );
		endif;
	elseif className = CM_Container.name then
		// TFS 58928 coming from reserve selection criteria building, we want default measurement types
		if useDefMeasure then
			queryProp := CM_QDefTrackedItem.firstInstance.getPropertyFromYATypeDefMeas( yaTypeKey );
		else
			queryProp := CM_QDefContainer.firstInstance.getPropertyFromYAType( yaTypeKey );
		endif;
	endif;

	if queryProp = null then
		return "No equivalent Selector query property found for '" &amp; self.myYACriteriaType.description &amp; "'";
	endif;
	
	operClass := queryProp.getQueryOperatorForYADataConv();
	dataValue := self.myYAData.getDataValue;
	
	if dataValue &lt;&gt; null and dataValue.isKindOf(String) and dataValue.String.pos("*",1) &gt; 0 then
		if operClass = CM_QStringEquals then
			if dataValue.String.length &gt; 1 then
				if dataValue.String[1] = "*" then
					operClass := CM_QStringEndsWith;
					dataValue := dataValue.String[2:end];
				elseif dataValue.String[dataValue.String.length] = "*" then
					operClass := CM_QStringStartsWith;
					dataValue := dataValue.String[1:dataValue.String.length - 1];
				endif;
			endif;
		endif;
	endif;
	
	if operClass = CM_QCollIncludesOneOf and queryProp.isKindOf(CM_QCollTiHazardsProperty) then
		if dataValue &lt;&gt; null and dataValue.isKindOf(String) then
			hazClass := app.myRoot.allHazardClasses.getAtKey( dataValue.String );
			if hazClass &lt;&gt; null then
				dataValue := hazClass;
			else
				strArray := dataValue.String.cnGetTokens(",");
				if strArray &lt;&gt; null and not strArray.isEmpty then
					create hazClassColl transient;
					foreach str in strArray do
						hazClass := app.myRoot.allHazardClasses.getAtKey( str.trimBlanks );
						if hazClass &lt;&gt; null then
							hazClassColl.addNoDuplicates(hazClass,false);
						endif;
					endforeach;
					if not hazClassColl.isEmpty then
						dataValue := hazClassColl;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if yaTypeKey = YACriteriaType_RailReleaseReq then
		dataValue := self.myYAData.getDataValue.ObjectSet.first.CM_BulkRelease.code;
	endif;
	
	if operClass = null then
		return "'No valid Selector query operator found to use for '" &amp; queryProp.niceName &amp; "' in this query mode.";
	endif;
	if dataValue = null then
		return "'" &amp; self.myYACriteriaType.description &amp; "' had no YA criteria data value!";
	endif;
	
	if queryProp.isKindOf(CM_QBooleanProperty) or queryProp.isKindOf(CM_QBooleanMethod) then
		if dataValue.isKindOf(String) and dataValue.String = app.getErrorString(NotApplicable) then
			return "'" &amp; self.myYACriteriaType.description &amp; "' = Not Applicable, skipped.";
		elseif dataValue.isKindOf(Integer) and dataValue.Integer = CM_YADataBoolean.VALUE_EITHER then
			return "'" &amp; self.myYACriteriaType.description &amp; "' = Not Applicable, skipped.";
		endif;
	endif;
	
	return null;

epilog

	delete strArray;
	delete hazClassColl;

end;</source>
        <Parameter name="className" type="String"/>
        <Parameter name="useDefMeasure" type="Boolean"/>
        <Parameter name="queryProp" type="CM_QueryProperty" usage="output"/>
        <Parameter name="operClass" type="Class" usage="output"/>
        <Parameter name="dataValue" type="Any" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFAutoPlanDataMatch" id="e61d6bc5-10cf-427a-8d0e-f80124ef49dc">
        <source>isCMIFAutoPlanDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan) : Boolean;
// -------------------------------------------
// Created 17 March 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance Remove sharedLock on myYAData
22 Oct 2024 navma1  MTN-23340 MTN - Performance issues and locks when completing the Retrospective Pack jobs 
*/

vars
	
	
begin
	on Exception do self.xHandler(exception, _cmifAutoPlan.raiseWarning);
	
	if _cmifAutoPlan.isCMIFYAAutoPlanSenario() and _cmifAutoPlan.CMIF_YAAutoPlanSenario.allScenarioCriteria.isNotEmpty then   //22.10.2024 navma1 #MTN-23340
		
		return _cmifAutoPlan.CMIF_YAAutoPlanSenario.isCriteriaMatch(self);
		
	endif;
	
	return self.myYACriteriaType.isCMIFDataMatch(_cmifAutoPlan, self.myYAData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isProformaDataMatch" id="7839cc87-959d-49e1-a869-9399ace09973">
        <source>isProformaDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan) : Boolean;
// copy of isCMIFAutoPlanDataMatch with logging, called from cash receipt for pro forma invoice lines
// 23 Oct 2024 	navlw1 	JIRA-33107: Invoice Logging Use Levels
vars
	result	: Boolean;
	
begin
	on Exception do self.xHandler(exception, _cmifAutoPlan.raiseWarning);
	
	if _cmifAutoPlan.isKindOf(CMIF_YAAutoPlanSenario) and _cmifAutoPlan.CMIF_YAAutoPlanSenario.allScenarioCriteria.size &gt; 0 then
		
		result := _cmifAutoPlan.CMIF_YAAutoPlanSenario.isCriteriaMatch(self);
		app.invLog("Criteria " &amp; self.code &amp; " match=" &amp; result.String, LogTRACE.String);
		return result;
		
	endif;
	
	result := self.myYACriteriaType.isCMIFDataMatch(_cmifAutoPlan, self.myYAData);
	app.invLog("Criteria " &amp; self.code &amp; " match=" &amp; result.String, LogTRACE.String);
	return result;
epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
