    <JadeMethod name="setupForm" id="164f2529-3ae6-4cdf-841b-bbf2f53c9c39">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	sheetName : String;
	str : String;

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.myBulkRelease := self.myMobileGenericAgent.myBulkRelease;
	self.mySourceLocation := self.myMobileGenericAgent.myYardLocation;
	self.setMyTargetLocation ( self.myMobileGenericAgent.myLocationsController );
	
	//09 May 2017	NDL	TFS 4016
	self.applyTwelveStwRules :=  self.myTerminal.getConfig(UseAltSelectRulesTL).Boolean and app.isCargoGroupEnabled;
	if self.applyTwelveStwRules then
		str := self.myMobileGenericAgent.stringField1;
		if str &lt;&gt; null and str.isInteger then
			self.stwRuleNum := str.Integer;
			self.myMobileGenericAgent.setStringField1( null );
		endif;
	endif;
	
	self.allowLoadAll := false;

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	inheritMethod();
	
	if app.getMyUser.canDo(self.myTerminal, PmHHAllowLoadAll) then
		self.allowLoadAll := true;
	endif;
	
	if self.allowLoadAll then
		self.setupCmdButtons( 3, app.getErrorString(Complete),  app.getErrorString(Load_All), app.getErrorString(Back), null, null );	//11 Nov 2014	NDL	Par 35146
	else
		self.setupCmdButtons( 2, app.getErrorString(Complete),  app.getErrorString(Back), null, null, null );
	endif;
	
	setupControls();
	
	shtOnTruck.caption := app.getErrorString(Loaded);
	shtInYard.caption := app.getErrorString(CargoToLoad);
	shtInYard.setFocus;
	
	if self.allowLoadAll then
		self.btnTwo.enabled := self.inYardButtonCount &gt; 0;	//11 Nov 2014	NDL	Par 35146
	endif;
	self.txtCargoId.setFocus();	//19 Apr 2016	NDL	TFS 1868
	
	//23 Sep 2016	NDL	TFS 2648
	sheetName := self.myMobileGenericAgent.stringField1;
	if sheetName &lt;&gt; null then
		if sheetName = self.shtOnTruck.name then
			self.fldCargo.querySheetChg(self.fldCargo,self.shtOnTruck);
			self.fldCargo.topSheet := self.shtOnTruck;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInTargetLocation" id="736dbedb-5ead-49df-b548-668abe117fa6">
        <updating/>
        <source>setupInTargetLocation() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	cargoTypeString : String;
	quantityString : String;
	buttonHeight : Integer;
	reserveDetail : CM_ReserveDetail;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	reason : String;
	wc : CM_WagonController;
	
begin

	self.docActsToDispLoaded.clear();
	create tiArray transient;
	
	if self.isWagon then	//25 Jan 2017	NDL	TFS 3198/2877
		foreach wc in self.myWagon.allLocationsControllersArray do
			foreach ti in wc.allTrackedItems do
				tiArray.addExclusive(ti);
			endforeach;
		endforeach;
	else
		self.myTargetLocation.allTrackedItems.copy( tiArray );
	endif;
	size := tiArray.size;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );

	foreach ti in tiArray do
	
		reserveDetail := null;
		docActions := null;
		if self.myBulkRelease &lt;&gt; null then
			if ti.allBulkReleasesAssigned.includes( self.myBulkRelease) then
				reserveDetail := self.myBulkRelease.getReserveDetailFor( ti );
				if reserveDetail &lt;&gt; null then
					docActions := reserveDetail.myReserveDetailActions;
				endif;
			endif;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton = null then	//16 Oct 2015	NDL	Par 37033
			menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		endif;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" ;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"; 
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
		endif;
		
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDispLoaded.addExclusive( docActions );
			endif;
		endif;
		
		//26 Jan 2017	NDL	TFS 3198/2877
		if self.isWagon and self.myWagon.allLocationsControllersArray.size &gt; 1 then
			menuButton.caption :=  menuButton.caption &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullIdTI(ti);
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		self.allNotableObjects.add(ti);

		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	self.onTruckButtonCount := buttonNumber;	//30 Nov 2015	NDL	Par 37153
	
	if size = 0 then
		lblNoCargoTruck.visible := true;
		lblNoCargoTruck.caption := "No Cargo Loaded";
	else
		lblNoCargoTruck.visible := false;
	endif;
	
epilog

	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupInYard" id="129802c8-02c7-4b65-8623-af2e6257ecb0">
        <updating/>
        <source>setupInYard() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	desc1 : String;
	desc2 : String;
	qty : Integer;
	checksSubCargo : CM_TrackedItem;
	allowMoreCargoButton : Boolean;
	density : Decimal [16,4];
	weightRequested : Decimal [16,4];
	buttonHeight : Integer;
	reserveSelection : CM_ReserveSelection;
	
	reserveDetail : CM_ReserveDetail;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
begin

	self.docActsToDispToLoad.clear();

	//11 Nov 2014	NDL	Par 35146
	if self.inYardButtonCount &gt; 0 then
		foreach buttonNumber in 1 to self.inYardButtonCount do
			menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
		self.inYardButtonCount := 0;
		buttonNumber := 0;
	endif;

	self.txtCargoId.visible := true;
	self.txtCargoId.parent := self.shtInYard;
	self.txtCargoId.move(	0,
							1,
							self.shtInYard.width - self.resizedMargin,
							self.getStdControlHeight
							);

	allowMoreCargoButton := self.myTerminal.getConfig(AllowLoadMoreCargo).Boolean;	//04 Dec 2015	NDL	Par 36866
	allowMoreCargoButton := false;	// At the moment.
	
	create tiArray transient;
	
	reserveSelection := self.myMobileGenericAgent.myReserveSelection;	//11 Dec 2015	NDL	Par 37288 
	
	//09 May 2017	NDL	TFS 4016
	if self.applyTwelveStwRules then
		self.myMobileGenericAgent.getCargoBasedOnSTW12Rules( self.myBulkRelease, reserveSelection, self.mySourceLocation, self.myTargetLocation, self.stwRuleNum, tiArray );
	else
		self.getBRPropsectiveChildCargo( self.myBulkRelease, reserveSelection, self.mySourceLocation, self.myTargetLocation, tiArray );
	endif;
							
	size := tiArray.size;
	if allowMoreCargoButton then	//06 Mar 2014	NDL	Par 33554
		size := size + 1;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard );
	
	// add an extra button for finding unknown items....
	if allowMoreCargoButton then	
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := null;
		menuButton.caption := app.getErrorString( Find_more_cargo );
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;
	
	foreach ti in tiArray do
	
		//30 Nov 2016	NDL	TFS 2967
		reserveDetail := null;
		docActions := null;
		if self.myBulkRelease &lt;&gt; null then
			if ti.allBulkReleasesAssigned.includes( self.myBulkRelease) then
				reserveDetail := self.myBulkRelease.getReserveDetailFor( ti );
				if reserveDetail &lt;&gt; null then
					docActions := reserveDetail.myReserveDetailActions;
				endif;
			endif;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		//30 Nov 2016	NDL	TFS 2967
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDispToLoad.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.inYardButtonCount := buttonNumber;	//05 Aug 2014	NDL	Par 34675
	
	self.btnInYardTemp.visible := false;
	self.frmCargoInYard.caption := null;
	
	lblNoCargoYard.visible := false;	// because we have the 'find more cargo' button.
	
epilog

	delete tiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="523f87b9-86a2-45bf-a86f-eb5f0fede36f">
