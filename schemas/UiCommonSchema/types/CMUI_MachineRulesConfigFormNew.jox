    <JadeMethod name="setupForm" id="92ed41e5-b686-47ae-8c14-d84c4a626cd7">
        <updating/>
        <source>setupForm() updating;

// Created by cnwdvb1 on 05 September 2006
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 02/09/2011	cnwdap1		PAR #25693 CCMS POL 2008 Added Queuing Rule
vars
	entTableDef : EntTableDef;
begin

	inheritMethod();

	self.showToolbar := false;

	
	self.myAssistant.comboBoxMachineRuleType(self.cmbRuleType);

	entTableDef := app.myController.getEntTableDef(ETDef_MachineRulesTable);
	self.tblMoveRules.setTblDataEntRowsFromDef(entTableDef);
	self.tblMoveRules.userInputEnabled:=false;
	self.tblMoveRules.selectMode:=Table.SelectMode_CurrentRow;
	
	// PAR #25693
	self.cmbQueuingRule.addItem(LegMoveQueuing);
	self.cmbQueuingRule.addItem(FullMoveQueuing);
	self.cmbQueuingRule.listIndex := -1;
	self.cmbQueuingRule.enabled := false;
	// PAR #25693 end
	
	self.setFormFromRule();
end;</source>
    </JadeMethod>
