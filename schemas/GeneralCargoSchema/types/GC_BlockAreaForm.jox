    <JadeMethod name="doTableDblClick" id="94545d1b-2bfc-44f6-aae9-f0c6731990c4">
        <updating/>
        <source>doTableDblClick(_table:Table input) protected, updating;

vars
	itemObject		: CM_Object;
	tmpForm			: CM_TableViewForm;

begin

	if _table.CM_ColourLegendTable.myCaller.CMUI_ColourLegendFrame.viewMode = VIEW_YARD_ALLOC then
		self.btnViewYardAllEd.value := true;	// make sure the edit button is enabled
		self.doBtnEditYardAlloc();
		return;
	endif;

	if _table = null then
		return;
	elseif _table.row &lt;= _table.fixedRows then
		return;
	endif;
	
	itemObject	:=	_table.accessRow(_table.row).itemObject.CM_Object;
	
	if itemObject &lt;&gt; null then
		if itemObject.isKindOf(CM_Product) then
			tmpForm := self.showFormFromPermission(PmGCProductView, false).CM_TableViewForm;
			tmpForm.showWithObject(itemObject, false, false);
		elseif itemObject.isKindOf(CM_CargoType) then
			self.myAssistant.showCargoTypeForm(itemObject,null,null,false);
		elseif itemObject.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(itemObject.CM_Voyage, self.myMasterMenuAction, false, false);
		elseif itemObject.isKindOf(CM_BulkRelease) then
			self.myAssistant.releaseRequestView (itemObject.CM_BulkRelease, self.myMasterMenuAction);
		else
			self.myAssistant.showTableMaintForm(itemObject, self.myMasterMenuAction, false, false);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="310d69e6-3556-459f-89e1-739db187786d">
