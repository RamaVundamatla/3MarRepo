    </JadeMethod>
    <JadeMethod name="buildProductCode" id="970a6249-0c13-4e58-95cb-f790a75bb2c3">
        <source>buildProductCode(): String;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return app.buildLogProductCode(self.speciesCode, self.gradeCode, 
								   self.typeCode, self.treatmentCode, self.lengthCode);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="calculateSedMean" id="6e85ccee-dff2-4598-9fe7-745019f0cc5e">
        <updating/>
        <source>calculateSedMean() updating;
// -----------------------------------------------------------------------------
// Created:		18 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
//	difference : Integer;
	oldSedMean	: Decimal[6,2];
begin

	if self.sedMin = NULL_NEVERSCALED_LOG_SED or
	   self.sedMax = NULL_NEVERSCALED_LOG_SED then
		// In this case SEDMean is going to be set manually
	   	return;
	endif;	

	exclusiveLock(self);

	oldSedMean := self.sedMean;

	self.sedMean := global.calcSEDMean(self.sedMin, self.sedMax);

	if self.sedMean &lt;&gt; oldSedMean then
		self.recalcJASVolume();
	endif;

/*
	if self.sedMin = NULL_UNSCALED_LOG_SED or
	   self.sedMax = NULL_UNSCALED_LOG_SED then
	   	self.sedMean := NULL_UNSCALED_LOG_SED;
	   	return;
	endif;
	

	difference := (self.sedMax - self.sedMin).Integer;
	self.sedMean := self.sedMin;		//????
	if self.sedMin &gt;= 14 and self.sedMin &lt; 40 then
		self.sedMean := self.sedMean + ((difference div 6) * 2);
	elseif self.sedMin &gt;= 40 then
		self.sedMean := self.sedMean + ((difference div 8) * 2);
	endif;
	
	self.sedMean := self.sedMean.roundedTo(2);
*/	
end;</source>
    </JadeMethod>
