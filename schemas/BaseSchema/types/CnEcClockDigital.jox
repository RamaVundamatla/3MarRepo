    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isTwentyFourHour" id="ff410652-f5e6-4a74-92b9-4043afc3ed58">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeDisplay" id="4c43cc4e-c4e6-43e7-9b76-c37111f9c84b">
        <length>12</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="buildSelf" id="4d59fd1d-8320-4090-b5ab-5aa2d4a44617">
        <updating/>
        <source>buildSelf() updating;

vars
	time : Time;
	
begin
	inheritMethod();
		
	self.setClockSize();	
	self.setTime(time);
	self.setTimeDisplay();
	self.setPosition();
	self.displayTime();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTime" id="f68de744-c7fc-4103-94f8-43e7a3cc834f">
        <updating/>
        <source>displayTime() updating;

begin
	self.clearGraphics();
	self.autoRedraw	:=	true;
	self.drawTextAt(self.timeDisplay, self.clockLeft, self.clockTop, self.foreColor);
end;</source>
    </JadeMethod>
    <JadeMethod name="setClockSize" id="964f0f60-a2f2-4ac5-abbf-1004b702f755">
        <updating/>
        <source>setClockSize() updating;

vars
	time : String;
	
begin
	if self.width &lt; 90 then
		self.width := 90;
	endif;
	if self.height &lt; 25 then
		self.height := 25;
	endif;
			
	self.clockWidth		:=	self.width.Integer;
	self.clockHieght	:=	self.height.Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="setPosition" id="94dc5df7-49e5-40b2-bb48-d430ee08f75e">
        <updating/>
        <source>setPosition() updating;

begin
	self.drawFontSize := self.fontSize;
	self.drawFontBold := self.fontBold;
	
	self.clockTop	:=	((self.clockHieght - drawTextHeight(self.timeDisplay) ) / 2).Integer;
	self.clockLeft	:=	((self.clockWidth - drawTextWidth(self.timeDisplay) ) / 2).Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTimeDisplay" id="ac9a0082-bad8-4396-9a97-de37c1a8f25e">
        <updating/>
        <source>setTimeDisplay() updating;

vars
	clockHour	: String;
	clockMinute	: String;
	clockSecond	: String;
	meridian : String;
	
begin
	if self.isTwentyFourHour then
		meridian := "";
	else 
		meridian := " am";
	endif;			

	if not self.isTwentyFourHour and self.hour.Integer &gt; 12 then
		clockHour	:=	(self.hour.Integer - 12).String;
		meridian	:=	" pm";
		
		if clockHour.length() = 1 then
			clockHour :=  "0" &amp; clockHour;
		endif; 
	else
		clockHour := self.hour;
	endif;
	
	clockMinute	:=	self.min;
	clockSecond	:=	self.sec;
	
	if clockHour = "" then
		clockHour	:=	"00";
	endif;
	
	if clockMinute = "" then
		clockMinute	:=	"00";
	endif;
	
	if clockSecond = "" then
		clockSecond	:=	"00";
	endif;
	
	if self.isShowSeconds then
		self.timeDisplay := clockHour &amp; ":" &amp; clockMinute &amp; ":" &amp; clockSecond;
	else
		self.timeDisplay := clockHour &amp; ":" &amp; clockMinute;
	endif;
	
	if not self.isTwentyFourHour then
		self.timeDisplay := self.timeDisplay &amp; meridian;
	endif;
	
	if not self.isInPainter() then	
		self.setTimer();	
	endif;
end;</source>
    </JadeMethod>
