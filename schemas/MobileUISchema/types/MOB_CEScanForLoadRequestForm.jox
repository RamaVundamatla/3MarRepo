    <JadeMethod name="deleteObjectFromTable" id="f6bebb9d-1eed-4377-8bd2-d1b611a6d051">
        <updating/>
        <source>deleteObjectFromTable(obj: Object io) updating;

vars
	ti 			: CM_TrackedItem;
	wle,
	thisWLE 	: CM_WorkListEntry;
	result		: Integer;
begin
	if obj = null then
		return;
	endif;
	ti := obj.CM_TrackedItem;
	foreach wle in ti.allWorklistEntries do
		if wle.job = ti.jobRoadRelease then
			thisWLE := wle;
			break;
		endif;
	endforeach;
	if thisWLE = null then
		return;
	endif;
	while true do
		app.myTrxDA.trxDeleteJobEntry(thisWLE, null,  app.myPassport); // cnwrd1 par 22624 3.5.2010
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Road Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	self.loadCargoIDsTbl(self.tbl_CargoIDs);
	self.loadPackingReqTbl(self.tbl_PackingRqst);
end;
</source>
        <Parameter name="obj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCompleteTruck" id="369d546d-50a2-4268-b75a-fa92813d8e89">
        <updating/>
        <source>doCompleteTruck():Boolean updating;

vars
	job : CM_RoadJob;
	result : Integer;
begin
	if not self.myMobileDataAgent.deviceIsLastOnJob(myMobileDataAgent.myRoadJob, app.myMobileGUIAgent.strDevice) then
		app.msgBox(app.getErrorString(Truck_cannot_exit),"",MsgBox_OK_Only);
		return false;
	endif;
	job := self.myRoadJob;
	while true do
		app.myTrxUA.trxUpdateMobileCompleteTruck(job, self.myMobileDataAgent.strDevice , app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			result := app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors
			and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;	
	myRoadJob := null;
	app.myTrxUA.trxUpdateRoadJobDevices(job, app.myMobileGUIAgent.strDevice, self.myRoadJob.Remove_Device, app.myPassport);
	if app.myPassport.trxCompletedOK then
		app.myTrxUA.trxUpdateJobStatus(job, app.myPassport);
	endif;
	return true;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doContainerSave" id="0284ce10-da63-40fd-8925-c995756e260d">
        <source>doContainerSave(_item : CM_TrackedItem io; _job : CM_RoadJob io; _lc : CM_LocationsController input; unLoading : Boolean);

vars
	result 		: Integer;
	cmif_Cargo 	: CMIF_TIGenCargo;
	cmifArray 	: CMIF_TIObjectArray;
	cmif_Rel	: CMIF_ReleaseById;
	wle			: CM_WorkListEntry;
	wleArray,
	wlesWithWarnings: CM_WLEArray;
begin
	cmif_Cargo := myMobileDataAgent.createCMIFForTrackedItem(_item, CMIF_TIGenCargo.Action_ReleaseByID);
	create cmifArray transient;
	if cmif_Cargo = null then
		app.msgBox('Unexpected Program error creating table line - see developer', '', MsgBox_OK_Only);
		return;
	endif;
	if cmif_Cargo.myCMIFRelease = null then
		app.msgBox('Unexpected Program error creating table line - see developer', '', MsgBox_OK_Only);
		return;
	endif;
	cmif_Rel := cmif_Cargo.myCMIFRelease;
	create cmifArray transient;
	cmifArray.add(cmif_Rel);
	while true do
		wle := self.myMobileDataAgent.getWLEForTI(self.myRoadJob, _item);
		if wle = null then
			cmif_Rel.myIntFaceInOutCommon.roadTransAreaId := self.myTerminal.getConfig(DefWarehouseArea).String.trimRight();
			
			//app.myTrxCA.trxCreateInOutVehicle(cmif_Rel.myIntFaceInOutCommon, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
			app.myTrxCA.trxCreateInOut(cmif_Rel.myIntFaceInOutCommon, cmifArray, app.myPassport, null);	//TFS 53107, AjitM, navam1
			if app.myPassport.trxCompletedOK then
				wle := self.myMobileDataAgent.getWLEForTI(self.myRoadJob, _item);
			endif;
		endif;
		if wle &lt;&gt; null and wle.status &lt;&gt; WLE_COMPLETED then
			create wleArray transient;
			create wlesWithWarnings transient;
			wleArray.add(wle);	
			app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false, null,app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			result := app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors
			and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;

/*	while true do
		app.myTrxUA.trxUpdateRoadJobWithReleaseTI(_job, _item, app.myPassport, false);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			result := app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors
			and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
*/
epilog
	cmifArray.purge;
	delete wleArray;
	delete wlesWithWarnings;
	delete cmifArray;
end;</source>
        <Parameter name="_item" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_job" type="CM_RoadJob" usage="io"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="input"/>
        <Parameter name="unLoading" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPackComplete" id="ab24deb0-4faa-4eb7-8f7d-641ea3de30d9">
        <updating/>
        <source>doPackComplete() : Boolean updating;
//02 November 2009	cnwml2
//16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

vars
	theVehicle		: CM_Vehicle;
	theRoadJob		: CM_RoadJob;
	alertCreated	: Boolean;
	userResponse	: Integer;
	result			: Integer;
	
begin
	if not app.myCurrentUserCan(self.myRoadJob.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox("You do not have permission to perform this task", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;	
	
	theVehicle := self.myTruck;		
	theRoadJob := self.myRoadJob;
	
	while true do
		
		app.myTrxUA.trxUpdateRoadJobMobileLoadComp(theRoadJob, app.myPassport);
		
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Process Road Exit', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		
		self.blnRoadExit := true;
	
		//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
		app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
		
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Road Exit Process', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		
		return false;
	endwhile;

epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReserveDisplay" id="8e655512-700f-48a9-a0f5-9072bca8b849">
        <source>getReserveDisplay(_res: CM_ReserveDetail): String;
// ---------------------------------------------------------------------------
// Created:     01 May 2008 by cnwaer1
//
// Purpose:     
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
	product,
	marks,
	locs,
	str				: String;
	countRel,
	countOnsite		: Integer;
	ti 				: CM_TrackedItem;
	markArray 		: StringArray;
	allTis			: CM_TISet;
begin
	product := '';
	create markArray transient;
	create allTis transient;
	
	//epr 30546 15/10/12 
	if _res.getProductCode &lt;&gt; null then
		product := _res.getProductCode ;
	elseif _res.getISOType &lt;&gt; null then
		product := _res.getISOType.description;
	elseif _res.getCargoType &lt;&gt; null then
		product := _res.getCargoType.description;
	endif;
	
	countRel := _res.allTrackedItemsReleased.size;
	countRel := countRel + self.myRoadJob.allReleaseTrackedItems.size;
	_res.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in _res.allTrackedItems 
	foreach ti in allTis //23/06/2023	navkc1	CR 58406 Task 58408
	where not _res.allTrackedItemsReleased.includes(ti) 
	and not self.myRoadJob.allReleaseTrackedItems.includes(ti) do
		if ti.isOnSite  then
			countOnsite := countOnsite + 1;
			if locs &lt;&gt; '' then
				locs := locs &amp; CrLf;
			endif;
			locs := locs &amp; ti.getPrimaryLocation(REAL_MODE).getFullId;
			if not markArray.includes(ti.mark) then
				if marks &lt;&gt; '' then
					marks := marks &amp; CrLf;
				endif;
				marks := marks &amp; ti.mark;
				markArray.add(ti.mark);
			endif;
		endif;
	endforeach;
	str := product &amp; Tab &amp; _res.totalRequested.String &amp; Tab &amp; countRel.String
	&amp; Tab &amp; countOnsite.String &amp; Tab &amp; locs &amp; Tab &amp; marks;
	return str;
epilog
	delete markArray;
	delete allTis;
end;</source>
        <Parameter name="_res" type="CM_ReserveDetail"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTblCargoIDsSetting" id="fd525477-6bea-4f50-9d59-e42dd453b974">
