    <JadeMethod name="doPrintJRWReport" id="4eee40ee-e2b7-4bf1-9d79-cc4093a4d236">
        <source>doPrintJRWReport();
//----------------------------------------------------------------
//	Created:	01 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
05 May 2008	cnwkpd1	PAR #16602 - Correct behaviour for reports other than Rail Release Equipment Report
30 Jun 2017 cnwma1	TFS #4718:STWO - Release request print out - double copy (Original + copy)
*/

vars
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	report				: Object;
	featureColl			: MemberKeyDictionary;
	feature				: Object;
	pos					: Integer;
	queryPath			: String;
	jadeReport			: JadeReport;
	termDict			: CM_TerminalByCodeDict;
	jrwTransient		: CM_JRWTransient;
	bulkRelease			: CM_JRWBulkRelease;
	reserveDetails		: CM_JRWReserveDetails;
	useReserveDetails	: Boolean;
	printCopies 		: Integer;
begin
	jrwReport := self.cmbReport.listObject.JadeReportWriterReport;
	if jrwReport = null then
		app.msgBox('You must select a Jade Report Writer design to run the report against.','No report design selected.',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	// 32411 par 16602 checked for "CM_RailReleaseEquipReq" to use reserveDetails, changed to default to using reserveDetails
	//	unless report is "CM_MTRelSummaryRep"
	// 37098 fix this by checking the report definition, so that running a copy of CM_MTRelSummaryRep still works
	// NOTE: still to do - loadCmbReport loads all reports using view CM_MTReportView but several of these report use CM_JRWEmpty or CM_TrackedItems
	//		which are not populated here so produce no output.  Ideally these should be filtered out in loadCmbReport using the allFeatures check done here.
	report := jrwReport.getPropertyValue("persistentReport").Object;
	if report &lt;&gt; null then						//30.6.2017 cnwma1 TFS #4718
		printCopies := report.getPropertyValue("printCopies").Integer;
	endif;
	featureColl := report.getPropertyValue("allFeatures").MemberKeyDictionary;
	foreach feature in featureColl do
		queryPath := feature.getPropertyValue("queryPath").String;
		pos := queryPath.pos(".", 1);
		if pos &gt; 1 then
			if queryPath[1:pos-1] = "allReserveDetails" then
				useReserveDetails := true;
				break;
			elseif queryPath[1:pos-1] = "allBulkReleases" then
				break;
			endif;
		endif;
	endforeach;
	
	if useReserveDetails then
		reserveDetails := app.myQAFilter.createJRWTransient(CM_JRWReserveDetails).CM_JRWReserveDetails;
		jrwTransient := reserveDetails;
	else
		bulkRelease := app.myQAFilter.createJRWTransient(CM_JRWBulkRelease).CM_JRWBulkRelease;
		jrwTransient := bulkRelease;
	endif;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');
		return;
	endif;
	
	// PAR #16602 - Rework to optionally use reserve details
	// Set up the selection criteria and reporting collections
	if useReserveDetails then
		self.setReportSelCriteriaReserve(reserveDetails);
		reserveDetails.allReserveDetails.clear();
		self.getReserveDetails(reserveDetails.allReserveDetails);
	else
		self.setReportSelCriteriaBulk(bulkRelease);
		bulkRelease.allBulkReleases.clear();
		self.getReleasesToPrint(bulkRelease.allBulkReleases);
	endif;
		
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
	
	jrwManager := app.createReportWriterManager();
	create jadeReport transient;
	
	app.printer.printPreview := false;
	if self.optCSV.value then
		jrwReport.setOutputDestination(JadeReportWriterReport.CSV);
		jrwReport.setOutputFileTitle(self.txtFileName.text.trimBlanks());
	else
		jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	endif;
	
	jadeReport.description := jrwReport.name;
	if printCopies &lt;&gt; null then 
		jadeReport.copies:=printCopies; 					//30.6.2017 cnwma1 TFS #4718
	endif;
	app.printer.setReport(jadeReport);
	
	jrwReport.run();

	if self.chkPrintPreview.value and (not self.optCSV.value) then
		
		app.printPreview(jadeReport, true);
	else
		app.printer.printReport(jadeReport);
	endif;

	
epilog
	abortTransaction;		// to clear any locks held by the report writer
	
	delete jrwTransient;
	delete jrwManager;
	delete termDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintTblData" id="cd1d3ba1-987f-4a2e-93a0-ed9661b352c7">
