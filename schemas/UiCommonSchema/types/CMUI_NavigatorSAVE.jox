    <JadeMethod name="doDblClick2" id="0e784e8e-5525-4dba-8f3d-2fa774c7add9">
        <source>doDblClick2();
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuEnt	: CM_MenuEntity;
	
begin

	on Exception do app.invalidObjExHandler(exception, Err_MenusNeedReload);

	menuEnt := lstTest.listObject.CM_MenuEntity;
	
	if menuEnt.isKindOf(CM_MenuUserDtl) then
		menuEnt.CM_MenuUserDtl.doDblClick(null);
	elseif menuEnt.isKindOf(CMUI_MenuAction) then
		menuEnt.CMUI_MenuAction.handleDblClick();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDockTopLeft" id="04ead53a-c0d6-41af-9cfc-b852e12355af">
        <updating/>
        <source>doDockTopLeft(pDock : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pDock then
		mnuDockTopLeft2.checked := true;
		self.dockType := DockType_TopLeft;
		self.move(0, 0, self.width, self.height);
	else
		mnuDockTopLeft2.checked := false;
		self.dockType := DockType_Floating;
	endif;

end;</source>
        <Parameter name="pDock" type="Boolean"/>
    </JadeMethod>
