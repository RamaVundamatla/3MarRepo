    <JadeMethod name="getRowColour" id="cc3767d9-227c-44e2-a344-4aa82e8ccc14">
        <source>getRowColour(_foreColour: Integer output; _backColour: Integer output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.actualEndTs &lt;&gt; null then
		_backColour := self.Colour_HatchLidComplete;		
		
		_foreColour := Black;	
	else
		inheritMethod(_foreColour, _backColour);
	endif;

epilog

end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
