    <JadeMethod name="validateDateForStatusPost" id="ce36fe50-3257-4fe6-8e1d-72d7ab0c7094">
        <source>validateDateForStatusPost(closeDateTime	: TimeStamp) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	messageString : String;
	datetimeStart, datetimeEnd, invDate:   Date;
	rootCompany : CM_Bank;
	periodNumStart, periodNumCur,tmpPeriodNumCur,yearNumCur	: Integer;
	lastDay	: IntegerArray;
	ioClass	: CM_ExtFinanceIO;
	
begin
	// cnwjre1 Apr 2011 this validation gets in the way of invoicing testing ...
	if app.isJMTUnitTest then
		return true;
	endif;

	ioClass := app.getMyTerminalConfigDO_NOT_USE(FinancialIOClass).CM_ExtFinanceIO;	//PAR17685
	
	if ioClass = null then		// PAR17685
		return true;			// PAR17685
	endif;						// PAR17685
	
//	if ioClass.isKindOf(CM_Decfin) 											//PAR17685
	if app.myRoot.isClientPortOtago	//PAR17670 - cnwsh3 Not directly related but this should occur for Otago as they were using CM_Decfin before their financial system change.
	or app.myRoot.isClientCentrePort() then	//PAR17685 - CentrePort needs to use this functionality
		if ioClass.glPeriod.Integer &lt; 1 or ioClass.glPeriod.Integer &gt; 12 then
			return true;
		endif;
		invDate := closeDateTime.date;
		create lastDay transient;
		lastDay.add(31); // Jan
		if invDate.isLeapYear then
			lastDay.add(29); // Feb
		else
			lastDay.add(28); // Feb
		endif;
		lastDay.add(31); // Mar
		lastDay.add(30); // Apr
		lastDay.add(31); // May
		lastDay.add(30); // Jun
		lastDay.add(31); // Jul
		lastDay.add(31); // Aug
		lastDay.add(30); // Sep
		lastDay.add(31); // Oct
		lastDay.add(30); // Nov
		lastDay.add(31); // Dec

		periodNumCur := ioClass.glPeriod.Integer;
		periodNumStart := ioClass.firstMonthOfFinYear.Integer;
		tmpPeriodNumCur := periodNumStart + periodNumCur - 1; // PAR 10090

		yearNumCur := ioClass.glYear.Integer - 1; // XPOSE 3289 added
		if tmpPeriodNumCur &gt; 12 then // XPOSE 3289 added
			periodNumCur := tmpPeriodNumCur - 12; // XPOSE 3289 added
			yearNumCur := ioClass.glYear.Integer ; // XPOSE 3289 added
		elseif tmpPeriodNumCur &gt;= periodNumCur then // PAR 10090
			periodNumCur := periodNumCur + (tmpPeriodNumCur - periodNumCur); // PAR 10090
		endif; // XPOSE 3289 added
		datetimeStart.setDate(1,periodNumCur,yearNumCur);
		datetimeEnd.setDate(lastDay[periodNumCur],periodNumCur,yearNumCur);
		
		if invDate &gt;= datetimeStart and invDate &lt;= datetimeEnd then
			return true;
		else
			messageString := "Period " &amp; ioClass.glYear.trimBlanks &amp; "/" ;
			messageString := messageString &amp; ioClass.glPeriod.trimBlanks &amp; " - " &amp; datetimeStart.String &amp; " to " &amp; datetimeEnd.String;
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_INVALID_VALUE, "Closing Date", messageString, null, null);
			return false;
		endif;
	endif;

	return true;
epilog
	delete lastDay;
end;</source>
        <Parameter name="closeDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
