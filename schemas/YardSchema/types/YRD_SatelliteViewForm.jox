    <JadeMethod name="getXMLSettingsForSave" id="ead5fbf5-5700-4712-8398-5ed8a0e10eb5">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// --------------------------------------------------------------------------------
// Created:		18 February 2009 by cnwdad1
//
// Purpose:		Standard method for saving the receiver's contents/setting for the
//				current user.  Table columns will be restored automatically by the
//				EntTableDef stuff, however other local settings (if any are added
//				to this method) will need to be restored by implementing the
//				initFromUserWindow method on this form.
//
// Parameters:	None
//
// Returns:		The XML data containing the settings to save.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// --------------------------------------------------------------------------------
vars
	theXML				: String;
	totalWidth,
	usedWidth,
	qInWidth,
	qOutWidth,
	freeWidth,
	projectedWidth,
	planInWidth,
	planOutWidth,
	priorityWidth,
	deckingWidth,
	seqWidth,
	ifNoLocFoundWidth,
	overstowRuleWidth,
	allowOthersWidth : Integer;
	emptyLocn : CM_LocnStatsTable;
	emptyYAM : CM_YAMTable;
	userTerminal : CM_UserTerminal;
	oldTag,
	oldTAViewXML : String;
	invalidUserWindow : Boolean;
	userWindow		: CM_UserWindow;
	attrNameArray : StringArray;
	attrName : String;
	column : Integer;
	colWidth : Integer;
begin
	//we want to keep the other terminal's satellite view xml data 
	//so have to get it before we override it with what we have
	
	userWindow := self.myUserWindow;
	if userWindow &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userWindow, invalidUserWindow);
		theXML := userWindow .xmlInfo;
		if theXML &lt;&gt; null then
			foreach userTerminal in app.myPassport.myUser.allUserTerminals do
				if userTerminal.myTerminal = self.myTerminal then
					continue;
				endif;
				oldTag:=theXML.cnEcGetTagValueOfName(userTerminal.myTerminal.code &amp; self.XML_TAView);
				if oldTag &lt;&gt; null then
					oldTAViewXML:=oldTAViewXML &amp;  global.formatAsXML(userTerminal.myTerminal.code &amp; self.XML_TAView,oldTag);
				endif;
			endforeach;
		endif;
	endif;

	
	
	theXML	:=	inheritMethod();
	
	self.calculateTitleWidths(self.tblLocnStats,emptyYAM,totalWidth,usedWidth,qInWidth,qOutWidth,freeWidth,projectedWidth,planInWidth,planOutWidth,priorityWidth,deckingWidth,seqWidth,ifNoLocFoundWidth,overstowRuleWidth,allowOthersWidth); 

	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_totalWidth,totalWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_usedWidth,usedWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_qInWidth,qInWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_qOutWidth,qOutWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_freeWidth,freeWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_projectedWidth,projectedWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_planInWidth,planInWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_LocnStats_planOutWidth,planOutWidth.String);
				
	self.calculateTitleWidths(emptyLocn,self.tblYAM,totalWidth,usedWidth,qInWidth,qOutWidth,freeWidth,projectedWidth,planInWidth,planOutWidth,priorityWidth,deckingWidth,seqWidth,ifNoLocFoundWidth,overstowRuleWidth,allowOthersWidth); 
				
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_totalWidth,totalWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_usedWidth,usedWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_qInWidth,qInWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_qOutWidth,qOutWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_freeWidth,freeWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_projectedWidth,projectedWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_planInWidth,planInWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_planOutWidth,planOutWidth.String);
				
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_priorityWidth,priorityWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_deckingWidth,deckingWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_seqWidth,seqWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_ifNoLocFoundWidth,ifNoLocFoundWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_overstowRuleWidth,overstowRuleWidth.String);
	theXML := theXML &amp; global.formatAsXML(XML_YAMTable_allowOthersWidth,allowOthersWidth.String);

	//05 Jan 2012	NDL	Par 28889
	create attrNameArray transient;
	self.tblYAM.getGenFilterableColumns(attrNameArray);
	foreach attrName in attrNameArray do	
		column := self.tblYAM.getColumnByRowName(attrName);
		if column &gt; 0 then
			colWidth := self.tblYAM.accessColumn(column).width;
			if colWidth &gt; 0 then
				theXML := theXML &amp; global.formatAsXML("YAMTable_" &amp; attrName &amp; "Width", colWidth.String);
			endif;
		endif;	
	endforeach;
	
	//21 Sep 2011	NDL Par 28236
	theXML := theXML &amp; global.formatAsXML(XML_DblClickAction,self.dblClickAction);
				
	
	theXML	:=	theXML &amp; self.tblYAM.getXmlStrForColumns(false);
	theXML	:=	theXML &amp; self.tblLocnStats.getXmlStrForColumns(false);
	theXML	:=  theXML &amp; self.tblFailAutoPlan.getXmlStrForColumns(false);	//16 May 2012	NDL	Par 29356
	theXML	:=  theXML &amp; self.tblFailRequest.getXmlStrForColumns(false);	//16 May 2012	NDL	Par 29356
	
	if self.myTerminalAreaView &lt;&gt; null then
		theXML := theXML &amp; 	global.formatAsXML( self.myTerminal.code&amp;XML_TAView,self.myTerminalAreaView.getOidString);
	endif;
	theXML:=theXML &amp; oldTAViewXML;
	return theXML;
	
epilog
	delete attrNameArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="5101840c-b422-403d-ba56-345383cfa0e7">
        <updating/>
        <source>getXMLSettingsForSetup() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;

begin

	inheritMethod();
	
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_DblClickAction);
 	if theXMLValue &lt;&gt; null then
 		self.dblClickAction := theXMLValue;
 	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hasCargoInObject" id="508770a0-ca9f-4d2b-816b-1cafdcf54ad9">
        <source>hasCargoInObject(_object :Object):Boolean protected;
/*
Purpose		Use instead of findCargoFromObject if you just want to know if there are any TIs.  Saves populating
			collection with all TIs
Parameters	_object	- a terminal area, grid object or null (selected region)
Returns		true if there are TIs in _object

Date		Who		Reason
08 November 2011	cnwcs5	Initial creation - par 28623 menu build performance issues
*/
vars
	termArea 	: CM_TerminalArea;
	gridObject 	: CM_GridObject;
	irrBlockCont : CM_IrregularBlockController;
	obj 		: Object;
	array		: ObjectArray;
begin

	if _object = null then
		if self.allSelectedRegionLocs.isEmpty then
			// nowehere to look
			return false;
		endif;
		
		foreach obj in self.allSelectedRegionLocs do
			if not obj.CM_LocationsController.allTrackedItems.isEmpty then
				// there are tracked items
				return true;
			endif;
		endforeach;
		// nothing found
		return false;
	endif;
		
	if _object.isKindOf(CM_TerminalArea) then
		termArea := _object.CM_TerminalArea;
		
	elseif _object.isKindOf(CM_GridObject) then
		gridObject := _object.CM_GridObject;
		
	elseif _object.isKindOf(CM_IrregularBlockController) then
		irrBlockCont := _object.CM_IrregularBlockController;
		
	else
		// nowhere to look
		return false;
	endif;
	
	create array transient;
	
	if termArea &lt;&gt; null then
		termArea.getAllLCsWithCargo(array);
		
	elseif gridObject &lt;&gt; null then
		gridObject.getAllLocationsControllers(array, true);
		
	elseif irrBlockCont &lt;&gt; null then
		if irrBlockCont.isRack then
			irrBlockCont.allSubLocations.copy(array);
		else
			array.add(irrBlockCont);
		endif;
	endif;
	
	if array.isEmpty  then
		// only contains LCs that have tracked items
		return false;
	endif;
	
	return true;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesCargoInShowableArea" id="36d017c1-48b8-48dc-b3c4-0f94b2b005cc">
        <source>includesCargoInShowableArea():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28901

*/

vars

	lc : CM_LocationsController;

begin

	foreach lc in self.allSelectedRegionLocs discreteLock do
		if lc.isGridLocation then
			return true;
		elseif lc.isRoRoController then
			return true;
		endif;
	endforeach;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
