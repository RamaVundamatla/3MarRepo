    <JadeMethod name="isTiLoaded" id="91f02e5e-aa8b-4659-8002-3f17cfdbb1b9">
        <source>isTiLoaded(_ti: CM_TrackedItem; _target: CM_LocationsController): Boolean;
/*
Purpose:	has the Ti been loaded to the target?		

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2015	cnwdw1	Initial creation  PAR 35781
*/
vars

begin

	//26 Jan 2017	NDL	TFS 3198/2877
	if _target.isWagon and _ti.myPrimaryActualLocation.isWagon then
		return ( _ti.myPrimaryActualLocation.CM_WagonController.myWagon = _target.CM_WagonController.myWagon );
	endif;
			
	return _ti.myPrimaryActualLocation = _target;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_target" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTargetLocation" id="0058501a-772b-4c2e-a64c-69c4e2148973">
        <updating/>
        <source>setMyTargetLocation( _lc : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2017	cnwndl1	Initial creation	TFS 3198/2877

*/

vars

begin

	self.myTargetLocation := _lc;
	self.isWagon := ( _lc &lt;&gt; null and _lc.isWagon );
	if self.isWagon then
		self.myWagon := _lc.CM_WagonController.myWagon;
	else
		self.myWagon := null;
	endif;
	self.isVehicle := ( _lc &lt;&gt; null and _lc.isVehicle );
	if self.isVehicle then
		self.myTruck := _lc.CM_VehicleController.vehicle;
	else
		self.myTruck := null;
	endif;
	self.isTrailer := ( _lc &lt;&gt; null and _lc.isTILCController );
	if self.isTrailer then
		self.myTrailer := _lc.CM_TILCController.myTILC;
	else
		self.myTrailer := null;
	endif;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
