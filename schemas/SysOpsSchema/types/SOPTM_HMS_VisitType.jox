begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="7fa25475-54b9-4a50-91c1-9c2a2dc63885">
        <source>setupThumbnailDetails();
// --------------------------------------------------------------------------------
// Created:		04 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj	: SOP_TableMaintForm;
	
begin
	formObj	:=	self.myForm;
	formObj.useProxyObject	:=	true;
	formObj.setTblDataEntRows(ETDef_HMSTblData);
	//12/01/2011 cnwdz2 25840
//	formObj.zClearSortColumns();
//	formObj.zAddSortColumn(ETRow_Code, false);


//	formObj.zAddSortColumn(ETRow_Description, false);

	formObj.shtTblInput1.caption	:=	"Details";

	formObj.initTblInput(formObj.tblInput1, ETDef_HMSTblData);
	formObj.shtTblInput1.visible	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7395c4eb-e1f6-444a-8d71-de58be2f239e">
        <updating/>
        <source>showThumbnail(pObj:HMS_VisitType) updating;
// --------------------------------------------------------------------------------
// Created:		04 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj		: SOP_TableMaintForm;
	
begin
    formObj	:=	self.myForm;
	formObj.tblInput1.clearValues();
	formObj.tblInput1.setValueByName(ETRow_Code, pObj.code);
	formObj.tblInput1.setValueByName(ETRow_Description, pObj.description);
end;</source>
        <Parameter name="pObj" type="HMS_VisitType"/>
    </JadeMethod>
</Class>
