		sent_6  := JadeRegex@replaceAll(sent_6 , "", IdRegex, true);			
		exp_6 := JadeRegex@replaceAll(exp_6, "", IdRegex, true);
		
		self.assertTrueMsg(sent_6.compareEql(exp_6,true,false,null),"The message sent for UC6 was not as expected"&amp;"SENT"&amp;CrLf&amp;sent_6&amp;"EXPECTED"&amp;CrLf&amp;exp_6);		
	endif;
	
	beginTransaction;			
		camProtocol.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, false);		
	commitTransaction;
	
	theLines.purge();
	delete theLines;				
	
