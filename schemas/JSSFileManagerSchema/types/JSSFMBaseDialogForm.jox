    <ImplicitInverseRef name="aMyServiceManager" id="381d8b18-8cdd-4545-9574-4a283c3ff784">
        <embedded/>
        <type name="JSSFMServiceManager"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="aMyServiceObject" id="d87646d7-6204-4d9e-adb8-3077933f630a">
        <embedded/>
        <type name="JSSFMFileManagerService"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="setServiceManager" id="0b63435b-0f68-46e0-a570-6fcdae67755b">
        <updating/>
        <source>setServiceManager(pTheServiceManager:JSSFMServiceManager) updating;
// --------------------------------------------------------------------------------
// Created:		23 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyServiceManager &lt;&gt; pTheServiceManager then
		self.aMyServiceManager	:=	pTheServiceManager;
	endif;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSFMServiceManager"/>
    </JadeMethod>
    <JadeMethod name="setServiceObject" id="c2eccf69-8241-45df-832c-3c7782bcbc8a">
        <updating/>
        <source>setServiceObject(pTheServiceObject:JSSFMFileManagerService) updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyServiceObject &lt;&gt; pTheServiceObject then
		self.aMyServiceObject	:=	pTheServiceObject;
	endif;
end;</source>
        <Parameter name="pTheServiceObject" type="JSSFMFileManagerService"/>
    </JadeMethod>
</GUIClass>
