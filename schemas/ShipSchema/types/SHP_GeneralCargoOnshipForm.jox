        <source>tblStowagePlan_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	hatch : CM_GeneralCargoController; 
begin
	hatch := table.accessRow(table.row).itemObject.CM_GeneralCargoController;
	if hatch &lt;&gt; null then
		self.btnStowageEdit.enabled := true;
		self.btnStowageDelete.enabled := true;
