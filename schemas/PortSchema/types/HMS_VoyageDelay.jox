    <JadeMethod name="pxyCreateUpdateProxy" id="c81f19cd-f737-4e78-9f54-78558604f18d">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_VoyageDelay;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myDelay := self.myDelay;
	proxy.myVoyageDataArchived := self.myVoyageDataArchived;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b8aa3be9-ecf3-47ed-bf19-3717dc15b268">
        <updating/>
        <source>setForCreate(_pxyObj: HMS_VoyageDelay; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	09 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	// DVB changed. Don't want an add transaction and an edit transaction.
	self.archived := _pxyObj.archived;
	self.archivedDT := _pxyObj.archivedDT;
	self.isChargeable := _pxyObj.isChargeable;
	self.myDelay := _pxyObj.myDelay;
	
	self.myVoyageData := _pxyObj.myVoyageData;
	
	self.setStartStopDateTime(_pxyObj.startTime, _pxyObj.stopTime);
	if (not app.isConverting) then
		self.createTransaction(TRANS_TYPE_AddVoyageDelay, null, _pxyObj, _passport);
	endif;
end;</source>
        <Parameter name="_pxyObj" type="HMS_VoyageDelay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="17f3c123-5f66-4bf7-af55-971608843f88">
        <updating/>
        <source>setForUpdate(_pxyVoyDelay : HMS_VoyageDelay; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars

	createEditTransaction : Boolean;

begin
	inheritMethod(_pxyVoyDelay, _passport);

	if self.archived &lt;&gt;  _pxyVoyDelay.archived then
		self.archived := _pxyVoyDelay.archived;	
		createEditTransaction := true;
	endif;
	
	if self.archivedDT &lt;&gt; _pxyVoyDelay.archivedDT then
		self.archivedDT := _pxyVoyDelay.archivedDT;
		createEditTransaction := true;
	endif;
	
	if self.isChargeable &lt;&gt; _pxyVoyDelay.isChargeable then
		self.isChargeable := _pxyVoyDelay.isChargeable;
		createEditTransaction := true;
	endif;
	
	if self.myDelay &lt;&gt; _pxyVoyDelay.myDelay then
		self.myDelay := _pxyVoyDelay.myDelay;
		createEditTransaction := true;
	endif;
	
	if self.startTime &lt;&gt; _pxyVoyDelay.startTime or self.stopTime &lt;&gt; _pxyVoyDelay.stopTime then
		self.setStartStopDateTime(_pxyVoyDelay.startTime, _pxyVoyDelay.stopTime);
		createEditTransaction := true;
	endif;

	// Shifted transaction after updates.	
	if (not app.isConverting) and createEditTransaction  then //rs nov 2004 dont want to create trans when creating voyage adds
		self.createTransaction(TRANS_TYPE_EditVoyageDelay, null, _pxyVoyDelay, _passport);
	endif;	

end;</source>
        <Parameter name="_pxyVoyDelay" type="HMS_VoyageDelay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromWorkingDelay" id="14cc6926-a328-4b37-8243-d3a36ce5c0e9">
        <updating/>
        <source>setFromWorkingDelay(_cmifVoyageDelayWorking : CMIF_HMS_VoyageDelay; _transType : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myVoyageData 	:= _cmifVoyageDelayWorking.myHMSVoyageData;	
	self.createTransaction(_transType, _cmifVoyageDelayWorking, null, _passport);											
	self.isChargeable 	:= _cmifVoyageDelayWorking.isChargeable;
	self.startTime 		:= _cmifVoyageDelayWorking.startTime;
	self.stopTime 		:= _cmifVoyageDelayWorking.stopTime;
	self.myDelay 		:= _cmifVoyageDelayWorking.myDelay;
end;</source>
        <Parameter name="_cmifVoyageDelayWorking" type="CMIF_HMS_VoyageDelay"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="00782f43-8acd-45ea-9411-a4b0c39954b8">
        <updating/>
        <source>setProxy(_isChargeable : Boolean; _startTime, _stopTime : TimeStamp; _myDelay : HMS_Delay; _voyageData : HMS_VoyageData) updating;
//--------------------------------------------------
// Created:	09 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.isChargeable := _isChargeable;
	self.myDelay := _myDelay;
	self.myVoyageData := _voyageData;
	
	self.setStartStopDateTime(_startTime, _stopTime);

end;</source>
        <Parameter name="_isChargeable" type="Boolean"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_stopTime" type="TimeStamp"/>
        <Parameter name="_myDelay" type="HMS_Delay"/>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="setStartStopDateTime" id="219a6afd-dca8-4b2a-bee5-6d9bf187f51e">
        <updating/>
        <source>setStartStopDateTime(_start, _stop : TimeStamp) updating;
//--------------------------------------------------
// Created:	01 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _start &gt; _stop then
		self.startTime := _stop;
		self.stopTime := _start;
	else
		self.startTime := _start;
		self.stopTime := _stop;	
	endif;
end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_stop" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="31c1d48c-b421-442c-8652-8fd227062d9c">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	existingDelay,
	tmpDelay,
	realDelay : HMS_VoyageDelay;
begin
	inheritMethod(_passport);

	self.raiseExceptionIfNotTransient(method);
	
	if self.myDelay = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Delay', ETRow_MyDelay, null );
		app.raiseCMException(Input_required_field_delay, ETRow_MyDelay, null ); // cnwdb2	PAR 35364
	endif;
	
	if (not self.startTime.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Delay Start Date', ETRow_DelayStartDate, null );
		app.raiseCMException(Input_required_field_delSrtDte, ETRow_DelayStartDate, null ); // cnwdb2	PAR 35364
	endif;

	if (not self.stopTime.isValid) then
//		app.raiseCMException1(REQUIRED_FIELD, 'Delay End Date', ETRow_DelayEndDate, null );
		app.raiseCMException(Input_required_field_delEndDat, ETRow_DelayEndDate, null ); // cnwdb2	PAR 35364


	endif;

	if self.startTime &gt;= self.stopTime then
		app.raiseCMException1(AutoScheduleDateError, 'Start date/time must be before finish date/time', null, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//---------------------------------------------------------------------------
	// Check for duplicates - 
	//---------------------------------------------------------------------------
	if self.isTransient then		
		realDelay := self.pxyGetRealObject();
	endif;

	foreach tmpDelay in self.myVoyageData.allVoyageDelays do
		if tmpDelay = self then
			continue;
		endif;
		if tmpDelay = realDelay then
			continue;
		endif;		
		if tmpDelay.isTransient then
			existingDelay := tmpDelay.pxyGetRealObject();
		endif;
		if existingDelay &lt;&gt; null then
			if existingDelay = realDelay then
				continue;
			endif;
		endif;
		
		if tmpDelay.myDelay = self.myDelay then
			//app.raiseCMException2(DuplicateItem, 'Voyage Delay', self.myDelay.code, ETRow_MyDelay, null); //14.06.2022 navds20 53760
			// Voyage Delay already exists for %1 : Voyage_delay_already_exists
			app.raiseCMException1(Voyage_delay_already_exists, self.myDelay.code, ETRow_MyDelay, null);  //14.06.2022 navds20 53760
			return;		
		endif;
		if tmpDelay.startTime = self.startTime then
			//app.raiseCMException2(DuplicateItem, 'Voyage Delay ' &amp; tmpDelay.getDisplayString(), self.startTime.shortCurrentLocaleFormat(), ETRow_MyDelay, null); //14.06.2022 navds20 53760
			//Voyage Delay already exists for %1 : Voyage_delay_already_exists
			app.raiseCMException2(Voyage_delay_already_exists, tmpDelay.getDisplayString(), self.startTime.shortCurrentLocaleFormat(), ETRow_MyDelay, null); //14.06.2022 navds20 53760
			return;		
		endif;
	endforeach;
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
