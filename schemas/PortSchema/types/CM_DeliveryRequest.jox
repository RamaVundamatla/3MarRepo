        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_widthString" type="String"/>
        <Parameter name="_heightString" type="String"/>
        <Parameter name="_lengthString" type="String"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_yardInstructions" type="String"/>
        <Parameter name="_type" type="String"/>
