epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="dac498ac-bbd9-4bcf-93e2-80749062ffc2">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	30 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
20/04/2011	 cnwmh5		 PAR #27401 - Add code to handle prossible exceptions occurring when
						 trying to create the proxy
*/
vars
	delayType : SelfType;
	completedOK		: Boolean;
	
begin
	
	delayType := inheritMethod();
	
	self.allDelayTypeGroups.copy(delayType.allDelayTypeGroups);
	delayType.myMachineAvailability := self.myMachineAvailability;
	
	//24 Aug 2018	NDL	TFS 40309
	delayType.myEventTypeToCreate := self.myEventTypeToCreate;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return delayType;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete delayType;
	endif;
	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="61bc5782-fcbd-4fb8-86b1-8707347ee90c">
        <updating/>
        <source>setForCreate(pProxyDelayType : CM_DelayType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	pProxyDelayType.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(pProxyDelayType);
	self.myRoot := app.myRoot;
end;
</source>
        <Parameter name="pProxyDelayType" type="CM_DelayType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="faa5cb62-7b89-478c-be6a-1bdfdef88973">
        <updating/>
        <source>setForUpdate(_proxy : CM_DelayType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02/04/2011 	cnwcs5		CCMS 1132 - add is not available for entry
06/09/2011	cnwcs5		CCMS MES 1033 - add requires workpoint
*/
vars

begin
	self.description 			:= _proxy.description.trimBlanks;
	self.myMachineAvailability 	:= _proxy.myMachineAvailability;
	self.canScheduleInAdvance 	:= _proxy.canScheduleInAdvance;
	self.requiresMachine 		:= _proxy.requiresMachine;
	self.requiresVoyage 		:= _proxy.requiresVoyage;	
	self.requiresWorkpoint		:= _proxy.requiresWorkpoint;
	self.delayTypeOrder 		:= _proxy.delayTypeOrder;
	self.isOperational 			:= _proxy.isOperational;
	self.isNotAvailableForEntry	:= _proxy.isNotAvailableForEntry;
	
	
	//24 Aug 2018	NDL	TFS 40309
	if self.myEventTypeToCreate &lt;&gt; null and self.myEventTypeToCreate &lt;&gt; _proxy.myEventTypeToCreate then
		self.myEventTypeToCreate := null;
	endif;
	self.myEventTypeToCreate := _proxy.myEventTypeToCreate;
	
	self.allDelayTypeGroups.clear();
	
	_proxy.allDelayTypeGroups.copy(self.allDelayTypeGroups);
end;
</source>
        <Parameter name="_proxy" type="CM_DelayType"/>
    </JadeMethod>
    <JadeMethod name="setMyEventToCreate" id="95c627ef-222e-48c6-b95e-bae9bc627e63">
