    <JadeMethod name="getNumberFulfilled" id="aa3f1e02-e4e9-40b8-829b-9cdf1b4be3fa">
        <source>getNumberFulfilled() : Integer;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutLine		: CM_BOLOutStockOrderLineTI;
	cnt				: Integer;
begin
	foreach bolOutLine in self.allBOLOutStockOrderTIs do
		if bolOutLine.myTrackedItem &lt;&gt; null then
			cnt := cnt + 1;
		endif;
	endforeach;

	return cnt;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberUnfulfilled" id="574a4bea-e778-4214-af8f-27c370b48d14">
        <source>getNumberUnfulfilled(): Decimal;
// ---------------------------------------------------------------------------
// Created:     05 July 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	numFulfilled			: Integer;
begin

	numFulfilled := self.getNumberFulfilled();
	if self.reqdQuantity &gt; numFulfilled then
		return (self.reqdQuantity - numFulfilled);
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getPercentFulfilled" id="c50bcb4b-402e-40f8-b735-ac8678685f59">
        <source>getPercentFulfilled() : Decimal;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnVal			: Decimal[5,2];
	numFulfilled	: Integer;
begin
	numFulfilled := self.getNumberFulfilled();
	if self.reqdQuantity &lt;= 0 then
		return null;
	endif;
	
	if (numFulfilled &gt;= self.reqdQuantity) then
		rtnVal := 100;
	else
		rtnVal := ((numFulfilled / self.reqdQuantity) * 100);
	endif;
	
	return rtnVal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
