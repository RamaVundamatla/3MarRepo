06/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars

begin
	self.externalRef1 	:= _pxyInvoiceLine.externalRef1;
	self.externalRef2 	:= _pxyInvoiceLine.externalRef2;
	self.externalRef3 	:= _pxyInvoiceLine.externalRef3;
	self.externalRef4	:= _pxyInvoiceLine.externalRef4;
	self.quantity		:= _pxyInvoiceLine.quantity;
	self.uomCode		:= _pxyInvoiceLine.uomCode;
epilog

