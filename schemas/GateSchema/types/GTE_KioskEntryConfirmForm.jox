	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
	app.beep();
	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSwap_click" id="21312ef1-1ae8-4f3a-b251-9012042d2b80">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSwap_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
