    <JadeMethod name="bgpRunReportRequest" id="061d923b-f47e-4216-9242-791a5568cb64">
        <source>bgpRunReportRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2019	jlgsl4	TFS 44013 - POL - UI output different from BGP for rel req report
*/

vars
	bgpRequest : BGP_Request;
	bgpController : BGP_ReportController;
begin
	app.initialize(); // relies on a Template Reporting BGP task having run first to create
	app.setIsBackGroundApp(true); // the BGP_ReportRequest
	foreach bgpController in BGP_ReportController.instances where bgpController.myBGPManager &lt;&gt; null and
		bgpController.myBGPManager.name = "MAP"	and bgpController.numQueuedRequests = 1 do
			break;
	endforeach;
	//bgpRequest := BGP_ReportRequest.instances.first.BGP_Request;
	bgpRequest := "5000.90".asOid.BGP_ReportRequest;
	process.profiler.methodCount := 50;
	process.profiler.start();
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, bgpRequest, app.myPassport);
	app.myBGPObject := bgpController;
	//app.logLevel := LogNormal;
	//bgpController.initApp();
	bgpRequest.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog
	app.setIsBackGroundApp(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="bgpRunWSRequest" id="aab95175-809a-4aff-a746-f492c9385d58">
        <source>bgpRunWSRequest();
//
//25 June 2018	jlgrs1	Initial creation
//
vars
	bgpRequest : BGP_Request;
	bgpController : BGP_ExternalWSController;
begin
	app.initialize();
	app.setIsBackGroundApp(true);
	foreach bgpController in BGP_ExternalWSController.instances do
		if global.isValidObject(bgpController.myExternalWSDef) and
		   bgpController.myExternalWSDef.isKindOf(CM_SAPWebService) then
			break;
		endif;
	endforeach;
	bgpRequest := BGP_SAPWSRequest.instances.first.BGP_Request;
	process.profiler.methodCount := 50;
	process.profiler.start();
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, bgpRequest, app.myPassport);
	app.myBGPObject := bgpController;
//	app.logLevel := LogNormal;
//	bgpController.initApp();
	bgpRequest.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog
	app.setIsBackGroundApp(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="bj_CheckForCorruptGlobalConsts" id="434fca0f-b552-4fae-8ed0-f20d07420875">
        <source>bj_CheckForCorruptGlobalConsts() protected;

vars
	schema					: Schema ;
	constantCategory		: Constant;
	constant				: Constant;
	tmpCategoryDict			: ConstantNDict;
	tmpConstantDict			: ConstantNDict;
	schemaName				: String;
	className				: String;
	controlName				: String;
	controlProperty			: String;
	xmlDoc					: CM_XMLDocument;
	xmlElement				: JadeXMLElement;
	xmlArray				: JadeXMLElementArray;
begin
	create xmlDoc transient;
	create xmlArray transient;

	schema		:= rootSchema.getSchema(PortSchemaName) ;

	tmpCategoryDict := schema.getConstantCategory("XLAT_GCCatetegories").getConstants;

	foreach constantCategory in tmpCategoryDict do
	
		if constantCategory.name &lt;&gt; 'XLAT_FormCaptions' then 
			continue ;
		endif;

		// for each translatable text item ...
		if schema.getCategory(constantCategory.name) = null then
			app.writeStatement( 'Unable to find category....');
			continue ;
		endif;
		
		tmpConstantDict := schema.getCategory(constantCategory.name).getConstants();
		foreach constant in tmpConstantDict where constant.text &lt;&gt; null do
			xmlDoc.parseString(constant.text);
			xmlDoc.getElementsByTagName(XMLTag_Header, xmlArray);
			xmlElement := xmlArray[1];
		
			schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
			className := xmlElement.getAttributeByName(XML_Tag_FormClass).value;
			controlName := xmlElement.getAttributeByName(XML_Tag_ControlName).value;
			controlProperty := xmlElement.getAttributeByName(XML_Tag_ControlProperty).value;
			
			if schemaName = null or
				className = null or
				controlName = null or
				controlProperty = null then
				app.writeStatement( constant.name);
			endif;
		endforeach;	// constant

	endforeach; // category

epilog
	delete xmlDoc ;
	delete xmlArray ;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="boomController" id="d2a3dea7-05f0-4ace-8122-73933a393faa">
        <source>boomController();

constants
	ConnectionTimeOut = 2000;
	SendTimeOut = 2000;
	ReceiveTimeOut = 2000;
	Module  = 6060;
vars
	conn		: JadeHTTPConnection;
	ipAddress	: String;
	channel		: Integer;
	user : String;
	password : String;
	authString : String;
	authToken : String;
	headers : String;
	
	byte 		: Binary;

	returnVal		: String;
	sendSuccess		: Boolean;
	
begin
	app.initialize();

	ipAddress:="172.16.64.200";
	channel := 1;
	user := "root";
	password := "00000000";
	
	authString := user &amp; ":" &amp; password;
	byte := authString.Binary; //authString.asANSI();
	authToken := byte.base64Encode();
	//cm9vdDowMDAwMDAwMA==
	headers := "Authorization: " &amp; "Basic " &amp; authToken;
	
	
	create conn transient;
	
	// Set timeouts of required
	/*
	if self.timeoutSeconds &lt;&gt; 0 then
		timeoutMS := self.timeoutSeconds * 1000;
		conn.sendTimeout := timeoutMS;
		conn.receiveTimeout := timeoutMS;
	endif;
	*/
	
	conn.url := "http://172.16.64.200/digitaloutput/all/value";
	
	sendSuccess := conn.sendRequest(JadeHTTPConnection.Verb_GET, headers, null);
	write conn.queryStatusCode();
	
	if sendSuccess then
		conn.readBody(0);
		returnVal := conn.responseBody.StringUtf8.String;
		app.writeLog("BOOM TEST:" &amp; Space &amp; returnVal, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		write returnVal;
	else

	app.writeLog("BOOM TEST: Send Request Failed", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		write "sendRequest failed";
	endif;
	
	write "DONE";
	
	
	
	
	
	/*
	
	// Set first byte to true. Only one channel
	byte[1]:=1;
		
	result := call adamTcp_Open;	
	if result &lt;&gt; 0 then
		write "failed to open";
		return;
	endif;
	
	result := call adamTcp_Connect(ipAddress,ipPort,ConnectionTimeOut,SendTimeOut,ReceiveTimeOut);
	//write result;
	if result &lt;&gt; 0 then
		write "failed to connect";
		return;
	endif;
	
	// Push the button
	call adamTcp_Write6KDO(ipAddress,Module,1,channel,1,byte);
	
		
	if result &lt;&gt; 0 then
		write "failed to write";
		return;
	endif;
	
	// Wait a little bit.
	process.sleep(500);
	
	// Set first byte to false. Only one channel
	byte[1]:=0;
	
	// Take finger of button.
	call adamTcp_Write6KDO(ipAddress,Module,1,channel,1,byte);
	
	if result &lt;&gt; 0 then
		write "failed to write";
		return;
	endif;
	
	call adamTcp_Disconnect();
	call adamTcp_Close;
	
	write "done";
	return;
	*/
epilog
	delete conn;

end;
</source>
    </JadeMethod>
    <JadeMethod name="buildJCFForCategory" id="a25805e2-6723-4506-a94c-7651ad0c1d4f">
        <updating/>
        <source>buildJCFForCategory(_file : File; _category : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2010	conkc1	Initial creation
*/
vars
	agent	: FormCaptionsAgent;
	constantObj		: Constant;
	allMethodRefs	: MethodSet;
	lsSchema		: LSschema;
	lsClass			: LSclass;
	otherConstant	: LSconstant;
	lsConstant		: LSconstant;
	controlName		: String;
	controlProperty	: String;
	schemaName		: String;
	formClass		: String;
	xmlDoc			: CM_XMLDocument;
	xmlElement		: JadeXMLElement;
	attribute       : JadeXMLAttribute;
	errStr			: String;
	textElement		: JadeXMLElement;
	textValue		: String;
	logMsg			: String;
	count           : Integer;
	
	
begin

	create agent transient;
	agent.fillSchemas();
	
	create allMethodRefs transient;
	
	foreach constantObj in rootSchema.getSchema(PortSchemaName).getCategory(_category).getConstants do
		
		allMethodRefs.clear();
		constantObj.getMethodRefs(allMethodRefs);
		
		if allMethodRefs.isEmpty() then
			if constantObj.getPropertyValue('schema').Schema.getPropertyValue('name').String = 'PortSchema' then
				if _category = XLAT_Exceptions and constantObj.name.length &gt; 9 and constantObj.name[1 : 10] = 'TransType_' then
				// dont remove these
				//	write constantObj.name;
				else
					_file.writeLine('Delete GlobalConstant PortSchema::' &amp; constantObj.name);
					count := count + 1;
				endif;
			endif;
			continue;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;

		if constantObj.text = null then
			continue;
		endif;

		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);

		// get local transient schema &amp; class objects
		attribute  := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if attribute = null then
			continue;
		endif;

		schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
		if schemaName = null then
			continue;
		endif;

		formClass := xmlElement.getAttributeByName(XML_Tag_FormClass).value;
		lsSchema := agent.allSchemas[schemaName];
		
		if lsSchema = null then
			// assume not one of the schemas we have selected to look at
			continue;
		endif;
		
		lsClass := lsSchema.getLSclass(formClass);
		
		if lsClass = null then
			continue;
		endif;

		controlName := xmlElement.getAttributeByName(XML_Tag_ControlName).value;
		controlProperty := xmlElement.getAttributeByName(XML_Tag_ControlProperty).value;
		
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			textValue := textElement.text;
		else
			textValue := null;
		endif;
				
		otherConstant := agent.allDefinedFormCaptionConstants[schemaName, formClass, controlName, controlProperty];
		
		if otherConstant &lt;&gt; null then
			errStr := 'Duplicate constant (' &amp; otherConstant.name &amp; ') found for ' &amp;
				schemaName &amp; ' - ' &amp; formClass &amp; ' - ' &amp; controlName &amp; ' - ' &amp; controlProperty &amp;
				'  -&gt; ' &amp; constantObj.name;
			logMsg	:=	"*** WARNING - " &amp; errStr;
			write logMsg;
		endif;

		// Create the new LSconstant object and add to allDefinedFormCaptionConstants
		create lsConstant transient;
		lsConstant.schemaName := schemaName;
		lsConstant.formName := formClass;
		lsConstant.controlName := controlName;
		lsConstant.controlProperty := controlProperty;
		lsConstant.name := constantObj.name;
		lsConstant.text := textValue;
		lsConstant.number := constantObj.getSource().Integer;
		agent.allConstantsByName.add(lsConstant);
		agent.allDefinedFormCaptionConstants.add(lsConstant);
	endforeach;

	write _category &amp; ' completed ' &amp; count.String &amp; ' lines written';
	
epilog
	delete xmlDoc;
	delete allMethodRefs;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_category" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildJCFUnreferencedGlobalCons" id="85356399-a2c9-4be5-bad4-ba144aacf8a5">
        <updating/>
        <source>buildJCFUnreferencedGlobalCons() updating;
/*
Purpose:	To create a .jcf file to remove unreferenced GlobalConstants		

Date			Who		Reason
13 January 2010	conkc1	Initial creation

Sample .bat file to run
C:\DMast\bin\jadloadb path = C:\DMast\c_system commandFile = C:\DMast\logs\removeGlobalConstant.jcf  ini=c:\DMast\cnwdmast.ini

*/
vars
	fileOut      : File;
	filename     : String;
	fileFolder   : FileFolder;
	foldername   : String;
	categoryArray: StringArray;
	category     : String;

begin

	create categoryArray transient;
	
	categoryArray.add(XLAT_FormCaptions);
	categoryArray.add(XLAT_Exceptions);

	create fileFolder transient;
	fileFolder.fileName := app.getJadeInstallDir;
	foldername := fileFolder.browseForFolder('jcf Folder', fileFolder.fileName);

	if fileFolder.isValidPathName(foldername) = false then
		app.msgBox('Invalid path, no scm files produced ' &amp; foldername, 'Error', 0);
		return;
	endif;

	create fileOut transient;

	fileOut.mode     := File.Mode_Output;
	fileOut.fileName := foldername &amp; '\removeGlobalConstant.jcf';
	fileOut.open;

	fileOut.writeLine('JadeCommandFile');
	fileOut.writeLine('JadeVersionNumber 6.3.05');
	fileOut.writeLine('Commands');
	fileOut.writeLine('AbortOnError True');

	foreach category in categoryArray do
		buildJCFForCategory(fileOut, category);
	endforeach;
	
	fileOut.close;
	
epilog

	delete fileOut;
	delete fileFolder;
	delete categoryArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="bxDecode" id="2b6d3053-c820-43ab-8f41-89efbb918a95">
        <updating/>
        <source>bxDecode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2023	navrr1	Initial creation

*/

vars
	str : String;
	bin : Binary;
	invalid : Boolean;
	_string : String;
begin


	_string := "CXjay3TxqKg0cQ41TXG1BAAaHgPK";

	bin := _string.base64Decode();
	if invalid then
		write "invalid";
	else
		str := bin.uncompressToString;
	endif;

	write str;

epilog

end;</source>
