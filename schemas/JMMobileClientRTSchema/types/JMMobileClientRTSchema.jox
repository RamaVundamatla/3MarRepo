    <JadeMethod name="getSystemColorsFromIni" id="90832f3e-7ad2-4dbc-baa7-7010c1c2bfdd">
        <source>getSystemColorsFromIni(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer output) : Boolean;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
vars
	iniFileName : String;

begin
	iniFileName				:=	app.getIniFileName();
	_sysBackColorGeneral	:=	app.getProfileString(iniFileName, RadioTelemetryIniFileSection, SysBackColorGeneral, null).Integer;
	_sysForeColorGeneral	:=	app.getProfileString(iniFileName, RadioTelemetryIniFileSection, SysForeColorGeneral, null).Integer;
	_sysBackColorTable		:=	app.getProfileString(iniFileName, RadioTelemetryIniFileSection, SysBackColorTable, null).Integer;
	_sysForeColorTable		:=	app.getProfileString(iniFileName, RadioTelemetryIniFileSection, SysForeColorTable, null).Integer;
	
	if _sysBackColorGeneral = null or _sysForeColorGeneral = null then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysForeColorGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysBackColorTable" type="Integer" usage="output"/>
        <Parameter name="_sysForeColorTable" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
