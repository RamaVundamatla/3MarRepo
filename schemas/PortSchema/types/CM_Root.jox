    <JadeMethod name="isClientUmmQasr" id="9a66901d-214f-49da-84a0-d8c2505d4a5b">
        <source>isClientUmmQasr() : Boolean;

/*

Purpose:			Check for Gulftainer Umm Qasr - the 'GT_UMQR' value is their test server setting, the "GT UmQasar" value is what JMT sets.

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2013	cnwjre1	Initial creation 31602 user-specific cash receipt reporting

*/

vars

begin
//	if process.isJLGAB1 then
//		return true;
//	endif;
	
//	return (self.client = "GT_UMQR" or self.client = Client_GT_UMMQASAR);
	if self.licenseName.length &gt; 20 and self.licenseName[1:21] = "Gulftainer - Umm Qasr" then	//03 May 2017	NDL	TFS 
		return true;
	endif;

	return self.client = Client_GT_UMMQASAR; // ### JIRA 33710 20DEC2024 NAVAB1

epilog

end;</source>
