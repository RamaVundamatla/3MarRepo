	self.displayBayDetails(self.cmbBayList.listObject.CM_Bay);

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnBayEditClick" id="69b3d2f0-5780-4a28-93e9-a88d46d21682">
        <updating/>
        <source>doBtnBayEditClick() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStructure : CM_CellularVoyageStructure;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		tmpStructure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	
	if self.myCurrentBay = null then
		app.msgBox(app.getErrorString(SHP_SelectBay),app.getErrorString(SHP_BayDefinitionError), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
	if tmpStructure &lt;&gt; null then
		if tmpStructure.allHolds.isEmpty then
			app.msgBox("You must specify a number of holds before you can enter bays. " &amp; Cr &amp; 
						"See 'Vessel Details' tab.",app.getErrorString(SHP_BayDefinitionError),MsgBox_Information_Icon + MsgBox_OK_Only);
			return;
		
		endif;
	else
		return;
	endif;
	
	self.anythingChangedBay := true;

	self.btnBayEditBay.visible := false;
	if self.myTemplateBay &lt;&gt; null then
		self.btnBayTempBay.caption := "Bay " &amp; self.myTemplateBay.id;
		self.btnBayTempBay.bubbleHelp := app.getErrorString1(SHP_BayTempBubble, self.myTemplateBay.id);
	else
		self.btnBayTempBay.caption := "Template";
		self.btnBayTempBay.bubbleHelp := app.getErrorString(SelectTemplateBay);
		
	endif;
	self.btnBayTempBay.enabled := true;
	self.btnBayApplyBay.visible := true;
	self.frmToolBarBay.positionToolbarControls();
		
	self.setEnableBayObjects(true);
	self.cmbBayList.enabled := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnBayNewClick" id="8d3792bb-72b4-4a6d-9e84-eb7f4c71ef23">
        <updating/>
        <source>doBtnBayNewClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	newBayID, theBayOrder : String;
	aBay,aProxyBay : CM_Bay;
	beforeBay : Boolean;
	tmpStructure : CM_CellularVoyageStructure;
	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		tmpStructure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	
	aBay := self.cmbgetBayIDBays.listObject.CM_Bay;
	if aBay = null and self.cmbgetBayIDBays.listCount &gt; 0 then
		app.msgBox(app.getErrorString(SHP_Select_A_Bay_FromList),app.getErrorString(SHP_Select_A_Bay),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	newBayID := self.txtGetBayID.text.trimBlanks;
	if newBayID = null then
		app.msgBox(app.getErrorString(SHP_BayEnterID),app.getErrorString(SHP_BayEnterID),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if tmpStructure &lt;&gt; null then
		if tmpStructure.allBayVoyagesById[newBayID] &lt;&gt; null then
			app.msgBox(app.getErrorString(SHP_EnterUniqueBayID),app.getErrorString(SHP_EnterUniqueBayID),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "No current voyage to update.");	
		return;
	endif;
			
	beforeBay := self.chkGetBayID.value;
	
	self.frmGetBayID.visible := false;

	foreach aProxyBay in tmpStructure.allBayVoyagesByOrdinal do
		if aProxyBay = aBay then
			if beforeBay then
				theBayOrder := theBayOrder &amp; " " &amp; newBayID;
			endif;
		endif;
		theBayOrder := theBayOrder &amp; " " &amp; aProxyBay.id; 
		if aProxyBay = aBay then
			if not beforeBay then
				theBayOrder := theBayOrder &amp; " " &amp; newBayID;
			endif;
		endif;
	endforeach;

	self.lblBayOrderTxt.caption := theBayOrder;

	if self.validateTierCellLabels('Physical Bay Order', theBayOrder) then
	
		self.doBuildComboBayString(self.cmbBridgeAftBay, theBayOrder);
		self.doBuildProxyBayList(theBayOrder);
		
		aProxyBay:=tmpStructure.allBayVoyagesById[newBayID];
		if aProxyBay &lt;&gt; null and aBay &lt;&gt; null then
			aProxyBay.setMyHold(tmpStructure.allBayVoyagesById[aBay.id].myHold);
			self.cmbBayList.setIndexFromObject(aProxyBay);
			if aBay.getAllCellsOnDeck.trimBlanks &lt;&gt; null then
				aProxyBay.setProxyCellsODFromLabels(aBay.getAllCellsOnDeck,false);
			endif;
			if aBay.getAllCellsUnderDeck.trimBlanks &lt;&gt; null then
				aProxyBay.setProxyCellsUDFromLabels(aBay.getAllCellsUnderDeck,aBay.getAllCellsHiCubeHeightsString,false);
			endif;
			if aBay.getAllTiersOnDeck.trimBlanks &lt;&gt; null then
				aProxyBay.setProxyTiersODFromLabels(aBay.getAllTiersOnDeck,false);
			endif;		
			if aBay.getAllTiersUnderDeck.trimBlanks &lt;&gt; null then
				//epr TFS 1762 -1/4/16
				aProxyBay.setProxyTiersUDFromLabels(aBay.getAllTiersUnderDeck,false);
			endif;		
		endif;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnBayRemoveClick" id="fe178d32-a031-4765-8eb2-28b20555ad49">
        <updating/>
        <source>doBtnBayRemoveClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn, idx : Integer;
	theBayOrder : String;
	aProxyBay : CM_Bay;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	if self.myCurrentBay = null then
		app.msgBox(app.getErrorString(SHP_SelectBay),app.getErrorString(SHP_BayDefinitionError),MsgBox_OK_Only);
		return;
	endif;
	
	theReturn := app.msgBox(app.getErrorString1(SHP_BayRemoveConfirm, self.myCurrentBay .id), app.getErrorString(CMUI_ConfirmRemove), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_No then
		return;
	endif;

	self.cmbBayList.removeObject(self.myCurrentBay);
	self.myCurrentBay.setForDelete(); // this is a proxy copy

	self.doBtnBayCancelClick();
	
	self.displayBayDetails(null);
	self.initWithBay := false;
	
	if structure &lt;&gt; null then
		foreach aProxyBay in structure.allBayVoyagesByOrdinal do
			theBayOrder := theBayOrder &amp; " " &amp; aProxyBay.id; 
		endforeach;
	else
		return;	
	endif;

	self.lblBayOrderTxt.caption := theBayOrder;
	
epilog
	self.btnBayApplyBay.userObject := null;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCopySave" id="392c6e02-ed7f-4652-bd97-a7f0c17b0eb8">
        <updating/>
        <source>doBtnCopySave() updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aVesselBay : CM_BayDefn;
	targetBay : CM_Bay; //CM_BayVoyage;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	structure : CM_CellularVoyageStructure;	
begin
	aVesselBay := self.cmbBayCopyVessel.listObject.CM_BayDefn;

	targetBay := self.cmbBayCopyVoyage.listObject.CM_Bay; //Voyage;
	
	if aVesselBay = null or targetBay = null then
		app.msgBox("You must select both a vessel and a target bay.", "Bay Copy Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if app.msgBox("Are you sure that you want to erase bay " &amp; targetBay.id &amp; "," &amp; Cr 
		&amp; "and recreate it using VESSEL bay " &amp; aVesselBay.id &amp; "?" &amp; Cr &amp; Cr
		&amp; "WARNING! Clicking Save will erase the selected target bay," &amp; Cr
		&amp; "including any tracked items," &amp; Cr
		&amp; "and rebuild that bay from the chosen vessel definition.", "Copy Bay Confirm" , MsgBox_Yes_No + MsgBox_Question_Mark_Icon)
		= MsgBox_Return_No then
		return;
	endif;
	
	self.frmBayCopy.visible := false;
	
	
	app.myTrxUA.trxCopyVessalBayPlanToVoyage(targetBay,aVesselBay,self.myCurrentVoyage,app.myPassport);
	
	self.doBuildComboBay(self.cmbBayList);
	self.cmbBayList.click(self.cmbBayList);		
	
	global.beep;
	app.msgBox("Copy finished." &amp; Cr &amp; "If you copied a forward by into an aft bay you will need to set any 40 foot attributes in the new aft bay."	,"Copy Complete",
		MsgBox_OK_Only);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDirDefaultsClick" id="2e77c37a-22a9-4472-a192-2eb79a7737ca">
        <updating/>
        <source>doBtnDirDefaultsClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cnt : Integer;
	aSlotDefn : CM_SlotDefn;
	aBay : CM_Bay;
	dirController : CMIF_DirectionController;
	theReturn : Integer;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	if structure = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString(SHP_Apply_Default_Dir_Voyage),app.getErrorString(SHP_Confirm),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	create dirController transient; //CCMS 1045 AKB2004Jan
	dirController.setForCreate(); //CCMS 1045 AKB2004Jan

	self.progressStart(structure.allBayVoyagesByOrdinal.size, null, null, null, 'Applying default directions');
	
	foreach aBay in structure.allBayVoyagesByOrdinal do

		cnt := cnt + 1;
		self.lblModalInfo.caption := app.getErrorString(SHP_Setting_Door_Dir) &amp; aBay.id &amp; "...";
		self.pbProgressBar.partsDone := cnt;
		self.frmModalDialog.doWindowEvents(0);
		
		foreach aSlotDefn in aBay.allSlotsByOrdinal do
			aSlotDefn.setDefaultDoorDirections(dirController);
		endforeach;
		
	endforeach;

	global.beep;
epilog
	delete dirController;
	self.progressFinish();
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEdit" id="123fc9a8-b40b-4e9a-99e0-b286aef45933">
        <updating/>
        <source>doBtnEdit()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	aBay, pxyBay : CM_Bay;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	if structure = null then
		app.msgBox('Cannot perform edit as there is no voyage selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
		self.cmbVoyage.setFocus();
		return;
	endif;
	
	aBay := self.cmbBayList.listObject.CM_Bay;
	self.mode := self.Mode_Update;

	self.createUpdateProxy();

	structure := self.myCurrentVoyage.myCellularVoyageStructure; // this should be a proxy by now

	self.doBuildComboBay(self.cmbBayLayout);
	self.doBuildComboBay(self.cmbBayList);
	self.doBuildComboBay(self.cmbBridgeAftBay);
	self.doBuildComboHolds(structure);
				
	self.setControlsForUpdate();
	
	if aBay &lt;&gt; null then
		pxyBay := aBay.pxyGetProxyObject();
		if pxyBay &lt;&gt; null then
			self.cmbBayList.listObject := pxyBay;	
			self.cmbBayList.click(self.cmbBayList);
		endif;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnShowSeqNumClick" id="d899a9a6-4add-459b-b8ba-4a694fabf189">
        <source>doBtnShowSeqNumClick(_is40 : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	found : Boolean;
	bayFrame : CMUI_GridAreaFrame;

begin
	app.mousePointer := Window.MousePointer_HourGlass;

	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		if _is40 then
			bayFrame.myGridArea.SHP_BayArea.showSeqNum40 := true;
		else
			bayFrame.myGridArea.SHP_BayArea.showSeqNum40 := false;
			bayFrame.myGridArea.SHP_BayArea.showSeqNum := not bayFrame.myGridArea.SHP_BayArea.showSeqNum;
			found := true;
		endif;
		bayFrame.myGridArea.drawSelf();
		
	endif;
	bayFrame := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		if _is40 then
			bayFrame.myGridArea.SHP_BayArea.showSeqNum40 := true;
		else
			bayFrame.myGridArea.SHP_BayArea.showSeqNum40 := false;
			bayFrame.myGridArea.SHP_BayArea.showSeqNum := not bayFrame.myGridArea.SHP_BayArea.showSeqNum;
			found := true;
		endif;
		bayFrame.myGridArea.drawSelf();
		
	endif;

	if found then
		if self.btnBaySeqBay.caption = self.CAPTION_BTN_SEQNUM then
			self.btnBaySeqBay.caption := self.CAPTION_BTN_ATTRIBUTES;
			self.btnBaySeqBay.bubbleHelp := self.BUBBLE_ATTRIBUTE;
			
		else
			self.btnBaySeqBay.caption := self.CAPTION_BTN_SEQNUM;
			self.btnBaySeqBay.bubbleHelp := self.BUBBLE_SEQNUM;
		endif;
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnTemplateClick" id="6b1b3f85-38da-471d-8b8f-408ed5bc8f8f">
        <updating/>
        <source>doBtnTemplateClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aBay : CM_Bay;
begin
	aBay := self.cmbBayList.listObject.CM_Bay; //Defn;

	if self.btnBayEditBay.visible = true then
		
		self.btnBayTempBay.userObject := aBay;
		self.myTemplateBay := aBay;
		self.btnBayTempBay.caption := "Template";
		self.btnBayTempBay.bubbleHelp := app.getErrorString(SelectTemplateBay); 
		if self.myTemplateBay &lt;&gt; null then
			self.btnBayTempBay.bubbleHelp := self.btnBayTempBay.bubbleHelp &amp; Cr &amp; app.getErrorString1(SHP_TemplatBay, self.myTemplateBay.id);
		endif;
		self.btnBayTempBay.enabled := true;

	elseif self.myTemplateBay &lt;&gt; null then
		self.btnBayApplyBay.userObject := self.myTemplateBay;
		self.displayDataForBay(self.myTemplateBay, true, true);
	endif;


end;</source>
    </JadeMethod>
