    <JadeMethod name="tAddYATemplate_Operator" id="4bf55234-de5d-4de9-913b-f7482f7c0920">
        <source>tAddYATemplate_Operator();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	operatorName: String;
begin
	operatorName := app.myRoot.allOperators.last.code;
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, operatorName);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataObjects), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.getDescription(), "Operator (Item) "&amp;operatorName, "Incorrect criteria description");
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplate_Operators_Diff" id="06a598bc-ba4d-41c5-b02b-ff3ad1a057d8">
        <source>tAddYATemplate_Operators_Diff();
// cnwndl1
//17 July 2008	cnwdw1	
// Add YA Template with two different operators
vars
	yATemplate: CM_YATemplate;
	operator1, operator2: CM_Operator;
	operatorName1, operatorName2: String;
	iter: Iterator;
	description: String;
begin
	iter := app.myRoot.allOperators.createIterator;
	iter.next(operator1);	//ignore first one as it is ***
	iter.next(operator1);	
	while iter.next(operator2) do
		if operator2.code &lt;&gt; operator1.code then
			break;
		endif;
	endwhile;	
	
	operatorName1 := operator1.code;
	operatorName2 := operator2.code;
	
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, operatorName1 &amp; "," &amp; operatorName2);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataObjects), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.size, 2,  "Incorrect criteria myYAData");
	description := yATemplate.myYardAllocation.allCriteria.first.getDescription();
	self.assertTrueMsg(description.pos(operatorName1, 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;operatorName1);
	self.assertTrueMsg(description.pos(operatorName2, 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;operatorName2);
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");


epilog
	delete iter;
end;</source>
    </JadeMethod>
