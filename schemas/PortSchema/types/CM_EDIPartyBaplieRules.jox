<Class name="CM_EDIPartyBaplieRules" id="e2a0c873-0541-4208-bb97-26fd3c9f5e55">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="enableAtmosphere" id="2c3946c8-08d8-41bc-a63f-ae6092b41b8d">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="create" id="134d57e6-40f7-414c-96f3-e4206fc63e88">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2015 cnwma1 PAR# 36526 Patch for Baplie File MEA segment
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
*/
vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Baplie20, null);
	
	if type = null or type.type &lt;&gt; EDIFileType_Baplie20 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Baplie file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4fc95223-cb4d-4920-a13f-4780aa40be89">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2015 cnwma1 PAR# 36526 Patch for Baplie File MEA segment

*/

vars
	proxy	:CM_EDIPartyBaplieRules;
begin
	proxy :=  inheritMethod();
	
	proxy.enableAtmosphere	:= self.enableAtmosphere;

	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a9da4a2c-bbe9-4cc7-9146-33aad7231c5f">
        <updating/>
        <source>setForUpdate(_proxy:  CM_EDIPartyBaplieRules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2015 cnwma1 PAR# 36526 Patch for Baplie File MEA segment

*/

vars

begin
	inheritMethod(_proxy);
	self.enableAtmosphere := _proxy.enableAtmosphere;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyBaplieRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="25270b56-2261-4bbe-8ecf-86f94dbb4fb0">
        <updating/>
        <source>setProxy(_enableAtmosphere : Boolean)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2015 cnwma1 PAR# 36526 Patch for Baplie File MEA segment

*/

vars

begin
	self.enableAtmosphere := _enableAtmosphere;
epilog

end;</source>
        <Parameter name="_enableAtmosphere" type="Boolean"/>
    </JadeMethod>
</Class>
