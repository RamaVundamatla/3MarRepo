    <JadeMethod name="translateToDisplayValue" id="dafdfbf2-6102-41e1-ad54-4ccc023b3566">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	if _value.Decimal &lt;&gt; NULL_HUMIDITY then
		return _value.String;
	endif;
	
	return null;
epilog

end;</source>
