        <source>getContractIds() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	woDtl      : CM_WorkOrderDtl;
	contractId, returnStr : String;
begin
	foreach woDtl in self.allWoDtls discreteLock do								//28.05.2024 navma1 #64224
		contractId := woDtl.contractId;
		if contractId &lt;&gt; null then
			/*
			if returnStr.pos(contractId,1) = 0 then
				if returnStr = null then
					returnStr := contractId;
				else
					returnStr := returnStr &amp; ", " &amp; contractId;
				endif;
			endif;
			*/
			
			returnStr.addStringToList(contractId, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endif;
	endforeach;
	
	return returnStr;
epilog

end;</source>
