        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="3d9a494e-642c-40ce-b6b0-cbc1e674b3f5">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		06 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	description := self.Operator_Between;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="3ac05876-e01a-45c3-b1d1-bbd42a5cae52">
        <source>doMatch(_value : Any): Boolean;
// -----------------------------------------------------------------------------
// Created:		06 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if not _value.Date.isValid then
          return false;
	endif;//par 21575
	return (_value.Date &gt;= fromDate and _value.Date &lt;= toDate);
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="ba3b40c1-83fd-4bfc-bed5-49effde6adb1">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	_searchValueA			:= self.fromDate.asStringJMT();
	_searchValueB			:= self.toDate.asStringJMT();
	_searchValueBoolean		:= null;
	_isStringProperty		:= false;
	_isStringBetweenProperty:= true;
	_isBooleanProperty		:= false;
	
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="df532166-744d-4b87-acf1-2ec18512fd8d">
        <source>getSearchValue(): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06 September 2019	jlgdap1		Initial creation TFS 
//
vars
	str			: String;
begin
	str := self.fromDate.shortFormatJMT() &amp; ' and ' &amp; self.toDate.shortFormatJMT();
	return str;

epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueFromDate" id="6bea8b09-1784-4aa5-aa22-d91365c5ed6b">
        <source>getSearchValueFromDate() : Date;
// ---------------------------------------------------------------------------
// Created:     04 February 2004	cnwth2
//
