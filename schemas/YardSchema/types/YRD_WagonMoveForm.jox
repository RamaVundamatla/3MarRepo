    <JadeMethod name="buildComboMoveMode" id="71ef8dcb-9438-4948-bbc1-ad55181630bd">
        <updating/>
        <source>buildComboMoveMode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 August 2022	navgm20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	idx : Integer;
begin
	self.cmbMoveMode.clear;
	
	idx := self.cmbMoveMode.addItem(self.Move_Instant);
	self.cmbMoveMode.itemData[idx ] := REAL_MODE;
	idx := self.cmbMoveMode.addItem(self.Move_Planned);
	self.cmbMoveMode.itemData[idx ] := PLANNING_MODE;
	idx := self.cmbMoveMode.addItem(self.Move_Unplan);
	self.cmbMoveMode.itemData[idx ] := UNPLAN_MODE;
	idx := self.cmbMoveMode.addItem(self.Move_PlannedLocation);
	self.cmbMoveMode.itemData[idx ] := CMIF_WagonMoveController.MOVE_TO_PLAN;
	
	self.cmbMoveMode.listIndex := self.cmbMoveMode.findItemData(self.moveMode);
	self.cmbMoveMode_click(self.cmbMoveMode);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboPosition" id="1710bf0e-c27c-49b8-991f-5d064cb66311">
        <updating/>
        <source>buildComboPosition(_railLine : CM_RailLine) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2022	navhl20	Initial creation

*/

vars
	lCol,idx	: Integer;
	lID				: String;
begin
	self.cmbRakePosition.clear;
	if _railLine = null then
		return;
	endif;
	
	foreach lCol in 1 to _railLine.maximumWagons do
		lID := _railLine.getIdString.trimBlanks &amp; ' ' &amp; lCol.String.padLeadingZeros(2);
		idx := self.cmbRakePosition.addItem(lID);
		self.cmbRakePosition.itemObject[idx] := _railLine;
		self.cmbRakePosition.itemData[idx] := lCol;
	endforeach;
epilog

end;</source>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="buildComboRailAreas" id="da2319f5-44dc-438c-b29d-aee111784af6">
        <updating/>
        <source>buildComboRailAreas() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2022		navgm20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	idx				: Integer;
	lRail			: CM_TerminalArea;
	termAreaDict	: CM_TAByIdDict;
	obj				: CM_Wagon;
begin
	
	self.cmbRailArea.clear;
	termAreaDict := self.myTerminal.getAllTAsOfType(TA_TYPE_RAILWAY_TRACK);

	foreach lRail in termAreaDict do // RR1 RR2
		idx := self.cmbRailArea.addItem(lRail.id);
		self.cmbRailArea.itemObject[idx] := lRail;
	endforeach;
	
	foreach obj in self.allSelectedWagons do
		if obj.allPlannedFutureMoves.isNotEmpty then
			self.myRailArea := obj.getPlannedRailArea();
			self.cmbRailArea.listIndex := self.cmbRailArea.findObject(self.myRailArea);
			self.cmbRailArea_click(self.cmbRailArea);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboRailLine" id="5b345177-9b30-4b89-ba72-dae026f456e8">
        <updating/>
        <source>buildComboRailLine(pRail : CM_Rail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 August 2022	navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	lRow,idx	: Integer;
	lID				: String;
	lRailLine	: CM_RailLine;
	obj			: CM_Wagon;
begin
	self.cmbRailLine.clear;
	if pRail = null then
		return;
	endif;
	
	foreach lRow in 1 to  pRail.allRailLinesByIndex.size do
		lRailLine := pRail.allRailLinesByIndex[lRow];
			lID := lRailLine.getIdString.trimBlanks;
			idx := self.cmbRailLine.addItem(lID);
			self.cmbRailLine.itemObject[idx] := lRailLine;
	endforeach;
	
	foreach obj in self.allSelectedWagons do
		if obj.allPlannedFutureMoves.isNotEmpty then 
			self.myRailLine := obj.getPlannedRailLine();
			self.cmbRailLine.listIndex := self.cmbRailLine.findObject(self.myRailLine);
		endif;
	endforeach;
end;</source>
        <Parameter name="pRail" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="cmbMoveMode_click" id="5e69a9f7-88d1-4fa0-b652-e3dd836f14df">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMoveMode_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2022	navgm20	ChangeRequest 54281: EUP - Wagon Track Planning
01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars
	moveMode	: String;
begin
	moveMode := self.cmbMoveMode.text;
	
	if moveMode	= self.Move_Planned then	
		self.btnPlan.caption	:= self.Move_Plan;
		self.lblRakePosition.visible := false;
		self.cmbRakePosition.visible := false;
		self.lblOutward.visible 	 := true; // 01/05/2023	navkc1	Bug 57742
		self.chkOutward.visible 	 := true; // 01/05/2023	navkc1	Bug 57742
	elseif moveMode = self.Move_Instant then
		self.btnPlan.caption	:= self.Move_Move;
		self.lblRakePosition.visible := true;
		self.cmbRakePosition.visible := true;
		self.lblOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
		self.chkOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
	elseif moveMode = self.Move_PlannedLocation then
		self.btnPlan.caption	:= self.Move_Move;
		self.lblRakePosition.visible := false;
		self.cmbRakePosition.visible := false;
		self.lblOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
		self.chkOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
	else
		self.btnPlan.caption	:= moveMode;
		self.lblRakePosition.visible := false;
		self.cmbRakePosition.visible := false;
		self.lblOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
		self.chkOutward.visible 	 := false; // 01/05/2023	navkc1	Bug 57742
	endif;

	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
