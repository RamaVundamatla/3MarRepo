    <JadeMethod name="pxyCreateUpdateProxy" id="cad29f54-cc0d-4056-929a-9a6c7d0bc599">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyTempRange:CM_TempRange;
	completedOK		: Boolean;
begin

	proxyTempRange := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTempRange;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTempRange;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e004dd8e-8a53-4de6-88fb-69a9301a2dcc">
        <updating/>
        <source>setForCreate(pProxyTempRange:CM_TempRange) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyTempRange.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyTempRange);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyTempRange" type="CM_TempRange"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7a9ec424-d74e-49a2-8b5f-695ca61d318e">
        <updating/>
        <source>setForUpdate(pProxyTempRange:CM_TempRange) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.value := pProxyTempRange.value;
	self.colour := pProxyTempRange.colour;
	self.lower := pProxyTempRange.lower;
	self.upper := pProxyTempRange.upper;

end;</source>
        <Parameter name="pProxyTempRange" type="CM_TempRange"/>
    </JadeMethod>
