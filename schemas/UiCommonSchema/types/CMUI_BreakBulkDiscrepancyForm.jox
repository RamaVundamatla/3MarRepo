    <JadeMethod name="tblWeight_change" id="68439c73-208e-454b-80f0-197f5a5ccc33">
        <controlMethod name="CMUI_MeasurementTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWeight_change(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	option : Integer;
	timeRemaining : Integer;

begin

	if not self.getTimerStatus(WeightChange, option, timeRemaining) then
		self.beginTimer( 10, Timer_OneShot, self.WeightChange );
	endif;

epilog

end;</source>
