    <JadeMethod name="addObjectToCollection" id="ddaf01b9-e493-4f96-abd9-de1d01394753">
        <updating/>
        <source>addObjectToCollection(_locActivity : CMEVT_LocationActivity; _user : CM_User) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if not ( _locActivity.canView(_user) ) then
		return false;
	endif;
		
	if self.numItemsShown &gt; JadeTableRowLimit then
		return true;
	endif;

	self.numItemsShown := self.numItemsShown + 1;
	self.allLocActivityByDate.addNoDuplicates( _locActivity, false );
	self.allLocationActivitySet.addNoDuplicates( _locActivity, false );
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locActivity" type="CMEVT_LocationActivity"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="a2fe04a2-d874-4697-812d-a2dba1cd5cfd">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	queryToolbar,
	toolbar	: CMUI_Toolbar;

begin

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
    toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
    toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then 
		toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCSV_click" id="56d937f6-efc1-48a0-b404-12b53d1ee5f7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCSV_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	fileObj : File;
	
begin

	create fileObj transient;	
	fileObj.mode := File.Mode_Output; 
	self.tblLocActivity.cnEcExportToCSV(fileObj, true);
	
epilog

	delete fileObj;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="19ad6536-5826-46e6-909b-d16cdfd57b07">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEdit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	rowIndex : Integer;
	obj : Object;
	edition : Integer;
	invalid : Boolean;
	locActivity : CMEVT_LocationActivity;

begin

	on Exception do app.handleDeletedObject( exception, obj, invalid );

	rowIndex := self.tblLocActivity.row;
	if rowIndex &lt;= self.tblLocActivity.rows then
		if not self.tblLocActivity.accessRow( rowIndex ).selected then
			return;
		endif;
		obj := self.tblLocActivity.accessRow( rowIndex ).itemObject;
		if obj &lt;&gt; null then
			edition := obj.edition;
			if invalid then
				return;
			endif;
			locActivity := obj.CMEVT_LocationActivity;
			if not locActivity.isAbleToBeEdited then
				return;
			endif;
			self.doEdit( locActivity );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
