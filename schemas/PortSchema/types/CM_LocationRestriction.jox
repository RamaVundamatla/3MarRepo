    <JadeMethod name="setId" id="a8407f27-888f-4536-b25b-8c1144535cf0">
        <updating/>
        <source>setId(_terminalArea : CM_TerminalArea) protected, updating;

vars

	restriction : CM_LocationRestriction;
	idAsNum		: Integer;

begin
	//cnwmc5 - 16 Dec 2014 - CCMS 1133
	if _terminalArea &lt;&gt; null then
		foreach restriction in _terminalArea.allRestrictionsLocation do
			idAsNum := idAsNum.max(restriction.id.Integer);
		endforeach;
	endif;
	
	if idAsNum &gt; 0 then
		self.id := (idAsNum + 1).String;
	else
		id := "1";
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setToAllowType" id="587acc3a-08ff-474d-9011-a4c2bb3326ff">
        <updating/>
        <source>setToAllowType(_search: CMIF_SearchTypes) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
begin

	tmpOperator := _search.myOperator;
	if tmpOperator &lt;&gt; null and 
	   (not self.allOperators.isEmpty) and 
	   (not self.allOperators.includes(tmpOperator)) then
		self.allOperators.add(tmpOperator);
	endif;

end;</source>
        <Parameter name="_search" type="CMIF_SearchTypes"/>
    </JadeMethod>
    <JadeMethod name="testDoISpanFrontToBack" id="506894cc-44b6-4573-a078-7644de0bf0ce">
        <source>testDoISpanFrontToBack(_myTerminalArea : CM_TerminalArea;_touchBack : Boolean output;_touchFront : Boolean output ) ;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		Yes/No does this restriction, cover a whole column of pads from the front of the terminal area to the back
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLocationController: CM_LocationsController;
	aGridController,firstController, lastController : CM_GridController;
	theFLS : CM_ForkLiftStack;
	theTerminalArea : CM_TerminalArea;
	ordinalColumn, ordinalRow : Integer;
begin
//	if not _myTerminalArea.isKindOf(CM_ForkLiftStack) then
//		return ;
//	endif;
	theTerminalArea := _myTerminalArea;
//	theFLS := _myTerminalArea.CM_ForkLiftStack;

	// a location controller from my list of controllers
	if self.allLocationControllers.isEmpty then
		return ;
	endif;

	aLocationController := self.allLocationControllers.first;
	if not aLocationController.isKindOf(CM_GridController) then
		return ;
	endif;
	aGridController:= aLocationController.CM_GridController;
	
	ordinalColumn := aGridController.myGridColumn.column;
	ordinalRow := theFLS.numberOfRows;
	
	// get the first and last controlers in this column
	firstController := theFLS.allGridControllersByRowColumn[1,ordinalColumn];
	lastController := theFLS.allGridControllersByRowColumn[ordinalRow,ordinalColumn];

	// do I include the first and last controllers in the column?
	if self.allLocationControllers.includes(firstController) then
		_touchBack := true;
	endif;
	if self.allLocationControllers.includes(lastController) then
		_touchFront := true;
	endif;
end;</source>
        <Parameter name="_myTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_touchBack" type="Boolean" usage="output"/>
        <Parameter name="_touchFront" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="validate" id="fd85dc4c-5d53-4086-a7b0-f43dfcb9ef59">
        <source>validate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	inheritMethod();
	if self.id.trimBlanks = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "ID", "Please enter an ID", null, null);
	endif;
	self.validateTerminalArea(self.myTerminalArea);
	self.validateLocationControllers(self.myTerminalArea, self.allLocationControllers);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b76f9590-e355-4450-9cb1-5453e003c91f">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2014   cnwdb2		PAR #35364
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	//Do we have another one with the same id? - Par7665
	if self.myTerminalArea &lt;&gt; null then
		if self.myTerminalArea.allRestrictionsLocation.includesKey(self.id) then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Location Restriction", self.id, null,null, null);
			app.raiseCMException1(Already_exists_locnRestrict, self.id,null, null); // cnwdb2 PAR 35364
		endif;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e086ca2e-8fb1-4788-8c04-e3cc181341c8">
        <source>validateForUpdate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
// 08/12/2014   cnwdb2		PAR #35364

vars

	restrict,
	original : CM_LocationRestriction;

begin

	inheritMethod();
	
	original := self.pxyGetRealObject();
	restrict := self.myTerminalArea.allRestrictionsLocation[self.id];
	if restrict &lt;&gt; null and restrict &lt;&gt; original then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Location Restriction", self.id, null,null, null);
		app.raiseCMException1(Already_exists_locnRestrict, self.id,null, null); // cnwdb2 PAR 35364

	endif;
	


end;</source>
    </JadeMethod>
    <JadeMethod name="validateIsCompatible" id="3eae5b89-a6b4-44a1-839f-bf2dada4a102">
        <source>validateIsCompatible() protected;

vars
	lController	: CM_LocationsController;
	ti			: CM_TrackedItem;
	auto		: CMIF_AutoMovePlan;

begin

	create auto transient;
	auto.generateLog := false;
	foreach lController in self.allLocationControllers do
		foreach ti in lController.allTrackedItems do
			if (not ti.isCompatibleWithRestriction(self, auto)) then
				app.raiseCMWarning3(TiIncompatibleWithRestriction, ti.cargoTypeDescr, ti.id, lController.getFullId, null, null, self);
			endif;
		endforeach;
	endforeach;

epilog
	delete auto;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
