<Class name="HMS_MovementArchived" id="08e479f5-716b-483e-b1fa-7d2852e80f03">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="6c547d47-3897-4495-b76a-767732057fd1">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
 	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);
	create propertyChange;
	propertyChange.set(self, "Movement Archived", null, null);
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="3a0f0899-8f99-4a4e-975f-39b25d7d4e50">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type := TRANS_TYPE_ArchiveMovement;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="2d3328cf-53f1-45db-9cd5-c8afaccd7064">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;

	return rtnValue;		
	
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
