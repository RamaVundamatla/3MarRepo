    <JadeMethod name="cmbReason_displayEntry" id="7dbe936b-2717-45ff-89ab-e596a18ff11f">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbReason_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.HMS_VesselUnavailCode.getListDisplay();
end;</source>
