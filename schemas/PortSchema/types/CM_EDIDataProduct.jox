    <JadeMethod name="setForCreateFromTIs" id="119e0102-db7a-49be-b8aa-0debaedcfb31">
        <updating/>
        <source>setForCreateFromTIs(_tiDict: CM_TIByIdDict; _ediConfig: CM_EDIConfig input; _realEdiFile: CM_EDIFile input; _userCode: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti : CM_TrackedItem;
begin
	
	self.setForCreateNoProxy(_ediConfig, EDIDataType_Product, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010

	foreach ti in _tiDict do
		self.processTIs(ti, null);
	endforeach;


end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
