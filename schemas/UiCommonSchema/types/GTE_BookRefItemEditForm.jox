<GUIClass name="GTE_BookRefItemEditForm" id="f9924c77-1ed7-4fcb-91f1-655d69e7ce24">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnNext" id="feb6b613-22be-48a0-83cf-65f6cfd0b191">
        <embedded/>
        <type name="CMUI_Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblBookRefItem" id="bd1d2d14-c9ed-46fe-9987-61b3cdd38c9d">
        <embedded/>
        <type name="CM_EntryTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="translateForm" id="bdecb19c-5cd5-416c-b64e-da3664155289">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014641, locale);
	btnNext.translateCaption(Xlat_0008389, locale);
end;</source>
    </JadeMethod>
</GUIClass>
