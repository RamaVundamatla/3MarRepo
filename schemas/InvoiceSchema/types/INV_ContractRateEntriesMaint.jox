    <JadeMethod name="setupForm" id="36506226-f1c5-40ea-9c12-4739082449af">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
03 Sep 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars

begin
	self.handleMenusForModalDisplay();
	self.initTblContractRateEntries();
	if self.updateMode then
		self.setFromTS(self.myContractRateEntryDates.fromTS);
		self.setToTS(self.myContractRateEntryDates.toTS);
		self.populateRateEntryDT();
		self.tblDisplayRow();
	endif;
	self.setFormCaption();
	
	self.doPermissions();		//03.09.2024 navnk30 #65602
	
	self.doCmbCalculationTypes(); // ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
	
	if self.myContractDetail.isVolumeBased() then
		self.cmbDeriveQuantity.visible := false;
		self.lblCalcTypeForRange.visible := false;
	endif;
epilog

end;</source>
