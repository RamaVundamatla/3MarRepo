    <JadeMethod name="doLoad" id="463c9d19-b56e-4003-afd8-81ce434ecb0b">
        <updating/>
        <source>doLoad() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2022	navmd1	Initial creation Moved from CMS_Logon::load event
30 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
25 Aug 2025 		navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/
constants
	HIGH			: Integer = 2^15;
vars
	systemTitle		: String;
	ssoProvider		: Integer;  //20.07.2022 navam1 #52824
	shiftBtnState	: Integer;
begin
	self.centreWindow();
	
	self.term := app.getMyTerminalDO_NOT_USE;
	self.lblCopyright.caption	:=	app.getCopyrightLine;
	self.caption := "Login to " &amp; app.niceName;
	
	self.lblVersion.caption:=app.myRoot.getVersionAndPatchLevelDisplay.String; //epr TFS 42569 15/5/19
	if app.isDevelopmentSystem then
		self.lblVersion.caption := self.lblVersion.caption &amp; CrLf &amp; "Development System";
	endif;
	
	systemTitle	:= app.myRoot.getConfig(SystemTitle).String;
	if systemTitle = null then
		lblSysTitle.visible	:=	false;
	else
		lblSysTitle.visible	:=	true;
		lblSysTitle.cnEcSet(systemTitle);
		
		if app.isDevelopmentSystem() then
			self.beginTimer(500, Timer_Continuous, self.TITLE_BLINK_TIMER);
		endif;
	endif;
	
	
	// 03/06/2025 navmd1 MTN-34699 Only show SSO options if actually starting from UICommonSchema (JMTerminal)
	// Things like JSSFileBrowser will only ever use 'local' auth
	if currentSchema.name = UiCommonSchemaName then
		//20.07.2022 navam1 #52824
		ssoProvider	:= app.myRoot.getConfig(SsoProvider).Integer;
		if ssoProvider &gt; CMIF_SSOHelper.SSO_Provider_Default then
			showHideLoginControls(false);
			
			btnLoginMTN.visible := true;
			btnLoginMTN.left := 294;
			btnLoginMTN.top := 200;
			
			if ssoProvider = CMIF_SSOHelper.SSO_Provider_Microsoft then
				btnLoginSSO.visible := true;
				btnLoginSSO.left := 294;
				btnLoginSSO.top := 250;
			elseif ssoProvider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
				btnLoginOktaSSO.visible := true;
				btnLoginOktaSSO.left := 294;
				btnLoginOktaSSO.top := 250;
			endif;
		endif;
	endif;
	
	self.ssoSuperEnabled := not app.myRoot.getConfig(DisableSSOSuperuser).Boolean;
	
	if self.userID.text &lt;&gt; null then
		self.password.setFocus;
	endif;
	
	// Sneaky method to auto-login because Mason was lazy!
	// This ini setting, along with the JMT User Preference of remembering your SSO session
	// will allow you to automagically login ;)
	
	// Only try and auto-login if sso is still enabled, and we haven't just logged out
	if self.btnLoginSSO.visible and app.mdiFrame = null then
		if app.getProfileStringMyIni(JMTThinClientSection, "AutoLoginWithSSO", "false").asBooleanJMT() then
			// Only auto-login if Shift is not held
			shiftBtnState := call getKeyState(J_key_Shift);
			if shiftBtnState.bitAnd(HIGH) &lt;&gt; HIGH then
				self.btnLoginSSO.click(self.btnLoginSSO);
			endif;
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLogon" id="16a79f8e-e946-4550-8841-c0107fa54ff0">
        <updating/>
        <source>doLogon(_isSSO: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 August 2022		navmd1	Initial creation - Moved from bOk_Click
01 February 2024	navmd1	TFS 60905 Refactor SSO for Superuser
09 Sept  	2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
08 Dec 2025 		navlc30 JIRA 36748 CUX - Enforce SSO Login


*/

vars
	saveMouse		: Integer;
	result			: Integer;
	chgPass			: ChangePassword;
	msg				: String;
	isSuperuser,
	isSupportUser	: Boolean;
	isSSO			: Boolean;
	optOut, msRemaining		: Integer;
begin
	app.mousePointer	:=	Busy;
	on NormalException do app.normalExceptionHandler(exception);
	
	isSSO := _isSSO;
	
	//==================
	// Check the user ID
	//==================
	while true do
		result := ERR_PASSWORD;
		
		if _isSSO then
			if app.mySSOAgent.login() then
				if app.mySSOAgent.oktaSsoInFlight then  // MTN-35151 - navec1 - Okta SSO
					// Okta SSO in flight, the default browser popup to SSO, start a timer to monitor SSO login status
					if not self.getTimerStatus(OKTA_SSO_TIMER_TAG, optOut, msRemaining) then
						self.beginTimer(500, Timer_Continuous, OKTA_SSO_TIMER_TAG);
					endif;
					return;  // return to here stay on login screen
				else
					// this is Azure SSO login
					result := app.validateUserSSO(app.mySSOAgent.upnMatchingId, app.mySSOAgent.uidUniqueId);
				endif;
			endif;
		else
			if self.ssoSuperEnabled and userID.text.toUpper.isOneOf(SUPERUSER_Str, JMTSUPPORT_Str) then
				isSSO := true;
				// Now use SSO for validate Superuser logins
				if app.mySSOAgent.loginSpecial(isSuperuser, isSupportUser, false, self.userID.text.toUpper) then
					
					if isSuperuser and userID.text.toUpper = SUPERUSER_Str then
						result := app.validateUserSSO(null, SUPERUSER_Str);
					elseif isSupportUser and userID.text.toUpper = JMTSUPPORT_Str then
						result := app.validateUserSSO(null, JMTSUPPORT_Str);
					endif;
				endif;
			else
				result := app.validateUserPassword(userID.text, password.text);
			endif;
		endif;
		
		if result = 0 then
			modalResult := 0;
			break;
		endif;
		
		msg := app.getErrorString(result); 
		
		app.myRoot.resolveMessagesWithExtraInfo(result, msg); //+ cnwmd1 Par 22287
		
		if result = ERR_LOCAL_LOGIN_DISABLED then											//08.12.2025 navlc30 #36748
			app.msgBox(msg, "", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
			showHideLoginControls(false);
			btnLoginMTN.visible := true;
			btnLoginSSO.visible := true;
			return;
		endif;
		
		if isSSO then
			// Only show the generic error if we haven't already shown a more specific one
			if app.myPassport.allErrors.size = 0 then
				app.msgBox(msg, "Single Sign On", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
			else
				app.myPassport.clearErrorsWarnings();
			endif;
		else
			app.msgBox(msg, "", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
		endif;
		
		if result = ERR_PSWD_RETRY_LIMIT then
			modalResult := ERR_PSWD_RETRY_LIMIT;
			break;
		endif;
		
		if result = ERR_RETRY_LIMIT then
			modalResult := ERR_RETRY_LIMIT;
			break;
		endif;
		
		if result = Err_Password_Expired then
			//app.mousePointer := MousePointer_Default;
			create chgPass;
			self.modalResult := chgPass.showModal();
			
			if self.modalResult = 0 then
				// user has successfully changed their password
				break;
			endif;
		endif;
		
		if self.visible = true then
			// Reset
			if _isSSO then
				self.btnLoginSSO.setFocus();
			else
				self.password.text := "";
				self.password.setFocus();
			endif;
			return;
		else
			// If auto-login SSO wasn't successful, then just stay on the logon splash
			if _isSSO then
				return;
			endif;
		endif;
	endwhile;
	
	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_isSSO" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="29b54496-b57a-4bcc-9b45-a360a05af4ed">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// 20/09/2022 Moved to doLoad method instead
	self.doLoad();
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideLoginControls" id="cbf9bc0a-7cf2-4971-bc05-adeedf88c984">
        <source>showHideLoginControls(_show: Boolean) protected;
/*

Purpose:			Show/Hide the default user/password controls

Parameters:			

Return Value:		

Date			Who		Reason
23 August 2022	navmd1	Initial creation TFS 52824 AAD Single Sign On
25 March 2024	jlizm1	TFS 54869 Exit button on login screen

*/

vars

begin
	self.lblUser.visible := _show;
	self.userID.visible := _show;
	self.lblPassword.visible := _show;
	self.password.visible := _show;
	
	if _show and self.userID.text &lt;&gt; null then
		self.password.setFocus;
	endif;
	
	self.bOk.visible := _show;
	self.bExit.visible := _show;
	self.btnExit.visible := not _show;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="skipOktaException" id="b51d3ff0-8aca-4321-a434-cc761e630701">
        <source>skipOktaException(ex: Exception): Integer protected;
/*

Purpose:		Skip any exception to skip, this should be called only when try to execute an Okta method that execution not mandatory	

Parameters:			

Return Value:		

Date			Who		Reason
15 Sept  2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	// Skip any exception to skip, this should be called only when try to execute an Okta method that execution not mandatory
	return Ex_Resume_Next; // skip the exception, do next line
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="95453c24-fb44-48b1-8f32-6c9bde77af21">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10 Sept 2025 navec1		MTN-35151: Single Sign On via Okta for MTN Thin Client
// --------------------------------------------------------------------------------
begin
	if eventTag = self.TITLE_BLINK_TIMER then
		lblSysTitle.visible	:=	(not lblSysTitle.visible);
		return;
	elseif eventTag = self.OKTA_SSO_TIMER_TAG then  // MTN-35151 - navec1 - Okta SSO
		timerEventOktaSSO(eventTag);
		return;
	endif;
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEventOktaSSO" id="585be4f2-4f7d-479c-a78a-e50e3f8b4a50">
        <updating/>
        <source>timerEventOktaSSO(eventTag: Integer) updating, protected;
/*

Purpose:			Okta SSO timer event

Parameters:			

Return Value:		

Date			Who		Reason
10 Sept 2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	if eventTag &lt;&gt; self.OKTA_SSO_TIMER_TAG then
		return;
	endif;
	
	// ensure SSO Provider is Okta
	if app.myRoot.getConfig(SsoProvider).Integer &lt;&gt; CMIF_SSOHelper.SSO_Provider_Okta then
		self.endTimer(OKTA_SSO_TIMER_TAG);	// should not happen, but if SSO Agent is not Okta, should not run Okta SSO timer.
		return;
	endif;
	
	// check Okta SSO in flight or completed, if in flight then do nothing, keep waiting
	if not app.mySSOAgent.oktaSsoInFlight then
		self.endTimer(OKTA_SSO_TIMER_TAG);
		
		if app.mySSOAgent.isLoggedInUsingSSO then
			// Okta SSO finished successful
			self.modalResult := 0;
			self.unloadForm();
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userID_change" id="d7f6b81b-af93-4d45-9b6c-614224608bf0">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userID_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 January 2024			navmd1	TFS 60905 Refactor SSO for Superuser

*/

vars

begin
	if self.ssoSuperEnabled then
		if textbox.text.toUpper().isOneOf(SUPERUSER_Str, JMTSUPPORT_Str) then
			self.password.enabled := false;
			self.password.backColor := WindowsGrey;
		else
			if not self.password.enabled then
				self.password.enabled := true;
				self.password.backColor := White;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
