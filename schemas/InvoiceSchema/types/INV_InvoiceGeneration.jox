    <JadeMethod name="cmbInvoiceTypeLostFocus" id="8b2c1025-73b9-4a9c-9f08-f0a997f0a609">
        <updating/>
        <source>cmbInvoiceTypeLostFocus() updating, protected;
/* ---------------------------------------------------------------------------
Created:	17 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
------------------------------------------------------------------------------*/
vars
	invoiceType	: CM_InvoiceDesc;
	timeStampSystem : TimeStamp;
begin
	if self.cmbInvoiceType.listIndex = NULLINDEX then
		return;
	endif;
	
	invoiceType	:= self.cmbInvoiceType.itemObject[self.cmbInvoiceType.listIndex].CM_InvoiceDesc;
	
	if invoiceType.invoiceGenerationDateTo &lt;&gt; null then
		timeStampSystem.cnEcSetDateAndTime(invoiceType.invoiceGenerationDateTo,TimeStartOfDay);				// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtDateFrom.text := self.systemToLocalTime(timeStampSystem).date().addDays(1).asStringJMT();	// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		self.txtDateFrom.text := null;	
	endif;
	
	self.doCmbSetStatusToBuild( invoiceType.invoiceGenerationStatus );

end;</source>
        <access>protected</access>
    </JadeMethod>
