    <JadeMethod name="createProxySeals" id="9bd9759c-23e8-4735-8ecc-9468f1e2b761">
        <updating/>
        <source>createProxySeals( _allSeals : CM_SealTIBySealTypeDict ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2010	cnwndl1	Initial creation
11/04/2011	cnwmh5		PAR #27347 - Change code to use app.cmsBeginLoad and add app.cmsEndLoad
*/

vars

	seal : CM_SealTI;
	pxySeal : CM_SealTI;
	loadState	: Boolean;
	
begin

	self.allSeals.purge();
	
	if _allSeals &lt;&gt; null and not _allSeals.isEmpty then			// 11/04/2011 cnwmh5 #27347
		app.cmsBeginLoad(loadState);
	endif;	
	
	foreach seal in _allSeals do
		//cnwmc5 - 2 March 2015 - PAR 35773 - commented out the creation of proxy seals.. 
		//the proxy seals were never used as real proxies.. and was casuing issues on the web service..
		//only transient copies are required
		
		//epr par 32649 5/11/13 
		//if seal.isTransient then
		//	pxySeal:= seal.cloneSelf(true).CM_SealTI;
		//else
		//	pxySeal := seal.pxyCreateUpdateProxy.CM_SealTI;
		//endif;
		
		pxySeal := seal.cloneSelf(true).CM_SealTI;
		self.allSeals.add( pxySeal );
	endforeach;

epilog
	app.cmsEndLoad(loadState);					// 11/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_allSeals" type="CM_SealTIBySealTypeDict"/>
    </JadeMethod>
    <JadeMethod name="createROBReleaseGTE" id="dcd2ea39-f4d7-4679-81d6-bccf1a827a17">
        <updating/>
        <source>createROBReleaseGTE(_realVVR : CM_VehicleVisitRecord;
					oldId : String;
					oldIMEX : Integer ) updating, protected;
/*

Date		Who		Reason
22 July 2014	cnwer1	Initial creation PAR
11 July 2018	cnwma1	Bug 39649: PEN - ROB Chassis with Underslung Gen Sets attached
*/

vars
	gteEntity			: CMGTE_Entity;
	robReleaseTrailer : CMGTE_Release;
begin
	if oldIMEX = TI_IMEX_STATUS_REMAINONBOARD and self.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
		if oldId &lt;&gt; null then
			foreach gteEntity in _realVVR.allGateEntities where gteEntity.isKindOf(CMGTE_Release) do
				if gteEntity.id = oldId then
					robReleaseTrailer:=gteEntity.CMGTE_Release;
				endif;
			endforeach;
		endif;
		if robReleaseTrailer &lt;&gt; null then
			delete robReleaseTrailer;
		endif;
	endif;
	
	
	if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and _realVVR &lt;&gt; null then
		if oldId &lt;&gt; null then
			foreach gteEntity in _realVVR.allGateEntities where gteEntity.isKindOf(CMGTE_Release) do
				if gteEntity.id = oldId then
					robReleaseTrailer:=gteEntity.CMGTE_Release;
				endif;
			endforeach;
		endif;
		if self.isKindOf(CMGTE_TILC) then      //11.7.2018 cnwma1 Bug #39649
			if robReleaseTrailer =  null then
				create robReleaseTrailer persistent;
			endif;
			
			robReleaseTrailer.setFromROB_GTE_Receival(self,_realVVR);
			robReleaseTrailer.setJobQueueNum(self.jobQueueNum + 1000);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="oldId" type="String"/>
        <Parameter name="oldIMEX" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createRequest" id="78cd31d7-5a7c-4365-bbc3-b47394d4be01">
        <updating/>
        <source>createRequest(_passport : CM_Passport input) : Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpConsignorVoyageCode, tmpEirNumber, tmpConsignee : String;
	theTI : CM_TrackedItem;
	roadJob : CM_RoadJob;
	proxyTIRequest : CM_TIRequest;
begin
	//epr CCMS 1386 ROB changed to getVehcileVisit so it will return something if child cargo
	roadJob := self.getVehicleVisitRecord.myRoadJob;

	theTI := self.myTrackedItem;
	
	create proxyTIRequest transient;

	tmpConsignorVoyageCode := theTI.consignorVoyageCode;
	tmpEirNumber := theTI.eirNumber;
	tmpConsignee := theTI.consignee;
	
	proxyTIRequest.setProxy(false, tmpConsignorVoyageCode, tmpEirNumber, // lClean, lconsignorVoyageCode, leirNumber
							tmpConsignee, 0, 
							null, self.freightForwarderCode, null, true, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
							null,null, 0,null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
							false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
							false, null, self.remarks, self.myTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI
							_passport.userCode, null);
								
	if _passport.noErrors() then	
		//Validate the request (TI is already validated)
		proxyTIRequest.validate(_passport.myUser);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;

	//Add the request to the job	
	self.myYardRequest := roadJob.addRequest(proxyTIRequest, _passport).CM_YardRequest;
	if _passport.hasErrors() then
		return false;
	endif;
	

	//Add the TI to the job
	roadJob.addTI(self.myTrackedItem, proxyTIRequest);

	return true;
epilog
	delete proxyTIRequest;   // Leak found in unit test
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="defaultDetailsFromParentItem" id="35dc37c9-e34a-470c-bdc9-75fea23886c1">
        <updating/>
        <source>defaultDetailsFromParentItem(_parent: CMGTE_Entity) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2009	cnwdap1	Initial creation
18/06/2015	cnwdap1	PAR #36421 hazardous Materials Handling
21/09/2015  cnwma1  PAR #36885 Validation of parent to do tasks is applied to child items at road gate
*/
vars
	str		: String;
	lift	: CM_SpecialLift;
	int		: Integer;
	task	: CM_ToDoTaskDesc;
	hazard	: CM_Hazard;

begin
	inheritMethod(_parent);
	

	self.destinationPort 	:= _parent.CMGTE_Receival.destinationPort;
	self.dischargePort 		:= _parent.CMGTE_Receival.dischargePort;

	self.allDischargePorts.clear;
	foreach str in _parent.CMGTE_Receival.allDischargePorts do
		self.allDischargePorts.add(str);
	endforeach;
	
	self.consignorCode 		:= _parent.CMGTE_Receival.consignorCode;
	self.consigneeCode 		:= _parent.CMGTE_Receival.consigneeCode;
	self.customsAgentCode 	:= _parent.CMGTE_Receival.customsAgentCode;
	self.imExStatus 		:= _parent.CMGTE_Receival.imExStatus;
	self.specialStow 		:= _parent.CMGTE_Receival.specialStow;

	
	if self.operatorCode = null then
		self.operatorCode	:= _parent.CMGTE_Receival.operatorCode;
	endif;
	
	// PAR #36421 If the terminal config item Hazardous - UseDetailedHazEntry is set,	// PAR #36421
	// then we want to keep the hazards for this child item, rather than copying them 	// PAR #36421
	// from the parent																	// PAR #36421
	if not self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then					// PAR #36421
		self.allTIHazards.clear;
		foreach hazard in _parent.CMGTE_Receival.allTIHazards do
			self.allTIHazards.add(hazard);
		endforeach;
	endif;																				// PAR #36421
	
	/* 19 Feb 2016	NDL	Par 37538 - Do NOT copy speical lifts or to do tasks from parent to child
	self.allSpecialLifts.clear;
	foreach lift in _parent.CMGTE_Receival.allSpecialLifts do
		self.allSpecialLifts.add(lift);
	endforeach;
	*/
	
	self.allStops.clear;
	foreach int in _parent.CMGTE_Receival.allStops do
		self.allStops.add(int);
	endforeach;
	
	/* 19 Feb 2016	NDL	Par 37538 - Do NOT copy speical lifts or to do tasks from parent to child
	self.allToDoTasks.clear;
	foreach task in _parent.CMGTE_Receival.allToDoTasks do
		if task.isAvailableForCargoType(self.cargoType) then							// 21/09/2015 cnwma1 PAR #36885 
			self.allToDoTasks.add(task);
		endif;
	endforeach;
	*/

epilog

end;</source>
        <Parameter name="_parent" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d76eaeff-a78b-4489-9dca-929d2eb1bb92">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	cnwjk3	Initial creation
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
26/05/2023	jlika1	TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
5/8/24       jlier1 TFS 64964 - moved code to CM_UtilityDeleteAgent utlDeleteVehicleVisitGTE
*/

vars
	invalidTI : Boolean;
	ti	: CM_TrackedItem;
	realOne : CMGTE_Receival;
	cargoGroup : CM_CargoGroup;
begin
	// 14/02/2011 cnwar2 #26992 - commented out //16 Mar 2012	NDL	Par 28495
	//on Exception do app.handleDeletedObject(exception, ti, invalidTI);

	ti := self.myTrackedItem;
	
	//16 Mar 2012	NDL	Par 28495
	if ti &lt;&gt; null and not global.isValidObject(ti) then
		self.myTrackedItem := null;
		ti := null;
	endif;
	
	if self.isTransient then
		if   ti &lt;&gt; null and
		   ti.isTransient then
			delete self.myTrackedItem;
		endif;
		
		cargoGroup := self.myCargoGroup;
		//jlier1 TFS 53515 8/6/22
		if cargoGroup &lt;&gt; null and cargoGroup.isTransient then	// ### TFS 58164 29May2023 NAVPW1
			delete cargoGroup;										// ### TFS 58164 29May2023 NAVPW1
		endif;
	endif;
	
	self.allTIHazards.purge();
	
	//10 Dec 2010	NDL	Par 26567
	if not self.allSeals.isEmpty then
		self.allSeals.purge;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteRemovedChildrenFromTI" id="e478d09f-7ea0-4e63-b128-528a96a9b357">
        <source>deleteRemovedChildrenFromTI(_pxyTI : CM_TrackedItem) protected;
//Purpose:			
//
//Parameters:			
//
//Return Value:		
//
//Date		Who		Reason
//30 March 2010	cnwjk3	PAR 23476
//We can have cargo pre-noted with attachments.  When gated in, the user could change the ID of the attachment.  This method serves
//to remove any children from the proxy TI, whos IDs are not included in the gate entity.
vars
	tiChild 		: CM_TrackedItem;
	gteChild		: CMGTE_Entity;
	//tiChildren		: CM_TISet;
	found			: Boolean;
begin
	if _pxyTI = null then
		return;
	endif;
	
	//create tiChildren transient;
	//_pxyTI.getAllChildren(tiChildren);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
	
	if _pxyTI.allChildren.isEmpty() then
		return;
	endif;
	
	foreach tiChild in _pxyTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		found := false;
		foreach gteChild in self.allChildren do
			if gteChild.id = tiChild.id then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			delete tiChild;
		endif;
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="directDeliveryCopyWLEs" id="3968dc74-44fe-479b-9c81-c29eeb6262c6">
        <source>directDeliveryCopyWLEs(_roadJob : CM_RoadJob; _prenoteTI : CM_TrackedItem);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial prenoted Cargo from Truck to Vessel
// 10/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 10/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	mp : CM_FutureMove;
	fmp, newFmp : CM_FutureMovePlanned;
	roadWle, wle, newWle : CM_WorkListEntry;
	prenoteTI : CM_TrackedItem;

begin
	if _roadJob = null or _prenoteTI = null or _prenoteTI = self.myTrackedItem then
		if self.myTrackedItem.wasPrenotified then
			// even though the prenote may be null, we're still interested in this TI if it was prenoted
			// it may be the last prenoted bit being received on site
		else
			return;
		endif;
	endif;
	
	// If we have a prenote, make a copy of all future planned moves on the prenoted TI to the new TI
	// Use the road job WLE's quantity / weight for the new wles
	roadWle := _roadJob.workListEntries.first;
	prenoteTI := _prenoteTI;
	if prenoteTI &lt;&gt; null and prenoteTI.isOnSite then
		prenoteTI := null;
	endif;
	if prenoteTI &lt;&gt; null then
		foreach mp in _prenoteTI.allPlannedFutureMoves  
			where mp.moveType &lt;&gt; TI_FutureMoveEDI do // ### TFS 52618 22DEC2021 NAVAB1
			fmp := mp.CM_FutureMovePlanned;
			wle := fmp.myWorkListEntry;
			
			// ### TFS 52618 22DEC2021 NAVAB1. It is possible to plan a prenote without a job or WLE
			if wle = null then 
				continue;
			endif;
			
			newFmp := fmp.cloneSelf(false);
			newWle := wle.cloneSelf(false);
			newFmp.setMyTrackedItem(self.myTrackedItem);
			fmp.allLocationsControllers.copy(newFmp.allLocationsControllers);
			newFmp.setMyWorkListEntry(newWle, false);
			
			newWle.updateRequest(wle.myRequest);
			//newWle.setDirectDeliveryUpdate(roadWle, _prenoteTI);				// TFS 52293
			newWle.setDirectDeliveryUpdate(roadWle, _prenoteTI, wle.job);		// TFS 52293
			newWle.causeEvent(newWle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, newWle);	// TFS 52360
		endforeach;
	else
	// if we don't have a prenote, then there will be a voyage WLE on the TI - hook this to the yard WLE
	// this happens when the last bit of the prenote is brought onsite - in this case we also need to 
	// record the original planning voyage WLE amounts otherwise we lose them
		foreach wle in self.myTrackedItem.allWorklistEntries do
			if not wle.isKindOf(CM_VoyageWLE) then
				continue;
			endif;
			wle.setMyDirectDeliveryParentWLE(roadWle);
			if self.myTrackedItem.isBulkByQuantity then
				wle.CM_VoyageWLE.setSubSeqNum(wle.quantity);		// TFS 52360
				wle.setQuantity(roadWle.quantity);
			else
				wle.CM_VoyageWLE.setSubSeqNum(wle.weight.Integer);	// TFS 52360
				wle.setWeight(roadWle.weight);
			endif;
			wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, wle);			// TFS 52360
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <Parameter name="_prenoteTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getActualLength" id="29983fd9-f0ac-4617-b7e8-ba4fca8b3e6f">
