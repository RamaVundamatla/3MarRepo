<Class name="CMUI_GridPoint" id="26fda009-e85c-4865-b41d-631c784e7e22">
    <superclass name="CMUI_GridObject"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>
This is really the "cell" at the intersection of its row and 
column.  The term "cell" is not used because it has special 
(and different) meaning for Bay Defs.</text>
