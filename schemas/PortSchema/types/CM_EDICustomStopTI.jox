    <JadeMethod name="messageModeVerify" id="9d1a06d9-cac4-4452-8292-76cebcfa4516">
        <source>messageModeVerify(_terminal: CM_Terminal);
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 26 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window

vars

begin
	if self.messageMode = "" then
		//app.raiseCMException1(REQUIRED_FIELD, 'message Mode', 'messageMode', self);
	else
		if self.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or
		   self.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE or
		   self.messageMode = Agency_NZCS or // TFS 39133
		   self.messageMode = Agency_MPI or	// TFS 39133		  
		   self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		else
		//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'tiType', self);
			app.raiseCMException(Input_required_field_cargoType, 'tiType', self); // cnwdb2	PAR 35364
		endif;
	endif;
end;</source>
