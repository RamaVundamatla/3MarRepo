    <JadeMethod name="addProxyObjectToDetailTable" id="4f6d4e9a-da9c-41ce-9c26-b172d6c8bce1">
        <updating/>
        <source>addProxyObjectToDetailTable(_tbl : CM_DataTable input; _obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	backColour,
	rowIdx : Integer;
	tmpTable : CM_DataTable;
	rowArray : EntTableRowArray;
//	newDateCntrl : CMUI_DateBox;
//	newTimeCntrl : CMUI_TimeEntry;
	newTxtBox : CMUI_TextBox;
	newCombo : CMUI_ComboBox;
	assist : CMUI_Assistant;
begin	
	if _obj = null then
		return;
	endif;
	
	tmpTable := self.tblDataDetail;
	rowArray := tmpTable.allTblDataEntRows;
		
	assist := self.myAssistant;
	
	rowIdx := tmpTable.rows+1;
	tmpTable.addItemAt(_obj.CMIF_Object.getAttributeStringForDefArray(rowArray), rowIdx);

	tmpTable.accessRow(rowIdx).itemObject := _obj;
	
	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	tmpTable.accessRow(rowIdx).backColor := backColour;	

	if self.mode = self.Mode_Edit
	or self.mode = self.Mode_New then

	endif;
	
end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5fc14e2c-2ea2-4a62-9bfd-1ad884fc521c">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm			: CMUI_Toolbar;
	masterEntityDescr,
	detailEntityDescr	: String;
begin
	inheritMethod();
	masterEntityDescr := self.getDataEntityDescription(true);
	detailEntityDescr := self.getDataEntityDescription(false);
	
	frm := self.frmToolbar;
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if self.allowMasterNew then
		self.btnNew.caption := '&amp;New ' &amp; masterEntityDescr &amp; ' (Alt-N)'; // PAR 8990
		frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if self.allowMasterEdit then
		self.btnEdit.caption := '&amp;Edit ' &amp; masterEntityDescr &amp; ' (Alt-E)'; // PAR 8990
		frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if self.allowMasterDelete then
		self.btnDelete.caption := '&amp;Delete ' &amp; masterEntityDescr &amp; ' (Alt-D)'; // PAR 8990
		frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if self.allowDetailAdd then
		self.btnAddShow.caption := '&amp;Add ' &amp; detailEntityDescr &amp; ' (Alt-A)'; // PAR 8990
		frm.addButton(self.btnAddShow, CMUI_Toolbar.Control_Alignment_Left);
	endif;	
	
//	if self.allowDetailUpdate then
//		self.btnUpdateShow.caption := '&amp;Update ' &amp; detailEntityDescr &amp; ' (Alt-U)'; // PAR 8990
//		frm.addButton(self.btnUpdateShow, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
		
	if self.allowDetailRemove then
		self.btnRemoveDtl.caption := '&amp;Remove ' &amp; detailEntityDescr &amp; ' (Alt-R)'; // PAR 8990
		frm.addButton(self.btnRemoveDtl, CMUI_Toolbar.Control_Alignment_Left);
	endif;	
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	////////////
	//searcher toolbar
	frm := self.frmToolbarSearch;
	frm.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.positionToolbarControls();
	frm.visible := true;
	////////////
	//detail entry toolbar
	frm := self.frmToolbarDetail;
	frm.addButton(self.btnAddDetail, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUpdateDetail, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRemoveDtl2, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnHideDetailEnt, CMUI_Toolbar.Control_Alignment_Left);
	frm.positionToolbarControls();
	frm.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
