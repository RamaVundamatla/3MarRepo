        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars

begin
	/* ### TFS 53105 02JUN2022 NAVAB1
	if self.job &lt;&gt; null then
		if self.job.isVoyageJob() then // LOLO Job
			return true;
		endif;
	else
	*/
	if self.myTrackedItem &lt;&gt; null // ### TFS 51855 03FEB2022 NAVAB1
	and  self.myTrackedItem.isOpsViewData() then  // ### TFS 53105 02JUN2022 NAVAB1
