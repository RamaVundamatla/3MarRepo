	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 121.00, 10.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	
	create tiArray transient;
	self.locationArray.clear();
	self.locationArray.add("D4421O");
	self.locationArray.add("D4422O");
	self.locationArray.add("D4423O");
	self.locationArray.add("D4424O");
	self.locationArray.add("D4426O");
	self.locationArray.add("D4428O");
	self.locationArray.add("D4430O");
	
	foreach locn in self.locationArray do
		location := self.myDeck.allROROLocnDefnByCode[locn];
		self.assertNotEqual(location, null);
		
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;	
		app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	
	self.locationArray.clear();
	self.locationArray.add("D4421OR");
	self.locationArray.add("D4422OR");
	self.locationArray.add("D4423OR");
	self.locationArray.add("D4424OR");
	self.locationArray.add("D4426OR");
	self.locationArray.add("D4428OR");
	self.locationArray.add("D4430OR");
	
	isoTypeStr := "U20G";
	foreach locn in self.locationArray do
	
		if locn = "D4426OR" or locn = "D4428OR" or locn = "D4430OR" then
			isoTypeStr := "U40G";
		endif;
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), isoTypeStr, "GENL", TI_IMEX_STATUS_REMAINONBOARD, slotLC, port, self.myVoyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
		endforeach;
		
		
	endforeach;
	
