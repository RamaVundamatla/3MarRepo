    <JadeMethod name="setBaseEndpoint" id="05321e4f-c01b-4ee0-ad3d-4d26a4d93c11">
        <updating/>
        <source>setBaseEndpoint(_endPoint: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	defaultBaseEndpoint	: String;
	newEndpoint			: String;
	wsc					: IPN1_InaportnetServiceP1ControllerService;
	
begin
	inheritMethod(_endPoint);

	defaultBaseEndpoint := self.getDefaultBaseEndpoint();
	
	create wsc transient;
	newEndpoint := wsc.getEndpointURL();
	newEndpoint := newEndpoint.replace(defaultBaseEndpoint, _endPoint);
	
	myIPNConsumer.setEndpointURL(newEndpoint);
	
epilog
	delete wsc;
	
end;</source>
        <Parameter name="_endPoint" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRestAPIBaseEndpoint" id="66d6b472-bbd1-44cf-ad1a-3ecad1d176a7">
        <updating/>
        <source>setRestAPIBaseEndpoint(_baseRestEndpoint : String) updating;
/*

Purpose:			Ensure that the base Rest endpoint has a trailing '/'

Parameters:			New base Rest endpoint to set 

Return Value:		None

Date		Who		Reason
2 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.restAPIBaseEndpoint := _baseRestEndpoint.trimBlanks();
	if not self.restAPIBaseEndpoint.endsWith('/') then
		self.restAPIBaseEndpoint := self.restAPIBaseEndpoint &amp; '/';
	endif;
	
epilog

end;</source>
        <Parameter name="_baseRestEndpoint" type="String"/>
    </JadeMethod>
