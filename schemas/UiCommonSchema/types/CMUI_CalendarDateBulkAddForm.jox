    <JadeMethod name="genDatesByYear" id="73aae358-4a89-490e-bda3-adb353cec22f">
        <source>genDatesByYear( templateRow : JadeTableRow; label : String io; startDate : Date; endDate : Date; startTime : Time; endTime : Time ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation
11/03/2015		cnwmh5	tranisent leak
*/

vars

	templateCalendarDate : CM_CalendarDate;
	newDate : Date;
	transCalendarDate : CM_CalendarDate;
	errString : String;
	nullTime : Time;
	hookDayNamesArray : StringArray;
	hookCalendar : CM_Calendar;

begin

	templateCalendarDate := templateRow.itemObject.CM_CalendarDate;
	if templateCalendarDate = null then
		return;
	endif;
	if label = null then
		label := templateCalendarDate.description;
	endif;
	newDate.setDate( templateCalendarDate.date.day, templateCalendarDate.date.month, startDate.year );
	if not newDate.isValid then
		errString := app.getErrorString4(Not_create_date, templateCalendarDate.date.day.String, templateCalendarDate.date.month.String, startDate.year.String, label);
		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	if newDate &lt; startDate then
		return;
	elseif newDate = startDate then
		nullTime := "00:00:00".Time;
		if startTime &lt;&gt; nullTime and endTime &lt;&gt; nullTime and templateCalendarDate.endTime &lt; startTime then
			return;
		endif;
	endif;
	
	while newDate.year &lt;= endDate.year do
	
		if self.myCalendar.myHookCode &lt;&gt; null then
			
			delete hookDayNamesArray;
			create hookDayNamesArray transient;
			self.dayListArray.copy(hookDayNamesArray);
			hookCalendar := self.myCalendar;
			if not app.myHookAgent.runHookLinkPublic(	HookType_CalendarDay,
														self.myCalendar,
														self.myCalendar,
														hookDayNamesArray,	//_dayNamesArray : StringArray; 
														hookCalendar,	//_calendar : CM_Calendar;
														templateCalendarDate,	//_templateCalendarDate : CM_CalendarDate;
														newDate	//_proposedDate : Date
														).Boolean then
				continue;
			endif;
			
		endif;
	
		if newDate.year = endDate.year then
			if newDate.month &gt; endDate.month then
				break;
			elseif newDate.month = endDate.month then
				if newDate.day &gt; endDate.day then
					break;
				elseif newDate.day = endDate.day then
					if endTime &lt;&gt; null and templateCalendarDate.startTime &gt; endTime then
						break;
					endif;
				endif;
			endif;
		endif;
	
		create transCalendarDate transient;
		
		transCalendarDate.setProxy(	newDate,	//_date : Date;
									label,	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									0	//_dataSource : Integer
									);
		transCalendarDate.setStartEndTime(	templateCalendarDate.startTime,	//_startTime : Time;
											templateCalendarDate.endTime	//_endTime : Time
											);
											
		self.allTransCalendarDates.add(transCalendarDate);
		
		newDate.setDate( newDate.day, newDate.month, newDate.year + 1 );
		if not newDate.isValid then
			errString := app.getErrorString4(Not_create_date, newDate.day.String, newDate.month.String, (newDate.year + 1).String, label);
			app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			return;
		endif;
		
	endwhile;

epilog

	delete hookDayNamesArray;

end;</source>
        <access>protected</access>
        <Parameter name="templateRow" type="JadeTableRow"/>
        <Parameter name="label" type="String" usage="io"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startTime" type="Time"/>
        <Parameter name="endTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="genTransientCalendarDates" id="0266d284-48b2-44cd-b91b-6a022dc923ff">
        <source>genTransientCalendarDates() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	templateCell : JadeTableCell;
	templateRow : JadeTableRow;
	pos : Integer;
	byDay : Boolean;
	byMonth : Boolean;
	byYear : Boolean;
//	templateCalendarDate : CM_CalendarDate;
	labelCell : JadeTableCell;
	label : String;
//	transCalendarDate : CM_CalendarDate;
	startDate : Date;
	endDate : Date;
	newDate : Date;
	startTime : Time;
	endTime : Time;
	
begin

	byDay := self.optDay.value;
	byMonth := self.optMonth.value;
	byYear := self.optYear.value;
	
	startDate := self.txtDateFrom.getDate;
	endDate := self.txtDateTo.getDate;
	startTime := self.txtTimeFrom.getTime;
	endTime := self.txtTimeTo.getTime;

	foreach pos in 1 to tblTemplates.rows do
	
		templateCell := tblTemplates.accessCell(pos,1);
		if templateCell.text.Integer.Boolean then
			// its selected
			templateRow := tblTemplates.accessRow(pos);
			labelCell := tblLabels.accessCell(pos,1);
			label := labelCell.text;
		
			if byDay then
				self.genDatesByDay( templateRow, label, startDate, endDate, startTime, endTime );
			
			elseif byMonth then
				self.genDatesByMonth( templateRow, label, startDate, endDate, startTime, endTime );
			
			elseif byYear then
				self.genDatesByYear( templateRow, label, startDate, endDate, startTime, endTime );
				
			endif;
		endif;
		
	endforeach;
	
	self.populateTblDayData();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblDayData" id="90ddd919-cb45-43c6-b9a0-22f95ab22ee5">
        <source>initTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	headingRow : String;
	
begin

	self.tblDayData.clear();
	self.tblDayData.fixedRows := 1;
	self.tblDayData.rows := 1;
	self.tblDayData.fixedColumns := 0;
	self.tblDayData.columns := 5;
	
	self.tblDayData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblDayData.selectionType := CM_BaseTable.SelectionType_Row;
	
	headingRow := app.getErrorString(Year) &amp; Tab
					&amp; app.getErrorString(DateStr) &amp; Tab
					&amp; app.getErrorString(Day) &amp; Tab
					&amp; app.getErrorString(TimeStr) &amp; Tab
					&amp; app.getErrorString(Description);
					
	self.tblDayData.setCellText(1,1,headingRow);

epilog

end;</source>
