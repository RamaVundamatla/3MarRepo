    <JadeMethod name="doSetupConsumerInstance" id="e38b9382-a735-43da-9a5b-f944f4a700d9">
        <updating/>
        <source>doSetupConsumerInstance(_consumerClass : Class) updating, protected;
/*

Purpose:			Setup the Web Service consumer (of the class passed in) ready for the upcoming call.

Parameters:			Class of consumer required

Return Value:		None

Date		Who		Reason
14 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	defaultBaseEndpoint	: String;
	newEndpoint			: String;
	
begin
	if self.myWebServiceConsumer = null or not self.myWebServiceConsumer.isKindOf(_consumerClass) then
		delete self.myWebServiceConsumer;
		create self.myWebServiceConsumer as _consumerClass transient;

		if self.baseEndpoint &lt;&gt; null then
			// Setup the Endpoint URL using the current baseEndpoint
			defaultBaseEndpoint	:= self.getDefaultBaseEndpoint();
		
			newEndpoint := self.myWebServiceConsumer.getEndpointURL();
			newEndpoint := newEndpoint.replace(defaultBaseEndpoint, self.baseEndpoint);
		
			self.myWebServiceConsumer.setEndpointURL(newEndpoint);
		endif;
		
		app.writeLog(method.qualifiedName &amp; " consumer " &amp; self.myWebServiceConsumer.String &amp;
					   " created, endpointURL is " &amp; self.myWebServiceConsumer.getEndpointURL(), LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
	endif;	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_consumerClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="doSetupForWebServiceRequest" id="f5b682a7-45ba-4da3-b637-6804f336632d">
        <source>doSetupForWebServiceRequest(_consumer: JadeWebServiceConsumer input; _request: ImportedWebServiceProxy input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	
begin
	inheritMethod(_consumer, _request);

	// The SAP Web Service requires the authentication in the header, so set up the Web Service consumer
	_consumer.userName := self.usercode;
	_consumer.password := self.password;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_consumer" type="JadeWebServiceConsumer" usage="input"/>
        <Parameter name="_request" type="ImportedWebServiceProxy" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDefaultBaseEndpoint" id="bf770e06-e406-4b9e-9ff5-2c8ff1817352">
        <source>getDefaultBaseEndpoint(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	wsc				: SAP11_HTTP_Port;
	pos				: Integer;
	defaultEndpoint	: String;
	
begin
	create wsc transient;
	defaultEndpoint := wsc.getEndpointURL();
	
	pos := defaultEndpoint.pos("/XISOAPAdapter", 1);
	if pos = 0 then
		return defaultEndpoint;
	else
		return defaultEndpoint[1:pos];
	endif;
	
epilog
	delete wsc;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
