    <JadeMethod name="setProxyCriteria" id="adb2e0e6-ac48-4abb-a396-46b82c1d97b3">
        <source>setProxyCriteria(_item: Any; _criteriaType: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
	
begin
	return;
	criteriaType := app.myRoot.allYACriteriaTypes[_criteriaType];
	if criteriaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Shipping Line Status criteria type (' &amp; _criteriaType.String &amp; ') not present');
		return;
	endif;
	
	create criteria transient;
	criteria.setProxy(criteriaType, _item, null);
	
	self.allCriteria.add(criteria);
	
epilog

end;</source>
        <Parameter name="_item" type="Any"/>
        <Parameter name="_criteriaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f6eb6075-1287-46d9-a781-a1b6a3c12c03">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="525a082f-95cc-4d6e-aacc-a1c3df1fcd61">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars

begin
	if self.allCriteria.isEmpty then
		app.raiseCMWarning(NoCriteriaEnteredShipLineStat, null, null, null);
	endif;

	if self.myShippingLineStatus = null then
		app.raiseCMException(ShipLineStatusCriteriaOrphan, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
