        <updating/>
        <source>btn_Cancel_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 29/05/2015	cnwdap1		PAR #36231 changed to doCancel method
//
vars

begin
	app.mousePointer := Busy;
	//self.doCloseForm();			// PAR #36231
	self.doBtnCancel();				// PAR #36231
epilog
	app.mousePointer := Idle;
end;</source>
