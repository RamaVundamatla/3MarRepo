    <JadeMethod name="displayResults" id="1713ef43-2b25-496c-b32e-4c8a4f73b9a7">
        <updating/>
        <source>displayResults() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	matches : CM_ViewTable;
	candidate : CM_BulkYACandidate;
	lastCriteriaType : Integer;
	criteriaTypes : CM_YACritetriaTypeByTypeDict;
	displayValue : String;
	criteriaTypeObj : CM_YACriteriaType;

begin
	matches := self.tblMatches;
	
	self.setupMatchesTable();
	
	if self.myBulkYACandidateResults.hasExistingYardAllocations() then
		// Add a "Yard Allocations" heading
		matches.addItem(app.getErrorString(Yard_allocation));
		matches.accessRow(1).backColor := LightGray;
		matches.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
		
		// Add the existing yard allocations
		foreach candidate in self.myBulkYACandidateResults.allCandidates where candidate.myExistingYardAllocation &lt;&gt; null do
			matches.addItemObjectAt(candidate, Tab &amp; candidate.myExistingYardAllocation.code &amp; Tab &amp; candidate.allMatchingTIs.size.String, matches.rows+1);
		endforeach;
		
		matches.addItem(Tab);
	endif;
	
	// Now the candidates with criteria
	// Add a "Criteria" heading
	matches.addItem(app.getErrorString(Criteria_selection) &amp; Tab &amp; Tab &amp; app.getErrorString(NumberOfMatches));
	matches.accessRow(matches.rows).backColor := LightGray;
	matches.accessCell(matches.rows, 1).mergeCells := Table.MergeCells_Merge;
	criteriaTypes := app.myRoot.allYACriteriaTypes;
	
	foreach candidate in self.myBulkYACandidateResults.allCandidates where candidate.criteriaType &lt;&gt; null do
		// Add a heading for criteria type
		criteriaTypeObj := criteriaTypes[candidate.criteriaType];
		if candidate.criteriaType &lt;&gt; lastCriteriaType then
			matches.addItem("-" &amp; Tab &amp; criteriaTypeObj.description);
			matches.accessRow(matches.rows).backColor := Cn_LightGray;
		endif;
		
		// Now add the criteria detail
		displayValue := candidate.getCriteriaValueForDisplay;
		matches.addItemObject(candidate, Tab &amp; displayValue &amp; Tab &amp; candidate.allMatchingTIs.size.String);
		
		lastCriteriaType := candidate.criteriaType;
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddToProposed" id="bc0e6d0a-c994-4a9f-a2aa-60c1ea6738bb">
        <source>doAddToProposed(_all : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
// 17/10/2025	navdap1		MTN-36258 ENT | Issue in Bulk Yard Allocation Creation on Different Criteria
//
vars
	row, propRow : Integer;
	obj : Object;
	candidate : CM_BulkYACandidate;
	alloc : CM_YardAllocation;
	candidateSet : CM_BulkYACandidateSet;
	block : CM_YABlock;
	capacity : Integer;
	lc : CM_LocationsController;
	tis : Integer;
	str : String;
	newCode : String;
	critType : CM_YACriteriaType;
	yaPriority : CM_YAPriority;
	priority : Real;
	doneThisOne : Boolean;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, alloc, invalid);
	
	// What has been selected - more than one line for the same criteria type means we need to combine the 2
	foreach row in 1 to self.tblMatches.rows do
		obj := self.tblMatches.accessRow(row).itemObject;
		if obj = null then
			continue;
		endif;
		
		candidate := obj.CM_BulkYACandidate;
		if self.tblMatches.accessedRow.selected or _all then
			// Add this item to the "proposed" table
			if candidate.myExistingYardAllocation &lt;&gt; null then
				// Yard Allocation - simple, just add it and get details from the Yard Allocation
				alloc := candidate.myExistingYardAllocation;
				invalid := false;
				alloc.edition;
				if invalid then
					continue;
				endif;
				
				capacity := null;
				tis := null;
				foreach block in alloc.allYABlocksIn discreteLock do
					if block.myLocationStatistics &lt;&gt; null then
						capacity := capacity + block.myLocationStatistics.c20Free + block.myLocationStatistics.c30Free + block.myLocationStatistics.c40Free + block.myLocationStatistics.c45Free + block.myLocationStatistics.c53Free + block.myLocationStatistics.free;
					endif;
					foreach lc in block.allYardControllers do
						tis := tis + lc.allTrackedItems.size;
					endforeach;
				endforeach;
				
				str := alloc.code &amp; Tab &amp; alloc.getCriteriaString &amp; Tab &amp; candidate.allMatchingTIs.size.String &amp; Tab &amp; app.getErrorString(Yes) &amp; Tab &amp; alloc.priorityValue.String &amp; capacity.String &amp; Tab &amp; tis.String;
				self.tblProposed.addItemObject(candidate, str);
				
			else
				// Candidate - check if an existing entry for the same criteria type - if yes, append. If no, just add
				doneThisOne := false;
				priority := null;
				newCode := self.myImexStatus.description[1:1] &amp; Space;
				if self.myVoyage &lt;&gt; null then
					newCode := newCode &amp; self.myVoyage.code &amp; Space;
				else
					newCode := newCode &amp; candidate.getCriteriaValueForDisplay();
				endif;
				critType := app.myRoot.allYACriteriaTypes[candidate.criteriaType];
				foreach yaPriority in critType.allYAPriorities where yaPriority.myTerminal = self.myTerminal do
					priority := yaPriority.priorityValue;
					break;
				endforeach;
				
				// MTN-36258 Don't add a criteria to an existing Proposed row if that row is disabled
				// (because it's already been used to create a yard allocation)
				foreach propRow in self.tblProposed.fixedRows + 1 to self.tblProposed.rows where self.tblProposed.accessRow(propRow).enabled do
					obj := self.tblProposed.accessRow(propRow).itemObject;
					if obj.isKindOf(CM_BulkYACandidate) and obj.CM_BulkYACandidate.criteriaType = candidate.criteriaType 
					or obj.isKindOf(CM_BulkYACandidateSet) and obj.CM_BulkYACandidateSet.first.criteriaType = candidate.criteriaType then
						// We already have an entry for this criteria type - add the criteria value to this item's description
						// and replace the CM_BulkYACandidate itemObject with a CM_BulkYACandidateSet containing both candidates
						if obj.isKindOf(CM_BulkYACandidate) then
							create candidateSet transient;
							candidateSet.add(obj.CM_BulkYACandidate);
						else
							candidateSet := obj.CM_BulkYACandidateSet;
						endif;
						candidateSet.add(candidate);
						self.tblProposed.accessedRow.itemObject := candidateSet;
						
						self.tblProposed.accessCell(propRow, 1).text := newCode &amp; Tab &amp; candidateSet.getDescription &amp; Tab &amp; candidateSet.getNumberofTIs.String &amp; Tab &amp; Tab &amp; priority.asStringJMT;
						doneThisOne := true;
					endif;
				endforeach;
				
				if not doneThisOne then
					// This is a candidate for a criteria value we haven't had before - add it
					self.tblProposed.addItemObject(candidate, newCode &amp; Tab &amp; app.myRoot.allYACriteriaTypes[candidate.criteriaType].description &amp; Space &amp; candidate.getCriteriaValueForDisplay() &amp; Tab &amp; candidate.allMatchingTIs.size.String &amp; Tab &amp; Tab &amp; priority.asStringJMT);
				endif;
			endif;
			
			// Disable the Matches table row so we can't click it again
			self.tblMatches.accessedRow.enabled := false;
			self.tblMatches.accessedRow.selected := false;
		endif;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCalculations" id="6051b14a-2dfd-49e4-a63c-68f92cfd719e">
        <updating/>
        <source>doCalculations() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
// 10/10/2025	navdap1		MTN-36239 Error 96940 When clicking calculate on Bulk Yard Allocation creation
//
vars
	pxyRequest, realRequest : BGP_BulkYARequest;
	cmifAgent : CMIF_BulkYAAgent;

begin
	self.setupMatchesTable();
	self.setupProposedTable();
	if self.myBulkYACandidateResults &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkYACandidateResult(self.myBulkYACandidateResults, app.myPassport);
		self.myBulkYACandidateResults := null;
	endif;
	
	// Check whether we need to use a BGP, or if we can just do the calculations here
	if self.allTrackedItems.size &gt; 500 or self.myTerminal.allYardAllocatonsByCode.size &gt; 100 then
		// Need to use a BGP - check there's one running
		create pxyRequest transient;
		if not app.isAppropriateBGPRunning(pxyRequest.class.name) then
			app.raiseCMException1(Request_Cannot_Be_Created, pxyRequest.class.text.cnEcGetTagValueOfName('display'), null, null );
			return;
		endif;
		
		// Create a request and action it
		self.allTrackedItems.copy(pxyRequest.allTIs);
		app.myTrxCA.trxCreateBulkYABGPRequest(pxyRequest, realRequest, app.myPassport);
		if realRequest &lt;&gt; null then
			self.lblBGPProgress.caption := app.getErrorString1(Background_process_progress, "0");
			app.msgBox(app.getErrorString(Success_created_bulk_YA_task), app.getErrorString(Information), MsgBox_OK_Only);	// MTN-36239
		endif;
		
		return;
	endif;
	
	// OK We can process this ourselves
	create cmifAgent transient;
	cmifAgent.setDetails(self.myTerminal, self.myImexStatus.code, self.allTrackedItems);
	cmifAgent.doCalculations();
	self.myBulkYACandidateResults := cmifAgent.myBulkCandidateResults;
	self.displayResults();
	
epilog
	delete pxyRequest;
	delete cmifAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreateProposed" id="4e6f13ec-3522-4b41-b9c7-c613476e5eac">
        <updating/>
        <source>doCreateProposed() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	candidatesProposed : ObjectSet;
	row : Integer;
	obj : Object;
	result : Integer;

begin
	// Collect up the proposed candidates
	create candidatesProposed transient;
	foreach row in self.tblProposed.fixedRows + 1 to self.tblProposed.rows do
		if self.tblProposed.accessRow(row).selected then
			
			obj := self.tblProposed.accessedRow.itemObject;
			
			// Ignore lines that are existing yard allocations
			if obj.isKindOf(CM_BulkYACandidate) and obj.CM_BulkYACandidate.myExistingYardAllocation &lt;&gt; null then
				continue;
			endif;
			
			// Put the itemObject in the object set - the trx knows how to deal with a single candidate
			// or a candidate set (we'll have a candidate set if we've combined criteria for a single criteria type)
			candidatesProposed.tryAdd(obj);
		endif;
	endforeach;
	
	// Did we have anything selected?
	if candidatesProposed.isEmpty then
		app.raiseCMException1(Please_Select_Something_First, app.getErrorString(ProcessStr), null, null);
		return;
	endif;
	
	// Do the updates
	while true do
	
		app.myTrxCA.trxCreateBulkYardAllocations(candidatesProposed, app.myPassport);
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			self.postCreateProposed(candidatesProposed);
			return;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(Yard_allocation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
		endif;
		
		return;
	endwhile;
	
epilog
	delete candidatesProposed;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveFromProposed" id="4ea167a2-4cb8-4366-a987-467ececf82a0">
        <updating/>
        <source>doRemoveFromProposed(_all : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
// 30/10/2025	navdap1		MTN-36258 ENT | Issue in Bulk Yard Allocation Creation on Different Criteria
//
vars
	row : Integer;
	obj, cand : Object;
	removedObjects : ObjectArray;

begin
	// Go through the "Proposed" table and remove the selected entries, re-enabling the "matches" table entry
	create removedObjects transient;
	foreach row in self.tblProposed.fixedRows + 1 to self.tblProposed.rows reversed do
		// MTN-36258 Don't remove rows that have had allocations created for them (and are therefore disabled)
		if not self.tblProposed.accessRow(row).enabled then
			continue;
		endif;
		if self.tblProposed.accessRow(row).selected or _all then
			// Do we have a yard allocation, a single candidate, or multiple candidates?
			obj := self.tblProposed.accessedRow.itemObject;
			if obj.isKindOf(CM_BulkYACandidateSet) then
				foreach cand in obj.CM_BulkYACandidateSet do
					removedObjects.add(cand);
				endforeach;
			else
				removedObjects.add(obj);
			endif;
			
			// Remove the entry from the table, and delete any transient CM_BulkYACandidateSets
			self.tblProposed.removeItemObject(obj);
			if obj.isKindOf(CM_BulkYACandidateSet) then
				obj.CM_BulkYACandidateSet.clear;
				delete obj;
			endif;
		endif;
	endforeach;
	
	// For each thing removed, re-enable the matching entry in the "Matches" table
	foreach obj in removedObjects do
		row := 1;
		if self.tblMatches.findObjectInRow(obj, row) then
			self.tblMatches.accessRow(row).enabled := true;
		endif;
	endforeach;
	
epilog
	delete removedObjects;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveSelected" id="35abdc02-0f56-4c26-9814-566286f8aacc">
        <source>doRemoveSelected() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars
	table : CM_DataTable;
	obj : Object;
	row : Integer;

begin
	table := self.tblSelectedCargo;
	
	foreach row in table.rows to table.fixedRows step -1 do
		if table.accessRow(row).selected then
			obj := table.accessedRow.itemObject;
			table.removeItem(row);
			if obj &lt;&gt; null then
				table.allSelectedObjects.tryRemove(obj);
				self.allTrackedItems.tryRemove(obj.CM_TrackedItem);
				// And stop listneing for notifications
				endNotification(obj, Object_Update_Event);
			endif;
		endif;
	endforeach;
	
	self.tblSelectedCargo.allSelectedObjects.clear();
	
	self.lblCargoCount.caption := self.allTrackedItems.size.String &amp; " Cargo Items Selected";
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowConfigForm" id="ec5d6c2e-cd2e-4d75-a22f-9e356313f59c">
        <updating/>
        <source>doShowConfigForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	theForm : CMUI_YAConfigForm;
	config : CM_YAConfig;
	rebuild : Boolean;
	criteriaType : CM_YACriteriaType;
	
begin
	theForm := app.loadForm(CMUI_YAConfigForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_YAConfigForm;
	
	if theForm = null then
		return;
	endif;
	
	rebuild := false;
	theForm.setParentForm(self);
	if theForm.showModal() = IDOK then
		// Do we need to rebuild / reload the table?
		config := self.myTerminal.myYAConfig;
		if config.allDefaultBulkCriteriaTypes.size &lt;&gt; self.allCriteriaTypes.size then
			rebuild := true;
		endif;
		
		foreach criteriaType in config.allDefaultBulkCriteriaTypes do
			if not self.allCriteriaTypes.includes(criteriaType) then
				rebuild := true;
				break;
			endif;
		endforeach;
	endif;
	
	if rebuild then
		self.allCriteriaTypes.clear;
		config.allDefaultBulkCriteriaTypes.copy(self.allCriteriaTypes);
		self.setupSelectedTable();
		self.loadSelectedTable();
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblSelectedContext" id="269df2f3-c2e6-40e7-9ee7-4a4ac83c136c">
        <updating/>
        <source>doTblSelectedContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	if cntrl.CM_BaseTable.allSelectedObjects.isEmpty then
		return false;
	endif;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuRemoveSelected.visible := true;
	self.popupMenu(self.mnuSelectedContext, xLeft.Integer, yTop.Integer);
	
	return false;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblSelectedDblClick" id="db780f75-e4da-4dbb-a707-daed29efc0d4">
        <source>doTblSelectedDblClick(_table : CM_DataTable input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars

begin
	if _table.row &gt; _table.fixedRows then
		return;
	endif;
	if _table.sortColumn[1] &lt;&gt; null then
		_table.accessCell(1, _table.sortColumn[1]).fontBold := false;
	endif;
	_table.sortColumn[1] := _table.column;
	_table.sortAsc[1] := not _table.sortAsc[1];
	_table.accessCell(1, _table.column).fontBold := true;
	_table.resort();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="expandContractMatches" id="e3cafe66-7a45-4e0f-bb5d-67ccd54ffbeb">
        <updating/>
        <source>expandContractMatches(_startingRow : Integer) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	matches : CM_ViewTable;
	row : Integer;
	isRowVisible : Boolean;
	plusMinus : String;

begin
	matches := self.tblMatches;
	
	// Starting at the supplied row, hide or unhide table rows until we get to the next + / - row
	plusMinus := matches.accessCell(_startingRow, 1).text;
	if plusMinus = null then
		return;
	endif;
	foreach row in _startingRow to matches.rows do
		if matches.accessCell(row,1).text &lt;&gt; null and row &gt; _startingRow then
			break;
		endif;
		
		if row = _startingRow then
			if plusMinus = "+" then
				matches.accessCell(row, 1).text := "-";
			else
				matches.accessCell(row, 1).text := "+";
			endif;
			continue;
		endif;
		
		if plusMinus = "+" then
			// We are closing
			isRowVisible := true;
		else
			isRowVisible := false;
		endif;
		
		matches.accessRow(row).visible := isRowVisible;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startingRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedYardAllocation" id="b9847eb9-57b7-402e-8b59-bf847cc95ea9">
        <updating/>
        <source>handleDeletedYardAllocation(_deletedYA : CM_YardAllocation) updating;
//
// Purpose:			Remove any matching entries from the "Matches" and "Proposed" tables if a yard allocation is deleted
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	row : Integer;
	matches : CM_ViewTable;
	proposed : CM_DataTable;
	candidate : CM_BulkYACandidate;
	candidateSet : CM_BulkYACandidateSet;

begin
	// Matches table first - remove any rows that match the deleted yard allocation
	matches := self.tblMatches;
	foreach row in matches.fixedRows + 1 to matches.rows do
		if matches.accessRow(row).itemObject &lt;&gt; null then
			candidate := matches.accessedRow.itemObject.CM_BulkYACandidate;
			if candidate.myExistingYardAllocation = _deletedYA then
				matches.accessedRow.visible := false;
				matches.accessedRow.selected := false;
			endif;
		endif;
	endforeach;
	
	// Now Proposed table
	proposed := self.tblProposed;
	foreach row in proposed.fixedRows + 1 to proposed.rows do
		if proposed.accessRow(row).itemObject &lt;&gt; null then
			if proposed.accessedRow.itemObject.isKindOf(CM_BulkYACandidate) then
				candidate := proposed.accessedRow.itemObject.CM_BulkYACandidate;
				if candidate.myExistingYardAllocation = _deletedYA then
					proposed.accessedRow.visible := false;
					proposed.accessedRow.selected := false;
				endif;
			elseif proposed.accessedRow.itemObject.isKindOf(CM_BulkYACandidateSet) then
				candidateSet := proposed.accessedRow.itemObject.CM_BulkYACandidateSet;
				foreach candidate in candidateSet do
					if candidate.myExistingYardAllocation = _deletedYA then
						proposed.accessedRow.visible := false;
						proposed.accessedRow.selected := false;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_deletedYA" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="loadSelectedTable" id="69b1a7ce-31e6-4c4e-810d-cf14d82af14c">
        <updating/>
        <source>loadSelectedTable() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	dataString, critString : String;
	ti : CM_TrackedItem;
	criteriaType : CM_YACriteriaType;
	idx, newRow : Integer;
	obj : CM_Object;
	proc : Boolean;
	intArray : IntegerArray;
	objs : ObjectSet;
	stopTable : CM_StopsTable;
	toDoDesc : CM_ToDoTaskDesc;

begin
	// Get the data for each TI
	foreach ti in self.allTrackedItems do
		dataString := ti.getDisplayStringForAttribute(ETRow_Id, false) &amp; Tab &amp;
						ti.getDisplayStringForAttribute(ETRow_CargoType, false) &amp; Tab &amp;
						ti.getDisplayStringForAttribute(ETRow_Product, false) &amp; Tab &amp;
						ti.getDisplayStringForAttribute(ETRow_Operator, false) &amp; Tab &amp;
						ti.getDisplayStringForAttribute(ETRow_ImexStatus, false) &amp; Tab &amp;
						ti.getDisplayStringForAttribute(ETRow_Location, false) &amp; Tab;
		
		foreach criteriaType in self.allCriteriaTypes where not criteriaType.isDefaultForBulkYAs() do
			critString := criteriaType.getValueFromTrackedItem(ti);
			if criteriaType.isBooleanType then
				if critString = CM_YADataBoolean.VALUE_TRUE.String then
					critString := app.getErrorString(Yes);
				else
					critString := null;
				endif;
			elseif criteriaType.isTransportModeType() or criteriaType.isTransitStatusType() or criteriaType.isIntendedRelModeType() then
				// These types return an integer array
				criteriaType.getCriteriaValueForTi(ti, intArray);
				critString := criteriaType.getIntegerDisplay(intArray[1]);
			elseif criteriaType.isYATypeStops() then 
				critString := null;
				criteriaType.getCriteriaValueForTi(ti, objs);
				foreach stopTable in objs as CM_StopsTable do
					critString := critString &amp; criteriaType.getDisplay(stopTable) &amp; Comma;
				endforeach;
				critString := critString.stripTrailingChar(Comma);
				delete objs;
			elseif criteriaType.isYATypeToDoTasks() then
				critString := null;
				criteriaType.getCriteriaValueForTi(ti, objs);
				foreach toDoDesc in objs as CM_ToDoTaskDesc do
					critString := critString &amp; criteriaType.getDisplay(toDoDesc) &amp; Comma;
				endforeach;
				critString := critString.stripTrailingChar(Comma);
				delete objs;
			elseif critString = "** not initialised **" then
				// It's an object type
				criteriaType.getCriteriaObjectForTi(ti, obj, proc);
				if obj &lt;&gt; null then
					critString := obj.getYADisplay();
					idx := 1;
					critString.scanUntil(Tab, idx);
					if idx &gt; 1 then
						critString := critString[1:idx-1];
					endif;
				else
					critString := null;
				endif;
			endif;
			dataString := dataString &amp; critString &amp; Tab;
		endforeach;
		
		newRow := self.tblSelectedCargo.addItem(dataString);
		self.tblSelectedCargo.accessRow(newRow).itemObject := ti;
	endforeach;
	
	self.lblCargoCount.caption := self.allTrackedItems.size.String &amp; " Cargo Items Selected";
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuRemoveSelected_click" id="ae77252f-9ca8-43a5-86ec-bc2952d9bf6c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRemoveSelected_click(menuItem: MenuItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars

begin
	self.doRemoveSelected();
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postCreateProposed" id="8bab211e-b49f-4475-a370-b5d56a6aef24">
        <updating/>
        <source>postCreateProposed(_candidates : ObjectSet) updating;
//
// Purpose:			Disable the rows in the "Proposed" table when yard allocations successfully created
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 100/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars
	obj : Object;
	row : Integer;

begin
	foreach obj in _candidates do
		// See if we can find this object in the table
		row := 1;
		if self.tblProposed.findObjectInRow(obj, row) then
			// Found it? Disable the row so it can't be selected again
			self.tblProposed.accessRow(row).enabled := false;
			self.tblProposed.accessRow(row).selected := false;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_candidates" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0130f157-d187-4a20-baa0-4f0364a30e25">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	config : CM_YAConfig;
	ti : CM_TrackedItem;

begin
	// Set minimum height/width
	self.minimumHeight := 650;
	self.minimumWidth := 1100;
	
	self.toolbarStyle := self.ToolbarStyle_None;
	self.showToolbar := false;
	
	inheritMethod();
	
	config := self.myTerminal.myYAConfig;
	config.allDefaultBulkCriteriaTypes.copy(self.allCriteriaTypes);
	
	self.setupSelectedTable();
	self.setupMatchesTable();
	self.setupProposedTable();
	self.loadSelectedTable();
	
	self.btnCalculate.setFocus;
	
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_BulkYAProgress), Response_Continuous, 0);
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_BulkYAFailed), Response_Continuous, 0);
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_BulkYAComplete), Response_Continuous, 0);
	foreach ti in self.allTrackedItems do
		beginNotification(ti, Object_Update_Event, Response_Continuous, null);
	endforeach;
	
	// Listen for deleted yard allocations as well
	self.beginClassNotification(CM_YardAllocation, false, Object_Delete_Event, Response_Continuous, 0);
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCalculate.enabled := false;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		self.lblVoyageDetails.caption := self.myVoyage.code &amp; " - " &amp; self.myVoyage.vesselName;
	else
		self.lblVoyageDetails.caption := null;
	endif;
	self.lblBGPProgress.caption := null;
	
	self.btnConfigure.enabled := app.myPassport.myUser.canDo(self.myTerminal, PmAdmYAConfigMaint);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMatchesTable" id="8cd2eef2-fb9d-40fe-8d8d-b1389066171c">
        <source>setupMatchesTable() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	matches : CM_ViewTable;

begin
	matches := self.tblMatches;
	matches.rows := matches.fixedRows;
	matches.gridLines := false;
	matches.columns := 3;
	matches.columnWidth[1] := 15;
	matches.columnWidth[2] := 200;
	matches.columnWidth[3] := matches.clientWidth - 215;
	matches.multiSelect := CM_ViewTable.MultiSelect_Simple;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupProposedTable" id="013ee8bd-3665-4b59-9c6d-323edab44ebb">
        <updating/>
        <source>setupProposedTable() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars
	table : CM_DataTable;
	header : String;

begin
	table := self.tblProposed;
	
	table.rows := table.fixedRows;
	table.columns := 7;
	table.selectMode := Table.SelectMode_WholeRows;
	
	header := app.getErrorString(Allocation) &amp; Tab &amp;
				app.getErrorString(Criteria) &amp; Tab &amp;
				app.getErrorString(Matching_Cargo) &amp; Tab &amp;
				app.getErrorString(Existing) &amp; QuestionMark &amp; Tab &amp;
				app.getErrorString(Priority) &amp; Tab &amp;
				app.getErrorString(Capacity) &amp; Tab &amp;
				app.getErrorString(CargoItems);
	table.accessCell(1, 1).text := header;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSelectedTable" id="80553002-2556-428f-a73f-dcdf5c92d421">
        <updating/>
        <source>setupSelectedTable() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars
	table : CM_BaseTable;
	headings : String;
	type : CM_YACriteriaType;
	typeCount : Integer;

begin
	table := self.tblSelectedCargo;
	table.rows := table.fixedRows;
	
	headings := app.getErrorString(Cargo_ID) &amp; Tab &amp; 
				app.getErrorString(CM_Cargo_Type) &amp; Tab &amp; 
				app.getErrorString(Product) &amp; Tab &amp; 
				app.getErrorString(Operator) &amp; Tab &amp; 
				app.getErrorString(Imex_status) &amp; Tab &amp; 
				app.getErrorString(Location) &amp; Tab;
	foreach type in self.allCriteriaTypes do
		// Ignore any duplicates from above
		if type.isDefaultForBulkYAs() then
			continue;
		endif;
		
		headings := headings &amp; type.description &amp; Tab;
		typeCount += 1;
	endforeach;
	
	table.columns := 6 + typeCount;
	table.accessCell(1, 1).text := headings;
	table.multiSelect := CM_BaseTable.MultiSelect_Simple;
	table.selectionType := CM_DataTable.SelectionType_Row;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="d2c95a0b-5023-4c27-b605-cc3ba4560dc7">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/08/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	if eventType = Object_Delete_Event and theObject.isKindOf(CM_YardAllocation) then
		self.handleDeletedYardAllocation(theObject.CM_YardAllocation);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMatches_click" id="21ce1220-43e9-4ecf-a6c9-e6e84dbac9be">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMatches_click(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2025	navdap1		Initial creation MTN-35617 ENS | Bulk Creation of Yard Allocations 
//
vars

begin
	if table.accessRow(table.row).itemObject = null then
		// do nothing
		table.accessedRow.selected := false;
		return;
	endif;
	
	table.CM_ViewTable.selectTheCurrentRow(table);
	if table.column = table.cnEcFirstColumn() then
		// Expand / contract the lines underneath
		self.expandContractMatches(table.row);
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMatches_dblClick" id="629c3261-ece4-4da5-a20c-86862771c10c">
