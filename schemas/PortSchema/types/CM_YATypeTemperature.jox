    <JadeMethod name="getCriteriaValueForTi" id="60880d42-9aca-4006-8f45-d9a041aeba1d">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	_criteriaValue := _ti.getRequiredTemperature();
epilog

end;</source>
