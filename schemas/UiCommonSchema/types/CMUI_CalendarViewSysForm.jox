    <JadeMethod name="setupForm" id="8d033b28-6296-437c-bd01-84d32a433322">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2011	cnwndl1	Initial creation	Par 27946 

*/

vars

begin

	inheritMethod();
	
	self.btnCalendar.enabled :=  (app.myCurrentUserCan(null, PmAdmCalendarMaint));	// extra security required to maintain calendars globally...
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="db7d79dc-40a1-421d-9539-4c9e3fa6a33d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015983, locale);
end;</source>
    </JadeMethod>
</GUIClass>
