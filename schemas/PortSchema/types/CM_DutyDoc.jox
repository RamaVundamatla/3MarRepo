    <JadeMethod name="getFOBvalue" id="027b8897-d5da-4ffb-97af-9f1c62c1f37a">
        <source>getFOBvalue( _items : CM_DutyDocItemSet ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2013	cnwndl1	Initial creation	Par 33229

*/

vars

	decimal : Decimal [16,4];
	item : CM_DutyDocItem;

begin

	if _items &lt;&gt; null then
		foreach item in _items do
			decimal := decimal + ( item.foreignValue * item.currencyRate );
		endforeach;
	endif;

epilog

	return decimal;

end;</source>
