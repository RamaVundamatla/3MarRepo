<Class name="WS_CargoCheck" id="530a9112-1c97-4c9e-a10e-af01e524d669">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Cargo Check Item describes the checks that have been performed on a cargo item.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="context" id="03db8c5d-a9fd-48c0-8e7b-3ec0db824699">
