    <JadeMethod name="setupForm" id="b8e8c334-31ac-45bc-98a1-ac27018dc61b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
20 March 2024		navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
08 April 2024		navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	ti 			: CM_TrackedItem;
	readOnly 	: Boolean;
begin
	ti := self.myTrackedItem;
	
	inheritMethod();
	
	self.frmMain.top			:= 250;
	self.frmMain.left			:= 10;
	self.frmMain.width			:= self.clientWidth - 20;
	self.frmMain.parentAspect	:= 0;
	
	self.btnAdd.enabled := false;
	
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	
	self.btnOk.visible := true;
	
	self.resizeTable(self.tblData);
	
	self.initEntTable(self.tblData, ETDef_CustomsReferences);
	
	self.setCaption(app.getErrorString(Customs_references) &amp; " for " &amp; ti.id);
	
	if self.mode &lt;&gt; self.Mode_View then
		readOnly := true;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) or readOnly then
		self.btnOk.visible := false;
		self.btnNew.enabled := false;
	endif;
	
	if self.allProxyCustomsRefs.isEmpty then
		self.frmControls.enabled := false;
	endif;
	
	self.txtPosNum.enabled := false;
	self.txtRefType.enabled := false;
	self.txtRefNum.enabled := false;
	
	self.hasChanged := false;
epilog

end;</source>
    </JadeMethod>
