<GUIClass name="MOB_CompleteMasterPackForm" id="18ff1888-6aa1-439c-8553-012def1b4443">
    <superclass name="MOB_TwoEntryModalForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="setupForm" id="854842f8-3a9b-4b40-a552-dc0feacf2b5e">
        <updating/>
        <source>setupForm() updating, protected;

vars

begin
	inheritMethod();
	self.lbl_Input3.caption := "Confirm Pack ID";
	if self.myTrackedItem &lt;&gt; null then
		self.txt_Input3.text := self.myTrackedItem.id;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2e0b2979-e3ea-410f-ab48-1a067b8aa5a2">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018478, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
