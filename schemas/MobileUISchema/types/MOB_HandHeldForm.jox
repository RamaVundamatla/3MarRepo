    <JadeMethod name="resizeCmdButtons" id="6fe6d06a-2db4-4840-9ca1-273c51ac7e09">
        <updating/>
        <source>resizeCmdButtons() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	btnWidth : Real;
	btnHeight : Real;
	btnTop : Real;
	evenlySpace : Integer;
	left2 : Real;
	left3 : Real;
	left4 : Real;
	left5 : Real;

begin

	btnWidth := 100;
	btnHeight := self.getCMDButtonsHeight();
	btnTop := self.clientHeight - btnHeight - self.resizedMargin;

	if self.btnFive.visible then
		if self.clientWidth &gt; ( 6 * self.resizedMargin ) then
			btnWidth := ( self.clientWidth - ( 6 * self.resizedMargin )) / 5;
		endif;
	elseif self.btnFour.visible then
		if self.clientWidth &gt; ( 5 * self.resizedMargin ) then
			btnWidth := ( self.clientWidth - ( 5 * self.resizedMargin )) / 4;
		endif;
	elseif self.btnThree.visible then
		if self.clientWidth &gt; ( 4 * self.resizedMargin ) then
			btnWidth := ( self.clientWidth - ( 4 * self.resizedMargin )) / 3;
		endif;
	elseif self.btnTwo.visible then
		if self.clientWidth &gt; ( 3 * self.resizedMargin ) then
			btnWidth := ( self.clientWidth - ( 3 * self.resizedMargin )) / 2;
		endif;
	elseif self.btnOne.visible then
		if self.clientWidth &gt; ( 2 * self.resizedMargin ) then
			btnWidth := ( self.clientWidth - ( 2 * self.resizedMargin )) / 1;
		endif;
	endif;
	
	if btnWidth &gt; 4 * btnHeight then
		btnWidth := 4 * btnHeight;
	endif;
	
	//17 Feb 2017	NDL	TFS 3387/3006
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(HhSpreadButtons).Boolean then
		if self.btnTwo.visible then
			evenlySpace := 2;
			if self.btnThree.visible then
				evenlySpace := 3;
				if self.btnFour.visible then
					evenlySpace := 4;
					if self.btnFive.visible then
						evenlySpace := 5;
					endif;
				endif;
			endif;
		endif;
		if evenlySpace = 2 then
			left2 := self.resizedMargin;
		elseif evenlySpace = 3 then
			left2 := ( self.clientWidth - btnWidth ) / 2;
			left3 := self.resizedMargin;
		elseif evenlySpace = 4 then
			left2 := ( self.clientWidth - btnWidth ) * (2 / 3);
			left3 := ( self.clientWidth - btnWidth ) * (1 / 3);
			left4 := self.resizedMargin;
		elseif evenlySpace = 5 then
			left2 := ( self.clientWidth - btnWidth ) * (3 / 4);
			left3 := ( self.clientWidth - btnWidth ) * (2 / 4);
			left4 := ( self.clientWidth - btnWidth ) * (1 / 4);
			left5 := self.resizedMargin;
		endif;
		
	endif;

	if self.btnOne.visible then
		self.btnOne.width := btnWidth;
		self.btnOne.height := btnHeight;
		self.btnOne.top := btnTop;
		self.btnOne.left := self.clientWidth - self.resizedMargin - btnWidth;
		if self.btnTwo.visible then
			self.btnTwo.width := btnWidth;
			self.btnTwo.height := btnHeight;
			self.btnTwo.top := btnTop;
			if left2 &gt; 0 then
				self.btnTwo.left := left2;
			else
				self.btnTwo.left := self.btnOne.left - self.resizedMargin - btnWidth;
			endif;
			if self.btnThree.visible then
				self.btnThree.width := btnWidth;
				self.btnThree.height := btnHeight;
				self.btnThree.top := btnTop;
				if left3 &gt; 0 then
					self.btnThree.left := left3;
				else
					self.btnThree.left := self.btnTwo.left - self.resizedMargin - btnWidth;
				endif;
				if self.btnFour.visible then
					self.btnFour.width := btnWidth;
					self.btnFour.height := btnHeight;
					self.btnFour.top := btnTop;
					if left4 &gt; 0 then
						self.btnFour.left := left4;
					else
						self.btnFour.left := self.btnThree.left - self.resizedMargin - btnWidth;
					endif;
					if self.btnFive.visible then
						self.btnFive.width := btnWidth;
						self.btnFive.height := btnHeight;
						self.btnFive.top := btnTop;
						if left5 &gt; 0 then
							self.btnFive.left := left5;
						else
							self.btnFive.left := self.btnFour.left - self.resizedMargin - btnWidth;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBulkWeightVolumeFields" id="9611bf39-91dc-474f-a21b-98b79e87c5c4">
        <source>setBulkWeightVolumeFields(	 _ti : CM_TrackedItem; 
							_measureTbl : CMUI_MeasurementTable input;
							_lbl : MOB_Label input;
							_setValue : Decimal //in JMT units, i.e. kgs or m3
							);
/*

Purpose:			

Parameters:			This is for Bulk stuff, where we use teh same measurement table to capture either teh volume or the
					weight values for a tracked item

Return Value:		

Date		Who		Reason
03 April 2014	cnwndl1	Initial creation	CCMS 1366

*/

vars

	weightStr : String;
	volumeStr : String;
	measureType : CM_MeasurementType;

begin

	if _ti &lt;&gt; null then
		if _ti.isBulkByWeight then
			measureType := _ti.myCargoType.getMeasurementTypeFor( Type_Weight, true );
			if _measureTbl &lt;&gt; null then
				_measureTbl.visible := true;
				_measureTbl.setup(Type_Weight, _measureTbl.backColor);
				_measureTbl.setValues(app.convertMeasurementForDisplay(measureType.shortName, _setValue) &amp; Space &amp; measureType.shortName);
			endif;
			if _lbl &lt;&gt; null then
				_lbl.visible := true;
				weightStr := app.convertMeasurementForDisplay(measureType.shortName, _ti.totalWeight) &amp; " " &amp; measureType.shortName;
				_lbl.caption := weightStr;
			endif;
			
		elseif _ti.isBulkByVolume then
			measureType := _ti.myCargoType.getMeasurementTypeFor( Type_Volume, true );
			if _measureTbl &lt;&gt; null then
				_measureTbl.visible := true;
				_measureTbl.setup(Type_Volume, _measureTbl.backColor);
				_measureTbl.setValues(app.convertMeasurementForDisplay(measureType.shortName, _setValue) &amp; Space &amp; measureType.shortName);
			endif;
			if _lbl &lt;&gt; null then
				_lbl.visible := true;
				volumeStr := app.convertMeasurementForDisplay(measureType.shortName, _ti.totalVolume) &amp; " " &amp; measureType.shortName;
				_lbl.caption := volumeStr;
			endif;
			
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_measureTbl" type="CMUI_MeasurementTable" usage="input"/>
        <Parameter name="_lbl" type="MOB_Label" usage="input"/>
        <Parameter name="_setValue" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMenuScrollStart" id="c57beb8a-5950-4e8a-a5f2-2091fad540c7">
        <updating/>
        <source>setMenuScrollStart( _scroll: ScrollBar; _btnTemplate : MOB_Button; _frame : MOB_Frame; _size : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	index : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	position : Integer;
	scroll : ScrollBar;
	buttonHeight : Integer;

begin

	if not _scroll.visible then
		//everything is already visible, no need to scroll
		return;
	endif;

	scroll := _scroll;
	position := scroll.value;
	if self.isKindOf(MOB_HandHeldMenuForm) then
		buttonHeight := self.getCMDButtonsHeight();
	else
		buttonHeight := self.getScrollingButtonHeight();
	endif;
	
	if position &gt; scroll.max then
		position := scroll.max;
	elseif position &lt; scroll.min then
		position := scroll.min;
	endif;
	
	scroll.value := position;
	buttonOffset := - position;
	
	if _size = 0 then
		return;
	endif;
	
	foreach index in 1 to _size do
		menuButton := _btnTemplate.getControl(index).MOB_Button;
		if menuButton = null then
			break;
		endif;
		
		if buttonOffset &lt; _frame.height-6 or (buttonOffset + buttonHeight - self.resizedMargin) &gt; 0 then
			menuButton.move(0, buttonOffset, menuButton.width, menuButton.height );
		endif;
		
		menuButton.visible := true;
		buttonOffset := buttonOffset + buttonHeight + self.resizedMargin;
		
	endforeach;
	
	
	_frame.setFocus();
	
epilog

end;</source>
        <Parameter name="_scroll" type="ScrollBar"/>
        <Parameter name="_btnTemplate" type="MOB_Button"/>
        <Parameter name="_frame" type="MOB_Frame"/>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="6bc1d9eb-f8d4-4206-ae61-327008d186d6">
        <source>setNotifications();
