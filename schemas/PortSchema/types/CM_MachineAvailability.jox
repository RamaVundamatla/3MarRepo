    <JadeMethod name="pxyCreateUpdateProxy" id="00d5a5bd-1fc7-46e7-92fb-b9ce44ad70f0">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyMachineAvailability:CM_MachineAvailability;
	completedOK		: Boolean;
	
begin

	proxyMachineAvailability := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyMachineAvailability;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyMachineAvailability;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2bd2a811-95c8-4960-8cc0-e3d5b2ebd621">
        <updating/>
        <source>setForCreate(pProxyMachineAvailability:CM_MachineAvailability) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyMachineAvailability.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyMachineAvailability);
	self.myRoot := app.myRoot; //+ cnwmd1 Par 22197

end;</source>
        <Parameter name="pProxyMachineAvailability" type="CM_MachineAvailability"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="41cd54ee-130b-42e7-8095-87dda8f9fd50">
        <updating/>
        <source>setForUpdate(pProxyMachineAvailability:CM_MachineAvailability) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.code := pProxyMachineAvailability.code.trimBlanks;
	self.description := pProxyMachineAvailability.description.trimBlanks;

end;</source>
        <Parameter name="pProxyMachineAvailability" type="CM_MachineAvailability"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="3215c5b8-1449-47e4-92d9-cb7cae795122">
