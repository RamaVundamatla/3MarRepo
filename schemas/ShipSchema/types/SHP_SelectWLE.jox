    <JadeMethod name="setCollections" id="5fb90183-d147-47bb-a90e-1862b803988b">
        <updating/>
        <source>setCollections(_available : CM_TIArray; _selected : CM_TIArray) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	_available.copy(self.allAvailableTIs);
	_selected.copy(self.allOriginalTIs);
	// these are all the TIS on the slot controller
	self.msgCargo.setAvailable(self.allAvailableTIs,true);
	self.msgCargo.setSelected(self.allOriginalTIs);
end;</source>
        <Parameter name="_available" type="CM_TIArray"/>
        <Parameter name="_selected" type="CM_TIArray"/>
    </JadeMethod>
