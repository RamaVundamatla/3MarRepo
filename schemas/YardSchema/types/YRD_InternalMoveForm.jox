    <JadeMethod name="txtNumRequested_hasLostFocus" id="405b8466-b7fc-4838-b0f8-e9baaeaa7bb2">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtNumRequested_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
//14 September 2010	cnwml2
//+cnwml2 PAR25730

vars
	releaseItem : CM_ReserveSelection;

begin
	releaseItem := self.cmbReleaseItem.getObject().CM_ReserveSelection;
	if releaseItem &lt;&gt; null then
		if self.txtNumRequested.getString.Integer &gt;= releaseItem.totalRequested or self.txtNumRequested.getString = null then
			self.txtNumRequested.setValue(releaseItem.totalRequested ); 
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
