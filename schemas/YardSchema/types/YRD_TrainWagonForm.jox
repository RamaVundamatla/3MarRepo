    <JadeMethod name="handleNotifications" id="0f2bdf34-d3bf-4828-99c1-f3d87524d18e">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 June 2009	cnwmd1	Initial creation
12 Oct 2016		cnwrs1	TFS 2829 Cams processing failure with Train Events
01 Jul 2023		jlizm1	TFS 59215 Wagon maintenance notifications
*/

vars
	reloadWagons : Boolean;
	rowIdx : Integer;
	selectedWagons : CM_WagonSet;
//	theWagon : CM_Wagon;
	invalidObject : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);
	
	if eventType = self.myTerminal.getTerminalEvent(Wagon_Delete_Event) then
		if self.myCurrentWagon = theObject then
			if self.mode = self.Mode_View then
				app.msgBox(app.getErrorString(Anoth_user_delet_wag_that_cu_v),app.getErrorString(Wagon_deleted), MsgBox_Information_Icon);
			else //must be editing
				app.msgBox(app.getErrorString(Anoth_user_delet_wagon_curre_e), app.getErrorString(Wagon_deleted), MsgBox_Information_Icon);
			endif;
			self.buildComboWagon();
			self.myCurrentWagon:= null;
			self.clearControls();
			self.setControlsForAddEditDelete(false);
		else
			self.buildComboWagon();
		endif;
		
		return;
	endif;	

	str := theObject.creationTime.String;
	if invalidObject then
		return;
	endif;
	
	//handle getting a Wagon
	//if eventType = Object_Create_Event and self.mode = self.Mode_View and CM_Wagon.hasInstance(theObject) then //- cnwmd1, CCMS 1067, Par 19913
	if eventType = self.myTerminal.getTerminalEvent(Wagon_Create_Event) and CM_Wagon.hasInstance(theObject) then //+ cnwmd1, CCMS 1067, Par 19913 - Allow for updating the wagon combo anytime.
		if self.cmbWagon.findObject(theObject.CM_Wagon) = -1 then
			self.cmbWagon.itemObject[self.cmbWagon.addItem(theObject.CM_Wagon.getDisplayDetails(false))] := theObject.CM_Wagon;
		endif;

	elseif eventType = self.myTerminal.getTerminalEvent(Wagon_Update_Event) and self.myCurrentWagon = theObject then
		if self.mode = self.Mode_View then
			self.doWagonDisplay(false);
			self.loadCargo(self.optDirInTB.value);
		else //must be editing
			if not self.mode = Mode_Updating then
				if app.msgBox(app.getErrorString(Anoth_user_updat_this_wagon_wa), app.getErrorString(Wagon_updated), MsgBox_Yes_No + MsgBox_Information_Icon) &lt;&gt; MsgBox_Return_Yes then
					return;
				else
					self.doWagonDisplay(false);
					self.loadCargo(self.optDirInTB.value);
				endif;
			else
				self.mode := Mode_Update;
			endif;
		endif;
		
	elseif eventType = Wagon_Update_Cargo_Event then //handle cargo changes
		if self.myCurrentWagon = theObject then
			self.loadCargo(self.optDirInTB.value);
		endif;
	endif;
	
epilog
	endLoad;
end;


</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
