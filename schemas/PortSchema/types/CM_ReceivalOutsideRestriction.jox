    <JadeMethod name="getDisplayStringForAttribute" id="86be9a55-a4d3-4efe-a479-2e34d851384d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 Jun 2010		cnwndl1	Initial creation	Par 23498
01 Apr 2012 	cnwer1	PAR 29487 - more information so we can tell why transaction was created i.e. before earliest or after the cut-off
13 March 2025	navlw1	JIRA-34229: MTN | Prenote Voyage Cut Offs - Cutoff Transaction Changes
*/

vars
	
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.cutoffReceival &lt;&gt; null then
				// Start #JIRA-34229 navlw1 13/05/2025
				if self.dateTime &gt; self.cutoffDateTimePN then
					return app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.cutoffDateTimePN.asStringJMT);
				else 
					return app.getErrorString4(Receive_before_voyage_earliest,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.earliestDateTimePN.asStringJMT);
				endif;
				// End #JIRA-34229 navlw1 13/05/2025
				if self.dateTime &gt; self.cutoffTS then
					return app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.cutoffTS.asStringJMT);
				else
					return app.getErrorString4(Receive_before_voyage_earliest,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.earliestTS.asStringJMT);
				endif;
			endif;
			
			if self.myReceivalRestriction &lt;&gt; null then
			// created before earliestTS and cutoff were recorded have no way of knowing why transaction was created
				return app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.myReceivalRestriction.code,null);
			endif;	
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="a00bfe4c-d141-4f02-bc2c-e08ab75bb1d8">
        <source>getEnquiryRow(): String;

/*
Date			Who		Reason
29 May 2009		cnwar2	Initial creation
13 March 2025	navlw1	JIRA-34229: MTN | Prenote Voyage Cut Offs - Cutoff Transaction Changes

*/
vars
	lDetail 	: String;
	lInvalidBR 	: Boolean;
	lReturn		: String;
	
begin
	lDetail := inheritMethod();
	
	if self.cutoffReceival &lt;&gt; null then
		// Start #JIRA-34229 navlw1 13/05/2025
		if self.dateTime &gt; self.cutoffDateTimePN then
			return lDetail &amp; app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.cutoffDateTimePN.asStringJMT);
		else 
			return lDetail &amp; app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.earliestDateTimePN.asStringJMT);
		endif;
		// End #JIRA-34229 navlw1 13/05/2025
		if self.dateTime &gt; self.cutoffTS then
			return lDetail &amp; app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.cutoffTS.asStringJMT);
		else
			return lDetail &amp; app.getErrorString4(Receive_before_voyage_earliest,self.dateTime.asStringJMT,self.voyageCode,self.cutoffReceival,self.earliestTS.asStringJMT);
		endif;
	
	endif;
	
	if self.myReceivalRestriction &lt;&gt; null then
		lDetail := lDetail &amp;  app.getErrorString4(Receive_after_voyage_cutoff,self.dateTime.asStringJMT,self.voyageCode,self.myReceivalRestriction.code,null);
	endif;
	return lDetail;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="406f469a-3fe6-4b35-86f6-e161d0df676c">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;

/*
Date		Who		Reason
29 May 2009	cnwar2	Initial creation

*/
vars

begin
	
	
	inheritMethod(_tiTransCntrl, _passport);
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myReceivalRestriction := self.myTrackedItem.getReceivalCutoff;
	
	if self.myTrackedItem.isPreNote() then //04/03/2025	navkc1 JIRA Story MTN-34227
		self.myTrackedItem.getReceivalCutoffDetailsPN(self.cutoffReceival,self.earliestDateTimePN,self.cutoffDateTimePN);
	else
		self.myTrackedItem.getReceivalCutoffDetails(self.cutoffReceival,self.earliestTS,self.cutoffTS);
	endif;
		
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
