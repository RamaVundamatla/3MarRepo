    <JadeMethod name="setProxy" id="255088f2-dc81-4027-a3b7-74330a668cd5">
        <updating/>
        <source>setProxy(_direction				: Integer; 
		 _booking				: CM_BookingRef; 
		 _bookingItem			: CM_BookingRefItem; 
		 _bulkRelease			: CM_BulkRelease;
		 _reserveDetail			: CM_ReserveDetail; 
		 _trackedItem			: CM_TrackedItem; 
		 _vehicleBookingSlot	: CM_VehicleBookingTimeSlot;
		 _quantity,
		 _sequence,
		 _sourceType			: Integer; 
		 _weight,
		 _volume,
		 _maxWeight				: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
02 June 2023	navpw1	TFS: 58256 - Added volume to time slot item
11 July 2024	navpw1	TFS: 61525 (61527) - Added Max Weight Field

*/

begin
	self.direction				:= _direction;
	self.myBooking				:= _booking;
	self.myBookingItem			:= _bookingItem;
	self.myBulkRelease			:= _bulkRelease;
	self.myReserveDetails		:= _reserveDetail;
	self.myTrackedItem			:= _trackedItem;
	self.myVehicleBookingSlot	:= _vehicleBookingSlot;
	self.quantity				:= _quantity;
	self.sequence				:= _sequence;
	self.sourceType				:= _sourceType;
	self.weight					:= _weight;
	self.volume					:= _volume;		// ### TFS 58256 02Jun2023 NAVPW1
	self.maxWeight				:= _maxWeight;	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_vehicleBookingSlot" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_sourceType" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="26876cdb-64cc-4b0e-a4ea-0955d8883a53">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
15 Aug 2023	navma1	ChangeRequest 59875: EUP | VBS - Add Created by user code

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_VehicleBookingTimeSlotItem::direction.name or
		propName = CM_VehicleBookingTimeSlotItem::myBooking.name or
		propName = CM_VehicleBookingTimeSlotItem::myBookingItem.name or
		propName = CM_VehicleBookingTimeSlotItem::myBulkRelease.name or 
		propName = CM_VehicleBookingTimeSlotItem::myReserveDetails.name or 
		propName = CM_VehicleBookingTimeSlotItem::myTrackedItem.name or 
		propName = CM_VehicleBookingTimeSlotItem::myVehicleBookingSlot.name or 
		propName = CM_VehicleBookingTimeSlotItem::quantity.name or 
		propName = CM_VehicleBookingTimeSlotItem::sequence.name or
		propName = CM_VehicleBookingTimeSlotItem::sourceType.name or
		propName = CM_VehicleBookingTimeSlotItem::volume.name or
		propName = CM_VehicleBookingTimeSlotItem::weight.name or 
		propName = CM_VehicleBookingTimeSlotItem::createdUserCode.name				//17.08.2023 navma1 #59875
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
