    <JadeMethod name="deleteRequest" id="2796ac68-0083-4c40-a999-ce011a2f2c75">
        <source>deleteRequest(_ti : CM_TrackedItem; _requests : CM_RequestSet io);
/*

Purpose:	Read through YardJob / Bulk Release	requests collection and 
			remove required CM_TIREequests

Date		Who		Reason
09/05/2014	cnwmh5	Initial creation

*/

vars

	request 				: CM_Request;
	bulkRelease				: CM_BulkRelease;
	terminal				: CM_Terminal;
	
	iter					: Iterator;
	
	ts						: TimeStamp;

begin

	terminal := self.getTerminal();

	///if not process.isInTransactionState then
		beginTransaction;
	///endif;
	foreach request in _requests do
		if request.isKindOf(CM_TIRequest) then
			if request.CM_TIRequest.trackedItem = _ti then
				if request.CM_TIRequest.deliveryNumber &lt;&gt; null then
					delete iter;
					ts := null;
					iter := terminal.allBulkReleasesByCodeDate.createIterator;
					terminal.allBulkReleasesByCodeDate.startKeyLeq(request.CM_TIRequest.deliveryNumber, ts, iter);
					while iter.back(bulkRelease) do
						if bulkRelease.code &lt;&gt; request.CM_TIRequest.deliveryNumber then
							break;
						endif;
						bulkRelease.requests.copyNoDups(_requests);
					endwhile;
				endif;
				delete iter;
				request.erase(FORCED_ERASE);
			endif;
		elseif request.isKindOf(CM_DeliveryRequest) then						// 16/05/2014 cnwmh5
			request.erase(NORMAL_ERASE);
		endif;
	endforeach;
	_requests.removeInvalidObjects();
	commitTransaction;
	
	if _requests.isEmpty() then
		if _ti &lt;&gt; null then
			self.deleteReleaseRequest(_ti.deliveryRelease);
		endif;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_requests" type="CM_RequestSet" usage="io"/>
    </JadeMethod>
