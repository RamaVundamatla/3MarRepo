    <JadeMethod name="setQuantityRange" id="86f1c580-71c3-4348-86d7-d725eab6e3ef">
        <updating/>
        <source>setQuantityRange(_qrm : CM_QuantityRangeMap) updating;
// ---------------------------------------------------------------------------
// Created:		12 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		// TFS 37852
//
// ---------------------------------------------------------------------------
vars
	zero : Boolean;
	calctype : CM_CalculationType;
begin
	if _qrm = null then
		self.quantityRangeStart := 0;
		self.quantityRangeEnd := 0;
		self.quantityRangeZero := false;
		self.quantityRangeCalc := 0;// TFS 38113
	
	else
		zero := (_qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single and _qrm.myQuantityMap.chargeZero);
	
		self.quantityRangeStart := _qrm.rangeStart;
		self.quantityRangeEnd := _qrm.rangeEnd;
		self.quantityRangeZero := zero;
		
		self.quantityRangeCalc := 0;// TFS 38113
		calctype := _qrm.getCalcType();// TFS 38113
		if calctype &lt;&gt; null then// TFS 38113
			self.quantityRangeCalc := calctype.calculationType;// TFS 38113
		endif;// TFS 38113
	endif;
end;</source>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="setQuantityToHMSResoureQty" id="4284305b-2981-4c3b-b7b7-28d7d78c3932">
        <updating/>
        <source>setQuantityToHMSResoureQty() : Real updating;
// ---------------------------------------------------------------------------
// Created:		15 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//				May 2012 CCMS 1264 save original resource value in .quantityNoMinMax
// ---------------------------------------------------------------------------

vars
	tmpQty : Real;
	diffMin	: Integer;
	calcType	: CM_CalculationType;
	resourceUsed	: HMS_ResourceUsed;
begin
	if self.myTransactionHMS &lt;&gt; null then
		if self.myTransactionHMS.myResourceUsed &lt;&gt; null then
			resourceUsed := self.myTransactionHMS.myResourceUsed;
			tmpQty := resourceUsed.unitsUsed;
			if tmpQty = 0 then
				tmpQty:= 1;
				// 35339 date range processing
				calcType := self.invoiceLineDesc.myCalculationType;
				if calcType &lt;&gt; null and
				   calcType.requiresDateRange and
				   resourceUsed.fromDateTime.isValid and
				   resourceUsed.toDateTime.isValid then				   
					diffMin := (resourceUsed.toDateTime.cnEcDiff(resourceUsed.fromDateTime) / MillisecondsPerMinute).Integer;
					tmpQty := calcType.getNumHourBlocks(diffMin, true, null);
				endif;
			endif;
		else
			tmpQty := 1;
		endif;
	endif;
	
	self.quantity := tmpQty;
	
	return tmpQty;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
