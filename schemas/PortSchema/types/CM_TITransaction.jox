/*
----------   ----------  --------------------------------------------------
Created:	15 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str : String;
begin
	return self.getExtraData(TrnsExtraDataComment);	
end;
</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getFreightTons" id="520cb339-efd7-41f8-afbb-abc9ea565631">
        <source>getFreightTons() : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 December 2019	jlgzm1	Initial creation TFS 47944 STWO - Fields on merged cargo zero on exported invoices

*/

vars
	ftWeight : Real;
	ftVolume : Real;
begin
	ftWeight := self.totalWeight/1000;
	ftVolume := self.totalVolume;
	
	if ftVolume &gt; ftWeight then
		return ftVolume;
	else
		return ftWeight;
	endif;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
