    <JadeMethod name="deleteLogDocketData" id="35b1148f-cf1a-4714-8d8e-f56240c6365f">
        <updating/>
        <source>deleteLogDocketData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	logDocketData			: CM_LogDocketData;
	sht					: GTE_Sheet;
	sheetIdx			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	logDocketData := self.tblLogDocketData.accessRow(self.tblLogDocketData.row).itemObject.CM_LogDocketData;
	
	if logDocketData = null then
		app.msgBox('Please select a Log Docket Data item to delete first.', ' Nothing selected', 0);
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteLogDocketData(logDocketData, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.doLoadLogDocketData();
			break;
		else
			theResult := app.showErrorWarningDialog('Delete Log Docket Data', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteSheet" id="c1551ed4-d476-44a3-9bea-ef3d922bcc04">
        <updating/>
        <source>deleteSheet(pSheet : GTE_Sheet io) updating;

vars
	contFrm		: GTE_ContainerFrame;
begin

	// clear any container attached to this sheet
	foreach contFrm in pSheet.allContainerFrames do
		contFrm.clearDetails();
	endforeach;
	
	self.notifySheetDelete(pSheet);

	if pSheet = self.myGTESheetRequiresRefresh then	//PAR 23408 22/04/2010
		self.myGTESheetRequiresRefresh := null;
	endif;
	
	delete pSheet;
	
	if fldInOut.sheets &lt;= 2 then
		btnDeleteCurrent.enabled := false;
		btnSaveBase.enabled := false;
	endif;
	
	self.fldInOut.initSheetBackColors();

	self.setBtnRefresh();	//PAR 23408 22/04/2010
	
end;</source>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doActionJob" id="f59f1d18-4c1a-4080-b80c-6346e8d6aef4">
        <source>doActionJob() protected;
// ---------------------------------------------------------------------------
// Created:     16 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Removed redundant code

*/

vars
	reserve : CM_ReserveDetail;
	objHolder : CM_Object;

begin
	if self.fldLeft.topSheet = self.shtJobs then
		if self.tblBulkRelease.row &gt; self.tblBulkRelease.fixedRows and self.tblBulkRelease.accessRow(self.tblBulkRelease.row).selected then
			//PAR16823 cnwsh3 27/5/2008  We are now loading the table with reserve details from self.fillTblJobs
			objHolder := self.tblBulkRelease.accessRow(self.tblBulkRelease.row).itemObject.CM_Object;
			if objHolder &lt;&gt; null then  //just to be extra self
				if objHolder.isKindOf(CM_ReserveDetail) then  //par 19561
					reserve := objHolder.CM_ReserveDetail;
					self.addFromReserveDetail(reserve);
					return;
				endif;
			endif;
		endif;
		
		app.msgBox('You must select a bulk release to action', 'Nothing Selected', MsgBox_OK_Only);
		
	elseif self.fldLeft.topSheet = self.shtLogDocketData then
		self.doLogDocketDataPrefill(null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActionTransfer" id="c8b03d6f-75e2-460f-81e4-66f4ba8116ee">
        <source>doActionTransfer() protected;
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
begin
	
	if self.tblTransfers.row &gt; self.tblTransfers.fixedRows 
	and self.tblTransfers.accessRow(self.tblTransfers.row).selected then
		ti := self.tblTransfers.accessRow(self.tblTransfers.row).itemObject.CM_TrackedItem;
		if global.isValidObject(ti) then
			self.addFromInterTerminalTI(ti);
		endif;
		return;
	endif;
	app.msgBox('You must select a inter-terminal transfer to action', 'Nothing Selected', MsgBox_OK_Only);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="51c7bf7c-39a3-4b03-8878-52a73f2ecb59">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	15 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	numCntrls,
	numSheets	: Integer;
	cnt			: Integer;
	cntl		: Control;
begin
	inheritMethod();

	numCntrls := self.controlCount;

	foreach cnt in numCntrls to 1 step -1 do
		cntl := controls(cnt);
		if cntl.isKindOf(GTE_Sheet) and
		   cntl.visible then
			numSheets := numSheets + 1;
		endif; 
	endforeach;

	if numSheets = 0 then
		self.unloadForm();
	else
		if app.msgBox('You are about to delete all of the sheets, do you wish to continue?',
						'Warning', MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;

	self.clearForm();
	
	self.fldInOut.initSheetBackColors();

	/*Done in clearForm() par 8969
	// doWindowEvents is a fudge as sometimes the setFocus does
	// not cause the app.activeControl to be set correctly which
	// then causes problems when the user tabs into tblCommon
	// (after Save tab key does not go to first row in tblCommon) - rjs Jun2303
	txtNewItem.doWindowEvents(0);
	txtNewItem.setFocus;
	*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="f24cbec7-3566-48f3-994f-c3edf25f6899">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//--------------------------------------------------
// Created:	15 September 2003 By: cnwgd1
//--------------------------------------------------
// PAR 20338 18807 - replay deadlocks
//7/3/2025 navsaa30 TFS 14818 MTN | Silent Deadlock Retry Technical Debt
//03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
vars
	result     : Boolean;
	localCaption : String;
begin

	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	self.mousePointer := Window.MousePointer_HourGlass;
	localCaption :=self.caption;
	
	while true do
		result := self.saveData();

		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);
	endwhile;
		/*Done in clearForm() par8969
		// doWindowEvents is a fudge as sometimes the setFocus does
		// not cause the app.activeControl to be set correctly which
		// then causes problems when the user tabs into tblCommon
		// (after Save tab key does not go to first row in tblCommon) - rjs Jun2303
		txtNewItem.doWindowEvents(0);
		txtNewItem.setFocus;
		*/

	if result = true then
		self.clearForm();
		self.fldInOut.initSheetBackColors(); 
	endif;
epilog
	app.myPassport.resetSilentDeadlockHandler;  //7/3/25  navsaa30 #14818
	self.caption:=localCaption;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbLogLocationUpdate" id="76ad8db2-45e9-409b-93fd-d00d7304bc69">
        <source>doCmbLogLocationUpdate(_location : CM_LogController; _isDeleted : Boolean);

// cnwdvb1 31 October 2002 

vars
	combo 		: ComboBox;
	isProcessed	: Boolean;
	numControls,
	idx			: Integer;
	cntrl		: Control;
	sheet		: GTE_Sheet;
	

begin

	numControls := self.controlCount;
	foreach idx in numControls to 1 step -1 do
		cntrl := controls(idx);
		if cntrl.isKindOf(GTE_Sheet) and 
		   cntrl.parent = fldInOut and 
		   cntrl.visible and
		   cntrl.GTE_Sheet.myMenuAction &lt;&gt; null then
		   
			sheet := cntrl.GTE_Sheet;
			//combo := sheet.getControlByName(Cntrl_cmbLogLocation).ComboBox;
			combo := sheet.getControlByName(GTE_InOutForm::cmbLogLocation.name).ComboBox;

			if combo &lt;&gt; null then
				if _isDeleted then
					self.myTerminal.availableLocationsForType(sheet.mySearchTypeCompare, sheet.allLogLocations, TA_TYPE_LOGAREA);
					self.myAssistant.GTE_Assistant.comboBoxLocationControllers(combo, sheet.allLogLocations, false);
					combo.text := null;
					self.setCellTextFromControl(sheet, combo, null);

				elseif _location &lt;&gt; null then
					if _location.doesAllowType(sheet.mySearchTypeCompare, false) then
						if not sheet.allLogLocations.includes(_location) then
							sheet.allLogLocations.add(_location);
							isProcessed := true;
						endif;
					else
						if sheet.allLogLocations.includes(_location) then
							sheet.allLogLocations.remove(_location);
							isProcessed := true;
							combo.text := null;
							self.setCellTextFromControl(sheet, combo, null);
						endif;
					endif;
					if isProcessed then
						self.myAssistant.GTE_Assistant.comboBoxLocationControllers(combo, sheet.allLogLocations, false);
					endif;
				endif;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_location" type="CM_LogController"/>
        <Parameter name="_isDeleted" type="Boolean"/>
    </JadeMethod>
