    <JadeMethod name="translateToDisplayValue" id="e80fbf7f-f22f-4d46-8b19-0a75e7970685">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/12/2014	cnwma1	Initial creation
03/10/2017	jlgdap1	TFS 7204 STWR Issues with decimals in locales whwere the decimal place is not a .
*/


vars
	pos 		: Integer;
	propName 	: String;
	measure 	: String;
	prop		: Property;
	value 		: Decimal [22,10];

begin
	if _value.String.isDecimalJMT then		// TFS 7204
		return _value.asStringJMT;			// TFS 7204
	endif;									// TFS 7204
	return inheritMethod(_value);
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="b189cbd9-0d4c-4b87-8f1d-30c1eac642d8">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web portal selector query parameters
//
vars

begin
	if _value.isKindOf(Decimal) then
		return _value.Decimal.asStringJMT;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
