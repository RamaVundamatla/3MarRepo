    <JadeMethod name="trxUpdateVoyageRequest" id="cb618eff-0036-4e4a-99fb-6ba7c29721d8">
        <updating/>
        <source>trxUpdateVoyageRequest(_pxyWorkOrder : CM_WorkOrder input;
						_allDocuments	: ObjectArray input ;
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2021	jlier1	Initial creation 51963
09 March 2022		jlizm1	TFS 52834 SAL file attachments filter by work order
26 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	realObj : CM_WodVoyageRequest;
	realWorkOrder : CM_WorkOrder;
	voyage : CM_Voyage;
	trxAA : CM_UpdateTransactionAuditAgent;
	voyageProformaTrxAction  : CMIF_TrxActionWOProforma;
	pxyDocuments : CM_FileDataSet;
	documentsToDelete : CM_FileDataSet;
	obj : Object;
	newDocuments : ObjectArray;
	filesToCreate : Boolean;
	filesToUpdate : Boolean;
	realFile : CM_FileData;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
			// Start the transaction

	realWorkOrder:=_pxyWorkOrder.pxyGetRealObject;
	if realWorkOrder = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyWorkOrder.getName, null, null);
		return;
	endif;
	
	voyage:=realWorkOrder.getMyVoyageObject;
	if voyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, realObj.getName, null, null);
		return;
	endif;
	create trxAA transient;
	trxAA.audUpdateGeneric(realWorkOrder, true);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateWorkOrder(_pxyWorkOrder,true, _passport);
	
	
	if app.myPassport.hasErrors  then
		return;
	endif;
	
	if not app.isInProformaMode  then		
		//epr 20/6/18 TFS 39166
		create voyageProformaTrxAction transient;
		voyageProformaTrxAction.setMyWorkOrder(realWorkOrder,CM_TrxControlAgent.Trx_Update);
		_passport.addTrxPostAction(voyageProformaTrxAction);
			
	endif;
	
	if _allDocuments &lt;&gt; null then
		// TFS 54298
		create pxyDocuments transient;
		create newDocuments transient;
		create documentsToDelete transient;
		realWorkOrder.allFiles.copy(documentsToDelete);
		foreach obj in _allDocuments do
			if obj.isKindOf(CM_FileData) and obj.CM_FileData.pxyIsProxy then
				// document is for update
				pxyDocuments.add(obj.CM_FileData);
				filesToUpdate := true;
				realFile := obj.CM_FileData.pxyGetRealObject();
				if documentsToDelete.includes(realFile) then
					documentsToDelete.remove(realFile);
				endif;
			else
				// document is to be created
				newDocuments.add(obj);
				filesToCreate := true;
			endif;
		endforeach;

		if filesToCreate then
			app.myUtilityCA.utlCreateFiles(realWorkOrder, newDocuments, _passport);
		endif;
		if filesToUpdate then
			app.myUtilityUA.utlUpdateFiles(pxyDocuments, _passport);
		endif;
		if documentsToDelete.size() &gt; 0 then
			// any documents that are on the exisitng voyage request, 
			// but aren't in the list to update, will get deletetd
			app.myUtilityDA.utlDeleteFiles(documentsToDelete, _passport);
		endif;
	endif;
	
	if _passport.noErrors then
		trxAA.audUpdateGeneric(realWorkOrder, false);
	endif;
	
epilog
	delete trxAA;
	delete pxyDocuments;
	delete newDocuments;
	delete documentsToDelete;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
