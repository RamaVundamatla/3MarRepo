    </JadeMethod>
    <JadeMethod name="translateForm" id="2aa35b3e-970b-4855-8db0-e99cc6968ecc">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020790, locale);
	lblBatNo.translateCaption(Xlat_0020791, locale);
	lblPackLoadTarg.translateCaption(Xlat_0020792, locale);
	lblParentId.translateCaption(Xlat_0020793, locale);
	lblRequest.translateCaption(Xlat_0020794, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtBatNo_gotFocus" id="a31e4716-5ec3-475c-b51f-d8e0a54ac917">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBatNo_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars

begin

	if txtBatNo.text = lblBatNo.caption.toUpper then
		//txtTruck.text := null;
		txtBatNo.selStart := 0;
		txtBatNo.selLength := lblBatNo.caption.length;
	endif;

epilog

end;</source>
