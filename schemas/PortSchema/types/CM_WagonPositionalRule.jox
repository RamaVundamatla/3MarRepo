    <JadeMethod name="getName" id="ec695962-338d-4863-bb8e-50599c630fbd">
        <source>getName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

	returnStr	: String;
	
begin
	
	returnStr	:=	inheritMethod();
	if myWagonClass &lt;&gt; null then
		returnStr := returnStr &amp; " " &amp; app.getErrorString(For_wagon_class) &amp; " " &amp; self.myWagonClass.code;
	endif;
	
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b123da7a-e856-455d-8963-1f123af7bca7">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 June 2009	cnwndl1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	tmpWagonPositionalRule : CM_WagonPositionalRule;
	tmpPosi : CM_WagonPosition;
	posi : CM_WagonPosition;
	completedOK		: Boolean;
	
begin

	tmpWagonPositionalRule := inheritMethod();
	tmpWagonPositionalRule.myWagonClass := self.myWagonClass;
	
	foreach posi in allWagonPositions do
		tmpPosi := posi.pxyCreateUpdateProxy();
		tmpPosi.setMyWagonPositionalRule(tmpWagonPositionalRule);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpWagonPositionalRule;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpWagonPositionalRule;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2d4483fa-0082-466a-bac2-53e90f5178fd">
        <updating/>
        <source>setForCreate( pProxyWagonPositionalRule : CM_WagonPositionalRule) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	persistWagonClass : CM_WagonClass;
begin

	persistWagonClass := app.myRoot.allWagonClasses.getAtKey(pProxyWagonPositionalRule.myWagonClass.code);
	self.myWagonClass := persistWagonClass;

	self.setForUpdate(pProxyWagonPositionalRule);
	
epilog

end;</source>
        <Parameter name="pProxyWagonPositionalRule" type="CM_WagonPositionalRule"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e4fc10cb-a960-4096-ac04-beca82854a9d">
        <updating/>
        <source>setForUpdate( pProxyWagonPositionalRule : CM_WagonPositionalRule ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	posi : CM_WagonPosition;
	pxyPosi : CM_WagonPosition;
	
begin
	self.numberOfPositions := pProxyWagonPositionalRule.numberOfPositions;
	
	if numberOfPositions = 0 then
		foreach posi in self.allWagonPositions do
			delete posi;
		endforeach;
		
	else
		foreach pos in 1 to self.numberOfPositions do
			posi := self.allWagonPositions.getAtKey(pos);
			pxyPosi := pProxyWagonPositionalRule.allWagonPositions.getAtKey(pos);
			if pxyPosi = null then
				if posi &lt;&gt; null then
					delete posi;
				endif;
				continue;
			endif;
			if posi = null then
				create posi;
			endif;
			posi.setForUpdate(pxyPosi);
			posi.setMyWagonPositionalRule(self);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="pProxyWagonPositionalRule" type="CM_WagonPositionalRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b6f4d20d-2b96-4451-812d-bc7c368cbeec">
        <updating/>
        <source>setProxy(	_myWagonClass : CM_WagonClass;
			_numberOfPositions : Integer;
			_allWagonPositions : CM_WagonPositionDict
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

	posi : CM_WagonPosition;
	pxyPosi : CM_WagonPosition;
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	self.myWagonClass := _myWagonClass;
	self.numberOfPositions := _numberOfPositions;
	
	if _allWagonPositions &lt;&gt; null then
		foreach posi in _allWagonPositions where posi.position &lt;= self.numberOfPositions do
			pxyPosi := posi.pxyCreateUpdateProxy();
			pxyPosi.setMyWagonPositionalRule(self);
		endforeach;
	endif;
	
	if self.allWagonPositions.size = self.numberOfPositions then
		return;
	elseif self.allWagonPositions.size &lt; self.numberOfPositions then
		while self.allWagonPositions.size &lt; self.numberOfPositions do
			create posi transient;
			posi.setProxy(	0,	//_cargoLength : Integer;
							0,	//_deckHeight : Integer;
							0,	//_maxWeight : Decimal;
							self.allWagonPositions.size + 1,	//_position : Integer;
							self	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="_myWagonClass" type="CM_WagonClass"/>
        <Parameter name="_numberOfPositions" type="Integer"/>
        <Parameter name="_allWagonPositions" type="CM_WagonPositionDict"/>
    </JadeMethod>
