    <JadeMethod name="addToolbarControls" id="b673074c-b081-4f19-a457-b76426734155">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			Adds toolbar controls to the forms toolbar

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
