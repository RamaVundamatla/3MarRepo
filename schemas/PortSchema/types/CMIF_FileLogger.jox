<Class name="CMIF_FileLogger" id="6fa50822-4375-4623-b6bb-3cc66a1364de">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ImplicitInverseRef name="log" id="41f45dd5-6515-4d9e-b2f8-577f6b637097">
        <embedded/>
        <type name="Object"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="logCounter" id="9edafc66-d605-4875-b602-ee2d6e329c5e">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="erase" id="1e82cd95-4a13-45cc-a837-aa6a010d1025">
        <updating/>
        <source>erase(_lvl: Integer) updating;

vars

begin
	exclusiveLock(self);
	if log &lt;&gt; null then
		exclusiveLock(log);
		log.JadeLog.commitLog;
		delete log;
	endif;
end;</source>
        <Parameter name="_lvl" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="f74eec8f-f123-4a55-b821-19c19b0a09df">
        <updating/>
        <source>initialise(selectorStr	:	String) updating;

vars

begin
	if log &lt;&gt; null then
		log.JadeLog.selector := selectorStr;	//This is a tag
		return;
	endif;
	create log.JadeLog transient;
	log.JadeLog.fileName := "PortTec.log";

end;</source>
        <Parameter name="selectorStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="7b8f1d36-24e1-487e-8f4d-4750fc46e3d9">
        <updating/>
        <source>logMessage(msgToLog : String) updating;

constants
	LOG_STR : String =  "Seq Log No.=" ;
vars

begin
	if log = null then
		self.initialise("");
	endif;
	logCounter := logCounter +1;
	log.JadeLog.log(LOG_STR &amp; logCounter.userNumberFormat($DecfinSeqNum) &amp; " " &amp; msgToLog);

end;</source>
        <Parameter name="msgToLog" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLogTag" id="89be3793-ca44-4e9e-8c0f-916c91e7698d">
        <source>setLogTag(tag:String);

vars

begin
	if log = null then
		return;
	endif;
	log.JadeLog.selector := tag;	//This is a tag

end;</source>
        <Parameter name="tag" type="String"/>
    </JadeMethod>
</Class>
