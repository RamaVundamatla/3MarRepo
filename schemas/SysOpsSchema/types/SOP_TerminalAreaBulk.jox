    <JadeMethod name="translateForm" id="9313327d-5a43-4629-9213-999e7c5438b1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 August 2022 11:04:24.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024977, locale);
	btnAdd.translateCaption(Xlat_0024978, locale);
	btnAddAll.translateCaption(Xlat_0024979, locale);
	btnRemove.translateCaption(Xlat_0024980, locale);
	btnRemoveAll.translateCaption(Xlat_0024981, locale);
	lblAvail.translateCaption(Xlat_0024982, locale);
	lblICArea.translateCaption(Xlat_0024983, locale);
	lblSelected.translateCaption(Xlat_0024984, locale);
end;</source>
    </JadeMethod>
