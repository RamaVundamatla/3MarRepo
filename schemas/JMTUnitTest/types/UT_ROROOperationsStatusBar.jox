    <JadeMethod name="xGCDCStatusBarStep4" id="293b3482-7182-4b5c-8d0f-e32ab6914178">
        <source>xGCDCStatusBarStep4();

/*

Purpose:		Plan discharge job and check that the status bar is correct	

Date			Who		Reason
14/05/2013		cnwmh5	Initial creation

*/


vars

	location							: CM_LocationsController;
	job									: CM_Job;
	req 								: CM_Request;
	wle 								: CM_WorkListEntry;

	itemsToDischarge					: StringArray;
	
begin

	app.writeLog("STEP 4", LogINFO);
	app.writeLog("Planning containers to discharge.  Please wait...", LogINFO);
	
	create itemsToDischarge transient;
	itemsToDischarge.add("UTGCDC10014");
	itemsToDischarge.add("UTGCDC10015");
	itemsToDischarge.add("UTGCDC10027");
	itemsToDischarge.add("UTGCDC10028");
	itemsToDischarge.add("UTGCDC10007");
	itemsToDischarge.add("UTGCDC10021");
	itemsToDischarge.add("UTGCDC10006");
	itemsToDischarge.add("UTGCDC10005");
	
	location := self.myBlockStack.allLocationsControllers.first;
	
	foreach job in self.myVoyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null and itemsToDischarge.includes(wle.myTrackedItem.id) then
					self.movePlannedWLE(wle.myTrackedItem, location, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	app.writeLog("Checking Status Bar (ACTUAL) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4339O");
	self.statusArray.add("D4339O D4339O | 2 x CONT NZLYT  U20G | UTGCDC10020, UTGCDC10021");
