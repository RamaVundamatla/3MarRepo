/*	if self.type = TA_TYPE_RMG then
		if (not app.checkRMGLicense()) then
			return;
		endif;
	else
		if (not app.checkRTGLicense()) then
			return;
		endif;
	endif; */	//07 Oct 2019	NDL	TFS 46169
	
	inheritMethod();

	//done on the proxy object
	if self.allAssociatedInterchangeAreas.size = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Side_IC_Area_Position),null,null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Side_IC_Area_Position),null,null); // cnwdb2	PAR 35364
