	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmGteEmptyReleaseMaintAll);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//ReleaseRequest_DoesNotExist
	if bulkReleaseRequest.myBulkRelease &lt;&gt; null then
		bulkRelease := app.myPassport.getObjectOfTypeFromOid(bulkReleaseRequest.myBulkRelease.cmObjectId,CM_BulkRelease).CM_BulkRelease;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;

	if bulkRelease = null  then
		app.raiseCMException1(Matching_found, app.getErrorString(BulkRelease), null, null);
		completedOK := true;
		return response;
	endif;
	
	// Do the delete 
	app.myTrxDA.trxDeleteBulkRelease(bulkRelease, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
