					_originalBol.bolType,	//_bolType: Integer; 
					_originalBol.myTerminal,	//_terminal: CM_Terminal; 
					_originalBol.mySubTerminal,	//_subTerminal: CM_SubTerminal;
					null,	//_destination : String;
					null,	//_dischargePort : String;
					null,	//_loadPort : String;
					false,	//_directDelivery : Boolean;
					null,	//_serviceOrder : String;			
					null,	//_poNbr : String;
