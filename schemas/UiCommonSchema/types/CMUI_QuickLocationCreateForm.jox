    <JadeMethod name="doMouseLeave" id="47fe5bcc-c4f2-4ef1-b1e2-5c1f942e70ba">
        <updating/>
        <source>doMouseLeave(group : GroupBox) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars
	tmpControl : Control;
	tmpFrame : Frame;
	numRow, numCol : Integer;
	tmpPoint : IntegerArray;
begin
if self.polyType = DeckItemLayoutType_Slot then
	return;
else	foreach tmpControl in self.allControlsByName do
		if tmpControl.parent = group then
			if tmpControl.isKindOf(Frame) then
				tmpFrame := tmpControl.Frame;
				tmpFrame.backColor := White;
				tmpFrame.borderColorSingle := SkyBlue;
				tmpFrame.foreColor := White;
			endif;
		endif;
	endforeach;
	self.lblInfo.caption := null;
	self.numCol := 0;
	self.numRow := 0;
	if self.myPointDrawingFrame &lt;&gt; null then
		self.myPointDrawingFrame.purgeDeckItems(); // delete any previous proxies created during quick draw
		self.myPointDrawingFrame.doBtnClearClick(true);
	endif;
	endif;
epilog


end;</source>
        <Parameter name="group" type="GroupBox"/>
    </JadeMethod>
    <JadeMethod name="doMouseMove" id="f24d212f-4566-4c5f-9851-ba2c3273ecea">
        <updating/>
        <source>doMouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real; group : GroupBox) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars
	tmpControl : Control;
	tmpFrame : Frame;
	chkRow, chkCol : Integer;
	tmpPoint : IntegerArray;
begin

if self.polyType = DeckItemLayoutType_Slot then
	return;
else
	foreach tmpControl in self.allControlsByName do
		if tmpControl.parent = group then
			if tmpControl.isKindOf(Frame) then
				tmpFrame := tmpControl.Frame;
				
				if x &gt; tmpFrame.left 
				and y &gt; tmpFrame.top then
					tmpFrame.borderColorSingle := Red;
					tmpPoint := tmpFrame.userObject.IntegerArray;
					self.lblInfo.caption := tmpFrame.caption;
				else
					tmpFrame.borderColorSingle := SkyBlue;
					tmpFrame.foreColor := White;
					tmpFrame.backColor := White;
				endif;
			endif;
		endif;
	endforeach;
endif;
	if self.myPointDrawingFrame &lt;&gt; null then
		chkRow := self.numRow;
		chkCol := self.numCol;
		
		if tmpPoint &lt;&gt; null then 
			self.numRow := tmpPoint[1];
			self.numCol := tmpPoint[2];
		endif;
		
		// Lots of mouse moves, only draw if need to
		if chkRow &lt;&gt; self.numRow
		or chkCol &lt;&gt; self.numCol then
			self.myPointDrawingFrame.doDrawQuickPolyArrayNEW(self.origMouseX.Integer, self.origMouseY.Integer, numRow, numCol,(group=self.grpLocnLR), self.polyType, self.myProxyDeckLayerLayout);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="group" type="GroupBox"/>
    </JadeMethod>
    <JadeMethod name="doMouseUp" id="f7d185a8-6dec-4513-9e72-11d2ab0551f5">
        <updating/>
        <source>doMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real; group : GroupBox) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars
	tmpControl : Control;
	tmpFrame : Frame;
begin
if self.polyType = DeckItemLayoutType_Slot then
	return;
else
	if self.myPointDrawingFrame &lt;&gt; null 
	and self.myProxyDeckLayerLayout &lt;&gt; null then
		self.myProxyDeckLayerLayout.setProxyDeckItemLayouts(self.myPointDrawingFrame.allPointGraphics);
		self.myProxyDeckLayerLayout.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
	endif;

	if self.myPointDrawingFrame &lt;&gt; null then
		self.myPointDrawingFrame.doBtnClearClick(true);
		self.unloadForm();
	endif;
endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="group" type="GroupBox"/>
