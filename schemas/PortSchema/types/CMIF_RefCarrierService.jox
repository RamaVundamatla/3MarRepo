<Class name="CMIF_RefCarrierService" id="0461238f-e00e-473e-bfe3-bdb0602e20e0">
    <superclass name="CMIF_OpsViewTables"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

DATASET - Waterside

Mapping 
MTN : CM_Trade
N4  : ref_carrier_service

[gkey] 			   [bigint] 	   NOT NULL,
[id] 			   [nvarchar](16)  NOT NULL,
[name] 			   [nvarchar](255) NOT NULL,
[carrier_mode] 	   [nvarchar](255) NOT NULL,
[life_cycle_state] [nvarchar](3)   NOT NULL,</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="carrier_mode" id="f24cd43a-be06-4007-b8d6-7a2a615592c8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="58610676-5753-445c-9054-ed6592074164">
        <length>17</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="life_cycle_state" id="378e3de9-cd4d-4137-82d8-6121a0e828c3">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="5de71132-d83b-427c-a693-1af99bac6507">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="initializeForActivity" id="6d655036-43f9-4bd8-8510-02a0adc1b501">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
31 Aug 2021 navpw1 ChangeRequest 51853: MTN - Opsview Container - Gate
*/

vars
	trade	: CM_Trade;
	carrier : CM_Carrier;
begin

	self.tableName	   := self.Ref_carrier_service;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	//navsp1 05MAY2022 TFS#53569
	if _any.isKindOf(CM_Trade) then
		trade	:= _any.CM_Trade;
		trade.initializeForActivity(_ewsOpsView,self);
	elseif _any.isKindOf(CM_Carrier) then // ### TFS 53105 21JUN2022 NAVAB1
		carrier	:= _any.CM_Carrier;
		carrier.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
