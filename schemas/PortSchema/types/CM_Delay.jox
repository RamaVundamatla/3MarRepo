    <JadeMethod name="initializeForActivity" id="678f1d3c-18a4-40e4-8503-1a7243271fb2">
        <updating/>
        <source>initializeForActivity(_ewsOpsView	: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	xpsCraneShift	    	: CMIF_XpsCraneshift;
	xpsPointOfWorkCmif      : CMIF_XpsPointOfWork;
	xpsCraneActivity : CMIF_XpsCraneactivity;
	invWqCmif               : CMIF_InvWq;
	machine : CM_Object;
	shift       : CM_Shift;
begin

	if _opsViewTable.isKindOf(CMIF_XpsCraneshift) then
		xpsCraneShift := _opsViewTable.CMIF_XpsCraneshift;
		
		xpsCraneShift.tableName				:= xpsCraneShift.Xps_craneshift;
		
		xpsCraneShift.gkey                   := xpsCraneShift.generateFullGKey(self, "");
		xpsCraneShift.pkey                   := xpsCraneShift.generateFullGKey(self, "");	
		xpsCraneShift.owner_pow              := xpsCraneShift.generateFullGKey(self, "");
		xpsCraneShift.owner_pow_gkey         := xpsCraneShift.generateFullGKey(self, "");
		
		if self.myVoyage &lt;&gt; null then // ### TFS 53569 10MAY2022 NAVAB1
			xpsCraneShift.visit := self.myVoyage.code; // ### TFS 53569 10MAY2022 NAVAB1
		endif;
		
		
	elseif _opsViewTable.isKindOf(CMIF_XpsPointOfWork) then
		xpsPointOfWorkCmif := _opsViewTable.CMIF_XpsPointOfWork;
		xpsPointOfWorkCmif.tableName				:= xpsPointOfWorkCmif.Xps_pointofwork;

		xpsPointOfWorkCmif.gkey                   := xpsPointOfWorkCmif.generateFullGKey(self, "");
		
		machine := xpsPointOfWorkCmif.getMachine(self);
		if machine &lt;&gt; null then // ### TFS 53105 13JUN2022 NAVAB1
			if machine.isKindOf(CM_Machine) then // ### TFS 53105 13JUN2022 NAVAB1
				xpsPointOfWorkCmif.che_id := machine.CM_Machine.code.getStringValueAsInteger64();
			elseif machine.isKindOf(CM_WorkPoint) then // ### TFS 53105 13JUN2022 NAVAB1
				xpsPointOfWorkCmif.che_id := machine.CM_WorkPoint.code.getStringValueAsInteger64(); // ### TFS 53105 13JUN2022 NAVAB1
			endif;
		endif;
		
		xpsPointOfWorkCmif.vessel_visit_gkey := xpsPointOfWorkCmif.generateFullGKey(self.myVoyage, "");

		// xpsPointOfWorkCmif.pkey - the old mapping used a machine for this field and there was no code under CM_Machine for pkey so it is always null
		//shift  	  := self.getCraneCurrentShift();
		//xpsPointOfWorkCmif.pkey := xpsPointOfWorkCmif.generateFullGKey(shift, "");
	elseif _opsViewTable.isKindOf(CMIF_XpsCraneactivity) then
		xpsCraneActivity := _opsViewTable.CMIF_XpsCraneactivity;
		xpsCraneActivity.tableName				:= xpsCraneActivity.Xps_craneactivity;

		xpsCraneActivity.gkey                   := xpsCraneActivity.generateFullGKey(self, "");
		
		xpsCraneActivity.absolute_start_time    := self.startDT.asEpochFormat();
		xpsCraneActivity.plan_status			:= 0;
		xpsCraneActivity.duration			    := self.getDelayDurationMillisec();
		xpsCraneActivity.variable_start_time    := 0;
		xpsCraneActivity.positioning_obj 	    := xpsCraneActivity.generateFullGKey(self, ""); // ### TFS 53569 10MAY2022 NAVAB1
		xpsCraneActivity.user_defined			:= "";
		
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="af6175e3-dcf1-4188-85a5-12f799aad6df">
        <source>isOpsViewData(): Boolean;
/*

Purpose:			
		Cuurently Ops view only using Delays for Cranes 
Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars

begin

	if self.myVoyage &lt;&gt; null then
		if self.myMachine &lt;&gt; null then
		
			if self.myMachine.isKindOf(CM_Crane) or self.myMachine.isKindOf(CM_WorkPoint) then
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="overlapsRange" id="0b2e4ec6-2912-416b-84c4-ef8b3810c22f">
        <source>overlapsRange( _startTS : TimeStamp; _endTS : TimeStamp ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	par 29369

*/

vars

begin

	if _endTS &lt; self.startDT then
		// range ends before I start
		return false;
	endif;
	
	if _startTS &gt; self.getEndDT then
		// range starts after I End
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
