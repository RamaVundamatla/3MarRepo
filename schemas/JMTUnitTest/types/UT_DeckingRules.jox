    <JadeMethod name="tDefaultRTGStackingOrder" id="ac72b169-1c7f-4e8e-b6d6-55c2bfe1d3c0">
        <source>tDefaultRTGStackingOrder();
// cnwndl1
//31 December 2008	cnwdw1	
// Test the correct default rule is created when an a RTG is created
constants
	IN = true;
vars
	rtg: CM_RTGArea;
	rows, stacks, tiers: Integer;
	gridColumn: CM_GridColumn;
	stack, row, tier: Integer;
	index: Integer;
	deckingLocation, location: CM_GridController;
	deckingCell: CM_YALocationCell;
begin
	self.deleteTerminalArea("UTRTG");

	rows := 4;
	stacks := 5;
	tiers := 4;
	rtg := self.addRTGArea("UTRTG",  rows, stacks, tiers);

	assertNotNull(rtg);
	assertEqual(rtg.getDeckingOptions().allYALocationCellsIn.size, rows * stacks * tiers);
	
	// default is DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise
	// Check the fill sequence
	/*
	foreach gridColumn in rtg.allGridColumns do
		stack := stack + 1;
		foreach tier in 1 to tiers do
			foreach location in gridColumn.allControllersByRow where location.isDeckable do
				row := row + 1;
				index := index + 1;
				deckingCell := rtg.getDeckingOptions().allYALocationCellsIn[index];
				assertEqual(deckingCell.column, stack);
				assertEqual(deckingCell.height, tier);
				assertEqual(deckingCell.row, row);
				
				deckingLocation := deckingCell.myYardController.CM_GridController;
				assertNotNull(deckingLocation);
				assertTrueMsg(deckingLocation.isRTGController, "Expected a RTGController and got "&amp;deckingLocation.asStringJMT);
				assertEqualMsg(deckingLocation.getID, location.getID, "Index: "&amp;index.String);
			endforeach;
			row := 0;
		endforeach;
	endforeach;
	*/
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tROROArea" id="c3002470-49e3-4228-86cc-a117a5638bf7">
        <source>tROROArea();
// cnwndl1
//21 January 2010	cnwdw1	
//
vars
	roroArea: CM_RoRoLaneArea;
begin
	deleteTerminalArea("UTRORO");
	roroArea := addROROArea("UTRORO",  4, 100);
	assertTrueMsg(roroArea &lt;&gt; null, "Failed to add RORO Area");
	assertNotNull(roroArea.myYADeckingOptions);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.size, 4);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.myYardController, roroArea.allLanesById.first);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.row, roroArea.allLanesById.first.laneNumber);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsOut.first.myYardController, roroArea.allLanesById.last);
	
	// By Lane, Lane Increasing 
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByRow, 0, DeckingRule_Increasing, 0, 0);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.myYardController, roroArea.allLanesById.first);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.row, roroArea.allLanesById.first.laneNumber);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.last.myYardController, roroArea.allLanesById.last);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.last.row, roroArea.allLanesById.last.laneNumber);
	
	// By Lane, Lane Decreasing
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByRow, 0, DeckingRule_Decreasing, 0, 0);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.myYardController, roroArea.allLanesById.last);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.last.myYardController, roroArea.allLanesById.first);
	
	// By Position, Lane Increasing
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByStack, 0, DeckingRule_Increasing, 0, 0);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.myYardController, roroArea.allLanesById.first);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.last.myYardController, roroArea.allLanesById.last);

	// By Position, Lane Decreasing
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByStack, 0, DeckingRule_Decreasing, 0, 0);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.first.myYardController, roroArea.allLanesById.last);
	assertEqual(roroArea.myYADeckingOptions.allYALocationCellsIn.last.myYardController, roroArea.allLanesById.first);

end;</source>
    </JadeMethod>
    <JadeMethod name="tSequenceByRowStackingRules" id="1faff8f9-2429-4a9e-8a77-4b3569d0a538">
        <source>tSequenceByRowStackingRules();
// cnwndl1
//17 December 2008	cnwdw1	
//
vars
	sequencer: CMIF_DeckingSequenceService;
	seq: Integer;
	stack, row, tier: Integer;
begin
	create sequencer transient;
	sequencer.onCreate(DeckingRule_ByRow);
	sequencer.setExtent(3, 5, 4);
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise);
	seq := 1;
	foreach row in 1 to 5 do
		foreach stack in 1 to 3 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error A");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach row in 1 to 5 do
			foreach stack in 1 to 3 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error B ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error B");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Columnwise);
	seq := 1;
	foreach row in 5 to 1 step -1 do
		foreach stack in 1 to 3 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error C ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error C");
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach row in 5 to 1 step -1 do
			foreach stack in 1 to 3 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error D ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error D");


	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_Columnwise);
	seq := 1;
	foreach row in 1 to 5 do
		foreach stack in 3 to 1 step -1 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error E ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error E");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach row in 1 to 5 do
			foreach stack in 3 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error F ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error F");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Columnwise);
	seq := 1;
	foreach row in 5 to 1 step -1 do
		foreach stack in 3 to 1 step -1 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error G ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error G");
	
	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach row in 5 to 1 step -1 do
			foreach stack in 3 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error H ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error H");

	
epilog
	delete sequencer;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSequenceByStackStackingRules" id="e739b29e-a559-4f9d-b2c9-925cec742845">
        <source>tSequenceByStackStackingRules();
// cnwndl1
//17 December 2008	cnwdw1	
//
vars
	sequencer: CMIF_DeckingSequenceService;
	seq: Integer;
	stack, row, tier: Integer;
begin
	create sequencer transient;
	sequencer.onCreate(DeckingRule_ByStack);
	sequencer.setExtent(3, 5, 4);
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise);
	seq := 1;
	foreach stack in 1 to 3 do
		foreach row in 1 to 5 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error A");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach stack in 1 to 3 do
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error B ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error B");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Columnwise);
	seq := 1;
	foreach stack in 1 to 3 do
		foreach row in 5 to 1 step -1 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error C ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error C");
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach stack in 1 to 3 do
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error D ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error D");


	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_Columnwise);
	seq := 1;
	foreach stack in 3 to 1 step -1 do
		foreach row in 1 to 5 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error E ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error E");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach stack in 3 to 1 step -1 do
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error F ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error F");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Columnwise);
	seq := 1;
	foreach stack in 3 to 1 step -1 do
		foreach row in 5 to 1 step -1 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error G ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error G");
	
	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Tierwise);
	seq := 1;
	foreach tier in 1 to 4 do
		foreach stack in 3 to 1 step -1 do
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error H ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error H");

	
epilog
	delete sequencer;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSequenceMiddleOut" id="d47d14dd-4868-449f-ad15-62d081c2ad36">
        <source>tSequenceMiddleOut();
// cnwndl1
//17 December 2008	cnwdw1	
//
vars
	sequencer: CMIF_DeckingSequenceService;
	seq: Integer;
	row, stack, tier: Integer;
	seqArrayRows, seqArrayStacks, seqArrayTiers: IntegerArray;
begin
	create seqArrayRows transient;
	create seqArrayStacks transient;
	create seqArrayTiers transient;

	create sequencer transient;
	sequencer.onCreate(DeckingRule_ByStack);
	sequencer.setExtent(3, 5, 4);
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_MiddleOut, DeckingRule_Columnwise);

	seq := 1;
	seqArrayRows.add(3);seqArrayRows.add(2);seqArrayRows.add(4);seqArrayRows.add(1);seqArrayRows.add(5);
	foreach stack in 1 to 3 do
		foreach row in seqArrayRows do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");

	sequencer.setExtent(3, 5, 4);
	sequencer.setRules(DeckingRule_MiddleOut, DeckingRule_Increasing, DeckingRule_Columnwise);

	seq := 1;
	seqArrayStacks.clear;
	seqArrayStacks.add(2);seqArrayStacks.add(3);seqArrayStacks.add(1);
	foreach stack in seqArrayStacks do
		foreach row in 1 to 5 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");

	sequencer.setRules(DeckingRule_MiddleOut, DeckingRule_Increasing, DeckingRule_Tierwise);
	seq := 1;
	seqArrayStacks.clear;
	seqArrayStacks.add(2);seqArrayStacks.add(3);seqArrayStacks.add(1);
	foreach tier in 1 to 4 do
		foreach stack in seqArrayStacks do
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");

	sequencer.setRules(DeckingRule_MiddleOut, DeckingRule_Decreasing, DeckingRule_Columnwise);
	seq := 1;
	seqArrayStacks.clear;
	seqArrayStacks.add(2);seqArrayStacks.add(3);seqArrayStacks.add(1);
	foreach stack in seqArrayStacks do
		foreach row in 5 to 1 step -1 do
			foreach tier in 1 to 4 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");
	
	sequencer.setRules(DeckingRule_MiddleOut, DeckingRule_Decreasing, DeckingRule_Tierwise);
	seq := 1;
	seqArrayStacks.clear;
	seqArrayStacks.add(2);seqArrayStacks.add(3);seqArrayStacks.add(1);
	foreach tier in 1 to 4 do
		foreach stack in seqArrayStacks do
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");

	sequencer.setRules(DeckingRule_MiddleOut, DeckingRule_MiddleOut, DeckingRule_Columnwise);
	seqArrayRows.clear; seqArrayRows.add(3); seqArrayRows.add(2); seqArrayRows.add(4); seqArrayRows.add(1); seqArrayRows.add(5);
	seqArrayStacks.clear; seqArrayStacks.add(2); seqArrayStacks.add(3); seqArrayStacks.add(1);
	seqArrayTiers.clear; seqArrayTiers.add(1); seqArrayTiers.add(2); seqArrayTiers.add(3); seqArrayTiers.add(4);
	seq := 1;
	foreach stack in seqArrayStacks do
		foreach row in seqArrayRows do
			foreach tier in seqArrayTiers do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 61, "final seq error");
	
epilog
	delete sequencer;
	delete seqArrayRows;
	delete seqArrayStacks;
	delete seqArrayTiers;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSequenceSideToSidePattern" id="d522a456-bfb7-4eac-9987-db441b5de8db">
        <source>tSequenceSideToSidePattern();
// cnwndl1
//17 December 2008	cnwdw1	
//
vars
	sequencer: CMIF_DeckingSequenceService;
	seq: Integer;
	stack, row, tier: Integer;
begin
	create sequencer transient;
	sequencer.onCreate(DeckingRule_ByStack);
	sequencer.setExtent(3, 5, 3);
	sequencer.topupTier := 2;
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_SideToSide);
	seq := 1;
	tier := 1;
	foreach stack in 1 to 3 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 2;
	foreach stack in 1 to 3 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 3;
	foreach stack in 1 to 3 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error A");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_SideToSide);
	seq := 1;
	tier := 1;
	foreach stack in 1 to 3 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 2;
	foreach stack in 1 to 3 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 3;
	foreach stack in 1 to 3 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error B");
	
	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_SideToSide);
	seq := 1;
	tier := 1;
	foreach stack in 3 to 1 step -1 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 2;
	foreach stack in 3 to 1 step -1 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 3;
	foreach stack in 3 to 1 step -1 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error C");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_SideToSide);
	seq := 1;
	tier := 1;
	foreach stack in 3 to 1 step -1 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 2;
	foreach stack in 3 to 1 step -1 do
		if stack.isOdd then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	tier := 3;
	foreach stack in 3 to 1 step -1 do
		if stack.isEven then
			foreach row in 1 to 5 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		else
			foreach row in 5 to 1 step -1 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endif;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error D");
	
epilog
	delete sequencer;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSequenceTopupPattern" id="45941565-2d42-492f-a982-b4a250d20ab4">
        <source>tSequenceTopupPattern();
// cnwndl1
//17 December 2008	cnwdw1	
//
vars
	sequencer: CMIF_DeckingSequenceService;
	seq: Integer;
	stack, row, tier: Integer;
begin
	create sequencer transient;
	sequencer.onCreate(DeckingRule_ByStack);
	sequencer.setExtent(3, 5, 3);
	sequencer.topupTier := 2;
	
	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Topup);
	seq := 1;
	foreach stack in 1 to 3 do
		foreach row in 1 to 5 do
			foreach tier in 1 to 2 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	tier := 3;
	foreach stack in 1 to 3 do
		foreach row in 1 to 5 do
			assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error A ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
			seq := seq + 1;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error A");

	sequencer.setRules(DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Topup);
	seq := 1;
	foreach stack in 1 to 3 do
		foreach row in 5 to 1 step -1 do
			foreach tier in 1 to 2 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error B ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	tier := 3;
	foreach stack in 1 to 3 do
		foreach row in 5 to 1 step -1 do
			assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error B ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
			seq := seq + 1;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error B");
	
	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Increasing, DeckingRule_Topup);
	seq := 1;
	foreach stack in 3 to 1 step -1 do
		foreach row in 1 to 5 do
			foreach tier in 1 to 2 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error C ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	tier := 3;
	foreach stack in 3 to 1 step -1 do
		foreach row in 1 to 5 do
			assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error C ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
			seq := seq + 1;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error C");

	sequencer.setRules(DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Topup);
	seq := 1;
	foreach stack in 3 to 1 step -1 do
		foreach row in 5 to 1 step -1 do
			foreach tier in 1 to 2 do
				assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq,  "Sequence error D ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
				seq := seq + 1;
			endforeach;
		endforeach;
	endforeach;
	tier := 3;
	foreach stack in 3 to 1 step -1 do
		foreach row in 5 to 1 step -1 do
			assertEqualMsg(sequencer.getStackingSequence(stack, row, tier), seq, "Sequence error D ("&amp;row.String&amp;","&amp;stack.String&amp;","&amp;tier.String&amp;")");
			seq := seq + 1;
		endforeach;
	endforeach;
	assertEqualMsg(seq, 46, "final seq error D");
	
epilog
	delete sequencer;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateStraddleStackDecking" id="26a97e37-9058-4a46-8174-a47498337ac6">
        <source>tUpdateStraddleStackDecking();
// cnwndl1
//04 February 2009	cnwdw1	
//
constants
	IN = true;
	OUT = false;
vars
	straddleStack: CM_StraddleStack;
	rows, stacks, tiers: Integer;
	stack, row, tier: Integer;
	locations: CM_LCArray;
	msg: String;
	index: Integer;
	locationCell: CM_YALocationCell;
	yaLocationCells: CM_YALocationCellArray;
begin
	
	self.deleteTerminalArea("UTSTRD");
	
	rows := 2;
	stacks := 2;
	tiers := 2;
	straddleStack := self.addStraddleStack("UTSTRD", rows, stacks, tiers);
	assertNotNull(straddleStack);
	
	self.updateDeckingRulesTA("UTSTRD", IN, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	assertTrue(straddleStack.myYADeckingOptions.useReverseOfIn);
	// Validate order of cells
	index := 1;
	yaLocationCells := straddleStack.myYADeckingOptions.allYALocationCellsIn;
	foreach row in 1 to rows do
		foreach stack in 1 to stacks do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Validate order of Out - should be reverse of In
	index := 1;
	yaLocationCells := straddleStack.myYADeckingOptions.allYALocationCellsOut;
	foreach row in rows to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in tiers to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Check that location cells are in both collections
	foreach locationCell in straddleStack.myYADeckingOptions.allYALocationCellsIn do
		assertTrue(straddleStack.myYADeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;

	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYAWithNewYABlock" id="f1eead04-6af8-46e4-8321-229ad860232b">
        <source>tUpdateYAWithNewYABlock();
// cnwndl1
//31 December 2008	cnwdw1	
// Test the correct decking rules are picked up when a YABlock is added to a YA
constants
	IN = true;
	OUT = false;
vars
	straddleStack: CM_StraddleStack;
	rows, stacks, tiers: Integer;
	stack, row, tier: Integer;
	locations1, locations2: CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	msg: String;
	index: Integer;
	locationCell: CM_YALocationCell;
	yaLocationCells: CM_YALocationCellArray;
	yaLocations: ObjectArray;
begin

	self.deleteTerminalArea("UTSTRD");
	
	rows := 6;
	stacks := 10;
	tiers := 2;
	straddleStack := self.addStraddleStack("UTSTRD", rows, stacks, tiers);
	assertNotNull(straddleStack);
	
	self.deleteYA("UT");

	create locations1 transient;
	locations1.add(straddleStack.allGridControllersByRowColumn[1,1]);
	locations1.add(straddleStack.allGridControllersByRowColumn[2,2]);

	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations1);
	self.assertEqual(ya.allYABlocksIn.first.allYardControllers.size, 4);
	self.updateDeckingRulesTA("UTSTRD", IN, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);

	create yaLocations transient;
	locations1.clear;
	self.allLocationsBetween(locations1, straddleStack.allGridControllersByRowColumn[1, 1], 
										 straddleStack.allGridControllersByRowColumn[2, 2]);
	create locations2 transient;
	self.allLocationsBetween(locations2, straddleStack.allGridControllersByRowColumn[3, 1], 
										 straddleStack.allGridControllersByRowColumn[6, 6]);
	yaLocations.add(locations1);
	yaLocations.add(locations2);
	
	self.updateYABlocks(ya, yaLocations);
	self.assertEqual(ya.allYABlocksIn.first.allYardControllers.size, 4);
	self.assertEqual(ya.allYABlocksIn.last.allYardControllers.size, 24);
		
	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.last.myDeckingOptions.allYALocationCellsIn;
	foreach stack in 1 to 6 do
		foreach row in 3 to 6 do
			foreach tier in 1 to 2 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Validate order of Out - should be reverse of In
	index := 1;
	yaLocationCells := ya.allYABlocksIn.last.myDeckingOptions.allYALocationCellsOut;
	foreach stack in 6 to 1 step -1 do
		foreach row in 6 to 3 step -1 do
			foreach tier in 2 to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Check that location cells are in both collections
	foreach locationCell in ya.allYABlocksIn.last.myDeckingOptions.allYALocationCellsIn do
		assertTrue(ya.allYABlocksIn.last.myDeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;

epilog
	delete locations1;
	delete locations2;
	delete yaLocations;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYAPicksUpRTGDefaults" id="ea0982e6-baa9-4e38-b49c-967e76523a0e">
        <source>tYAPicksUpRTGDefaults();
// cnwndl1
//04 February 2009	cnwdw1	
// Check that a YA Block defaults to the Decking Order of the TA
constants
	IN = true;
	OUT = false;
vars
	rtg: CM_RTGArea;
	rows, stacks, tiers: Integer;
	stack, row, tier: Integer;
	locations: CM_LCArray;
	msg: String;
	operatorSet: CM_ObjectSet;
	index: Integer;
	locationCell: CM_YALocationCell;
	ya: CM_YardAllocation;
	yaLocationCells: CM_YALocationCellArray;
begin
	
	self.deleteTerminalArea("UTRTG");
	self.deleteYA("UT");
	
	rows := 2;
	stacks := 2;
	tiers := 2;
	rtg := self.addRTGArea("UTRTG",  rows, stacks, tiers);
	assertNotNull(rtg);
	
	self.updateDeckingRulesTA("UTRTG", IN, DeckingRule_ByRow, DeckingRule_Decreasing, DeckingRule_Decreasing, DeckingRule_Columnwise, 0);
	
	create locations transient;
	locations.add(rtg.allGridControllersByRowColumn[1,1]);
	locations.add(rtg.allGridControllersByRowColumn[1,2]);

	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);

	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach row in 1 to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Check that location cells are in both collections
	foreach locationCell in rtg.myYADeckingOptions.allYALocationCellsIn do
		assertTrue(rtg.myYADeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;
	
epilog
	delete locations;
	delete operatorSet;
end;</source>
    </JadeMethod>
