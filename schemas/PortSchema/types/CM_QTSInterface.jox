    <JadeMethod name="getExternalNumber" id="f96a8f65-e863-417d-b9dc-4d15e6bf8d14">
        <source>getExternalNumber(_finObject : CM_FinancialObject) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	externalNumber,
	year,
	tmpStr,
	sequenceKey			: String;
	sequenceNum		    : Integer;
	invoiceTotal        : Decimal [23,6];
	invoice				: CM_Invoice;
	cashReceipt         : CM_CashReceipt;
	cashCredit          : CM_CashCredit;
	bank                : CM_Bank;
begin
	
	if _finObject.isKindOf(CM_Invoice) then
		invoice := _finObject.CM_Invoice;
		bank    := invoice.bank;
		
		if invoice.exportCurrencyCode &lt;&gt; null then
			externalNumber := invoice.exportCurrencyCode;	
		else
			invoiceTotal := invoice.getTotalAmount();
			
			if invoiceTotal &lt; 0 then
				tmpStr := bank.code 	&amp; "/" ;//&amp; self.Type_Credit_Invoice &amp; "/";
			else
				tmpStr := bank.code 	&amp; "/" ;//&amp; self.Type_CASH_Invoice &amp; "/";
			endif;
			
			if invoice.postedDT.isValid then
				year := invoice.postedDT.date.year.padLeadingWith('0', 4);
			else
				year := app.actualTimeServer.date().year.padLeadingWith('0', 4);
			endif;
			
			externalNumber := tmpStr &amp; invoice.sequenceNum.padLeadingWith('0', 6) &amp; '/' &amp; year;
		endif;
	elseif _finObject.isKindOf(CM_CashReceipt) then
		cashReceipt := _finObject.CM_CashReceipt;
		bank        := cashReceipt.myBank;
		
		year		   := cashReceipt.dateTime.date.year.padLeadingWith('0', 4);
		sequenceKey    := SN_CashReceipt &amp; year[3:2];	
		sequenceNum    := bank.getSeqNum(sequenceKey);
		externalNumber := bank.code &amp; "/RCT/"  &amp; sequenceNum.padLeadingWith('0', 6) &amp; "/" &amp; year; 
	
	elseif _finObject.isKindOf(CM_CashCredit) then
		cashCredit      := _finObject.CM_CashCredit;
		
		year    		:= cashCredit.dateTime.date.year.padLeadingWith('0', 4);
		sequenceKey 	:= SN_CashCredit &amp; year[3:2];	
		sequenceNum 	:= cashCredit.myBank.getSeqNum(sequenceKey);
		externalNumber  := cashCredit.myBank.code &amp; "/CN/" &amp; sequenceNum.padLeadingWith('0', 6) &amp; "/" &amp; year; 
	endif;


	return externalNumber;
epilog

end;</source>
        <Parameter name="_finObject" type="CM_FinancialObject"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalReciptNumber" id="dc2f989d-a6e3-407a-8fe0-dd544b0fb437">
