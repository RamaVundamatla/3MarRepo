    <JadeMethod name="archive" id="9813345c-da23-4207-abe8-6ae45ec62b34">
        <updating/>
        <source>archive(_cmifArchiveVoy : CMIF_ArchiveVoyage; _passport : CM_Passport input) updating;
/*

Purpose:			
			THIS SHOULD ONLY BE CALLED FROM CM_Voyage::archive();	
Parameters:			

Return Value:		


Date			Who		Reason
30 Mar 2006 	cnwgd1	Initial creation
13 Mar 2020     cnwma1  Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
*/


vars
	objArray	    : ObjectArray;
	obj			    : Object;
	moveController  : CMIF_MoveController;
	theMonitor      : CMIF_Monitor;
begin

	exclusiveLock(self);
	
	if _cmifArchiveVoy.myMonitor &lt;&gt; null then
		theMonitor := _cmifArchiveVoy.myMonitor;
	endif;
	
	//----------------------
	//Process each bayplan
	//----------------------
	if theMonitor &lt;&gt; null then
		theMonitor.updateProgress(app.getErrorString(ProcessingBayPlans) &amp; '...', null, null);
	endif;
	
	create moveController transient; //create once - used to unplan/unqueue TIs in slot
	create objArray       transient;
	
	self.allBayVoyagesByOrdinal.copy(objArray);
	
	foreach obj in objArray do
		if obj.isKindOf(CM_BayVoyage) then
			obj.CM_BayVoyage.archive(_cmifArchiveVoy, moveController, _passport);
		endif;
	endforeach;

epilog
	delete moveController;
	delete objArray;
end;</source>
        <Parameter name="_cmifArchiveVoy" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="58c88fad-770c-45c6-8a4d-c1cca6c8d7a5">
