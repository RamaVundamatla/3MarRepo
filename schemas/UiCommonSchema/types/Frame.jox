<GUIClass name="Frame">
    <JadeMethod name="cnEcResizeContents" id="aaf89837-9747-499d-a50a-074a8d930757">
        <updating/>
        <source>cnEcResizeContents() updating;
vars
	idx		: Integer;
	cntrl	: Control;

begin

	inheritMethod();
	
	foreach idx in 1 to form.controlCount do
		cntrl := form.controls(idx);
		if cntrl.parent = self then
			cntrl.repositionAfterResize();
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCaptionForTranslation" id="6a41dd8a-0c96-437e-ba02-ed883e1f1096">
        <updating/>
        <source>setCaptionForTranslation(_str: String) updating;
//15 October 2009	cnwml2


vars

begin
	inheritMethod(_str);
	self.caption := _str;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
</GUIClass>
