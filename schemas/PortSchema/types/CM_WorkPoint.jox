    <JadeMethod name="getDisplayStringForAttribute" id="62f3cb18-c4c0-48d5-9340-690205d3206f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116
02 OCt  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars

begin

	if _attrName = ETRow_DefineRates then	//06 Mar 2018	NDL	TFS 37437
		return app.getErrorString( Dbl_Click_Edit_View );
		
	elseif _attrName = ETRow_NumWorkPointRates then	//06 Mar 2018	NDL	TFS 37437
		if not self.hasDefinedCargoRates() then
			return false.cnEcGetYesNo();
		else
			return true.cnEcGetYesNo() &amp; " (x" &amp; self.allWorkPointRates.size.String &amp; ")";
		endif;
	elseif _attrName = ETRow_ExternalRef then  //02.10.2018 cnwma1 TFS #41234
		return self.externalRef;
	elseif _attrName = ETRow_WorkPointType then  //26.4.2023 navhl20 #57712[54552]
		if self.myWorkPointType &lt;&gt; null then
			return self.myWorkPointType.code;
		endif;
		return null;
	endif;
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
