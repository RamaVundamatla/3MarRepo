    <JadeMethod name="removeString" id="93e989ea-1d00-40fe-87cf-f7fc42e674c8">
        <source>removeString(_string : Character) : String;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars


 	newString,tmpString : String;
	pos, posSt, posEnd,charPos, st : Integer;
begin
	charPos := 1;
	newString := self;
	
	pos := newString.pos(_string, charPos);

	if pos &gt; 0 then	
		pos := 1;
		charPos := 1;
		st := 1;
		while pos &gt;= 1 do
			pos := newString.pos(_string, charPos);
			if pos &gt; 0 then
				if pos = newString.length then
					tmpString := newString[1:(pos - 1)];
					newString := tmpString;
				else
					posSt := (pos - 1);
					posEnd := (pos + 1);
					tmpString := newString[st: posSt] &amp; newString[posEnd:end];
					newString := tmpString;
					st := charPos;
				endif;
			endif;
		endwhile;
	endif;	

	return newString;
end;</source>
        <Parameter name="_string" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeSubstringPlusExtraChars" id="03c73bac-e48b-45e4-9dba-8c7d28830ff6">
        <source>removeSubstringPlusExtraChars( _searchStr : String; _noExtraChars : Integer ) : String;

/*
Purpose:		This method takes self (a string) and will remove every occurrence of the supplied search string
				plus the specified number of characters after each found search string.
				eg substring ABC and number of characters 2 this will remove every occurrence
				of ABC found (case sensitive) and then the next 2 characters as well.
				
				Specifying 0 for the number of extra characters to be stripped effectively
				does a removal of all of the substring occurrences only.
				
				NOTE: because the search starts from 1 each time if the resulting string after stripping
				the additional characters ends up containing the substring then this will also be removed
				eg "AAND1ND23" if "AND" and 1 is specified then the first "AND" and the "1" will be
				removed leaving "AND23" which will then be checked and reset to "3"

Parameters:		1) The search substring
				2) The number of additional characters to be stripped after the substring is found
Return Value:	The string with required substring(s) and character(s) stripped.

Date				Who		Reason
24 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	ipos			: Integer;
	returnStrLen	: Integer;
	searchStrLen	: Integer;
	returnStr		: String;
	
begin
	// do some basic validation.
	if self = null or _searchStr = null or _noExtraChars &lt; null then
		return self;
	endif;
	
	returnStr		:= self;
	searchStrLen	:= _searchStr.length;
	ipos			:= returnStr.pos( _searchStr, 1 );
	
	while ipos &gt; null do
		if returnStr = _searchStr then
			returnStr	:= null;
			break;
		endif;
		returnStrLen	:= returnStr.length;
		
		if ipos = 1 then
			// first remove the search string
			returnStr		:= returnStr[ ipos + searchStrLen : end ];
			returnStrLen	:= returnStr.length;
			// now remove the number of characters to be stripped
			if _noExtraChars &gt;= returnStrLen then
				returnStr	:= null;
			else
				returnStr	:= returnStr[ ipos + _noExtraChars : end ];
			endif;
		elseif ipos = returnStrLen then
			returnStr		:= returnStr[ 1 : ipos - 1 ];
		else
			// first remove the search string
			if ipos + searchStrLen &gt;= returnStrLen then
				returnStr	:= returnStr[ 1 : ipos - 1 ];
			else
				returnStr	:= returnStr[ 1 : ipos - 1 ] &amp; returnStr[ ipos + searchStrLen : end ];
			endif;
			returnStrLen	:= returnStr.length;
			// now remove the number of characters to be stripped
			if ipos - 1 + _noExtraChars &gt;= returnStrLen then
				returnStr	:= returnStr[ 1 : ipos - 1 ];
			else
				returnStr	:= returnStr[ 1 : ipos - 1 ] &amp; returnStr[ ipos + _noExtraChars : end ];
			endif;
		endif;
		// now recheck the whole string ready to loop again
		ipos	:= returnStr.pos( _searchStr, 1 );
	endwhile;
	
	return returnStr;
	
epilog
	
end;
</source>
        <Parameter name="_searchStr" type="String"/>
        <Parameter name="_noExtraChars" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeTabCrLfs" id="4d712259-59c9-4270-bdb7-65901f0039f4">
        <source>removeTabCrLfs() : String;

vars
	aStr : String;
begin
	aStr := self;
	aStr.replaceChar(Tab, " ");
	aStr.replaceChar(Cr, " ");
	aStr.replaceChar(Lf, " ");
	aStr := aStr.trimRight;
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replace" id="f747535e-eb27-426c-b7b1-dbfa349e50d7">
        <source>replace(mask, newMask : String) : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	maskLen,
	newMaskLen,
	selfLen,
	currentPos,
	pos			: Integer;
	result		: String;
	
begin
	//handle exception casese first
	if self = null or mask = null then
		return self;
	endif;
	
	maskLen := mask.length;
	newMaskLen := newMask.length;
	
	//if both characters,use Jade
	if maskLen = 1 and newMaskLen = 1 then
		result := self;
		result.replaceChar(mask.Character, newMask.Character);
		return result;
	endif;
	
	//scan through self building up string
	result := null;
	currentPos := 1;
	selfLen := self.length;
	
	while currentPos &lt;= selfLen do
		pos := self.pos(mask, currentPos);
		if pos = 0 then //no more occurrences of mask
			result := result &amp; self[currentPos:end];
			break;
		endif;
		
		//if mask is somewhere after current pos then copy it up to result
		if pos &gt; currentPos then
			result := result &amp; self[currentPos:pos-currentPos];
		endif;
		
		//now copy replacement mask into result if there is one
		if newMaskLen &gt; 0 then
			result := result &amp; newMask;
		endif;
		
		//finally shift the current pos to the end
		currentPos := pos + maskLen;
	endwhile;

	return result;
end;</source>
        <Parameter name="mask" type="String"/>
        <Parameter name="newMask" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceAll_regex" id="da6e3164-cb4f-4f13-96a3-dd4452fc8560">
