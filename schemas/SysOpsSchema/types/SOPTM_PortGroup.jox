    <JadeMethod name="setupThumbnailDetails" id="074abe77-39f0-4d62-8f5c-fe4e6029a452">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
begin

  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_PortGroupTbl);
	

	//theForm.zAddColumn('Port Group Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	 
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_PortGroupMaint);
	theForm.shtTblInput1.visible := true;

	//Ports are now shown on separate sheet.  
	theForm.tblInput1.hideRowByName(ETRow_Ports,false);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="fb5edd64-1caa-40e6-8e84-66be9d158f08">
        <updating/>
        <source>showThumbnail(pPortGroup : CM_PortGroup) updating;

vars

	theForm : SOP_TableMaintForm;
	list:String;	
	first:Boolean;
	port:CM_Port;
begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pPortGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pPortGroup.description);
/*	first := false;
	foreach port in pPortGroup.allPorts do
		if (not first) then
			first := true;
			list := port.code.trimBlanks;
		else
			list := list &amp; ", " &amp; port.code.trimBlanks;
		endif;
	endforeach;
	theForm.tblInput1.setValueByName(ETRow_Ports, list);
*/	
	theForm.mulSelect1.setSelected(pPortGroup.allPorts);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pPortGroup" type="CM_PortGroup"/>
    </JadeMethod>
</Class>
