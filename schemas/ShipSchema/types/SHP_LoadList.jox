    <JadeMethod name="checkReceivalHalt" id="3bb06184-92c3-484f-9717-8c1d9d717f4c">
        <source>checkReceivalHalt(_theController : CMIF_OpCargoRecController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ops, label, voyCode : String;
	anOp : CM_Operator;
	invalidVoyage : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	if _theController.stopReceival then
		label := app.getErrorString(SHP_Unavailable);
	else
		label := app.getErrorString(SHP_Available);
	endif;
	voyCode := self.myCurrentVoyage.code;
	//10/10/08 cnwdz2 Par 17732
	if invalidVoyage then		
		app.msgBox(app.getErrorString(ERR_DELETED_VOYAGE),"",MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if self.lstOperators.allSelectedObjects.isEmpty then
		return app.msgBox(app.getErrorString(SHP_Voyage) &amp; voyCode &amp; ". " &amp;  app.getErrorString(SHP_Make_All_Operators) &amp; ' ' &amp; label &amp; app.getErrorString(SHP_For_Cargo_Receival),app.getErrorString(SHP_Confirm_Cargo_Receive), MsgBox_Yes_No) = MsgBox_Return_Yes;
	else
		foreach anOp in _theController.allOperators do
			if ops = null then
				ops := anOp.code;
			else
				ops := ops &amp; ", " &amp;  anOp.code;
			endif;
		endforeach;
		
		return app.msgBox(app.getErrorString(SHP_Voyage) &amp; voyCode &amp; ". " &amp; app.getErrorString(SHP_Make) &amp; ' ' &amp; ops &amp; " "  &amp; label &amp; app.getErrorString(SHP_For_Cargo_Receival),app.getErrorString(SHP_Confirm_Cargo_Receive), MsgBox_Yes_No) = MsgBox_Return_Yes;
		
	endif;
end;</source>
        <Parameter name="_theController" type="CMIF_OpCargoRecController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanUpInvalidObjects" id="6a9b1da4-708b-4f60-bc1b-af39e7d67b3f">
        <updating/>
        <source>cleanUpInvalidObjects(_table : CM_DataTable io) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2009 by cnwjo3
//
// Purpose:		There can be invalid objects in tables.  clean them up
//				21/4/2010 cnwjo3: not a par.  But I should clean this up!!!
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars
	idx : Integer;
	removeObjects : CM_ObjectSet;
	obj : Object;
	startFrom : Integer;
	theTI : CM_TrackedItem;
	invalid : Boolean;
	ct : TimeStamp;
begin
	on Exception do app.handleDeletedObject(exception, theTI, invalid);
	
	startFrom := _table.fixedRows;
	
	create removeObjects transient;
	foreach idx in startFrom to _table.rows do
		invalid := false;
		theTI := _table.CM_DataTable.accessRow(idx).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null then
			ct := theTI.createdTime;
			//if not app.isValidObject(theTI) then
			if invalid then
				removeObjects.add(theTI);
			endif;
			//endif;
		endif;
	endforeach;

	foreach obj in removeObjects do
		_table.cnEcRemoveObjectRow(obj);
	endforeach;
epilog
	delete removeObjects;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clearAllFilters" id="b2c60170-ca43-4050-9b49-eb9c76ee1875">
        <updating/>
        <source>clearAllFilters() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation	Par 25297

*/

vars

begin

	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		if self.allColumnFilters.includesFiltersFor( self.tblData ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
			self.applyColumnFilter( self.tblData );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblPlanned ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblPlanned, null );
			self.applyColumnFilter( self.tblPlanned );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblDLR ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblDLR, null );
			self.applyColumnFilter( self.tblDLR );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblAll ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblAll, null );
			self.applyColumnFilter( self.tblAll );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblTranShip ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblTranShip, null );
			self.applyColumnFilter( self.tblTranShip );
		endif;
		if self.allColumnFilters.includesFiltersFor( self.tblTBA ) then // TFS 45590
			self.allColumnFilters.replaceAllFiltersForTable( self.tblTBA, null );
			self.applyColumnFilter( self.tblTBA );
		endif;
		self.setFormCaption();
	endif;

epilog

end;</source>
    </JadeMethod>
