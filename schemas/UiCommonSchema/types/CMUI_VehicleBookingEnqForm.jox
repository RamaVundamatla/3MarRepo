    <JadeMethod name="initTableData" id="b4b359b7-ef7d-4e06-9875-bc2b9eeea7fa">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
*/

vars
	entTableDef 		: EntTableDef;
	tbl					: CM_DataTable;
begin
	inheritMethod(_theEntDef);

	entTableDef := app.myController.getEntTableDef(_theEntDef);
	tbl			:= self.tblData;	
	tbl.rows 	:= tbl.fixedRows;
	
	tbl.setTblDataEntRowsFromDef(entTableDef);

	tbl.setMyDataClass(CM_VehicleBookingTimeSlot);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
	
epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFilter" id="4a017162-40cd-4856-9217-bf2b40ef7711">
        <updating/>
        <source>populateCriteriaFilter() updating;
/*

Purpose:			
	This will be used to build all of the combos used for criteria filtering 
Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
22 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12
*/

vars

begin
	self.buildCmbSlotType();
	self.buildCmbCarrier();
	self.buildCmbSubCarrier();
	self.buildCmbDirection();
	self.buildCmbStatus();
	self.buildCmbType();	
	self.mskStartDate.setDate(app.cnGetServerTime().Date);
	self.mskEndDate.setDate(app.cnGetServerTime().Date);
	self.buildCmbMonth();
	self.buildCmbCreationMethod();								//14.07.2023 navma1 #59136
	self.buildCmbOperator();									//22.11.2023 navlc30 #61256
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateVbsSlots" id="fe4938fd-975a-4445-9d9c-ec22769b7fe2">
        <updating/>
        <source>populateVbsSlots(_allVBSTimeSlots : CM_VehicleBookingTimeSlotById; _isFromSelector : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
19 May 2023		navlw1	Initial creation CR 53902 EUP - VBS MTN - [6] - Selector Query and JRW
*/
vars
	tbl					: CM_DataTable;
	vehicleBookingItem	: CM_VehicleBookingTimeSlot;
	idx					: Integer;
	theDataLine			: String;
	vbTerminal			: CM_VehicleBookingTerminal;	// 23.12.2022 navak20 TFS 55979
	index 				: Integer;		// 23.12.2022 navak20 TFS 55979
begin
	vbTerminal := self.myTerminal.myVehicleBookingTerminal;		// 23.12.2022 navak20 TFS 55979
	tbl := self.tblData;
	
	self.mnuSendToReport.visible := true; //19/05/2023 navlw1 tfs 53902 
	
	foreach vehicleBookingItem in _allVBSTimeSlots //19/05/2023 navlw1 tfs 53902 
	do
		//19/05/2023 navlw1 tfs 53902
		if not _isFromSelector and not self.includeObject(vehicleBookingItem) then
			continue;
		endif;
		
		if idx &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		theDataLine := vehicleBookingItem.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		index := tbl.addItem(theDataLine);	// 23.12.2022 navak20 TFS 55979
		//tbl.accessRow(tbl.addItem(theDataLine)).itemObject := vehicleBookingItem;		// 23.12.2022 navak20 TFS 55979
		tbl.accessRow(index).itemObject := vehicleBookingItem;		// 23.12.2022 navak20 TFS 55979
		idx := idx + 1;
	endforeach;
	
	self.frmQuery.visible := (tbl.rows &lt;= tbl.fixedRows);
	self.numRows := tbl.rows - tbl.fixedRows;											//24.4.2023 navhl20 #57716[57718]
	self.staStatusBar.caption := (tbl.rows - tbl.fixedRows).String &amp; " rows found.";	//24.4.2023 navhl20 #57716[57718]
	
end;</source>
        <Parameter name="_allVBSTimeSlots" type="CM_VehicleBookingTimeSlotById"/>
        <Parameter name="_isFromSelector" type="Boolean"/>
    </JadeMethod>
