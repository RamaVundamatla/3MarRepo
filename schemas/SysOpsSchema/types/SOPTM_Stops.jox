    <JadeMethod name="setControlsForAddEdit" id="ddede9c0-d4fb-4a08-a2f3-4a4c6f93fc2c">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//15/07/2022 	navds20 		ChangeRequest 53943: MTN - Dbl-Click to Add Place holder text missing in Hook Code while adding
//29 July 2022  navhl20 		TFS 53862 EUP - WMS - Damage Recording Extra Details
//19 Sept 2022  navds21         Bug 54861: Place holder text missing and mismatch 
// 06/11/2023	navkc1 			Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
// ---------------------------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;
	etRowEdit : Boolean;
	theRow    : Integer;  //19/09/2022 navds21 TFS 54861
begin
	
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.btnSingle1Edit.enabled := false; //ccms1824 cnwrs1 may 2009
	theForm.mulSelect1.userInputEnabled := true;
	theForm.shtDataTable1.enabled	:= true;	//06 Nov 2012	NDL	Par 24203
	if theForm.mode = theForm.Mode_Add then
		theForm.btnSingle1Edit.enabled:=true; //ccms1824 cnwrs1 may 2009
		theForm.shtSingleSelect2.visible := false; //ccms1824 cnwrs1 may 2009
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.shtDataTable1.enabled	:= false;	//06 Nov 2012	NDL	Par 24203
		// 06/11/2023	navkc1 Bug 61094 - Display this, allow user to set the criteria while Adding new stop
		//theForm.tblInput1.hideRowByName(ETRow_SetCriteria,false);		//29.07.2022 navhl20 TFS 53862 
		theForm.tblInput1.setValueByName(ETRow_SetCriteria, "Dbl-Click to add"); //06/11/2023	navkc1 Bug 61094
		theForm.tblInput1.setValueByName(ETRow_HookCode,"Dbl-Click to add"); // 19/09/2022 navds21 TFS 54861
	elseif theForm.mode = theForm.Mode_Update then
		theForm.btnSingle1Edit.enabled := true; //ccms1824 cnwrs1 may 2009
	endif;
	
	//theForm.tblInput1.setValueByName(ETRow_HookCode,"Dbl-Click to View"); //15/07/2022 navds20 TFS 53943 		// 19/09/2022 navds21 TFS 54861
	if theForm.mode = theForm.Mode_Update and 
	   theForm.mulSelect1.isMySheetVisible then
		theForm.mulSelect1.setFocus;
	else
		theForm.tblInput1.setFocus;
		theForm.fldInput.initSheetBackColors();	
	endif;
	
	self.enableMulSelect1Contents();
	theForm.tblInput1.moveFirst();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="0ff63c3a-a712-49d0-a10f-30af7529bb5f">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.btnDT1_Edit.enabled			:= false;
	//theForm.btnSingle1Edit.enabled := false;  //ccms1824 cnwrs1 may 2009
	//theForm.shtSingleSelect2.visible := true; //ccms1824 cnwrs1 may 2009
	theForm.shtDataTable1.enabled	:= true;	//06 Nov 2012	NDL	Par 24203
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDisplayForTerminal" id="c8747eb0-a4a4-4a45-abcc-8bd2d8c8e31e">
        <source>setTableDisplayForTerminal(_stt :CM_StopTableTemplate; _table :CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:     05 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
	applyArea, preventArea, processArea : Integer;
	voyage 		: CM_Voyage;
	terminal	: CM_Terminal;
	eventRequest : CM_EventRequest;
begin
	if _stt.isNotSet then
		_table.addItemObject (null, "Not Setup");
	else
		terminal := _stt.myTerminal;
		
		_table.addItemObject (terminal, 'Is Child Ignore' &amp; Tab &amp; _stt.isChildIgnore.getYesNo);
		_table.addItemObject (terminal, 'Is Child Only' &amp; Tab &amp; _stt.isChildOnly.getYesNo);
		_table.addItemObject (terminal, 'Is Coastal Ignore' &amp; Tab &amp; _stt.isCoastalIgnore.getYesNo);
		_table.addItemObject (terminal, 'Is Coastal Only' &amp; Tab &amp; _stt.isCoastalOnly.getYesNo);
//		_table.addItemObject (terminal, 'Is Tranship Ignore' &amp; Tab &amp; _stt.isTranshipIgnore.getYesNo);
//		_table.addItemObject (terminal, 'Is Tranship Only' &amp; Tab &amp; _stt.isTranshipOnly.getYesNo);
		_table.addItemObject (terminal, 'Is Full' &amp; Tab &amp; _stt.isFull.getYesNo);
		_table.addItemObject (terminal, 'Is MT' &amp; Tab &amp; _stt.isMT.getYesNo);
		
		foreach applyArea in _stt.allApplyAreas do
			if tmpStr = null then
				tmpStr := _stt.myStopTable.convertTypeToString(applyArea);
			else
				tmpStr := tmpStr &amp;',' &amp; _stt.myStopTable.convertTypeToString(applyArea);
			endif;
		endforeach;
	
		_table.addItemObject (terminal, 'Set Stops On' &amp; Tab &amp; tmpStr);
		
		tmpStr := null;
		
		foreach preventArea in _stt.allPreventAreas do
			if tmpStr = null then
				tmpStr := _stt.myStopTable.convertTypeToString(preventArea);
			else
				tmpStr := tmpStr &amp;',' &amp; _stt.myStopTable.convertTypeToString(preventArea);
			endif;
		endforeach;
		
		_table.addItemObject (terminal, 'Stops Prevent Actions' &amp; Tab &amp; tmpStr);
		
		tmpStr := null;
		foreach processArea in _stt.allProcessAreas do
			if tmpStr = null then
				tmpStr := _stt.myStopTable.convertTypeToString(processArea);
			else
				tmpStr := tmpStr &amp;',' &amp; _stt.myStopTable.convertTypeToString(processArea);
			endif;
		endforeach;
		
		_table.addItemObject (terminal, 'Processing Options' &amp; Tab &amp; tmpStr);
	
		tmpStr := null; //ccms1824 cnwrs1 May 2009
		
		foreach voyage in _stt.allHoldVoyages do
			if tmpStr = null then
				tmpStr := voyage.code;
			else
				tmpStr := tmpStr &amp;',' &amp; voyage.code;
			endif;
		endforeach;
		_table.addItemObject (terminal, 'Hold Voyages' &amp; Tab &amp; tmpStr);
		
		
		//02 May 2019	NDL	TFS 43918
		tmpStr := null;
		foreach eventRequest in _stt.allEventRequests do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; CrLf;
			endif;
			tmpStr := tmpStr &amp; eventRequest.typeString &amp; "-" 
					&amp;	eventRequest.CM_EventRequestForStop.getUpdateDetails;
		endforeach;
		_table.addItemObject (terminal, 'Stop Event Requests' &amp; Tab &amp; tmpStr);
		
	endif;
end;
</source>
        <Parameter name="_stt" type="CM_StopTableTemplate"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="69f91c28-b99e-4f0c-ab7c-98eace90226d">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;
	dict : CM_CargoBOLTypeByIdDict;
begin
	theForm := self.myForm;
	theForm.setTblDataEntRows(ETDef_StopsTable);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Id, false);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_StopsMaint);
	theForm.shtTblInput1.visible := true;
	theForm.shtMultiSelect1.caption := 'Cargo Attributes';
	theForm.mulSelect1.formDisplayEntryMethodName := 'displayEntryCargoType';
	theForm.mulSelect1.availableHeading := 'Cargo Types available';
	theForm.mulSelect1.selectedHeading  := 'Cargo Types selected';
	create dict transient;
	app.myRoot.allCargoTypesById.copy(dict);
	app.myRoot.allBOLTypes.copy(dict);
	theForm.mulSelect1.setAvailable(dict, true);

	//----- Stops Stuff
	theForm.fldInput.topSheet := theForm.shtTblInput1;
epilog
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4c9fe083-5ce2-4439-8dfe-b2cf7bff0900">
        <updating/>
        <source>showThumbnail(_stopTable: CM_StopsTable) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//01/07/2022    navds20 	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//27 Jul 2022	navsj20		TFS 53862	EUP - WMS - Damage Recording Extra Details
//19 Sept 2022  navds21     Bug 54861: Place holder text missing and mismatch 
// ---------------------------------------------------------------------------

vars
	theRow 				: Integer;
	theForm 			: SOP_TableMaintForm;
	stopTableTemplate 	: CM_StopTableTemplate;
	terminal 			: CM_Terminal;
	table				: CM_DataTable;
	criteria 			: CM_YACriteria;	//27 Jul 2022	navsj20	TFS 53862
begin 
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
    self.getTerminalsForUser();
 
    self.myCurrentTerminal := self.allTerminalsForThisUser.first;
    

	theForm.chkFullsOnly.visible := false; //ccms1824 cnwrs1 may 2009
	theForm.chkMTsOnly.visible := false; //ccms1824 cnwrs1 may 2009
	theForm.tblInput1.setValueByName(ETRow_Id, _stopTable.id);
	theForm.tblInput1.setValueByName(ETRow_Heading, _stopTable.heading);

	theForm.tblInput1.setValueByName(ETRow_Code, _stopTable.code);
	theForm.tblInput1.setValueByName(ETRow_ShortHeading, _stopTable.shortHeading);
	theForm.tblInput1.setValueByName(ETRow_RequiresInfo, _stopTable.requiresInfo);
	
		
	if _stopTable.requiresInfo then
		theForm.tblInput1.showRowByName(ETRow_CustomsInfoEntry, false);
	else
		theForm.tblInput1.hideRowByName(ETRow_CustomsInfoEntry, false);
	endif;
	
	
	//theForm.chkRequestedInfo.value := _stopTable.requiresInfo; //cnwrd1 par #18271 12.5.09
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _stopTable.isNotAvailableForEntry);
	
	theForm.tblInput1.setValueByName( ETRow_AllowClearanceExpiryDate, _stopTable.allowClearanceExpiryDate );	// cnwrl1 08/12/2009 PAR 21889
	
	//epr TFS 1946 26/5/16 first time stops selected and new clicked wasn't loading the combo
	if theForm.mode = theForm.Mode_Add then 
		self.myForm.cmbCustomEntry.setIndex(0);
	else
		self.myForm.cmbCustomEntry.setIndexForItemData(_stopTable.requiresInfoType);
		theForm.tblInput1.setValueByName(ETRow_CustomsInfoEntry, _stopTable.requiresInfoString());
	endif;
	
	// START 20 Jul 2022	navsj20	TFS 53862
	//theForm.mulSelect1.setSelected(_stopTable.allCargoTypesNew);	
	if _stopTable.myStopCriteria &lt;&gt; null then
		foreach criteria in _stopTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do 				//27 Jul 2022	navsj20	TFS 53862
			theForm.mulSelect1.setSelected(criteria.myYAData.CM_YADataObjects.allObjects);
		endforeach;				//27 Jul 2022	navsj20	TFS 53862
	endif;
	// END 20 Jul 2022	navsj20	TFS 53862
	theForm.shtTblInput1.cnEcResizeContents;
	self.disableMulSelect1Contents();
	
	theRow := theForm.tblInput1.showRowByName(ETRow_HookCode, false);
	self.jadeCode := _stopTable.getJadeCode(); //par17724 cnwrs1 aug 2008
	if theForm.mode = theForm.Mode_View then
		theForm.tblInput1.setValue(theRow, 'Dbl-Click to view');
	else
		//theForm.tblInput1.setValue(theRow, 'Dbl-Click to update'); // 19/09/2022 navds21 TFS 54861
		theForm.tblInput1.setValue(theRow, 'Dbl-Click to edit'); // 19/09/2022 navds21 TFS 54861
	endif;
	theForm.lstSingleSelect1.listCollection(self.allTerminalsForThisUser, false, 0); //ccms1824 cnwrs1 may 2009
	
	//01/07/2022 navds20 TFS 53862
	theRow := theForm.tblInput1.showRowByName(ETRow_SetCriteria, false);
	theForm.tblInput1.setValue(theRow, _stopTable.getStopCritDisp);
	//01/07/2022 navds20 TFS 53862
	
	theForm.tblInput1.setValueByName(ETRow_ExcludedForPinGeneration, _stopTable.excludedForPinGeneration);	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	
	// concms1 par 19830 june 2009
	self.showThumbnail_Terminal (_stopTable);
	// par 19830 - end

end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail_Terminal" id="3a2a94cf-77a1-4b5f-8fb3-7e92fc15d880">
        <source>showThumbnail_Terminal(_stopTable :CM_StopsTable)protected;
// ---------------------------------------------------------------------------
// Created:     08 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table		:CM_DataTable;
	terminal	:CM_Terminal;
	row			:Integer;
	template	:CM_StopTableTemplate;
begin
	table 		:= self.myForm.tblData1;
	table.rows 	:= 0;

	
	foreach terminal in self.allTerminalsForThisUser do		
		row 	:= table.addItemObject (terminal, app.getErrorString (Terminal) &amp; ': ' &amp; terminal.code);
		table.accessRow(row).fontBold := true;
		table.accessRow(row).backColor := Gray;

		template := _stopTable.allStopTableTemplates[terminal, _stopTable];
		
		if template = null then
			row := self.myForm.tblData1.addItemObject (terminal, app.getErrorString (Not_Setup));
		else
			self.setTableDisplayForTerminal(template, table);
		endif;
	endforeach;
	// par 19830 - end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
</Class>
