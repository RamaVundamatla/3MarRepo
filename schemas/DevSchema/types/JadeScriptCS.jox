<Class name="JadeScriptCS" id="ff95c140-bb03-4c2c-a8a9-fbc037fa53ab">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="addingRootDebtor" id="b1253af8-20c8-4453-b607-b6285af902b0">
        <source>addingRootDebtor();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2022	navcs2	Initial creation

*/

vars
	paymentType			 	: Integer;					
	usesCash 				: Boolean;
	currencyType 			: CM_CurrencyType; 
	locale 					: CM_Locale; 		
	defaultInvoiceJRW 		: String;
	terminal				: CM_Terminal;
	theBank					: CM_Bank;
	rdg						: CM_Debtor;
	allTerminals			: CM_TerminalByCodeDict;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.rootDebtor;
	allTerminals := app.myRoot.allTerminals;
		
	foreach terminal in allTerminals do
		if not rdg.CM_Debtor.allDebtorTerminals.includesKey( terminal ) then
			paymentType			:= PaymentType_None; 
			usesCash 			:= false;
			currencyType 		:= null; 	
			locale 				:= null; 
			defaultInvoiceJRW 	:= null; 

			beginTransaction;
			rdg.CM_Debtor.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW, "", ""); 
			commitTransaction;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createWorkOrder" id="23f3626d-3835-42bd-8532-72c4b0c5c56a">
        <source>createWorkOrder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2022	navcs2	Initial creation
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
14 Mar 2023 navma1  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
*/

vars
	pxyRequest : CM_WorkOrderRequestByType;
	pxyWorkOrderSource : CM_WorkOrderTISource;
	availGrades	: IntegerArray;
	cargoType: CM_CargoType;
	cargoList : String;
	root: CM_Root;
	totalReq : Integer;
	dtStart	: 	TimeStamp;
	remarks : String;
	emails : CM_EmailEntityByTypeNameDict;
	operator: CM_Operator;
	terminal 		: CM_Terminal;
	realWorkOrder	: CM_WorkOrder;
	pxyWorkOrder	:  CM_WorkOrderToDo;
	pxyWODtl,
	realWODtl 		: CM_WodToDoVBS;
	autoQ,
	autoRTQ 		: Boolean;
	taskType 		: Integer;
	dtRequired		: TimeStamp;
	toDoTaskID 		: Integer;
	toDoTaskDesc 		: CM_ToDoTaskDesc;
	allVBSSlots		: CM_VehicleBookingTimeSlotById;
begin
	app.initialize();
	create emails transient;

	create pxyWorkOrder transient;
	
	create pxyWODtl transient;
	
	create allVBSSlots transient;
	
	allVBSSlots.add(app.getTerminalByName("Callums Terminal").myVehicleBookingTerminal.allVBTimeslotsById.last);
	allVBSSlots.add(app.getTerminalByName("Callums Terminal").myVehicleBookingTerminal.allVBTimeslotsById.first);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["ADPOT"]; 
	
	pxyWorkOrder.setProxy(		
			emails, 										//_allEmailAddresses
			null, 											//_customerReference
			false, 											//_emailNotification
			app.actualTimeServer, 							//_enteredByDT
			app.getMyUser(), 								//_enteredByUser 
			'',												//_approvedBy
			null, 											// _myOrganisation
			app.getTerminalByName("Callums Terminal"), 		//_myTerminal
			remarks,  										//_remarks
			app.actualTimeServer().addDays(2),				//_requiredByDT
			app.actualTimeServer().addDays(1), 				//_startAtDT
			WO_STATUS_PENDING 								//_taskStatus
			);
			
	//pxyWODtl.CM_WodToDoVBS.setProxyAllVbsSlots(allVBSSlots);						//14.03.2023 navma1 #56840:[54265]

	pxyWorkOrder.setProxyWorkOrderTask(
										pxyWODtl,
										app.actualTimeServer().addDays(2), 			// required by date/time
										app.actualTimeServer().addDays(1),			// start at date/time
										autoQ,  									// auto queue task for BGP
										WO_TASK_ToDo_VBS, 							// task type constant
										toDoTaskDesc);								// todo task if needed

					
	
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder, app.myPassport);
	
epilog
	delete pxyWorkOrder;
	delete emails;
end;</source>
    </JadeMethod>
    <JadeMethod name="csTestScript" id="bc6568bb-4310-4898-ad57-d91f56594d64">
        <source>csTestScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navcs2	Initial creation

*/

vars
	agent 		: PortSchema_20_0_21;
begin
	app.initialize();
	
	app.changeLogLevel(LogDEBUG);
	
	create agent transient;
	
	agent.addPrimaryTaskFieldDefaults(null);
	
	if app.myPassport.hasErrorsOrWarnings then
		app.myPassport.inspectModal();
	endif;
	
epilog
	delete agent;
end;</source>
    </JadeMethod>
</Class>
