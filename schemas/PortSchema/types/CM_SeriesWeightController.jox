<Class name="CM_SeriesWeightController" id="0ece585c-e57c-4dd0-b2ac-0077a74f0a73">
    <superclass name="CM_WeightIntController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="generateDevTestData" id="70fbc1b4-4c3e-4fa4-a15c-2cd0a072983d">
        <source>generateDevTestData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

	randomNum : Integer;
	strResponse : String;
	binResponse : Binary;
	weight : Decimal[16,4];

begin

	/*
	normal response message format - length = 14.
	stx 			1 		= '&amp;'
	deviceAddress	2-3		= A two digit numerical field representing the weigh bridge internal address.
	weight	 		4-9 	= 6 characters to represent the number of units of weight the first may be a '-' indcating a negative value
	type			10		= 't' = Gross weight
	backslash		11		= '\'
	checksum		12-13	= 
	etx				14		= Cr, The 'Carriaage return' character	
	
	This is as best we can determine based on Page 5, item 2 of the PDF attached to TFS 2862
	
	*/

	randomNum := app.random(8);
	
	if randomNum = 1 then
		strResponse := "&amp;01012192t\75" &amp; Cr;
	elseif randomNum = 2 then
		strResponse := "&amp;01011376t\75" &amp; Cr;
	elseif randomNum = 3 then
		strResponse := "&amp;01011000t\75" &amp; Cr;
	elseif randomNum = 4 then
		strResponse := "&amp;01011500t\75" &amp; Cr;
	elseif randomNum = 5 then
		strResponse := "&amp;01013208t\75" &amp; Cr;
	elseif randomNum = 6 then
		strResponse := "&amp;01011939t\75" &amp; Cr;
	elseif randomNum = 7 then
		strResponse := "&amp;01014000t\75" &amp; Cr;
	elseif randomNum = 8 then
		strResponse := "&amp;01011753t\75" &amp; Cr;
	endif;
	
	binResponse := strResponse.Binary;
	
	weight := self.getWeight( binResponse );
	
	self.myWeightCallerInterface.sendWeight(weight);

epilog

end;</source>
    </JadeMethod>
