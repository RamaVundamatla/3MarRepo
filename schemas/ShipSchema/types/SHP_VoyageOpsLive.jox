    <JadeMethod name="mnuCustomerPriorityBtn_click" id="9982e26f-287a-4352-9ab0-e935eadf9a70">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCustomerPriorityBtn_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
08 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

	customerPriority : CM_CustomerPriority;
	button : Button;
begin
	if self.mnuCustomerPriorityBtn.userObject.isKindOf(Button) then
		button := self.mnuCustomerPriorityBtn.userObject.Button;
	endif;
	
	if button &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_CustomerPriority) then
			customerPriority :=  menuItem.userObject.CM_CustomerPriority;
			button.caption := customerPriority.code;
			button.userObject := customerPriority;
		endif;
	endif;

	self.myCustomerPriority1 := self.btnCustomerPri1.userObject.CM_CustomerPriority;
	self.myCustomerPriority2 := self.btnCustomerPri2.userObject.CM_CustomerPriority;
	self.myCustomerPriority3 := self.btnCustomerPri3.userObject.CM_CustomerPriority;


epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
