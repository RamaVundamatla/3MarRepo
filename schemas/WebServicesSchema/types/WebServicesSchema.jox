    <JadeMethod name="handleJADEParsingException" id="41195288-bf73-46bf-81f8-4af4e50e1548">
        <source>handleJADEParsingException(_exc : Exception) : Integer;

/*

Purpose:			Global exception handler to catch any exceptions during the JADE framework's
					parsing of the incomong XML messages.
					Will just do a minidump of the exception, and abort the current action.

Parameters:			Exception object

Return Value:		Standard exception return code


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
18 Dec 2013	cnwkpd1	PAR #33225 - Invalid session exception under certain conditions
27 Jan 2016	cnwkpd1	PAR #35261 - Changes for JADE 7.1
01 Jul 2016	cnwkpd1	TFS 2249 - Default to no dump, but allow runtime configuration of a full dump

*/

constants
	ObjectNotFound	= 4;
	Dummy = 'Dummy';
		
vars
	cc				: CnCntrl;
	str				: String;
	stackDump		: CnStackDump;
	saveMini,
	ignoreDump		: Boolean;
	iniValue		: String;
	
begin
	cc := app.myCnCntrl;
	saveMini := cc.logMiniStackDump;

	app.writeLog("Exception handler is " &amp; method.qualifiedName, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	
	str := "Exception " &amp; _exc.errorCode.String &amp; "  (" &amp; _exc.text &amp; ")  in application " &amp; process.getProcessApp().name &amp;
		   " (application type = " &amp; app.cnGetApplicationType &amp; "), extendedErrorText=" &amp; _exc.extendedErrorText;

	app.writeLog(str, LogERROR);	//26 Nov 2019	NDL	TFS 47053

	// PAR #33225 - Specifically ignore exceptions on Web Session objects
	if _exc.errorCode = ObjectNotFound and _exc.errorObject.isKindOf(SWebServiceSchema) then
		app.writeLog("Error object is a Web Session, ignoring dump", LogERROR);	//26 Nov 2019	NDL	TFS 47053
		ignoreDump := true;
	endif;
	
	// TFS 2249 - Check ini file for setting to decide whether or not to dump
	if not ignoreDump then
		iniValue := app.getProfileStringMyIni(JMTWebService_Section, JMTWebService_DumpType, Dummy);
		if iniValue = Dummy then
			iniValue := 'None';
			app.setProfileStringMyIni(JMTWebService_Section, JMTWebService_DumpType, iniValue);		// set default in the ini file
		endif;
		
		iniValue := iniValue.toLower();
		
		if iniValue = 'none' then
			// do nothing
		else
			cc.setLogMiniStackDump(iniValue = 'mini');
			create stackDump transient;
			stackDump.dumpStack(_exc);
		endif;
	endif;
	
	app.writeLog("Aborting transaction and returning Ex_Abort_Action", LogERROR);	//26 Nov 2019	NDL	TFS 47053
	
	abortTransaction;
	abortTransientTransaction;
	
	return Ex_Abort_Action;
	
	
epilog
	cc.setLogMiniStackDump(saveMini);
	delete stackDump;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromWebConfig" id="388bd90c-29f2-49d8-95f4-ae9caf2c5947">
        <updating/>
        <source>initFromWebConfig(_config : CM_WebSiteConfig) protected, updating;

/*

Purpose:			Validate the required settings on the passed in Web Config

Parameters:			None

Return Value:		None, will terminate on error, and will set values from the passed in config if
					everything is OK


Date		Who		Reason
22 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
09 Feb 2009	cnwkpd1	Add Help File URL
19 Jun 2020 jlgmd1	49615	Add validation to prevent 'important system' users from being disabled/deleted
16 Feb 2021	navmd1	Made fatal error messages a little clearer

*/

vars
	folder			: FileFolder;
	startStr		: String;
	
begin
	startStr := 'Web Config [' &amp; _config.name &amp; ']';
	
	// Check it's the right type of config
	if not _config.isWebServiceConfig then
       	self.writeLog(startStr &amp; ' is not a Web Service configuration - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
       	terminate;
	endif;
	
	// Validate download directory
	if _config.downloadFileDirectoryPath = null then
		self.writeLog(startStr &amp; ': Download File Directory not defined - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	else
		self.downloadFileDirectoryPath := _config.downloadFileDirectoryPath.stripTrailingSlashes &amp; "/";
		create folder transient;
		folder.fileName := self.downloadFileDirectoryPath;
		if not folder.isAvailable() then
			self.writeLog(startStr &amp; ': Download File Directory [' &amp; self.downloadFileDirectoryPath &amp; '] is not available - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
			terminate;
		endif;
	endif;
	
	// Validate download URL
	if _config.downloadFileDirectoryURL = null then
		self.writeLog(startStr &amp; ': Download File Directory URL not defined - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	else
		self.downloadFileDirectoryURL := _config.downloadFileDirectoryURL.stripTrailingSlashes &amp; "\";
	endif;
	
	// Download file timeout has a minimum of 1 minute
	self.downloadFileTimeout := _config.downloadFileTimeout.max(1);
	
	// Validate anonymous User
	self.myPublicUser := app.myRoot.allUsers[_config.publicUser];
//	if self.myPublicUser = null or self.myPublicUser.isDisabled then
	if self.myPublicUser = null then	 //23 Nov 2020	NDL TFS 50378
		self.writeLog(startStr &amp; ': Public user not defined - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	elseif self.myPublicUser.isSuspendedOrIsDisabled() then
		self.writeLog(startStr &amp; ': Public user [' &amp; _config.publicUser &amp; '] or disabled or suspended - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
	// Set up Printer
	self.myPDFPrinter := _config.myPDFPrinter;
	
	// Set up Help File URL
	self.helpFileURL := _config.helpFileURL;
	
	self.downloadFileRemoteCopy := _config.downloadFileRemoteCopy;// 27/07/2010 cnwdz2 24674
	
	// Override/set the logging level
	if _config.defaultLoggingLevel &gt; 0 then
		// The log level is shifted by 1 here, to handle 0 meaning "not entered"/default and also meaning INFO &gt;.&lt;
		self.changeLogLevel(_config.defaultLoggingLevel - 1);	// TFS 51054 navmd1 01/04/21
	endif;
	
	// And finally set up Web Config reference
	self.myWebConfig := _config;
	
		
epilog
	delete folder;
	
end;</source>
        <access>protected</access>
        <Parameter name="_config" type="CM_WebSiteConfig"/>
    </JadeMethod>
    <JadeMethod name="initInternalAPI" id="e121a142-082a-4fdb-9c57-8a3e79d6c27f">
        <updating/>
        <source>initInternalAPI() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 July 2023	navcs2	Bug 55248: MTN - InternalAPI doesn't terminate if no web config is found

*/

vars
	root : CM_Root;
	msg  : String;
	cmdLine			: String;
	config			: CM_WebSiteConfig;
begin
	self.initialize();
	
	// Ensure no pass back to JADE exception handler
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);		
	
	root := self.myRoot;
	if root = null or not root.canDo(Mod_Webservice) then
		msg := 'System is not licensed to run JMT Rest Service application  - terminating';
		app.writeLog(msg, LogFATAL);	
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
		terminate;
	endif;

	// Initialise settings
	self.isWebApp:=true;
	// this is to set the public user if needed
	cmdLine := self.getUserCommandLine(false);
	
	app.writeLog(cmdLine, LogINFO);
	
	if cmdLine = null then
		app.writeLog('No command line', LogINFO);
		
		// Try and work out if there is a sensible config to use
		
		// If there is only 1 in the system, then just use that one
		if app.myRoot.allWebSiteConfigs.size = 1 then
			config := app.myRoot.allWebSiteConfigs.first;
		endif;
		
		// Otherwise, if we are just debugging in a Development environment, then auto select the Debug one
		executeWhen JMTDevelopmentEnvironment;
			config := root.allWebSiteConfigs["WebServiceDebug"];
		endExecuteWhen;
	else
		config := self.getWebSiteConfigFromCmdLine(cmdLine);
	endif;
	
	if config = null then
		msg := 'No Web Config found or selected - terminating';
		self.writeLog(msg, LogFATAL);
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
       	terminate;
	else
		self.initFromWebConfig(config);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTExtInterfaceService" id="3898dd15-5783-43ca-9379-daaec4b5e147">
        <updating/>
        <source>initJMTExtInterfaceService(_initializeParam : Object) updating;

/*

Purpose:			Initialize method for JMTExternalInterfaceService app

Parameters:			

Return Value:		


Date		Who		Reason
04 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
07 May 2018	jlgkpd1	TFS #37190 - Add facility for INI file default user

*/

constants
	IniSection		= "JMTExternalInterfaceService";
	IniDefUserIPN	= "DefaultUsercodeINAPORTNET";
	IniDefUserNone	= "&lt;none&gt;";
	IniDummy		= "Dummy";
	
vars
	root			: CM_Root;
	msg				: String;
	iniFile			: String;
	iniValue		: String;
	
begin
	self.initialize();
	
	// Ensure no pass back to JADE exception handler
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);		// PAR #24010
	
	// Check application licensing
	root := self.myRoot;
	if root = null or not root.canDo(Mod_Webservice) then
		msg := 'System is not licensed to run External Interface Web Service application  - terminating';
		app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
		terminate;
	endif;

	// Initialise settings
	self.setAsWebApp();
	
	// Now need to single thread through INI file check for default usercode(s), to ensure only one copy creates
	// an emtpy section if required
	reserveLock(global);
	iniFile := app.getIniFileName();
	iniValue := app.getProfileString(iniFile, IniSection, IniDefUserIPN, IniDummy);
	
	// No INI file entry, then create one
	if iniValue = IniDummy then
		app.writeLog("Setting default value for [" &amp; IniSection &amp; "] " &amp; IniDefUserIPN, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.setProfileString(iniFile, IniSection, IniDefUserIPN, IniDefUserNone);
		iniValue := IniDefUserNone;
	endif;
	
	// Set the app default usercode if there is one
	if iniValue &lt;&gt; IniDefUserNone then
		app.defaultUsercodeForInaportnet := iniValue.trimBlanks().toUpper()[1:10];
		app.writeLog("Default usercode for INAPORTNET set to " &amp; app.defaultUsercodeForInaportnet, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	else
		app.writeLog("[" &amp; IniSection &amp; "] " &amp; IniDefUserIPN &amp; " is " &amp; IniDefUserNone &amp; " - no default INAPORTNET user", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	endif;
	
	// Finally, arm global exception handler for JADE parsing exceptions
	on Exception do app.handleJADEParsingException(exception) global;
	
epilog
	unlock(global);
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
