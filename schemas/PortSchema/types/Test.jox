    <JadeMethod name="table1_click" id="c325d192-a575-4cf5-b44a-47c4b91b5191">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>table1_click(table: Table input) updating;
vars
	cell	: JadeTableCell;
	txtBox	: TextBox;
begin
	if table.column = 2 then
		cell := table.accessCell(table.row, table.column);
		cell.backColor := LightYellow;
		if TextBox.hasInstance(cell.cellControl) then
			txtBox := cell.cellControl.TextBox;
			txtBox.selStart := 0;
			txtBox.selLength := -1;
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
