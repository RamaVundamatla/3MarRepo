    <JadeMethod name="generateCheckDigit" id="8be8a34a-12d9-4907-887f-0e11308ced68">
        <source>generateCheckDigit(_seq : Real):Integer64;
/*

Purpose:			
	Calculation of Check Digits According to ISO 7064 MODULUS 97-10			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2022	navsrk20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation

*/
constants
	MODULUS97   : Integer64 = 97;
vars
	tmp         : String;
	checkDigit : Real;
	result      : Integer64;
	
begin
	
	//Step1 append two zeroes to occupy the check character positions
	tmp :=  _seq.String &amp; '00';
	
	//Step 2: Mod by 97
	checkDigit := tmp.asRealJMT mod MODULUS97;
	
	//Step 3: determine the check character value as (97 + 1) - result from Step2
	
	checkDigit := (MODULUS97+1) - checkDigit;
	
	result := checkDigit.String.asInteger64JMT();
	
	return result;
epilog
end;</source>
        <Parameter name="_seq" type="Real"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
