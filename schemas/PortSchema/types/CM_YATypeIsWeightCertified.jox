<Class name="CM_YATypeIsWeightCertified" id="189860d6-cbfd-484f-9f1b-92a641425ecd">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="60103caa-ab06-4ee4-9726-79e5d345d2f3">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2016	cnwdap1		Initial creation TFS #1949 VGM Process Requirements - Allocations
//
vars

begin
	if CM_Container.hasInstance(_ti) and _ti.isWeightCertified then
		_process := true;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="6f8044c6-aafe-4080-a8dc-64be776e2506">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2016	cnwdap1		Initial creation TFS #1949 VGM Process Requirements - Allocations
//
vars

begin
	if CM_Container.hasInstance(_ti) then
		if _ti.isWeightCertified then
			_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
		else
			_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
