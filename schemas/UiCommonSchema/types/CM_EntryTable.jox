    <JadeMethod name="create" id="e34c1f73-f1a8-42f8-9133-ef26cb1c3af7">
        <updating/>
        <source>create() updating;

vars

begin

	self.fixedColumns := ColumnHeading;
	self.fixedRows	 := 1;
	
	self.rows	:= 1;
	self.columns := ColumnValue;
	
	self.tabKey := J_key_Tab;
	self.fixed3D := false;
	self.allowResize := Table.AllowResize_Column; // No resize allowed
end;</source>
