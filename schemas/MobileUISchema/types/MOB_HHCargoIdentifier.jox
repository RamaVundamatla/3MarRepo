    <JadeMethod name="doResizeControls" id="c337bebd-6c60-4c88-a697-af1b3df2019d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move( self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );

	
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.txtAltId.setAndIncrementTabIndex( tabIndex );
		self.txtAltId.visible := true;
		self.txtAltId.enabled := false;
	endif;
	self.txtAltId.move( self.resizedMargin,
							 cTop,
							 stdWidth,
							 cHeight ); 
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="2d9906a5-a40c-4c38-86b0-b4235657a496">
        <source>doSave();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation

*/

vars

	altId : String;
	result : Integer;

begin

	if self.myTrackedItem = null then
		app.msgBox(app.getErrorString(No_Cargo_selected), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtCargoId.setFocus();
		return;
	endif;

	altId := self.txtAltId.text.toUpper;
	if altId = self.lblAltId.caption.toUpper.trimBlanks then
		altId := null;
	endif;
//	if altId = null then
//		app.msgBox(app.getErrorString1(No_blah_Entered,app.getErrorString(AlternativeID)), app.getErrorString(Error), MsgBox_OK_Only);
//		self.txtAltId.setFocus();
//		return;
//	endif;
	
	if altId = self.myTrackedItem.id then
		app.msgBox( app.getErrorString(Cargo_same_alterna_id), app.getErrorString(Error), MsgBox_OK_Only );
		self.txtAltId.setFocus();
		return;
	endif;
	
	while true do
		
		app.myTrxRT.trxUpdateAltID(self.myTrackedItem, altId, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			
			result := app.showErrorWarningDialog(app.getErrorString(AlternativeID), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
		
	endwhile;
	
	self.populateTrackedItem();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="3c3a95a2-1c06-4e56-a5d3-862177b18b46">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 30506

*/

vars

begin

	if self.btnOne.caption = app.getErrorString(Edit) then
		self.doEdit;
	elseif self.btnOne.caption = app.getErrorString(Save) then
		self.doSave;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
