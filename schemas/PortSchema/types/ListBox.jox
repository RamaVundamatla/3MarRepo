<GUIClass name="ListBox">
    <JadeMethod name="addObjectAt" id="51003b94-d2c4-4601-bb3a-e8ae8ce38325">
        <source>addObjectAt(_text : String;_newIdx : Integer; _obj : Object; _level : Integer; _expanded : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2009	cnwer1	Initial creation

*/

vars
	idx		: Integer;
begin

	self.addItemAt(_text,_newIdx);
	self.itemExpanded[_newIdx] 	:= _expanded;
	self.itemObject[_newIdx] 	:= _obj;
// PAR 34403	if self.hasTreeLines then
		self.itemLevel[_newIdx]:=_level;
//	endif;
epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_newIdx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextIndexAtLevel" id="b076e296-d3b6-4083-8b36-8ccef5b96a55">
        <source>getNextIndexAtLevel(_startIndex : Integer; _level : Integer; _up : Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:	Will return the next index at the _level from the _startIndex searching in direction _up.
				If _startIndex is invalid or seaching backwards(up the tree) and no index found with the level will return -1.
	

Date		Who		Reason
23 April 2009	cnwer1	Initial creation

*/

vars
	idx,
	lastIndex : Integer;
begin
		
	idx:=_startIndex;
	if _up then
		lastIndex:=1;
	else
		lastIndex:=self.listCount;
	endif;
	if idx = 0 or idx &gt; self.listCount then
		return -1;
	endif;
	 
	while idx &lt;&gt; lastIndex do
		if _up then
			idx:=idx -1;
		else
			idx:=idx + 1;
		endif;
		if self.itemLevel[idx] = _level then
			return idx;
			break;
		endif;
	endwhile;
	

	if lastIndex = self.listCount then
		return lastIndex;
	endif;
	
	return -1;

epilog

end;</source>
        <Parameter name="_startIndex" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_up" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSubItems" id="c3aa8df4-92e0-4693-9679-385b5e98b9f9">
        <source>getNumberOfSubItems(_parentIndex : Integer) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2008	cnwer1	Initial creation

*/

vars


	lastIndex		: Integer;
	startIndex		: Integer;
	listPointer		: Integer;
	currentLevel	: Integer;
	parentLevel		: Integer;
	childLevel,
	numSubItems		: Integer;
	childNodeObj	: CnEcTreeNode;
		
begin
	numSubItems:=0;
	lastIndex	:=	self.listCount();
	
	if _parentIndex &lt; 1 or _parentIndex &gt; lastIndex then
		return numSubItems;
	endif;
	
	if not self.itemHasSubItems(_parentIndex) then
		return numSubItems;
	endif;
	
	startIndex	:=	_parentIndex + 1;
	parentLevel	:=	self.itemLevel[_parentIndex];
	childLevel	:=	self.itemLevel[_parentIndex];
	
	foreach listPointer in startIndex to lastIndex do
		currentLevel	:=	self.itemLevel[listPointer];
		
		if currentLevel &lt;= parentLevel then
			break;
		endif;
		numSubItems:=numSubItems+1;
		
	endforeach;
	
	return numSubItems;
epilog

end;</source>
        <Parameter name="_parentIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveItemLevel" id="535fef4b-1a8e-45f2-9051-2872cf5f30b3">
        <source>moveItemLevel(_up: Boolean);
/*

Purpose:	For _up change selected item no longer be a child of its current parent

			For Down change selected item be a child of current item + 1

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars
	selectedObject : Object;
	selectedLevel,
	selectedIndex,
	newIndex: Integer;
	displayText : String;
begin
	
	selectedIndex:=self.listIndex; 
	selectedLevel:=self.itemLevel[selectedIndex];
	//if nothing is selected then return;
	if selectedIndex &lt;=1 then
		return;
	endif;
	//validation for changing to a higher level
	if _up  then
		//if it is already the highest level then can't do anything
		if selectedLevel = 1 then
			return;
		endif;	
		
	else
		if selectedIndex &lt;=1 then
			return;
		endif;
		self.itemLevel[selectedIndex]:=selectedLevel+1;
		return;
	endif;
	
	selectedObject:=self.itemObject[selectedIndex];
	displayText:=self.itemText[selectedIndex];
	newIndex:=self.getNextIndexAtLevel(selectedIndex,selectedLevel-1,false);

	if newIndex &lt;&gt; self.listCount then
		newIndex:=newIndex-1;
	endif;
	self.removeItem(selectedIndex);

	self.addObjectAt(displayText,newIndex,selectedObject,selectedLevel-1,true);
epilog

end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveItemObject" id="de501eb7-d3ff-4bde-ac3f-6d2fd0cede0e">
        <updating/>
        <source>moveItemObject(_up: Boolean) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2009	cnwer1	Initial creation

*/

vars
	idx,newIdx,
	nextItemIdx,
	theItemLevel,
	nextItemLevel,
	subObjectIdx,
	newSubObjectIdx: Integer;
	displayText : String;
	wasSelected: Boolean;
	obj : Object;
	allSubObjects : ObjectArray;
	allSubObjectsText : StringArray ;
begin

	idx:=self.listIndex;
	if idx &lt; 1 then
		return false;
	endif;
	
	theItemLevel :=self.itemLevel[idx].Integer;
	create allSubObjects transient;
	create allSubObjectsText transient;
	//check if we have to move the subitems;
	if self.itemHasSubItems(idx) then
		nextItemIdx:=idx + 1;
		nextItemLevel:=self.itemLevel[nextItemIdx];
		while nextItemLevel &gt; theItemLevel do
			allSubObjects.add(self.itemObject[nextItemIdx]);
			allSubObjectsText.add(self.itemText[nextItemIdx]);
			nextItemIdx:=nextItemIdx+1;
			if nextItemIdx &gt; self.listCount then
				break;
			endif;
			nextItemLevel:=self.itemLevel[nextItemIdx];
		endwhile;
	endif;
	
	
	if _up then
		newIdx:=self.getNextIndexAtLevel(idx,theItemLevel,_up);
		if newIdx &lt; 0  then
			return false;
		endif;
		if self.itemLevel[newIdx] &lt;&gt; theItemLevel then
			return false;
		endif;
	else
	
		if idx =self.listCount then
			return false;
		endif;
		if self.itemHasSubItems(idx  + 1) then
			newIdx:=self.getNextIndexAtLevel(idx +1,theItemLevel,_up);
			if self.itemLevel[newIdx] =  theItemLevel then
				newIdx:=newIdx-1;
			endif;
		else	
			newIdx:=self.getNextIndexAtLevel(idx,theItemLevel,_up);
		endif;

		if  newIdx &lt; 0 then
			return false;
		endif;
	
		//add the number of subitems at the new index
		newIdx:=newIdx+self.getNumberOfSubItems(newIdx);
		//remove the current subitems as these will be removed
		newIdx:=newIdx-allSubObjects.size;
	endif;

	obj:=self.itemObject[idx];
	displayText:=self.itemText[idx].String;
	wasSelected:=self.itemSelected[idx].Boolean;
	
	self.removeItem(idx);

	self.addObjectAt(displayText,newIdx,obj,theItemLevel,true);
	self.listIndex := newIdx;
	self.itemSelected[newIdx]:=wasSelected;
	
	subObjectIdx:=1;
	while subObjectIdx &lt;= allSubObjects.size do
		newSubObjectIdx:=newIdx + subObjectIdx;
		displayText:=allSubObjectsText[subObjectIdx];
		obj:=allSubObjects[subObjectIdx];
		self.addObjectAt(displayText,newSubObjectIdx,obj,theItemLevel+1,true);
		subObjectIdx:=subObjectIdx + 1;
	endwhile;
	
	self.itemExpanded[newIdx]:=true;
	
	return true;
epilog
	delete allSubObjects;
	delete allSubObjectsText;
end;</source>
        <Parameter name="_up" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
