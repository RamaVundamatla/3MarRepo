end;</source>
        <Parameter name="pProxyTA" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="pRealTA" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="valTerminalAreaFlags" id="b6b60b77-76fa-45cb-b232-de05280a4ea5">
        <source>valTerminalAreaFlags(_realTerminalArea : CM_TerminalArea input;
					_isSuitableForLoadFrom,
					_isSuitableForLoadInto : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal		: CM_Terminal;
	ta				: CM_TerminalArea;
begin
	if _realTerminalArea = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent terminal area object passed in is null');
		return;
	endif;

	if _isSuitableForLoadFrom and _isSuitableForLoadInto then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Both flags ("load from" and "load into") have been pased in as true');
	endif;
	
	terminal := _realTerminalArea.myTerminal;
	
	if _isSuitableForLoadFrom then
		//check it's not already flagged to load into - you can't have both true!!
		if _realTerminalArea.isSuitableForLoadInto then
			app.raiseCMException2(ERR_TA_ALREADY_FLAGGED, _realTerminalArea.id, _realTerminalArea.FLAG_LOAD_INTO_DESCR, null, null);
			return;
		endif;
		//warn if there are other terminal areas flagged already for this
		foreach ta in terminal.allTerminalAreas do
			if ta.isSuitableForLoadFrom and
			   (ta &lt;&gt; _realTerminalArea) then
				app.raiseCMWarning2(WARNING_TA_ALREADY_FLAGGED, ta.id, _realTerminalArea.FLAG_LOAD_FROM_DESCR, null, null, ta);
				break;
			endif;
		endforeach;

	elseif _isSuitableForLoadInto then
		//check it's not already flagged to load into - you can't have both true!!
		if _realTerminalArea.isSuitableForLoadFrom then
			app.raiseCMException2(ERR_TA_ALREADY_FLAGGED, _realTerminalArea.id, _realTerminalArea.FLAG_LOAD_FROM_DESCR, null, null);
			return;
		endif;
		//warn if there are other terminal areas flagged already for this
		foreach ta in terminal.allTerminalAreas do
			if ta.isSuitableForLoadInto and
			   (ta &lt;&gt; _realTerminalArea) then
				app.raiseCMWarning2(WARNING_TA_ALREADY_FLAGGED, ta.id, _realTerminalArea.FLAG_LOAD_INTO_DESCR, null, null, _realTerminalArea);
				break;
			endif;
		endforeach;	
	endif;
	
end;</source>
        <Parameter name="_realTerminalArea" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_isSuitableForLoadFrom" type="Boolean"/>
        <Parameter name="_isSuitableForLoadInto" type="Boolean"/>
    </JadeMethod>
