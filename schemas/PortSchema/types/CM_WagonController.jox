    <JadeMethod name="isStackFull" id="db5b11ec-cf86-4430-9962-768b74f31e9d">
        <source>isStackFull(_mode : Integer; _moveTI : CM_TrackedItem) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			03 December 2001 by cnwdwq1
Purpose:			Tells us whether we have exceeded the stack height of this wagon
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
constants
	TiHeight = 9.6; //Covers a High Cube container
vars
	ti : CM_TrackedItem;
	tmpArray : CM_TIArray;
	maxHeight,
	tmpHeight : Real;
begin
	
	create tmpArray transient;
	self.getTIs(tmpArray,_mode, true); // PAR 27749
	
	foreach ti in tmpArray do
		tmpHeight := tmpHeight + ti.getActualHeight();
	endforeach;
	if _moveTI &lt;&gt; null then
		tmpHeight := tmpHeight + _moveTI.getActualHeight();
	endif;
	maxHeight := (TiHeight*self.myWagon.myWagonClass.maxNumInStack);

	return tmpHeight &gt;= maxHeight;
	
epilog
	delete tmpArray;		
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isThereRoomForTI" id="73f6fb6a-f575-4217-885d-c50a0f6e5aea">
        <source>isThereRoomForTI(_overHangLC : CM_LocationsController; _control: CMIF_MoveController input; _ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
//					PAR 18682 - CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	primaryPortion : Integer;
	overHangFree, offset : Integer;
	tiLen : Integer;
	wholeLC : Integer;
	lcLen : Integer;
	nextWC : CM_WagonController;
	tmpLen : String;
	stackHeight : Integer;
begin
	
	lcLen := 10; //self.myTerminalArea.locationLength.Integer;
	stackHeight := self.allTrackedItems.size;	//13 Oct 2014	NDL	Par 35040
	
	if self.offsetFlexi = lcLen then
		primaryPortion := lcLen.Integer;
	else
		offset := self.offsetFlexi;
		if offset = 0 then
			offset := self.getStrictOffsetForTI(_ti);
		endif;
		
		primaryPortion := (lcLen -  offset).Integer;
	endif;
	tiLen := _ti.getActualLength().Integer;
	
	nextWC := self;
	while true do
		nextWC := nextWC.myNextController;
	//	if nextWC = null or nextWC = _overHangLC or nextWC.allTrackedItems.size &lt;&gt; 0 then
		if nextWC = null or nextWC = _overHangLC then	// 10 Aug 2010	NDL Par 25316
			break;
		endif;
		//13 Oct 2014	NDL	Par 35040
		if stackHeight &lt;&gt; self.allTrackedItems.size then
			//Its not on the same level as the previous one.
			break;
		endif;
		
		wholeLC := (wholeLC + lcLen).Integer;
	endwhile;
	if tiLen &gt; (primaryPortion + overHangFree + wholeLC) then
	
		if _overHangLC.allTrackedItems.includes(_ti) then
			return null;
		endif;
//		return "There is cargo in the way.";
		tmpLen := _ti.getActualLength().String;
		return app.getErrorString3(ERR_NO_MOVE_ODD, _ti.id, tmpLen, tmpLen); // PAR 18647
	
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_overHangLC" type="CM_LocationsController"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTopTI" id="c51c1c86-a088-490d-a94a-9e130e1b3bd9">
        <source>isTopTI(ti: CM_TrackedItem; mode : Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			14 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin
	create array transient;
	self.getTIs(array, mode, true); // PAR 27749
	if not array.includes(ti) then
		return false;
	endif;
	return (array.last = ti);
epilog
	delete array;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
