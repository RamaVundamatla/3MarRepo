    <JadeMethod name="setState" id="7ffdd078-ff9e-4d22-a162-c88bab6b9f3e">
        <updating/>
        <source>setState() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation
*/
// 16 Feb 2018	jlgrs1	TFS 37036 Booking Discrepancy Query does not filter the state correctly

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.state := self.myTrackedItem.state;
//	elseif self.myBookingRef &lt;&gt; null then
//		self.state := self.myBookingRef.status;
	else
		self.state := 0;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="92069ad8-b84a-443b-b8f0-cc10a41f432d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwndl1	Initial creation

*/

vars

begin

	if _property.name = CMEVT_BookingRefDiscrep::allBookingRefDiscrepFieldVs.name
	or _property.name = CMEVT_BookingRefDiscrep::bookingRefId.name
	or _property.name = CMEVT_BookingRefDiscrep::createdTS.name
	or _property.name = CMEVT_BookingRefDiscrep::myBookingRef.name
	or _property.name = CMEVT_BookingRefDiscrep::myTrackedItem.name
	or _property.name = CMEVT_BookingRefDiscrep::state.name
	then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
