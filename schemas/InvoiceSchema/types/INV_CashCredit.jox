    <JadeMethod name="translateForm" id="1f03af66-db0f-4653-a900-bd6a7c20a30a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2019 13:14:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021115, locale);
	btnClose.translateCaption(Xlat_0021116, locale);
	btnComments.translateCaption(Xlat_0021117, locale);
	btnFind.translateCaption(Xlat_0023358, locale);
	btnSave.translateCaption(Xlat_0021120, locale);
	chkPrintRec.translateCaption(Xlat_0021121, locale);
	lblAgent.translateCaption(Xlat_0021122, locale);
	lblAgentName.translateCaption(Xlat_0021123, locale);
	lblBank.translateCaption(Xlat_0023674, locale);
	lblCashRec.translateCaption(Xlat_0023763, locale);
	lblCashRecValue.translateCaption(Xlat_0023764, locale);
	lblCreditAvailable.translateCaption(Xlat_0023765, locale);
	lblCreditAvailableValue.translateCaption(Xlat_0021124, locale);
	lblDebtor.translateCaption(Xlat_0021125, locale);
	lblDrName.translateCaption(Xlat_0021126, locale);
	lblReceipt.translateCaption(Xlat_0021127, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0021129, locale);
	mnuExtraItems.translateCaption(Xlat_0021130, locale);
	mnuInspect.translateCaption(Xlat_0021131, locale);
	mnuSelectAll.translateCaption(Xlat_0021132, locale);
	mnuTableContext.translateCaption(Xlat_0021133, locale);
	mnuUnselectAll.translateCaption(Xlat_0021134, locale);
end;</source>
    </JadeMethod>
