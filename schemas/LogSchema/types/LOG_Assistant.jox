    <JadeMethod name="comboBoxLogLotOperators" id="2155b9ad-9a14-4a77-95c9-ab1425836d56">
        <source>comboBoxLogLotOperators(pCmb: ComboBox input; _lot : CM_LogLot; _operator : CM_Operator);
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operSet : CM_OperatorSet;	
begin
	create operSet transient;
	if _lot &lt;&gt; null then
		_lot.getOperatorsForLot(operSet);
	endif;
	
	if _operator &lt;&gt; null and (not operSet.includes(_operator)) then
		operSet.add(_operator);
	endif;
	pCmb.listCollection(operSet, false, 0);
	if _operator &lt;&gt; null then
		pCmb.text := self.displayEntryOperatorAll(_operator);
	endif;

epilog
	delete operSet;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_lot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
