<PrimType name="Boolean">
    <JadeMethod name="jssFormat" id="ab98f98d-f020-4eab-911a-c8c6c2b52103">
        <source>jssFormat(pTrueValue:String; pFalseValue:String):String;
// --------------------------------------------------------------------------------
// Created:		24 April 2002 by cnwdad1
//
// Purpose:		Returns the string appropriate for the receiver's value.
//
// Parameters:	pTrueValue - The string to return if the receiver is true.
//				pFalseValue - The string to return if the receiver is false.
//
// Returns:		The string representation of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trueString	: String;
	falseString	: String;

begin
	// If no values supplied use default.

	if pTrueValue.trimBlanks() = null then
		trueString	:=	$JSS_TRUE;
	else
		trueString	:=	pTrueValue;
	endif;

	if pFalseValue.trimBlanks() = null then
		falseString	:=	$JSS_FALSE;
	else
		falseString	:=	pFalseValue;
	endif;

	if self	then
		return trueString;
	else
		return falseString;
	endif;
end;</source>
        <Parameter name="pTrueValue" type="String"/>
        <Parameter name="pFalseValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetTableCheckBoxValue" id="cdc43af0-dd52-4f48-bdc6-43e9832a93cd">
        <source>jssGetTableCheckBoxValue():String;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Returns a value suitable for setting the contents of a table control
//				cell where the InputType for that cell is of type "Input_CheckBox".
//
// Parameters:	None
//
// Returns:		String - Either "1" (true) or "0" (false).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self then
		return "1";
	else
		return "0";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssYesNo" id="c19e28d6-d866-4eb3-8479-7a5ef5c2f47a">
        <source>jssYesNo():String;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns a literal (translatable) string for "Yes" or "No" based
//				upon the value of the receiver.
//
// Parameters:	None
//
// Returns:		String (translated) according to the receiver's value).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self then
		return "Yes";
	else
		return "No";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
