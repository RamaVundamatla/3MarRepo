    <JadeMethod name="addInvoiceEndDateSelector" id="2ba434c8-bf60-4406-a354-533436301a4f">
        <source>addInvoiceEndDateSelector(_controller : CnEcReleaseController);

/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
25 November 2016	cnwrh7	Initial creation TFS2983 PAR38418 Add Invoice End Date In Selector
*/

vars
	invoiceQDef : CM_QDefInvoice;
	queryProp	: CM_QueryProperty;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Adding Invoice End Date In Selector", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Adding Invoice End Date In Selector") ;	
	endif;
	
	beginTransaction;
		invoiceQDef  := CM_QDefInvoice.firstInstance;
		queryProp :=  invoiceQDef.allQueryProperties[CM_Invoice :: toDT.name];
		if queryProp = null then
			create queryProp as CM_QDateProperty persistent;
			queryProp.set("Invoice End Date",  CM_Invoice ::toDT.name, invoiceQDef.className);
			invoiceQDef.allQueryProperties.add(queryProp);
		endif;
		commitTransaction;
		app.writeLog(method.qualifiedName &amp; " Adding Invoice End Date In Selector",LogINFO );
		if _controller &lt;&gt; null then
			_controller.logEntry("Adding Invoice End Date In Selector complete") ;	
		endif;
	self.addScriptRun(method.name);
	
epilog
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
