// ---------------------------------------------------------------------------
// Created:     31 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridPoint	 	: SOP_GridPoint;
begin
	gridPoint := self.doUpdateAllPoints(LOC_Display_20ft);

	self.frmStrictGrid.visible := false;
	
	if gridPoint &lt;&gt; null then
		if gridPoint.myGridController &lt;&gt; null then
			if gridPoint.myGridController.is20ft then
				self.showLengthWarning("20");
			endif;
		endif;
	endif;

epilog

end;</source>
