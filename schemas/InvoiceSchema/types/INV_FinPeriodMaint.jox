    <JadeMethod name="displayMSGDebtors" id="7325126c-8e22-4a3c-83c0-2f67ff56f396">
        <source>displayMSGDebtors(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.CM_Debtor.name;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayPropData" id="bfd73ed6-921a-4c42-95ba-50f0bc72ce3c">
        <updating/>
        <source>displayPropData() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
begin
	self.shtPropTwo.visible := (self.modePropertyNew = self.MODEPROPERTY_PERIOD);

	if self.updateMode = self.UpdateMode_New then
		self.tblProperties.clearValues();
//		self.txtPeriodTime.setTime(now.time);	
//		self.txtPeriodTime.setTime(null);	
//		self.txtPeriodTime.lostFocus(self.txtPeriodTime);
		self.tblProperties.setValueByName(ETRow_PeriodTime, NULL_TIME); 
		self.fldProperties.topSheet := self.shtPropOne;
		if self.modePropertyNew = self.MODEPROPERTY_PERIOD then
			self.loadDebtors();
			self.tblProperties.hideRowByName(ETRow_PeriodDate,false);
			self.tblProperties.hideRowByName(ETRow_PeriodTime,false);
			self.tblProperties.showRowByName(ETRow_IsDefault,false);
		else
			self.tblProperties.hideRowByName(ETRow_IsDefault,false);
			self.tblProperties.showRowByName(ETRow_PeriodDate,false);
			self.tblProperties.showRowByName(ETRow_PeriodTime,false);
		endif;
	else
		inheritMethod();
		if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
			if self.myCurrentFPDate &lt;&gt; null then
//				self.txtPeriodDate.setTextFromDate(self.myCurrentFPDate.dateTime.date);
//				self.txtPeriodTime.setTime(self.myCurrentFPDate.dateTime.time);
				self.tblProperties.setValueByName(ETRow_PeriodDate, self.myCurrentFPDate.dateTime.date()); 
				self.tblProperties.setValueByName(ETRow_PeriodTime, self.myCurrentFPDate.dateTime.time()); 
//				self.txtPeriodDate.lostFocus(self.txtPeriodDate);
//				self.txtPeriodTime.lostFocus(self.txtPeriodTime);
				self.tblProperties.setValueByName(ETRow_Description,self.myCurrentFPDate.remarks);
				self.tblProperties.hideRowByName(ETRow_IsDefault,false);
				self.tblProperties.showRowByName(ETRow_PeriodDate,false);
				self.tblProperties.showRowByName(ETRow_PeriodTime,false);
			endif;	
		else		
			self.tblProperties.setValueByName(ETRow_Description,self.myCurrentFPType.description);
			self.tblProperties.setValueByName(ETRow_IsDefault,self.myCurrentFPType.isDefault);
			self.tblProperties.hideRowByName(ETRow_PeriodDate,false);
			self.tblProperties.hideRowByName(ETRow_PeriodTime,false);
			self.tblProperties.showRowByName(ETRow_IsDefault,false);
			self.loadDebtors();
		endif;
		self.fldProperties.topSheet := self.shtPropOne;
		self.loadDebtors();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropNextClick" id="461cd97d-8207-407c-b0a9-73eefe045d3a">
        <updating/>
        <source>doBtnPropNextClick() updating;
// adm 290509 Par 19507
vars

begin
	self.doBtnPropSaveClick();
	if self.modePropertyNew = self.MODEPROPERTY_DATE
	or self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		self.btnNew_click(self.btnNew);
	else
		self.btnNewType_click(self.btnNewType);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="72a4e735-4bfe-4b8a-9d19-7d876e99514e">
        <updating/>
        <source>doBtnPropSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	aFPDate, pxyFPDate : CM_FinancialPeriodDateTime;
	aFPEnd, pxyFPEnd : CM_FinancialPeriodEnd;
	ls : Boolean;
	aTS : TimeStamp;
	theReturn : Integer;
	debtors : CM_DebtorNodeByNameDict;
begin
	// ### NEW STUFF
	if self.updateMode = self.UpdateMode_New then
		// ## NEW DATE
		if self.modePropertyNew = self.MODEPROPERTY_DATE then
			create pxyFPDate transient;
		// ### NEW TYPE
		else
			create pxyFPEnd transient;
		endif;	
	else
	// ### UPDATEs
		// ## UPDATE DATE
		if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
			app.cmsBeginLoad(ls);
			pxyFPDate := app.createUpdateProxy(self.myCurrentFPDate).CM_FinancialPeriodDateTime;
			app.cmsEndLoad(ls);
		// ## UPDATE TYPE
		else
			app.cmsBeginLoad(ls);
			pxyFPEnd := app.createUpdateProxy(self.myCurrentFPType).CM_FinancialPeriodEnd;
			app.cmsEndLoad(ls);
		
		endif;
	endif;

	// ### SET PROXY DATE
	if self.modePropertyNew = self.MODEPROPERTY_DATE
	or self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		aTS.setDate(self.tblProperties.getValueAsDate(ETRow_PeriodDate));
		aTS.setTime(self.tblProperties.getValueByName(ETRow_PeriodTime).Time);
		pxyFPDate.setProxy(aTS,self.tblProperties.getValueByName(ETRow_Description).String, self.myCurrentFPType);
	// ### SET PROXY TYPE
	else
		create debtors transient;
		pxyFPEnd.setProxy(self.tblProperties.getValueByName(ETRow_Description).String, 
							self.tblProperties.getValueByName(ETRow_IsDefault).Boolean);
		self.msgPropTwo.getSelected(debtors);
	endif;


	while true do
		// ### TRX DATE
		if self.modePropertyNew = self.MODEPROPERTY_DATE
		or self.modePropertyUpdate = self.MODEPROPERTY_DATE then
			// ### TRX NEW DATE
			if self.updateMode = self.UpdateMode_New then
				app.myTrxCA.trxCreateFPDateTime(pxyFPDate,aFPDate,app.myPassport);
			// ### TRX UPDATE DATE
			else
				app.myTrxUA.trxUpdateFPDateTime(pxyFPDate, app.myPassport);
			endif;
		else
			// ### TRX NEW TYPE
			if self.updateMode = self.UpdateMode_New then
				app.myTrxCA.trxCreateFPType(pxyFPEnd,aFPEnd,app.myPassport);
			// ### TRX UPDATE TYPE
			else
				app.myTrxUA.trxUpdateFPType(pxyFPEnd,debtors, app.myPassport);
			endif;
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Financial Periods", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyFPDate;
	delete pxyFPEnd;
	delete debtors;
	self.enableControls();				// cnwrl1 06/11/2009 PAR 19278
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5573c01d-51aa-44c4-bbe5-c7f459ef5ac5">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFP			: CM_FinancialPeriodDateTime;
	anFPE			: CM_FinancialPeriodEnd;
	theReturn		: Integer;
	
begin

	if self.doDeleteBulk() then
		return;
	endif;
	
	if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		anFP := self.myCurrentFPDate;
		if anFP = null then
			app.msgBox("Please select a date.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		
		if app.msgBox(app.getErrorString1(Want_delete_fincanc_period,self.myCurrentFPDate.dateTime.date.String),app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		anFPE := self.myCurrentFPType;
		if anFPE = null then
			app.msgBox("Please select a period type.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if app.msgBox("Are you sure that you want to" &amp; Cr 
						&amp; " delete " &amp; anFPE.description,app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;

	while true do
		if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		 	app.myTrxDA.trxDeleteFPDateTime(anFP, app.myPassport);
		 else
		 	app.myTrxDA.trxDeleteFPType(anFPE, app.myPassport);
		 endif;
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.btnRefresh.click( self.btnRefresh );			// cnwrl1 06/11/2009 PAR 19278
			return ;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Financial_Period_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has Acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteBulk" id="0b1443b1-96b7-4dad-835b-d0970b73b3ef">
        <updating/>
        <source>doDeleteBulk() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFP			: CM_FinancialPeriodDateTime;
	anFPE			: CM_FinancialPeriodEnd;
	theReturn		: Integer;
	objs : ObjectArray;
	obj : Object;
	allSelectedDates : CM_FinancialPeriodDateTimeDict;
begin

	objs := self.lstData.getAllSelectedObjects();
	if objs = null or objs.size = 0 then
		return false;
	endif;
	
	if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		if app.msgBox(app.getErrorString1(Sure_that_want_delet_selec_dat, objs.size.String) ,app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return true;
		endif;
	else
		return false;
	endif;
	
	
	create allSelectedDates transient;
	foreach obj in objs discreteLock where obj.isKindOf(CM_FinancialPeriodDateTime) do
		anFP := obj.CM_FinancialPeriodDateTime;
		allSelectedDates.add(anFP);
	endforeach;

	while true do
		app.myTrxDA.trxDeleteFPDateTimeBulk(self.myCurrentFPType, allSelectedDates);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.btnRefresh.click( self.btnRefresh );			// cnwrl1 06/11/2009 PAR 19278
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Financial_Period_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has Acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return true;
		endif;
		break;
	endwhile;
	
	return true;
epilog
		delete allSelectedDates;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="745f3372-797b-4153-9805-f886c57baef3">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	inheritMethod(listbox);
	
	if listbox.listIndex &lt; 0 then
		return;
	endif;
	
	anObject := listbox.itemObject[listbox.listIndex];
	self.modePropertyNew := null;
	
	self.btnBulk.enabled := false;

	if anObject = null 
	or anObject.isKindOf(CM_Bank) then
		self.myCurrentFPDate:= null;
		self.myCurrentFPType := null;
		self.modePropertyUpdate := null;
	elseif anObject.isKindOf(CM_FinancialPeriodDateTime) then
		self.modePropertyUpdate := self.MODEPROPERTY_DATE;
		self.myCurrentFPDate:= anObject.CM_FinancialPeriodDateTime;
		self.myCurrentFPType := self.myCurrentFPDate.myFinancialPeriodEnd;
	else
		self.btnBulk.enabled := true; // TFS 215
		self.myCurrentFPDate:= null;
		self.myCurrentFPType := anObject.CM_FinancialPeriodEnd;
		self.modePropertyUpdate := self.MODEPROPERTY_PERIOD;
	endif;
	
	self.enableControls();	// cnwrl1 06/11/2009 PAR 19278
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="09602b25-8793-4a8c-be0f-31f1c2a09334">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
