    <JadeMethod name="validateSelection" id="84e5a61b-9898-4120-a557-e6fe64fde731">
        <source>validateSelection(serviceName,
				  operationName,
				  xmlMessage : String io) : Boolean protected;

/*

Purpose:			Check the input values are populated, and pass them back in the
					io parameters


Return Value:		True if the values are correct, false otherwise


Date		Who		Reason
21 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	
begin
	serviceName := cmbService.text.trimBlanks;
	if serviceName = null then
		cmbService.setFocus;
		app.msgBox("Service must be selected", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	operationName := cmbOperation.text.trimBlanks;
	if operationName = null then
		cmbOperation.setFocus;
		app.msgBox("Operation must be selected", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	xmlMessage := txtInput.text.trimBlanks;
	if xmlMessage = null then
		txtInput.setFocus;
		app.msgBox("Input message can not be blank", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	return true;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="serviceName" type="String" usage="io"/>
        <Parameter name="operationName" type="String" usage="io"/>
        <Parameter name="xmlMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zLoadPresetMessageDetails" id="4d4d9ff3-0f22-47fb-9064-7a7357cb93a7">
        <source>zLoadPresetMessageDetails() protected;

/*
Purpose:	To allow empty messages to be prefilled.
*/
	
vars
	containerId		: String;
	tempStr			: String;
	fileStr			: String;
	searchStr		: String;
	binaryMsg		: Binary;
	searchLen		: Integer;
	pos				: Integer;
	
begin
	if not self.chkPrefillOp.value then
		return;		// do nothing !
	endif;
	
	containerId	:= 'Client Ref00001';
	
	tempStr		:= self.txtInput.text;
	searchStr	:= '&lt;clientRef&gt;';
	searchLen	:= searchStr.length;
	pos			:= tempStr.pos( searchStr, 1 );
	if pos &lt;&gt; null then
		// strip the space out and use my data
		tempStr	:=	tempStr[ 1 : pos + searchLen - 1 ] &amp;
					'What ever'[ 1 : 30 ] &amp;
					tempStr[ pos + searchLen + 1 : end ];
		self.txtInput.text	:= tempStr;
	endif;
	
	tempStr		:= self.txtInput.text;
	searchStr	:= '&lt;messageType&gt;';
	searchLen	:= searchStr.length;
	pos			:= tempStr.pos( searchStr, 1 );
	if pos &lt;&gt; null then
		// strip the space out and use my data
		tempStr	:=	tempStr[ 1 : pos + searchLen - 1 ] &amp;
					'System' &amp;
					tempStr[ pos + searchLen + 1 : end ];
		self.txtInput.text	:= tempStr;
	endif;
	
	tempStr		:= self.txtInput.text;
	searchStr	:= '&lt;message xsi:type="xsd:base64"&gt;';
	searchLen	:= searchStr.length;
	pos			:= tempStr.pos( searchStr, 1 );
	if pos &lt;&gt; null then
		// set up the the required input "file"
//	/* an IFTMIN example
fileStr	:=
"UNB+UNOA:1+MAEU+PLGDNDCT+090706:1032+21567'" &amp; CrLf &amp;
"UNH+2156700001+IFTMIN:D:95B:UN'" &amp; CrLf &amp;
"BGM+340+56109+9'" &amp; CrLf &amp;
"DTM+201:200907070700:203'" &amp; CrLf &amp;
"FTX+SIN+++AQABA\/2 PROBES\/DATA LOGGER\/GENSET\/CTR LESS THAN 4 YEARS OLD ODPRAW:A GDANSKMONKA SLAWOMIR AMP429163 GA 0295J GA 85778'" &amp; CrLf &amp;
"FTX+SIN+++MONKA SAWOMIR AMP429163 GA 0295J GA 85778'" &amp; CrLf &amp;
"CNT+16:1'" &amp; CrLf &amp;
"RFF+AIL:56109'" &amp; CrLf &amp;
"RFF+TON:9815310'" &amp; CrLf &amp;
"TDT+20+JVOY+1++MAE:172+++9144720:146:11:PONL TARANAKI'" &amp; CrLf &amp;
"LOC+9+PLGDN:139:6:GDANSK'" &amp; CrLf &amp;
"TDT+1++3++:::GDANSK DCT'" &amp; CrLf &amp;
"LOC+61+DEBRV:139:6:BREMERHAVEN'" &amp; CrLf &amp;
"LOC+163+JOAQB:139:6:AQABA'" &amp; CrLf &amp;
"NAD+MS+MAE'" &amp; CrLf &amp;
"CTA+IC+:POLOPSMETS@MAERSK.COM'" &amp; CrLf &amp;
"NAD+SF++PL-81-127 GDYNIA:REFCON::HUTNICZA'" &amp; CrLf &amp;
"NAD+ST++PL-80 601 GDANSK:DCT GDANSK SA::SUCHARSKIEGO 7 STREET'" &amp; CrLf &amp;
"RFF+SRN:PO BEL 5227028'" &amp; CrLf &amp;
"GID+1'" &amp; CrLf &amp;
"FTX+AAA+++1600 CTN POLYBAG 12 COX ORANGE PIPPIN APPLES COUNT 96 NETT WEIGHT 1998:4.72 KGS'" &amp; CrLf &amp;
"NAD+PW++PL-03-228 WARSZAWA:BEL POLSKA SP ZOO:CHLODNIE WARSZAWSKIE MORSPOL:MARYWILSKA 26'" &amp; CrLf &amp;
"DTM+234:200907070700:203'" &amp; CrLf &amp;
"MEA+AAE+AAL+KGM:19177'" &amp; CrLf &amp;
"RFF+BN:87654'" &amp; CrLf &amp;
"RFF+SQ:MVDD4TX0VUN1O'" &amp; CrLf &amp;
"EQD+CN+" &amp; containerId &amp; "+45R1:102:5:40HREF++2+5'" &amp; CrLf &amp;
"MEA+AAE+G+KGM:24017'" &amp; CrLf &amp;
"TMP+2+001:CEL'" &amp; CrLf &amp;
"EQA+RG'" &amp; CrLf &amp;
"EQN+2'" &amp; CrLf &amp;
"EQA+AD'" &amp; CrLf &amp;
"UNT+30+2156700001'" &amp; CrLf &amp;
"UNZ+1+21567'";
//	*/
		// make it binary and this binary encoded is what gets passed via the web message
		binaryMsg	:= fileStr.Binary;
		
		// strip the encoded space out of the screen text and use my data instead
		tempStr		:=	tempStr[ 1 : pos + searchLen - 1 ] &amp;
						binaryMsg.base64Encode() &amp;
						tempStr[ pos + searchLen + 4 : end ];
		self.txtInput.text	:= tempStr;
	endif;

	tempStr		:= self.txtInput.text;
	searchStr	:= 'false';
	searchLen	:= searchStr.length;
	pos			:= tempStr.pos( searchStr, 1 );
	if pos &lt;&gt; null then
		tempStr	:=	tempStr[ 1 : pos - 1 ] &amp;
					'true' &amp;
					tempStr[ pos + searchLen : end ];
		self.txtInput.text	:= tempStr;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
