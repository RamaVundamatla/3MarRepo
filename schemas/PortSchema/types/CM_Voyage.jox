    <JadeMethod name="doActualDeleteAccrualsCargo" id="b4366d2d-dbe2-4830-978a-483cbe3508de">
        <source>doActualDeleteAccrualsCargo(_tiSet : CM_TISet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2024	navra1	Initial creation for //navra1 - MTN-33087 - 23rd Oct 2024

*/

vars	
	tisWithWarnSet : CM_TISet;	
	result	: Integer;
	ti : CM_TrackedItem;
	inv : CM_InvoiceLine;
	pxyInvoice : CM_Invoice;
	theStatus : CMIF_InvoiceStatus;
	tiTrx : CM_TITransaction;
begin	
	if _tiSet = null or _tiSet.size() = 0 then
		return;
	endif;	
	
	foreach ti in _tiSet do
		if ti.invoiceLines &lt;&gt; null and ti.invoiceLines.size() &gt; 0 then
			foreach	inv in ti.invoiceLines do				
				if inv.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED then
					//void the statues of the invoices of Accurals cargo(which is dummy)
					inv.changeStatus(CM_InvoiceLine.STATUS_VOIDED);					
				endif;				
			endforeach;
		endif;	
	endforeach;
	
	create tisWithWarnSet transient;

	while true do
		app.myTrxDA.trxDeleteTrackedItems(_tiSet, tisWithWarnSet, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then			
			break;
		else
			//do not ask the user, force delete them ignoring the warnings
			app.myPassport.warningsAcknowledged	:= true;				
			_tiSet.clear;
			tisWithWarnSet.copy(_tiSet);
			tisWithWarnSet.clear;	
			continue;
		endif;
		
		break;
	endwhile;	
epilog
	delete theStatus;
	delete pxyInvoice;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doBerthageArrivalToDeparture" id="93a7c8d5-6f2b-4ecd-b5b2-d45a4b9dddd1">
        <source>doBerthageArrivalToDeparture(_autoCreate : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		If the calc type is INV_CALC_TYPE_TIMEBLCK_HRS_ONE then ignore shift movements 
//				and only charge berthage from arrival to departure.

//				NOTE: The departure movement's wharf is always the logical wharf, which cannot have resources attached.
//				So we use the wharf of the previous movement to get the correct resource.
//
// ---------------------------------------------------------------------------

vars
	aVM : HMS_VoyageMovement;
	aRes : HMS_Resource;
	theCalcType : CM_CalculationType;
	berthageCharged : Boolean;
begin

	return app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;
	
	
/*	
	// get the arrival movement
	aVM := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
	if aVM &lt;&gt; null then
		if aVM.myBerth = null then
			return false;
		endif;
		// go to the arrival movements wharf (non logical) and get it's first departure resource
		aRes := aVM.myBerth.myWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.First_Resource);
		if aRes &lt;&gt; null then
			if app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean then
//			theCalcType := aRes.getMappedInvoiceCalcType(self,true);
			// if the resource is for charging from arrival to departure, ignoring shifts then charge it like that NOW
//			if theCalcType &lt;&gt; null 
//			and theCalcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE then
				aVM := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
				if aVM &lt;&gt; null then
					berthageCharged := true;
					if _autoCreate then
						aVM.myBerth.createAutoCharge(aVM);
					endif;
				endif;
			endif;
		endif;
	endif;

	return berthageCharged;
	*/
end;</source>
        <Parameter name="_autoCreate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHandle1035ForLocation" id="02392897-3e6a-4ec6-9b91-c6436d42fbe3">
        <source>doHandle1035ForLocation( _exc : Exception; _got1035 : Boolean io ) : Integer;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/
constants
	StringTooLong	= 1035;
vars

	returnVal : Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = StringTooLong then
		_got1035 := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;


	return returnVal;
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_got1035" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
