    <JadeMethod name="setProxyFromObject" id="acde4055-5915-415c-a934-1d2274c80142">
        <updating/>
        <source>setProxyFromObject(_object: CM_BulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2021	navpw1	Initial creation TFS: 52268
15 Nov 2022	navdap1	TFS 55405 AAT 1-Stop Integration - Carrier Description Being Sent
*/
vars
	carrier : CM_Carrier;
	ti : CM_TrackedItem;

begin
	inheritMethod(_object);
	
	self.cargoType := _object.getMyCargoType.description;
	
	carrier := _object.getCarrier();
	if carrier &lt;&gt; null then
		//self.carrier := carrier.description;		// TFS 55405
		self.carrier := carrier.code;				// TFS 55405
	endif;
	
	self.operator := _object.myOperator.description;
	self.releaseCode := _object.code;
	self.status := _object.statusString;
	self.totalBeingActioned := 	_object.getNumItemsBeingActioned();
	self.totalDelivered := _object.getTotalReleased;
	self.totalOutstanding := _object.getTotalOutstanding;
	self.totalRequested := 	_object.getTotalRequested;
	
	foreach ti in _object.allTrackedItemsAssigned discreteLock do
		self.cargoItems.add(ti.id);
	endforeach;
	foreach ti in _object.allTrackedItemsReleased discreteLock do
		self.cargoItemsDelivered.add(ti.id);
	endforeach;

end;</source>
        <Parameter name="_object" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
