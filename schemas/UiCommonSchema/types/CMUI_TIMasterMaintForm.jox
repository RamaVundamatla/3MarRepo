    <JadeMethod name="cmbTILCType_lostFocus" id="2f9e3490-fc6c-414a-bc7c-ef6043cb1cef">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTILCType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 April 2007	cnwer1	Initial creation - PAR#xxxx
15 May   2018   cnwma1	Bug 38541: PENN - Chassis Maintenance
*/


vars
	cargoType  	: CM_CargoType;
	tilcType 	: CM_TILCType;
	measure		: CM_MeasurementType;	
begin

	if cmbTILCType.listIndex = -1 then	//Par 18789
		return;
	endif;
	
	tilcType := combobox.itemObject[cmbTILCType.listIndex].CM_TILCType;
	if tilcType &lt;&gt; null then
		cargoType := tilcType.myCargoType;
		self.allStopsForUser.clear();
		self.allToDoTasksForUser.clear();
		self.lstTblStops.clearTable();
		self.lstTblToDoTasks.clearTable();
		
		self.myAssistant.listTableStopsTableSysUser( self.lstTblStops, cargoType, self.allStopsForUser, true);
		self.myAssistant.listTableToDoTasksSysUser( self.lstTblToDoTasks,cargoType, self.allToDoTasksForUser );	//self.myAssistant.listTableToDoTasks(self.lstToDoTasks,self.myTerminal);
		measure := app.getDefaultMeasurementForType(Type_Weight);	                                       //15.5.2018 cnwma1	Bug 38541
		self.txtWeight.text	:= app.convertMeasurementForDisplay(measure.shortName, tilcType.tareWeight);   //15.5.2018 cnwma1	Bug 38541
	endif;
	
epilog

end;
/*
	self.tblData.setValueByControlName(combobox.name, combobox.text);
	type :=self.getTILCType();
	if type &lt;&gt; null and type.myCargoType.showDamageCodes then
//		self.tblData.enableRowByName(ETRow_DamageDetail);
		self.tblDamage.userInputEnabled := true;
	else
		self.tblDamage.userInputEnabled := false;
//		self.tblData.disableRowByName(ETRow_DamageDetail);
	endif;
	
	// populate available stops and to do tasks for the trailer type. Only when type has been changed. Par 17781
	if self.aTILCType &lt;&gt; combobox.text then
		self.lstAllStops.clearTable();
		self.lstToDoTasks.clearTable();
		self.setListAllStops;
		self.setListToDoTaksDescs();
		if type &lt;&gt; null then
			self.myAssistant.listTableStopsTableSysUser( self.lstAllStops, type.myCargoType, self.allStopsForUser, true ); 	
			self.myAssistant.listTableToDoTasksSysUser(	self.lstToDoTasks, type.myCargoType, self.allToDoTasksForUser );	
		endif;
	endif;
	
epilog

end;
*/</source>
