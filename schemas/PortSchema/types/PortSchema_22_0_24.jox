    <JadeMethod name="ediCustomsMessageTI" id="95af3213-c30b-4354-8e5d-70e43679ca53">
        <source>ediCustomsMessageTI(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navtnr20	Bug 53101: MTN US Customs Message EDI not added to collection by Voyage Code
*/

vars
	cust  : CM_EDIUSCustomsMessageTI;
	config : CM_EDIConfig;
	codeUpper : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary") ;	
	endif;
	beginTransaction;
	foreach cust in CM_EDIUSCustomsMessageTI.instances do
		if cust.myEDIConfig = null then
			continue;
		endif;
		if cust.voyageCode &lt;&gt; null and cust.myEDIConfig.allEDITrackedItemsByVoyageCode &lt;&gt; null then
			codeUpper := cust.voyageCode.toUpper;
			if not cust.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey(codeUpper, cust) then
				cust.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey(codeUpper, cust, cust);
			endif;
		endif;
	endforeach;
	commitTransaction;
	app.writeLog(method.qualifiedName &amp; "Completed Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixBadScanReaderETDef" id="f10493ad-cc25-49b4-8274-1b5868b4cd1e">
        <source>fixBadScanReaderETDef(_controller: CnEcReleaseController);
/*

Purpose:			The ETDef_ScanReader was originally part of the "ScanReader" Group and then changed to the "LaneDevicesMaint" group a few releases later
					This breaks with a duplicate key error, so lets avoid that by deleting the 'old' group just before the ET constants get reloaded.

Parameters:			

Return Value:		

Date				Who		Reason
14 February 2023	navmd1	Initial creation TFS 56560 POB - Fix Scan Reader ETDef belonging to multiple groups over various releases

*/

vars
	etRoot : EntTableDataRoot;
	etDef : EntTableDef;
	msg : String;
begin
	msg := "Fixing up ETDef_ScanReader object prior to EntTableDefs being reloaded";

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Starting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Starting");
	endif;	
	
	etRoot := app.myRoot.myEntTableDataRoot;
	if etRoot = null then
		// Running in a starterDB, EntTableDataRoot might not be set up yet.
		// So, we never need to fix up anything old, so never run again
		self.addScriptRun(method.name);
		return;
	endif;
	
	etDef := etRoot.allEntTableDefs["ScanReader"];
	if etDef = null then
		// Huh? Might be renamed in the future I guess ?
		self.addScriptRun(method.name);
		return;
	endif;
	
	if etDef.myEntTableGroup &lt;&gt; null and etDef.myEntTableGroup.name = "ScanReader" then
		app.writeLog(method.qualifiedName &amp; " Bad EntTableDef found, deleting", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg &amp; " Bad EntTableDef found, deleting");
		endif;
		
		beginTransaction;
		delete etDef;
		commitTransaction;
	endif;

	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Finished", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Finished");
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixCargoLocationsOnWagons" id="fb380f24-6e4c-4d32-9565-68b3b7249c55">
        <source>fixCargoLocationsOnWagons(_controller: CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2024	jlier1	Initial creation 65100

*/

vars
	msg : String;
	iter : Iterator;
	wagonControllerID	: String;
	lc   : CM_LocationsController;
	terminal : CM_Terminal;
	cargo : CM_TrackedItem;
	cargoToUpdate : CM_TISet;
begin
	msg := "Fixing up Cargo Location IDs on wagons";

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Starting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Starting");
	endif;	
	
	foreach terminal in app.myRoot.allTerminals do
		delete iter;
		iter:=terminal.allOnsiteTIsByIdCargoType.createIterator;
		while iter.next(cargo) do
			lc := cargo.getPrimaryLocation(REAL_MODE);
			if lc = null then
				continue;
			endif;
			if not lc.isKindOf(CM_WagonController) then
				continue;
			endif;
			wagonControllerID:= lc.getFullId[1:30]; 
			if not cargo.locationId.startsWith(wagonControllerID) then								
					beginTransaction;
					cargo.setLocationId(wagonControllerID);
					commitTransaction;
			
			endif;
		endwhile;	
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Completed Fixing up Cargo Location IDs on wagons", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Fixing up Cargo Location IDs on wagons");
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="initOnePortStatuses" id="a56348f3-3bd7-4072-ad46-97e4dabc8fce">
        <source>initOnePortStatuses(_controller: CnEcReleaseController);
/*

Purpose:			This upgrade script initialise each terminal in the system to have "Booked", "Confirmed", "Completed" and "Cancelled" as valid OnePort statuses

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
	root		: CM_Root;
	term		: CM_Terminal;
	nvPair		: CM_NameValuePair;
	termCode	: String;
begin
	
	// Only do this for NSW
	if not app.myRoot.isClientNSWPorts() then
		return;
	endif;
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Adding OnePort Status", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding OnePort Status") ;	
	endif;
	
	root := app.myRoot;
	
	beginTransaction;
	
	foreach term in root.allTerminals discreteLock do
		termCode := term.code;
		// Booked|Planned
		create nvPair persistent;
		nvPair.createNewPair("Booked", MovementStatus_Planned.String &amp; "|1");
		term.addOnePortStatus(nvPair);
		app.writeLog(method.qualifiedName &amp; " Addded 'Booked' status as 'Planned' to Terminal " &amp; termCode &amp; " OID - " &amp; nvPair.getOidString(), LogINFO);
		
		// Confirmed|Actual
		create nvPair persistent;
		nvPair.createNewPair("Confirmed", MovementStatus_Actual.String &amp; "|1");
		term.addOnePortStatus(nvPair);
		app.writeLog(method.qualifiedName &amp; " Addded 'Confirmed' status as 'Actual' to Terminal " &amp; termCode &amp; " OID - " &amp; nvPair.getOidString(), LogINFO);
		
		// Completed|Actual
		create nvPair persistent;
		nvPair.createNewPair("Completed", MovementStatus_Actual.String &amp; "|1");
		term.addOnePortStatus(nvPair);
		app.writeLog(method.qualifiedName &amp; " Addded 'Completed' status as 'Actual' to Terminal " &amp; termCode &amp; " OID - " &amp; nvPair.getOidString(), LogINFO);

		// Cancelled|Cancelled
		create nvPair persistent;
		nvPair.createNewPair("Cancelled", MovementStatus_Cancelled.String &amp; "|1");
		term.addOnePortStatus(nvPair);
		app.writeLog(method.qualifiedName &amp; " Addded 'Cancelled' status as 'Cancelled' to Terminal " &amp; termCode &amp; " OID - " &amp; nvPair.getOidString(), LogINFO);
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Adding OnePort Status complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding OnePort Status complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="invoiceStatusColour" id="c1632083-b666-4df3-ae35-66dfdd5d75d9">
