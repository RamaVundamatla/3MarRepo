<Class name="CMIF_TMCTIDefaultGroup" id="bfef2d04-32d9-4f95-8400-1c5b2e546017">
    <superclass name="CMIF_TMCTIGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
