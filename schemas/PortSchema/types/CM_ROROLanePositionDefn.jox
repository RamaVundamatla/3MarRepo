    <JadeMethod name="setFromLaneController" id="cefadf51-1c02-49b8-b6ed-9f22b226f9a7">
        <updating/>
        <source>setFromLaneController(_mainLaneLC : CM_ROROLaneController; _mode : Integer; _locnCode : String; _lengthDecimetres : Integer) updating;
/*
Purpose:			
Date		Who		Reason
06 December 2011	cnwab1	Initial creation
*/
 
vars
	theDeck : CM_Deck;
	theLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	lastLane : CM_ROROLaneDefn;
begin

	theDeck:= _mainLaneLC.myDeck;
	
	if _mode = ShpDisplayMode_ColCodeLoad then
		theLayer := theDeck.myDeckLayout.getCCLoadLayer();
	else
		theLayer := theDeck.myDeckLayout.getLaneLayer();
	endif;
	
	self.myDeck := theDeck;
	
	lastLane := theDeck.allROROLaneDefnByOrdinal.last;
	if lastLane &lt;&gt; null then
		self.ordinal := lastLane.ordinal + 1;
	else
		self.ordinal := 1;
	endif;
	
	if _locnCode &lt;&gt; null then
		self.setCode( _locnCode, false );
	else
		self.setCode( _mainLaneLC.myLaneDefn.code &amp; self.ordinal.String, false );
	endif;
	
	self.createLaneController();
	self.length := _lengthDecimetres / ROROStructurePixelsPerMetre; // TFS 39254  our length is in METRES
	self.myLanePositionController.setMyLaneController(_mainLaneLC);
	
	
	// ### CREATE A DEFAULT LAYOUT, We will resize this to match the Colour Coding RORO Request's layout
	if _mode = ShpDisplayMode_ColCodeLoad then
		pxyItemLayout := theLayer.setProxyNewItemLoadCC(true,4, 0, 0, self.code, White);
	else
		pxyItemLayout := theLayer.setProxyNewItemGC(false,true, 0, 0, self.code, White);
	endif;
	
	pxyItemLayout.setType(DeckItemLayoutType_Lane); // TFS 39254
	
	pxyItemLayout.setMyDeckLayer(theLayer);
	app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, app.myPassport); 
	if app.myPassport.hasErrorsOrWarnings() then
		return;
	endif;

	self.myLayout := realItemLayout;
epilog
	delete pxyItemLayout;
end;</source>
        <Parameter name="_mainLaneLC" type="CM_ROROLaneController"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_locnCode" type="String"/>
        <Parameter name="_lengthDecimetres" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="dcb53e7e-7e4f-4db4-a9a1-da29ab7304e6">
        <source>validateDelete(_passport: CM_Passport input);
/*
Purpose:		PAR 31671	
Date				Who			Reason
JUNE 2013		CNWAB1		Initial creation
*/

vars

begin

		
		if self.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasTIs(REAL_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_actual_ca,self.code, null, null);
		endif;
		if self.hasTIs(PLANNING_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_planne_ca,self.code, null, null);
		endif;
		if self.hasTIs(QUEUE_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_queued_ca,self.code, null, null);
		endif;	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
