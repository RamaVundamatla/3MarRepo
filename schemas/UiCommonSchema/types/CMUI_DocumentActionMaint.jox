    <JadeMethod name="doAddCargoOK" id="30ac2831-50a9-4d49-8099-524ac11a7f09">
        <source>doAddCargoOK() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001	

*/

vars

	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	selected : Boolean;
	rowIndex : Integer;
	amount : Real;
	amountArray : RealArray;

begin

	create tiArray transient;
	create amountArray transient;

	foreach rowIndex in 1 to self.tblCargo.rows do
		selected := self.tblCargo.accessCell( rowIndex, 1 ).text.Integer = 1;
		if not selected then
			continue;
		endif;
		ti := self.tblCargo.accessRow( rowIndex ).itemObject.CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		amount := ti.totalQuantity.max(1);
		if ti.myCargoType.allowDuplicates then
			if ti.myCargoType.isBulkByVolume then
				amount := ti.totalVolume;
			elseif ti.myCargoType.isBulkByWeight then
				amount := ti.totalWeight;
			endif;	
		endif;
		tiArray.add(ti);
		amountArray.add(amount);
	endforeach;
	
	app.myTrxUA.trxUpdateDocActionAssign( self.myRealDocumentAction, tiArray, amountArray, app.myPassport );
	
	self.populateTblCargo();

epilog

	delete tiArray;
	delete amountArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddCompletionsOK" id="eeac5372-b10a-4dfe-9263-a351d3ca3088">
        <source>doAddCompletionsOK() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars

	processingStops : Boolean;
	processingTasks : Boolean;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	table : Table;
	
	rowIndex : Integer;
	selected : Boolean;
	ti : CM_TrackedItem;
	qty : Real;
	remaining : Real;
	errMess : String;
	tiArray : CM_TIArray;
	qtyArray : RealArray;
	stopArray : ObjectArray;
	taskArray : ObjectArray;
	
	index : Integer;
	cmifDAC : CMIF_DocumentActionTrxCont;
	txnControllerSet : CMIF_TITxnControllerSet;
	newTrxSet : CM_TITransactionSet;
	
	result : Integer;
	
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	resourceUsageResult : Boolean;

begin

	processingStops := self.optStops.value;
	processingTasks := self.optTasks.value;
	
	table := self.tblCargoIDs;
	
	create tiArray transient;
	create qtyArray transient;
	create stopArray transient;
	create taskArray transient;
	
	foreach rowIndex in 2 to table.rows do
		selected := (table.accessCell( rowIndex, 2 ).text.String = '1');
		if not selected then
			continue;
		endif;
		if processingStops then
			stop := table.accessCell( rowIndex, 6 ).itemObject.CM_StopsTable;
			if stop = null then
				errMess := "Row " &amp; rowIndex.String &amp; " Stop Object not identified";
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				break;
			endif;
		elseif processingTasks then
			task := table.accessCell( rowIndex, 6 ).itemObject.CM_ToDoTaskDesc;
			if task = null then
				errMess := "Row " &amp; rowIndex.String &amp; " Task Object not identified";
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				break;
			endif;
		endif;
		
		ti := table.accessRow( rowIndex ).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			qty := table.accessCell( rowIndex, 5 ).text.String.Real;
			if qty &lt;= 0 then
				errMess := app.getErrorString2(Quantit_complet_not_valid, ti.id, qty.String);
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				break;
			endif;
			remaining := table.accessCell( rowIndex, 5 ).text.String.Real;
			if qty &gt; remaining then
				errMess := app.getErrorString3(Quant_compl_inval_not_great_th, ti.id, qty.String, remaining.String);
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				break;
			endif;
			tiArray.add( ti );
			qtyArray.add( qty ) ;
			stopArray.add( stop );
			taskArray.add( task );
		endif;
		
	endforeach;
	
	if tiArray.isEmpty then
		errMess := app.getErrorString(CMUI_Nothing_Selected);
		app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;

	if processingTasks then
	
		create resourceUsageProxys transient;
		task := self.cmbTasks.listObject.CM_ToDoTaskDesc;
		if task &lt;&gt; null and not task.allResourceTypes.isEmpty then
			resourceUsageResult := self.myAssistant.showResourceTypeUsageForTxn(null, null, task, tiArray.first, resourceUsageProxys, true, null);		//05.07.2024  navbs1  CR 64901 Task 64903
			if resourceUsageResult = false then
				// failed to create the form or was cancelled.
				app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return;
			endif;	
		endif;
		
	endif;
	
	create txnControllerSet transient;
	
	foreach index in 1 to tiArray.size do
		create cmifDAC transient;
		if processingStops then
			cmifDAC.type := TRANS_TYPE_STOPCLEARDA;
			cmifDAC.myStopsTable := stopArray[index].CM_StopsTable;
		elseif processingTasks then
			cmifDAC.type := TRANS_TYPE_TASKCOMPLETEDA;
			cmifDAC.myToDoTaskDesc := taskArray[index].CM_ToDoTaskDesc;
			if not resourceUsageProxys.isEmpty then
				resourceUsageProxys.copy( cmifDAC.allResourceUsageProxys );
			endif;
		endif;
		cmifDAC.noCharge := true; // TFS 3844 NOT CHARGEABLE; this is part of the functionality of duty docs
		cmifDAC.myTerminal := self.myTerminal;
		cmifDAC.myTrackedItem := tiArray[index];
		cmifDAC.amount := qtyArray[index];
		cmifDAC.myDocumentActions := self.myRealDocumentAction;
		txnControllerSet.add( cmifDAC );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateTITransactions( txnControllerSet, newTrxSet, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Create_locatio_check_transac), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;

		break;
	endwhile;
		
	self.populateTblCargoIds();
	
epilog

	delete tiArray;
	delete qtyArray;
	delete stopArray;
	delete taskArray;
	
	if txnControllerSet &lt;&gt; null and not txnControllerSet.isEmpty then
		txnControllerSet.purge();
	endif;
	delete txnControllerSet;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="ee7caee8-59a5-464b-b35e-f53b8706749b">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	topSheet : CMUI_Sheet;
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	selected : Boolean;
	rowIndex : Integer;

begin
	
	topSheet := self.fldMain.topSheet.CMUI_Sheet;
	
	if topSheet = self.shtAddCargo then
		self.doAddCargoOK();
			
	elseif topSheet = self.shtAddCompl then
		self.doAddCompletionsOK();
		
	else
		//shouldn't happen
		return;
	endif;

epilog

	delete tiSet;
	app.mousePointer := Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="fldMain_querySheetChg" id="fcf8f42a-51bb-4c7e-bcaf-b0c932aca19e">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

	msg : String;

begin
	
	if newSheet &lt;&gt; self.shtDelCompl then
		self.btnOk.parent := newSheet;
		self.btnOk.left := newSheet.width - self.btnOk.width - 5;
		self.btnOk.top := newSheet.height - self.btnOk.height - 5;
	endif;
	
	if newSheet = self.shtAddCargo then
		self.populateTblCargo();
		if self.myRealDocumentAction = null then
			msg := "Cargo can not be assigned to the Document Actions, until the Release has been saved.";
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
	elseif newSheet = self.shtAddCompl then
		self.populateTblCargoIds();
		if self.myRealDocumentAction = null then
			msg := "Cargo can not be completed on the Document Actions, until the Release has been saved.";
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
	elseif newSheet = self.shtDelCompl then
		self.populateTblTrans();
	endif;
	
	return true;

epilog

	app.mousePointer := Idle;

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuDelete_click" id="34095725-2227-4485-bf50-5a66fcf79676">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDelete_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2649

*/

vars

	txn : CM_TITransaction;

begin

	txn := menuItem.userObject.CM_TITransaction;
	if txn = null then
		return;
	endif;
	if app.getMyUser.canDo( self.myTerminal,  PmTiTransactionMaint) then
		app.myTrxDA.trxDeleteTITransaction(txn, null, app.myPassport);		// 12/10/18 MAP TFS41191
		self.populateTblTrans();
	endif;

epilog

	app.mousePointer := Idle;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
