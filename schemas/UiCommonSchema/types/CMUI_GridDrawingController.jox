    <JadeMethod name="getFillColourForRequest" id="b92f277f-29bd-4828-b9cb-c2dd1aaba279">
        <source>getFillColourForRequest(_sr: CM_SlotRequest): Integer;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCol : Integer;
begin
	
	if not self.myDrawingAttrController.allDischargePorts.includes(_sr.getAttrDischargePort()) then
		tmpCol := self.myDrawingAttrController.getColourForCC(self.viewMode, _sr);

	endif;
	
	return tmpCol;
end;</source>
