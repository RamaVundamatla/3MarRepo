    <JadeMethod name="setBusinessUnit" id="da917636-30ff-4bbf-bf20-1988e94f82d4">
        <updating/>
        <source>setBusinessUnit() updating;
/*
Purpose:			

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry
*/

vars
	shipTerm : CM_InvoiceContractShipTerm;
begin
	self.endNotificationForSubscriber(self.myCurrentBank);
	self.myCurrentBank := self.cmbBusinessUnit.listObject.CM_Bank;
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOTermCreate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOTermUpdate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOTermDelete), Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a316f54f-071c-4df6-9066-f1ff2449951a">
        <updating/>
        <source>setupForm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars

begin
	inheritMethod();
	self.doPermissions();	
	// ### TFS BUG 59633 31AUG2023 NAVAB1 self.handleMenusForModalDisplay();
	if self.myCurrentBank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	endif;
	self.doCmbBUBuild(self.cmbBusinessUnit);
	self.initTblINCOTerm(ETDef_IncoTermList);
	self.tblDisplayRow();
	self.setBusinessUnit();
	self.setNavigatorHeading(self.caption);
	
	self.setCaption("Invoice INCO Terms Enquiry " &amp; self.myCurrentBank.code );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="22a51d7f-bf9e-448c-910a-b4c9765093f7">
        <updating/>
        <source>tblDisplayRow()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	tbl					: CM_DataTable;
	iNCOTerm			: CM_InvoiceINCOTerm;
	idx					: Integer;
	str 				: String;

begin

	tbl := self.tblINCOTerm;
	tbl.rows := tbl.fixedRows;
	
	foreach iNCOTerm in self.myCurrentBank.allInvoiceINCOTerms
		where iNCOTerm.myBusinessUnit = self.myCurrentBank do
		str := iNCOTerm.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := iNCOTerm;
	endforeach;
epilog

end;</source>
    </JadeMethod>
