    <JadeMethod name="isSimilarQueueArea" id="25b7a3ac-7484-4b7b-b7bc-5724ff07631d">
        <source>isSimilarQueueArea(_location: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:     28 June 2010 by cnwcs5
// Purpose:     par 24418
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_TerminalAreaMaster;
begin
	if _location.isKindOf (CM_VehicleController) then
		// use area the vehicle is located
		area := _location.getMyTerminalArea;
	
		if area = self then
			return true;
		endif;
	
		return false;
	endif;
	
	return inheritMethod(_location);

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrouble" id="9162ab4d-0688-4ee4-ba7a-bd6dfb147006">
        <source>isTrouble():Boolean;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.areaType = CM_GateArea.AreaType_T;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUsedByOtherGates" id="641bc065-0588-4af2-b4c1-9fb917ee9def">
        <source>isUsedByOtherGates(_gate :CM_Gate):Boolean;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGates_IN do
		if usage.myGate &lt;&gt; _gate then
			return true;
		endif;
	endforeach;
	
	foreach usage in self.allGates_OUT do
		if usage.myGate &lt;&gt; _gate then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateDefaultLanes" id="b6093ede-67d1-415a-99fe-02c21a4d33a5">
        <updating/>
        <source>pxyCreateDefaultLanes() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:CM_LaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	
	lc := self.pxyCreateNewLane (true);
	lc.setLockDirection (true);
	lc := self.pxyCreateNewLane (false);
	lc.setLockDirection (true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7e3c9af4-4dec-452c-a03a-e2a346478242">
        <updating/>
        <source>setForCreate(_proxy :CM_GateArea input; _passport : CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod (_proxy, _passport);
	
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_GateArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f8d04338-69a8-47f0-8159-01041c6ca0f4">
        <updating/>
        <source>setForUpdate(_proxy :CM_GateArea)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config 
//				Required because other terminal area setForCreate methods
//				take CMIF_TerminalArea as parameter.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod (_proxy);
	
	self.areaType	:= _proxy.areaType;
	self.isInGate	:= _proxy.isInGate;
	self.isOutGate	:= _proxy.isOutGate;
epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="setMyPreGateLocation" id="8ac85e78-1cc9-4c9b-9eda-9c17f7230df3">
        <updating/>
        <source>setMyPreGateLocation(_location :CM_BlockController)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myInTransitToLocation &lt;&gt; _location then
		self.myInTransitToLocation	:= _location;
	endif;
epilog

end;</source>
        <Parameter name="_location" type="CM_BlockController"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e7e55641-f947-49cc-b36d-020f2b100d31">
        <updating/>
        <source>setProxy(_id :String; _comment :String; _terminal :CM_Terminal;
		_areaType :Integer;_in, _out :Boolean; _lanes :Integer)updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rows	:Integer;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _lanes = null then
		// has default lanes
		rows := 2;
	else
		rows := _lanes;
	endif;
	
	self.setGridAreaProxy (_id, _comment, TA_TYPE_GATE_ROAD, rows, 1, 2, true, _terminal, 
							false, false, false, null, false, false, false, false, false, null,null, false, false,
							null,null,null,null);	
	
	self.laneCount	:= _lanes;
	self.areaType	:= _areaType;
	self.isInGate	:= _in;
	self.isOutGate	:= _out;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_areaType" type="Integer"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <Parameter name="_lanes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1fb16981-b5e6-4f75-9cba-d682008d9287">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.isAGate then 
		if self.isOutGate then
			// temporary restriction for initial implementation
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'A gate cannot be an out-gate');
		endif;
		
		if not self.isInGate then
			// temporary restriction for initial implementation
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'A gate must be an in-gate');
		endif;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateLanes" id="d4545ba6-fa8f-4580-8c19-9ddcfed188db">
        <source>validateLanes() protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod();
	
	if self.laneCount = 0 then
		if self.allGridRows.size &lt;&gt; 2 then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Lane count mismatch. Expecting ' &amp;
											2.String &amp; ' found ' &amp; self.allGridRows.size.String);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
