        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars

begin
	inheritMethod();
	self.optCSV.value := true;
	if self.mode = EXTRACT_MODE then
		self.optCSV.caption := app.getErrorString(Extract);
		self.optXml.caption := app.getErrorString(ExtractXML);
