    <JadeMethod name="doBaseFormSave" id="83384731-70cb-4818-8143-43aa3349d448">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

//	pxyVoyageLayoutGraphic : CM_VoyageLayoutGraphic;
//	theVoyageLayoutGraphic : CM_VoyageLayoutGraphic;
	aCommand :	CM_GraphicCommand;
	theController : CMIF_GraphicCommandController;
	idx : Integer;
	theType,theX1, theY1,theX2, theY2, theFill,theColour : Integer;
	theStartX,theEndX,theStartY,theEndY: Integer;
	theLabel : String;
//	ls : Boolean;
begin
	if self.cmbGraphics.listIndex &lt; 1 then
		return;
	endif;
//	theVoyageLayoutGraphic := self.myGraphic.CM_VoyageLayoutGraphic;
	
	create theController transient;
	theController.myGraphic := self.myGraphic;
	theController.type := self.cmbGraphics.itemData[self.cmbGraphics.listIndex];
	
	foreach idx in 2 to self.tblDim.rows do
		theX1 := self.tblDim.accessCell(idx,COLUMN_X1).text.Integer;
		theY1 := self.tblDim.accessCell(idx,COLUMN_Y1).text.Integer;
		theX2 := self.tblDim.accessCell(idx,COLUMN_X2).text.Integer;
		theY2 := self.tblDim.accessCell(idx,COLUMN_Y2).text.Integer;
		//epr 8/8/08 ccms 1045
		theStartX:= self.tblDim.accessCell(idx,COLUMN_STARTX).text.Integer;
		theEndX:= self.tblDim.accessCell(idx,COLUMN_ENDX).text.Integer;
		theStartY:= self.tblDim.accessCell(idx,COLUMN_STARTY).text.Integer;
		theEndY:= self.tblDim.accessCell(idx,COLUMN_ENDY).text.Integer;
		
		theType := self.getCommandType(self.tblDim.accessCell(idx,COLUMN_TYPE).text.trimBlanks);
		theColour := self.tblDim.accessCell(idx,COLUMN_COLOUR).backColor;
		theFill := self.tblDim.accessCell(idx,COLUMN_FILL).backColor;
		theLabel := self.tblDim.accessCell(idx,COLUMN_LABEL).text;

		create aCommand transient;
		theController.allGraphicCommands.add(aCommand);
		aCommand.setProxy(theType,theX1,theY1,theX2,theY2,theStartX, theEndX,theStartY,theEndY,theColour,theFill,theLabel);
		
	endforeach;

	app.myTrxUA.trxUpdateGraphicCommands(theController,app.myPassport);
	
	if app.myPassport.hasErrorsOrWarnings = false then
		self.drawGraphic();
		
		self.lblColour.backColor := White;
		self.lblColour.foreColor := Black;
		global.beep;
	endif;
epilog
	if theController &lt;&gt; null then
		theController.allGraphicCommands.purge;
	endif;
	delete theController;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnExportClick" id="e8d6debc-d942-41d2-8801-af6441217cc4">
        <source>doBtnExportClick();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if self.mode = self.Mode_Ship then
		self.doExportShip();
	else
		self.doExportTIBehaviour();
	
	endif;

end;</source>
