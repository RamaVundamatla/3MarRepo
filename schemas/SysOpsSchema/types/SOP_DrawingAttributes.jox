    <JadeMethod name="btnNewSave_click" id="0f2e8397-45f1-4540-80e2-3ea7a56baac4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewSave_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCode : String;
	theRoot : CM_Root;
	aDT : CM_DrawingAttribute;
begin
	theRoot := app.myRoot;
	theCode := self.txtNewCode.text.trimBlanks;
	if theRoot.allDrawingAttributes[theCode] = null then
		beginTransaction;
		create aDT;
		aDT.myRoot := theRoot;
		aDT.fontName := "Ariel";
		aDT.fontCharacter := 65;
		aDT.code := theCode;
		aDT.colour := 255;
		commitTransaction;
		
		self.tblAttributes.rows := 0;
		self.displayTable();
		self.frmNew.visible := false;
		app.msgBox("Drawing attribute " &amp; theCode &amp; " has been added. " &amp; Cr
			&amp; "Please amend in the table to the font and character that you want." &amp; Cr
			&amp; "And then click SAVE.","Attribute Added", MsgBox_OK_Only);
	endif;
	self.frmNew.visible := false;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
