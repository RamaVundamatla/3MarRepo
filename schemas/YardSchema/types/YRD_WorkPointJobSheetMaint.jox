    <JadeMethod name="cmbShift_click" id="fcf8bfa8-9edd-43c0-8949-e42b31fed284">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbShift_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	shift : CM_Shift;
begin
	
	shift := self.cmbShift.listObject.CM_Shift;
	
	if shift &lt;&gt; null then
		self.dtDateFrom.setDate(shift.startDateTime.Date);
		self.tmFrom.setTime(shift.startDateTime.time);
		
		self.dtDateTo.setDate(shift.endDateTime.Date);
		self.tmTo.setTime(shift.endDateTime.time);
		
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbShift_displayEntry" id="ad83f438-f4af-4f39-b547-5342b7267323">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbShift_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars

begin
	return obj.CM_Shift.startDateTime.date.asStringJMT() &amp; Space &amp; obj.CM_Shift.getShiftDay &amp; Tab &amp; obj.CM_Shift.code;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
