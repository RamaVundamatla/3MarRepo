    <JadeMethod name="currentUserHasAccessToFormName" id="550c75a6-eb91-4a80-9147-f488ff53274f">
        <source>currentUserHasAccessToFormName(_formName : String) : Boolean;

/*

Purpose:			Determine whether the current user has any access to the passed in 
					JMT Web form name

Parameters:			Form name to check

Return Value:		True if the current user has any access, false otherwise


Date		Who		Reason
26 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	viewPermission,
	addPermission,
	updatePermission,
	deletePermission	: Integer;
	user				: CM_User;
	terminal			: CM_Terminal;

begin
	self.getJMTPermissionsForFormName(_formName,
									  viewPermission,
									  addPermission,
									  updatePermission,
									  deletePermission);
									 
	// If there's no view permission, then everyone can see it
	if viewPermission = null then
		return true;
	endif;
	
	user := app.getMyUser();
	terminal := app.getMyTerminalDO_NOT_USE();
	
	return user.canDo(terminal, viewPermission);

	
epilog

end;</source>
        <Parameter name="_formName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
