// ---------------------------------------------------------------------------
// Created:     06 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.showResultsInTable();
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
