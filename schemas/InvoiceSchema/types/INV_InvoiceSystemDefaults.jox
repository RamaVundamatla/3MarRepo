    <JadeMethod name="addToolbarControls" id="6c486f59-b2c5-474c-9ad5-718a3c683b46">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	// 34917 prototype, 36340 make them available for all
	///if app.isSpecial or app.isDevelopmentSystem then
		frm.addButton(self.btnProfConfig, CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnProfInvoice, CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnHealthCheck, CMUI_Toolbar.Control_Alignment_Left); // TFS 2682
	///endif;
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
