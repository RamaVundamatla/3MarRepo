    <JadeMethod name="displayTotalsRow" id="2f79fe22-1be6-481b-855f-e1db9f39b3bd">
        <source>displayTotalsRow();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars
	
	allocTotals : CM_VoyAllocationByPriority;
	tbl : CM_CCVoyAllocTable;
	voyAlloc : CM_VoyageAllocation;
	
	
	varianceColumn	: Integer;
	projectedColumn	: Integer;
	plannedColumn	: Integer;
	ccTotalColumn	: Integer;
	ccExportColumn	: Integer;
	ccSOBColumn	: Integer;	 
	ccDLRColumn	: Integer;
	selectedCol	: Integer;
	exportActualColumn	: Integer;
	sobActualColumn	: Integer;
	dlrActualColumn	: Integer;
	actualTotalColumn	: Integer;			
	
	exportActualTotal	: Integer;
	varianceTotal	: Integer; 
	projectedTotal	: Integer; 
	plannedTotal	: Integer;
	ccExportTotal	: Integer;
	ccTotal	: Integer;
	ccSOBTotal	: Integer;
	dlrActualTotal	: Integer; 
	ccDLRColumnTot	: Integer; 
	sobActualTotal	: Integer;
	actualTotalTotal	: Integer;					
	
	idx	: Integer;
	totTIs	: Integer;
	varience : Integer;
	iter : Iterator;
	doTotals : Boolean;
	
begin
	
	tbl := self;
	
	// ### GET COLUMN NUMBERS
	exportActualColumn := tbl.getColumnByRowName(ETRow_MatchingTIsCollection);	
	varianceColumn := tbl.getColumnByRowName(ETRow_Variance);	
	projectedColumn := tbl.getColumnByRowName(ETRow_Projected);	
	plannedColumn := tbl.getColumnByRowName(ETRow_SlotReqWithPlannedTIs);	
	ccTotalColumn := tbl.getColumnByRowName(ETRow_SlotRequests);	
	ccDLRColumn := tbl.getColumnByRowName(ETRow_ColourCodedRehandles);	
	dlrActualColumn := tbl.getColumnByRowName(ETRow_NumRehandles);				
	sobActualColumn := tbl.getColumnByRowName(ETRow_NumSoB);
	actualTotalColumn := tbl.getColumnByRowName(ETRow_TotalActual);
	ccExportColumn := tbl.getColumnByRowName(ETRow_ColourCodedExports);
	ccSOBColumn := tbl.getColumnByRowName(ETRow_ColourCodedSobs);
	
	//get rid of any existing totals rows.
	foreach idx in tbl.fixedRows + 1 to tbl.rows reversed do
		if tbl.accessRow(idx).itemObject = null then
			tbl.deleteRow(idx);
		endif;
	endforeach;
	
	// ### ADD UP ALL THE NUMBERS
	foreach idx in tbl.fixedRows + 1 to tbl.rows do		//cnwas3 par 26840
		if projectedColumn &gt; 0 then
			projectedTotal := projectedTotal + tbl.accessCell(idx,projectedColumn).text.Integer;
		endif;
		if exportActualColumn &gt; 0 then
			exportActualTotal := exportActualTotal + tbl.accessCell(idx,exportActualColumn).text.Integer;
		endif;
		if varianceColumn &gt; 0 then
			varianceTotal := varianceTotal + tbl.accessCell(idx,varianceColumn).text.Integer;
		endif;
		if plannedColumn &gt; 0 then
			plannedTotal := plannedTotal + tbl.accessCell(idx,plannedColumn).text.Integer;
		endif;
		if ccTotalColumn &gt; 0 then
			ccTotal := ccTotal + tbl.accessCell(idx,ccTotalColumn).text.Integer;
		endif;
		if ccDLRColumn &gt; 0 then
			ccDLRColumnTot := ccDLRColumnTot + tbl.accessCell(idx,ccDLRColumn).text.Integer;
		endif;
		if dlrActualColumn &gt; 0 then								
			dlrActualTotal := dlrActualTotal + tbl.accessCell(idx,dlrActualColumn).text.Integer;
		endif;
		if sobActualColumn &gt; 0 then								
			sobActualTotal := sobActualTotal + tbl.accessCell(idx,sobActualColumn).text.Integer;
		endif;
		if actualTotalColumn &gt; 0 then								
			actualTotalTotal := actualTotalTotal + tbl.accessCell(idx,actualTotalColumn).text.Integer;
		endif;
		if ccExportColumn &gt; 0 then								
			ccExportTotal := ccExportTotal + tbl.accessCell(idx,ccExportColumn).text.Integer;
		endif;
		if ccSOBColumn &gt; 0 then								
			ccSOBTotal := ccSOBTotal + tbl.accessCell(idx,ccSOBColumn).text.Integer;
		endif;
		doTotals := true;
	endforeach;
	
	selectedCol := tbl.getColumnByRowName(ETRow_Projected);

	// ### DISPLAY TOTALS
	if doTotals then
		// blank line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 5;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		// bold black line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 2;
		tbl.accessedRow.backColor := Black;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		
		// totals line
		idx := tbl.addItem(null);
		tbl.accessRow(idx);
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		if projectedColumn &gt; 0 then
			tbl.accessCell(idx,projectedColumn).text := projectedTotal.zeroNotAllowed();
		endif;
		if exportActualColumn &gt; 0 then
			tbl.accessCell(idx,exportActualColumn).text := exportActualTotal.zeroNotAllowed();
		endif;
		if varianceColumn &gt; 0 then
			tbl.accessCell(idx,varianceColumn).text := varianceTotal.zeroNotAllowed();
		endif;
		if plannedColumn &gt; 0 then
			tbl.accessCell(idx,plannedColumn).text := plannedTotal.zeroNotAllowed();
		endif;
		if ccTotalColumn &gt; 0 then
			tbl.accessCell(idx,ccTotalColumn).text := ccTotal.zeroNotAllowed();
		endif;
		if ccDLRColumn &gt; 0 then
			tbl.accessCell(idx,ccDLRColumn).text := ccDLRColumnTot.zeroNotAllowed();
		endif;
		if dlrActualColumn &gt; 0 then						
			tbl.accessCell(idx,dlrActualColumn).text := dlrActualTotal.zeroNotAllowed();
		endif;
		if sobActualColumn &gt; 0 then						
			tbl.accessCell(idx,sobActualColumn).text := sobActualTotal.zeroNotAllowed();
		endif;		
		if actualTotalColumn &gt; 0 then						
			tbl.accessCell(idx,actualTotalColumn).text := actualTotalTotal.zeroNotAllowed();
		endif;
		if ccExportColumn &gt; 0 then						
			tbl.accessCell(idx,ccExportColumn).text := ccExportTotal.zeroNotAllowed();
		endif;
		if ccSOBColumn &gt; 0 then						
			tbl.accessCell(idx,ccSOBColumn).text := ccSOBTotal.zeroNotAllowed();
		endif;

		// bold black line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 2;
		tbl.accessedRow.backColor := Black;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT

	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefreshAll" id="7b79ad42-ec14-46b1-b474-a83df2f4759c">
        <updating/>
        <source>doRefreshAll( _voyage : CM_Voyage ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars

	entTableDef : EntTableDef;
	selectedCol : Integer;
	ccVoyAllocRow : CMIF_CCVoyAllocRow;
	allVoyAllocsInOrder : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;
	
//	start : TimeStamp;

begin

	self.isInitialising := true;

//	start := app.actualTimeAppServer;
	
	self.rows := self.fixedRows;

	if _voyage &lt;&gt; null then	
		create allVoyAllocsInOrder transient;
		_voyage.populateAllocationsByPriority(allVoyAllocsInOrder);
		foreach voyAlloc in allVoyAllocsInOrder do
			ccVoyAllocRow := self.myCCVoyAllocTableRoot.getCCVoyAllocRowFor( voyAlloc );
			if ccVoyAllocRow &lt;&gt; null then
				self.addCCVoyAllocTableRow( ccVoyAllocRow );
				ccVoyAllocRow.setHasBeenUpdated(false);
			endif;
		endforeach;
	endif;
	
	self.displayTotalsRow();
	self.refreshNow();
	
	if self.myCCVoyAllocTableRoot.fullRefreshIsQueued then	// could have been set again.
		self.myCCVoyAllocTableRoot.startTimerForFullRefresh;
	elseif self.myCCVoyAllocTableRoot.partRefreshIsQueued then	// could have been set again.
		self.myCCVoyAllocTableRoot.startTimerForPartRefresh;
	endif;
	
//	writeElapsedTime( method.qualifiedName, start);
	
epilog

	self.isInitialising := false;
	delete allVoyAllocsInOrder;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doRefreshFromChanges" id="49d429b8-647c-4759-915c-bc55090155a9">
        <updating/>
        <source>doRefreshFromChanges() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars

	ccVoyAllocRow : CMIF_CCVoyAllocRow;
	wasSelected : Boolean;
	reselectVoyageAlloc : CM_VoyageAllocation;
	tableRow : JadeTableRow;
	reCalcTotals : Boolean;
	
//	start : TimeStamp;

begin

//	start := app.actualTimeAppServer;

	foreach ccVoyAllocRow in self.myCCVoyAllocTableRoot.allCCVoyAllocRows do
	
		if ccVoyAllocRow.hasBeenUpdated then
			reCalcTotals := true;
			ccVoyAllocRow.setHasBeenUpdated(false);
			wasSelected := self.updateCCVoyAllocTableRow( ccVoyAllocRow );
			if wasSelected then
				reselectVoyageAlloc := ccVoyAllocRow.myVoyageAllocation;
			endif;
		endif;
	endforeach;
	
	if reCalcTotals then
		self.displayTotalsRow();
		
		if reselectVoyageAlloc &lt;&gt; null then
			self.selectVoyageAllocationRow( reselectVoyageAlloc );
		endif;
	endif;
	
//	writeElapsedTime( method.qualifiedName, start);

epilog

	self.myCCVoyAllocTableRoot.partRefreshIsQueued := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="initialSetup" id="14912bee-69db-4865-94a6-b124514495a4">
        <updating/>
        <source>initialSetup( _voyage : CM_Voyage ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation	Par 28896


*/

vars

	entTableDef : EntTableDef;
	selectedCol : Integer;
	ccVoyAllocRow : CMIF_CCVoyAllocRow;
	allVoyAllocsInOrder : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;
	allVoyAllocByCode : CM_YardAllocationsByCodeDict;
	alloc : CM_YardAllocation;
	term : CM_Terminal;

begin

	self.isInitialising := true;

//	start := app.actualTimeAppServer;

	if self.myCCVoyAllocTableRoot = null then
		create self.myCCVoyAllocTableRoot transient;
		self.myCCVoyAllocTableRoot.setMyTable( self );
		self.setBaseTableData();
	endif;
	
	self.myCCVoyAllocTableRoot.setVoyage(_voyage);
	self.rows := self.fixedRows;

	
	if _voyage &lt;&gt; null then	
		term := _voyage.myTerminal;
		if term.getConfig(VoyAllocSortOrder).Integer = VoyAllocationSort_Alphabetic then // PAR 34184
			create allVoyAllocByCode transient;
			foreach alloc	in _voyage.allVoyageAllocations	 discreteLock do
				allVoyAllocByCode.add(alloc);
			endforeach;
			foreach alloc in allVoyAllocByCode do
			voyAlloc := alloc.CM_VoyageAllocation	;
				ccVoyAllocRow := self.myCCVoyAllocTableRoot.getCCVoyAllocRowFor( voyAlloc );
				if ccVoyAllocRow &lt;&gt; null then
					self.addCCVoyAllocTableRow( ccVoyAllocRow );
					ccVoyAllocRow.setHasBeenUpdated(false);
				endif;
			endforeach;
		else
			create allVoyAllocsInOrder transient;
			_voyage.populateAllocationsByPriority(allVoyAllocsInOrder);
			foreach voyAlloc in allVoyAllocsInOrder do
				ccVoyAllocRow := self.myCCVoyAllocTableRoot.getCCVoyAllocRowFor( voyAlloc );
				if ccVoyAllocRow &lt;&gt; null then
					self.addCCVoyAllocTableRow( ccVoyAllocRow );
					ccVoyAllocRow.setHasBeenUpdated(false);
				endif;
			endforeach;
		endif;
	endif;
	
	self.displayTotalsRow();
	self.refreshNow();
	
//	writeElapsedTime( method.qualifiedName, start);
	
	if self.myCCVoyAllocTableRoot.fullRefreshIsQueued then	// could have been set again.
		self.myCCVoyAllocTableRoot.partRefreshIsQueued := false;
//write "overlapped full refresh";
		self.myCCVoyAllocTableRoot.startTimerForFullRefresh; //epr par 30348 19/2/13
	elseif self.myCCVoyAllocTableRoot.partRefreshIsQueued then	// could have been set again.
//write "overlapped part refresh";
		self.myCCVoyAllocTableRoot.startTimerForPartRefresh;//epr par 30348 19/2/13
		endif;
	
epilog

	self.isInitialising := false;
	delete allVoyAllocsInOrder;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="selectVoyageAllocationRow" id="185b2b4e-a826-4752-b1af-b072e3fab068">
        <updating/>
        <source>selectVoyageAllocationRow( _selectVoyageAlloc : CM_VoyageAllocation ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars

	tableRow : JadeTableRow;

begin
	
	tableRow := self.cnEcFindObjectRow(_selectVoyageAlloc);
	if tableRow &lt;&gt; null then
		self.selectRow(tableRow.row,true);
		self.click(self);
	endif;

epilog

end;</source>
        <Parameter name="_selectVoyageAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="setBaseTableData" id="7c26b6d9-9572-44ed-a5a7-69ff8dd130c6">
        <updating/>
        <source>setBaseTableData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	entTableDef : EntTableDef;
	selectedCol : Integer;

begin

	self.clear();
	
	self.userInputEnabled := true;
	self.inputType := Table.InputType_None;	
	self.selectMode := CM_EntryTable.SelectMode_FixedRow;
	self.selectionType := CM_EntryTable.SelectionType_Row;

	self.defaultRowHeight := 20;
	self.fixedRows := 1;
	self.rows := self.fixedRows;
	
	entTableDef := app.myController.getEntTableDef(ETDef_ColourCodingPallette);
	if entTableDef &lt;&gt; null then
		self.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	self.readOnly := false;	
	self.fixedColumns := 0;
	self.show3D := Table.Show3D_Not3D;
	
	self.sortColumn[1] := 2;	
	self.sortAscending := true;	
	
	self.addItemAt(Tab &amp;  Tab &amp; "Exports" &amp; Tab &amp; Tab &amp; "Actual Cargo" &amp; Tab  &amp; Tab &amp; Tab &amp; Tab &amp; "Colour Coding" &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; "Planned",1);
	self.fixedRows := 2;
	
	self.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
	self.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	self.accessCell(1,3).mergeCells := Table.MergeCells_Merge;
	self.accessCell(1,3).alignment := Table.Alignment_Center_Middle;
	
	self.accessCell(1,5).mergeCells := Table.MergeCells_Merge;
	self.accessCell(1,5).alignment := Table.Alignment_Center_Middle;
	
	self.accessCell(1,9).mergeCells := Table.MergeCells_Merge;
	self.accessCell(1,9).alignment := Table.Alignment_Center_Middle;
	
	self.accessCell(1,13).mergeCells := Table.MergeCells_Merge;
	self.accessCell(1,13).alignment := Table.Alignment_Center_Middle;		
	
	self.accessRow(2).alignment:=Table.Alignment_Center_Middle;
	self.accessCell(2,2).alignment := Table.Alignment_Center_Middle;
	
	self.alignment := Table.Alignment_Right_Middle;
	self.accessColumn(2).alignment := Table.Alignment_Left_Middle;
	self.accessColumn(1).width := 25;	
	
	
	selectedCol := self.getColumnByRowName(ETRow_Projected);
	if selectedCol &gt; 0 then
		self.accessColumn(selectedCol).inputType := Table.InputType_TextNumeric;
		self.accessColumn(selectedCol).alignment := Table.Alignment_Center_Middle;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSelectedIndicator" id="ff0119cb-1bb6-4cf8-bc60-1c125e1ccf5e">
        <source>setSelectedIndicator();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars
	row,idx : Integer;	
	table : CM_DataTable;
begin
	table := self;
	
	row := table.row;
	if row &gt; 1 then
		foreach idx in table.fixedRows + 1 to table.rows do
			table.accessCell(idx,1).text := "";
			table.accessRow(idx).gridBottom := false;
			table.accessRow(idx).gridRight := false;
		endforeach;
		
		if table.accessRow(row).itemObject &lt;&gt; null then
			table.accessCell(row,1).alignment := Table.Alignment_Center_Top;
			table.accessCell(row,1).fontSize := 12;
			table.accessCell(row,1).fontName := "Wingdings";	
			table.accessCell(row,1).text := 232.Character;		
			table.accessRow(row).gridBottom := true;
			table.accessRow(row - 1).gridBottom := true;
		endif;
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateCCVoyAllocTableRow" id="db49975d-2c1f-412d-a58f-de09700f12bc">
        <updating/>
        <source>updateCCVoyAllocTableRow( _ccVoyAllocRow : CMIF_CCVoyAllocRow ):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896


*/

vars

	rowIndex : Integer;
	str : String;
	selectedColumnIndex : Integer;
	wasSelected : Boolean;
	nameCellColour : Integer;
	nameCellColumnIndex : Integer;
	cell :  JadeTableCell;

begin

	self.findObjectInRow( _ccVoyAllocRow.myVoyageAllocation, rowIndex );
	
	if rowIndex &gt; self.fixedRows and rowIndex &lt;= self.rows then
		
		selectedColumnIndex := self.getColumnByRowName( ETRow_Selected );
		if self.getCellText( rowIndex, selectedColumnIndex ).trimBlanks &lt;&gt; null then	// retain selection.
			wasSelected := true;
		endif;
		
		str := _ccVoyAllocRow.getTableRowDataDisplay( nameCellColour );
		self.setCellText( rowIndex, 1, str );
		
		nameCellColumnIndex := self.getColumnByRowName( ETRow_AllocName );
		cell := self.accessCell( rowIndex, nameCellColumnIndex );
		
		cell.backColor := nameCellColour;
		cell.foreColor := nameCellColour.getInverseColour;
		
	endif;
	
	return wasSelected;

epilog

end;</source>
        <Parameter name="_ccVoyAllocRow" type="CMIF_CCVoyAllocRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeElapsedTime" id="7fe7318d-eb96-4223-8453-753fef21ed45">
        <source>writeElapsedTime( _msg : String; _start : TimeStamp );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	elapsed : TimeStampInterval;

begin

	//If testing may want to uncomment use of this method in 
	//	doRefreshAll
	//	doRefreshFromChanges
	//	initialSetup
	
	executeWhen JMTDevelopmentEnvironment;

	elapsed := app.actualTimeServer() - _start;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	write _msg &amp; " - " &amp; _start.Time.format("hh:mm:ss.") &amp; _start.Time.milliSecond.String &amp; " - " &amp; elapsed.cnFormatted();

	endExecuteWhen;
	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_start" type="TimeStamp"/>
    </JadeMethod>
