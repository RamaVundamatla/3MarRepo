    <JadeMethod name="doBaseFormSave" id="630b7fd0-5a97-4d38-8b2f-4db14923d49c">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars

	voyAllocation : CM_YardAllocation;
	slotsSelected : Boolean;
	
begin
	
	if self.myCurrentVoyageAllocation = null then 
		return;
	endif;
	
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
			slotsSelected := self.myParentForm.CMUI_GridAreaForm2.anyVoySlotsSelected();		
		elseif parentIsROROplanningForm then
			slotsSelected := self.myParentForm.sendMsg("anyVoySlotsSelected").Boolean;
		else
			app.msgBox("Unknown Parent Form", "Parent Form Null", MsgBox_OK_Only);
			return;
		endif;
	endif;	
	
	if not slotsSelected then
		app.msgBox(app.getErrorString(Select_update_slots), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myParentForm.sendMsgWithParams("doSaveCC", self.myCurrentVoyageAllocation);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="a4d6b1bc-9568-4a4a-b0cd-f7108b230888">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
13 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
15 July 2010		cnwdap1	PAR #25021 review use of isImport/isExport for tranships
*/
	
vars
	coll				: ObjectSet;
	cm_TrackedItem		: CM_TrackedItem;
	iter1				: Iterator;
	isVoyCC : Boolean;
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myVoyage &lt;&gt; null then
		// For the current voyage get the ONSITE tracked items.
		iter1	:= self.myVoyage.allNotifiedTIsByIdCargoType.createIterator;
		while iter1.next( cm_TrackedItem ) do 
			if cm_TrackedItem.isChild() then // PAR 23271
				continue; // PAR 23271
			endif;
			//if cm_TrackedItem.isExport then										// PAR #25021
			if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	// PAR #25021
				coll.addNoDuplicates( cm_TrackedItem, false );
			endif;
		endwhile;
		delete iter1;
		
		iter1	:= self.myVoyage.allOnsiteTIsByIdCargoType.createIterator;
		while iter1.next( cm_TrackedItem ) do 
			if cm_TrackedItem.isChild() then // PAR 23271
				continue; // PAR 23271
			endif;
			//if cm_TrackedItem.isExport then										// PAR #25021
			if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	// PAR #25021
				coll.addNoDuplicates( cm_TrackedItem, false );
			endif;
		endwhile; 
		isVoyCC := true;
	endif;
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, isVoyCC, true );
	
epilog
	delete coll;
	delete iter1;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseBookings" id="bb0eb3ec-096f-4ea4-8ae4-0346348328a7">
        <source>doBtnSummariseBookings();
// ---------------------------------------------------------------------------
// Created:     29 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	coll				: ObjectSet;
	bookRef : CM_BookingRef;
begin
	
	app.mousePointer	:= Busy;
	create coll transient;
	
	foreach bookRef in self.myVoyage.allBookingRefs  discreteLock do
		if bookRef.isStockBookingRef then // PAR 22572
			continue; // PAR 22572
		endif;
		coll.add(bookRef);
	endforeach;
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, true, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;

end;</source>
    </JadeMethod>
