    <JadeMethod name="addCarrier" id="48f41783-65bc-4090-9e73-39add9849f6a">
        <source>addCarrier(_code, _description: String; _pinEmailAddresses: CM_EmailEntityByTypeNameDict; _isNotAvailableForEntry, _isRail, _isRoad : Boolean; _debtor : CM_Debtor): CM_Carrier;
//09 September 2010	by cnwvu1
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	pxyCarrier, newCarrier	: CM_Carrier;
	
begin

	self.deleteCarrier(_code);				// 06/12/2011 cnwmh5

	create pxyCarrier transient;
	
	//pxyCarrier.setProxy(_code, _description, _pinEmailAddresses, _isNotAvailableForEntry, _isRail, _isRoad, _debtor, null, null, null);			//12/05/2022 navhl20 TFS 53430
	pxyCarrier.setProxy(_code, _description, _pinEmailAddresses, _isNotAvailableForEntry, _isRail, _isRoad,false, _debtor, null, null, null);		//12/05/2022 navhl20 TFS 53430	

	app.myTrxCA.trxCreateCarrier(pxyCarrier, newCarrier, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();

	return newCarrier;
	
epilog

	delete pxyCarrier;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_pinEmailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isRail" type="Boolean"/>
        <Parameter name="_isRoad" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="addCashDebtor" id="c86035c3-c6cd-4428-9328-bd25f6103701">
        <source>addCashDebtor(_name : String; _address : String; _decfinName : String; _terminal : CM_Terminal) : CM_DebtorNode;
// add a cash-only debtor for a single terminal, populating the essential properties only
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	debtorTermDetail : CMIF_DebtorTerminalDetail;
	term : CM_Terminal;
	root : CM_Root;
	bank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;

	debtorNode	: CM_DebtorNode;
	proxyDebtor	: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;

begin
	create debtorNodeController transient;
	create proxyDebtor transient;
	root := app.myRoot;
	bank := root.myRootCompany;
	rdg := bank.getRootDebtorGroup();
	
	debtorNodeController.billingAddress := _address;
	debtorNodeController.decfinName := _decfinName;
	debtorNodeController.isSuspended := false;
	debtorNodeController.isZeroRated := false;
	debtorNodeController.badDebtor := false;
	debtorNodeController.myBank := bank;
	debtorNodeController.myTermsOfTrade := null ;	
	// parent is root debtor
	debtorNodeController.myParentDebtorNode := rdg;

	debtorNodeController.myPxyDebtorNode := proxyDebtor;
	debtorNodeController.name := _name;

	 // ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
	foreach term in root.allTerminals do
		create debtorTermDetail transient;
		
		debtorTermDetail.setMyTerminal(term);
		debtorTermDetail.setPaymentType(PaymentType_PostPay);
		debtorTermDetail.setCashOnly(term = _terminal);
		debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
	endforeach;
	
	//proxyDebtor.setProxy(debtorNodeController.name);								// TFS 40092
	proxyDebtor.setProxy(debtorNodeController.name, debtorNodeController.code);		// TFS 40092
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return debtorNode;
epilog
	debtorNodeController.allDebtorTerminalDetails.purge;
	delete debtorNodeController;
	delete proxyDebtor;
end;

</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_address" type="String"/>
        <Parameter name="_decfinName" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="addCheckPoint" id="902c3d1d-3aa3-4939-9708-6e0fe0027d13">
        <source>addCheckPoint(_checkPointId, _checkPointDesc, _hiLoTideReference, _hiLoTideReference2 : String; _harbour : HMS_Harbour; _tidalModel : HMS_TidalModelDefinition; 
			_checkPointType, _hiLoRelativeTimeFrom, _hiLoRelativeTimeTo, _hiLoRelativeTimeFrom2, _hiLoRelativeTimeTo2, 
			_tideRangeAmount, _tideRangeAmount2, _tideState: Integer) : HMS_CheckPoint;

/*

Purpose:		Add Check Point / Restriction	

Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/

vars

	pxyCheckPoint				: HMS_CheckPoint;
	checkPointObj				: HMS_Object;
	checkPoint					: HMS_CheckPoint;

begin

	self.deleteCheckPoint(_checkPointId, _harbour);

	create pxyCheckPoint transient;
	pxyCheckPoint.setProxy(app.myRoot,							// root 		: CM_Root; 
						  _harbour, 				 			// harbour : HMS_Harbour;
						  _checkPointType,						// checkpoint type : Integer;
						  _tidalModel, 							// tidal model : HMS_TidalModelDefinition;
						  _hiLoTideReference, 					//  : String;
						  _hiLoRelativeTimeTo, 					// : Integer;
						  _hiLoRelativeTimeFrom, 				// : Integer;
						  _hiLoTideReference2, 					// : String;
						  _hiLoRelativeTimeTo2, 				// : Integer;
						  _hiLoRelativeTimeFrom2, 				// : Integer;
						  null,									//_tideRangeReference : String;
						  _tideRangeAmount,						//_tideRangeAmount : Integer;
						  null,									//_tideRangeReference2 : String;
						  _tideRangeAmount2,					//_tideRangeAmount2 : Integer;
						  0,									//_gapTimeDifference : Integer;
						  null,									//_shipsDepartTimings : String;
						  false,								//_timeGapCheckArrivals : Boolean;
						  false,								//_timeGapCheckDepartures : Boolean;
						  null,									// _timeGapToCheckRegion : HMS_HarbourRegion;
						  _tideState,							//_tideState : Integer;
						  null, 								// jadeCode : String
						  null);								// user code : String
						  
	pxyCheckPoint.setPropertyValue("code", _checkPointId);
	pxyCheckPoint.setPropertyValue("description", _checkPointDesc);
	
	app.myTrxCA.trxCreateHMSObject(pxyCheckPoint, checkPointObj, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	if self.opts.includesKey("OverrideCheckPointType") then
		beginTransaction;
		checkPointObj.HMS_CheckPoint.setPropertyValue("checkPointType", self.opts.int("OverrideCheckPointType"));
		commitTransaction;
	endif;
	
	if self.opts.includesKey("HookCode") then
		checkPoint := checkPointObj.HMS_CheckPoint;
		if checkPoint.myHookCode &lt;&gt; null then
			beginTransaction;
			if checkPoint.myHookCode.myHookType &lt;&gt; null then
				checkPoint.myHookCode.myHookType.setPropertyValue("hookMethodTemplate", self.opts.str("HookCode"));
			endif;
			checkPoint.myHookCode.setPropertyValue("code", checkPoint.code);
			if not checkPoint.myHookCode.allHookCodeHistory.isEmpty() then
				checkPoint.myHookCode.allHookCodeHistory.first.CM_HookCodeHistory.setPropertyValue("jadeCode", self.opts.str("HookCode"));
			endif;
			commitTransaction;
		endif;
	endif;
	
	return checkPointObj.HMS_CheckPoint;
	
epilog

	delete pxyCheckPoint;

end;</source>
        <Parameter name="_checkPointId" type="String"/>
        <Parameter name="_checkPointDesc" type="String"/>
        <Parameter name="_hiLoTideReference" type="String"/>
        <Parameter name="_hiLoTideReference2" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_checkPointType" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeTo" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom2" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeTo2" type="Integer"/>
        <Parameter name="_tideRangeAmount" type="Integer"/>
        <Parameter name="_tideRangeAmount2" type="Integer"/>
        <Parameter name="_tideState" type="Integer"/>
        <ReturnType type="HMS_CheckPoint"/>
    </JadeMethod>
    <JadeMethod name="addCodeGroup" id="8bcb1c83-1e69-4389-ac6b-d74d1a582be7">
        <source>addCodeGroup(_codeGroupName: String; _codeGroupType: Integer) : CM_CodeGroup;
//03 September 2010	by cnwvu1

vars
	newCodeGroup	: CM_CodeGroup;
	pxyCodeGroup	: CM_CodeGroup;
	
begin


	if _codeGroupType = CodeGroup_LogSpecs then	// Log Specs case
		create pxyCodeGroup as CM_CodeGroupLogSpecs transient;	
	
	elseif _codeGroupType = CodeGroup_SourceLocation then	// Source Locations
		create pxyCodeGroup transient;
	else	
		// for other code groups put code here for proxy objects
	endif;
	
	pxyCodeGroup.setProxy( _codeGroupType, _codeGroupName, app.myRoot);
								
	app.myTrxCA.trxCreateCodeGroup(pxyCodeGroup, newCodeGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newCodeGroup;

epilog
	delete pxyCodeGroup;
	
end;</source>
        <Parameter name="_codeGroupName" type="String"/>
        <Parameter name="_codeGroupType" type="Integer"/>
        <ReturnType type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="addCommodity" id="1d7264ed-faf4-4704-8f3e-acd0f8831b64">
        <source>addCommodity(_commodityId, _commodityDesc : String; _selectedCargoTypes : ObjectArray) : CM_Commodity;

/*

Purpose:		Add a commodity	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation
25/03/2015		cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
*/

vars

	pxyCommodity					: CM_Commodity;
	commodity						: CM_Commodity;
	
	selectedCargoTypes				: ObjectArray;
	
	requiresTemp					: Boolean;
	maxTemp							: Real;
	minTemp							: Real;
	isEmptyCommodityForContainer	: Boolean;
	requiresPower					: Boolean;
	requiresPackDetailsMAF			: Boolean;
	codeToPrintBayPlan				: String;
	selectedCargoCreatedHere		: Boolean;

begin

	self.deleteCommodity(_commodityId);

	create pxyCommodity transient;
	
	// no cargo types then default to ISO Container
	selectedCargoTypes := _selectedCargoTypes;
	if selectedCargoTypes = null then
		create selectedCargoTypes transient;
		selectedCargoCreatedHere := true;
	endif;
	if selectedCargoTypes.isEmpty() then
		selectedCargoTypes.add(app.myRoot.getCargoTypeForID(1));
	endif;
	
	if self.opts.includesKey("RequiresTemp") then
		requiresTemp := self.opts.bool("RequiresTemp");
	endif;
	if self.opts.includesKey("MaxTemp") then
		maxTemp := self.opts.real("MaxTemp");
	endif;
	if self.opts.includesKey("MinTemp") then
		minTemp := self.opts.real("MinTemp");
	endif;
	if self.opts.includesKey("RequiresPower") then
		requiresPower := self.opts.bool("RequiresPower");
	endif;
	if self.opts.includesKey("RequiresPackDetailsMAF") then
		requiresPackDetailsMAF := self.opts.bool("RequiresPackDetailsMAF");
	endif;
	if self.opts.includesKey("IsEmptyCommodityForContainer") then
		isEmptyCommodityForContainer := self.opts.bool("IsEmptyCommodityForContainer");
	endif;
	if self.opts.includesKey("CodeToPrintBayPlan") then
		codeToPrintBayPlan := self.opts.str("CodeToPrintBayPlan");
	endif;
	
	pxyCommodity.setProxy(_commodityId,				// Id / Code
						  _commodityDesc,			// Description
						  null, 					// Short Description
						  codeToPrintBayPlan,		// Bayplan Print As
						  requiresTemp,				// has temp
						  requiresPower,			// requeires power
						  requiresPackDetailsMAF,	// requires pack details
						  false, 					// not available for enty
						  isEmptyCommodityForContainer,	// is empty
						  0, 						// colour
						  maxTemp,					// max temp
						  minTemp, 					// min temp
						  null, 					// Commodity Group
						  null,						// Special stow
						  false,					// Is Used For Packing				// PAR #35895
						  selectedCargoTypes,		// all cargo Types
						  false						// requiresWeighing 
						  );		
						  
	app.myTrxCA.trxCreateCommodity(pxyCommodity, commodity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return commodity;

epilog
	delete pxyCommodity;
	if selectedCargoCreatedHere then
		delete selectedCargoTypes;
	endif;
end;</source>
        <Parameter name="_commodityId" type="String"/>
        <Parameter name="_commodityDesc" type="String"/>
        <Parameter name="_selectedCargoTypes" type="ObjectArray"/>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="addCommodityGroup" id="e3ddc6fa-c0f0-4487-8637-628bb3289a14">
        <source>addCommodityGroup(_commodityGroupCode,_commodityGroupDesc : String): CM_CommodityGroup;
/*

Purpose:	Add a Commodity Group			

Parameters:			
upup
Date		Who		Reason
20/02/2014	cnwma1	Initial creation

*/

vars
	pxyCommodityGroup	: CM_CommodityGroup;
	commodityGroup		: CM_CommodityGroup;
	commodities			: CM_CommodityByCodeDict;

begin

	// Delete commodityGroup
	self.deleteCommodityGroup(_commodityGroupCode);

	create pxyCommodityGroup transient;
	create commodities transient;

	if self.opts.includesKey("Commodity") then
		self.opts.obj("Commodity").ObjectArray.copy(commodities);
	endif;	
	
	pxyCommodityGroup.setProxy(_commodityGroupCode,
							   _commodityGroupDesc,
							   1,
							   true,
							   6,
							   5,
							   commodities,
							   true,
							   true);

	app.myTrxCA.trxCreateCommodityGroup(pxyCommodityGroup,commodityGroup,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return commodityGroup;

epilog
	delete commodities;
	delete pxyCommodityGroup;

end;</source>
        <Parameter name="_commodityGroupCode" type="String"/>
        <Parameter name="_commodityGroupDesc" type="String"/>
        <ReturnType type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="addConsignGroup" id="97f3e08f-97ae-40d5-acd1-7bc676500f26">
        <source>addConsignGroup(_consignGroupID, _consignGroupDesc : String; _consignColl : CM_ConsignByCodeDict) : CM_ConsigneeConsignorGroup;

/*

Purpose:		Add a consignor / consignee / freight forwarder group

Date			Who		Reason
18/02/2013		cnwmh5	Initial creation

*/

vars

	pxyConsignGroup				: CM_ConsigneeConsignorGroup;
	consignGroup				: CM_ConsigneeConsignorGroup;
	
	consignColl					: CM_ConsignByCodeDict;
	
	description					: String;

begin

	self.deleteConsignGroup(_consignGroupID);
	
	if _consignColl = null then
		create consignColl transient;
	else
		_consignColl.copy(consignColl);
	endif;	
	
	create pxyConsignGroup transient;
	pxyConsignGroup.setProxy(_consignGroupID, _consignGroupDesc, consignColl);
	
	app.myTrxCA.trxCreateConsignGroup(pxyConsignGroup, consignGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	return consignGroup;

epilog

	delete pxyConsignGroup;
	delete consignColl;

end;</source>
        <Parameter name="_consignGroupID" type="String"/>
        <Parameter name="_consignGroupDesc" type="String"/>
        <Parameter name="_consignColl" type="CM_ConsignByCodeDict"/>
        <ReturnType type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
    <JadeMethod name="addConsigneeConsignor" id="a53f5d56-1e87-4362-9509-76099c43575e">
        <source>addConsigneeConsignor(_code, _desc : String; _isConsignee, _isConsignor, _isFreightFwdr : Boolean) : CM_ConsigneeConsignor;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/08/2011	cnwmh5	Initial creation
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 added isUsedForPacking attribute
03 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
*/

vars
	consignGroup			: CM_ConsigneeConsignorGroup;
	debtor					: CM_Debtor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	newConsigneeConsignor	: CM_ConsigneeConsignor;
	passport				: CM_Passport;
	license : String;
	licenseExpiryDate : Date;
	isUsedForPacking		: Boolean;				// PAR #35895
	isRestricted			: Boolean;	// 2.8.2017 cnwma1 TFS #5209
	isInternal				: Boolean;
begin
	
	self.deleteConsigneeConsignor(_code);						// 18/09/2012 cnwmh5
	
	if self.opts.str( ETRow_ConsignGroupStr ) &lt;&gt; null then
		consignGroup	:= app.myRoot.allConsignGroups[ self.opts.str( ETRow_ConsignGroupStr ) ];
	endif;
	
	if self.opts.str( ETRow_DebtorStr ) &lt;&gt; null then
		debtor	:= app.myRoot.myRootCompany.debtors[ self.opts.str( ETRow_DebtorStr ) ];
	endif;
		
	if self.opts.includesKey( ETRow_License ) then
		license	:= opts.str(ETRow_License);
	endif;
	
	licenseExpiryDate := null;
	if opts.includesKey(ETRow_LicenseExpiryDate) then
		licenseExpiryDate := opts.str(ETRow_LicenseExpiryDate).Date;
	endif;
	
	isUsedForPacking := false;
	if opts.includesKey (ETRow_IsUsedForPacking) then
		isUsedForPacking := opts.str(ETRow_IsUsedForPacking).Boolean;
	endif;

	// 3.8.2017 cnwma1 TFS #5209
	if opts.includesKey (ETRow_IsRestricted) then
		isRestricted := opts.str(ETRow_IsRestricted).Boolean;
	endif;
	
	isInternal := self.opts.bool(ETRow_IsInternal);
	
	create proxyConsigneeConsignor transient;
	proxyConsigneeConsignor.setProxy( _code,												// Code
									  _desc,												// Description
									  self.opts.bool( ETRow_IsNotAvailableForEntry ),		// Available for entry
									  false,												// secure export partner
									  null,													// derogation number
									  null,													// email address
									  0,													// colour
									  0,													// order is always zero!
									  consignGroup,											// consignee/consignor group
									  debtor,												// debtor
									  false,												// show OOW remarks
									  _isConsignee,											// is consignee
									  _isConsignor,											// is consignor
									  _isFreightFwdr,										// is freight forwarder
									  null,													// PIN notify email address
									  license,												//cnwmc5 - 19/12/2012 - HAT 2198
									  licenseExpiryDate,									//cnwmc5 - 19/12/2012 - HAT 2198
									  isUsedForPacking,									// PAR #35895
									  isRestricted,
									  isInternal);											// 2.8.2017 cnwma1 TFS #5209
	app.myTrxCA.trxCreateConsigneeConsignor( proxyConsigneeConsignor, newConsigneeConsignor, app.myPassport );
	self.assertNoTrxErrorsOrWarnings();
	
	return newConsigneeConsignor;
	
epilog
	delete proxyConsigneeConsignor;
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isConsignee" type="Boolean"/>
        <Parameter name="_isConsignor" type="Boolean"/>
        <Parameter name="_isFreightFwdr" type="Boolean"/>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="addConsigneeConsignorAddress" id="74004010-cedb-45de-9ec8-0ab96c56c246">
        <source>addConsigneeConsignorAddress(_code, _desc : String; _isConsignee, _isConsignor, _isFreightFwdr : Boolean;
							 _address1, _address2, _address3, _postCode, _region, _countryCode : String) : CM_ConsigneeConsignor;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/08/2011	cnwmh5	Initial creation
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedforPacking attribute
03 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
*/

vars
	addressDetailsEntered	: Boolean;
	consignGroup			: CM_ConsigneeConsignorGroup;
	debtor					: CM_Debtor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	newConsigneeConsignor	: CM_ConsigneeConsignor;
	proxyAddress			: CM_Address;
	passport				: CM_Passport;

begin
	
	self.deleteConsigneeConsignor(_code);						// 18/09/2012 cnwmh5
	
	if self.opts.str( ETRow_ConsignGroupStr ) &lt;&gt; null then
		consignGroup	:= app.myRoot.allConsignGroups[ self.opts.str( ETRow_ConsignGroupStr ) ];
	endif;
	
	if self.opts.str( ETRow_DebtorStr ) &lt;&gt; null then
		debtor	:= app.myRoot.myRootCompany.debtors[ self.opts.str( ETRow_DebtorStr ) ];
	endif;

	if _address1 &lt;&gt; null or
	   _address2 &lt;&gt; null or
	   _address3 &lt;&gt; null or
	   _postCode &lt;&gt; null or
	   _region &lt;&gt; null or
	   _countryCode &lt;&gt; null then
		addressDetailsEntered := true;
	endif;
	// don't create a CM_Address if no address details entered
	if addressDetailsEntered then
		create proxyAddress transient;
		proxyAddress.update(_address1, _address2, _address3, _postCode, _region, _countryCode);
	endif;
	
	create proxyConsigneeConsignor transient;

	proxyConsigneeConsignor.setMyAddress(proxyAddress);
	proxyConsigneeConsignor.setProxy( _code,												// Code
									  _desc,												// Description
									  self.opts.bool( ETRow_IsNotAvailableForEntry ),		// Available for entry
									  false,												// secure export partner
									  null,													// derogation number
									  null,													// email address
									  0,													// colour
									  0,													// order is always zero!
									  consignGroup,											// consignee/consignor group
									  debtor,												// debtor
									  false,												// show OOW remarks
									  _isConsignee,											// is consignee
									  _isConsignor,											// is consignor
									  _isFreightFwdr,										// is freight forwarder
									  null,													// PIN notify email address
									  null,													//cnwmc5 - 19/12/2012 - HAT 2198
									  null,													//cnwmc5 - 19/12/2012 - HAT 2198
									  false,												// PAR #35895
									  false,
									  false);											    // 3.8.2017 cnwma1 TFS #5209
	app.myTrxCA.trxCreateConsigneeConsignor( proxyConsigneeConsignor, newConsigneeConsignor, app.myPassport );
	self.assertNoTrxErrorsOrWarnings();
	
	return newConsigneeConsignor;
	
epilog
	delete proxyConsigneeConsignor;
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isConsignee" type="Boolean"/>
        <Parameter name="_isConsignor" type="Boolean"/>
        <Parameter name="_isFreightFwdr" type="Boolean"/>
        <Parameter name="_address1" type="String"/>
        <Parameter name="_address2" type="String"/>
        <Parameter name="_address3" type="String"/>
        <Parameter name="_postCode" type="String"/>
        <Parameter name="_region" type="String"/>
        <Parameter name="_countryCode" type="String"/>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="addContainer" id="a3726291-bf58-468f-9a6b-1dd9ac3394b4">
        <source>addContainer(_id: String; _operator:CM_Operator; _isoType: String; _commodity: String; _imexStatus: Integer) : CM_TrackedItem;
//29 August 2008	cnwdw1	
// This call should be followed by a move so that the container has a location
//
// Date			Who		Reason
// 23 Apr 13	PJS		PAR #31237
// 07 Nov 2025	jlizm1	MTN 36328 Rotabox Assign Release To Vessel Unit Test
//
vars
	pxyTI: CM_TrackedItem;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
begin
	deleteContainer(_id);
	pxyTI := self.createContainer(_id, _isoType, _commodity, _operator,true);
	//pxyTI.setWeight(2000, null, null);					//-cnwml2 MSL CCMS 1017
	pxyTI.setTotalWeight(2000, null, null);				//+cnwml2 MSL CCMS 1017
	pxyTI.setWeightTare(400);
	pxyTI.zSetPxyImexStatus(_imexStatus);
//	pxyTI.setVolume(6.666);	// #25592. Need some volume to test. 08/11/2010
	// ### TFS 59411 (61855) 30Jan2024 NAVPW1
	if self.opts.includesKey(UT_OPTS_TotalVolume) then
		if self.opts.dec(UT_OPTS_TotalVolume) &lt;&gt; null then
			pxyTI.zSetPxyTotalVolume(self.opts.dec(UT_OPTS_TotalVolume));
		else
			pxyTI.zSetPxyTotalVolume(self.opts.int(UT_OPTS_TotalVolume));
		endif;
	else
		pxyTI.zSetPxyTotalVolume(6.666);	//03 Jun 2011	NDL Par 26504
	endif;
	// ### TFS 59411 (61855) 30Jan2024 NAVPW1
	
	if self.opts.includesKey("quantity") then							// 24/09/2012 cnmwh5 #30120/#29876
		pxyTI.zSetPxyQuantity(self.opts.int('quantity'));
	endif;
	
	// PAr # 31237
	if self.opts.includesKey(UTTI_SpecialLifts) then							
		pxyTI.zSetPxySpecialLifts(self.opts.obj(UTTI_SpecialLifts).CM_SpecialLiftByCodeDict);
	endif;
	
	if self.opts.includesKey(UTTI_VoyageCode) then
		voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.opts.str(UTTI_VoyageCode), null);
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	
	// ### TFS 60223 (60467) 12Sep2023 NAVPW1
	if self.opts.includesKey(UT_OPTS_DestinationPort) then
		pxyTI.setDestinationPort(self.opts.str(UT_OPTS_DestinationPort));
	endif;
	// ### TFS 60223 (60467) 12Sep2023 NAVPW1
	
	if self.opts.includesKey("cargoTypeForContents") then
		pxyTI.setCargoTypeForContents(self.opts.obj("cargoTypeForContents").CM_CargoType);
	endif;
	
	if self.opts.includesKey("cargoSubTypeForContents") then
		pxyTI.setCargoSubTypeForContents(self.opts.obj("cargoSubTypeForContents").CM_Product);
	endif;
	
	// ### JIRA: MTN-36370 19Nov2025 NAVPW1
	if self.opts.includesKey(UTTI_Consignee) then							
		pxyTI.zSetPxyConsignee(self.opts.str(UTTI_Consignee));
	endif;
	// ### JIRA: MTN-36370 19Nov2025 NAVPW1
	
	if _commodity = "REEF" then
		pxyTI.setTemperature(4);
	endif;
	
	if self.opts.includesKey("temp") then	
		pxyTI.setTemperature( self.opts.dec("temp") );
	endif;
	
	//26 Aug 2020	NDL	TFS 49950
	if self.opts.includesKey("STATE") then
		pxyTI.changeState(self.opts.int("STATE"), app.myPassport);
	endif;
	
	return self.addContainerFromProxy(pxyTI);

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainerAtLocation" id="c4000727-2e45-4801-8348-c85b52765e43">
        <source>addContainerAtLocation(id: String; _operator:CM_Operator; isoType: String; commodity: String; _imexStatus: Integer; _location : Any) : CM_Container;
/*
Date		Who		Reason
05 February 2009	cnwcp2	Initial creation
*/

vars
	cont			: CM_Container;
	operatorObj		: CM_Operator;
	
begin
	if _operator = null then
		operatorObj	:=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	else
		operatorObj	:=	_operator;
	endif;
	
	cont := self.addContainer(id, operatorObj, isoType, commodity, _imexStatus).CM_Container;
	move(cont, self.getLocationsController(_location));
	
	return cont;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="isoType" type="String"/>
        <Parameter name="commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_location" type="Any"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="addContainerAtLocnDisch" id="47438774-c6bf-44be-80bc-f5a25d86ed61">
        <source>addContainerAtLocnDisch(id: String; isoType: String; commodity: String; _imexStatus: Integer; location : CM_LocationsController; _disch : CM_Port;_voyage : CM_Voyage) : CM_Container;
// ---------------------------------------------------------------------------
// Created:     June 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cont : CM_Container;
begin

	if id[1:4] = "ODOD" then
		self.opts.addAssoc(UTTI_OverWidthLeft, 23);
	endif;
	if _voyage &lt;&gt; null then
		self.opts.addAssoc(UTTI_VoyageCode, _voyage.code);
	endif;
	if _disch &lt;&gt; null then
		self.opts.addAssoc(UTTI_DischargePort, _disch.code);
	endif;
	self.opts.addAssoc(UTTI_IMEX, _imexStatus);
	
	cont := self.addContainerOpts(id, isoType, commodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	
	move(cont, location);
	return cont;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="isoType" type="String"/>
        <Parameter name="commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="location" type="CM_LocationsController"/>
        <Parameter name="_disch" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="addContainerChildren" id="1ef3b3a2-117f-486a-805d-83fee4fd5067">
        <source>addContainerChildren(/*_parentTI: CM_Container input;*/ _parentTI: CM_TrackedItem input; _attachments: CMIF_InOutAttachmentArray);
//13 November 2008	cnwdw1	
//
// 12/04/2021 navmd1 TFS 51050 Allow non-container TIs to have child cargo packed into them
//
vars
	attach: CMIF_InOutAttachment;
	updateController	: CMIF_TIUpdateController;
	proxyChildTI: CM_TrackedItem;
begin
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);

	foreach attach in _attachments do
		create proxyChildTI as attach.myCargoType.myClassToCreate transient;
		proxyChildTI.setPxyFromDefaultTI(getTerminal, attach.myCargoType.id, attach.id, null, null); 
		proxyChildTI.setPxyFromCMIF_InOutAttachment(attach, app.myPassport);
		proxyChildTI.zSetPxyRemarks(self.createdByUnitTest(null));								// 15/09/2015 cnwmh5
		updateController.allTransientTIs.add(proxyChildTI);
	endforeach;
	app.myTrxCA.trxCreateTrackedItemsAndAttach(updateController, _parentTI, app.myPassport);
	assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete updateController;
end;</source>
        <Parameter name="_parentTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_attachments" type="CMIF_InOutAttachmentArray"/>
    </JadeMethod>
    <JadeMethod name="addContainerForExport" id="4a0bb35c-1a03-4a0f-8e78-643b3431a5ed">
        <source>addContainerForExport(
	_id			: String;
	_operator	: CM_Operator;
	_isoType	: String;
	_commodity	: String;
	_imexStatus	: Integer;
	_bookingRef	: String;
	_voyageCode	: String;
	_dischargePort : String;
	_transhipToPort : CM_Port) : CM_TrackedItem;
	
vars
	pxyTI	: CM_TrackedItem;
	
begin
	pxyTI := self.createContainer(_id, _isoType, _commodity, _operator,true);
	pxyTI.setTotalWeight(4000, null, null);
	pxyTI.zSetPxyImexStatus(_imexStatus);
	pxyTI.setBookingReference( _bookingRef );
	pxyTI.setVoyageCode( _voyageCode, app.myPassport );
	if _dischargePort &lt;&gt; null then
		pxyTI.setDischargePort (_dischargePort);
	endif;
	pxyTI.setTranshipToPort (_transhipToPort);
	return self.addContainerFromProxy( pxyTI );
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_transhipToPort" type="CM_Port"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainerFromProxy" id="4223c6f3-ba3f-4ab3-a4c4-6e59b1974f61">
        <source>addContainerFromProxy(_proxyTI: CM_TrackedItem input): CM_TrackedItem;
//11 September 2008	cnwdw1	
//
vars
	ti: CM_TrackedItem;
	remarks : String;
	skipErrorCheck : Boolean;
begin
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTIWithMove(_proxyTI, ti, null, app.myPassport);
	//self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	if self.opts.includesKey("DontDoAssert") then
		skipErrorCheck := self.opts.bool("DontDoAssert").Boolean;
	endif;
	
	if skipErrorCheck then
		if not global.isValidObject(ti) then
			return null;
		endif;
	else
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	if ti &lt;&gt; null then
		beginTransaction;													// 29/08/2012 cnwmh5
		global.setExtraData(ti.allExtraData, ti, "createdByUnitTest" , self.getClassMethodCreatedBy());
		// 13/07/015 cnwmh5
		remarks := ti.remarks;
		if remarks &lt;&gt; null then
			if not self.opts.includesKey("DontAddCrLf") then							// 14/09/2015 cnwmh5
				remarks := remarks &amp; CrLf;
			endif;
		endif;
		if not remarks.cnContains(self.createdByUnitTest(remarks)) then
			ti.setRemarks(remarks &amp; self.createdByUnitTest(remarks), false);
		endif;
		commitTransaction;
	endif;
	return ti;
end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainerFromProxyToLC" id="10fd87ab-9720-48d2-b497-658bdb8e2a23">
        <source>addContainerFromProxyToLC(_proxyTI : CM_TrackedItem input; _lcStr : String): CM_TrackedItem;
//15 March 2010 cnwrs1	
//
vars
	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	remarks	: String;
begin
	self.ignoreTrxWarnings(true);
	create moveController transient;
	moveController.isForcedMove := true;
	moveController.setMyToPrimaryLocnFromString(self.getTerminal, _lcStr, REAL_MODE);
	app.myTrxCA.trxCreateTIWithMove(_proxyTI, ti, moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	beginTransaction;									// 29/08/2012 cnwmh5
	global.setExtraData(ti.allExtraData, ti, "createdByUnitTest" , self.getClassMethodCreatedBy());
	// 13/07/015 cnwmh5
	remarks := ti.remarks;
	if remarks &lt;&gt; null then
		remarks := remarks &amp; CrLf;
	endif;
	ti.setRemarks(remarks &amp; self.createdByUnitTest(remarks), false);
	commitTransaction;
	return ti;
epilog
	delete moveController;
end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_lcStr" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainerOnShip" id="1833baeb-0364-412d-bf3b-bbd5877b3b82">
        <source>addContainerOnShip(_id : String;
	_operator : CM_Operator;
	_isoType : String;
	_commodity : String;
	_bookingRef : String;
	_voyage	: CM_Voyage;
	_dischargePort : String;
	_locationId : String) : CM_TrackedItem;
//
// cnwrs1 27 Apr 2011
//	
vars
	pxyTI		: CM_TrackedItem;
	totalWeight	: Decimal[14,4];
	
begin
	pxyTI := self.createContainer(_id, _isoType, _commodity, _operator, true);
	totalWeight := 4000;
	if self.opts.includesKey(UT_OPTS_TotalWeight) then
		totalWeight := self.opts.dec(UT_OPTS_TotalWeight);
	endif;
	
	pxyTI.setTotalWeight(totalWeight, null, null);
	pxyTI.zSetPxyBookingReference(_bookingRef);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_IMPORT);
	pxyTI.setVoyageCode(_voyage.code, app.myPassport);
	if _dischargePort &lt;&gt; null then
		pxyTI.setDischargePort(_dischargePort);
	else
		pxyTI.setDischargePort('NZPOE');
	endif;
	
	if self.opts.includesKey(UT_OPTS_DestinationPort) then
		pxyTI.setDestinationPort(self.opts.str(UT_OPTS_DestinationPort));
	endif;
	if self.opts.includesKey(UT_OPTS_Bol) then
		pxyTI.setBOL(self.opts.str(UT_OPTS_Bol));
	endif;
	
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	if _voyage.code = _locationId then	//22 Sep 2017	NDL	TFS 7032
		return self.addContainerFromProxyToLC(pxyTI, _locationId);
	else
		return self.addContainerFromProxyToLC(pxyTI, _voyage.code&amp;' '&amp;_locationId);
	endif;
end;

</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_locationId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainerOpts" id="4ddb9ddc-2f5e-41d2-8ff0-5d02836e32a7">
        <source>addContainerOpts(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator) : CM_TrackedItem;
//29 August 2008	cnwdw1	
// 29/06/2012		cwnmh5	Fix issue with sealNumShipper
vars
/*
	pxyTI			: CM_TrackedItem;	
	voyage			: CM_Voyage;
	tmpCustomsAgent	: CM_CustomsAgent;
	tmpBR			: CM_BulkRelease;
	trailerType		: CM_TILCType;
	product			: CM_Product;			// aka CargoSubtype
	operator		: CM_Operator;
*/	
begin
	return self.addCargoOpts(_id,_isoType,_commodity, _operator, TI_CargoType_Container);	

	
	
	
	
	
	
	
	
/*	

	self.deleteContainer(_id);
	operator := _operator;
	if self.opts.includesKey("Operator") then
		operator := self.opts.obj("Operator").CM_Operator;
	endif;
	pxyTI := self.createContainer(_id, _isoType, _commodity, operator, true);
	//pxyTI.setWeight(4000, null, null);						//-cnwml2 MSL CCMS 1017
	pxyTI.setTotalWeight(4000, null, null);						//+cnwml2 MSL CCMS 1017
	pxyTI.setWeightTare(4000);
	
	if self.opts.includesKey(UTTI_VoyageCode) then
		voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.opts.str(UTTI_VoyageCode), null);
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	
	if self.opts.includesKey(UTTI_Volume) then
		pxyTI.setMyTotalVolume(self.opts.int(UTTI_Volume));
	endif;
	if self.opts.includesKey("TotalVolume") then
		pxyTI.setMyTotalVolume(self.opts.int("TotalVolume"));
	endif;
	if self.opts.includesKey("CargoVolume") then
		pxyTI.setMyCargoVolume(self.opts.int("CargoVolume"));
	endif;
		
		
	if self.opts.includesKey ("operImportReleasePin") then
		pxyTI.setOperatorImportReleasePIN  (self.opts.str ("operImportReleasePin"));
	endif;
	
	if self.opts.includesKey(UTTI_AvailabilityGrade) then
		pxyTI.CM_Container.setPropertyValue(CM_Container::availabilityGrade.name, self.opts.int(UTTI_AvailabilityGrade));
	endif;
	if self.opts.includesKey(UTTI_BOL) then
		pxyTI.setBOL(self.opts.str(UTTI_BOL));
	endif;
	if self.opts.includesKey(UTTI_BookingRef) then
		pxyTI.setBookingReference(self.opts.str(UTTI_BookingRef));
	endif;
	if self.opts.includesKey(UTTI_BulkRelease) then
		if self.opts.str(UTTI_BulkRelease) &lt;&gt; null then
			tmpBR := self.getTerminal.getBulkReleaseFromCode(self.opts.str(UTTI_BulkRelease));
			self.assertNotNullMsg(tmpBR, 'Bulk Release (' &amp; self.opts.str(UTTI_BulkRelease) &amp; ')');
		endif;
		if tmpBR &lt;&gt; null then
			// not strictly correct as really needs to add to a reserve detail as well.
			// If need ti implement then look at CM_BulkRelease.assignTIToBulkRelease (requires a persistent ti)
			pxyTI.allBulkReleasesAssigned.add(tmpBR);
		endif;
	endif;
	if self.opts.includesKey(UTTI_Consignee) then
		pxyTI.setPropertyValue(CM_TrackedItem::consignee.name, self.opts.str(UTTI_Consignee));
	endif;
	if self.opts.includesKey(UTTI_Consignor) then
		pxyTI.setPropertyValue(CM_TrackedItem::consignor.name, self.opts.str(UTTI_Consignor));
	endif;
	if self.opts.includesKey(UTTI_CustomsAgent) then
		if self.opts.str(UTTI_CustomsAgent) &lt;&gt; null then
			tmpCustomsAgent := app.myRoot.allCustomsAgents[self.opts.str(UTTI_CustomsAgent)];
			self.assertNotNullMsg(tmpCustomsAgent, 'Customs Agent (' &amp; self.opts.str(UTTI_CustomsAgent) &amp; ')');
		endif;
		pxyTI.zSetPxyCustomsAgent(tmpCustomsAgent);
	endif;
	if self.opts.includesKey(UTTI_CustomsEntryNumber) then
		pxyTI.zSetPxyCustomsEntryNumber(self.opts.str(UTTI_CustomsEntryNumber));
	endif;
	if self.opts.includesKey(UTTI_CustomsExportEntryNumber) then
		pxyTI.zSetPxyCustomExportEntryNumber(self.opts.str(UTTI_CustomsExportEntryNumber), app.myPassport);
	endif;
	if self.opts.includesKey( ETRow_CustomsReference ) then
		pxyTI.zSetPxyCustomsReference( self.opts.str( ETRow_CustomsReference ) );
	endif;
	if self.opts.includesKey(UTTI_DeliveryRelease) then	// cnwcs5 April 2012
		pxyTI.setDeliveryRelease(self.opts.str(UTTI_DeliveryRelease));
	endif;
	if self.opts.includesKey ("DeliveryReleaseReason") then
		pxyTI.zSetPxyDeliveryReleaseReason (self.opts.int ("DeliveryReleaseReason"));
	endif;
	
	if self.opts.includesKey(UTTI_DestinationPort) then
		pxyTI.setDestinationPort(self.opts.str(UTTI_DestinationPort));
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	if self.opts.includesKey(UTTI_FreightForwarder) then
		pxyTI.setPropertyValue(CM_TrackedItem::freightForwarderCode.name, self.opts.str(UTTI_FreightForwarder));
	endif;
	if self.opts.includesKey(UTTI_Height) then
		pxyTI.setHeight(self.opts.str(UTTI_Height).Decimal);
	endif;	
	pxyTI.zSetPxyImexStatus(self.opts.intDef(UTTI_IMEX, TI_IMEX_STATUS_EXPORT));
	if self.opts.includesKey(UTTI_IntendedReleaseMode) then
		pxyTI.setPropertyValue(CM_TrackedItem::intendedReleaseMode.name, self.opts.str(UTTI_IntendedReleaseMode).Integer);
	endif;
	if self.opts.includesKey(UTTI_Length) then
		pxyTI.setLength(self.opts.str(UTTI_Length).Decimal);
	endif;
	if self.opts.includesKey(UTTI_OverHeight) then // AKB2010JUN
		pxyTI.CM_Container.setOverHeight(self.opts.int(UTTI_OverHeight), null, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_OverWidthLeft) then // AKB2011DEC
		pxyTI.CM_Container.setOverWidthLeft(self.opts.int(UTTI_OverWidthLeft), null, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_Remarks) then
		pxyTI.setPropertyValue(CM_TrackedItem::remarks.name, self.opts.str(UTTI_Remarks));
	endif;
	if self.opts.includesKey(UTTI_ReceiptMode) then
		pxyTI.setReceiptTransportMode(self.opts.int(UTTI_ReceiptMode));
	endif;
	if self.opts.includesKey(UTTI_ShipperSeal) then
		//pxyTI.setPropertyValue(CM_Container::sealNumShippers.name, self.opts.str(UTTI_ShipperSeal));
		///pxyTI.setPropertyValue(SealNumShippers, self.opts.str(UTTI_ShipperSeal));	//17 Sep 2010	NDL	Par 25608
		pxyTI.setSealNumShippers(self.opts.str(UTTI_ShipperSeal));				// 29/06/2012 cnwmh5
	endif;
	if self.opts.includesKey(UTTI_State) then
		pxyTI.setStatePxy(self.opts.int(UTTI_State));
	endif;
	if self.opts.includesKey(UTTI_TotalWeight) then
		pxyTI.setPropertyValue(CM_TrackedItem::totalWeight.name, self.opts.int(UTTI_TotalWeight).Decimal);
	endif;
	if self.opts.includesKey(UTTI_Wagon) then
		pxyTI.setWagon(self.opts.str(UTTI_Wagon),null);
	endif;
	if self.opts.includesKey(UTTI_Width) then
		pxyTI.setWidth(self.opts.str(UTTI_Width).Decimal);
	endif;
	
	if self.opts.includesKey( ETRow_TrailerType ) then
		trailerType	:= self.getTrailerType( self.opts.str( ETRow_TrailerType ) );
		pxyTI.setMyType( trailerType );
	endif;	
	if self.opts.includesKey( ETRow_MyProduct ) then		// aka CargoSubtype
		product	:= pxyTI.myCargoType.getProductFromCode( self.opts.str( ETRow_MyProduct ) );
		pxyTI.setMyProduct( product );
	endif;
	
	return self.addContainerFromProxy(pxyTI);
*/
epilog

	
end;
</source>
