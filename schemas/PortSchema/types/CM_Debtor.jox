    <JadeMethod name="hasStorageInvoiceDueToClose" id="6983913f-b0dc-4f2a-8ddb-4ce30eeed484">
        <source>hasStorageInvoiceDueToClose(_date : Date) : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theInvoice : CM_Invoice;
	iter : Iterator;
begin
	iter := self.invoicesByStatus.createIterator;
	self.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_OPEN, iter);
	while iter.next(theInvoice) do

		if theInvoice.status &lt;&gt; CM_Invoice.INVOICE_OPEN then
			break;
		endif;
		
		if theInvoice.invoiceType.invoiceType &lt;&gt; InvoiceTypeStorage then // STORAGE ONLY
			continue;
		endif;
		// look at invoice who are set to close today
		if theInvoice.toDT.date() = _date then
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCashOnlyDebtor" id="8449ef5d-e26f-40ae-88e5-ea202e716b86">
        <source>isCashOnlyDebtor( _terminal : CM_Terminal ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drTerm : CM_DebtorTerminal;

begin

	if _terminal = null then
		return false;
	endif;
	if self.allDebtorTerminals.isEmpty then
		return false;
	endif;

	drTerm := self.allDebtorTerminals.getAtKey( _terminal );
	if drTerm = null then
		return false;
	endif;
	
	return drTerm.isCashOnly;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCashOnlyDebtorAllTerminals" id="0c39e55e-7df5-4d88-9bb5-31ae66e2435a">
        <source>isCashOnlyDebtorAllTerminals() : Boolean;
// return true if this debtor is a cash-only debtor for every terminal which is cash-enabled
vars
	term	: CM_Terminal;
	result	: Boolean;
begin
	if self.allDebtorTerminals.isEmpty() then
		return false;
	endif;

	foreach term in app.myRoot.allTerminals do
		if not term.isCashOnlyEnabled then
			continue;
		endif;
		result := self.isCashOnlyDebtor(term);
		if not result then
			return false;
		endif;
	endforeach;
	
	return result;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
