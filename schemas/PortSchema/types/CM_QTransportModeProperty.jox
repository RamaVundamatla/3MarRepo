		_tbl.addItem(1.String &amp; Tab &amp; TI_TRANSMODE_SHIP_STR);
	else
		_tbl.addItem(0.String &amp; Tab &amp; TI_TRANSMODE_SHIP_STR);	
	endif;
	
	if _operator &lt;&gt; null and _operator.allSelectionValues.includes(TI_TRANSMODE_ROAD) then
		_tbl.addItem(1.String &amp; Tab &amp; TI_TRANSMODE_ROAD_STR);
	else
