        <type name="Integer"/>
    </Constant>
    <Constant name="Maximum_Retry_Count" id="2ebd739a-7500-4f67-b7d8-8516a50e3a95">
        <source>5</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Time_Check_Object_Count" id="40d4d5b5-2f52-411e-b755-ec963c9746bc">
        <source>500</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Timer_Instances_Delay" id="69eef615-2af5-45eb-a46b-0e8e1b7158cd">
        <source>2 * 60 * 60 * 1000</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Timer_Instances_Delay_Second" id="1bb524e8-7a66-4c93-92b0-d9cee416435e">
        <source>60 * 60 * 1000</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Timer_Startup_Instances_Delay" id="a39917af-46de-4c79-8d61-95fcc336ccf9">
        <source>5000</source>
        <type name="Integer"/>
    </Constant>
