    <JadeMethod name="doBuildInvStatusForQuery" id="33ec7048-e860-44b3-9887-9cc7bf4f40af">
        <source>doBuildInvStatusForQuery(_listOfStatus : IntegerArray io);
/*

Purpose:			
	This method builds a list of statuses from the invoice process and exclude the statuses in CM_Invoice.isPostedOrReversal;
Parameters:			

Return Value:		

Date		Who		Reason
08 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	invoiceProcess		: CM_InvoiceProcess;
	invoice				: CM_Invoice;
	allStatuses			: CM_InvoiceStatusById;
	invoiceStatus		: CM_InvoiceStatus;
	statusToExclude		: IntegerArray;
begin
	invoice := self.allInvoicesToLink.first().CM_Invoice;
	
	if invoice = null then
		return;
	endif;
	
	invoiceProcess := invoice.getMyInvoiceProcess();
	
	if invoiceProcess = null then
		invoiceProcess := CM_InvoiceProcessDefault.firstInstance();
	endif;
	
	allStatuses := invoiceProcess.allStatuses;
	
	create statusToExclude transient;
	statusToExclude.add(CM_Invoice.INVOICE_POSTED);
	statusToExclude.add(CM_Invoice.INVOICE_POSTED_CREDIT);
	statusToExclude.add(CM_Invoice.INVOICE_POSTED_REVERSE);
	statusToExclude.add(CM_Invoice.INVOICE_PENDING_REVERSE);
	
	foreach invoiceStatus in allStatuses discreteLock do
		if statusToExclude.indexOf(invoiceStatus.id) &gt; 0 then
			continue;
		endif;
		_listOfStatus.add(invoiceStatus.id);
	endforeach;
	
epilog
	delete statusToExclude;
end;</source>
        <Parameter name="_listOfStatus" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="485878e7-be22-4bc7-bfd3-01df869e728a">
        <source>doCreateCriteriaLine(_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
begin
	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);
epilog

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doDisplayInvoicesLabel" id="3c6cca20-2b2b-43fd-8a72-4847cdda1aaa">
        <source>doDisplayInvoicesLabel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2023	navkc1	Initial creation  TFS CR 55305 TASK 55536

*/

vars
	invoice	: CM_Invoice;
	label	: String;
begin
	
	foreach invoice in self.allInvoicesToLink do
		if label = null then
			label &amp;= invoice.sequenceNum.String;
		else
			label &amp;= ", " &amp; invoice.sequenceNum.String;
		endif;
	endforeach;
	
	self.lblListInvoices.caption := app.getErrorString(Invoices) &amp; " : " &amp; label;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLink" id="31502ac9-8075-41ee-9a84-df295cafaeb1">
        <updating/>
        <source>doLink() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	pxyCreditNote,
	creditNote,
	pxyInvoice,
	invoice 		: CM_Invoice;	
	allInvoices 	: CM_InvoiceSet;	
	theReturn 		: Integer;
begin
	
	creditNote := self.tblCreditNotes.allSelectedObjects.first().CM_Invoice;
	
	if creditNote = null then
		app.msgBox(app.getErrorString(Please_select_credit_note), app.getErrorString(Information), MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString(Confirm_link_to_credit_note), app.getErrorString(Information), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	
	pxyCreditNote := app.createUpdateProxy(creditNote).CM_Invoice;
	
	create allInvoices transient;
	
	foreach invoice in self.allInvoicesToLink do
		pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
		allInvoices.add(pxyInvoice);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateLinkCreditToInvoice(pxyCreditNote, allInvoices, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox( app.getErrorString(SAVE_COMPLETE),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
epilog
	if allInvoices &lt;&gt; null then
		allInvoices.purge();
		delete allInvoices;
	endif;
	
	delete pxyCreditNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="131289d2-d6c2-44a1-b214-c68ac1b8f219">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	invName			: String;
	theTable 		: CM_DataTable;
	collInvoices	: CM_InvoiceBySeqNumDict;
	idx				: Integer;
	anInvoice		: CM_Invoice;
	bank			: CM_Bank;
	pd				: CMS_Progress;
	lastUpdate		: Decimal [20];
begin
	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString1(Loading_invoices,null));
	
	self.tblCreditNotes.rows := 1;
	theTable := self.tblCreditNotes;
	theTable.rows := theTable.fixedRows;
	theTable.clearAllSelected ();

	create collInvoices transient;

	bank := self.myBank;
	
	invName := self.doQueryInvoicesUsingSelector( collInvoices );
	
	if collInvoices &lt;&gt; null then
		if not self.doMaxTableSizeCheck(collInvoices.size, null) then
			return;
		endif;
		
		pd.progress.partsInJob := collInvoices.size;
		
		foreach anInvoice in collInvoices reversed do
			idx := idx + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
				pd.setAction(app.getErrorString1(Loading_invoices,invName));
				pd.progress.partsDone := idx;
				lastUpdate := app.relativeMachineTime;													
			endif;																						
			
			if bank &lt;&gt; null and bank &lt;&gt; anInvoice.bank then
				continue;
			endif;
			
			self.doQueryAddItemToTable(anInvoice);
			
			if theTable.rows = JadeTableRowLimit then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	
	delete pd;
	delete collInvoices;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItemToTable" id="d2834a60-ce1a-4fe1-b769-ef76b0263159">
        <updating/>
        <source>doQueryAddItemToTable(_theInvoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	theDataLine : String;
	theTable	: CM_DataTable;
	
begin
	if not global.isValidObject(_theInvoice) then
		return;
	endif;
	
	if _theInvoice.category = InvoiceCategory_Invoice then
		return;
	endif;
	
	// Add Credit notes to the table
	theTable := self.tblCreditNotes;
	
	theDataLine := _theInvoice.getAttributeStringForDefArray(theTable.allTblDataEntRows);

	theTable.addItemObject(_theInvoice, theDataLine);

epilog

end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="doQueryInvoicesUsingSelector" id="81f68f8a-f910-4b32-bba2-fb21b6ed30ac">
        <source>doQueryInvoicesUsingSelector(_collInvoices	: CM_InvoiceBySeqNumDict input ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	qDef 			: CM_QueryDefinition;
	criteriaHolder  : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoice;
	bank		 	: CM_Bank;
	invName			: String;
	statuses		: IntegerArray;
	debtors : CM_DebtorSet;
	debtor : CM_Debtor;
	invoice : CM_Invoice;
begin
	 // ### TFS BUG 58822 27UN2023 NAVAB1
	create debtors transient;
	foreach invoice in self.allInvoicesToLink discreteLock do
			debtor := invoice.debtor;
			if debtor &lt;&gt; null 
			and not debtors.includes(debtor) then
				debtors.add(debtor);
			endif;
	
	endforeach;

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.Invoice_Query_Mode];

	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.myTerminal);

	bank := self.myBank;
	if bank &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::bank.name, CM_QReferenceLookup.Operator_Equal, bank);
	endif;
	
	// Only search for Credit notes, not Invoices
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCategoryInt.name, CM_QReferenceLookup.Operator_Equal, InvoiceCategory_CreditNote);
	
	// Build a list of status excluding CM_Invoice.isPostedOrReversal;
	create statuses transient;
	self.doBuildInvStatusForQuery(statuses);
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvStatus.name, CM_QReferenceLookup.Operator_IsOneOf, statuses);
	
	 // ### TFS BUG 58822 27UN2023 NAVAB1 - Debtors
	if debtors.isNotEmpty() then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getDebtor.name, CM_QReferenceLookup.Operator_IsOneOf, debtors);
	
	endif;
	
	myEnqController.doQuery( qDef );
	
	myEnqController.allObjects.CM_InvoiceBySeqNumDict.copy( _collInvoices );
	
	return invName;
epilog
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
	delete statuses;
	delete debtors;
end;</source>
        <Parameter name="_collInvoices" type="CM_InvoiceBySeqNumDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="1b3d25f9-66c0-42da-aeb5-1f1f4c3909b5">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	xLeft	: Real;
	yTop	: Real;
	
begin
	
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);	
	self.screenToWindow(xLeft, yTop);
	
	self.mnuMenuContext.userObject := cntrl;
	
	self.popupMenu(self.mnuMenuContext, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="6fe473f4-cf4e-4ea5-91f0-2123b33b3db6">
        <updating/>
