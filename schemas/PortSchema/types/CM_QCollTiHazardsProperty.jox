<Class name="CM_QCollTiHazardsProperty" id="084898fd-1519-4962-b9c7-fd385082d211">
    <superclass name="CM_QCollectionProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="ceced6b1-eb86-4a53-912a-47ae7344cac4">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	oper : CM_QueryOperator;
	oper1 : CM_QueryOperator;
	oper2 : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;
	
	foreach oper in self.allAllowedOperators do
		if oper.isKindOf(CM_QCollIncludesNoneOf) then
			oper1 := oper;
		elseif oper.isKindOf(CM_QCollIncludesAllOf) then
			oper2 := oper;
		endif;
	endforeach;
	
	if oper1 &lt;&gt; null then
		self.allAllowedOperators.remove(oper1);
		delete oper1;
	endif;
	
	if oper2 &lt;&gt; null then
		self.allAllowedOperators.remove(oper2);
		delete oper2;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="66942096-7908-45e9-b66f-818f8e6346a7">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin
	
	if _op.isKindOf(CM_QCollIncludesOneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);

epilog

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
