			_ordinal: Integer; _orientation: Integer; _voltageType: Integer; _adjacentSlot: CM_ROROLocnDefn; _deckLayerLayout: CM_DeckLayerLayout; _labelManChanged, _isOOTL : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_structure, _code, _desc, _remarks, _deckItemLayout, _deck, _hasPower, _isRotatable, _isWaterCooled, _maxLoadPer20, 
			_maxLoadPer40, _maxLoadTotal, _maxStackHeight, _numTiers, _ordinal, _orientation, _voltageType, _adjacentSlot, _deckLayerLayout,_labelManChanged, _isOOTL);

	self.myVoyageStructure:=_structure;
epilog

end;</source>
