    <JadeMethod name="getDefaultSubTerminal" id="f739bc8b-69c7-4fdd-9eb3-b0cff434f83d">
        <source>getDefaultSubTerminal(_objType : Integer; _releaseType : Integer; _imexStatus : Integer; _commodityCode : String; _isContainer:Boolean) : CM_SubTerminal;
/* ---------------------------------------------------------------------------
Created:     04 May 2009 by cnwrs2

Purpose:	This method will determine which Default Sub-Terminal is appropriate
			based upon the IMEX Status and the Commodity Code.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
// _objType can be one of the following CM_SubTerminal class constants:
//		Type_BOL
//		Type_BulkRelease
//		Type_TrackedItem
//
// IMEX status can be one of the following:
//		TI_IMEX_STATUS_EXPORT = 2
//		TI_IMEX_STATUS_IMPORT = 1
//		TI_IMEX_STATUS_MASK = #1FF0
//		TI_IMEX_STATUS_NULL = 0
//		TI_IMEX_STATUS_STORAGE = 3
//		TI_IMEX_STATUS_TRANSIT = 6
//
vars
	commodityObj	: CM_Commodity;
	
begin

	//28 Nov 2014	NDL	Par 35295
	if self.getConfig(IsSubTerminalAreaDefined).Boolean then
		return null;
	endif;
	
	commodityObj	:=	app.myRoot.allCommodities[_commodityCode];
	
	// Check if we are working with a BOL.
	
	if _objType = CM_SubTerminal.Type_BOL then
		if _imexStatus = TI_IMEX_STATUS_IMPORT then
			return self.getConfig(MySubTerminalForBOLIn).CM_SubTerminal;
		endif;
	endif;
	
	// Check if we are working with a Bulk Release.
	
	if _objType = CM_SubTerminal.Type_BulkRelease then
// cnwdad1 27/01/2010 - PAR #22205.
		//return self.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
		return self.getDefaultSubTerminalForRel(_releaseType);
	endif;
	
	// Check if we are working with a Tracked Item.
	
	if _objType = CM_SubTerminal.Type_TrackedItem then
	
		if _isContainer and commodityObj &lt;&gt; null then
			if _imexStatus = TI_IMEX_STATUS_IMPORT then
				if commodityObj.isEmpty then
					return self.getConfig(MySubTerminalForImportMTY).CM_SubTerminal;
				else
					return self.getConfig(MySubTerminalForImportFull).CM_SubTerminal;
				endif;
				
			elseif _imexStatus = TI_IMEX_STATUS_EXPORT then
				if commodityObj.isEmpty then
					return self.getConfig(MySubTerminalForExportMTY).CM_SubTerminal;
				else
					return self.getConfig(MySubTerminalForExportFull).CM_SubTerminal;
				endif;
				
			elseif _imexStatus = TI_IMEX_STATUS_STORAGE then
				if commodityObj.isEmpty then
					return self.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal;
				else
					return self.getConfig(MySubTerminalForStorageFull).CM_SubTerminal;
				endif;
			endif;
		else
			if _imexStatus = TI_IMEX_STATUS_IMPORT then
				return self.getConfig(MySubTerminalForImportGen).CM_SubTerminal;
			elseif _imexStatus = TI_IMEX_STATUS_EXPORT then
				return self.getConfig(MySubTerminalForExportGen).CM_SubTerminal;
			elseif _imexStatus = TI_IMEX_STATUS_STORAGE then
				return self.getConfig(MySubTerminalForStorageGen).CM_SubTerminal;
			else
				//return self.getConfig(MySubTerminalForOther).CM_SubTerminal;
			endif;
		endif;
	endif;
	
	return self.getConfig(MySubTerminalForOther).CM_SubTerminal;
end;</source>
        <Parameter name="_objType" type="Integer"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_commodityCode" type="String"/>
        <Parameter name="_isContainer" type="Boolean"/>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="getDefaultSubTerminalForRel" id="80e5c755-398d-4630-bbe0-84d5c15ccea9">
        <source>getDefaultSubTerminalForRel(_releaseType:Integer):CM_SubTerminal;
// --------------------------------------------------------------------------------
// Created:		27 January 2010 by cnwdad1
//
// Purpose:		This method will determine which default Sub-Terminal is appropriate
//				based upon the Release Type.
//
// Parameters:	_releaseType - The release type code.
//
// Returns:		A reference to an appropriate Sub-Terminal object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		Added for PAR #22205 (CCMS POL 1904).
// --------------------------------------------------------------------------------
begin
	//cnwrd1 
	if not app.isSubTerminalsOn(self) then
		return null;
	endif;
	
	//28 Nov 2014	NDL	Par 35295
	if self.getConfig(IsSubTerminalAreaDefined).Boolean then
		return null;
	endif;

	if _releaseType = BR_TYPE_ROAD then
		return self.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
	elseif _releaseType = BR_TYPE_RAIL then
		return self.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal;
	elseif _releaseType = BR_TYPE_SHIP then
		return self.getConfig(MySubTerminalForSourceBulkShip).CM_SubTerminal;
	elseif _releaseType = BR_TYPE_PACKING then
		return self.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal;
	else
		return self.getConfig(MySubTerminalForOther).CM_SubTerminal;
	endif;
end;</source>
        <Parameter name="_releaseType" type="Integer"/>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyageCode" id="4ccd9f9a-4dc1-4074-80ca-69c6d77cadf7">
        <source>getDefaultVoyageCode() : String;
// ---------------------------------------------------------------------------
// Created:     14 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;

begin

	tmpVoyage := self.getConfig(DefVoyage).CM_Voyage;
	if tmpVoyage &lt;&gt; null then
		return tmpVoyage.code;
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyageProcess" id="fd8891a5-31b2-4f2c-8dc3-a86ab7ee27e9">
        <source>getDefaultVoyageProcess() : CM_VoyageProcess;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	return app.myRoot.allVoyageProcesses[self.getConfig(DefaultVoyageProcess).String];
epilog

end;</source>
        <ReturnType type="CM_VoyageProcess"/>
    </JadeMethod>
    <JadeMethod name="getDefaultWeighAuthority" id="8ff3107a-7b35-42ad-8458-39b7a3042dec">
        <source>getDefaultWeighAuthority() : CM_WeighAuthTerminal;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth : CM_WeighAuthTerminal;

begin
	foreach weighAuth in self.allWeighAuthTerminals where weighAuth.isDefaultForTerminal do
		return weighAuth;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WeighAuthTerminal"/>
    </JadeMethod>
    <JadeMethod name="getDictForTISelector" id="febe268c-a9b8-4c2f-bc73-82af0ade13ae">
        <source>getDictForTISelector(_querySite : Integer; _voyage : CM_Voyage; _haveId, _reversed : Boolean) : Dictionary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2015	cnwndl1	Initial creation	Par 36347 - Standardises the site/state stuff up.
// 06 Sep 2016	cnwrs1	TFS 2586 Fix indentation
*/

vars

begin
	if _querySite = SEL_QUERYSITE_CARGOGROUP and app.isCargoGroupEnabled then
		if _haveId then
			return self.allCargoGroupsByIdCargoType;
		else
			return self.allCargoGroupsByCargoTypeId;
		endif;
	endif;

	if (_voyage &lt;&gt; null) and (_querySite = SEL_QUERYSITE_ONSHIP) then
		//epr par 33310 
		if _reversed then
			if _haveId then
				return _voyage.allOnshipTIsByIdCargoTypeRev;
			else
				return _voyage.allOnshipTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return _voyage.allOnshipTIsByIdCargoType;
			else
				return _voyage.allOnshipTIsByCargoTypeId;
			endif;
		
		endif;
	elseif (_voyage &lt;&gt; null) and (_querySite = SEL_QUERYSITE_ONSITE) then
	
	
		if _haveId then
			return _voyage.allOnsiteTIsByIdCargoType;
		else
			return _voyage.allOnsiteTIsByCargoTypeId;
		endif;
		
	elseif (_voyage &lt;&gt; null) and (_querySite = SEL_QUERYSITE_OFFSITE) then
		//epr par 36151 7/5/14
		if  _reversed then
				return null;
		endif;
		
		if _haveId then
			return _voyage.allOffsiteTIsByIdCargoType;
		else
			
			return _voyage.allOffsiteTIsByCargoTypeId;
		endif;
		
	
	elseif (_voyage &lt;&gt; null) and (_querySite = SEL_QUERYSITE_NOTIFIED) then
	
		if _haveId then
			return _voyage.allNotifiedTIsByIdCargoType;
		else
			return _voyage.allNotifiedTIsByCargoTypeId;
		endif;
		
	elseif _querySite = SEL_QUERYSITE_ONSITE then 
		if _reversed then
			if _haveId then
				return self.allOnsiteTIsByIdCargoTypeRev;
			else
				return self.allOnsiteTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allOnsiteTIsByIdCargoType;
			else
				return self.allOnsiteTIsByCargoTypeId;
			endif;
		endif;

	elseif _querySite = SEL_QUERYSITE_OFFSITE then
		if _reversed then
			if _haveId then
				return self.allOffsiteTIsByIdCargoTypeRev;
			else
				return self.allOffsiteTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allOffsiteTIsByIdCargoType;
			else
				return self.allOffsiteTIsByCargoTypeId;
			endif;
		endif;
	
	elseif _querySite = SEL_QUERYSITE_NOTIFIED then
		if _reversed then
			if _haveId then
				return self.allNotifiedTIsByIdCargoTypeRev;
			else
				return self.allNotifiedTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allNotifiedTIsByIdCargoType;
			else
				return self.allNotifiedTIsByCargoTypeId;
			endif;
		endif;
		
	elseif _querySite = SEL_QUERYSITE_TBA  then 
		if _reversed then
			if _haveId then
				return self.allTbaTIsByIdCargoTypeRev;
			else
				return self.allTbaTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allTbaTIsByIdCargoType;
			else
				return self.allTbaTIsByCargoTypeId;
			endif;
		endif;
		
	elseif _querySite = SEL_QUERYSITE_PLACEHOLDER  then 	//13 Mar 2020	NDL	TFS 47004
		if _haveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;	

	elseif _querySite = SEL_QUERYSITE_DELETED  then
		if _reversed then
			if _haveId then
				return self.allDeletedTIsByIdCargoTypeRev;
			else
				return self.allDeletedTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allDeletedTIsByIdCargoType;
			else
				return self.allDeletedTIsByCargoTypeId;
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_querySite" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_haveId" type="Boolean"/>
        <Parameter name="_reversed" type="Boolean"/>
        <ReturnType type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="getDictForTISite" id="fd8d6410-5d4e-4016-a479-59957ed0056d">
        <source>getDictForTISite(_site : Integer; _voyage : CM_Voyage; _haveId, _reversed : Boolean) : Dictionary;
// ---------------------------------------------------------------------------
// Created:     21 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	app.writeLog(method.qualifiedName &amp; Tab &amp; "logdap1: _site is " &amp; _site.String, LogDEBUG);
	//02 June 2015	NDL	Par 36338
	if _site = TI_SITE_CARGOGROUP and app.isCargoGroupEnabled then
		if _haveId then
			return self.allCargoGroupsByIdCargoType;
		else
			return self.allCargoGroupsByCargoTypeId;
		endif;
	endif;

	if (_voyage &lt;&gt; null) and (_site = TI_SITE_ONSHIP) then
		//epr par 33310 
		if _reversed then
			if _haveId then
				return _voyage.allOnshipTIsByIdCargoTypeRev;
			else
				return _voyage.allOnshipTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return _voyage.allOnshipTIsByIdCargoType;
			else
				return _voyage.allOnshipTIsByCargoTypeId;
			endif;
		
		endif;
	elseif (_voyage &lt;&gt; null) and (_site = TI_SITE_ONSITE) then
	
	
		if _haveId then
			return _voyage.allOnsiteTIsByIdCargoType;
		else
			return _voyage.allOnsiteTIsByCargoTypeId;
		endif;
		
	elseif (_voyage &lt;&gt; null) and (_site = TI_SITE_OFFSITE) then
		//epr par 36151 7/5/14
		if  _reversed then
				return null;
		endif;
		
		if _haveId then
			return _voyage.allOffsiteTIsByIdCargoType;
		else
			
			return _voyage.allOffsiteTIsByCargoTypeId;
		endif;
		
	// 10/03/2015 cnwar2 #35836
	elseif (_voyage &lt;&gt; null) and (_site = TI_SITE_UNDEFINED) then
	
		if _haveId then
			return _voyage.allNotifiedTIsByIdCargoType;
		else
			return _voyage.allNotifiedTIsByCargoTypeId;
		endif;
		
	elseif _site = TI_SITE_ONSITE then 
		if _reversed then
			if _haveId then
				return self.allOnsiteTIsByIdCargoTypeRev;
			else
				return self.allOnsiteTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allOnsiteTIsByIdCargoType;
			else
				return self.allOnsiteTIsByCargoTypeId;
			endif;
		endif;

	elseif _site= TI_SITE_OFFSITE then
		if _reversed then
			if _haveId then
				return self.allOffsiteTIsByIdCargoTypeRev;
			else
				return self.allOffsiteTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allOffsiteTIsByIdCargoType;
			else
				return self.allOffsiteTIsByCargoTypeId;
			endif;
		endif;
	//th2 added 08/05/2007 for PAR 14021 - pre-notifys are site undefined
// PAR 33695	elseif _site = TI_SITE_TBA or _site = TI_SITE_UNDEFINED then
	elseif _site = TI_SITE_UNDEFINED then
		if _reversed then
			if _haveId then
				return self.allNotifiedTIsByIdCargoTypeRev;
			else
				return self.allNotifiedTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "logdap1: _haveId so using self.allNotifiedTIsByIdCargoType", LogDEBUG); 
				return self.allNotifiedTIsByIdCargoType;
			else
				return self.allNotifiedTIsByCargoTypeId;
			endif;
		endif;
	elseif _site = TI_SITE_TBA  then // PAR 33695
		if _reversed then
			if _haveId then
				return self.allTbaTIsByIdCargoTypeRev;
			else
				return self.allTbaTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allTbaTIsByIdCargoType;
			else
				return self.allTbaTIsByCargoTypeId;
			endif;
		endif;
	
	elseif _site = TI_SITE_PLACEHOLDER  then //13 Mar 2020	NDL	TFS 47004
		if _haveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;	
		
	//23 July 2014	NDL	Par 34625 - Yes its a state, but it is used as a site in the selector..
	elseif _site = TI_STATE_DELETED  then
		if _reversed then
			if _haveId then
				return self.allDeletedTIsByIdCargoTypeRev;
			else
				return self.allDeletedTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allDeletedTIsByIdCargoType;
			else
				return self.allDeletedTIsByCargoTypeId;
			endif;
		endif;
		/*
	elseif _site = SEL_QUERYSITE_NOTIFIED then
		if _reversed then
			if _haveId then
				return self.allNotifiedTIsByIdCargoTypeRev;
			else
				return self.allNotifiedTIsByCargoTypeIdRev;
			endif;
		else
			if _haveId then
				return self.allNotifiedTIsByIdCargoType;
			else
				return self.allNotifiedTIsByCargoTypeId;
			endif;
		endif;
		*/
	endif;
end;</source>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_haveId" type="Boolean"/>
        <Parameter name="_reversed" type="Boolean"/>
        <ReturnType type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="getDictForTIState" id="a224fe47-643b-49fb-ae2f-537ecbddfb75">
        <source>getDictForTIState(pState : Integer; pVoyage : CM_Voyage; pHaveId, pReversed : Boolean) : Collection;

vars

begin
	if pVoyage &lt;&gt; null then
		if pReversed then
			if pState = TI_STATE_ONSHIP then
				if pHaveId then
					/*
						Date		 Who		Reason
						1 Sep 2008	cnwdz2	    Par17807 - Should return the reversed collection.
					*/
					//return pVoyage.allOnshipTIsByIdCargoType;
					return pVoyage.allOnshipTIsByIdCargoTypeRev;
					
				else
					//return pVoyage.allOnshipTIsByCargoTypeId; // 1 Sep 2008	cnwdz2	Par17807
					return pVoyage.allOnshipTIsByCargoTypeIdRev;
				endif;
			else
				return null;
			endif;
		else
			return pVoyage.getDictForTIState(pState, pHaveId);
		endif;
	endif;
	
	if pState = TI_STATE_NORMAL then 
		if pReversed then
			if pHaveId then
				return self.allOnsiteTIsByIdCargoTypeRev;
			else
				return self.allOnsiteTIsByCargoTypeIdRev;
			endif;
		else
			if pHaveId then
				return self.allOnsiteTIsByIdCargoType;
			else
				return self.allOnsiteTIsByCargoTypeId;
			endif;
		endif;

	elseif pState = TI_STATE_NOTIFIED then
		if pReversed then
			if pHaveId then
				return self.allNotifiedTIsByIdCargoTypeRev;
			else
				return self.allNotifiedTIsByCargoTypeIdRev;
			endif;
		else
			if pHaveId then
				return self.allNotifiedTIsByIdCargoType;
			else
				return self.allNotifiedTIsByCargoTypeId;
			endif;
		endif;
	elseif pState = TI_STATE_TRANSFER_FROM then
		return self.allInTransitTIsToByFromTypeId;
	elseif pState = TI_STATE_TRANSFER_TO then
		return self.allInTransitTIsFromByToTypeId;
	elseif pState = TI_STATE_TBA then 
		if pReversed then
			if pHaveId then
				return self.allTbaTIsByIdCargoTypeRev;
			else
				return self.allTbaTIsByCargoTypeIdRev;
			endif;
		else
			if pHaveId then
				return self.allTbaTIsByIdCargoType;
			else
				return self.allTbaTIsByCargoTypeId;
			endif;
		endif;
		
	elseif pState = TI_STATE_PLACEHOLDER then //13 Mar 2020	NDL	TFS 47004
		if pHaveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;

	elseif pState = TI_STATE_DELETED then 
		if pReversed then
			if pHaveId then
				return self.allDeletedTIsByIdCargoTypeRev;
			else
				return self.allDeletedTIsByCargoTypeIdRev;
			endif;
		else
			if pHaveId then
				return self.allDeletedTIsByIdCargoType;
			else
				return self.allDeletedTIsByCargoTypeId;
			endif;
		endif;
	else
		if pReversed then
			if pHaveId then
				return self.allOffsiteTIsByIdCargoTypeRev;
			else
				return self.allOffsiteTIsByCargoTypeIdRev;
			endif;
		else
			if pHaveId then
				return self.allOffsiteTIsByIdCargoType;
			else
				return self.allOffsiteTIsByCargoTypeId;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pState" type="Integer"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pHaveId" type="Boolean"/>
        <Parameter name="pReversed" type="Boolean"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="def3fd9b-3543-4d0b-9dc1-4debdcd9c5da">
        <source>getDisplayDetails(_short: Boolean): String;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.code;


end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataOutwardRail" id="d37020af-b2c0-4fe4-83fb-f91096303d06">
        <updating/>
        <source>getEDIDataOutwardRail(pEDIDataOR : CM_EDIDataOutwardRail output) updating;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	pEDIDataOR := self.myEDIDataOutwardRail;
	if pEDIDataOR = null then
		app.myTrxCA.trxCreateEDIDataOutwardRail(pEDIDataOR, app.myPassport);		
	endif;
	
end;</source>
        <Parameter name="pEDIDataOR" type="CM_EDIDataOutwardRail" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getEmailDefaultCarrier" id="36fa24de-623a-4823-8427-005cfee323b1">
        <source>getEmailDefaultCarrier( _emailDefaultType : Integer ) : Boolean;

/*

Purpose:		This method will attempt to find the Email Default matching the supplied integer value.
				If found then the CM_PINObjectDefaultEmail instance setting of Send to Carrier will be returned.
				This should be used instead of getConfig(DefaultCarrierEmail).
				
				The currently (30/07/2009) existing PINEmailTypes constants are:
				PINEmail_ReleaseRequest			1
				PINEmail_ReleaseRequestDelete	2
				PINEmail_CargoRelease			3
				PINEmail_CargoReleaseDelete		4
				PINEmail_Prenote				5
				PINEmail_PrenoteDelete			6
				PINEmail_PrenoteCustomsInspect	7
				PINEmail_ReleaseStatusPending	8
				PINEmail_ReleaseStatusActive	9
				
Date			Who		Reason
30 July 2009	cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests

*/
	
vars
	pinDefaultEmail		: CM_PINObjectDefaultEmail;
	
begin
	pinDefaultEmail	:= self.getEmailDefaultsSettings( _emailDefaultType );
	return pinDefaultEmail &lt;&gt; null and pinDefaultEmail.sendToCarrier;
	
epilog
	
end;
</source>
        <Parameter name="_emailDefaultType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEmailDefaultConsignee" id="0093f3f1-7b14-4926-aff9-ae0af78d76b3">
        <source>getEmailDefaultConsignee( _emailDefaultType : Integer ) : Boolean;

/*

Purpose:		This method will attempt to find the Email Default matching the supplied integer value.
				If found then the CM_PINObjectDefaultEmail instance setting of Send to Consignee will be returned.
				This should be used instead of getConfig(DefaultConsigneeEmail).
				
				The currently (30/07/2009) existing PINEmailTypes constants are:
				PINEmail_ReleaseRequest			1
				PINEmail_ReleaseRequestDelete	2
				PINEmail_CargoRelease			3
				PINEmail_CargoReleaseDelete		4
				PINEmail_Prenote				5
				PINEmail_PrenoteDelete			6
				PINEmail_PrenoteCustomsInspect	7
				PINEmail_ReleaseStatusPending	8
				PINEmail_ReleaseStatusActive	9
				
Date			Who		Reason
30 July 2009	cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests

*/
	
vars
	pinDefaultEmail		: CM_PINObjectDefaultEmail;
	
begin
	pinDefaultEmail	:= self.getEmailDefaultsSettings( _emailDefaultType );
	return pinDefaultEmail &lt;&gt; null and pinDefaultEmail.sendToConsignee;
	
epilog
	
end;
</source>
        <Parameter name="_emailDefaultType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEmailDefaultsSettings" id="249d7b9a-430e-4dc0-a11d-2caec475955d">
        <source>getEmailDefaultsSettings( _emailDefaultType : Integer ) : CM_PINObjectDefaultEmail;

/*

Purpose:		This method will attempt to find the Email Default matching the supplied integer value.
				If found then the appropriate CM_PINObjectDefaultEmail instance will be returned.
				This can then be used to get the Send to Carrier settings etc and should replace
				the usage of getConfig(DefaultCarrierEmail) and getConfig(DefaultConsigneeEmail).
				
				The currently (30/07/2009) existing PINEmailTypes constants are:
				PINEmail_ReleaseRequest			1
				PINEmail_ReleaseRequestDelete	2
				PINEmail_CargoRelease			3
				PINEmail_CargoReleaseDelete		4
				PINEmail_Prenote				5
				PINEmail_PrenoteDelete			6
				PINEmail_PrenoteCustomsInspect	7
				PINEmail_ReleaseStatusPending	8
				PINEmail_ReleaseStatusActive	9
				
Date			Who		Reason
30 July 2009	cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests

*/
	
vars
	pinDefaultEmail		: CM_PINObjectDefaultEmail;
	
begin
	return self.allPINObjectEmailDefaults[ _emailDefaultType ].CM_PINObjectDefaultEmail;
	/*
	pinDefaultEmail	:= self.getCarrierEmailDefaultsForType( _emailDefaultType );
	return pinDefaultEmail;
	*/
	
epilog
	
end;
</source>
        <Parameter name="_emailDefaultType" type="Integer"/>
        <ReturnType type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
