    <JadeMethod name="doBaseFormSave" id="9d5b0e00-b0c7-4d72-8701-ad960d355155">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// -------------------------------------------
// Created 21 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	if self.doSave() then
		if self.transportMode = TI_TRANSMODE_ROAD then
			self.unloadForm();
		else
			self.unloadForm();
//			self.doNext(); there is a next button so should use this if they dont want for to unload. PAR11618
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="0d491958-c653-4e57-8013-a7b623b28a09">
        <updating/>
        <source>doEdit() : Boolean updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	amount 			: Integer;
	docketNum,
	operCode,
	userCode		: String;
	cancelSave		: Boolean;
	pxyBOLOutHdr 	: CM_BOLOutHeader;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if self.mode &lt;&gt; Mode_Update then
		return false;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	userCode 	:= tblHeaderDtls.getValueByName(ETRow_ScalerCode).String;
	operCode 	:= tblHeaderDtls.getValueByName(ETRow_Operator).String;
	docketNum 	:= self.tblHeaderDtls.getValueByName(ETRow_DocketNumber).String;
	
	if self.optLoadOutItem.value then
		self.saveByItem();		
	else
		//Not implemeted yet
		return false;
	endif;
	
	self.validate();
	
	if (not app.myPassport.noErrors) then
		app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	endif;

	if self.transportMode = TI_TRANSMODE_ROAD then
		pxyBOLOutHdr := app.createUpdateProxy(self.myCurrentObject).CM_BOLOutHeader;
		
		if self.myCurrentObject.edition &lt;&gt; self.objectEdition then
			// This check is done here because we don't create the proxy when
			// the object is first retrieved, hence the check in the trx would
			// not be comparing the correct object editions
			app.addErrorFullPassport(ObjectUpdatedByAnotherUserSave, 'BOL Out Header', null, null, app.myPassport);
			app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		
		pxyBOLOutHdr.allTrackedItemIDs.purge();
		self.allLogIds.copy(pxyBOLOutHdr.allTrackedItemIDs);
		pxyBOLOutHdr.setProxy(BOLType_Log, docketNum, operCode, userCode, pxyBOLOutHdr.inputDateTime, pxyBOLOutHdr.myTerminal);	
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateBOLOutHeader(pxyBOLOutHdr, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
	elseif self.transportMode = TI_TRANSMODE_RAIL then
		//not implemented yet
		return false;
	elseif self.transportMode = TI_TRANSMODE_SHIP then
		//not implemented yet
		return false;
	endif;

	self.allLogIds.clear;
	self.allTrackedItems.clear;
	
	return true;

epilog
	delete pxyBOLOutHdr;
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
