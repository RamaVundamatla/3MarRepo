<Class name="CMQF_HMSMaster" id="e56deb86-6d31-4de7-ab07-970d240636bf">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="myMaster" id="12753450-82ee-4b9c-aa17-ef6713878385">
        <embedded/>
        <type name="HMS_Master"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="filterObjects" id="76814758-614c-4f48-8004-b40f3cf7aacf">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2012	cnwndl1	Initial creation	Par 29496
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/

vars

	term : CM_Terminal;
	harbour : HMS_Harbour;
	master : HMS_Master;
	breakOut : Boolean;

begin
	inheritMethod(_collection, _passport);
	
	if self.getMyMaster &lt;&gt; null then
		_collection.add(self.getMyMaster);
		return;
		
	else
		foreach term in self.allTerminals do
			harbour := term.myHarbour;
			if harbour &lt;&gt; null then
				foreach master in harbour.allMasters discreteLock do
					
					if self.includesObject(master, _passport, breakOut) then
						_collection.add(master);
					endif;
					
					if breakOut then
						break;
					endif;
				endforeach;
			endif;
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyMaster" id="63255acd-03c6-4893-8169-6d60633a30d2">
        <source>getMyMaster():HMS_Master;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : HMS_Master;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myMaster;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="HMS_Master"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="f5093c0b-3d09-448c-bf61-27d6abb73e3e">
        <updating/>
        <source>includesObject(_master: HMS_Master; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars
	querySelf 	: CMQF_HMSMaster;
	
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if not _master.notAvailForEntry then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_master" type="HMS_Master"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyMaster" id="84ade333-4e5e-4735-91c5-69df70cd7b93">
        <updating/>
        <source>setMyMaster( _object : HMS_Master ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myMaster := _object;

epilog

end;</source>
        <Parameter name="_object" type="HMS_Master"/>
    </JadeMethod>
</Class>
