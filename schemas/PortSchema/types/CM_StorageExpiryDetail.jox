    <JadeMethod name="cloneForSplit" id="cc2e69ce-7e7d-4e94-98c1-36b67a413ed0">
        <updating/>
        <source>cloneForSplit(_ti : CM_TrackedItem input; _cooSplit : Boolean) : CM_StorageExpiryDetail updating;
/*
Purpose:			

Date		Who		Reason
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
8/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email
08 Apr 2024	jlirs1	TFS 63597 unit test failing with duplcates in ti.allStorageExpiryDetails 1310 in CM_StorageExpiryDetailByTS
*/

vars
	newStorageExpiryDetail, storageExpiryDetail : CM_StorageExpiryDetail;
	transaction : CM_TITransaction; 
	now : TimeStamp;
begin
//	now := app.actualTimeAppServer(); // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	
	create newStorageExpiryDetail persistent;
	newStorageExpiryDetail.totalQuantity := _ti.totalQuantity;
	newStorageExpiryDetail.totalWeight := _ti.totalWeight;
	newStorageExpiryDetail.totalVolume := _ti.totalVolume;
	transaction := _ti.allTransactions.findFirstReceivalTrans();
	
	/* // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 this should be cloned
	//08/12/2023	navkc1 ChangeRequest 58261 Task 58260
	if _cooSplit then
		newStorageExpiryDetail.dateTime := self.dateTime;
	else
		newStorageExpiryDetail.dateTime := now;
	endif;
	*/
	newStorageExpiryDetail.dateTime := self.dateTime;
	foreach storageExpiryDetail in _ti.allStorageExpiryDetails do		// 08 Apr 2024	jlirs1	TFS 63597 unit test failing with duplcates in ti.allStorageExpiryDetails
		if storageExpiryDetail.dateTime = newStorageExpiryDetail.dateTime then
			now := app.actualTimeAppServer();
			newStorageExpiryDetail.dateTime := now;
		endif;
	endforeach;
	newStorageExpiryDetail.myTrackedItem := _ti;
	
	newStorageExpiryDetail.additionalStorageDays := self.additionalStorageDays;
	newStorageExpiryDetail.chargedDaysType := self.chargedDaysType;
	newStorageExpiryDetail.freeDays := self.freeDays;
	newStorageExpiryDetail.freeDaysType := self.freeDaysType;
	newStorageExpiryDetail.freeStorageAdjustment := self.freeStorageAdjustment;
	newStorageExpiryDetail.freeStorageDays := self.freeStorageDays;
	newStorageExpiryDetail.freeStorageDaysRemaining := self.freeStorageDaysRemaining;
	newStorageExpiryDetail.freeStorageExpiry := self.freeStorageExpiry;
	newStorageExpiryDetail.futureStorageAnniversary := self.futureStorageAnniversary;
	newStorageExpiryDetail.incoTermsCode := self.incoTermsCode;
	newStorageExpiryDetail.myOwnershipChange := self.myOwnershipChange;
// ### TFS BUG 64221 21MAY2024 NAVAB1	newStorageExpiryDetail.myStorageDetail := self.myStorageDetail;
	newStorageExpiryDetail.operatorCode := self.operatorCode;
	newStorageExpiryDetail.operatorForBillingCode := self.operatorForBillingCode;
	newStorageExpiryDetail.storageChangeReason := self.storageChangeReason;
	
	return newStorageExpiryDetail;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_cooSplit" type="Boolean"/>
        <ReturnType type="CM_StorageExpiryDetail"/>
    </JadeMethod>
    <JadeMethod name="getCOODate" id="d12d83a4-d746-4b21-902e-150a2f213069">
