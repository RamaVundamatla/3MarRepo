    <JadeMethod name="btnCopySave_click" id="c186e46b-a0e5-46a3-9dbd-86df441da4ee">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCopySave_click(btn: Button input) updating;
// 32311
//07 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions

vars

begin
	if self.myTranMapForm.modePropertyUpdate &lt;&gt; self.myTranMapForm.ModeProperty_Move then // TFS 38711
		if self.lstCopyList.listObject = null then // TFS 38711
			app.msgBox(	app.getString( Selection_value_required,"Copy" ), // TFS 38711
							app.getString( Error ), // TFS 38711
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First ); // TFS 38711
			return; // TFS 38711
		endif; // TFS 38711
	endif; // TFS 38711
	if self.cmbDebtorTypes.visible and
	   self.cmbDebtorTypes.listObject = null then
		app.msgBox(	app.getString( Selection_value_required, app.getString( Charges ) ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	endif;
	
	self.doCopyEntry();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyMoveServiceBroker" id="268c479a-e140-4ee5-ace3-028e5d6e924d">
        <updating/>
        <source>copyMoveServiceBroker(commodityMap : CM_CommodityMap) updating, protected;


/*

Purpose: Copy Move from one Commodity map to another			

Parameters:			

Return Value:		

Date			Who		Reason

07 June 2018	jlgsl4	TFS 38711 - STWO - initial creation - exception when copying Move transactions
29 Nov 2018    jlgrh7    TFS41632     STWO - copying a move Ship-&gt;Ship configuration does not work as expected (this method not being used anymore after re-worked)
*/


vars
	moveSB : CM_MoveServiceBroker;
	proxySB, realSB : CM_ServiceBroker;
	theReturn : Integer;
	copyDebtorMap, debtorMap : CM_DebtorMap;
	newQuantityMap : CM_QuantityMap;
	
begin
	/*
	create proxySB as CM_MoveServiceBroker transient;
	foreach moveSB in self.myTranMapForm.myCurrentMapCommodity.moveMap do
		if not global.isValidObject(moveSB) then
			continue; // SB's been deleted, but try copying other SB's if there are any...
		endif;
		proxySB.CM_MoveServiceBroker.setProxyMSB(moveSB.moveFrom, moveSB.moveTo, commodityMap);
		//create child
		//set child.paren
		while true do
			app.myTrxCA.trxCreateInvoiceTMTransaction(proxySB, realSB, app.myPassport);
			//app.myTrxCA.trxCopyTMMoveBroker(moveSB,commodityMap,app.myPassport);
			if app.myPassport.trxCompletedOK then // Clear errors/warnings from form and error/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Copied Move", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theReturn = IDOK then // there were warnings that the user acknowledged...
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport); // copies errors to this form and shows in error/warnings window
			endif;
			break;
		endwhile;
		foreach debtorMap in moveSB.allDebtorMapsByDebtor do // have persistent SB copy,
			beginTransaction;
				create copyDebtorMap persistent; //now copy debtor maps to SB copy from original SB
				copyDebtorMap.copyFrom(debtorMap, debtorMap.myDebtorNode, debtorMap.myDebtorType, realSB);
			commitTransaction;
		endforeach;
	endforeach;

epilog
	delete proxySB;
	*/
end;
</source>
        <access>protected</access>
        <Parameter name="commodityMap" type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxDebtor" id="90fb527a-44e1-40b4-a636-f82f50908b7a">
        <source>doBuildListBoxDebtor(_broker : CM_ServiceBroker) protected;

vars
	theList : CMUI_ListBox;
	debtor	: CM_Debtor;
	currentBroker	: CM_ServiceBroker;
	index			: Integer;

begin

	theList := self.lstCopyList;
	self.btnCopySave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentBroker:= _broker;
	
	foreach debtor in app.myRoot.myRootCompany.debtors do
		if debtor.isSuspended then
			continue;
		endif;
		if currentBroker.allDebtorMapsByDebtor[debtor.name] = null then
			theList.addItem(debtor.name);
			theList.itemObject[theList.newIndex] := debtor;
		endif;
	endforeach;

	// if selecting a to-location elsewhere, highlight the current debtor as the possible default one to use
	if _broker &lt;&gt; self.myTranMapForm.myCurrentMapServiceBroker then
		index := theList.findObject(self.myTranMapForm.myCurrentMapDebtor.myDebtorNode);
		if index &gt; 0 then
			theList.listIndex := index;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_broker" type="CM_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxCommodity" id="50629244-8769-4124-9d70-16e072251f8c">
        <source>doBuildListboxCommodity(_contentsMap : CM_ContentsMap) protected;

vars
	theList : CMUI_ListBox;
	commodity	: CM_Commodity;
	currentMapContents		: CM_ContentsMap;
	currentServiceMap		: CM_TIServiceMap;
	index		: Integer;
	mtCode		: String;
begin

	theList := self.lstCopyList;
	self.btnCopySave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapContents := _contentsMap;
	currentServiceMap := currentMapContents.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap;

	if currentMapContents.contentsType = TI_CONTENTS_STATUS_EMPTY then
		mtCode := self.myTerminal.getDefaultEmptyCommodity();
		theList.addItem(mtCode);
		theList.itemObject[theList.newIndex] := app.myRoot.allCommodities[mtCode];
		// show the empty commodity regardless, but if already used disable the save button
		if currentMapContents.commoditiesMap[mtCode] &lt;&gt; null then
			self.btnCopySave.enabled := false;
		endif;
	else
		
		if currentServiceMap.myCargoType = null then
			// cargo type = Default
			foreach commodity in app.myRoot.allCommodities do
				if currentMapContents.commoditiesMap[commodity.code] = null then
					theList.addItem(commodity.code.padBlanks(7) &amp; commodity.description);
					theList.itemObject[theList.newIndex] := commodity;
				endif;
			endforeach;
		else
			//individual cargo type selected.
			foreach commodity in currentServiceMap.myCargoType.allCommodities do
				if currentMapContents.commoditiesMap[commodity.code] = null then
					theList.addItem(commodity.code.padBlanks(7) &amp; commodity.description);
					theList.itemObject[theList.newIndex] := commodity;
				endif;
			endforeach;
		endif;
		
	endif;
	
	// if selecting a to-location elsewhere, highlight the current commodity as the possible default one to use
	if _contentsMap &lt;&gt; self.myTranMapForm.myCurrentMapContents then
		index := theList.findObject(self.myTranMapForm.myCurrentMapCommodity.getCommodity());
		if index &gt; 0 then
			theList.listIndex := index;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_contentsMap" type="CM_ContentsMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxContents" id="f3527c54-0b58-490b-9057-e776c398c89e">
        <source>doBuildListboxContents(_imexMap : CM_ImexServiceMap) protected;

vars
	theList : CMUI_ListBox;
	cargoMap : CM_TIServiceMap;
	currentMapImex	: CM_ImexServiceMap;
	stat			: CM_ContentsStatus;
	statusDict		: CM_ContentsStatusByCodeDict;
	index			: Integer;

begin

	theList := self.lstCopyList;
	btnCopySave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapImex := _imexMap;
	cargoMap := currentMapImex.myProductMap.myProductGroupMap.myCargoTypeMap;

	// the list of available contents statuses depends on the ti type.
	// i.e. containers have the full range, LCL only have LCL or NULL and
	// the rest only have NULL (which unfortuantely is also the default value.
	
	if cargoMap.className = CM_Container.name then
		statusDict := app.myRoot.allContentsStatuses;
		foreach stat in statusDict do
			if currentMapImex.contentsMaps[stat.code] = null then
				theList.itemObject[theList.addItem(stat.description)]:= stat;
			endif;
		endforeach;
	elseif cargoMap.className = CM_LCL.name then
		stat := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_LCL];
		if stat &lt;&gt; null then
			theList.itemObject[theList.addItem(stat.description)]:= stat;
		endif;
		if currentMapImex.contentsMaps[TI_CONTENTS_STATUS_LCL] = null then
		else
			theList.addItem("LCL");
			theList.enabled := false;
			btnCopySave.enabled := false;
		endif;
	else
		btnCopySave.enabled := false;
	endif;

	// if selecting a to-location elsewhere, highlight the current contents as the possible default one to use
	if _imexMap &lt;&gt; self.myTranMapForm.myCurrentMapIMEX then
		index := theList.findObject(self.myTranMapForm.myCurrentMapContents.getContentsStatus());
		if index &gt; 0 then
			theList.listIndex := index;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_imexMap" type="CM_ImexServiceMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxIMEX" id="b1235ad4-ec58-47f7-8393-5135106e3ccb">
        <source>doBuildListboxIMEX(_productMap : CM_ProductMap) protected;

vars
	theList : CMUI_ListBox;
	status : CM_CargoStatus;
	tmpIMEXDict : CM_IMEXStatusByCodeDict;
	tmpTranDict : CM_TransitStatusByCodeDict;
	currentProductMap	: CM_ProductMap;
	index				: Integer;
	
begin
	theList := self.lstCopyList;
	self.btnCopySave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentProductMap := _productMap;
	
	tmpIMEXDict := app.myRoot.allImexStatuses;
	tmpTranDict := app.myRoot.allTransitStatuses;

	foreach status in tmpIMEXDict do
		if status.code &lt; 1 then
			continue;
		endif;
		if currentProductMap.allImExMaps[status.code] = null then
			theList.itemObject[theList.addItem(status.description)]:= status;
		endif;
	endforeach;			

	foreach status in tmpTranDict do
		if status.code &lt; 1 then
			continue;
		endif;
		if currentProductMap.allImExMaps[status.code] = null then
			theList.itemObject[theList.addItem(status.description)]:= status;
		endif;
	endforeach;				

	// if selecting a to-location elsewhere, highlight the current imex as the possible default one to use
	if _productMap &lt;&gt; self.myTranMapForm.myCurrentMapProduct then
		index := theList.findObject(self.myTranMapForm.myCurrentMapIMEX.getImexStatus());
		if index &gt; 0 then
			theList.listIndex := index;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_productMap" type="CM_ProductMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxTransactions" id="b9e89049-f808-4895-8005-947c6fb59d4d">
        <source>doBuildListboxTransactions(_commodityMap : CM_CommodityMap) protected;

vars
	theList : CMUI_ListBox;
	currentMapCommodity	: CM_CommodityMap;
	aTranType : CM_TransactionType;
	index	: Integer;

begin
	theList := self.lstCopyList;
	self.btnCopySave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapCommodity := _commodityMap;

	foreach aTranType in app.myRoot.allTransactionTypes 
		where aTranType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_HMS do
		// CCMS DPH 2278 exclude future storage - is billed via a BG process
		if aTranType.trxType = TRANS_TYPE_FUTURE_STORAGE 
		or aTranType.trxType = TRANS_TYPE_MANUALLINECREATED then // TFS 46054 jlgzm1 20/09/2019	
			continue;
		endif;
		
		if aTranType.classNameToCreate = CM_Move.name then
			if currentMapCommodity.moveMap.size = 0 then
				theList.addItem(aTranType.description);
				theList.itemObject[theList.newIndex] := aTranType;
			endif;
		else
			if currentMapCommodity.allTransServiceBrokersByType[aTranType.trxType] = null then
				theList.addItem(aTranType.description);
				theList.itemObject[theList.newIndex] := aTranType;
			endif;
		endif;
		
	endforeach;

	// if selecting a to-location elsewhere, highlight the current transaction as the possible default one to use
	if _commodityMap &lt;&gt; self.myTranMapForm.myCurrentMapCommodity then
		index := theList.findObject(self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.myTransactionType);
		if index &gt; 0 then
			theList.listIndex := index;
		endif;
	endif;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_commodityMap" type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="doClose" id="fc0ee5ae-4275-4f99-90cc-c32fdca44ba4">
        <updating/>
        <source>doClose() updating;

vars

begin
	// if the app is closing, the parent form may have been closed before this one- check if valid before using
	if global.isValidObject(self.myTranMapForm) then
		self.myTranMapForm.lstData.enabled := true;
		self.myTranMapForm.frmToolbar.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCopyEntry" id="25c3ae22-d056-4dec-876b-7be9220b1c6d">
        <updating/>
        <source>doCopyEntry() updating, protected;
// ---------------------------------------------------------------------------
// Created:		21 Aug 2013	32311 	CCMS 1297
//
// Purpose:		Copy current entries as new under the selected item
//
// ---------------------------------------------------------------------------
//07 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions
// 29 Nov 2018	jlgrh7	TFS41632	 STWO - copying a move Ship-&gt;Ship configuration does not work as expected

vars

	tISM		: CM_TIServiceMap;
	imex		: CM_ImexServiceMap;
	contentsMap	: CM_ContentsMap;
	commodityMap	: CM_CommodityMap;
	debtorMap	: CM_DebtorMap;
	serviceBroker : CM_ServiceBroker;
	pgMap		: CM_ProductGroupMap;
	prodMap		: CM_ProductMap;
	moveServiceBroker : CM_MoveServiceBroker;
	currentMoveSB : CM_MoveServiceBroker;							//+TFS41632
	pathObject	: Object;
	prodGroup : CM_ProductGroup;
	product : CM_Product;
	label : String;
	commCode	: String;
	mapType, theReturn : Integer;
	cargoType : CM_CargoType;
	status : CM_CargoStatus;
	cStatus : 	CM_ContentsStatus;
	commodity	: CM_Commodity;
	debtor : CM_Debtor;
	debtorType	: CM_DebtorType;
	tranType : CM_TransactionType;

begin
	if self.tblPath.row &gt; 1 then
		pathObject := self.tblPath.accessRow(self.tblPath.row).itemObject.CM_Object;
	endif;

	// 33535 add invalid object checks to handle entries being removed by other users
	if self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_CargoType then
		cargoType := self.lstCopyList.listObject.CM_CargoType;
		label := "Copied Cargo Type";

		if not global.isValidObject(self.myTranMapForm.myCurrentMapTIService) or
		   not global.isValidObject(self.myTranMapForm.myCurrentMapTM) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_ProductGroup then
		prodGroup := self.lstCopyList.listObject.CM_ProductGroup;
		label := "Copied Cargo Subtype Group";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapProdGrp) or
		   not global.isValidObject(self.myTranMapForm.myCurrentMapTIService) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Product then
		product := self.lstCopyList.listObject.CM_Product;
		label := "Copied Cargo Subtype";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapProduct) or
		   not global.isValidObject(self.myTranMapForm.myCurrentMapProdGrp) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_IMEX then
		status := self.lstCopyList.listObject.CM_CargoStatus;
		mapType := status.code;
		if pathObject &lt;&gt; null then
			prodMap := pathObject.CM_ProductMap;
		else
			prodMap := self.myTranMapForm.myCurrentMapProduct;
		endif;
		label := "Copied ImEx Status";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapIMEX) or
		   not global.isValidObject(prodMap) then
			self.resetCopy();
			return;
		endif;
	
	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Contents then
		cStatus := self.lstCopyList.listObject.CM_ContentsStatus;
		mapType := cStatus.code;
		if pathObject &lt;&gt; null then
			imex := pathObject.CM_ImexServiceMap;
		else
			imex := self.myTranMapForm.myCurrentMapIMEX;
		endif;
		label := "Copied Contents Status";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapContents) or
		   not global.isValidObject(imex) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Commodity then
		commodity := self.lstCopyList.listObject.CM_Commodity;
		commCode := commodity.code;
		if pathObject &lt;&gt; null then
			contentsMap := pathObject.CM_ContentsMap;
		else
			contentsMap := self.myTranMapForm.myCurrentMapContents;
		endif;
		label := "Copied Commodity";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapCommodity) or
		   not global.isValidObject(contentsMap) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Debtor then
		if pathObject &lt;&gt; null then
			serviceBroker := pathObject.CM_ServiceBroker;
		else
			serviceBroker := self.myTranMapForm.myCurrentMapServiceBroker;
		endif;
		debtorMap := self.myTranMapForm.myCurrentMapDebtor;
		debtor := self.lstCopyList.listObject.CM_Debtor;
		debtorType := self.cmbDebtorTypes.listObject.CM_DebtorType;
		label := "Copied Debtor";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapDebtor) or
		   not global.isValidObject(serviceBroker) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_TransType then
		tranType := self.lstCopyList.listObject.CM_TransactionType;
		if pathObject &lt;&gt; null then
			commodityMap := pathObject.CM_CommodityMap;
		else
			commodityMap := self.myTranMapForm.myCurrentMapCommodity;
		endif;
		label := "Copied Transaction";
		if not global.isValidObject(self.myTranMapForm.myCurrentMapServiceBroker) or
		   not global.isValidObject(commodityMap) then
			self.resetCopy();
			return;
		endif;

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Move then 
		/*																																																//-TFS41632
		if pathObject &lt;&gt; null then // TFS 38711														
			commodityMap := pathObject.CM_CommodityMap; // TFS 38711
		else // TFS 38711
			commodityMap := self.myTranMapForm.myCurrentMapCommodity; // TFS 38711
		endif; // TFS 38711
		if not global.isValidObject(commodityMap) then // TFS 38711
			self.resetCopy(); // TFS 38711
			return; // TFS 38711
		endif; // TFS 38711
		copyMoveServiceBroker(commodityMap); // TFS 38711
		else
		return;
		*/
		if pathObject &lt;&gt; null then 																																								//+TFS41632
			commodityMap := pathObject.CM_CommodityMap; 
		else
			commodityMap := self.myTranMapForm.myCurrentMapCommodity;
		endif;
		label := "Copied Move";
		if  not global.isValidObject(self.myTranMapForm.myCurrentMapServiceBroker) or not global.isValidObject(commodityMap) then 
			self.resetCopy(); 
			return; 
		endif; 
	else
		return;
	endif;

	while true do
		if self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_CargoType then
			app.myTrxCA.trxCopyInvoiceTMCargoType(self.myTranMapForm.myCurrentMapTIService, cargoType, self.myTranMapForm.myCurrentMapTM,  tISM, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_ProductGroup then
			app.myTrxCA.trxCopyInvoiceTMProductGroup(self.myTranMapForm.myCurrentMapProdGrp, prodGroup, self.myTranMapForm.myCurrentMapTIService, pgMap, app.myPassport);
		
		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Product then
			app.myTrxCA.trxCopyInvoiceTMProduct(self.myTranMapForm.myCurrentMapProduct,  product, self.myTranMapForm.myCurrentMapProdGrp, prodMap, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_IMEX then
			app.myTrxCA.trxCopyInvoiceTMImex(self.myTranMapForm.myCurrentMapIMEX, mapType, prodMap, imex, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Contents then
			app.myTrxCA.trxCopyInvoiceTMContents(self.myTranMapForm.myCurrentMapContents, mapType, imex, contentsMap, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Commodity then
			app.myTrxCA.trxCopyInvoiceTMCommodity(self.myTranMapForm.myCurrentMapCommodity, commCode, contentsMap, commodityMap, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Debtor then
			app.myTrxCA.trxCopyInvoiceTMDebtor(self.myTranMapForm.myCurrentMapDebtor, debtor, debtorType, serviceBroker, debtorMap, app.myPassport);

		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_TransType then
			app.myTrxCA.trxCopyInvoiceTMTransaction(self.myTranMapForm.myCurrentMapServiceBroker, tranType, commodityMap, serviceBroker, app.myPassport);
		
		elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Move then 
			foreach currentMoveSB in self.myTranMapForm.myCurrentMapCommodity.moveMap do																									//+TFS41632
				app.myTrxCA.trxCopyInvoiceMoveTransaction(currentMoveSB, commodityMap, moveServiceBroker, app.myPassport);
			endforeach;
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(label, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.myTranMapForm.lstData.enabled := true;
	self.myTranMapForm.frmToolbar.enabled := true;

	self.unloadForm();

	// 32525 refresh after copy to get the display correct
	self.myTranMapForm.refreshForm();

epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="df10355a-ab64-4ac9-b707-2b6c1cbf7fc5">
        <updating/>
        <source>doResize() updating;

vars

begin
//	inheritMethod();

	self.frmToolbar.positionToolbarControls();
	
	
	self.lblCopy.top := self.frmToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.tblPath.top := self.lblCopy.top + lblCopy.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblCopy2.top := self.tblPath.top + self.tblPath.height; // ### TFS 50421 17SEP2021 NAVAB1
	
	self.cmbDebtorTypes.top := self.lblCopy2.top; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblCharge.top := self.lblCopy2.top; // ### TFS 50421 17SEP2021 NAVAB1
	self.lstCopyList.top := self.lblCopy2.top + self.lblCopy2.height; // ### TFS 50421 17SEP2021 NAVAB1
end;</source>
