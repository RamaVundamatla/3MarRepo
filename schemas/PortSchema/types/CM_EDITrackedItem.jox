    <JadeMethod name="shouldAuditProperty" id="130ce688-f6ae-469e-9090-9ebf90e8457d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//----------------------------------------------------------------
//	Created:	29 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 04 Sep 2012	cnwcs5		par 30064 - dont audit status or processedDateTime
// 22 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094(2) - now we can ignore/process EDi TIs it is important to audit status
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_EDITrackedItem::allExtraData.name or
		propName = CM_EDITrackedItem::myAttachedItems.name or
		propName = CM_EDITrackedItem::myEDIConfig.name or 
		propName = CM_EDITrackedItem::myEDIData.name or 
		propName = CM_EDITrackedItem::myParent.name or 
		propName = CM_EDITrackedItem::processedDateTime.name or		// par 30064 Sep 2012
		propName = CM_EDITrackedItem::rawEDIData.name or 
		propName = CM_EDITrackedItem::rawEDIDataArray.name then				
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
