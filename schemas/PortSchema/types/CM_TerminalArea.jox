    <JadeMethod name="createSwapStack" id="d829ccc5-cbbb-4a12-b8a2-1105a1e23527">
        <updating/>
        <source>createSwapStack() updating;
//Called in the set methods of C++. If no swap stack exists for this
//terminal area, and it can accept TI's, create one.

// cnwcs5	28/07/2009	ccms 1061 - gate areas and interchange areas do not have swap stacks
vars
	swap	:	CM_SwapStack;
begin

	if self.isKindOf(CM_SwapStack) then
		return;	//Invalid for us to create a swapStack of ourselves
	endif;

	if swapStack &lt;&gt; null then
		return;	//Already exists
	endif;

	if type = TA_TYPE_BUILDING or
		self.type = TA_TYPE_GATE_ROAD or			// cnwcs5 28/07/2009 ccms 1061
		self.type = TA_TYPE_YARD_INTERCHANGE or		// cnwcs5 28/07/2009 ccms 1061
		self.type = TA_TYPE_WORKPOINT_INTERCHANGE then	// epr ccms 1033 9/8/11 
		return;	//Cannot put TI's here
	endif;
	//--------------
	//Build the swap stack
	//--------------
	create swap;
	swap.parent := self;
	swap.type := TA_TYPE_SWAP;
	swap.myType := self.getMyTypeFromType(swap.type);

	//----------------
	//Call method to create controller.
	//----------------
	swap.createLC();
	//---------------
	//Check the length of the new Id string
	//---------------
	if id.trimBlanks.length + 5 &gt; swap.id.maxLength then
		swap.id := "SWAP_" &amp; id[1 : swap.id.maxLength-5] ;
	else		
		swap.id := "SWAP_" &amp; id.trimBlanks();
	endif;
	//------------
	swap.myTerminal := self.myTerminal;

end;</source>
    </JadeMethod>
