    <JadeMethod name="translateForm" id="fa7867e4-c5f1-4826-b0b3-008d881dae42">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 March 2021 13:57:55.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006349, locale);
	btn40BaySlots40.translateBubbleHelp(Xlat_0002580, locale);
	btn40BaySlots40.translateCaption(Xlat_0002594, locale);
	btnBayApplyBay.translateBubbleHelp(Xlat_0002618, locale);
	btnBayApplyBay.translateCaption(Xlat_0002633, locale);
	btnBayCancelbay.translateBubbleHelp(Xlat_0002582, locale);
	btnBayCancelbay.translateCaption(Xlat_0002596, locale);
	btnBayEditBay.translateBubbleHelp(Xlat_0002744, locale);
	btnBayEditBay.translateCaption(Xlat_0002753, locale);
	btnBayNewBay.translateBubbleHelp(Xlat_0002661, locale);
	btnBayNewBay.translateCaption(Xlat_0002667, locale);
	btnBayPrintBay.translateBubbleHelp(Xlat_0002620, locale);
	btnBayPrintBay.translateCaption(Xlat_0002636, locale);
	btnBayRemoveBay.translateBubbleHelp(Xlat_0002583, locale);
	btnBayRemoveBay.translateCaption(Xlat_0002598, locale);
