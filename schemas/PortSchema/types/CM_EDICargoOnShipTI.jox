    <JadeMethod name="canUserSet" id="f6c89fc9-e1bf-4051-9302-8b412fb06ecf">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDICargoOnShipTI::myEDIBOLDtl.name or
	   _propName = CM_EDICargoOnShipTI::myEDIBOLHeader.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="2c1e9110-ef49-42be-bfe4-99e2326b614b">
        <updating/>
        <source>create() updating;

vars

begin
	self.site := TI_SITE_ONSHIP;
	//self.imexStatus := app.myRoot.allImexStatuses[ TI_IMEX_STATUS_REMAINONBOARD ].description;		//cnwmc5 - 22 April 2014 - CCMS 2352
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getContainerLength" id="c3dca59b-4eb8-4afa-84a3-3f43e8c65ea0">
        <source>getContainerLength() : Integer;
/*
Purpose:	28479		
Date		Who		Reason
27 October 2011	cnwab1	Initial creation
*/

vars
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;

begin
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType &lt;&gt; null then
		if not isoType.is20ftLong then
			return 40;
		endif;
	else
		isoGroup := app.myRoot.allISOTypeGroups[self.isoTypeGroup];
		if isoGroup &lt;&gt; null then
			if not isoGroup.is20ftLong then
				return 40;
			endif;
		endif;
	endif;

	return 20;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
