    <JadeMethod name="getDefaultMeasurementForType" id="a833e74f-58d5-4d7c-81e7-a11f8cb48889">
        <source>getDefaultMeasurementForType(_type: String): CM_MeasurementType;
/*

Date		Who		Reason
12 Nov 2013	cnwer1	Initial creation PAR 32951
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars

begin
	//04 Sep 2018	NDL	TFS 39769
	if self.allProducts.isEmpty then
		if  _type = Type_Volume and self.isBulkByVolume  then					//25.02.2025 navma1 #MTN-34075
			if self.myVolumeMeasurementType &lt;&gt; null then
				return self.myVolumeMeasurementType;
			endif;
		elseif _type = Type_Weight and self.isBulkByWeight  then				//25.02.2025 navma1 #MTN-34075
			if self.myWeightMeasurementType &lt;&gt; null then
				return self.myWeightMeasurementType;
			endif;
		endif;
	endif;

	if self.mySystemProductType &lt;&gt; null then
		return self.mySystemProductType.getDefaultMeasurementForType(_type);
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultValueByName" id="d7b03e39-80fe-4496-b5a9-8aa9460fb895">
        <source>getDefaultValueByName(_attrName : String) : String;
// ---------------------------------------------------------------------------
// Created:     29 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _attrName = ETRow_MyWidth then
		if self.defaultWidth &lt;&gt; null then
			return self.defaultWidth.String;
		endif;	
	
	elseif _attrName  = ETRow_MyHeight then
		if self.defaultHeight &lt;&gt; null then
			return self.defaultHeight.String;
		endif;
	
	elseif _attrName  = ETRow_MyLength then
		if self.defaultWidth &lt;&gt; null then
			return self.defaultLength.String;
		endif;
			
	elseif _attrName  = ETRow_MyWidthString then
			return self.defaultWidthString.String;
	
	elseif _attrName  = ETRow_MyHeightString then
			return self.defaultHeightString.String;
	
	elseif _attrName  = ETRow_MyLengthString then
			return self.defaultLengthString.String;
			
	elseif _attrName  = ETRow_MyQuantity then
		if self.defaultQuantity &lt;&gt; null then
			return self.defaultQuantity.String;
		endif;
		
	elseif _attrName  = ETRow_MyVolume then
		if self.defaultVolume&lt;&gt; null then
			return self.defaultVolume.String;
		endif;
		
	elseif _attrName  = ETRow_MyDensity then
		if self.defaultDensity &lt;&gt; null then
			return self.defaultDensity.String;
		endif;
	elseif _attrName  = ETRow_MyWeight then
		if self.defaultWeight &lt;&gt; null then
			return self.defaultWeight.asStringWeightJMT();
		endif;
		
	elseif _attrName  = ETRow_MyType then
		return self.defaultType.String;
	endif;
	
	return null;	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefautlValueForAttr" id="3a7a9999-e6c9-4b87-ab7b-0046041eb2ff">
        <source>getDefautlValueForAttr(_attrName : String) : Real;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	product : CM_Product;
	attr : CM_ProductAttr;
begin
	product := self.mySystemProductType;
	
	if product = null then
		product := self.allProducts.first;
	endif;
	
	if product &lt;&gt; null then
		attr := product.getProdAttrFromName(_attrName);
		if attr &lt;&gt; null then
			return attr.getRawValue().Real;
		endif;
		
	endif;
	
	return 0;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayAttributeHeading" id="653e2c6e-0d26-48fe-978b-4b8d207ee70a">
        <source>getDisplayAttributeHeading(_rowName : String) : String;
// 35440
vars
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	
begin

	if self.isEntTableSpecialProductAttr( _rowName ) then
		prod := self.mySystemProductType;
		if prod &lt;&gt; null then
			return prod.getDisplayAttributeHeading(_rowName);
		endif;
	endif;
	return "";
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8d148c50-2b55-45d0-b830-0196ea1b60cb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 06/10/2014  	cnwdb2 		changes to cargo form needed. 
// 18.05.2022   navds20 	ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
// 31 May 2022	navsj20	    TFS 53756: MTN - Cargo Type Maint - Terminals
// 21July 2022  navvt20     ChangeRequest 53917: MTN - Cargo Types TEUs for GC
// 10/08/2022   navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
vars
	str, 
	type		: String;						// PAR #33606
	fileSize    : Integer;
begin
	
	if _attrName = ETRow_Abbreviation then
		return self.abbreviation;
	elseif _attrName = ETRow_TeuMultiplier then
		if self.teuMultiplier = 1 then
			return app.getErrorString(ValueOfOne);
		elseif self.teuMultiplier = 2 then
			return app.getErrorString(CM_Quantity);
		elseif self.teuMultiplier = 3 then
			return app.getErrorString(CM_Weight);
		endif;
		return app.getErrorString(ValueOfOne);
	elseif _attrName = ETRow_TeuConversion20 then	
		return self.getTEUConversionValue(TEUConversionIndex20).asStringJMT;
	elseif _attrName = ETRow_TeuConversion30 then	
		return self.getTEUConversionValue(TEUConversionIndex30).asStringJMT;
	elseif _attrName = ETRow_TeuConversion40 then
		return self.getTEUConversionValue(TEUConversionIndex40).asStringJMT;
	elseif _attrName = ETRow_TeuConversion45 then
		return self.getTEUConversionValue(TEUConversionIndex45).asStringJMT;
	elseif _attrName = ETRow_TeuConversion53 then
		return self.getTEUConversionValue(TEUConversionIndex53).asStringJMT;
	elseif _attrName = ETRow_TeuConversionGC then	
		return self.getTEUConversionValue(TEUConversionIndexGC).asStringJMT;
	elseif _attrName = ETRow_TeuConversionGCBreakBulk then	 							// 21 july 2022 navvt20 53917
		return self.getTEUConversionValue(TEUConversionIndexGCBreakBulk).asStringJMT;   // 21 july 2022 navvt20 53917
	elseif _attrName = ETRow_TeuConversionGCBulk then 									// 21 july 2022 navvt20 53917
		return self.getTEUConversionValue(TEUConversionIndexGCBulk).asStringJMT; 		// 21 july 2022 navvt20 53917
	elseif _attrName = ETRow_ProductType then
		return self.getProductTypeString();
	elseif _attrName = ETRow_NumberOfProducts then
		return self.allProducts.size.String;
	elseif _attrName = ETRow_Colour or 
		   _attrName = ETRow_ProdAttrsViewable then
		return null.String; 
	elseif _attrName = ETRow_DrawColour or
		_attrName = ETRow_DrawAttribute or
		_attrName = ETRow_Font or
		_attrName = ETRow_Character or
		_attrName = ETRow_CharacterNumber then
		if self.myDrawingAttribute &lt;&gt; null then
			return self.myDrawingAttribute.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_IncludeInStorage then
		return self.includeInStorageProcess.getYesNo;
	elseif _attrName = ETRow_ShowDamageCodes then
		return self.showDamageCodes.getYesNo;
	elseif _attrName = ETRow_IsDynamicallyCreated then
		return self.isDynamicallyCreated.getYesNo;	
	elseif _attrName = ETRow_IsBulkProduct then
		return isBulkProduct.getYesNo;		// R Barr 2/11/2006 Comalco	
	elseif _attrName = ETRow_MyWidth or
		_attrName = ETRow_MyWidthString or
		_attrName = ETRow_MyHeight or
		_attrName = ETRow_MyHeightString or
		_attrName = ETRow_MyLength or
		_attrName = ETRow_MyLengthString or
		_attrName = ETRow_MyQuantity or
		_attrName = ETRow_MyVolume or
		_attrName = ETRow_MyWeight or
		_attrName = ETRow_MyType or
		_attrName = ETRow_MyDensity then
		if self.allAttributesOnProduct.includes(_attrName) then
			return '1';
		else
			return '0';
		endif;
	elseif _attrName = ETRow_DefaultHandlingType then
		if self.myDefaultHandlingType &lt;&gt; null then
			return self.myDefaultHandlingType.description;
		endif;
		return null;
	elseif _attrName = ETRow_DefHandlingSubType then	//31 Mar 2017	NDL TFS 3414
		if self.myDefHandlingSubType &lt;&gt; null then
			return self.myDefHandlingSubType.description;
		endif;
		return null;
	elseif _attrName = ETRow_BehaviourType then
		if self.myTIBehaviourType &lt;&gt; null then
			return self.myTIBehaviourType.description;
		endif;
		return null;
	elseif _attrName = ETRow_CreateBOL then 				//ccms 1100 Mar 2008
		if self.getCreateBOL() then
			return '1';
		else
			return '0';
		endif;
	elseif _attrName = ETRow_DrawCreateBOL then				 //ccms 1100 Mar 2008
		return self.getCreateBOL().getYesNo();
	elseif _attrName = ETRow_CargoType then					// Par 17895 September 2008
		return self.description;
		
	elseif _attrName = ETRow_ChgToStorageOnUnpack then		//24 Apr 2015	NDL	Par 36111
		return self.chgToStorageOnUnpack.getYesNo();
		
	elseif _attrName = ETRow_IsNotAvailableForEntry then	// PAR 19704. ccms 1080 May 2009 cnwvu1
		return self.isNotAvailableForEntry.getYesNo();
	elseif _attrName = ETRow_IsSubCargoTypeRequired then	// PAR 19704. ccms 1080 May 2009 cnwvu1
		return self.isSubCargoTypeRequired.getYesNo();
	elseif _attrName = ETRow_IsCommodityRequired then		// PAR 19704. ccms 1080 May 2009 cnwvu1
		return self.isCommodityRequired.getYesNo();
	elseif _attrName = ETRow_DefaultCommodityCode then		// PAR 19704. ccms 1080 May 2009 cnwvu1
		return self.defaultCommodityCode;
	elseif _attrName = ETRow_UseTareCargoWeight then
		return self.useTareCargoWeight.getYesNo();			//+cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_AutoTareCargoWeightCalc then		//navra1 - TFS 63624 - 15th Apr 2024
		return self.autoTareCargoWeightCalc.getYesNo();			//navra1 - TFS 63624 - 15th Apr 2024
	elseif _attrName = ETRow_CanWeightBeCertified then
		return self.canWeightBeCertified.getYesNo();		//+cnwml2 MSL CCMS 1017
		
	// PAR #22938 reefer definition attributes for vehicles only come from default product type
	elseif _attrName = ETRow_Reefer then
		if self.mySystemProductType &lt;&gt; null then
			return self.mySystemProductType.isReefer.getYesNo();
		endif;
		return null;
	elseif _attrName = ETRow_Powered then
		if self.mySystemProductType &lt;&gt; null then
			return self.mySystemProductType.isPowered.getYesNo();
		endif;
		return null;
	elseif _attrName = ETRow_Integral then
		if self.mySystemProductType &lt;&gt; null then
			return self.mySystemProductType.isIntegral.getYesNo();
		endif;
		return null;
	elseif _attrName = ETRow_Fan then
		if self.mySystemProductType &lt;&gt; null then
			return self.mySystemProductType.isFan.getYesNo();
		endif;
	  return null;
	
	elseif _attrName = ETRow_RequiresWeighing then	//05 Jul 2019	NDL	TFS 44965
		self.requiresWeighing.getYesNo();
	elseif _attrName = ETRow_TrackBy then											// PAR #33606
		return app.cargoTypeTrackByEnumToString(self.trackByMeasureType);			// PAR #33606
	elseif _attrName = ETRow_DefaultWeightType then									// PAR #33606
		if self.myWeightMeasurementType &lt;&gt; null then								// PAR #33606
			return self.myWeightMeasurementType.shortName;							// PAR #33606
		endif;																		// PAR #33606
		return null;	
	elseif _attrName = ETRow_DefaultVolumeType then									// PAR #33606
		if self.myVolumeMeasurementType &lt;&gt; null then								// PAR #33606
			return self.myVolumeMeasurementType.shortName;							// PAR #33606
		endif;																		// PAR #33606
		return null;
	elseif _attrName= ETRow_FileAttachments then									// 03.03.2022 navma1 #52821
		fileSize := self.allFiles.size;
		if fileSize &gt; 0 then
			return fileSize.String;
		endif;
		return null;
	elseif _attrName = ETRow_UseCGForUniqueness then				//18 May 2022 navds20 TFS 53504
		return self.useCargoGroupForUniqueness.getYesNo();
	elseif _attrName = ETRow_UseSubTypeForUniqueness then			// 01/05/2023 jlizm1 TFS 55453
		return self.useCargoSubtypeForUniqueness.getYesNo();
	elseif _attrName = ETRow_IsCargoGroupRequired then 				//10/08/2022 navds20 TFS 54219
		return self.isCargoGroupRequired.getYesNo; 	  				//10/08/2022 navds20 TFS 54219
	elseif _attrName= ETRow_SelectedTerminals then  				// 31.05.2022 navsj20 TFS 53756
		return self.getSelectedTerminals();
	
	/*Always Should Be At the End*/
	elseif _attrName.isMeasurementType then											// PAR #33606
		_attrName.getRowNameMeasureType(str, type);									// PAR #33606
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #33606
	endif;
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawColour" id="6ca041e4-e80b-4238-a746-d786f557327c">
        <source>getDrawColour() : Integer;

/*

Purpose:			Get the drawing colour for the receiver, from its current Drawing Attributes


Return Value:		Colour value.  If no drawing attributes exist, then default is White, not Black


Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	drawAttibute	: CM_DrawingAttribute;
	
begin
	drawAttibute := self.myDrawingAttribute;
	if drawAttibute &lt;&gt; null then
		return drawAttibute.colour;
	else
		return White;
	endif;
	
		
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
