epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="00211253-6cb9-4292-b162-01b73286d582">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	31 October 2005	by Jason Chapman  (cnwjc2)
