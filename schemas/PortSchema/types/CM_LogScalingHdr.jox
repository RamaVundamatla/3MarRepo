    <JadeMethod name="validateHdr" id="b2cac359-dd8b-446c-b9e6-e160550e5060">
        <source>validateHdr() protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
begin

	if self.bolNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'docket number', ETRow_BolNumber, null);
		app.raiseCMException(Input_required_field_docNumber, ETRow_BolNumber, null); // cnwdb2	PAR 35364


	endif;

	if (not self.inputDateTime.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'input date/time', 'inputDateTime', null);
		app.raiseCMException(Input_required_field_inputDT, '', null); // cnwdb2	PAR 35364
		

	endif;

	if self.operatorCode = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_OperatorCode, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_OperatorCode, null); // cnwdb2	PAR 35364

	endif;

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'terminal', 'myTerminal', null);
		app.raiseCMException(Input_required_field_terminal, 'myTerminal', null); // cnwdb2	PAR 35364


	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateLocationRestrictions" id="6415a9dc-a2c7-4382-bcd6-86651efdceb7">
        <source>validateLocationRestrictions(_logDocket : CM_BOLIn; _passport : CM_Passport input) : Boolean;
// --------------------------------------------------------------------------------
// Created:		8 July 2009 by cnwjo3
//
// Purpose:		Validate if the dockets planned location (A log row) currently
//				fits with the dockets log specifications (+ operator)
//				In most forms it is not possible to get this out of sync apart
//				from the Docket Recon form where it is possible for a user
//				to update a Log Row before the Log Docket has been reconciled
//				This is for par 19812
//
// Updated:		cnwjo3, par 20940.  allLogSpecies accidently used throughout.
vars
	locRestLog : CM_LocationRestrictLog;
	logCont : CM_LogController;
	operatorsMatch,
	speciesMatch,
	gradesMatch,
	typesMatch,
	treatmentsMatch,
	lengthsMatch : Boolean;
	
begin
	if _logDocket.myPlannedLocation &lt;&gt; null then
		if _logDocket.myPlannedLocation.isKindOf(CM_LogController) then //always good to verify that we are actually moving a log
			logCont := _logDocket.myPlannedLocation.CM_LogController;
			if logCont.myLocationRestriction &lt;&gt; null then
				if logCont.myLocationRestriction.isKindOf(CM_LocationRestrictLog) then  //restriction is for logs
					locRestLog := logCont.myLocationRestriction.CM_LocationRestrictLog;
					//check everything is still hunky dorry
					if locRestLog.allOperators.includes(_logDocket.myOperator) or locRestLog.allOperators.size = 0 then
						operatorsMatch := true;
					endif;
					if locRestLog.allLogSpecies.includes(_logDocket.myLogSpecies) or locRestLog.allLogSpecies.size = 0 then
						speciesMatch := true;
					endif;
					if locRestLog.allLogGrades.includes(_logDocket.myLogGrade) or locRestLog.allLogGrades.size = 0 then
						gradesMatch := true;
					endif;
					if locRestLog.allLogTypes.includes(_logDocket.myLogType) or locRestLog.allLogTypes.size = 0 then
						typesMatch := true;
					endif;
					if locRestLog.allLogTreatments.includes(_logDocket.myLogTreatment) or locRestLog.allLogTreatments.size = 0 then
						treatmentsMatch := true;
					endif;
					if locRestLog.allLogLengths.includes(_logDocket.myLogLength) or locRestLog.allLogLengths.size = 0 then
						lengthsMatch := true;
					endif;
						
					if operatorsMatch and speciesMatch and gradesMatch and typesMatch and treatmentsMatch and lengthsMatch then
						// ok.  could return true here if I wanted to
					else
						// Par 25450 14/09/2010
						app.raiseCMException2(ERR_LOG_DOCKET_RESTRIC_NOMATCH, _logDocket.number, logCont.id, null, null);
						//return false; // we don't need this because an exception is raised. Anyway, return false doesn't work for app.raiseCMWarning
					endif;
				endif;
			endif;
		endif;
	endif;

	return true;
end;
</source>
        <Parameter name="_logDocket" type="CM_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xmlOutputForTestLoad" id="07e8c750-5c55-48cf-8e8b-fa444a31d487">
        <source>xmlOutputForTestLoad() : String;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     Used by the test framework to output the data in the
//				same format as the XML receives it.  
// ---------------------------------------------------------------------------
/*
&lt;tibatch class="LOG" type="SCALE"&gt;
&lt;batchhdr&gt;DAVETEST014,CH,20031120114400,20031120115000&lt;/batchhdr&gt; 
&lt;tidtls class="LOG" type="SCALE"&gt;
&lt;ti&gt;XXXVETESTLOG01,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG02,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG03,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG04,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG05,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG06,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG07,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG08,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG09,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG10,OK,34,36&lt;/ti&gt; 
&lt;/tidtls&gt;
&lt;/tibatch&gt;
*/
vars
	xml,
	tiDtls,
	tmpStr	: String;
	tmpDtl	: CM_LogScalingDtl;
	
begin

	foreach tmpDtl in self.allLogScalingDtls do
		tmpStr := tmpDtl.logID &amp; ',' &amp;
				  tmpDtl.conditionCode &amp; ',' &amp;
				  tmpDtl.minSED.String &amp; ',' &amp;
				  tmpDtl.maxSED.String;
				  
		tiDtls := tiDtls &amp;
			self.formatAsXML(XML_TI, tmpStr);

	endforeach;
	
	tmpStr := self.bolNumber &amp; ',' &amp; 
		   	  self.operatorCode &amp; ',' &amp;
		   	  self.inputDateTime.formatAsYYYYMMDDHHmmSS() &amp; ',' &amp;
		   	  self.inputDateTime.formatAsYYYYMMDDHHmmSS();

	xml := self.formatAsXMLPrefix(XML_TIBATCH &amp; ' class="LOG" type="SCALE"') &amp;
		   self.formatAsXML(XML_BATCHHDR, tmpStr) &amp;
		   self.formatAsXMLPrefix(XML_TIDTLS &amp; ' class="LOG" type="SCALE"') &amp;
		   tiDtls &amp;
		   self.formatAsXMLSuffix(XML_TIDTLS) &amp;
		   self.formatAsXMLSuffix(XML_TIBATCH);

	return xml;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
