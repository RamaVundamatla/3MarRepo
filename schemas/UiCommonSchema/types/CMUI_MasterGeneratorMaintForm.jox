    <JadeMethod name="doBtnDamageClick" id="339441d7-dd77-413c-abda-b3c6d9671ea0">
        <updating/>
        <source>doBtnDamageClick() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		30 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 28/09/2022	navkc1	ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
//----------------------------------------------------------------------
vars
begin
	self.myAssistant.showDamageSimpleFormForFleet(self, self.myTiMaster,CMUI_DamageCodesForm.Mode_Update, self.myTerminal); // ### TFS 55313 08NOV2022 NAVAB1
	
	// ### TFS 55313 08NOV2022 NAVAB1realTi := self.myTiMaster;
	/*	//	30/09/2022	navkc1	#54463
	form := app.loadForm (CMUI_DamageCodesAdvanceForm, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_DamageCodesAdvanceForm;
	form.mode := Mode_Update;
	form.isParentFormUpdate := true;
	
	form.setMyMasterItems(ti, realTi);
	form.setParentForm(self);

	form.centreWindow();
	form.show();
	*/ //	30/09/2022	navkc1	#54463
	
	// ### TFS 55313 08NOV2022 NAVAB1self.myAssistant.showDamageEntryForm(self, Mode_Update, self.myTerminal, ti, realTi, null, null, true);		// 30/09/2022	navkc1	#54463
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteTIMasterGen" id="dfaad4bc-c2dc-45e6-8236-9e1347f8866c">
        <updating/>
        <source>doDeleteTIMasterGen() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/10/2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
*/

vars
	realMasterContainer : CM_TIMasterContainer;
	selectedObject : CM_Object;
	message : String;
	result : Integer;
begin
	selectedObject := self.myTiMaster;
	message := app.getErrorString1(Confirm_detach, selectedObject.CM_TIMasterGenerator.id);
	if app.msgBox(message, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	realMasterContainer := selectedObject.CM_TIMasterGenerator.allTIMasterAttachers.first.CM_TIMasterContainer;
	beginTransaction;
	realMasterContainer.clearAllAttachees();
	commitTransaction;
	self.myParentForm.CMUI_ReceiveCargoForm.deleteAttachment(selectedObject); // remove TIMasterGenerator from Attachments
	self.unloadForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNext" id="52932f2a-73e2-4770-bdba-015f4d554271">
