        <updating/>
        <source>mnuMachineLoginAs_click(menuItem: MenuItem input) updating;

vars
	tmpMachine	: CM_Machine;
	tmpDevice	: CM_RadioTelemetryDevice;
begin
	if (not self.getCurrentMachine(tmpMachine)) then 
		foreach tmpDevice in self.myTerminal.radioTelemetry.allRTDevices discreteLock do
			if tmpDevice.isKindOf(CM_RTDeviceHandHeld) then
				app.startApplicationWithParameter('MobileUISchema', 'HandHeldWithDevApp', tmpDevice);
				return;
			endif;
		endforeach;
		return;
	endif;
	
	tmpDevice := tmpMachine.myRTDevice;
	if tmpDevice &lt;&gt; null then 
		tmpDevice.startAppFor();
	endif;
end;</source>
