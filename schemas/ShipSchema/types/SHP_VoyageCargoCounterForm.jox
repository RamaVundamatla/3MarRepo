    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="47bf81c0-97bd-49d9-bee5-4539c9f1d0c7">
        <source>doCargoEnquiry(_isSelected :Boolean);
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	set		:CM_TISet;
	coll	:ObjectArray;
begin
	create set transient;
	
	if _isSelected then
		self.myCargoCounterOutputAgent.getSelectedTrackedItems (self.tblData, set);
	else
		self.myCargoCounterOutputAgent.getAllTrackedItems (set);
	endif;
	
	
	if not set.isEmpty then
		create coll transient;
	
		set.copy (coll);
		
		self.myAssistant.showCargoEnquiryForTIs(coll.first.CM_TrackedItem, coll, null, false);
	endif;
epilog
	delete set;
	delete coll;
end;	
</source>
        <Parameter name="_isSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="7d919e91-14a5-4f68-97e0-d7161ab7cebc">
        <updating/>
        <source>doPrint() updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	self.doPrintOutTable(self.tblData, self.caption, true, true, true, false);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="bc53bb1a-4b23-433c-bba5-976bd431e39e">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	voyage	:CM_Voyage;
	coll	:CM_CargoTypeSet;
begin
	voyage	:= self.cmbVoyage.listObject.CM_Voyage;
	
	if voyage = null then
		app.msgBox(app.getErrorString(PleaseSelectAVoyage), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	self.translateCaption(Xlat_0016802, app.myCurrentLocale);
	self.setCaption( self.caption &amp; " - " &amp; voyage.code);
	
	create coll transient;
	
	self.mulCargoTypes.getSelected (coll);
	
	self.myCargoCounterOutputAgent.displayCapacityTable(voyage, self.tblData, self.optActual.value,
								self.chkContainerTI.value, self.chkContainerTEU.value, 
								self.chkGCCount.value, self.chkArea.value, self.chkLM.value, self.chkQty.value, 
								self.chkVolume.value, self.chkWeight.value, coll);
	inheritMethod ();
epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="8325f9ba-851e-49a8-90ba-318532877fa1">
        <source>doResetSearch();
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	voyage	:CM_Voyage;
	combo	:ComboBox;
	index	:Integer;
begin
	voyage 	:= self.myCurrentVoyage;
	
	if voyage = null then
		voyage := app.myCurrentVoyage;
	endif;
	
	combo	:= self.cmbVoyage;
	
	if voyage &lt;&gt; null then
		index	:= combo.findObject (voyage);
	endif;
	
	if index &gt; 0 then
		combo.listIndex := index;
	else
		combo.listIndex := -1;
	endif;
	
	self.optActual.value		:= true;
	self.chkContainerTI.value	:= true;
	self.chkContainerTEU.value	:= true;
