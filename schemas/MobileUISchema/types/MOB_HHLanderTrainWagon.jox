    <JadeMethod name="populateWagons" id="24a2112b-e985-42ca-99cf-8425180bb2d4">
        <source>populateWagons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	beforeWagon : CM_Wagon;
	train : CM_Train;
	wagon : CM_Wagon;
	index : Integer;
	load : Boolean;
	discharge : Boolean;
	wagons : CM_WagonSet;
	wleCount : Integer;
	job : CM_Job;
	wle : CM_WorkListEntry;

begin

	beforeWagon := self.cmbWagon.listObject.CM_Wagon;
	self.cmbWagon.clear();
	self.cmbWagon.addItem(self.lblWagon.caption);
	self.cmbWagon.itemEnabled[1] := false;

	discharge := self.optDischarge.value;
	load := self.optLoad.value;
	
	train := self.cmbTrain.listObject.CM_Train;
	if train &lt;&gt; null then
		wagons := train.getWagons(discharge, load);
	else
		create wagons transient;
	
		foreach wagon in self.myTerminal.allWagons do
			if not wagon.confirmed or wagon.confirmedOutwards then
				continue;
			endif;
			wagons.addNoDuplicates(wagon,false);
		endforeach;
	endif;
	
	if wagons.isEmpty then
		self.cmbWagon.itemText[1] := app.getErrorString(WagonsNone);
		self.cmbWagon.listIndex := 1;
		return;
	endif;
	
	//02 Oct 2014	NDL	Par 34981
	foreach wagon in wagons do
		wleCount := 0;
		if load then
			foreach job in wagon.allRailJobs do
				foreach wle in job.workListEntries do
					if not wle.isReceipt then
						if wle.status = WLE_UNACTIONED then
							wleCount := wleCount + 1;
						endif;
					endif;
				endforeach;
			endforeach;
		elseif discharge then
				foreach job in wagon.allRailJobs do
				foreach wle in job.workListEntries do
					if wle.isReceipt then
						if wle.status = WLE_UNACTIONED then
							wleCount := wleCount + 1;
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
		if wleCount &lt;&gt; 0 then
			self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.id &amp; " (" &amp; wleCount.String &amp; " " &amp; app.getErrorString(Tasks) &amp; ")")] := wagon;
		else
			self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.id)] := wagon;
		endif;
	endforeach;
	
	index := 0;
	if beforeWagon &lt;&gt; null then
		index := self.cmbWagon.findObject(beforeWagon);
	endif;
	
	if index &gt; 0 then
		self.cmbWagon.listIndex := index;
	elseif self.cmbWagon.listCount = 1 then
		self.cmbWagon.listIndex := 1;
	endif; 

epilog

	delete wagons;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="00f9a11a-eb7d-4e1f-a394-10c24a07c3c5">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	train : CM_Train;
	wagon : CM_Wagon;
	now : TimeStamp;

begin
					 
	self.cmbTrain.clear();
	self.cmbTrain.addItem(lblTrain.caption);
	now := app.actualTimeServer;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach train in self.myTerminal.allTrainsOnTerminal do
		if train.isNullTrain then
			continue;
		endif;
		self.cmbTrain.itemObject[cmbTrain.addItem( train.getCodeDateString )] := train;
	endforeach;
	
	train := self.myMobileGenericAgent.myCurrentTrain;
	
	if train &lt;&gt; null and cmbTrain.findObject(train) &gt; 0 then
		cmbTrain.listIndex := cmbTrain.findObject(train);
	elseif cmbTrain.listCount = 2 then
		cmbTrain.listIndex := 2;
	else
		cmbTrain.listIndex := 1;
	endif;
	
	self.populateWagons();
	
	self.doResizeControls(true);
							 
	//24 Mar 2010 NDL Par 23316	- retain value when returning...
	if self.myMobileGenericAgent.checksState = 0 then
		return;
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		self.optDischarge.value := true;
		self.optDischarge.click(self.optDischarge);
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
		self.optLoad.value := true;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ec476679-e12d-4c2a-9184-0445b0d0fbc4">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
