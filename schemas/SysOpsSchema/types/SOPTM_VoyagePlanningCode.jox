    <JadeMethod name="create" id="14c42bab-af2b-41cc-9652-d422b0d9c20f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.name				:=	SOP_TableMaintForm.Table_VoyagePlanningCode;
	self.permissionView		:=	PmVoyagePlanCodeView;
	self.permissionMaint	:=	PmVoyagePlanCodeMaint;
	self.myDataClass		:=	CM_VoyagePlanningCode;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2dd6dd09-c255-4a11-8acf-638546baecc6">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	app.myTrxDA.trxDeleteVoyagePlanningCode(pObj.CM_VoyagePlanningCode, app.myPassport);
end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="d996fe98-0bb6-46fc-95b2-de471b48d48c">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	formObj					: SOP_TableMaintForm;
	proxyPlanningCodeObj	: CM_VoyagePlanningCode;
	isNotAvailableForEntry	: Boolean;
	planningCode			: String;
	description				: String;
	
begin
	formObj 				:=	self.myForm;
	planningCode			:=	formObj.tblInput1.getValueByName(ETRow_Code).String;
	description 			:=	formObj.tblInput1.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry	:=	formObj.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if formObj.myProxyObject = null then
		if formObj.mode = formObj.Mode_Add then
			create formObj.myProxyObject as CM_VoyagePlanningCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyPlanningCodeObj	:=	formObj.myProxyObject.CM_VoyagePlanningCode;
	proxyPlanningCodeObj.setProxy(planningCode, description, isNotAvailableForEntry, app.myPassport.myTerminal);

	if formObj.mode = formObj.Mode_Add then
		app.myTrxCA.trxCreateVoyagePlanningCode(proxyPlanningCodeObj,
												formObj.myCurrentObject,
												app.myPassport);
		
	elseif formObj.mode = formObj.Mode_Update then
		app.myTrxUA.trxUpdateVoyagePlanningCode(proxyPlanningCodeObj, app.myPassport);
		
	endif;
epilog
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="cce53990-5356-4af9-9a5a-dc47cba8f007">
        <source>getCollection(): Collection;
// ---------------------------------------------------------------------------
// Created:     03 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	
begin
	terminalObj	:=	app.getMyTerminalDO_NOT_USE;
	
	if terminalObj = null then
		return null;
	else
		return terminalObj.allVoyagePlanningCodes;
	endif;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
