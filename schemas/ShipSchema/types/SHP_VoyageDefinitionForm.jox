    <JadeMethod name="translateForm" id="da9cb540-1f4d-452f-9a0d-6565c7f4058e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 March 2025 13:14:42.
	// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
