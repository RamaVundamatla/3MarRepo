    <JadeMethod name="getDisplayString" id="66cf9aab-ef9d-40c4-b4c5-4f429a322375">
        <source>getDisplayString(): String;

vars

begin
	return oldBookingReference &amp; " =&gt; " &amp; newBookingReference;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setBookingReferences" id="cc9a7ece-c46f-4a98-8813-5e3c7ec32114">
        <updating/>
        <source>setBookingReferences(_oldRef, _newRef :String) updating;

vars

begin
	oldBookingReference	:= _oldRef;
	newBookingReference	:= _newRef;
end;
</source>
        <Parameter name="_oldRef" type="String"/>
        <Parameter name="_newRef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setOtherReferences" id="2de19e39-8108-42ea-86e8-98b4d475e41d">
        <updating/>
        <source>setOtherReferences(_oldPort, _newPort, _oldVoyage, _newVoyage : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/10/2011	cnwdap1	Initial creation PAR #28524 CCMS POL 2096
*/
vars

begin
	self.oldDischargePort	:= _oldPort;
	self.newDischargePort	:= _newPort;
	self.oldVoyageCode		:= _oldVoyage;
	self.newVoyageCode		:= _newVoyage;
epilog

end;</source>
        <Parameter name="_oldPort" type="String"/>
        <Parameter name="_newPort" type="String"/>
        <Parameter name="_oldVoyage" type="String"/>
        <Parameter name="_newVoyage" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="f877bb7e-491e-4372-823b-2ee33812039c">
