//	endif;
//	if weighAuthority &lt;&gt; null then
//		self.cmbWeightAuth.setForObject(weighAuthority);
//		self.myAssistant.listWeighAuthorityPersons( self.cmbWeightPerson.getEmbeddedControl.ComboBox, self.myTerminal, weighAuthority.certifiedName );
