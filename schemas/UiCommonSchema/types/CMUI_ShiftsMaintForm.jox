// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.saveShift() then
		if self.optStandard.value then
			self.clearProxyDetails();
			self.frmAddDialog.visible := false;
		else
			if self.mode = self.MODE_EDIT then
				self.clearProxyDetails();
			endif;
			self.frmAddDialogDay.visible := false;
		
		endif;
		self.setFormMode(MODE_VIEW);
	endif;	
end;
