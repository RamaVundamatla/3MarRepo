    <JadeMethod name="isEdiHazardExistInCollection" id="e7905274-6d6c-479d-9232-5f2f5134b64c">
        <source>isEdiHazardExistInCollection(_ediHazDetails : CM_EDIHazDetailsTI) : Boolean;
/*

Purpose:	To check the EDI hazard details already added to the collection 'cmifPrenote.allTIHazards'	

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2024	navsp1	Initial creation TFS 61660

*/

vars
	result : Boolean;
	haz : CM_Hazard;
	str : String;
	strArray : StringArray;
begin
	foreach haz in self.allTIHazards do
		if	haz.code = _ediHazDetails.code.trimBlanks[1:9] and
			haz.description = _ediHazDetails.description.trimBlanks[1:40] and
			haz.CM_TIHazard.acidsBases = _ediHazDetails.acidsBases[1:10] and
			haz.CM_TIHazard.flashpointTemperature = _ediHazDetails.flashpointTemperature and
			haz.CM_TIHazard.isMarinePollutant = _ediHazDetails.isMarinePollutant and
			haz.CM_TIHazard.limitedQuantity = _ediHazDetails.limitedQuantity and
			haz.CM_TIHazard.packingGroup = _ediHazDetails.packingGroup[1:5] then
				
				if _ediHazDetails.undgCodes.trimBlanks &lt;&gt; null then						//TFS 61660/64071
					strArray := _ediHazDetails.undgCodes.cnGetTokens(" ");				//TFS 61660/64071
					if strArray &lt;&gt; null and not strArray.isEmpty then					//TFS 61660/64071
						foreach str in strArray do										//TFS 61660/64071
							if not haz.CM_TIHazard.allUNDGCodes.includes(str) then		//TFS 61660/64071
								return false;											//TFS 61660/64071
							endif;														//TFS 61660/64071
						endforeach;														//TFS 61660/64071
					endif;																//TFS 61660/64071
				endif;																	//TFS 61660/64071
				
				return true;
		else
			return false;			
		endif;			
	endforeach;
epilog
	delete strArray;
end;</source>
        <Parameter name="_ediHazDetails" type="CM_EDIHazDetailsTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
