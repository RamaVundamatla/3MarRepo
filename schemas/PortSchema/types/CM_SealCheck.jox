vars

begin

	return self.allSealCheckDetails.displayAllAfterAsCSV();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnknownSealTypeNumbersArray" id="c8eb7acd-8883-449f-92ba-69db7b996794">
        <source>getUnknownSealTypeNumbersArray(_allKnownSealTypes : String; _theSealNumbers : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2018	jlgsl4	TFS 39801 - SNO - Codeco needs 'at Receive' details
*/

vars
	sealCheckDetail : CM_SealCheckDetail;
begin
	foreach sealCheckDetail in self.allSealCheckDetails do
		if _allKnownSealTypes.pos(sealCheckDetail.sealType, 1) &gt; 0 then
			continue;
		else
			sealCheckDetail.sealAfter.getTokensForDelimiter(",", _theSealNumbers);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allKnownSealTypes" type="String"/>
        <Parameter name="_theSealNumbers" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includesSealType" id="5d79ff21-8ba9-432a-a9a9-88d08d950757">
        <source>includesSealType( _sealType : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation		Par 25608

*/

vars

	sealCheckDetail : CM_SealCheckDetail;
	
begin

	foreach sealCheckDetail in self.allSealCheckDetails do
		if sealCheckDetail.sealType = _sealType then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesUnMatched" id="997b5e76-a9f0-4959-ad94-b2d099168a4b">
        <source>includesUnMatched():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation		Par 25608

*/

vars

	sealCheckDetail : CM_SealCheckDetail;
	
begin

	foreach sealCheckDetail in self.allSealCheckDetails do
		if sealCheckDetail.isUnMatched() then
