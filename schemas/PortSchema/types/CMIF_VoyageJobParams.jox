    <JadeMethod name="addHatchLid" id="29cd7698-7bd0-4730-b0c6-319005618336">
        <updating/>
        <source>addHatchLid(_hatchLid : CM_HatchLid) updating;
// ---------------------------------------------------------------------------
// Created:     18 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _hatchLid = null then
		return;
	endif;
	
	if (not self.allHatchLids.includes(_hatchLid)) then
		self.allHatchLids.add(_hatchLid);
	endif;

end;</source>
        <Parameter name="_hatchLid" type="CM_HatchLid"/>
    </JadeMethod>
    <JadeMethod name="clearHatchLids" id="dd16acb4-d3e7-487a-b171-cdc30b22f374">
        <updating/>
        <source>clearHatchLids() updating;
// ---------------------------------------------------------------------------
// Created:     18 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allHatchLids.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="hasMultipleAllocations" id="0f23b868-a78b-46ba-bd7c-36f1b204ed99">
        <source>hasMultipleAllocations() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2012	cnwrd1	Initial creation

*/

vars
	allocs,
	requestAllocs : CM_YardAllocationSet;
	request : CM_Request;
begin

	create allocs transient;
	
	foreach request in self.allSlotRequests do
		requestAllocs := request.getVoyageAllocations();
		
		if requestAllocs.isEmpty then
			continue;
		endif;
		
		if requestAllocs.size &gt; 1 then
			return true;
		endif;
		
		allocs.addNoDuplicates(requestAllocs.first, false);
		
		if allocs.size &gt; 1 then
			return true;
		endif;
	endforeach;

	foreach request in self.allRORORequests do
		requestAllocs := request.getVoyageAllocations();
		
		if requestAllocs.isEmpty then
			continue;
		endif;
		
		if requestAllocs.size &gt; 1 then
			return true;
		endif;
		
		allocs.addNoDuplicates(requestAllocs.first, false);
		
		if allocs.size &gt; 1 then
			return true;
		endif;
	endforeach;
	
	return false;	
epilog
	delete allocs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHatchLidsFromCode" id="df57e869-5832-496f-9602-0e40d951269e">
        <updating/>
        <source>setHatchLidsFromCode(_hatches : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx , len, numLids : Integer;
	aLid : CM_HatchLid;
	hatchCode : String;
	created : Boolean;
begin
	if self.myBay.allHatchLids.isEmpty then
		return;
	endif;
	
	numLids := self.myBay.allHatchLids.size;
	len := _hatches.length;
	
	 foreach idx  in 1 to len do
	 	hatchCode := _hatches[idx:1];
	 	
	 	foreach aLid in self.myBay.allHatchLids do : innerLoop
	 		if aLid.sideAbbreviation = hatchCode then
	 			self.addHatchLid(aLid);
				self.allObjectEditions.add(aLid);
				created := true;
	 			break innerLoop;
	 		endif;
	 	endforeach;
	 endforeach;
	 
end;</source>
        <Parameter name="_hatches" type="String"/>
    </JadeMethod>
    <JadeMethod name="setROROSlotRequests" id="bdeba411-8355-4002-9967-1ba85a9d9992">
        <source>setROROSlotRequests(_isSOB : Boolean io): Boolean protected  ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	tmpSlot		: CM_VoyageROROController;
	tmpRORORequest		: CM_RORORequest;
	tmpROROSlotRequest	: CM_ROROSlotRequest;
	tmpDescr,
	errSlotStr		: String;
	slotsInError : CM_ROROVoyageControllerSet;
begin

	//epr 25/8/11 if not a deck set then should never be a roro job and have roro controllers
	if self.myDeck = null then
		return true;
	endif;
	
	create slotsInError transient;
	if self.allROROControllers.isEmpty() then
		return false;
	
	endif;
	
	foreach tmpSlot in self.allROROControllers do
		if self.isDischarge then
			tmpRORORequest := tmpSlot.myRORORequestDischarge;
			if tmpRORORequest &lt;&gt; null then
				if tmpRORORequest.isSoB then
					_isSOB := true;
				endif;
				self.allRORORequests.addNoDuplicates(tmpRORORequest, false); // PAR 27043
			else
				slotsInError.add(tmpSlot);
				continue;
			endif;
		else
			tmpRORORequest := tmpSlot.myRORORequestLoad;
			if tmpRORORequest &lt;&gt; null then
			/* PAR 33860  DO NOT PUT LOAD SOB CC in LOAD JOB. Load SoB CC goes in the discharge job.
				if tmpSlotRequest.isSOB then
					_isSOB := true;
				endif;
				*/
				if tmpRORORequest.isSOB then
					continue;
				endif;
				self.allRORORequests.addNoDuplicates(tmpRORORequest, false); // PAR 27043 
			else
				slotsInError.add(tmpSlot);
				continue;
			endif;
		endif;
		
		if tmpRORORequest &lt;&gt; null and
		   self.jobNumLinkedLoad &lt;&gt; null then
			if tmpRORORequest.isLinked and tmpRORORequest.isDischarge then
			else
				// The request for slot %1 is not linked.  You cannot create a linked job for it.
				app.raiseCMException1(ErrReqNotLinkedCannotCreateJob, tmpRORORequest.myROROController.getID, null, null);
			endif;
		endif;
	endforeach;
	
	if (not slotsInError.isEmpty) then
		foreach tmpSlot in slotsInError do
			if errSlotStr = null then
				errSlotStr := tmpSlot.ident;
			else
				errSlotStr := errSlotStr &amp; ', ' &amp; tmpSlot.ident;
			endif;
		endforeach;
		if self.isDischarge then
			tmpDescr := app.getErrorString(Discharge);
		else
			tmpDescr := app.getErrorString(Load);
		endif;
		app.raiseCMException2(SlotsNotMarkedUpDishLoadInJob, errSlotStr, tmpDescr, null, null);
		return false;
	endif;

	return true;
epilog
	delete slotsInError;


end;</source>
        <access>protected</access>
        <Parameter name="_isSOB" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRequests" id="75a4bc37-28c5-49ad-9013-ed1ea0f34fcf">
        <updating/>
        <source>setRequests() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
	tmpHatch	: CM_HatchLid;
	pxyVoyageJob	: CM_VoyageJob;
	isSOB,
	isUserJob,			// set to true if no slots
	isHatchLidJob,
	isDeckJob		: Boolean;
	theJobTypeNumber	: Integer;
	estMins : Integer;
begin

	isSOB := false;
	//returned false got an error so return
	if not self.setSlotRequests(isSOB) then
		return;
	endif;
	
	
	if self.allRORORequests.isEmpty()
	and not self.setROROSlotRequests(isSOB) then
		return;
	endif;
	isHatchLidJob := (not self.allHatchLids.isEmpty);
	// if no slots/requests passed or RORO slot requests in then this must
	// be a user defined job
	isUserJob := self.allSlotRequests.isEmpty and self.allRORORequests.isEmpty;
	isDeckJob :=	not self.allRORORequests.isEmpty;
	if isHatchLidJob then
		if self.myBay = null then
			tmpHatch := self.allHatchLids.first;
			if tmpHatch &lt;&gt; null then
				self.myBay := tmpHatch.allBays.first;
			endif;
		endif;
	elseif isUserJob then
		if self.myBay =  null then
			self.myBay := self.myVoyage.myCellularVoyageStructure.allBayVoyagesById.first;
		endif;
	endif;
	
	pxyVoyageJob := self.myProxyJob;


	if pxyVoyageJob = null then
	
		if isHatchLidJob or isUserJob then
			if self.myBay = null then
				app.raiseCMException(ErrNoBayForHatchLidJob, null, null);
				return;
			endif;

			create pxyVoyageJob as CM_VoyageHatchLidJob transient;
			theJobTypeNumber := JOB_TYPE_USER;
			if global.isValidObject( self.myJobType) then// AKB2007JULY - DCT EXCEPTION
				estMins := self.myJobType.estimatedTimeToCompleteMins;// AKB2007JULY - DCT EXCEPTION
			else
				estMins := 0;
			endif;
			
			pxyVoyageJob.setProxyVoyageJob(self.craneID, self.id, null, self.remarks, false, 
										theJobTypeNumber, self.myJobType, estMins, null, null,null);// AKB2007JULY - DCT EXCEPTION
		else
			if isDeckJob then
				create pxyVoyageJob as CM_VoyageDeckJob transient;
			else
				create pxyVoyageJob transient;
			endif;
			if isUserJob then
				theJobTypeNumber := JOB_TYPE_USER;
			elseif isSOB then
				theJobTypeNumber := JOB_TYPE_SOB;
			elseif self.isDischarge then
				theJobTypeNumber := JOB_TYPE_DISCHARGE;
			else
				theJobTypeNumber := JOB_TYPE_LOAD;
			endif;
		endif;
		pxyVoyageJob.setProxy(self.id, theJobTypeNumber); 
		pxyVoyageJob.setProxyVoyage(self.myVoyage);
		pxyVoyageJob.setProxyVoyageReturnJob(self.isExportReturn, self.isChargable);
		
		self.myProxyJob := pxyVoyageJob;
	else
		// this is an edit but we still update the type
		// according to what the passed in data is
		if isUserJob then
			theJobTypeNumber := JOB_TYPE_USER;
		elseif isSOB then
			theJobTypeNumber := JOB_TYPE_SOB;
		elseif self.isDischarge then
			theJobTypeNumber := JOB_TYPE_DISCHARGE;
		else
			theJobTypeNumber := JOB_TYPE_LOAD;
		endif;
		pxyVoyageJob.setProxy(pxyVoyageJob.id, theJobTypeNumber); 
		pxyVoyageJob.setProxyVoyageReturnJob(self.isExportReturn, self.isChargable);		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSlotRequests" id="fd884e7c-1e0f-4d4f-910d-5d2b718103a9">
        <source>setSlotRequests(_isSOB : Boolean io) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	tmpSlot		: CM_SlotController;
	tmpSlotRequest	: CM_SlotRequest;
	slotId			: String;
	tmpDescr,
	errSlotStr		: String;
	slotsInError : CM_SlotControllerSet;
begin

	create slotsInError transient;
	
	foreach tmpSlot in self.allSlotControllers do
		if self.isDischarge then
			tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
			
			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.myJob &lt;&gt; null and self.myProxyJob &lt;&gt; null and tmpSlotRequest.myJob.id &lt;&gt; self.myProxyJob.id then // PAR 34649
				tmpSlotRequest := null; // PAR 34649
			endif;
			
			
			if tmpSlotRequest = null // PAR 34649 is manually adding in the load SOB in a LOLO discharge job, add in the load CC
			and self.myProxyJob &lt;&gt; null and self.myProxyJob.jobType = JOB_TYPE_SOB then  // PAR 34649 - NOTE the proxy has no requests
				tmpSlotRequest := tmpSlot.mySlotRequestLoad; // PAR 34649
			endif; // PAR 34649
			
			if tmpSlotRequest &lt;&gt; null then
				if tmpSlotRequest.isSOB then
					_isSOB := true;
				endif;
				self.allSlotRequests.addNoDuplicates(tmpSlotRequest, false); // PAR 27043
			else
				slotsInError.add(tmpSlot);
				continue;
			endif;
		else
			tmpSlotRequest := tmpSlot.mySlotRequestLoad;
			if tmpSlotRequest &lt;&gt; null then
			/* PAR 33860  DO NOT PUT LOAD SOB CC in LOAD JOB. Load SoB CC goes in the discharge job.
				if tmpSlotRequest.isSOB then
					_isSOB := true;
				endif;
				*/
				if tmpSlotRequest.isSOB then
					continue;
				endif;
				self.allSlotRequests.addNoDuplicates(tmpSlotRequest, false); // PAR 27043 
			else
				slotsInError.add(tmpSlot);
				continue;
			endif;
		endif;
		
		if tmpSlotRequest &lt;&gt; null and
		   self.jobNumLinkedLoad &lt;&gt; null then
			if tmpSlotRequest.isLinked and tmpSlotRequest.isDischarge then
			else
				// The request for slot %1 is not linked.  You cannot create a linked job for it.
				app.raiseCMException1(ErrReqNotLinkedCannotCreateJob, tmpSlotRequest.mySlotController.getID, null, null);
			endif;
		endif;
	endforeach;
	
	if (not slotsInError.isEmpty) then
		foreach tmpSlot in slotsInError do
			slotId := tmpSlot.getStowageId(null);	// 28936 Mar 2012 include bay number in message, was using .ident
			if errSlotStr = null then
				errSlotStr := slotId;
			else
				errSlotStr := errSlotStr &amp; ', ' &amp; slotId;
			endif;
		endforeach;
		if self.isDischarge then
			tmpDescr := app.getErrorString(Discharge);
		else
			tmpDescr := app.getErrorString(Load);
		endif;
		app.raiseCMException2(SlotsNotMarkedUpDishLoadInJob, errSlotStr, tmpDescr, null, null);
		return false;
	endif;

	return true;
epilog
	delete slotsInError;
end;</source>
        <access>protected</access>
        <Parameter name="_isSOB" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSlotAndHatchEditions" id="b01f2441-24aa-4d52-a658-4638eec1614c">
        <source>validateSlotAndHatchEditions();
// ---------------------------------------------------------------------------
// Created:     04 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSlot		: CM_SlotController;
	tmpHatch	: CM_HatchLid;
begin

	foreach tmpSlot in self.allSlotControllers do
		self.allObjectEditions.validateEditionForObject(tmpSlot, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.ident);
	endforeach;

	foreach tmpHatch in self.allHatchLids do
		self.allObjectEditions.validateEditionForObject(tmpHatch, app.getErrorString(Hatch_Lid));
	endforeach;

end;</source>
    </JadeMethod>
</Class>
