    <JadeMethod name="createProxiesForEdit" id="a2332fa9-4bb4-45a0-87aa-e9b9f28eaf35">
        <source>createProxiesForEdit() : CM_ShiftEntity protected;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	shift : CM_ShiftEntity;
begin
	shift := self.tblShift.accessRow(self.tblShift.row).itemObject.CM_ShiftEntity;
	return app.createUpdateProxy(shift).CM_ShiftEntity;
end;
</source>
