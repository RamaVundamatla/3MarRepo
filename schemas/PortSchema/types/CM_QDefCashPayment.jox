	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefConsignMethod persistent;
	tmpProp.CM_QRefConsignMethod.type := CONSIGNEE;
	tmpProp.set('Cargo Consignee', CM_CashPayment::getTrackedItemConsignee.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	//consignor
	create tmpProp as CM_QRefConsignMethod persistent;
	tmpProp.CM_QRefConsignMethod.type := CONSIGNOR;
	tmpProp.set('Cargo Consignor', CM_CashPayment::getTrackedItemConsignor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
