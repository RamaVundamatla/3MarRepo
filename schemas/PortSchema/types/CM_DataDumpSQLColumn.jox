    </JadeMethod>
    <JadeMethod name="changeSQLDataType" id="81bd6f1e-7770-4b09-839f-af9c511a855c">
        <updating/>
        <source>changeSQLDataType(_sqlType:String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2010	#cnwdz2	 24557

*/

vars

begin
	self.myDataDumpSQLDataType := app.myRoot.allDataDumpSQLDataTypes[_sqlType.toUpper()];
epilog

end;</source>
        <Parameter name="_sqlType" type="String"/>
    </JadeMethod>
    <JadeMethod name="isEqualToSQLDataType" id="25f5d3ac-393e-4ea3-832d-958050568045">
        <updating/>
        <source>isEqualToSQLDataType(_sqlType:String):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2010	#cnwdz2	 24557

*/

vars

begin
	return self.myDataDumpSQLDataType = app.myRoot.allDataDumpSQLDataTypes[_sqlType.toUpper()];
epilog

end;</source>
        <Parameter name="_sqlType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8660149f-6dc7-45c8-9dc2-376b98107b66">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 conkc1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyExtractSQLColumn : CM_DataDumpSQLColumn;
	completedOK		: Boolean;
	
begin
	pxyExtractSQLColumn := inheritMethod;
	
	pxyExtractSQLColumn.myDataDumpFeature      := self.myDataDumpFeature;
	pxyExtractSQLColumn.myDataDumpSQLDataType  := self.myDataDumpSQLDataType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyExtractSQLColumn;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyExtractSQLColumn;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
