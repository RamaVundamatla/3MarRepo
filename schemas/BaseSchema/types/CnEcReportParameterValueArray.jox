    <DbClassMap file="baserepq"/>
    <JadeMethod name="addParameterValue" id="15d2b91a-1573-4b6f-aeb6-555575fdb0c6">
        <lockReceiver/>
        <updating/>
        <source>addParameterValue(	pQueueEntry:CnEcReportQueueEntry;
					pReportParameter:CnEcReportParameter;
					pObjectValue:Object;
					pStringValue:String) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Purpose:		Creates a report parameter value and adds it to the receiver.
//
// Parameters:	pQueueEntry - The queue entry object.
//				pReportParameter - The owning report parameter object.
//				pObjectValue - he obect value.
//				pStringValue - The string value.
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterValue	: CnEcReportParameterValue;
	
begin
	create parameterValue transient;
	parameterValue.initializeMe(pQueueEntry, pReportParameter, pObjectValue, pStringValue);
	self.add(parameterValue);
end;</source>
        <Parameter name="pQueueEntry" type="CnEcReportQueueEntry"/>
        <Parameter name="pReportParameter" type="CnEcReportParameter"/>
        <Parameter name="pObjectValue" type="Object"/>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
