    <JadeMethod name="addChild" id="7ba88f86-1f7b-48ff-a3b6-a737e9a4fb32">
        <updating/>
        <source>addChild(_child : CM_MenuEntity; _pos : Integer) updating;

vars

begin

	if _pos = 0 or _pos &gt; self.allChildren.size then
		self.allChildren.add(_child);
	elseif _pos &lt;= self.allChildren.size and
	   self.allChildren[_pos] &lt;&gt; null then
		self.allChildren.insert(_pos, _child);
	else
		self.allChildren.atPut(_pos, _child);
	endif;

end;</source>
        <Parameter name="_child" type="CM_MenuEntity"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuFromMenu" id="caa5e5e9-51dc-4278-bcfb-91c0d358abe9">
        <source>addToUserMenuFromMenu(_menuRoot : CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneFromSource" id="7b21a6a0-75fd-4ff3-949c-43c04e4d8027">
        <updating/>
        <source>cloneFromSource(_parent : CM_MenuEntity; 
				_source : SelfType; 
				_terminal : CM_Terminal;
				_targetMenuRoot : CM_MenuRoot input;
				_user : CM_User;
				_clearFirst : Boolean;
				_deleteSet : CM_MenuEntitySet input) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newEntity,
	childEntity,
	sourceEntity	: CM_MenuEntity;
	menuItem		: CM_MenuItem;
	dtlNav			: CM_MenuDtlNav;
begin
	//re-implement in subclasses to loop throught parents too
	self.index 						:= _source.index;
	self.pictureStringButton 		:= _source.pictureStringButton;
	self.pictureStringButtonDown 	:= _source.pictureStringButtonDown;
	self.pictureStringIcon 			:= _source.pictureStringIcon;
	self.myParent 					:= _parent;
	
	//if _deleteSet.includes(self) then
	//	_deleteSet.remove(self);
	//endif;
	
	foreach sourceEntity in _source.allChildren do : sourceLoop
		/*CNWTH2 added 12/07/2004 all this is redundant - it was trying to work out permissions
		//while building - this was being handled in a subsiquent call (CM_UserTerminal.checkUserMenuAgainstPermissions)
		if sourceEntity.isKindOf(CM_MenuUserItem) then
			menuItem := sourceEntity.CM_MenuUserItem.myMenuItem;
			if menuItem &lt;&gt; null and menuItem.isKindOf(CM_MenuDtlNav) then
				dtlNav := menuItem.CM_MenuDtlNav;
				if _user &lt;&gt; null then
					if (not _user.canDo(_terminal, dtlNav.constantValue)) then
						continue;
					endif;
					if dtlNav.childValue &gt; 0 and
					   (not _user.canDo(_terminal, dtlNav.childValue)) then
					   	continue;
					endif;
				endif;
			endif;
		endif;
		
		if (not _clearFirst) then //loop through and see if you've already got this entity
			foreach childEntity in self.allChildren do
				if childEntity.isKindOf(CM_MenuUserItem) and childEntity.CM_MenuUserItem.myMenuItem = menuItem then
					continue sourceLoop;
				endif;
			endforeach;
		endif;
		*/
		create newEntity as sourceEntity.class persistent;
		newEntity.cloneFromSource(self, sourceEntity, _terminal, _targetMenuRoot, _user, _clearFirst, _deleteSet);		
	
	endforeach;

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_source" type="SelfType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_targetMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
