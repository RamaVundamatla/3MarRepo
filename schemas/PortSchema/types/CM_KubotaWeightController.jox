    <JadeMethod name="getWeight" id="6cda45ff-13fd-4087-b693-3935c7e31099">
        <source>getWeight(_binResponse: Binary): Decimal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlger1	Initial creation

*/

constants

	PlusString : String = "+";
	DotKgString : String = ".kg";
	ReadingsNeeded : Integer = 4;
vars

	rawString : String;
	plusPos : Integer;
	dotKgPos : Integer;
	readingArray : IntegerArray;
	weightString : String;
	weight : Integer;
	index : Integer;
	finalWeight : Integer;
	count : Integer;

begin
	/*
	
		data expected in format 
		
		33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;
	
		
		read the data beween the &lt;2&gt; and &lt;3&gt; to get the kg amount between the + and .kg
		
		read until you get 5 weight readings the same and reutrn it
		
	*/
	
	rawString := _binResponse.String;
	
	create readingArray transient;	//will store the last 5 readings in this array.
	
	dotKgPos := 1;	// to set the initial start point
	while true do
		count := count + 1;	// simple loop count
		index := index + 1;	// index in the readings array to store the next reading in the string
		if index = ReadingsNeeded + 1  then	// set the index counter back to teh first one to overwrite the oldest reading 
			index := 1;
		endif;
		
		//find the position of the next '+', starting at the last know end position
		plusPos := rawString.pos( PlusString, dotKgPos );
		if plusPos &lt; 1 then
			//didn't find a '+'
			break;
		else
			plusPos := plusPos + 1;
		endif;
		if rawString.length &gt; plusPos then
			//find the next '.kg' starting from the latest '+' position.
			dotKgPos := rawString.pos( DotKgString, plusPos );
			if dotKgPos &gt; 0 then
				//get the reading string from between these two positions
				weightString := rawString[ plusPos : dotKgPos - plusPos].trimBlanks;
				if not weightString.isInteger then
					//the reading value found isn't an integer bail
					self.diagnosticLog( "Weight portion is not an Integer '" &amp; weightString &amp; "' - Invalid format.");
					continue;
				endif;
				weight := weightString.Integer;
				readingArray[index] := weight;
				if readingArray.size &lt; ReadingsNeeded  then
					//need at least 5 readings before we start checking
					continue;
				endif;
				if readingArray.allValuesIdentical() then
					//the last 5 readings are all the same, we have done enough.
					finalWeight := readingArray.first();
					return finalWeight;
				endif;
			else
				//didn't find another '.kg' position
				break;
			endif;
		else
			//'+' position is the last character, no point in trying any more 
			break;
		endif;
	endwhile;
	
	self.diagnosticLog(  count.String &amp; " readings checked, failed to find " &amp;  ReadingsNeeded.String &amp; " consecutive readings of the same value, please try again.");

epilog

	delete readingArray;

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
