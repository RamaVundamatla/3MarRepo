    <JadeMethod name="doBrowseForFile" id="ac3199f8-c985-4e9d-ace6-aee1f99461d7">
        <source>doBrowseForFile(_folderTextBox : TextBox input; _onServer : Boolean);
/*

Purpose:			Allows you to select a file from a file browser

Parameters:			_folderTextBox:	The textbox we are going to populate with the path once a file is selected
					_onServer:		Whether to look for the file on the server

Return Value:		

Date		Who		Reason
05 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	dlg	: CMDFileOpen;
	
begin
	create dlg transient;
	if not dlg.open() = 0 then
		// Exit as user did not select a file
		return;
	endif;
	
	_folderTextBox.text := dlg.fileName;
	_folderTextBox.tag := dlg.fileTitle;
	
epilog
	delete dlg;

end;</source>
        <Parameter name="_folderTextBox" type="TextBox" usage="input"/>
        <Parameter name="_onServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBrowseForFolder" id="908e02c2-03b3-41ea-8004-5e395ce2e893">
        <source>doBrowseForFolder(_folderTextBox : TextBox input; _onServer : Boolean);
/*

Purpose:			Allows you to select a folder from a folder browser

Parameters:			_folderTextBox:	The textbox we are going to populate with the path once a folder is selected
					_onServer:		Whether to look for the folder on the server

Return Value:		

Date		Who		Reason
05 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	ff			: FileFolder;
	newFolder	: String;
	
begin
	create ff transient;
	if _onServer then
		newFolder := ff.browseForServerFolder("Choose a server folder", _folderTextBox.text);
	else
		newFolder := ff.browseForFolder("Choose a folder", _folderTextBox.text);
	endif;

	if newFolder &lt;&gt; null then
		_folderTextBox.text := newFolder;
	endif;
	
epilog
	delete ff;

end;</source>
        <Parameter name="_folderTextBox" type="TextBox" usage="input"/>
        <Parameter name="_onServer" type="Boolean"/>
    </JadeMethod>
</GUIClass>
