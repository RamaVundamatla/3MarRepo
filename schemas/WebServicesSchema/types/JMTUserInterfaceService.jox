    <JadeWebServicesMethod name="getSelectorQueries" id="338584b1-838e-4d64-9b2e-ddae9c9575b0">
        <source>getSelectorQueries() : WS_SelectorQueriesResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
//
vars
	response : WS_SelectorQueriesResponse;
	completedOK : Boolean;
	reportAgent : WebService_ReportAgent;
	queries : CM_MenuEntityArray;
	query : CM_MenuUserQuery;
	passport : CM_Passport;
	wsQuery : WS_SelectorQuery;
	dynaDict : DynaDictionary;
	obj : Object;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	passport := app.myPassport;
	if passport.myTerminal = null then
		completedOK := true;
		return response;
	endif;
	
	create reportAgent transient;
	create queries transient;
	create dynaDict transient;
	dynaDict.setMembership(CM_MenuUserQuery);
	dynaDict.addMemberKey( CM_MenuUserQuery::heading.name, false, true );
	dynaDict.endKeys( true );
	
	reportAgent.getSelectorQueries(queries);
	queries.copy(dynaDict);
	
	foreach obj in dynaDict do
		query := obj.CM_MenuUserQuery;
		create wsQuery transient;
		wsQuery.setProxyFromObject(query);
		response.allSelectorQueries.add(wsQuery);
	endforeach;
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	delete reportAgent;
	delete queries;
	delete dynaDict;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_SelectorQueriesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getShippingLines" id="d2eb1611-7fca-444c-af8c-b613825b3739">
        <usesRPC>default</usesRPC>
        <source>getShippingLines() : WS_ShippingLinesResponse webService;

/*

Purpose:			Get all the valid Shipping Lines for the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_ShippingLinesResponse;
	completedOK		: Boolean;
	
	shippingLine	: CM_ShippingLine;
	proxyShippingLine	: WS_ShippingLine;
	failedDAC  		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Populate response - cloned from CMUI_ComboshippingLIne
	foreach shippingLine in app.myRoot.allShippingLines discreteLock do
		if shippingLine.isNotAvailableForEntry then
			continue;
		endif;
		
		if not shippingLine.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		create proxyShippingLine transient;
		proxyShippingLine.setProxyFromObject(shippingLine);
		response.allShippingLines.add(proxyShippingLine);
		
	endforeach;
	
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the valid Shipping Lines for the current user.</text>
        <wsdlName>getShippingLines</wsdlName>
        <ReturnType type="WS_ShippingLinesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSiteSate" id="032e5cab-1baf-44b8-8df4-7b8825436222">
        <source>getSiteSate() : WS_SiteStateResponse webService;


/*

Purpose:			Get cargo sites and states (e.g OnSite, OffSite).

Parameters:			

Return Value:		


Date		Who		Reason
31 Aug 2010	#cnwdz2	 par25524 - Development of new RIA Web Service application
16 Dec 2019	jlgka1	TFS 48024 - SNO - Offsite import container in Mobile App (Use the TI_STATE instead of the TI_SITE)
*/

vars
	response		: WS_SiteStateResponse;
	completedOK		: Boolean;
	siteState		: WS_SiteState;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//TFS 48024 --&gt;
	create siteState transient;
	siteState.setDetails(TI_STATE_NORMAL);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_OFFSITE);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_ONSHIP);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_OFFLOADED);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_NOTIFIED);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_DELETED);
	response.allSiteStates.add(siteState);
	
	if app.isInterTerminalTransferEnabled() then 
		create siteState transient;
		siteState.setDetails(TI_STATE_TRANSFER_TO);
		response.allSiteStates.add(siteState);
		
		create siteState transient;
		siteState.setDetails(TI_STATE_TRANSFER_FROM);
		response.allSiteStates.add(siteState);
	endif;
	
	/*create siteState transient;
	siteState.setDetailsFromDesc(TI_SITE_ONSITE_str);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetailsFromDesc(TI_SITE_ONSHIP_str);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetailsFromDesc(TI_SITE_OFFSITE_str);
	response.allSiteStates.add(siteState);

	create siteState transient;
	siteState.setDetailsFromDesc(TI_SITE_TBA_str);
	response.allSiteStates.add(siteState);
	
	//cnwmc5 - 1 Dec 2015 - PAR 36829
	create siteState transient;
	siteState.setDetailsFromDesc(TI_SITE_UNDEFINED_str);
	response.allSiteStates.add(siteState);*/
	//TFS 48024 &lt;--
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get cargo sites and states (e.g OnSite, OffSite).</text>
        <wsdlName>getSiteSate</wsdlName>
        <ReturnType type="WS_SiteStateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSitesForReports" id="f055e28e-e9c5-44b6-850b-3261a97d408c">
        <source>getSitesForReports(): WS_SiteStateResponse webService;
/*

Purpose:			
	******Only should be used by report Paramters******
	This method will be used to return the list of sites for report paramters.
	the reason why we created this method we did a change before and changed getSiteState() method to return states instead of sites.
	And now there is no way to search by sites because they allways using the state code to search instead 
	
Parameters:			

Return Value:		

Date		Who		Reason
13 Jan 2023 navma1	Bug 55319: AAT - Off site cargo not being included in reports from the web portal

*/

vars
	response		: WS_SiteStateResponse;
