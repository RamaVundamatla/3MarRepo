    <JadeMethod name="setComboValues" id="f5ffc2b0-6ecd-4e60-9a06-fa627d9a8546">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:	23 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
// 27 Oct 2016	cnwrs1	problem with test data.
vars
	debtor		: CM_Debtor;
	debtorType	: CM_DebtorType;
	debtorTypeKey : String;
	queryProp	: CM_QRefDebtorType;
	listItem	: Integer;
	
begin
	_combo.clear();
	
	//Fill Combobox
	debtorTypeKey := self.propertyName[6:end];
	debtorType := app.myRoot.allDebtorTypes[debtorTypeKey];
	if debtorType &lt;&gt; null then
		foreach debtor in debtorType.allDebtors do
			listItem := _combo.addItem(debtor.name);
			_combo.itemObject[listItem] := debtor;
		endforeach;

		//Highlight selected
		if _queryOperator &lt;&gt; null then
			if _queryOperator.isKindOf(CM_QReferenceLookup) then
				if _queryOperator.CM_QReferenceLookup.mySelectionValue.isKindOf(CM_Debtor) then
					debtor := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_Debtor;
					if debtorType.allDebtors.includes(debtor) then
						_combo.listObject := _queryOperator.CM_QReferenceLookup.mySelectionValue;
					endif;
				endif;
			endif;
		endif;

	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b6bf8311-85ad-4848-a62c-1cfe1beed0ea">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:	28 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - fix debtor type display for null

*/

vars
	
begin
	if _value &lt;&gt; null then
		return _value.CM_Debtor.name;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="cbbe6fdf-8075-466f-89de-7628910100ab">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:	29 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing

*/

vars
	returnVal		: CM_Debtor;
	
begin
	if _value &lt;&gt; null and _value.isKindOf(CM_Debtor) then
		returnVal := _value.CM_Debtor;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="09c45483-7be5-4822-b4e4-7dcebc73e649">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	debtor : CM_Debtor;

begin
	if _value.isKindOf(CM_Debtor) then
		return _value.CM_Debtor.getOidString;
	elseif _value.isKindOf(String) then
		debtor := _value.String.asOid.CM_Debtor;
		if debtor &lt;&gt; null then
			return debtor;
		endif;
		
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
