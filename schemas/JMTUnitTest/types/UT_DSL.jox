    <JadeMethod name="addAutoSchedule" id="27a1e3b9-7a8a-46b4-945d-ce52575b3478">
        <source>addAutoSchedule(_autoSchedule : String; _scheduleTS : TimeStamp; _recurValue : Integer) :CM_AutoSchedule;
/*

Purpose:			

/* Changes

Date		Name	TFS#	Description
============================================================================
14/04/2014	cnwma1			Initial creation
16/04/2019	jlgka1	43863	Added Recurring value.
============================================================================*/

vars
	pxyAutoSched  : CM_AutoSchedule;
	realAutoSched : CM_AutoSchedule;
begin

	deleteAutoSchedule(_autoSchedule, _scheduleTS);
		
	//time := "11:30".Time;
	create pxyAutoSched transient;
	pxyAutoSched.setForDate(_autoSchedule,					//Description
							_scheduleTS.date.day.String,	// Day
							_scheduleTS.time,				//Time
							_recurValue);	      			// jlgka1 TFS 43863
							
	if self.opts.includesKey("autoTasksArray") then
		self.opts.obj("autoTasksArray").CM_AutoTaskArray.copy(pxyAutoSched.allAutoTasks);	
	endif;	
							
	app.myTrxCA.trxCreateAutoSchedule(pxyAutoSched,realAutoSched,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realAutoSched;
	
epilog
	delete pxyAutoSched;

end;</source>
        <Parameter name="_autoSchedule" type="String"/>
        <Parameter name="_scheduleTS" type="TimeStamp"/>
        <Parameter name="_recurValue" type="Integer"/>
        <ReturnType type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="addAutoTask" id="62acb32e-1b33-4ed6-9d1a-1ba5244f705d">
        <source>addAutoTask(_autoTaskClassName, _autoDescription : String; _user : CM_User; _terminal : CM_Terminal) : CM_AutoTask;

/*

Purpose:		Create / Add an Auto Task

Date			Who		Reason
10/02/2016		cnwmh5	Initial creation

*/

vars

	pxyAutoTask					: CM_AutoTask;
	autoTask					: CM_AutoTask;
	klass						: Class;
	prop						: Property;
	assoc						: CM_Association;
	obj							: Object;
	
	
	properties					: PropertyColl;
	
	iter						: Iterator;
	iterAssoc					: Iterator;
	
	optsKey						: String;

begin

	self.deleteAutoTask(_autoDescription, _autoTaskClassName);

	klass := rootSchema.getSchema("PortSchema").getClass(_autoTaskClassName);
	self.assertNotNull(klass);
	
	create pxyAutoTask as klass transient;
	
	// set the default values for the auto task
	pxyAutoTask.setValueForRow(ETRow_BgpAutoDescription,_autoDescription);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoUser, _user);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoTerminals, _terminal);
	
	// grab the properties for the auto task and set accordingly	
	properties := pxyAutoTask.class.allPropertiesUpTo(klass);
	
	iter := properties.createIterator;
	while iter.next(prop) do
		delete iterAssoc;
		iterAssoc := self.opts.createIterator;
		self.opts.startKeyGeq(prop.name.toUpper(), iterAssoc);
		while iterAssoc.next(assoc) do
			self.opts.getIteratorKeys(optsKey, iterAssoc);
			if optsKey = prop.name.toUpper() then
				if prop.type.inheritsFrom(Collection) then
					assoc.getValue().Collection.copy(pxyAutoTask.getPropertyValue(prop.name).Collection);
				else
					pxyAutoTask.setPropertyValue(prop.name, assoc.getValue());
				endif;
				break;
			endif;
			self.opts.removeAssoc(optsKey);
		endwhile;
	endwhile;
	
	// create the auto task
	app.myTrxCA.trxCreateAutoTask(pxyAutoTask, autoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return autoTask;
	
epilog

	delete pxyAutoTask;
	delete properties;
	delete iterAssoc;
	delete iter;

end;</source>
        <Parameter name="_autoTaskClassName" type="String"/>
        <Parameter name="_autoDescription" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="addAvailabilityGrade" id="1ade5eac-ddb8-4ece-a597-8ed8e64cb3c7">
        <source>addAvailabilityGrade(_availGradeId : Integer; _availGradeDesc : String; _suitableForRelease, _notAvailable : Boolean) : CM_MTGrade;

/*

Purpose:		Add a commodity	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	pxyAvailGrade					: CM_MTGrade;
	availGrade,
	availGradeToDelete 				: CM_MTGrade;
		
begin

	// delete the existing availability grade
	availGradeToDelete := app.myRoot.allAvailabilityGrades[_availGradeId];
	self.deleteAvailabilityGrade(availGradeToDelete);

	create pxyAvailGrade transient;
	
	pxyAvailGrade.setProxy(_availGradeId,			// Id / Code
						   _availGradeDesc,			// Description
						   _suitableForRelease,		// Sutiable for Release
						   _notAvailable,			// not available
						   0,						// colour
						    null,					// Allowed Release terminal
						    null);					// allowed edit sub terminal
						  
	app.myTrxCA.trxCreateAvailabilityGrade(pxyAvailGrade, availGrade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return availGrade;

epilog
	delete pxyAvailGrade;
end;</source>
        <Parameter name="_availGradeId" type="Integer"/>
        <Parameter name="_availGradeDesc" type="String"/>
        <Parameter name="_suitableForRelease" type="Boolean"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="addBGPManager" id="a9ae0264-5ee8-4e31-b1de-5ca39f96134d">
        <source>addBGPManager(_bgpName : String) : BGP_Manager;

/*

Purpose:		Create a BGP Manager

Date			Who		Reason
18/02/2015		cnwmh5	Initial creation

*/

vars
	
	cmif 				: CMIF_BGPManagerChildren;
	manager				: BGP_Manager;
	
	isServer			: Boolean;
	
begin

	self.deleteBGPManager(_bgpName);


	create cmif transient;
	
	if opts.includesKey("IsServer") then
		isServer := self.opts.bool("IsServer");
	endif;	
	
	cmif.isServer 				:= isServer;					// Server
	cmif.managerName			:= _bgpName;					// Manager Name
	cmif.numberOfRemotes		:= 1;							// No Generic
	
	/*
	_cmif.numberOfRemotes		:= remote;						
	_cmif.numberOfReports		:= report;						// No. Reports
	_cmif.numberOfDirectories	:= directory;					// No. Directories
	_cmif.numberOfTcpIpServers	:= tcpServer;					// No. TCP/IP Servers
	_cmif.isAutoTimer			:= timer;						// Auto Timer
	_cmif.numberOfTcpIpClients	:= tcpClient;					// No. TCP/IP Clients
	_cmif.isLockKeeper			:= isLockKeeper;				// Lock Keeper
	_cmif.isChangeTracker		:= isChangeTracker;				// Change Tracker
	_cmif.isBackupJournal 		:= isBackupJournal;				// Backup Journal
	_cmif.machineNameSpecific	:= machineNameSpecific;			// Machine Name
	_cmif.isAutoWarning			:= isAutoWarning;				// Auto Warning
	_cmif.isVSBookGen			:= isVSBookGen;					// Slot Booking Generator
	*/
	
	app.myTrxCA.trxCreateBGPManager(manager, cmif, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return manager;
	
epilog

	delete cmif;

end;</source>
        <Parameter name="_bgpName" type="String"/>
        <ReturnType type="BGP_Manager"/>
    </JadeMethod>
    <JadeMethod name="addBOL" id="1790a78e-fd48-4335-9c69-3b08242edacf">
        <source>addBOL(_bolNumber : String; _voyage : CM_Voyage; _operator : CM_Operator; _notifyParty : String; _terminal : CM_Terminal): CM_BOL;
//08 January 2010	cnwml2
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL

vars
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
begin

	// get the subterminal
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);								// 29/04/2014 cnwmh5	
		self.assertNotNull(subTerminal);
	endif;

	create pxyBOL transient;	
	pxyBOL.setProxy(_bolNumber, _voyage, _operator, _notifyParty, 5, BOLType_GeneralBillOfLading, _terminal, subTerminal, null, null, null, false, null, null, null,
																																							null); //13/07/2022 navgm20 Tfs 54095
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "APPL", "colour", "mark",30, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realBOL;
epilog
	delete pxyBOL;
end;
</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_notifyParty" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="addBOLInForCars" id="1e1e8c2b-a99c-4ccc-8f77-04e114dbc360">
        <source>addBOLInForCars(_bolNumber : String; _voyage : CM_Voyage; _operator : CM_Operator; _notifyParty : String; _terminal : CM_Terminal): CM_BOLIn;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2020	jlgdap1		Initial creation TFS 49328 CPL Unable to load Custom Stops for Motor Vehicles
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
vars
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
	
begin

	// get the subterminal
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);
		self.assertNotNull(subTerminal);
	endif;

	create pxyBOL transient;	
	pxyBOL.setProxy(_bolNumber, _voyage, _operator, _notifyParty, 1, BOLType_GeneralBillOfLading, _terminal, subTerminal, null, null, null, false, null, null, null,
																																								null); //13/07/2022 navgm20 Tfs 54095
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Car, "USED", "RED", null, 6, null, 6000, null, null, null, null, null, "6 Cars");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realBOL.CM_BOLIn;
	
epilog
	delete pxyBOL;
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_notifyParty" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="addBOLItem" id="06f65873-cb98-47e2-9fa6-38049be2a810">
        <source>addBOLItem(_bol: CM_BOL input): CM_BOL;
//06 July 2009	cnwdw1	
//
vars
	pxyBOL, newBOL: CM_BOL;
	pxyBOLItem: CM_BOLDtl;
begin
	create pxyBOLItem transient;		
	pxyBOLItem.setProxy(_bol, TI_CargoType_Container, "APPL", "colour", "mark", 5, 30, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");

	pxyBOL := app.createUpdateProxy(_bol).CM_BOL;

	app.myTrxCA.trxCreateBOL(pxyBOL, newBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return _bol;
epilog
	delete pxyBOLItem;
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="addBOLStop" id="03d0e007-4e13-434c-8bb0-776a099e9e16">
        <source>addBOLStop(_bol: CM_BOLIn input; _stopTable: CM_StopsTable);
// 23 February 2015	cnwgb1	
// Add a stop to a BOL
vars
	tiSet: CM_TISet;
	stopArr: IntegerArray;
begin
	app.myTrxCA.trxCreateBOLStop( _bol, _stopTable, app.myPassport);
	checkTrxResult();
epilog
end;</source>
        <Parameter name="_bol" type="CM_BOLIn" usage="input"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="addBerth" id="2a75c62e-5992-4c7b-aaa0-0af69cffe0fc">
        <source>addBerth(_berthId, _berthDesc : String; _harbour : HMS_Harbour; _startPosition, _length : Integer; _minDepth : Decimal; _noMarineServices : Boolean; _wharf : HMS_Wharf) : HMS_Berth;

/*

Purpose:		Add Berth	

Date			Who		Reason
20/12/2011		cnwmh5	Initial creation
20 Jan 2025 navbs1 	Task MTN-33741: MTN - 22.0.24.12 - Unit Tests Review - [1] 

*/

vars

	pxyBerth			: HMS_Berth;
	berth				: HMS_Berth;

begin

	self.deleteBerth(_berthId, _harbour);
	
	create pxyBerth transient;
	pxyBerth.setProxy(_harbour,						// Harbour
					  0);							// Default cargo operation
					  
					  
	pxyBerth.setPropertyValue("code", _berthId);
	pxyBerth.setPropertyValue("description", _berthDesc);
	pxyBerth.setStartPositionLength(_startPosition, _length);
	pxyBerth.setPropertyValue("minimumDepth", _minDepth);
	pxyBerth.setPropertyValue("noMarineServices", _noMarineServices);
	pxyBerth.setPropertyValue("myWharf", _wharf);
	if self.opts.includesKey("DefaultCargoOperation") then
		pxyBerth.setPropertyValue("defaultCargoOperation", self.opts.int("DefaultCargoOperation"));
	endif;
	
	//05 Jun 2019	NDL	TFS 44773
	if self.opts.includesKey(HMS_Berth::requiresLengthOfTime.name) then
		pxyBerth.setPropertyValue(HMS_Berth::requiresLengthOfTime.name, self.opts.bool(HMS_Berth::requiresLengthOfTime.name));
	endif;
	

	app.myTrxCA.trxCreateBerth(pxyBerth, berth, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	if self.opts.includesKey("HarbourRegion") then
		beginTransaction;
		berth.setPropertyValue("myHarbourRegion", app.myRoot.allHMSHarbourRegions[self.opts.str("HarbourRegion")]);
		commitTransaction;
	endif;
	
	if self.opts.includesKey("ExternalReference1") then							//20.01.2025 navbs1 #33741
		beginTransaction;
		berth.setExternalReference1(self.opts.str("ExternalReference1"));
		commitTransaction;
	endif;
	
	return berth;
	
epilog
	
	delete pxyBerth;

end;</source>
        <Parameter name="_berthId" type="String"/>
        <Parameter name="_berthDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_startPosition" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_minDepth" type="Decimal"/>
        <Parameter name="_noMarineServices" type="Boolean"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="addBlockStack" id="7d8b64a1-dbcc-45b4-aaae-15e08796f707">
        <source>addBlockStack(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
//01 September 2008	cnwdw1	 
//30 Oct 2025 navhl20 Story MTN-36263: AAT | Auto Releasing from Release Trans Area SHOULD not allow auto release if cargo has a Stop but it does
vars
	
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	type			: Integer;	//21 May 2019	NDL	TFS 44774
	actAsRel		: Boolean;
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	
	//21 May 2019	NDL	TFS 44774
	type := TA_TYPE_BLOCK_STACK;	
	if self.opts.includesKey("TA_Type") then
		type := self.opts.int("TA_Type");
	endif;
	
	actAsRel := true;													//30.10.2025 navhl20 #36263
	if self.opts.includesKey("ActAsRelPoint") then						//30.10.2025 navhl20 #36263
		actAsRel := self.opts.bool("ActAsRelPoint");
	endif;
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					"",
					type, 
					_max,
					5,
					5,
					false,
					"", 
					_max,
					actAsRel, 											//30.10.2025 navhl20 #36263
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	if self.opts.includesKey("Comment") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	endif;
	
	if self.opts.includesKey("DefaultYIC") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addBolBasic" id="ea5670d6-ef34-4fbd-b988-0bfde5f5884f">
        <source>addBolBasic( _bolNumber : String; _voyage : CM_Voyage ):CM_BOLIn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2020	jlgndl1	Initial creation	TFS 49401
25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
*/

vars
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	subTerminal : CM_SubTerminal;
	operator : CM_Operator;
begin
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);									
	endif;
	operator := _voyage.myOperator;
	if operator = null then
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	
	create pxyBOL transient;	
	pxyBOL.setProxy(_bolNumber, _voyage,operator, null, 5, BOLType_GeneralBillOfLading, self.getTerminal, subTerminal, null, null, null, false, null, null, null,
																																							null);	//13/07/2022 navgm20 Tfs 54095
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertTrueMsg( realBOL &lt;&gt; null, "BOL " &amp; _bolNumber &amp; " not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	return realBOL.CM_BOLIn;
	
epilog

	delete pxyBOL;

end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="addBookingForContainer" id="5e1ba14b-9784-4cac-9bb1-9a517f865280">
        <updating/>
        <source>addBookingForContainer(	_bookingRef: String;
						_operator: CM_Operator;
						_voyage: CM_Voyage;
						_dischargePort: String;
						_isoType: String;
						_commodity: String): CM_BookingRef updating;
/* Changes
Date		Name	TFS#			Description
============================================================================
06/07/2009	cnwdw1					Create a booking for a container with a mt release
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 	coparn release updates
27/05/2013	cnwdap1	PAR #31596 		added freight forwarder parameter
28/02/2014	cnwma1					add special lift
09 Sep 2014	cnwrs1	CCMS 2351 		att Sequence to Release request 
05 Jun 2018	jlgrs1	TFS 39018 		SNO Cargo Operator in COPRAR
25/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
02 Oct 2020 cnwma1					ChangeRequest 50112: ASPA - GCI Stevedores
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight														
============================================================================*/
vars
	pxyBooking, 
	booking				: CM_BookingRef;
	pxyBookingItem		: CM_BRefItemContainer;
	release				: CM_BulkRelease;
	packAsInteger		: Integer;			// cnwrl1 20/04/2010 PAR 23624
	dischargePorts		: StringArray;
	hazards				: ObjectArray;
	pxyBulkRelease		: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	number 				: Integer;
	releaseTis 			: Any;
	stock 				: Boolean;
	isoGroup 			: String;
	temperature 		: Real;
	specialLift			: ObjectArray;
	spLift 				: CM_SpecialLiftByCodeDict;
	specialStow 		: CM_SpecialStow;
	shippingRef  		: String;
	
	humidity : Decimal[6,2];
	carbonDioxide : Decimal[6,2];
	oxygen : Decimal[6,2];
	
begin
	create dischargePorts transient;
	create hazards transient;
	
	create pxyBooking transient;
	if self.opts.includesKey("Stock") then
		stock := self.opts.bool("Stock");
	else
		stock := false;
	endif;

	//+cnwml2 MSL CCMS 1012
	if self.opts.includesKey("number") then
		number := self.opts.int("number");
	else
		number := 1;
	endif;

	// PAR #28803
	if self.opts.includesKey("ISO Group") then
		isoGroup := self.opts.str("ISO Group");
	else
		isoGroup := null;
	endif;
	
	if self.opts.includesKey("Temp") then
		temperature := self.opts.real("Temp");
	else
		temperature := NULL_TEMPERATURE;
	endif;

	// cnwrl1 20/04/2010 PAR 23624 - start of coding
	packAsInteger	:= app.bookingPackAsStringToEnumb(self.opts.str(ETRow_PackAs));
	if packAsInteger &lt; 0 then
		packAsInteger	:= 0;
	endif;
	// cnwrl1 20/04/2010 PAR 23624 - end of coding
	
	// cnwma1 28/02/2014 add SpecialLift
	create spLift transient;
	if self.opts.includesKey("SpecialLift") then
		specialLift := self.opts.obj("SpecialLift").ObjectArray;
		self.opts.obj("SpecialLift").ObjectArray.copy(spLift);
	endif;
	
	if self.opts.includesKey("SpecialStow") then
		specialStow := self.opts.obj("SpecialStow").CM_SpecialStow;
	endif;
	
	if self.opts.includesKey("ShippingRef") then					// 02/02/2016 cnmwh5
		shippingRef := self.opts.str("ShippingRef");
	endif;

	pxyBooking.setProxy(_bookingRef, 0, false, null,null, null,	null, _dischargePort,null, dischargePorts, // adm 160310 Par 22937 remove bolType
						hazards, NULL_HUMIDITY, false, "", null, null, _operator, _voyage, number, null,
						null, NULL_TEMPERATURE, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, stock, null, null, shippingRef,null, null, null, null, null,
						false, false, false, false, null, false,
						self.opts.bool( ETRow_OverDimension ),			// cnwrl1 20/04/2010 PAR 23624
						false, false, BOOKING_REF_ACTIVE,
						null, 
						specialLift,            //cnwma1 28/02/2014 Special Lift
						null, false, null,
						packAsInteger,							// cnwrl1 20/04/2010 PAR 23624
						null,		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						self.opts.bool("DD"),	// direct delivery
						null,					// freight forwarder
						null, 	//carrier
						null    //stevedore //02.10.2020 cnwma1 TFS #50112
						);
						
	//09 Apr 2020	NDL	TFS 47958
	if self.opts.includesKey("Humidity") then	
		humidity := self.opts.dec("Humidity");
	else
		humidity := NULL_HUMIDITY;
	endif;
	if self.opts.includesKey("CarbonDioxide") then	
		carbonDioxide := self.opts.dec("CarbonDioxide");
	else
		carbonDioxide := NULL_CARBON_DIOXIDE;
	endif;
	if self.opts.includesKey("Oxygen") then
		oxygen := self.opts.dec("Oxygen");
	else
		oxygen := NULL_OXYGEN;
	endif;
	
	
	create pxyBookingItem transient;	
	pxyBookingItem.setProxy(TI_CargoType_Container, 
							_commodity, 
							null,
							null, 
							null, 
							_isoType,
							number,
							2000, 
							0, 
							0, 
							humidity, 
							temperature, 
							NULL_VENTILATION, 
							0,
							carbonDioxide, 
							oxygen, 
							false, 
							false, 
							false, 
							specialStow, 
							isoGroup, 
							false, 
							spLift,
							null,
							null, // cnwma1 28/02/2014 Add SpecialLift
							CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	//+cnwml2 MSL CCMS 1012
	if opts.includesKey("releaseTIs") then
		releaseTis := opts.obj("releaseTIs");
	else
		releaseTis := null;
	endif;
	
	if releaseTis &lt;&gt; null then
		create pxyBulkRelease transient;
		pxyBulkRelease.setProxy(pxyBooking.bookingReference, //code same as this booking reference number
								BR_TYPE_ROAD, //always road from this form
								true,  //release by type - not chkIsReservedOnly
								BR_ACTIVE,
								null, ///availability grades null set on reserve selections
								null,//booking confirmation 
								self.getProfileSetting(UT_Profile.P_CARRIER).asString, //carrier
								null, //cargo remarks
								null,//consignee code 
								null, //_pxyBookingRef.consigneeDesc, //consigneeDesc				//-cnwml2 PAR19845 CCMS SFW 1079
								null,//consignor code
								null, //_pxyBookingRef.consignorDesc,//consignor desc				//-cnwml2 PAR19845 CCMS SFW 1079
								null,//_consignorVoyageCode 
								null, //date requested
								null,//_dateEstimatedRequired
								null,//_deliveryReasonCode
								null,//_deliveryReasonDescr
								null,//_deliveryReleaseNumber
								null,//_doorsDirection
								null,//_freightPayerCode
								pxyBooking,//CM_BookingRef
								null,//_loadPort
								null,//_destinationPort
								getRoot.allPorts[_dischargePort],//_dischargePort
								null,//_freightForwarder
								null,//_transferToTerminal
								pxyBooking.myTerminal,
								pxyBooking.myOperator,//_operator
								null,//_operatorGroup
								pxyBooking.myVoyage,//_voyage
								null,		//_businessUnit	
// TFS 2686								null,		//_removeStops,
								null,		//_fullRelease	
								null,
								null,
								null,
// cnwdad1 27/01/2010 - PAR #22205.
//								self.getTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal,
								self.getTerminal.getDefaultSubTerminalForRel(BR_TYPE_ROAD),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								null,	//_assignedTrain : CM_Train
								false,				//_allPackLocations	
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, 	// par 29480 April 2012
								null,	// CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(pxyBulkRelease);
		pxyReserveSelection.setProxy(CM_ReserveSelection.PackType_Parent, 
									getRoot.allCargoTypesById[TI_CargoType_Container],
									pxyBookingItem,
									getRoot.allISOTypes[_isoType],
									null,  //cnwrd1 par 20810 9/10/9
									null,
									null,
									null,
									1,
									null, //avail grades
									null,//clean
									null, //iso check
									false, //heavy rated
									null, //mask ids
									1,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									false,
									null,
									null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
									null,	// ### TFS 53953 11July2022 NAVPW1
									null,null,  //12-07-2022 navtnr20 53974
									null, //28/06/2023 navmv20 CR 58410 Task 58411
									false,	// 6/12/2023 navcs2 ChangeRequest 57537
									false, //19/02/2023	navkc1 CR 60078 Task 62450
									null, //24/04/2025	navrv30	MTN 34319
									null);
		pxyBulkRelease.createRequests;
		
		if releaseTis.isKindOf(CM_TISet) then
			releaseTis.CM_TISet.copy(pxyReserveSelection.allTrackedItems);
		else
			pxyReserveSelection.allTrackedItems.add(releaseTis.CM_TrackedItem);
		endif;
	endif;		

	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return booking;
epilog
	/*if pxyBooking &lt;&gt; null then
		if pxyBooking.allSpecialLifts.isTransient then
			pxyBooking.allSpecialLifts.purge();
		endif;
	endif;*/
	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
	delete spLift;
//	delete specialLift;
	
end;</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addBookingForGeneralCargo" id="da4fdc50-e7de-4a8f-a763-02d2feacb96a">
        <source>addBookingForGeneralCargo(_bookingRef: String; _operator: CM_Operator; _voyage: CM_Voyage; _dischargePort: String; _cargoType: Integer; _number: Integer): CM_BookingRef;
//06 July 2009	cnwdw1	
//
// 29/07/2011	cnwmh5	Remove passing of opts from signature
// 27/05/2013	cnwdap1	PAR #31596 Added freight forwarder parameter
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 02 Feb 2023  navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
vars
	pxyBooking, booking: CM_BookingRef;
	pxyBookingItem: CM_BRefItemContainer;
	release: CM_BulkRelease;
	dischargePorts: StringArray;
	hazards: ObjectArray;
	destPort	:String;
	weight : Decimal [14,4];
	isoType,isoGrpType	: String; 
begin
	destPort := self.opts.str ("DestinationPort");	// cnwcs5 June 2012
	
	create dischargePorts transient;
	create hazards transient;
	
	//21 Nov 2017	NDL	TFS 7820
	weight := 2000;
	if self.opts.includesKey("TotalWeight") then
		weight := self.opts.int("TotalWeight").Integer;
	endif;
	//Start 02.02.2023 navdp20 TFS #56969[56288]
	if self.opts.includesKey("ISOType") then	
		isoType := self.opts.str("ISOType").String;
	endif;
	if self.opts.includesKey("ISOGroupType") then	 
		isoGrpType := self.opts.str("ISOGroupType").String;
	endif;
    //End 02.02.2023 navdp20 TFS #56969[56288]
	create pxyBooking transient;
	pxyBooking.setProxy(_bookingRef, 0, false, null,null, null,	destPort, _dischargePort,null, dischargePorts,	// adm 160310 Par 22937 remove bolType
						hazards, NULL_HUMIDITY, false,isoType, null, null, _operator, _voyage, 0, null,
						null, NULL_TEMPERATURE, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, false, null, null, null, null, null, null, null, null,
						false, false, false, false, null, false, false, false, false, BOOKING_REF_ACTIVE,
						null, null, null, false, null, null,
						null, 		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						null,	//direct delivery
						null,	// freight forwarder
						null, 	//carrier
						null    //stevedore  //02.10.2020 cnwma1 TFS #50112
						);
	create pxyBookingItem transient;		
	pxyBookingItem.setProxy(_cargoType, null, null, null, null, isoType, _number, weight, 0, 0, NULL_INTEGER, NULL_TEMPERATURE, NULL_VENTILATION, 0
							, NULL_CARBON_DIOXIDE, NULL_OXYGEN, false, false, false, null, isoGrpType, false, null, null, null, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	
	if self.opts.includesKey("CargoSubType") then
		pxyBookingItem.setMyProduct(self.opts.obj("CargoSubType").CM_Product);
	endif;
	
	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return booking;
epilog
	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
end;</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addBookingForGnlCargoByVolume" id="c5becc72-f862-4b43-934d-a06cfaa82d67">
        <source>addBookingForGnlCargoByVolume(_bookingRef: String; 
								_operator: CM_Operator; 
								_voyage: CM_Voyage; 
								_dischargePort: String; 
								_cargoType: CM_CargoType; 
								_subCargoType : String;
								_commodity : String): CM_BookingRef;
/*

Purpose:			Helper Method to Add a booking for General Cargo by Volume

Parameters:			_bookingRef
					_operator
					_voyage
					_dischargePort
					_cargoType
					_volume

Return Value:		A CM_BookingRef containing the resulting booking

Date		Who		Reason
26 November 2021	navpw1	Initial creation TFS: 52193

*/

vars
	pxyBooking, booking: CM_BookingRef;
	pxyBookingItem: CM_BRefItemContainer;
	release: CM_BulkRelease;
	dischargePorts: StringArray;
	hazards: ObjectArray;
	destPort	:String;
	weight : Decimal [14,4];
	product : CM_Product;
	density	: Decimal [16,8];
	volume,
	productVolume	: Decimal [14,4];
	
begin
	destPort := self.opts.str ("DestinationPort");	// cnwcs5 June 2012
	
	create dischargePorts transient;
	create hazards transient;
	
	//21 Nov 2017	NDL	TFS 7820
	weight := 2000;
	if self.opts.includesKey("TotalWeight") then
		weight := self.opts.dec("TotalWeight").Decimal;
	endif;
	
	//21 Nov 2017	NDL	TFS 7820
	volume := 2000;
	if self.opts.includesKey("TotalVolume") then
		volume := self.opts.dec("TotalVolume").Decimal;
	endif;

	create pxyBooking transient;
	pxyBooking.setProxy(_bookingRef, 0, false, null,null, null,	destPort, _dischargePort,null, dischargePorts,	// adm 160310 Par 22937 remove bolType
						hazards, NULL_HUMIDITY, false, "", null, null, _operator, _voyage, 0, null,
						null, NULL_TEMPERATURE, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, false, null, null, null, null, null, null, null, null,
						false, false, false, false, null, false, false, false, false, BOOKING_REF_ACTIVE,
						null, null, null, false, null, null,
						null, 		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						null,	//direct delivery
						null,	// freight forwarder
						null, 	//carrier
						null    //stevedore  //02.10.2020 cnwma1 TFS #50112
						);
	create pxyBookingItem transient;		
	//pxyBookingItem.setProxy(_cargoType, null, null, null, null, null, _number, weight, 0, 0, NULL_INTEGER, NULL_TEMPERATURE, NULL_VENTILATION, 0
	//						, NULL_CARBON_DIOXIDE, NULL_OXYGEN, false, false, false, null, null, false, null, null, null);
	

	//Check if wer're dealing with bulk
	//If we are check if product track by volume or by weight
	//Calculate weight or volume based of weight or volume * density (Check if theres a calculation somewhere)
	if _cargoType &lt;&gt; null and _cargoType.isBulkProduct then
		if _subCargoType &lt;&gt; null then
			product := _cargoType.getProductFromCode(_subCargoType);
		else
			product := _cargoType.mySystemProductType;
		endif;
		
		if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then			// ### TFS 52193 22Nov2021 NAVPW1
			//epr TFS 7756 if we are showing density then have to change the weight when this changes
			density := product.getDensityValue();								// ### TFS 52193 22Nov2021 NAVPW1
			if product.myVolume &lt;&gt; null then
				productVolume := product.myVolume.value;
			endif;
			if _cargoType.isBulkByVolume then
				// calculate total weight
				weight := PortSchema@calculateTotalWeightVolume(weight, volume, density, CM_CalculateWeight);
			elseif _cargoType.isBulkByWeight then
				// calculate total volume
				volume := PortSchema@calculateTotalWeightVolume(weight, volume, density, CM_CalculateVolume);
			endif;
		endif;
	endif;
	
	pxyBookingItem.setProxyForCargo(_cargoType.id, _commodity, null, null, 1, null, 0.0000, 0.0000, 0.0000, null, null, null, null, density, volume, 0, null,
									weight, product, null, null, null, null, null, null, null, null, 0.0000, productVolume, null, null, null, CM_BookingRefItem.BASIC_MATCH);			//navra1 - CR 63764/Task 64227 - 23rd May 2024

	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return booking;
	
epilog
	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
	
end;</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_subCargoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addBookingForProduct" id="de4c0836-3587-4c8e-8a8e-5cde83033b94">
        <source>addBookingForProduct(_code: String; _operator: CM_Operator;_product: CM_Product; _quantity: Integer; _voyage: CM_Voyage): CM_BookingRef;
//26 January 2009	cnwdw1	
//
vars
	pxyBooking, booking: CM_BookingRef;
	cmifBooking: CMIF_BookingRef;
	cmifBookingItem: CMIF_BookingRefItem;
	dischargePorts: StringArray;
	hazards: ObjectArray;
begin

	create pxyBooking transient;
	create cmifBooking transient;
	create cmifBookingItem transient;
	create dischargePorts transient;
	create hazards transient;
	
	cmifBooking.setMyProxyBookingRef(pxyBooking); // adm 160310 Par 22937 remove bolType
	cmifBooking.setProxy(_code, BOOKING_REF_ACTIVE, 0, false, "", "", "", "", "",null, dischargePorts, hazards, 0, false, "", null, null, _operator, _voyage, 0, 
		"", "",NULL_TEMPERATURE, 0, 0, 0, 0,"", "", "", "", 0, 0, 0, 0, 0, self.getTerminal, null, true, true, null, "", "", null,false);
	
	cmifBookingItem := cmifBooking.createInterfaceItem(null, null);
	cmifBookingItem.set(_product.cargoType, false, "", "", hazards, 0, false, "", _quantity, "", NULL_TEMPERATURE, 0, // adm 160310 Par 22937 remove bolType
		NULL_OXYGEN, NULL_CARBON_DIOXIDE, false, 0, 0, 0, "", "", "", "", "", 0, 0, 0, 0, 0, _product, false, null, "", null); //cnwrd1 23.2.09 #18220 
		
	app.myTrxCA.trxCreateBookingRefMulti(cmifBooking, app.myPassport, null, booking);
	self.assertNoTrxErrorsOrWarnings();
	
	return booking;

epilog
	delete pxyBooking;
	delete cmifBooking;
	//delete cmifBookingItem;
	delete dischargePorts;
	delete hazards;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
