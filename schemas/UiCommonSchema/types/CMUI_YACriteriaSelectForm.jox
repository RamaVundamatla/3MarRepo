    <JadeMethod name="createTransients" id="8e3759d5-f181-4e6e-b875-dcc4746a2763">
        <source>createTransients( _identifierColl : StringArray; _criteriaColl, _selectedColl : ObjectSet input );

/*

Purpose:		Create transients objects to represent primitive values

Parameters:			

Return Value:		


Date			Who		Reason
27 August 2008	consw1	Initial creation

*/

vars
	id 		: String;
	pattern	: CMIF_YAPattern;
	proxy	: CM_YADataPattern;
	tokens	: StringArray;
	
begin
	//  Get selected criteria values
	create pattern transient;
	create tokens transient;
	pattern.setPattern( self.getCriteriaValue().toUpper, CMIF_YAPattern.YAPattern_Wildcard );
	pattern.getTokens(pattern.pattern, tokens );

	//  Create a transient object to represent each valid primitive value
	
	foreach id in _identifierColl do
		create proxy transient;
		proxy.setProxy( id );
		_criteriaColl.add( proxy );
		if tokens.includes( id.toUpper ) then
			_selectedColl.add( proxy );
		endif;
		//  Keep list of transients to be purged
		self.allTransients.add( proxy );
	endforeach;
	
epilog
	delete pattern;
	delete tokens;
end;</source>
        <Parameter name="_identifierColl" type="StringArray"/>
        <Parameter name="_criteriaColl" type="ObjectSet" usage="input"/>
        <Parameter name="_selectedColl" type="ObjectSet" usage="input"/>
    </JadeMethod>
