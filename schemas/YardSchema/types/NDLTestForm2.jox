    <JadeMethod name="getTermAreaDetailsForQuery" id="e036c4f0-f59b-41bb-b44a-8d187a3f0fe8">
        <source>getTermAreaDetailsForQuery( _terminal : CM_Terminal output;
							_terminalAreas : CM_TAMasterByIdDict io;
							_gridRows : CM_GridObjectSet io;
							_enqController : CM_EnquiryController output;
							_viewMode : Integer output
							);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation

*/

vars

	termArea : CM_TerminalAreaMaster;

begin

	_terminal := "2351.53".asOid.CM_Terminal;	// NDL Terminal
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLBLK");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLBK2");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLST2");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLSTR");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	_viewMode := VIEW_DWELL_DAYS;


epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_terminalAreas" type="CM_TAMasterByIdDict" usage="io"/>
        <Parameter name="_gridRows" type="CM_GridObjectSet" usage="io"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="output"/>
        <Parameter name="_viewMode" type="Integer" usage="output"/>
    </JadeMethod>
