	self.tblData.clearAllData();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearTblEntQuery" id="cbbba0b8-5bf9-4ef7-b9fd-6e297445d9e6">
        <source>zClearTblEntQuery() protected;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allTblQueryColHeadings.clear();
	self.allTblQueryColInputTypes.clear();
	self.allTblQueryColPropertyNames.clear();
	self.allTblQueryColWidths.clear();
	
	self.tblEntQuery.clearAllSelected();
	self.tblEntQuery.clear;
	self.tblEntQuery.rows := tblData.fixedRows;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zInitTblData" id="4a604ae8-856c-4164-b3c9-db92ac6f8264">
        <updating/>
        <source>zInitTblData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef 		:EntTableDef;
	entRow		: EntTableRow;
	inputType,
	tmpFactor				 :Integer;
	tmpLocale	: CM_Locale;
begin
	//get the display definition for tblMain
	entTableDef := self.getTblDataDef();

	tmpLocale := app.myCurrentLocale;
	
	self.allTblDataEntRows.clear();
	//copy all the rows in that def into the tblMainRows coll
	entTableDef.allEntTableRows.copy(self.allTblDataEntRows);

	//clear the tblMain and show the new data
	self.zClearTblData();

	foreach entRow in self.allTblDataEntRows do
		if entRow.inputType &lt;&gt; 1 then		//so if its not a checkBox (1) we want to see the text so inputType_None
			inputType := Table.InputType_None;
		else 
			inputType := entRow.inputType; //else it's a checkBox so we need to see that tick rather than a 1 or 0 
		endif;
		
		self.zAddTblDataColumn(entRow.getShortHeading(null, null, tmpLocale), entRow.name, inputType); // entRow.inputType
	endforeach;
	
	self.zTblDataSetup();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zInitTblEntQuery" id="a9d98e0a-bc58-4a76-b7c4-d9d641b5b093">
        <source>zInitTblEntQuery() protected;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	
begin
	theTable := tblEntQuery;
	theTable.rows := theTable.fixedRows;
	
	theTable.setTerminologyRelevant(null,self.myTerminal);
	controller := app.myController;
	entTableDef := self.getTblEntQueryDef;
	entTableDef.allEntTableRows.copy(self.allTblQueryEntRows);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef not found');
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSetup" id="7e4966ab-3221-405b-9083-9230f369c6bb">
        <source>zTblDataSetup() protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx, idx2	: Integer;
	col	: JadeTableColumn;
	
begin	

	tblData.selectionType := CM_BaseTable.SelectionType_Row;
	tblData.rows := 1;//tblData.fixedRows;
	tblData.columns := allTblDataColHeadings.size;
	tblData.addItemAt(' '&amp;Tab&amp;'Quantity'&amp;Tab&amp;Tab&amp;Tab&amp;'Volume'&amp;Tab&amp;Tab&amp;Tab&amp;'Weight (kgs)', tblData.rows);
	tblData.accessCell(1,2).mergeCells := Table.MergeCells_Merge;	
	tblData.accessCell(1,5).mergeCells := Table.MergeCells_Merge;	
	tblData.accessCell(1,8).mergeCells := Table.MergeCells_Merge;			
	tblData.accessCell(1,2).alignment := Table.Alignment_Center;	
	tblData.accessCell(1,5).alignment := Table.Alignment_Center;	
	tblData.accessCell(1,8).alignment := Table.Alignment_Center;		
	tblData.fixedRows := 2;
	
	foreach idx in 1 to tblData.columns do
		tblData.accessCell(2, idx).text := allTblDataColHeadings[idx];
		col := tblData.accessColumn(idx);
		//Allow auto format of width instead as per par 4359
		//col.width := ((self.allTblDataColWidths[idx] / 100) * tblData.width).rounded - 5;
		col.inputType := self.allTblDataColInputTypes[idx];	//Table.InputType_None;
		if idx &lt;&gt; 1 then
			col.alignment := Table.Alignment_Right;
		endif;
	endforeach;
	
	tblData.userInputEnabled := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
