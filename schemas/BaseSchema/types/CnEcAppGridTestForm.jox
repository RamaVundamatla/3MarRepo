    <JadeMethod name="btnApply_click" id="56af6445-b363-4d9b-b080-51fcdc89e95a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnApply_click(btn: Button input) updating;

vars
	intRowHeight, intColWidth, intFirstRowHeight, intFirstColWidth, intTimeGrid, intTimeSnap : Integer;
	timStartTime, timEndTime : Time;
begin
	if txtRowHeight.text = "" then
		intRowHeight := appGrid1.rowHeight;
	else
		intRowHeight := txtRowHeight.text.Integer;
	endif;
	if txtColWidth.text = "" then
		intColWidth := appGrid1.columnWidth;
	else
		intColWidth := txtColWidth.text.Integer;
	endif;
	if txtFirstRowHeight.text = "" then
		intFirstRowHeight := appGrid1.firstRowHeight;
	else
		intFirstRowHeight := txtFirstRowHeight.text.Integer;
	endif;
	if txtFirstColWidth.text = "" then
		intFirstColWidth := appGrid1.firstColumnWidth;
	else
		intFirstColWidth := txtFirstColWidth.text.Integer;
	endif;
	if txtStartTime.text = "" then
		timStartTime := appGrid1.startTime;
	else
		timStartTime := txtStartTime.text.Time;
	endif;
	if txtEndTime.text = "" then
		timEndTime := appGrid1.endTime;
	else
		timEndTime := txtEndTime.text.Time;
	endif;
	if txtTimeGrid.text = "" then
		intTimeGrid := appGrid1.timeGrid;
	else
		intTimeGrid := txtTimeGrid.text.Integer;
	endif;
	if txtTimeSnap.text = "" then
		intTimeSnap := appGrid1.timeSnap;
	else
		intTimeSnap := txtTimeSnap.text.Integer;
	endif;
	appGrid1.setGridScale(intRowHeight, intColWidth, intFirstRowHeight, intFirstColWidth);
	appGrid1.setGridTime(timStartTime, timEndTime, intTimeGrid);
	appGrid1.timeSnap := intTimeSnap;
	appGrid1.overlapping := chkOverlapping.value;
	appGrid1.overlaying := chkOverlaying.value;
	appGrid1.multiSelect := chkMultiSelect.value;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnScroll_click" id="bb1bafba-0231-42dd-9a78-a117511e4148">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnScroll_click(btn: Button input) updating;

vars

begin
	appGrid1.scrollTo(appGrid1.appLabel);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblAppCol_dblClick" id="0eb71928-fac4-42db-9ce3-e1e90236dfe7">
        <controlMethod name="Label::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblAppCol_dblClick(label: Label input) updating;

vars
	colour : CMDColor;
begin
	create colour;
	colour.color := backColor;	
	if colour.open = 0 then		
		label.backColor := colour.color;
	endif;
	delete colour;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblAppStatCol_dblClick" id="407b0403-b60a-4d29-a19f-a2791691543e">
        <controlMethod name="Label::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblAppStatCol_dblClick(label: Label input) updating;

vars
	colour : CMDColor;
begin
	create colour;
	colour.color := backColor;	
	if colour.open = 0 then		
		label.backColor := colour.color;
		picAppStat.picture := null;
	endif;
	delete colour;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblTarget_dragDrop" id="545de15c-422d-491d-b4d8-8f465a6412fe">
        <controlMethod name="Label::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblTarget_dragDrop(label: Label input; win: Window input; x: Real; y: Real) updating;

vars

begin
	if win.isKindOf(CnEcAppGridAppLabel) then
		label.caption := win.CnEcAppGridAppLabel.resource.display() &amp; CrLf &amp; 
		win.CnEcAppGridAppLabel.caption &amp; CrLf &amp; "Starts: " &amp; win.CnEcAppGridAppLabel.start.format("HH:mm") &amp; CrLf &amp;
		"  Ends: " &amp; (win.CnEcAppGridAppLabel.start + win.CnEcAppGridAppLabel.duration * 60000).Time.format("HH:mm") &amp; CrLf &amp;
		"Status: " &amp; win.CnEcAppGridAppLabel.status.caption;
	endif;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="aba03d12-38b9-4f20-81b8-1f1de8d66a75">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	today, endOfWeek : Date;
	res : CnEcAppGridResource;

begin
	today := today - today.dayOfWeek + 1;
	endOfWeek := today + 6;
	while today &lt;= endOfWeek do
		create res transient;
		res.myAppGrid := appGrid1;
		res.caption := today.longFormat;
		appGrid1.addResource(res);
		today := today + 1;
	endwhile;
	appGrid1.setGridTime("08:30".Time, "17:30".Time, 30);
	appGrid1.setGridScale(20, 100, 40, 50);
    lblAppCol.backColor := appGrid1.appColor;
    lblAppStatCol.backColor := appGrid1.appStatColor;
	txtRowHeight.text := appGrid1.rowHeight.String;
	txtColWidth.text := appGrid1.columnWidth.String;
	txtFirstRowHeight.text := appGrid1.firstRowHeight.String;
	txtFirstColWidth.text := appGrid1.firstColumnWidth.String;
	txtStartTime.text := appGrid1.startTime.format("HH:mm");
	txtEndTime.text := appGrid1.endTime.format("HH:mm");
	txtTimeGrid.text := appGrid1.timeGrid.String;
	txtTimeSnap.text := appGrid1.timeSnap.String;
    chkOverlapping.value := appGrid1.overlapping;
	chkOverlaying.value := appGrid1.overlaying;
    chkMultiSelect.value := appGrid1.multiSelect;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstEvents_dblClick" id="2d57d834-88e5-4384-bc94-179087029e18">
