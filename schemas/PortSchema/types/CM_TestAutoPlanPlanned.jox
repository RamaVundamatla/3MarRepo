vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSpecific" id="a01f786b-d771-437a-842e-1aebb9811504">
        <updating/>
        <source>setSpecific(	_myPlannedLocation : CM_LocationsController;
				_myAllocationUsed : CM_YardAllocation;
				_splitLocations : String
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	self.myPlannedLocation := _myPlannedLocation;
	self.myAllocationUsed := _myAllocationUsed;
	self.splitLocations := _splitLocations;

epilog

end;</source>
        <Parameter name="_myPlannedLocation" type="CM_LocationsController"/>
        <Parameter name="_myAllocationUsed" type="CM_YardAllocation"/>
        <Parameter name="_splitLocations" type="String"/>
    </JadeMethod>
</Class>
