    <JadeMethod name="btnCancel_click" id="74e933e1-22ad-415a-ac5b-0a89d8a71585">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="1c74b45f-f685-48ee-b586-641e0ee4608b">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doFormUpdate(false) then
		self.modalResult	:=	self.JSS_MODAL_SELECT;
		unloadForm();
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSetToday_click" id="37a54519-9c02-40ab-b7cf-f3622c342274">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetToday_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;
	
begin
	self.doResetDate(dateToday);
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calSelect_click" id="dd724921-cbaa-42dc-87ce-05f56a91ad81">
        <controlMethod name="BaseControl::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calSelect_click(cntrl: JSSCalendar input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doResetDate(cntrl.getSelectedDate());
	cntrl.setFocus();
end;</source>
        <Parameter name="cntrl" type="JSSCalendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calSelect_dblClick" id="0fd8764b-3dc6-4028-b089-b0f7785b2959">
        <controlMethod name="BaseControl::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calSelect_dblClick(cntrl: BaseControl input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doFormUpdate(false) then
		self.modalResult	:=	self.JSS_MODAL_SELECT;
		unloadForm();
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMonth_scrolled" id="f489535e-3fac-41f4-b22a-cd7bb07b7a9c">
        <controlMethod name="ComboBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMonth_scrolled(combobox: ComboBox input; scrollBar: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldDate	: Date;
	newDate	: Date;
	
begin
	oldDate	:=	calSelect.getSelectedDate();
	
	// Subtract the old month from the new month (yielding a +ve or -ve value)
	// and adjust the date accordingly.
	
	newDate	:=	oldDate.jssAddMonths(combobox.itemData[combobox.listIndex] - oldDate.month);
	self.doResetDate(newDate);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="94e6de1b-fbf3-4b7e-bdd6-a91827b9b849">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;
	
begin
	self.setStartDate(dateToday);
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="a060c4d2-42d0-4df1-b765-427f2fc0ae5c">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();

	if self.aPositionLeft = 0 and self.aPositionTop = 0 then
		centreWindow();
	else
		self.move(self.aPositionLeft, self.aPositionTop, self.width, self.height);
	endif;		
	
	txtYear.setMinValue(1);
	txtYear.setMaxValue(9999);
	self.doInitializeDateInfo();
epilog
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="7463173f-3665-4a2f-add6-0737dbbdd308">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aSelectedDate	:=	calSelect.getSelectedDate();
	self.modalResult	:=	self.JSS_MODAL_SELECT;
epilog
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInitializeDateInfo" id="069b5b07-3a30-4e8c-a5de-ef0b630b1ca8">
        <updating/>
        <source>doInitializeDateInfo() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startDate		: Date;
	newEntryIndex	: Integer;
	monthIndex		: Integer;
	theCalendar		: JSSCalendar;

begin
	startDate		:=	self.aStartDate;
	theCalendar		:=	calSelect;
	
	cmbMonth.clear;
	
	foreach monthIndex in 1 to 12 do
		newEntryIndex	:=	cmbMonth.addItem(("1/" &amp; monthIndex.String &amp; "/" &amp; startDate.year.String).Date.monthName);
		cmbMonth.itemData[newEntryIndex]	:=	monthIndex;
	endforeach;
	
	txtYear.setValue(startDate.year);
	cmbMonth.listIndex	:=	cmbMonth.findStringExact(1, startDate.monthName);
	theCalendar.setSelectedDate(startDate, true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetDate" id="d290f7bf-945e-4eb9-afc9-aab454399bc6">
        <updating/>
        <source>doResetDate(pDate:Date) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		This method will reset the calendar to the requested date.  Note
//				that if the newly requested date is outside of the date range that
//				was originally specified (i.e. for the Start Date and years either
//				side), then the Start Date will be reset to this specified date and
//				the calendar will be reinitialized based upon that new Start Date.
//
// Parameters:	pDate (Date) - The date to which the calendar will be set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	cmbMonth.listIndex	:=	cmbMonth.findStringExact(1, pDate.monthName);
	txtYear.setValue(pDate.year);
	
	if cmbMonth.listIndex = JSS_NULL_INDEX or txtYear.jssInteger() = 0 then
		self.setStartDate(pDate);
		self.doInitializeDateInfo();
		return;
	endif;
	
	calSelect.doClearHighlightedDays();
	calSelect.setSelectedDate(pDate, true);
	self.setStartDate(pDate);
end;</source>
        <access>protected</access>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDate" id="b4ec8e80-edeb-4269-90fe-e8ce298fa7e9">
        <source>getDate():Date;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the date that was selected by the User.
//
// Parameters:	None
//
// Returns:		Date
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.aSelectedDate;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setPosition" id="97ce8e17-512c-4a88-8079-d0d778d02aeb">
        <updating/>
        <source>setPosition(pPositionLeft:Integer; pPositionTop:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2004 by cnwdad1
//
// Purpose:		Sets the (screen) position at which to display this form.  This is
//				intended for use by the CnEcDateBox control to display this form
//				next to the control when the User double-clicks it to pick a date.
//
//				NOTE: These attributes are only used by the form's "load" event.
//
// Parameters:	pPositionLeft (Integer) - The Left position on the screen.
//				pPositionTop (Integer) - The Teft position on the screen.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aPositionLeft &lt;&gt; pPositionLeft then
		self.aPositionLeft	:=	pPositionLeft;
	endif;

	if self.aPositionTop &lt;&gt; pPositionTop then
		self.aPositionTop	:=	pPositionTop;
	endif;
end;</source>
        <Parameter name="pPositionLeft" type="Integer"/>
        <Parameter name="pPositionTop" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStartDate" id="fcf774ea-3862-4fcf-8d68-5f557d9699b5">
        <updating/>
        <source>setStartDate(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		This methods sets the default starting date for the select calendar.
//
// Parameters:	pDate - The new start date.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aStartDate &lt;&gt; pDate then
		self.aStartDate	:=	pDate;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="txtYear_scrolled" id="582c158d-38f5-4edb-9518-f7767ac90c82">
        <controlMethod name="JSSScrollBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtYear_scrolled(textbox: TextBox input; scrollBar: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldDate	: Date;
	newDate	: Date;
	
begin
	oldDate	:=	calSelect.getSelectedDate();

	// Subtract the old year from the new year (yielding a +ve or -ve value)
	// and adjust the date accordingly.
	
	newDate	:=	oldDate.jssAddYears(textbox.jssInteger() - oldDate.year);
	self.doResetDate(newDate);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
</GUIClass>
