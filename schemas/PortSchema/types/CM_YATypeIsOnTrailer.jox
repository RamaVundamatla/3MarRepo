    <JadeMethod name="isCMIFDataMatch" id="7e3e8db0-09e0-4717-9357-ee5134f2b8a8">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 January 2024
TFS#		: 62141
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
