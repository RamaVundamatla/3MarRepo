    <JadeMethod name="doUpdateDTOContainer" id="28e2e271-a338-4478-a0c0-399c5e4c3e5a">
        <source>doUpdateDTOContainer() :DTO_WagonPosition;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	wagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	
begin	
	
	if self.showingForInwards then
		wagonPos := self.myDTOWagonIn.allDTOWagonPositions[self.showingContainerNumIn,1];
		wagonPos.myDTOContainer.isoTypeCode 			:= self.cmbISOType.text;
		wagonPos.myDTOContainer.containerId 		:= self.txtId.text.trimBlanks.toUpper();	
		app.myHandHeldRailGuiAgent.getValidContainerInwards(wagonPos);
	else
		wagonPos := self.myDTOWagonOut.allDTOWagonPositions[self.showingContainerNumOut,1];
	endif;
	
	wagonPos.myDTOContainer.containerId 		:= self.txtId.text.trimBlanks.toUpper();	
	wagonPos.myDTOContainer.customsSeal 		:= self.txtSealCust.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.operatorSeal 		:= self.txtSealOp.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.shipperSeal 		:= self.txtSealShip.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.hazardousChecked 	:= self.chkHaz.value;

	return wagonPos;
epilog

end;</source>
        <ReturnType type="MobileHandHeldThin::DTO_WagonPosition"/>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="d7341a1e-6ba8-471a-885f-32bdd505c3bf">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	
	if folder.topSheet = self.shtInward then
		self.showingForInwards := true;
		if self.showingContainerNumIn &gt; 0 then
			self.doShowFrmInfo(self.showingContainerNumIn);
		else
			self.doShowFrmMain();
		endif;
	elseif folder.topSheet = self.shtOutward then
		self.showingForInwards := false;
		self.doShowFrmMain();
	endif;//elseif it's the error sheet, don't change the mode
	
end;


</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
