    <JadeWebServicesMethod name="getNextVoyageCode" id="335feb75-8dd4-48d7-9f13-bdea35a1911a">
        <source>getNextVoyageCode(request : WS_VoyageCodeRequest) : WS_VoyageCodeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 March 2018	jlger1	Initial creation tfs 37663
02 Aug 2018		jlgam15	TFS 40027 - External Voyage code to be auto-generated using hook code logic

*/

vars
	response : WS_VoyageCodeResponse;
	vessel	: CM_Vessel;
	completedOK : Boolean;
	voaygeNum : Integer;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	 
	if request.vessel = null then
		completedOK:=true;
		return response;
	endif;
	
	vessel:=app.myRoot.allVessels[request.vessel];
	if vessel = null then
		vessel := app.myPassport.getObjectOfTypeFromOid(request.vessel,CM_Vessel).CM_Vessel;
	endif;
	if vessel = null then
		completedOK:=true;
		return response;
	endif;
	
	// Populate the response
	response.voyageCode:=app.myPassport.myTerminal.getNextVoyageCode(vessel,voaygeNum, app.myPassport);
	response.externalVoyageCode := app.myPassport.myTerminal.getNextVoyageExternalCode(vessel);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_VoyageCodeRequest"/>
        <ReturnType type="WS_VoyageCodeResponse"/>
    </JadeWebServicesMethod>
