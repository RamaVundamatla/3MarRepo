<Class name="CM_MovePlan" id="856f35a4-0bde-4b1b-bfae-76af5afc4618">
    <superclass name="CM_PlanningObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to store the definition of work we do when we search for a 
planned location for a move.
Users can create/delete these objects, and allocate attributePlans
for the system to work through.</text>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="attributePlans" id="488f4704-8c86-420b-87be-5e8cfa471924">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_AttributePlansArray"/>
        <access>readonly</access>
        <text>These are the attribute plans associated with the moveplan. 
The attributeplans are a global resource that are available to all movePlans
they are NOT specifically allocated to any one moveplan.</text>
        <Inverse name="CM_AttributePlan::movePlans"/>
    </ExplicitInverseRef>
