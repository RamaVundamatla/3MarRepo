    <JadeMethod name="getTagData" id="fe0ca065-1d2e-49bd-9d0f-116b4a9eeaa9">
        <source>getTagData(_tag : String) : String protected;

// Created by cnwdvb1 on 07 August 2007

vars
	structureInstance	: CnEcXmlStructureInstance;

begin
	structureInstance	:=	self.xmlStruct.findStructure(_tag);
	
	if structureInstance &lt;&gt; null then
		return structureInstance.tagData;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTagDataFromXML" id="84043033-fcd5-4609-b8a4-4fb422e39955">
        <source>getTagDataFromXML(_tagName:String; _xmlObj:CnEcXmlStructureInstance):String protected;
// --------------------------------------------------------------------------------
// Created:		03 February 2009 by cnwdad1
//
// Purpose:		Returns the data for the specified tag name, from the specified XML
//				structure.
//
// Parameters:	_tagName - The name of the tag.
//				_xmlObj - A reference to the XML structure object.
//
// Returns:		The tag data, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	structureObj	: CnEcXmlStructureInstance;

begin
	structureObj	:=	_xmlObj.findStructure(_tagName);
	
	if structureObj = null then
		return null;
	else
		return structureObj.tagData;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_xmlObj" type="CnEcXmlStructureInstance"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTagDataFromXMLIfPresent" id="2599bbde-a0c3-4b5c-aecb-25f9347128a0">
        <source>getTagDataFromXMLIfPresent(_tagName:String; _xmlObj:CnEcXmlStructureInstance; _value : String output) : Boolean protected;
// --------------------------------------------------------------------------------
// Created:		7 Apr 2011 cnwrs2
//
// Purpose:		Returns the true if the tag is present, and puts the value into the _value parameter
//				else return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	structureObj	: CnEcXmlStructureInstance;

begin
	structureObj	:=	_xmlObj.findStructure(_tagName);
	
	if structureObj = null then
		return false;
	else
		_value := structureObj.tagData;
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_xmlObj" type="CnEcXmlStructureInstance"/>
        <Parameter name="_value" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="157cec1d-dc22-4efb-b3fb-544f98093393">
        <updating/>
        <source>handleException(_exp : Exception; _canContinue : Boolean output) : Integer updating;
//
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
//
vars
	errorInfo	: String;
	msg : String;
begin
	if _exp.errorCode = 1228 or 
	   _exp.errorCode = 1295 or 
	   _exp.errorCode = 3015 or 
	   _exp.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exp.errorCode.String&amp;' '&amp;_exp.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;
	_canContinue	:=	false;
	errorInfo		:=	"An application error occured (Error=" &amp; _exp.errorCode.String &amp; ").  A stack dump has been created in the system logs directory.";
	app.writeLog(errorInfo, LogINFO);
	app.doDumpStack(_exp);
	app.createAlert(errorInfo, true);
	
	return Ex_Resume_Next;
end;</source>
        <Parameter name="_exp" type="Exception"/>
        <Parameter name="_canContinue" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="parseBatchHdr" id="e7c3aae3-3d00-4f1e-a2ef-0f960890c75f">
        <source>parseBatchHdr(_detail : String; _remoteHeader : CM_RemoteDataHdr; _class, _type : String) : CM_RemoteDataDtl protected;

vars

	detail			: CM_RemoteDataDtl;
	huge			: HugeStringArray;
	docket,
	supplier,
	scalerCode,
	time,
	startTime,
	finishTime,
	reasonCode,
	recoveryCode,
	area,
	location,
	grade,
	species,
	length,
	type,
	treatment	: String;

begin

	create huge transient;

	if _class = CM_RemoteDataObject.Class_Log then
		if _type = CM_RemoteDataObject.Type_Scale then
			_detail.parseCSV(huge);
			if _remoteHeader.theVersion = 1 then
				docket 		:= huge[1];
				supplier	:= huge[2];
				scalerCode	:= huge[3];
				startTime	:= huge[4];
			elseif _remoteHeader.theVersion &gt;= 2 then
				docket 		:= huge[1];
				supplier	:= huge[2];
				startTime	:= huge[3];
				finishTime	:= huge[4];
				scalerCode := _remoteHeader.userId;
			endif;
			create detail as CM_RemoteScaleTruckDtl transient;
			detail.CM_RemoteScaleTruckDtl.setProxyForScaleTruck(_remoteHeader, docket, supplier, scalerCode, startTime, finishTime);
		elseif _type = CM_RemoteDataObject.Type_Reject then
			_detail.parseCSV(huge);
			reasonCode	:= huge[1];
			recoveryCode:= huge[2];
			create detail as CM_RemoteRejectDtl transient;
			detail.CM_RemoteRejectDtl.setProxyForReject(_remoteHeader, reasonCode, recoveryCode, _class);						
		elseif _type = CM_RemoteDataObject.Type_Regrade then
			_detail.parseCSV(huge);
			area 		:= huge[1];
			location	:= huge[2];
			supplier	:= huge[3];
			species		:= huge[4];
			grade		:= huge[5];
			type		:= huge[6];
			treatment	:= huge[7];
			length		:= huge[8];
			create detail as CM_RemoteRegradingDtlExt transient;
			detail.CM_RemoteRegradingDtlExt.setProxyForRegradingExt(_remoteHeader,_class, _type, area, location, supplier, species, grade,type, treatment, length);
		elseif _type = CM_RemoteDataObject.Type_Check then
			_detail.parseCSV(huge);
			time		:= huge[1];
			create detail as CM_RemoteCheckScalingDtl transient;
			detail.CM_RemoteCheckScalingDtl.setProxyForCheckScaling(_remoteHeader, time);
		endif;
	endif;
	
	return detail;
epilog
	delete huge;
end;</source>
        <access>protected</access>
        <Parameter name="_detail" type="String"/>
        <Parameter name="_remoteHeader" type="CM_RemoteDataHdr"/>
        <Parameter name="_class" type="String"/>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CM_RemoteDataDtl"/>
    </JadeMethod>
    <JadeMethod name="parseTiToExtraDetail" id="6b4e9587-3600-4a21-84ba-df508e5e1ad5">
        <source>parseTiToExtraDetail(_detail : String; _remoteDetail : CM_RemoteDataDtl; _class, _type : String) protected;

vars

	huge			: HugeStringArray;
	extra			: CM_RemoteDataExtra;
	id,
	newId,
	conditionCode,
	reasonCode,
	recoveryCode	: String;
	maxSED,
	minSED			: Integer;

begin

	create huge transient;
	
	if _detail.length &gt; 0 then
		_detail.parseCSV(huge);
	endif;
	if _class = CM_RemoteDataObject.Class_Log then
		if _type = CM_RemoteDataObject.Type_Scale then
			id	 			:= huge[1].trimBlanks();	//PAR 26835 16/02/2011
			conditionCode	:= huge[2];
			minSED			:= huge[3].Integer;
			maxSED			:= huge[4].Integer;
			create extra as CM_RemoteScalingExtra transient;	
			extra.CM_RemoteScalingExtra.setProxyForScalingExtra(_remoteDetail, id, conditionCode, minSED, maxSED);
		elseif _type = CM_RemoteDataObject.Type_Reject then
			id				:= huge[1];
			reasonCode		:= huge[2];
			recoveryCode	:= huge[3];
			create extra as CM_RemoteRejectExtra transient;
			extra.CM_RemoteRejectExtra.setProxyForRejectExtra(_remoteDetail, id, reasonCode, recoveryCode);
		elseif _type = CM_RemoteDataObject.Type_Regrade then
			id	 			:= huge[1];
			newId			:= huge[2];
			minSED			:= huge[3].Integer;
			maxSED			:= huge[4].Integer;
			reasonCode		:= huge[5];
			create extra as CM_RemoteRegradingExtra transient;
			extra.CM_RemoteRegradingExtra.setProxyForRegradingExtra(_remoteDetail, id, newId, reasonCode, minSED, maxSED);
		elseif _type = CM_RemoteDataObject.Type_Check then
			id	 			:= huge[1];
			conditionCode	:= huge[2];
			minSED			:= huge[3].Integer;
			maxSED			:= huge[4].Integer;
			create extra as CM_RemoteCheckScalingExtra transient;
			extra.CM_RemoteCheckScalingExtra.setProxyForCheckScalingExtra(_remoteDetail, id, conditionCode, minSED, maxSED);
		endif;
	endif;	
	
	return;
epilog
	delete huge;
end;</source>
        <access>protected</access>
        <Parameter name="_detail" type="String"/>
        <Parameter name="_remoteDetail" type="CM_RemoteDataDtl"/>
        <Parameter name="_class" type="String"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="setParsedData" id="4a19a52d-4fdc-43b5-bb50-3a4c4dd41155">
        <updating/>
        <source>setParsedData(_struct : CnEcXmlStructureInstance) updating;


vars

	
begin
	
	self.xmlStruct := _struct;

end;</source>
        <Parameter name="_struct" type="CnEcXmlStructureInstance"/>
    </JadeMethod>
</Class>
