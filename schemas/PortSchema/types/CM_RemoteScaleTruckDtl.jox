<Class name="CM_RemoteScaleTruckDtl" id="cdbd667b-a207-4fc6-aed8-41cfaeae12ac">
    <superclass name="CM_RemoteDataDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="docketId" id="922ac50d-b62c-4c1c-becf-eafeee2636ac">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="finishTime" id="42fd339f-fce1-4a5c-b83f-7fb46ac534b0">
        <length>31</length>
        <embedded/>
