    <JadeMethod name="setExportVoyageCode" id="a609382e-cd79-46f8-a0c5-0b22e4d46d37">
        <updating/>
        <source>setExportVoyageCode( _value : String ) updating;
//
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
//
vars

begin
	/* cnwrl1 11/06/2010 PAR 24299 - what it was
	if self.exportVoyageCode &lt;&gt; _exportVoyageCode then
		self.exportVoyageCode := _exportVoyageCode[1:30];
	endif;
	cnwrl1 11/06/2010 PAR 24299 - end of what it was */
	
	// cnwrl1 11/06/2010 PAR 24299 - start of coding
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.exportVoyageCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.exportVoyageCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.exportVoyageCode.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.exportVoyageCode	:= _value[ 1 : self.exportVoyageCode.maxLength ];
	if not self.isTransient and
	   self.exportVoyageCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.exportVoyageCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.exportVoyageCode.toUpper, self, self );
		endif;
	endif;
	// cnwrl1 11/06/2010 PAR 24299 - end of coding
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2dde0dde-1894-4de3-adb9-775ae3eb1e7a">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;

vars

begin
	inheritMethod(_proxyEDITI);
	self.setBookingRef(_proxyEDITI.bookingRef);
	self.setBillOfLading(_proxyEDITI.billOfLading);	// MES1008
	self.setIsoType(_proxyEDITI.isoType);
