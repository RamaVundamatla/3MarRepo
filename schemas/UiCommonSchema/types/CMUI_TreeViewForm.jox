    <JadeMethod name="setupForm" id="ec33a5d2-a2b8-4781-a58a-a3b555ed43c8">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason

//16 Dec 2022   navsa20     Bug 55878: SNO - Error 4033 happens while trying to update a Release Request
	
----------   ----------  --------------------------------------------------
*/
vars

	ls,                                     
	completed 	: Boolean;                   //16.12.2022 navsa20 TFS 55878
begin
	app.cmsBeginLoad(ls);
	if self.isShowingForObject then
		if self.mode = self.Mode_Add then
			self.myMasterProxyObject := self.myMasterObject;
			self.myMasterObject := null;//transient place holder only if adding new
			
			if self.myMasterProxyObject = null or (not self.myMasterProxyObject.isTransient()) then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Tree view form called to open in add mode, but transient place holder passed in is either null or persistent.');
				return;
			endif;
			
		elseif self.mode = self.Mode_Update then
			if self.myMasterObject = null or self.myMasterObject.isTransient then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Tree view form called to open in update mode, but object passed in is either null or transient.');
				return;
			endif;
			//proxy created here, after self.show so that the unload is called and cleans up the proxy if an exception occuts initializing the form
			self.myMasterProxyObject := self.myMasterObject.pxyCreateUpdateProxy();
		
		elseif self.mode = self.Mode_View then
			if self.myMasterObject = null or self.myMasterObject.isTransient then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Tree view form called to open in view mode, but entity passed in is either null or transient.');
				return;
			endif;
		
			self.myMasterProxyObject := null;
		endif;
	endif;

	//set at run-time instead of in the painter to allow ease of adding controls to sub-class in painter
	self.frmMain.allowDocking 			:= Frame.AllowDocking_All;
	
	self.dkbTopLeft.alignChildren 		:= JadeDockBar.AlignChildren_AllHorizontal;
	self.dkbBottomLeft.alignChildren 	:= JadeDockBar.AlignChildren_AllHorizontal;
	self.dkbTopRight.alignChildren 		:= JadeDockBar.AlignChildren_AllHorizontal;
	//self.dkbBottomRight.alignChildren 	:= JadeDockBar.AlignChildren_Auto;
	self.allRegisteredKeyCodes.add(J_key_DownArrow);
	self.allRegisteredKeyCodes.add(J_key_UpArrow);
	self.allRegisteredKeyCodes.add(J_key_LeftArrow);
	self.allRegisteredKeyCodes.add(J_key_RightArrow);
	self.allRegisteredKeyCodes.add(J_key_Delete);
	
	self.doRegisterFormKeys();
	
	self.refreshToolbar();
	self.setupTreeList();
	self.setFrameCaptions();
	
	//set the allowFrame booleans in your subclass prior to inheriting
	self.dkbTopLeft.visible := self.allowFrameTopLeft;
	self.dkbBottomLeft.visible := self.allowFrameBottomLeft;
	self.dkbTopRight.visible := self.allowFrameTopRight;
	self.dkbBottomRight.visible := self.allowFrameBottomRight;
	
	self.setDockBarsFloatingStyle(JadeDockBase.FloatingStyle_None);
	
	
	inheritMethod();
//	self.frmToolbarBtns.visible := false;
	
	self.loadTree();
	if self.lstTree.listCount &gt; 0 then
		self.selectObject(self.lstTree.itemObject[1].CM_Object);
		self.zSetTblEntryFocus();
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then
		self.setControlsForAddEdit();
	else
		self.setControlsForView();
	endif;
	
	completed := true;                     //16.12.2022 navsa20 TFS 55878
epilog
	if ls then
		endLoad;
	endif;
	if not completed then                  //16.12.2022 navsa20 TFS 55878
		delete self.myMasterProxyObject;   //16.12.2022 navsa20 TFS 55878
	endif;                                 //16.12.2022 navsa20 TFS 55878
end;


</source>
    </JadeMethod>
    <JadeMethod name="setupTreeList" id="de198b88-cd7c-4f4e-bf91-4e2014f8788d">
