<Class name="CMIF_KPIVoyageHelper" id="c4b4486a-4ddb-4f35-aac9-c9d624f9e570">
    <superclass name="CMIF_KPIHelper"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
