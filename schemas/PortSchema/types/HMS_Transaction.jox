    <JadeMethod name="setFromTransController" id="10d9bbdd-6b06-4888-941c-0e0ecded55be">
        <updating/>
        <source>setFromTransController(_transController : CMIF_HMS_TransactionController; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	self.setGeneralProperties(_transController, _passport);
	if not app.isConverting then //rs may2004 for HMS convertion
		self.createPropertyChanges(_transController);
	endif;
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="d2545012-1ba1-4bbb-a96b-d7ec9bbb5390">
        <updating/>
        <source>setGeneralProperties(_transController : CMIF_HMS_TransactionController; _passport : CM_Passport input) updating, protected;

vars

begin
	// This method sets general properties for a transaction:

	self.userCode		:= _passport.userCode;
	self.userName 		:= _passport.myUser.userName;
	self.transactionDT 	:= app.serverTimestampAtTrxStart;
	self.myTerminal 	:= _transController.myTerminal;
	self.myHMSVoyageData := _transController.myHMSVoyageData;
	self.myMovement := _transController.myVoyageMovement;

	// Set type details 
	//self.setTypeDetails(); Done in the create

end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
