    <JadeMethod name="mnuCargoEditSelected_click" id="3921dc0b-a9fe-4fcd-bb67-6d0064ccfaee">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEditSelected_click(menuItem: MenuItem input) updating;
/*
Date		    Who			Reason
12 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

