    <JadeMethod name="create" id="68ebd265-bb9d-42b2-9736-1879bf6dc146">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     The following things set here should never and are never changed
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myType := String;
	self.allValidationTypes.add(ValidationType_Codes);
	self.allValidationTypes.add(ValidationType_Value);

end;</source>
