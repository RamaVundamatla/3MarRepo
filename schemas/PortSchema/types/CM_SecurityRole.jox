        <source>setEventTypes( _eventTypes : CM_EventTypeByTypeDict );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

begin

	self.allEventTypes.clear();
