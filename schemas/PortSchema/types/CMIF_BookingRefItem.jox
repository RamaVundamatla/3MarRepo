    <JadeMethod name="isControlledAtmosphere" id="1d610fe6-d06c-4978-a2a2-342fdbc7b2bd">
        <methodInvocation>mapping</methodInvocation>
        <source>isControlledAtmosphere(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
11 September 2008	consw1	Initial creation - CCMS1654

*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.cargoType = TI_CargoType_Container then
			_value := self.getOxygen &lt;&gt; NULL_OXYGEN or self.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE or self.curtainsIn;
		else
			_value := false;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="matchesRealBRItem" id="b396c2bc-cba6-42a7-b108-e03b290ff4b1">
        <source>matchesRealBRItem(_brItem : CM_BookingRefItem; _exact : Boolean):Boolean;
/*
	Created on 05 March 2008
	
	by Debby Hutchison
	
	Purpose: find the correct book ref item for this cmif.
	This is used for matching from an EDI file.
	Try and get an exact match, but otherwise if the file 
	has a null and the cmif doesn't that is also a match.
*/

vars
	blnCommodity : Boolean;
	realTemp : Real;
	tempMatches : Boolean;
begin
	if CM_BRefItemContainer.hasInstance(_brItem) then
		realTemp := _brItem.CM_BRefItemContainer.getTemperature();
		tempMatches := self.temperature = realTemp;
	else
		tempMatches := true;
	endif;
	if _exact then
		return tempMatches
//		and self.bolType = _brItem.bolType // adm 160310 Par 22937 remove bolType
//		and self.cargoType = _brItem.cargoType // dh par 17029  - cargo type is being defaulted if null so won't always match
		and ((self.cargoType = null) or (self.cargoType = _brItem.cargoType)) // so do this instead
		and (self.commodity = _brItem.commodity or _brItem.isCommodityChanged)
		and self.height = _brItem.height
		and self.isoType = _brItem.isoType
		and self.isoTypeGroup = _brItem.isoTypeGroup //par24060 cnwrs1 28 may 2010 ccms 1882
		and self.length = _brItem.length
		and self.width = _brItem.width
		and self.volume = _brItem.volume
		and self.weight = _brItem.weight
		and self.myProduct = _brItem.myProduct;
	else  // if file has a null value but real item has data entered, this is ok
		return (self.temperature = null or self.temperature = realTemp)
//		and (self.bolType = null or self.bolType = brItem.bolType) // adm 160310 Par 22937 remove bolType
		and (self.cargoType = null or self.cargoType = _brItem.cargoType)
		and (self.commodity = null or self.commodity = _brItem.commodity or _brItem.isCommodityChanged)
		and (self.height = null or self.height = _brItem.height)
		and (self.isoType = null or self.isoType = _brItem.isoType)
		and (self.isoTypeGroup = null or self.isoTypeGroup = _brItem.isoTypeGroup) //par2430 cnwrs1 28 may 2010
		and (self.length = null or self.length = _brItem.length)
		and (self.width = null or self.width = _brItem.width)
		and (self.volume = null or self.volume = _brItem.volume)
		and (self.weight = null or self.weight = _brItem.weight)
		and (self.myProduct = null or self.myProduct = _brItem.myProduct);
	endif;
end;</source>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_exact" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myCargoType" id="81088fa0-e38f-4ef8-bf38-8ca605b97f85">
