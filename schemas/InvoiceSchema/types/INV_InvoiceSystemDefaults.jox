    <JadeMethod name="populateCmbDebtAction" id="d8710013-904f-4e5a-ac44-8fee7b78d1f5">
        <source>populateCmbDebtAction( _action : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38952

*/

vars

	combo : CMUI_ComboBox;

begin

	combo := self.cmbDebtAction;
	combo.clear;
	combo.itemData[ combo.addItem( " " ) ] := 0;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_error)) ] := 1;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_warnin)) ] := 2;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_no_action)) ] := 3;
	
	if _action &gt;= 1 and _action &lt;= 3 then
		combo.listIndex := combo.findItemData( _action );
		combo.lostFocus( combo );
	endif;

epilog

end;</source>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateCmbRoundInvLine" id="f97018d2-f0be-49b6-a55a-5822702d4b43">
        <source>populateCmbRoundInvLine(_roundValue : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form

*/

vars
	combo : CMUI_ComboBox;
begin
	combo := self.cmbRoundInvLine;

	combo.clear;
	combo.sorted := false;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_NoRound)]  := CMIF_ConfigTerminal.InvLineRound_Value_NoRound; //6
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Zero)]  	  := CMIF_ConfigTerminal.InvLineRound_Value_Zero;   
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_One)]   	  := CMIF_ConfigTerminal.InvLineRound_Value_One;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Two)]   	  := CMIF_ConfigTerminal.InvLineRound_Value_Two;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Three)] 	  := CMIF_ConfigTerminal.InvLineRound_Value_Three;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Four)]     := CMIF_ConfigTerminal.InvLineRound_Value_Four;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Five)]     := CMIF_ConfigTerminal.InvLineRound_Value_Five;
	
	if _roundValue &gt;= 0 and _roundValue &lt;= 6 then
		combo.listIndex := combo.findItemData( _roundValue );
		combo.lostFocus( combo );
	endif;

end;</source>
        <Parameter name="_roundValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="fcd8a964-25ad-4c85-a424-b5ca825d665e">
