    <JadeMethod name="createAllPxyCargoUpdates" id="0297c2e6-e20e-48f5-8757-e3765b2c8330">
        <source>createAllPxyCargoUpdates(_cmifEventReq 	: CMIF_EventRequestController  input) : Boolean;
/*

Date		Who		Reason
09 May 2014	cnwer1	Initial creation PAR
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

vars
	tmpUser 		: CM_User;
	addresses 		: CM_StringArray;
	stringAddresses	: StringArray;
	cargoType 		: CM_CargoType;
	organisation 	: CM_Organisation;
	usedProxy		: Boolean;
	isClear,
	isAutoCleanup: Boolean;
	todoRemarks,
	txnRemarks,
	additionalInfo	: String;
	expiryDate		: Date;	
	allCargoIds  : StringArray;
	cargoId : String;
	stop			: WS_Stop;
	stopObj			: CM_StopsTable;
	toDo			: WS_ToDoTaskDesc;
	toDoObj			: CM_ToDoTaskDesc;
	eventReq,
	pxyFromReal,
	pxyCargoUpdateRequest : CM_EventRequestStops;
	terminal : CM_Terminal;
	gradeObj 	: CM_MTGrade;
	pxyEmail,
	realEmail 		: CM_EventRequestEmail;
	index 			: Integer;
begin

	tmpUser 		:= app.getMyUser;
	cargoType 		:= app.myRoot.allCargoTypesById[self.myCargoType];
	organisation 	:= app.myRoot.allOrganisations[self.myOrganisation];
	terminal 		:=app.getMyTerminalDO_NOT_USE();
	
	// Get email addresses - needs to be refactored later
	create stringAddresses transient;
	self.emailAddresses.getTrimedTokensForDelimiter(";", stringAddresses); //18/03/2009 cnwdz2 par19178
	create addresses transient;
	stringAddresses.copy(addresses);
	
	additionalInfo := self.additionalRequiredInfo.truncatedAt(30);		//cnwmc5 - 17 Oct 2013 - PAR 32798
	expiryDate := self.clearanceExpiryDate.asDateFromWebInterface;		//cnwmc5 - 13 Jan 2016 - PAR 37326	
	isClear:=self.isClear.asBooleanJMT();
	isAutoCleanup:=self.autoCleanUp.asBooleanJMT();
	
	create allCargoIds transient;
	self.cargoId.expandCargoIDs(allCargoIds);
	
	usedProxy:=true;
	if self.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		eventReq := app.myPassport.getObjectOfTypeFromOid(self.cmObjectId,CM_EventRequestStops).CM_EventRequestStops;
		if app.myPassport.hasErrors then
			return false;
		endif;
		if eventReq &lt;&gt; null then
			// Setup for update - cloned from CMUI_EventRequestModal::doSaveNotify
			beginLoad;
			pxyFromReal := eventReq.pxyCreateUpdateProxy().CM_EventRequestStops;
			endLoad;
			usedProxy:=false;
		endif;
	endif;
	
	foreach cargoId in allCargoIds do
		index := 0;
		foreach stop in self.allStopTypes do
			index:=index +1;
			stopObj := app.myRoot.allStopsTable.getAtKey(stop.id);
			if stopObj = null then
				// Invalid request type
				app.raiseCMException2(Request_type_valid_user, stop.description, tmpUser.userName, 
							null, 
							null);
				return false;
			endif;
			
			if not usedProxy then
				pxyCargoUpdateRequest:=pxyFromReal;
				usedProxy:=true;
			else
				create pxyCargoUpdateRequest transient;
			endif;
			self.getStopDetails(index,isClear,txnRemarks,expiryDate,additionalInfo);
			
			pxyCargoUpdateRequest.setProxyRequestStops(EventRequestTypeStops,
												addresses,
												txnRemarks	,
												cargoId,
												tmpUser,
												cargoType,
												organisation,
												terminal,
												EventRequestPending,
												isClear,
												self.isNotify.asBooleanJMT,												
												self.reference,
												isAutoCleanup,
												stopObj,
												additionalInfo[1:30],
												expiryDate,
												false,
												null,null,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,   // 16/01/2017 cnwma1 TFS #2885
												null    // 16/01/2017 cnwma1 TFS #2885
												);
												
												
			_cmifEventReq.allPxyCargoUpdateRequests.add(pxyCargoUpdateRequest);
			
		endforeach;
		
		if self.cargoRemarks &lt;&gt; null then
			if not usedProxy then
				pxyCargoUpdateRequest:=pxyFromReal;
				usedProxy:=true;
			else
				create pxyCargoUpdateRequest transient;
			endif;
			pxyCargoUpdateRequest.setProxyRequestStops(EventRequestTypeRemarks,
												addresses,
												self.remarks	,
												cargoId,
												tmpUser,
												cargoType,
												organisation,
												terminal,
												EventRequestPending,
												isClear,
												self.isNotify.asBooleanJMT,												
												self.reference,
												isAutoCleanup,
												null,
												null,
												null,
												false,
												null,null,self.cargoRemarks,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,   // 16/01/2017 cnwma1 TFS #2885
												null    // 16/01/2017 cnwma1 TFS #2885
												);
												
												
			_cmifEventReq.allPxyCargoUpdateRequests.add(pxyCargoUpdateRequest);
			
		endif;
		
		if self.grade &lt;&gt; null then
			gradeObj:=app.myRoot.allAvailableAvailabilityGrades[grade.Integer];
			if gradeObj = null then
				continue;
			endif;
			
			if not usedProxy then
				pxyCargoUpdateRequest:=pxyFromReal;
				usedProxy:=true;
			else
				create pxyCargoUpdateRequest transient;
			endif;
			pxyCargoUpdateRequest.setProxyRequestStops(EventRequestTypeGrade,
												addresses,
												self.remarks	,
												cargoId,
												tmpUser,
												cargoType,
												organisation,
												terminal,
												EventRequestPending,
												isClear,
												self.isNotify.asBooleanJMT,												
												self.reference,
												isAutoCleanup,
												null,
												null,
												null,
												false,
												null,gradeObj,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,   // 16/01/2017 cnwma1 TFS #2885
												null    // 16/01/2017 cnwma1 TFS #2885
												);												
												
			_cmifEventReq.allPxyCargoUpdateRequests.add(pxyCargoUpdateRequest);
		endif;
		
		index := 0;
		foreach toDo in self.allToDoTaskDescs do
			index:=index +1;
			toDoObj:=app.myRoot.allToDoTaskDescsByShortDesc[toDo.shortDesc];		
			if toDoObj = null then
				// Invalid request type
				app.raiseCMException2(Request_type_valid_user, toDo.description, tmpUser.userName, 
							null, 
							null);
				return false;
			endif;
			
			if not usedProxy then
				pxyCargoUpdateRequest:=pxyFromReal;
				usedProxy:=true;
			else
				create pxyCargoUpdateRequest transient;
			endif;
			self.getToDoTaskDetail(index,isClear,todoRemarks);	
			pxyCargoUpdateRequest.setProxyRequestStops(EventRequestTypeToDo,
												addresses,
												self.remarks	,
												cargoId,
												tmpUser,
												cargoType,
												organisation,
												terminal,
												EventRequestPending,
												isClear,
												self.isNotify.asBooleanJMT,												
												self.reference,
												isAutoCleanup,
												null,
												null,
												null,
												false,
												toDoObj,null,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												todoRemarks,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,   // 16/01/2017 cnwma1 TFS #2885
												null    // 16/01/2017 cnwma1 TFS #2885
												);												
												
			_cmifEventReq.allPxyCargoUpdateRequests.add(pxyCargoUpdateRequest);
		endforeach;
		
		//epr TFS 38003 17/4/18 web portal needs to update total weight
		if self.totalWeight &lt;&gt; null then
			if not usedProxy then
				pxyCargoUpdateRequest:=pxyFromReal;
				usedProxy:=true;
			else
				create pxyCargoUpdateRequest transient;
			endif;
			pxyCargoUpdateRequest.setProxyRequestStops(	EventRequestTypeWeight,
											addresses,
											self.remarks	,
											cargoId,
											tmpUser,
											cargoType,
											organisation,
											terminal,
											EventRequestPending,
											false,
											self.isNotify.asBooleanJMT,												
											self.reference,
											isAutoCleanup,
											null,
											null,
											null,
											false,
											null,null, null,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,   // 16/01/2017 cnwma1 TFS #2885
											null,   // 16/01/2017 cnwma1 TFS #2885
											null    // 16/01/2017 cnwma1 TFS #2885
											);
			pxyCargoUpdateRequest.setProxyWeightCertified(self.totalWeight.asDecimalJMT,self.isCertified, self.weighCertifyingPerson, self.weightCerifyingAuthority);
			_cmifEventReq.allPxyCargoUpdateRequests.add(pxyCargoUpdateRequest);
		endif;
		
	endforeach;
	
	
	if self.isNotify.asBooleanJMT() and not self.allNotifyTimes.isEmpty() then
		beginLoad;
		realEmail := tmpUser.allEventRequestEmail[EventRequestTypeStops];
		if realEmail &lt;&gt; null then
			pxyEmail := realEmail.pxyCreateUpdateProxy();
		else
			create pxyEmail transient;
		endif;
		pxyEmail.setProxy(app.myRoot, tmpUser, EventRequestTypeStops, self.allNotifyTimes);
		endLoad;
	endif;
	
	_cmifEventReq.myPxyEventRequestEmail := pxyEmail;	
epilog
	delete addresses;
	delete stringAddresses;
	delete allCargoIds;
end;</source>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c6cc8576-5466-4b01-a28f-317ebc571dc0">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars

begin
	self.allStopTypes.purge();
	self.allToDoTaskDescs.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getActivityType" id="cb1cce60-a91e-47b0-9de6-b32c2cfe4e37">
        <source>getActivityType() : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars
	retVal : String;
begin
	if not self.allStopTypes.isEmpty() then
		retVal := self.allStopTypes.first().id.String;
	endif;
	
	//cnwmc5 - 30 Jan 2015 - PAR 35003 - all below
	if not self.allToDoTaskDescs.isEmpty() then
		retVal := self.allToDoTaskDescs.first().shortDesc.String;
	endif;
	
	if self.grade &lt;&gt; null then
		retVal := grade;
	endif;
	
	if self.cargoRemarks &lt;&gt; null then
		retVal := cargoRemarks;
	endif;
	
	return retVal;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCMTypeDesc" id="96f7e0e1-e7c6-4cff-9baf-6009ee45c7dd">
        <source>getCMTypeDesc() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation - needs translation

*/
begin
	return "Cargo Stop";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJMTUpdatePermission" id="076680c3-869b-4a67-a965-1d595b2e500c">
        <source>getJMTUpdatePermission(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	return PmEventReqStopsMaint;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStopDetails" id="5398d162-e0b7-49df-89c6-9d672d1e62c0">
        <source>getStopDetails(_index : Integer;
				_isClear : Boolean output;
				_transactionRemarks : String output;
				_clearanceExpiry : Date output ;
				_additionalInfo : String output) protected ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlger1	Initial creation 38003 web portal cargo update

*/

vars
	stopDetailArray,
	stopDetailsArray : HugeStringArray;
	stopDetail : String;
begin
	create stopDetailsArray transient;
	stops.getTokensForDelimiterHuge("|", stopDetailsArray);
	
	if stopDetailsArray.size &lt; _index then
		return;
	endif;
	stopDetail:=stopDetailsArray[_index];
	create stopDetailArray transient;
	stopDetail.getTokensForDelimiterHuge(";",stopDetailArray);
	_isClear:=self.isClear.asBooleanJMT();
	_transactionRemarks:=self.remarks;
	_clearanceExpiry:=self.clearanceExpiryDate.asDateFromWebInterface;
	_additionalInfo:=self.additionalRequiredInfo;
	if stopDetailArray.size &gt; 1 then
		_isClear := stopDetailArray[2] = "Clear";
	endif;
	if stopDetailArray.size &gt; 2 then
		_transactionRemarks := stopDetailArray[3];
	endif;
	if stopDetailArray.size &gt; 3 then
		_clearanceExpiry := stopDetailArray[4].asDateFromWebInterface;
	endif;
	if stopDetailArray.size &gt; 4 then
		_additionalInfo := stopDetailArray[5];
	endif;
epilog
	delete stopDetailArray;
	delete stopDetailsArray;
end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_isClear" type="Boolean" usage="output"/>
        <Parameter name="_transactionRemarks" type="String" usage="output"/>
        <Parameter name="_clearanceExpiry" type="Date" usage="output"/>
        <Parameter name="_additionalInfo" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDetail" id="6d77b4e5-8644-46c6-a821-902a7d357e2c">
        <source>getToDoTaskDetail(_index : Integer;
				_isClear : Boolean output;
				_todoRemarks : String output) protected ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlger1	Initial creation 38003 web portal cargo update

*/

vars
	todoDetailArray,
	todoDetailsArray : HugeStringArray;
	todoDetail : String;
begin
	create todoDetailsArray transient;
	toDoTasks.getTokensForDelimiterHuge("|", todoDetailsArray);
	
	if todoDetailsArray.size &lt; _index then
		return;
	endif;
	todoDetail:=todoDetailsArray[_index];
	create todoDetailArray transient;
	todoDetail.getTokensForDelimiterHuge(";",todoDetailArray);
	_isClear:=self.isClear.asBooleanJMT();
	_todoRemarks:=self.toDoRemarks;
	
	if todoDetailArray.size &gt; 1 then
		_isClear := todoDetailArray[2] = "Clear";
	endif;
	if todoDetailArray.size &gt; 2 then
		_todoRemarks := todoDetailArray[3];
	endif;

epilog
	delete todoDetailArray;
	delete todoDetailsArray;

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_isClear" type="Boolean" usage="output"/>
        <Parameter name="_todoRemarks" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="matchesActivityType" id="59e94e67-ba39-4312-aacc-ee93838bf7e7">
        <source>matchesActivityType(eventReq: CM_EventRequestStops; activityStr: String): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwkao1	Initial creation

*/

vars
	retVal : Boolean;
	
begin
	if eventReq.myStopsTable &lt;&gt; null and not self.allStopTypes.isEmpty() then
		retVal := eventReq.myStopsTable.id = activityStr.Integer;
	endif;
	
	//cnwmc5 - 30 Jan 2015 - PAR 35003 - all below
	if eventReq.myToDoTaskDesc &lt;&gt; null and not self.allToDoTaskDescs.isEmpty()  then
		retVal := eventReq.myToDoTaskDesc.shortDescription = activityStr;
	endif;
	
	if eventReq.myGrade &lt;&gt; null and self.grade &lt;&gt; null then
		retVal := eventReq.myGrade.code = activityStr.Integer;
	endif;
	
	if eventReq.cargoRemarks &lt;&gt; null and self.cargoRemarks &lt;&gt; null  then
		retVal := eventReq.cargoRemarks = activityStr;
	endif;
	
	return retVal;
	
epilog

end;</source>
        <Parameter name="eventReq" type="CM_EventRequestStops"/>
        <Parameter name="activityStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupIterator" id="993cdb83-92a6-465d-b4ea-54f3ee232423">
        <source>setupIterator(organisation: CM_Organisation): Iterator protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars
	iter : Iterator;
begin	
	// Check most recent first
	iter := organisation.allEventRequestsStops.createIterator;
	organisation.allEventRequestsStops.startKeyLeq(self.status, Max_Integer.Binary.TimeStamp, iter);
	return iter;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="organisation" type="CM_Organisation"/>
        <ReturnType type="Iterator"/>
    </JadeMethod>
    <JadeMethod name="stops" id="778d2119-8ebf-4db7-b878-45ef81fab119">
        <methodInvocation>mapping</methodInvocation>
        <source>stops(set : Boolean; _value : String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason 
10 September 2008	cnwkao1	Initial creation

*/
vars
	stopDetailArray,
	stopIdsArray	: HugeStringArray;
	id,
	stopId			: String;
	stop			: WS_Stop;
	stopsTable		: CM_StopsTable;
begin
	if set then
		create stopIdsArray transient;
		_value.getTokensForDelimiterHuge("|", stopIdsArray);
		foreach stopId in stopIdsArray do
			//epr tfs 38003 web portal cargo update
			delete stopDetailArray;
			create stopDetailArray transient;
			stopId.getTokensForDelimiterHuge(";", stopDetailArray);
			if stopDetailArray.size = 0 then
				continue;
			endif;
			id:=stopDetailArray[1];
			stopsTable := app.myRoot.allStopsTable.getAtKey(stopId.Integer);
			if stopsTable &lt;&gt; null then
				create stop transient;
				stop.description	:= stopsTable.heading;
				stop.id				:= stopId.Integer;		
				self.allStopTypes.add(stop);
			endif;
		endforeach;	
	endif;	
epilog
	delete stopIdsArray;
	delete stopDetailArray;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="toDoTasks" id="5ddc0345-48db-4867-bea8-9fe8c473ae41">
        <methodInvocation>mapping</methodInvocation>
        <source>toDoTasks(set : Boolean; _value : String io) mapping;
/*

Date		Who		Reason
12 May 2014	cnwer1	Initial creation PAR

*/

vars
	todoDescArray,
	todoIdsArray	: HugeStringArray;
	id,
	todoId			: String;
	todo			: WS_ToDoTaskDesc;
	todoTable		: CM_ToDoTaskDesc;
begin
	if set then
		create todoIdsArray transient;
		_value.getTokensForDelimiterHuge("|", todoIdsArray);
		foreach todoId in todoIdsArray do
			//epr tfs 38003 web portal cargo update
			delete todoDescArray;
			create todoDescArray transient;
			todoId.getTokensForDelimiterHuge(";", todoDescArray);
			if todoDescArray.size = 0 then
				continue;
			endif;
			id:=todoDescArray[1];
			todoTable := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(id);
			if todoTable &lt;&gt; null then
				create todo transient;
				todo.description	:= todoTable.description;
				todo.shortDesc		:=todoTable.shortDescription;	
				self.allToDoTaskDescs.add(todo);
			endif;
		endforeach;	
	endif;	
epilog
	delete todoIdsArray;	
	delete todoDescArray;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
