    <JadeMethod name="openBRwithVoyage" id="ba4ee2b4-1c1a-4d08-b4a6-caf093350069">
        <updating/>
        <source>openBRwithVoyage(_voyage :CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:     05/08/08 by cnwaer1
//
// Purpose:     Voyage booking change - for CCMS SFW 1037
// ---------------------------------------------------------------------------
vars
	invalidVoyage : Boolean;
	voyageCode	  : String;
begin
	on Exception do app.handleDeletedObject(exception, _voyage, invalidVoyage);

	self.mode 				:= Mode_Search;
	self.numItemsShown		:= 0;
	self.numItemsSearched	:= 0;
	self.isDataFiltered 	:= true;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(SearchingForData), null);
	voyageCode := _voyage.code ;
	
	if invalidVoyage then
		app.raiseCMException(Object_Deleted, 'Voyage', null);
		return;
	endif;
	// Set the combobox text
	self.tblSearch.setValueByControlName(self.cmbFiltVoyage.name, voyageCode);
	self.myAssistant.comboBoxVoyageCurrent(	cmbFiltVoyage,
											_voyage,
											true,
											false,
											false,
											true,
											true,
											true,
											true,
											false,
											false);	

	//set filter value for search
	self.filterVoyageCode := _voyage.code.String;
	
	//search and display
	self.zTblDataSortAndShow(true);
	
	self.postSearchProcessing();
	self.isThumbnailVisible := false; // dh for apmt this will be hidden

epilog
	self.frmModalDialog.visible := false;
	self.mode := Mode_View;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="openSplitRollForm" id="6cddc49b-220c-47ae-9bae-621e2ec11b35">
        <updating/>
        <source>openSplitRollForm(_isSplit : Boolean) updating;
// 10/03/2010	cnwcs5	par 22602 - avoid exception if booking does not have voyage
vars
	form : Form;
begin
	/*form	:= app.loadForm(GTE_BookingRollSplitForm,
					GTE_Assistant,
					false, true, false,
					self.myTerminal,
					null);
	form.GTE_BookingRollSplitForm.setIsSplit(_isSplit);
//	if myInterfaceBookingRef &lt;&gt; null then
		form.GTE_BookingRollSplitForm.setBookingRef(myCurrentObject.CM_BookingRef);
//	endif;
//	form.GTE_BookingRollSplitForm.setupForm;*/
	//-cnwml2 PAR24322
	/*if self.myCurrentObject.CM_BookingRef.myVoyage = null or 
		self.myCurrentObject.CM_BookingRef.myVoyage.isNullVoyage then
		app.raiseCMException1(Must_spec_voyage_before_split, self.myCurrentObject.CM_BookingRef.bookingReference.asStringJMT(), null, null);
		return;
	endif;*/

	form	:= 	app.loadForm(GTE_BookingRollSplitForm,
					GTE_Assistant,
					false, false, true,
					self.myTerminal,
					null);
	form.GTE_BookingRollSplitForm.setIsSplit(_isSplit);
	if self.myCurrentObject.CM_BookingRef &lt;&gt; null then
		form.GTE_BookingRollSplitForm.setBookingRef(self.myCurrentObject.CM_BookingRef);
	endif;
	
	modalResult:=form.showModal;
end;</source>
        <Parameter name="_isSplit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postSearchProcessing" id="52b3be32-d5ac-455b-b90e-5a10961e8342">
        <updating/>
        <source>postSearchProcessing() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2013	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.applyColumnFilter( self.tblData );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="33c81927-7864-4d47-900b-1f6cf73d45f9">
        <source>resetNotifications();

vars

begin
	inheritMethod();
	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefAdd), Response_Continuous, 0);
	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefUpdate), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);				//+cnwml2 PAR21708
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete), Response_Continuous, 0);				//+cnwml2 PAR21708

end;</source>
    </JadeMethod>
    <JadeMethod name="saveBookingRef" id="872d9b7c-ffac-4ad9-85a3-47cb7c96acf1">
        <updating/>
        <source>saveBookingRef() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     Scrapes the Booking Reference details from the entry table,
//				updates the proxy, then calls a transaction to update the
//				real object.
//
// Parameters:  None
//
// Returns:     True if the update was successful, otherwise false.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bookingRef		: CM_BookingRef;
	errObj			: CM_Error;
	result			: Integer;
	
begin 	
	if self.myProxyObject = null then
		if self.mode = Mode_Add then
			create self.myProxyObject as CM_BookingRef transient;
			self.myInterfaceBookingRef.setMyProxyBookingRef(self.myProxyObject.CM_BookingRef);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	bookingRef := self.myProxyObject.CM_BookingRef;
	
	// par 25648 - check that self.myCurrentBRItemInterface is not null before
	// deciding it needs to be re-created.  We only want to update self.myCurrentBRItemInterface
	// with details from tblExtra if we are NOT a nulti line booking reference
	if self.myCurrentBRItemInterface &lt;&gt; null and						// par25648 cnwcs5 06/09/2010
		not app.isValidObject(self.myCurrentBRItemInterface) then		// deleted by epilog of CM_BookingRef::setForCreateMulti
		self.myCurrentBRItemInterface := self.myInterfaceBookingRef.createInterfaceItem(null, null);
	endif;
	
	if self.myCurrentBRItemInterface &lt;&gt; null then
		// save the unchanged details from the Extra table into the selected BRItem interface
		// this is only for single line booking refs.  For multi line booking refs
		self.setBRItemInterfaceFromTable(myCurrentBRItemInterface);
	endif;
	self.setPxyBookingRefFromTables(bookingRef);	//par 28583 27 Oct 2011 cnwrs1 setup the proxy after getting the data from the screen
	
	while true do
		if self.mode = Mode_Add then 
			app.myTrxCA.trxCreateBookingRefMulti(	self.myInterfaceBookingRef,
													app.myPassport,
													self.myMasterMenuAction,
													self.myCurrentObject);
		else 
			app.myTrxUA.trxUpdateBookingRefMulti(self.myInterfaceBookingRef, app.myPassport, self.myMasterMenuAction);
		endif;

		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Booking Refs', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			errObj := app.myPassport.allErrorWarnings.first();
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;
	endwhile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
