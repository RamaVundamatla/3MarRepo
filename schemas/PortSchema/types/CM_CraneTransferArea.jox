    <JadeMethod name="isValidAreaForRTMoveMethod" id="a06b5100-3dbb-4d1b-9e3a-e40a9f12cb91">
        <source>isValidAreaForRTMoveMethod(_rtMoveMethod: CM_RTMoveMethod; _isSource: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars

begin
	
	if _isSource then
		if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_RTG 	then
			return false;
		endif;
	else
		if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_RTG then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="90beebf9-aec2-4435-b71f-33388c90f660">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 28 September 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	area	: SelfType;
	pxyLane,
	lane	: CM_LocationsController;
	completedOK		: Boolean;
	
begin

	area := inheritMethod();
	
	foreach lane in self.lanes do
		pxyLane := lane.pxyCreateUpdateProxy();
		area.lanes.add(pxyLane);
		if self.loadLanes.includes(lane) then
			area.loadLanes.add(pxyLane);
		endif;
		
		if self.dischargeLanes.includes(lane) then
			area.dischargeLanes.add(pxyLane);
		endif;
		pxyLane.setMyTerminalAreaProxy(area);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return area;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete area;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyUpdateLaneCount" id="893e5acc-8ed8-4150-ae0b-c9b231723c19">
        <updating/>
        <source>pxyUpdateLaneCount(_value : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2013	cnwer1	Initial creation 31244

*/

vars
	lanesSize, int  : Integer;
	pxyLane,lane : CM_CraneLaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	
	lanesSize:=self.lanes.size;
	if _value = lanesSize then
		return;	// nothing to do
	endif;
	if  _value &gt; lanesSize then
		// add lanes

		foreach int in (lanesSize + 1) to _value do
			create pxyLane transient;
			pxyLane.setProxy(self);
			pxyLane.setNumberOfTwinLiftCages(1);
			self.lanes.add(pxyLane);
			self.loadLanes.add(pxyLane);
			self.dischargeLanes.add(pxyLane);
		endforeach;
	elseif _value &lt; lanesSize then
		//delete extra lanes
		int := lanesSize;
		
		while int &gt; _value do
			lane := self.lanes[int].CM_CraneLaneController;
			
			if self.loadLanes.includes(lane) then
				self.loadLanes.remove(lane);
			endif;
			
			if self.dischargeLanes.includes(lane) then
				self.dischargeLanes.remove(lane);
			endif;
			
			self.lanes.remove(lane);
			lane.erase (NORMAL_ERASE);	// make sure we delete lane devices
			
			
			int := int - 1;
		endwhile;
		
	endif;
	
	self.numLanes:=_value;

epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1bb323d9-face-4708-aead-d667a44bd94a">
        <updating/>
        <source>setForCreate(_proxy :CM_CraneTransferArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_CraneTransferArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// ---------------------------------------------------------------------------


vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.createLC(_proxy);
	
	self.numLanes 			:= _proxy.numLanes;
	self.autoPlanEnabled 	:= _proxy.autoPlanEnabled;
    // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
    // So the field of all the other area will be set to be false.    

	inheritMethod(_proxy, _passport);

	self.createSwapStack;

end;</source>
        <Parameter name="_proxy" type="CM_CraneTransferArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7fbbfe1f-2136-4394-96a5-fdeeafe5f493">
        <updating/>
        <source>setForUpdate(_proxy :CM_CraneTransferArea) updating;
//setForUpdate(_proxy : CM_CraneTransferArea) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.type := _proxy.type;
	
	self.createLC(_proxy);
	
	self.numLanes := _proxy.numLanes;
//	self.typeString := _proxy.typeString;
	self.autoPlanEnabled := _proxy.autoPlanEnabled;
    // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
    // So the field of all the other area will be set to be false.    
	
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="CM_CraneTransferArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateLanes" id="d51fc30f-e47c-42d1-8862-94677beacce9">
        <updating/>
        <source>setForUpdateLanes(_theLLanes, _theDLanes : CM_LCArray) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.loadLanes.clear();
	self.dischargeLanes.clear();
	
	_theLLanes.copy(self.loadLanes);
	_theDLanes.copy(self.dischargeLanes);
	
end;</source>
        <Parameter name="_theLLanes" type="CM_LCArray"/>
        <Parameter name="_theDLanes" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="201321f3-c6fa-451d-bcd5-03402f146e0c">
        <updating/>
        <source>setProxy(pID,
		 pComment			: String; 
		 pType 				: Integer;
		 pNumLanes 			: Integer;
		 pRel 				: Boolean;
		 pTerm				: CM_Terminal;
		 pAutoPlanEnabled,
		 _stockControlled 	: Boolean;
		 _hideFromOverView 	: Boolean;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
// 3 Apr 2013 	cnwer1		par 31244
vars
	index		: Integer;
	aLCProxy	: CM_CraneLaneController;
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(pID, pComment, pType, pRel, pTerm,false, _stockControlled, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	self.numLanes := pNumLanes;
	
	if self.numLanes = 0 then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_CTA_NO_LANES, null, null);
		return;
	endif;
	
	
//   self.autoPlanEnabled := pAutoPlanEnabled; can't set this in the gui so always false
    // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
    // So the field of all the other area will be set to be false.    	
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pNumLanes" type="Integer"/>
        <Parameter name="pRel" type="Boolean"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="pAutoPlanEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="validate" id="63baf66d-3f17-4eb3-b1a2-21c01da8653c">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MAX_CRANE_LANES : Integer = 8;
	MIN_CRANE_LANES : Integer = 1;
vars
	lane : CM_LocationsController;
begin
	self.raiseExceptionIfNotTransient(method);

	if self.numLanes &gt; MAX_CRANE_LANES then
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Number Of Lanes", ". Please enter a value between " &amp; MIN_CRANE_LANES.String &amp; " &amp; " &amp; MAX_CRANE_LANES.String &amp; ".", null, null);
		return;		
	endif;
	if self.numLanes &lt; MIN_CRANE_LANES  then
		app.setContinueCMExceptions(true);
		app.raiseCMException(ERR_CTA_NO_LANES, null, null);
		return;		
	endif;
	
	
	//check that there is atlease one load lane epr 28/3/13 moved code from the voyage lane queue validation
	if self.loadLanes.isEmpty then
		app.raiseCMException(Please_select_least_load_lane,null,null);
		return;
	endif;
	
	//lanes can be neither load or discharge i.e. disabled.
	/*
	//lane must be either a load or discharge lane
	foreach lane in self.lanes do
		if not self.loadLanes.includes(lane) and not self.dischargeLanes.includes(lane) then
			app.raiseCMException1(Crane_trans_lane_load_or_disch,lane.CM_CraneLaneController.getLaneId,null,null);
			return;
		endif;
	endforeach;*/
	
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0f241848-4dae-48cd-b418-f2973095cf62">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/07/2014   CNWMA1		PAR#34514 - ERROR: Attempted Access via null object reference
// ---------------------------------------------------------------------------
vars
	bc	:	CM_LocationsController;



begin

	foreach bc in self.lanes do
		if bc.hasTIs then
			app.raiseCMException2(ERR_LC_HAS_TIS,bc.getFullId, null,null, null); // PAR 20584 AKB2009SEP
			break;
		endif;
	endforeach;

	foreach bc in self.dischargeLanes do
		if bc.hasTIs then
			app.raiseCMException2(ERR_LC_HAS_TIS,bc.getFullId, null,null, null); // PAR 20584 AKB2009SEP
			break;		
		endif;
	endforeach;

	foreach bc in self.loadLanes do
		if bc.hasTIs then
			app.raiseCMException2(ERR_LC_HAS_TIS,bc.getFullId, null, null, null); // PAR 20584 AKB2009SEP
			break;		
		endif;
	endforeach;
	
	 
	if self.crane &lt;&gt; null then														// 08/07/2014	PAR34514  CNWMA1
		app.raiseCMException2(ERR_LC_HAS_MAC,bc.getFullId, self.crane.getID, null, null); 
		
	endif;
	
	inheritMethod();

end;</source>
    </JadeMethod>
</Class>
