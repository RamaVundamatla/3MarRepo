    <JadeMethod name="btnTerminate_click" id="fedac325-c3ce-42a7-879f-761b35ae79fb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTerminate_click(btn:Button input) updating;

vars
i : Integer;

begin
	if app.msgBox("Are you sure you want to terminate replay?", "Terminate Replay?", MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		pbclassorder.clear; 
		i := app.atcgTerminateReplayApp;//askAboutRollback is not needed as it is done anyway when the execution gets back to doPlayback.
		playbackInProgress:=false;
		setStatus("Test execution aborted at user request");
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canRollBack" id="9fc4a4da-a7b3-4a02-890f-afb3828fe002">
        <source>canRollBack():Boolean;

vars
	nod : Node;
	proc : Process;
	nok : Boolean;
begin
	while true do : outer
		foreach nod in system.nodes do 
			nok := false;
			foreach proc in nod.processes do
				if nod.isServerNode or nod = node /* ie, control app node */ or proc.persistentApp.name = "AtcgRecordApp" then 
					nok:= true;
				endif;
				if system.getTimeInTransactionState(proc) &gt; 0 then
					if app.msgBox("Process " &amp; proc.atcgShowDetails &amp; " is in transaction state, which prevents rollback."&amp;CrLf&amp;CrLf&amp;"Please remedy this situation and then retry or cancel the rollback.", "Rollback Error Retry", MsgBox_Exclamation_Mark_Icon + MsgBox_Retry_Cancel) = MsgBox_Return_Retry then
						continue outer; // Retry from the beginning
					else 
						app.atcgLogMessage("Process " &amp; proc.atcgShowDetails &amp; " is in transaction state, which prevents rollback.");
						return false;
					endif;
				endif;
			endforeach;
		
			if not nok then 
				if app.msgBox("Node " &amp; nod.name.String &amp; " with a process id of " &amp; nod.osID.String &amp; " does not allow for safe rollback "&amp; CrLf &amp; " Please close the offending node" &amp; CrLf &amp; CrLf &amp; "Recheck valid to rollback", "Rollback Error Retry", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
					continue outer; // Retry from the beginning
				else 
					app.atcgLogMessage(nod.name.String &amp; " with a process id of " &amp; nod.osID.String &amp; " does not allow for safe rollback but Retry response set to false");
					return true; // Might as well break out here - they were warned it's not safe
				endif;
			endif;
		endforeach;
		return true;  // Life must be ok if I got to here
	endwhile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkAutoRollback_change" id="372762ba-425b-4c3d-8e89-10f0c44af05a">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAutoRollback_change(checkbox:CheckBox input) updating;

begin
	app.atcgAutoRollback:=checkbox.value;
	app.atcgLogMessage("AutoRollback="&amp;checkbox.value.String);
	if checkbox.value = false then
		askAboutRollback;
	endif;
end;
</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearRollbackPoint" id="18236828-341b-4dfb-83b6-5b846cac26ac">
        <updating/>
        <source>clearRollbackPoint() updating;

vars
	dba:JadeDatabaseAdmin;
begin
	create dba transient;
	dba.sendMsg("clearDatabaseRollbackStack");
	rollbackTime:=null;
	rollbackReloadClasses.purge;
epilog
	delete dba;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doGen" id="a680aaff-0c99-41d0-a858-08756c4ec00c">
        <updating/>
        <source>doGen() updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	rr:AtcgControl;
	cls:Class;
	classFile:String;
	pwf:AtcgPleaseWaitForm;
begin
	recordingInProgress:=false;
	setStatus("Generating...");
	if txtClassName.text = null then
		global.beep;
		setStatus("Please provide a class name");
		txtClassName.setFocus;
		return;
	endif;
	
	if txtClassName.text[1] &lt; "A" or txtClassName.text[1] &gt; "Z" then
		global.beep;
		setStatus("Please start the class name with a letter");
		txtClassName.setFocus;
		return;
	endif;
	
	if currentSchema.getConstant(txtClassName.text) &lt;&gt; null then
		global.beep;
		setStatus(txtClassName.text&amp;" is a global constant, please choose a different name for Generated Class Name");
		txtClassName.setFocus;
		return;
	endif;
	
	if currentSchema.getClass(txtClassName.text) &lt;&gt; null
	and app.msgBox("Class "&amp;txtClassName.text&amp;" already exists, do you want to overwrite it?", "Class Already Exists", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		txtClassName.setFocus;
		return;
	endif;
	
	if txtMethNamePref.text = null then
		global.beep;
		setStatus("Please provide a method name prefix");
		txtMethNamePref.setFocus;
		return;
	endif;
	
	if app.atcgCleanStartMode then
		setStatus("Stopping the record app");
		system.causeEvent(1147, true, "Terminate");
		terminateRecordApp(rr.targetProcess);
	endif;
	
	
	create rr transient;
	if app.atcgAutoRollback then
		askAboutRollback;
		if rollbackTime = null then
			// a rollback may have just been done, so reload classes as required
			foreach classFile in rollbackReloadClasses do
				rr.outFile.fileName:=classFile;
				rr.loadClassFile;
			endforeach;
			rollbackReloadClasses.purge;
		endif;
	endif;
	
	

	create pwf;
	pwf.lblMessage.caption:="Generating, please wait";
	pwf.lblMessage.backColor:=White;
	pwf.move(left-20, top+170, 500, 150);
	pwf.show;
	pwf.refreshNow;
	lastGenClassName:=txtClassName.text;
	delete app.atcgLog;  // create new one to get current file number
	app.atcgLogMessage(null);
	rr.inFile.fileName:=app.atcgLog.getActualFileName;
	rr.className:=txtClassName.text;
	rr.methodNamePrefix:=txtMethNamePref.text;
	rr.outFolderName:=rr.inFile.fileName.atcgWithoutFileName&amp;"/";
	rr.outFile.fileName:=rr.outFolderName&amp;rr.className&amp;"_"&amp;app.actualTimeServer.time.format("HHmmss")&amp;".cls";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.atcgLogMessage("generating class file "&amp;rr.outFile.fileName&amp;" from "&amp;rr.inFile.fileName);
	rr.genJadeVersion:="6.2.15";
	app.atcgGetControlOptions(rr.genSchema, rr.genSuperSchema, rr.genSuperClass, rr.logMessageMethod, rr.targetSchemas, rr.noiseMethods);
	rr.generatingValidationCommented:=chkGenValComment.value;
	rr.parseInputFile;
	//write "starting " &amp; app.actualTimeAppServer.String;
	
	if app.atcgAutoRollback and rollbackTime &lt;&gt; null then
		// a rollback point is set, so we may need to reload this class, so save the file name
		rollbackReloadClasses.add(rr.outFile.fileName);
	endif;
	rr.genClassFile;
	rr.loadClassFile;
	doWorkOutReplayClasses;
	
	setStatus("Class "&amp;txtClassName.text&amp;" loaded");
	pwf.unloadForm;
epilog
	delete rr;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doReplay" id="db238910-c159-445e-819c-2befae25cc8a">
        <updating/>
        <source>doReplay() updating;

vars
	i : Integer;
	rr:AtcgControl;
begin
	//GJtdMobileCommonSchema.firstInstance._clearAllBuffers;		// jlgmd1 27/08/2018 - TFS 40386 Jade 2016 Changes
	rr:=global.atcgMyControl;
	
	if pbclassorder.first = null then 
		playbackInProgress:=false;
		setStatus("finished executing all the requested jobs");
		if app.atcgAutoRollback then
			askAboutRollback;
			clearRollbackPoint;
		endif;
		return;
	else 
		beginTransaction;
		global.atcgReplayClassName := pbclassorder.first;
		commitTransaction;
		playbackInProgress:=true;
		setStatus("executing "&amp; global.atcgReplayClassName);
		app.atcgLogMessage("executing "  &amp; global.atcgReplayClassName);
		
		pbclassorder.remove(pbclassorder.first);
		app.startApplication(currentSchema.name, "AtcgReplayApp");
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doStart" id="248e51dd-d720-446c-b7cc-2b4b20290996">
        <updating/>
        <source>doStart() updating;

vars
	s,t,rollbackDisplay:String;
	rr:AtcgControl;
	proc,procSave:Process;
	pwf:AtcgPleaseWaitForm;
	schema:Schema;
begin
	rr:=global.atcgMyControl;
	if recordingInProgress and app.isValidObject(rr.targetProcess) and rr.targetProcess.persistentApp.name = rr.targetProcessName then
		if app.msgBox("A recording is already in progress. Are you sure you want to discard the recording?", "Sequence Anomaly", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		
		if app.atcgAutoRollback then
			askAboutRollback;
		endif;
		if app.atcgCleanStartMode then
			setStatus("Stopping the record app");
			terminateRecordApp(rr.targetProcess);
		endif;
	endif;
	
	if playbackInProgress then
		rr.addLogLine("must be already executing something so will exit " &amp; method.name &amp; " to avoid confusion");
		return;
	endif;
	
	if app.atcgCleanStartMode then
		setStatus("Starting the record app");
		startRecordApp;
	endif;
	
	rr.addLogLine("Starting...");
	if rr.targetProcess = null or not app.isValidObject(rr.targetProcess) or rr.trackedMethods.size = 0 then
		foreach proc in Process.instances do
			//if proc &lt;&gt; process and proc.userInfo.atcgContains("ShipLander/")  // allow for multiple record apps
			//if proc &lt;&gt; process and proc.userInfo.atcgContains("IMV/")
			if proc &lt;&gt; process
			and proc.persistentApp.name = rr.targetProcessName then
				if procSave &lt;&gt; null then
					global.beep;
					setStatus("Multiple "&amp;rr.targetProcessName&amp;" processes running");
					return;
				endif;
				procSave:=proc;
			endif;
		endforeach;/**/
		if procSave = null then
			global.beep;
			setStatus("Target process "&amp;rr.targetProcessName&amp;" not found");
			beginTransaction;
			rr.targetProcess:=null;
			commitTransaction;
			return;
		endif;

		s:="Starting method tracking for process "&amp;rr.targetProcessName&amp;", please wait...";
		rr.addLogLine(s);
		setStatus(s);
		create pwf;
		pwf.lblMessage.caption:="Starting method tracking"&amp;CrLf&amp;CrLf&amp;"Please Wait";
		pwf.lblMessage.backColor:=White;
		pwf.move(left-20, top+170, 500, 150);
		pwf.show;
		pwf.refreshNow;
		
		rr.stopMethodTracking;
		beginTransaction;
		schema:=currentSchema;
		while schema &lt;&gt; null do
			rr.superschemas:=rr.superschemas&amp;schema.name&amp;";";
			schema:=schema.superschema;
		endwhile;
		rr.targetSchemas.clear;
		rr.noiseMethods.clear;
		app.atcgGetControlOptions(rr.genSchema, rr.genSuperSchema, rr.genSuperClass, rr.logMessageMethod, rr.targetSchemas, rr.noiseMethods);
		rr.buildMethodSet;
		rr.targetProcess:=procSave;
		rr.generatingSource:=true;
		rr.generatingValidation:=chkGenValidation.value;
		rr.genValTableRowLimit:=10;
		commitTransaction;
	
		rr.startMethodTracking;
		pwf.unloadForm;
	endif;
	
	if rr.generatingValidation &lt;&gt; chkGenValidation.value then
		beginTransaction;
		rr.generatingValidation:=chkGenValidation.value;
		commitTransaction;
	endif;
	
	if app.atcgAutoRollback and rollbackTime = null then
		setRollbackPoint;
		rollbackDisplay:=", rollback point "&amp;rollbackTime.time.String;
	endif;
	
	recordingInProgress:=true;
	system.causeEvent(1147, true, "StartRecording");
	s:="Recording in progress for "&amp;rr.targetProcessName&amp;"/"&amp;getInstanceIdForObject(rr.targetProcess).String&amp;rollbackDisplay;
	rr.addLogLine(s);
	setStatus(s);
end;
</source>
    </JadeMethod>
    <JadeMethod name="doWorkOutReplayClasses" id="284217f8-6e3d-4881-a3dc-4825abd9f549">
        <source>doWorkOutReplayClasses();

vars
	cls	: Class;
	subs	: ClassColl;
begin
	pblistBox.clear;
	
	cls := currentSchema.getClass("JtdTransactionGenerator");
	
	if cls = null then
		//write "what the";
		return;
	endif;
	
	create subs transient;
	cls.allLocalSubclasses(subs);
	foreach cls in subs do 
		if cls.getMethod("runTest") = null then 
			continue;
			//ignore 
		elseif cls.getMethod("startup")= null then
			continue;
		else 
			pblistBox.addItem(cls.name);
		endif; 
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="formLoad" id="4a193f7c-07ba-47a5-bdb4-06ddb072337a">
        <updating/>
        <source>formLoad() updating;

vars
	rr:AtcgControl;
begin
	caption:="ATCG Control - "&amp;app.dbPath.toLower;
	rr:=global.atcgMyControl;  // this might create the rr object
	beginTransaction;
	rr.targetProcessName:="AtcgRecordApp";
	rr.targetProcess:=null;
	app.atcgGetControlOptions(rr.genSchema, rr.genSuperSchema, rr.genSuperClass, rr.logMessageMethod, rr.targetSchemas, rr.noiseMethods);
	commitTransaction;
	txtClassName.text:="TestProfile1";
	txtMethNamePref.text:="tp";
	chkGenValidation.value:=false;
	app.atcgSetRollbackEnabled;
	chkAutoRollback.enabled:=app.atcgRollbackEnabled;
	grpRollback.enabled:=app.atcgRollbackEnabled;
	chkAutoRollback.value:=app.atcgRollbackEnabled;
	if app.atcgRollbackEnabled then
		app.atcgAutoRollback:=chkAutoRollback.value;
	endif;
	btnStart.setFocus;
	setStatus("Ready");
	doWorkOutReplayClasses;
	beginNotification(process, 1148, Response_Continuous, 1148);
	beginNotification(system, 1149, Response_Continuous, 1149);
end;
</source>
    </JadeMethod>
