    <JadeMethod name="doMnuReleaseCargoClick" id="372cc34f-763f-4b76-9488-a3e15ecfde69">
        <updating/>
        <source>doMnuReleaseCargoClick(theMenuItem: MenuItem) updating;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//25/01/2016  cnwma1 PAR #37445 User defined Delivery Release Reasons not available in Release Transfer Area exit process
//--------------------------------------------------------------
vars
/*	idx : Integer;
	consign : CM_ConsigneeConsignor;
	obj : Object;
	reason : CM_DeliveryReleaseReason;
	index : Integer; */
	
		//23 Aug 2019	NDL	TFS 46020
	form : YRD_ReleaseFromTransferArea;
	obj : Object;
	tiSet : CM_TISet;
	msg : String;
	
begin

	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		tiSet.add(obj.CM_TrackedItem);
	endforeach;
	
	if tiSet.isEmpty then
		msg := app.getErrorString( No_Cargo_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;

	form := app.loadForm(	YRD_ReleaseFromTransferArea,
							YRD_Assistant,
							false,							// Maximized
							false,							// Show
							true,							// Modal
							self.myTerminal,
							null ).YRD_ReleaseFromTransferArea;
	
	form.setTisToRelease( tiSet );
	form.myParentForm := self;
	form.showModal;
	

/*	inheritMethod(theMenuItem);
    self.releaseCargoHideControls(false);
	self.txtDeliveryNum.text := null;
	self.cmbOpt1.clear();
	self.cmbOpt2.clear();
	self.chkEmailConsign.value := true;
				
	foreach consign in app.myRoot.allConsigneeConsignors do
		idx := self.cmbOpt1.addItem(consign.code &amp; ' ' &amp; consign.description);
		self.cmbOpt1.itemObject[idx] := consign;
	endforeach;			
	
	self.cmbOpt2.addItem(DELSTR_IST);
	self.cmbOpt2.addItem(DELSTR_NIB);
	self.cmbOpt2.addItem(DELSTR_PEX);
	self.cmbOpt2.addItem(DELSTR_RPK);
	self.cmbOpt2.addItem(DELSTR_SNT);
	self.cmbOpt2.addItem(DELSTR_TSC);
	
	foreach reason in app.myRoot.allDeliveryReasonselReasons do   //25/01/2016 cnwma1 PAR #37445
		index := self.cmbOpt2.addItem(reason.description);
		self.cmbOpt2.itemObject[index] := reason;
	endforeach;

	self.modalDialogShowCombos('Cancel', 'OK', null, 'Consignee', 'Delivery Reason');
	self.modalDialogShowForRelease();
	self.cmbOpt1.setFocus;
	self.txtDeliveryNum.tabIndex := 270;  	// the tabIndex on the form is 9132
	self.chkEmailConsign.tabIndex := 271; 	// the tabindex on the form is 9277
	self.btnModalOpt1.tabIndex := 272;		// the tabindex on the form is 124
	self.btnModalDefault.tabIndex := 273;	// the tabindex on the form is 123
	
	// turn off the tabIndex for all the controls following the btnModalDefault control
	// next tab has to bring up the cmbOpt1 
	
	foreach obj in self.allControlsByName where obj.Control.tabIndex &gt; 274  do
		obj.Control.tabStop:= false;
	endforeach; */

epilog
	
	delete form;
	delete tiSet;
	
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemarksClick" id="e7b6eaad-c6bf-4f0e-ae1f-a101216d8e11">
        <updating/>
        <source>doMnuRemarksClick(_menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2011	cnwmh5		#28531 - Change from .show to .showModal
// ---------------------------------------------------------------------------

vars
	lForm : CMUI_GetData;
	theTI : CM_TrackedItem;
begin
	if self.myCurrentObject = null then
		return;
	endif;
	
	theTI := self.myCurrentObject.CM_TrackedItem;

	create lForm;
	lForm.centreWindow;
	self.mousePointer := MousePointer_Default;
	
	lForm.lblTextCaption := app.getErrorString1( Additional_remarks_ti,theTI.id) ;
	
	lForm.txtReadOnly.visible := true;
	lForm.bigSize := true;
	lForm.txtReadOnly.text := theTI.remarks;
	lForm.txtData.text := null;
//	lForm.txtData.height := lForm.txtData.height * 5;
	lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
	lForm.myCaller := self;
	lForm.formCaption := app.getErrorString(Additional_remarks);
	lForm.type := self.GetData_Remarks;
	lForm.showModal;								
epilog
	mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuYardAllocBuild" id="da8c46fd-8ad8-4fce-97ee-ee4cdb9c0859">
        <updating/>
        <source>doMnuYardAllocBuild(_menuItem : MenuItem input) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars
	index :Integer;
	mnuChild,mnuMaster,
	tmpMenu	: MenuItem;
	ta		: CM_TerminalArea;
	yalloc : CM_YardAllocation;
begin

	_menuItem.visible := true;
	mnuMaster := _menuItem;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN";


	mnuChild := self.mnuYardAllocNew.description.asOid.MenuItem;
	while mnuChild &lt;&gt; null and index &lt; 50 do
		tmpMenu := null;
		index := index + 1;
		if mnuChild.description &lt;&gt; null then
			tmpMenu := mnuChild.description.asOid.MenuItem;
		endif;
		delete mnuChild;
		mnuChild := tmpMenu;
	endwhile;
	
	self.mnuYardAllocNew.description := null;
	
	mnuChild := self.zCloneMenu(mnuMaster, self.mnuYardAllocNew, true);	
	mnuChild.caption := "&amp;New Allocation...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "YAChild";
	mnuChild.userObject := null;

	tmpMenu := mnuChild;
	
	ta := self.filterTerminalArea;
	if ta = null then	//rs oct 2005 it may not be setup as yet
		return;
	endif;
	
	// CCMS 1013
	//foreach yalloc in ta.allYardAllocations do
	foreach yalloc in ta.allYardAllocations where yalloc.includeInYardDisplays() do
		
		mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true);	
		mnuChild.caption := yalloc.code &amp; "...";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := "YAChild";
		mnuChild.userObject := yalloc;
		tmpMenu := mnuChild;
	endforeach; 
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
