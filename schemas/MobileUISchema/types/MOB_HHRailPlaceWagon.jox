    <JadeMethod name="handleNotifications" id="c2c44b31-e979-4c5d-a7b5-a47c9da8eb95">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation

*/

vars

	mess : String;
	
begin

	if theObject = self.myMobileGenericAgent.myCurrentWagon or self.cmbWagon.listObject = theObject then
		mess := app.getErrorString1(DeletedByAnotherUser, app.getErrorString(Wagon));
		self.msgBox( mess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.handleBtnTwo();
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
