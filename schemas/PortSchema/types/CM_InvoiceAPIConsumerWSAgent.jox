    <JadeMethod name="doCreateActivityHistory" id="a42c644f-f0f8-4720-8dda-38bf5a154ec4">
        <updating/>
        <source>doCreateActivityHistory(_consumer: JadeWebServiceConsumer; _methodName: String; _request: String; _response: String; _responseCode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)
*/

vars
	pxyActivityMain			: CM_EWSActivityInvoiceAPI;	
	realActivityMain		: CM_EWSActivityInvoiceAPI;	
	pxyActivityPart			: CM_EWSActivityInvoiceAPIParts;	
	realActivityPart		: CM_EWSActivityInvoiceAPIParts;	
	statusString : String;
begin
	if self.myWebServiceDefinition = null then
		return;
	endif;
	
	//jlier1 16/9/24 TFS 65962 : CR 65949 NSW | Dynamic Integration Development
	if _responseCode = HttpResponseOK  or _responseCode = HttpResponseCreated then
		if not self.myWebServiceDefinition.allEndpoints.isEmpty then
			statusString:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SUCCESS; //we are not waiting for anything 
		else
			statusString:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SENT;
		endif;
	else
		statusString:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SEND_ERROR;
	endif;
	//navra1 - TFS54090-CR 61355/Task 61370 - 27th Nov 2023 - start
	if self.myEWSActivity = null then
		create pxyActivityMain transient;
		pxyActivityMain.initialiseFromInvoiceAndDef(self.myInvoice, self.myWebServiceDefinition, statusString);
		
		realActivityMain := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivityMain, app.myPassport).CM_EWSActivityInvoiceAPI;		
		if not app.myPassport.trxCompletedOK then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to create CM_EWSActivityInvoiceAPI - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogDEBUG);
			app.remoteErrorWarningToAlert(app.getErrorString(FailedToCreateActivityHist), null , app.myPassport.allErrors, null, false, false);
		endif;
		
		if realActivityMain &lt;&gt; null then	
			self.myEWSActivity := realActivityMain.CM_EWSActivityInvoiceAPI;
		endif;		
	else
		//this is an update - could of sent some successful messages but the last one had an error
		beginLoad;
			pxyActivityMain:=self.myEWSActivity.pxyCreateUpdateProxy();
			pxyActivityMain.fullMsgStatusStr:=statusString;
		endLoad;
		app.myTrxUA.trxUpdateEWSActivity(pxyActivityMain,app.myPassport);
	endif;

	create pxyActivityPart transient;
	pxyActivityPart.setProxyOnSend(self.myEWSActivity, _request, _responseCode, _response, statusString, self.myWebServiceDefinition,_methodName);
			
	realActivityPart := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivityPart, app.myPassport).CM_EWSActivityInvoiceAPIParts;		
	if not app.myPassport.trxCompletedOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to create CM_EWSActivityInvoiceAPIParts - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogDEBUG);
		app.remoteErrorWarningToAlert(app.getErrorString(FailedToCreateActivityHist), null , app.myPassport.allErrors, null, false, false);
	endif;
	//navra1 - TFS54090-CR 61355/Task 61370 - 27th Nov 2023 - end
	
	
	
epilog
	delete pxyActivityMain;
	delete pxyActivityPart;
	endLoad;
end;</source>
        <Parameter name="_consumer" type="JadeWebServiceConsumer"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_request" type="String"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_responseCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalHeadersForHTTP" id="340a9f9b-3046-4a1f-b175-060c3ec014a5">
        <source>getAdditionalHeadersForHTTP(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)
30 Augugst 2024		navmd1	TFS 65917 Return Error from Microsoft if oauth token fails

*/


vars
	header : String;
	token : String;	
	def : CM_InvoiceAPIServiceDef;
	errorResponse : String;

begin
	header := inheritMethod();
	
	if self.usercode &lt;&gt; null then
		header := header &amp; "Usercode:" &amp; self.usercode &amp; CrLf &amp;
					"Password:" &amp; self.password &amp; CrLf;
	endif;
	
	/* jlier1 4/9/24 task 65950 for CR 65949 - this stuff below is already done in the inherited method not sure why it gets the token twice
	
	def := self.myWebServiceDefinition.CM_InvoiceAPIServiceDef;
	if def.authKey &lt;&gt; null then
		header := header &amp; 
				"Auth-Key: " &amp; def.authKey &amp; CrLf &amp;
				"ClientKey: " &amp; def.clientKey &amp; CrLf;
	endif;
	
	if def.subscriptionKeyName &lt;&gt; null then
		header := header &amp; def.subscriptionKeyName &amp; ': ' &amp; def.subscriptionKeyValue &amp; CrLf;
	endif;
	
	if def.clientSecret &lt;&gt; null then
		token := app.getTokenFromEndpoint(self.myTerminal, CMIF_OAuthToken.TYPE_API, "https://login.microsoft.com/", def.clientKey, def.clientSecret, def.scope, def.tenantId, null, null, errorResponse);
		if token &lt;&gt; null then
			header := header &amp; 'Authorization: Bearer ' &amp; token &amp; CrLf;
		endif;
	endif;
	
	header := header &amp; "Content-Type: application/json";*/
	return header;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastEWSActivityPart" id="9258cc68-e52f-437f-a60c-3f44b1b43d8f">
        <source>getLastEWSActivityPart() : CM_EWSActivityInvoiceAPI protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2024	jlier1	Initial creation 65962

*/

vars
	lastEndPoint : CM_Endpoint;
	lastActivity : CM_EWSActivityInvoiceAPI;
	lastPart 	: CM_EWSActivityInvoiceAPI;
	iter : Iterator;
begin
	//if the last message was the update header should return true and just send the update header
	lastActivity:=self.myInvoice.allEWSInvoiceAPIActivities.last.CM_EWSActivityInvoiceAPI;
	if lastActivity = self.myEWSActivity then
		//if we have created activity for this attempt need to check the one before
		iter:=self.myInvoice.allEWSInvoiceAPIActivities.createIterator;

		if iter.back(lastActivity) then
			iter.back(lastActivity);
		endif;
		iter.current(lastActivity);
	endif;
	
	if lastActivity &lt;&gt; null then
		return lastActivity.allEWSMessageParts.last;
	endif;
	
	
	return null;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_EWSActivityInvoiceAPI"/>
    </JadeMethod>
    <JadeMethod name="getNSWInvoiceHeaderBody" id="db17a81f-3aae-4cde-b568-2a4d663cea4a">
        <source>getNSWInvoiceHeaderBody() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2024	jlier1	Initial creation 65959  CR 65949
16 Oct 2024	jlier1 	MTN-33103
23 OCt 2024 jlier1  MTN-33154 - was getting the wrong berth
29 Oct 2024	jlier1 	MTN-33304 - NSW | Dynamics Integration - Additional requirements identified
25 Nov 2024 jlier1  MTN-33449  - if voyage process is auto inward and external codes are stored in different attributes??
*/
constants 
	DataType =  "@odata.type";
	PAExternalInvoiceId  = "PAExternalInvoiceID";
	CurrencyCode = "CurrencyCode";
	CustomerAccount = "CustomerAccount";
	InvoiceDate = "InvoiceDate";
	PAOriginalInvoice = "PAOriginalInvoice";
	DocumentDate  = "DocumentDate";
	PAVesselDetail = "PAVesselDetail";
	PAVoyageDetail = "PAVoyageDetail";
	PAArrival = "PAArrival";
	PADeparture = "PADeparture";
	PABerthCode = "PABerthCode";
	PABillingGroup = "PABillingGroup";
	PAHeaderText = "PAHeaderText";
	LanguageId = "LanguageId";
	DataAreaId = "dataAreaId";
	InclTax	= "InclTax";
	PAReadyToInvoice = "PAReadyToInvoice";
vars
	jsonPostData : String;
	jdo : JadeDynamicObject;
	voyage : CM_Voyage;
	berth : HMS_Berth;
	firstInvoiceLine : CM_InvoiceLine;
	invoiceTypeDesc : String;
	arrivalDT,
	departureDT : TimeStamp;
	movement : HMS_Movement;
	isPBOT : Boolean;
begin
	create jdo transient;
	
	jdo.addProperty(DataType,String);
	jdo.setPropertyValue(DataType,"#Microsoft.Dynamics.DataEntities.FreeTextInvoiceHeader");
	jdo.addProperty(PAExternalInvoiceId,String);
	jdo.setPropertyValue(PAExternalInvoiceId,self.myInvoice.externalNumber);
	jdo.addProperty(CurrencyCode,String);
	jdo.setPropertyValue(CurrencyCode,"AUD");
	jdo.addProperty(CustomerAccount,String);
	if self.myInvoice.debtor.code &lt;&gt; null then
		jdo.setPropertyValue(CustomerAccount,self.myInvoice.debtor.code);
	endif;
	jdo.addProperty(InvoiceDate,String);
	jdo.setPropertyValue(InvoiceDate,self.myInvoice.postedDT.date.format("yyyy-MM-dd"));
	firstInvoiceLine:=self.myInvoice.invoiceLines.first;
	voyage:=firstInvoiceLine.getMyVoyageObject;
	if voyage &lt;&gt; null then
		movement:=voyage.getMovementForDateTime(firstInvoiceLine.chargeTime);
		arrivalDT:=voyage.arrivedDT;
		departureDT:=voyage.departedDT;
	endif;
	if movement &lt;&gt; null then
		//jlier1 JIRA#34034 &amp; 34033 NSW | D365 - Incorrect Dates in Header Call for Voyage Resource Based Invoices &amp; berth
		if not movement.isMovementTypeDeparture and movement.myNextMovement &lt;&gt; null then
			departureDT:= movement.myNextMovement.occursOnDTNEW;
		endif;

		if movement.isMovementTypeDeparture then
			if movement.myPreviousMovement &lt;&gt; null then
				movement:=movement.myPreviousMovement;
			endif;
		endif;
		berth:=movement.getMyBerth;
		arrivalDT:=movement.occursOnDTNEW;
	endif;
	
	isPBOT:=self.myTerminal.code = "PBOT";
	
	invoiceTypeDesc:=self.myInvoice.getInvoiceTypeDescription;
	if isPBOT then 
		jdo.addProperty(DocumentDate,String);
		if  invoiceTypeDesc = "Wharfage - Export" then
			jdo.setPropertyValue(DocumentDate,departureDT.date.format("yyyy-MM-dd"));
		else
			jdo.setPropertyValue(DocumentDate,arrivalDT.date.format("yyyy-MM-dd"));
		endif;
	endif;
	
	//jlier1 JIRA#33611 9/12/24
	if self.myInvoice.myPostedCreditInvoice &lt;&gt; null then
		jdo.addProperty(PAOriginalInvoice,String);
		jdo.setPropertyValue(PAOriginalInvoice,self.myInvoice.myPostedCreditInvoice.externalNumber);
	endif;
	
	if voyage &lt;&gt; null then	
		if voyage.myVessel &lt;&gt; null then
			jdo.addProperty(PAVesselDetail,String);
			jdo.setPropertyValue(PAVesselDetail,voyage.myVessel.name);
		endif;
		
		jdo.addProperty(PAVoyageDetail,String);
		//jlier1 MTN-33449 25/11/24
		if  invoiceTypeDesc = "Wharfage - Export" then
			jdo.setPropertyValue(PAVoyageDetail,voyage.getVoyageCodeExternalForJRW);
		else
			jdo.setPropertyValue(PAVoyageDetail,voyage.getInwardCodeForJRW);
		endif;
	endif;
	jdo.addProperty(PAArrival,String);
	jdo.setPropertyValue(PAArrival,arrivalDT.systemToUTC.asJSONFormat);
	jdo.addProperty(PADeparture,String);
	jdo.setPropertyValue(PADeparture,departureDT.systemToUTC.asJSONFormat);
	if berth &lt;&gt; null then
		jdo.addProperty(PABerthCode,String);
		jdo.setPropertyValue(PABerthCode,berth.externalReference1);	
	endif;
	
	jdo.addProperty(PABillingGroup,String);
	if invoiceTypeDesc = "Wharfage - Export" or invoiceTypeDesc = "Wharfage - Import" then
		jdo.setPropertyValue(PABillingGroup,"Wharfage");
	else
		jdo.setPropertyValue(PABillingGroup,invoiceTypeDesc);
	endif;
	if self.myInvoice.myInvoiceNote &lt;&gt; null and self.myInvoice.myInvoiceNote.internalOnly = false then
		jdo.addProperty(PAHeaderText,String);
		jdo.setPropertyValue(PAHeaderText,self.myInvoice.myInvoiceNote.note);
	endif;
	jdo.addProperty(LanguageId,String);
	jdo.setPropertyValue(LanguageId,"en-AU");
	jdo.addProperty(DataAreaId,String);
	jdo.setPropertyValue(DataAreaId,self.myTerminal.code);
	
	jdo.addProperty(InclTax,String);
	jdo.setPropertyValue(InclTax,'No');

	jdo.addProperty(PAReadyToInvoice,String);
	jdo.setPropertyValue(PAReadyToInvoice,'No');
	
	jdo.deserializeJSON(jsonPostData);
	
	return jsonPostData;
epilog
		delete jdo;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNSWInvoiceLinesBody" id="53b9e30c-2965-480f-b082-8d6ed72a7f4a">
        <source>getNSWInvoiceLinesBody(headerID : String; baseURL : String) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2024	jlier1	Initial creation 65959  CR 65949
06 Nov 2024	jlier1	MTN 33395 - line break between line header and body
19 Nov 2024 jlier1 	MTN-22438 - Issues with invoice line - some fields need to be numeric not string and rounded
15 Jan 2025	navhl20 Bug MTN-33758: NSW | D365 - Issues with Invoice Line Call for Voyage Invoices
23 Jan 2025 jlier1  33835	- removed TransactionCurrencyAmount
*/
constants 

	ParentRecId  = "ParentRecId";
	SalesTaxItemGroupId = "SalesTaxItemGroupId";
	LineNumber = "LineNumber";
	Description = "Description";
	MainAccountDisplayValue = "MainAccountDisplayValue";
	DefaultDimensionDisplayValue  = "DefaultDimensionDisplayValue";
	PAUnit = "PAUnit";
	Quantity = "Quantity";
	UnitPrice = "UnitPrice";
	DataAreaId = "dataAreaId";
	Free = "FREE";
	GST = "GST";
vars
	body,bodyEnd,invoiceLineGrpJSON : String;
	jdo : JadeDynamicObject;
	transientInvoice : CM_Invoice;
	iter : Iterator;
	invoiceLine : CM_InvoiceLine;
	contentID : Integer;
	consolMode : String;
	terminal : CM_Terminal;
begin
	body:="--batch_" &amp; headerID &amp; CrLf &amp; "Content-Type: multipart/mixed; boundary=changeset_" &amp; headerID &amp; CrLf ;
	//each line header need to add Content-ID 	
	create jdo transient;
	
	jdo.addProperty(ParentRecId,Integer64);
	jdo.setPropertyValue(ParentRecId,headerID.Integer64);
	jdo.addProperty(SalesTaxItemGroupId,String);
	jdo.addProperty(LineNumber,Integer);
	jdo.addProperty(Description,String);
	jdo.addProperty(MainAccountDisplayValue,String);
	jdo.addProperty(DefaultDimensionDisplayValue,String);
	jdo.addProperty(PAUnit,String);
	jdo.addProperty(Quantity,Decimal);
	jdo.addProperty(UnitPrice,Decimal);
	jdo.addProperty(DataAreaId,String);
	jdo.setPropertyValue(DataAreaId,self.myTerminal.code);
	
	transientInvoice := self.myInvoice.cloneForConsolidation();
	//	self.myInvoice.getInvLinesConsExternalRef4(transientInvoice);	

	// ### JIRA 34735 07MAY2025 NAVAB1
	terminal := self.myTerminal;
	if terminal = null then
		terminal := self.myInvoice.myTerminal;
	endif;
	consolMode := terminal.getConfig(InvoiceAPIOpModeConfig).String;
	if consolMode = CM_InvoiceAPI.CONSMODE_NO_CONS then
		// no consolidation clone invoice and invoice lines and charges.
		 self.myInvoice.getInvLinesConsByNothing(transientInvoice);  // ### JIRA 35848 27AUG2025 NAVAB1
	elseif consolMode = CM_InvoiceAPI.CONSMODE_CHARGE_AND_RATE then
		self.myInvoice.getInvLinesConsByServiceRate(transientInvoice);	
	elseif consolMode = CM_InvoiceAPI.CONSMODE_INV_LINE_AND_RATE then
		self.myInvoice.getInvLinesConsInfo(transientInvoice);	
	elseif consolMode = CM_InvoiceAPI.CONSMODE_INV_LINE_CRIT_RATE then
		self.myInvoice.getInvLinesConsByNarrCri(transientInvoice);	
	elseif consolMode = CM_InvoiceAPI.CONSMODE_EXTERNALREF4 then
		self.myInvoice.getInvLinesConsExternalRef4(transientInvoice);	
	elseif consolMode = CM_InvoiceAPI.CONSMODE_REF4_LINETYPE_RATE then
		self.myInvoice.getInvLinesConsRef4TypeRate(transientInvoice);	
	endif;
	
	iter:=transientInvoice.invoiceLines.createIterator;	
	while iter.next(invoiceLine) do
		
		contentID:=contentID+1;
			
		body:=body &amp; CrLf &amp; self.getNSWInvoiceLinesHeaderText(headerID,baseURL,contentID.String) &amp; CrLf;
		invoiceLineGrpJSON:=getNSWInvoiceLinesBodyText(jdo,invoiceLine,contentID,invoiceLine.externalRef4);	//15.01.2025 navhl20 #33758
		body:=body &amp; CrLf &amp; invoiceLineGrpJSON; 
	
	endwhile;
		
	bodyEnd := "--changeset_" &amp; headerID &amp; "--" &amp; CrLf &amp;
				"--batch_"  &amp; headerID &amp; "--";
	body:=body &amp; CrLf &amp;  bodyEnd;
	
	return body;
epilog
	delete jdo;
	delete iter;
	delete transientInvoice;
end;</source>
        <access>protected</access>
        <Parameter name="headerID" type="String"/>
        <Parameter name="baseURL" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNSWInvoiceLinesBodyText" id="62e33c82-eed1-4712-b008-ee46ebb57bb2">
        <source>getNSWInvoiceLinesBodyText(_jdo : JadeDynamicObject input; _invoiceLine : CM_InvoiceLine; _contentID : Integer; _financialDimensions : String ) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2024	jlier1	Initial creation 65959  CR 65949
19 Nov 2024 jlier1 	MTN-22438 - Issues with invoice line - some fields need to be numeric not string and rounded
09 Dec 2024 jlier1	MTN-33611 - if credit note sometimes the invoiceLine values area already neg, but not always in which case return them as neg
09 Jan 2025	navhl20 Bug MTN-33758: NSW | D365 - Issues with Invoice Line Call for Voyage Invoices
23 Jan 2025 jlier1  33835	- removed TransactionCurrencyAmount
19 Feb 2025 jlier1  34105 - issues with the rate - with consolidation - problems with credit notes because they are voided.  Also was using totalAmount on invoiceLine but that was only set for cargo transactions not
							hms or manual - have also changed getInvLinesConsExternalRef4 so totalAmount is always set correctly and quantity - then will calcualte the rate from those 2 values
*/
constants
	ParentRecId  = "ParentRecId";
	SalesTaxItemGroupId = "SalesTaxItemGroupId";
	LineNumber = "LineNumber";
	Description = "Description";
	MainAccountDisplayValue = "MainAccountDisplayValue";
	DefaultDimensionDisplayValue  = "DefaultDimensionDisplayValue";
	PAUnit = "PAUnit";
	Quantity = "Quantity";
	UnitPrice = "UnitPrice";
	DataAreaId = "dataAreaId";
	Free = "FREE";
	GST = "GST";
vars
	defaultDimensions,
	mainAccountDisplayValue,
	invoiceLineGrpJSON : String;
	isCreditReturn : Boolean;
	rate : Decimal[23,6];
begin	
	isCreditReturn:=self.myInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR or	
					self.myInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING;	
	//jlier1 JIRA#34055 &amp; 34035 14/2/25 - if credit invoice created and copy posted to new pending ticked it sets charges to void - unvoid to get values (remember this is a transient copy not real invoice lines)
	//jlier1 34105 now updated tax value on invoice line so don't have to worry about the voided charges for credit notes
	if _invoiceLine.taxValue = 0 then	//jlier1 JIRA#34045 12/2/25 - can have a tax code but the tax code has zero rate - so will just check if there is any tax - needs to be done before we get tax aswell
		_jdo.setPropertyValue(SalesTaxItemGroupId,Free);
	else
		_jdo.setPropertyValue(SalesTaxItemGroupId,GST);
	endif;
	_jdo.setPropertyValue(LineNumber,_contentID);
	_jdo.setPropertyValue(Description,_invoiceLine.getLineDescNarration );
	mainAccountDisplayValue:=null;
	if _invoiceLine.getGLCode &lt;&gt; null then
		mainAccountDisplayValue:=_invoiceLine.getGLCode.code;
	endif;
	_jdo.setPropertyValue(MainAccountDisplayValue,mainAccountDisplayValue);
	defaultDimensions:= _financialDimensions[mainAccountDisplayValue.length+1:end];
	_jdo.setPropertyValue(DefaultDimensionDisplayValue,defaultDimensions);

	
	if _invoiceLine.invoiceLineDesc &lt;&gt; null then
		_jdo.setPropertyValue(PAUnit,_invoiceLine.invoiceLineDesc.unitNarration);
	else
		_jdo.setPropertyValue(PAUnit,null);
	endif;
	//jlier1 JIRA#34105 19/2/25
	rate :=(_invoiceLine.totalAmount / _invoiceLine.quantity);
	if isCreditReturn then
		if _invoiceLine.quantity &gt; 0 then
			_jdo.setPropertyValue(Quantity,(_invoiceLine.quantity * -1).Decimal.roundedTo(2));
		else
			_jdo.setPropertyValue(Quantity,_invoiceLine.quantity.Decimal.roundedTo(2));
		endif;
		
		if rate &lt; 0 then
			_jdo.setPropertyValue(UnitPrice,(rate* -1).roundedTo(2));
		else
			_jdo.setPropertyValue(UnitPrice,rate.roundedTo(2));
		endif;
	else
		_jdo.setPropertyValue(Quantity,_invoiceLine.quantity.Decimal.roundedTo(2));
		_jdo.setPropertyValue(UnitPrice,rate.roundedTo(2));
	endif;
	_jdo.deserializeJSON(invoiceLineGrpJSON);
	
	return invoiceLineGrpJSON;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_jdo" type="JadeDynamicObject" usage="input"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_contentID" type="Integer"/>
        <Parameter name="_financialDimensions" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNSWInvoiceLinesHeaderText" id="8d6a2660-40cc-4a1a-bc84-18ba93e68290">
        <source>getNSWInvoiceLinesHeaderText(_headerID : String; _baseURL :String; _contentID : String) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2024	jlier1	Initial creation 65959  CR 65949

*/

vars

begin
	return "--changeset_" &amp; _headerID &amp; CrLf &amp; "Content-Type: application/http" &amp; CrLf &amp; "Content-Transfer-Encoding: binary" &amp; CrLf &amp; CrLf &amp;
		"POST " &amp; _baseURL &amp; "data/FreeTextInvoiceLines HTTP/1.1" &amp;CrLf &amp;
		"Content-ID: " &amp; _contentID &amp; CrLf &amp; 
		"Accept: application/json;odata.metadata=minimal" &amp; CrLf &amp;
		"OData-Version: 4.0" &amp; CrLf &amp; 
		"Content-Type: application/json"  &amp; CrLf &amp; 
		"OData-MaxVersion: 4.0" ;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_headerID" type="String"/>
        <Parameter name="_baseURL" type="String"/>
        <Parameter name="_contentID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendMessageInvAPI" id="6973449f-407b-407d-ae8b-70b6294d8a55">
        <updating/>
        <source>sendMessageInvAPI(_json : String;  _type : String) : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)

*/

vars	
	verb,
	endpoint,
	jsonPostData,
	errors,
	url,
	resultString	: String;
	resultCode : Integer;
begin
	if _json = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Incoming json was null", LogERROR);
		return false;
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending ", LogINFO);	
	
	url :=	 self.myWebServiceDefinition.baseEndpoint;	

	resultString := self.doSendHTTPRequest(url, "POST", self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	

	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode &lt;&gt; HttpResponseOK and resultCode &lt;&gt; HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	endif;
	return true;	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_json" type="String"/>
        <Parameter name="_type" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendNSWInvoice" id="4687a546-416b-4a8f-9163-4ccdc22a2336">
        <updating/>
        <source>sendNSWInvoice() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2024	jlier1	Initial creation  CR 65949

*/

vars
	addtionalHeaders,errorResponse : String;
	token : String;
	ewsActivity : CM_EWSActivityInvoiceAPI;
	isCreditReturn : Boolean;
	errorStatus,
	successStatus : Integer;
begin

	if self.myInvoice = null then
		return;
	endif;
	
	if self.myWebServiceDefinition = null then
		return;
	endif;
	
	if self.myWebServiceDefinition.allEndpoints.isEmpty then
		return;
	endif;
	
	isCreditReturn:=self.myInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR or	
					self.myInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING;	
	//really wantt to know I have the token before I call anything else
	if isCreditReturn then
		errorStatus:=CM_Invoice.INVOICE_POSTED_CREDIT_ERROR;
		successStatus:=CM_Invoice.INVOICE_POSTED_CREDIT;
	else
		errorStatus:=CM_Invoice.INVOICE_POSTED_ERROR;
		successStatus:=CM_Invoice.INVOICE_POSTED;
	endif;
	//to decide may need to send multi-part form data so may need different method
	token:=self.myWebServiceDefinition.CM_APIEndpointServiceDef.getMultipartFormDataToken(self.myTerminal,self.myInvoice,  errorResponse,ewsActivity);
	if ewsActivity &lt;&gt; null then
		//created one to get the token
		self.myEWSActivity :=ewsActivity;
	endif;
	
	if token = null then
		// activity history is created change invoice to Posted Error
		self.updateInvoiceStatus(errorStatus);
		return;
	endif;
	if token &lt;&gt; null then																															
		addtionalHeaders	:= 'Authorization: Bearer ' &amp; token; 																			
	endif;
	
	//add aditional O-DATA headers 
	addtionalHeaders := addtionalHeaders &amp; CrLf &amp; 'OData-Version: 4.0' &amp; CrLf &amp;
						'OData-MaxVersion: 4.0' &amp; CrLf &amp;
						'Accept: application/json;odata.metadata=minimal';
	
	//send the headers	
	if not self.sendNSWInvoiceHeader(addtionalHeaders) then
		self.updateInvoiceStatus(errorStatus);
		return;
	endif;
	//send the lines
	if not self.sendNSWInvoiceLines(addtionalHeaders) then
		self.updateInvoiceStatus(errorStatus);
		return;
	endif;
	
	if not self.sendNSWUpdateInvoiceHeader(addtionalHeaders) then
		self.updateInvoiceStatus(errorStatus);
	else
		self.updateInvoiceStatus(successStatus);
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sendNSWInvoiceHeader" id="28ba6987-c7c0-4a93-a5e0-bba8f8e237c9">
        <updating/>
        <source>sendNSWInvoiceHeader(_headers  : String) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
05 September 2024	jlier1	Initial creation 65958 : CR 65949

*/
vars
	resultString : String;
	resultCode : Integer;
	url : String;
	jsonPostData : String;
	addtionalHeaders : String;
		xml					: JadeXMLDocument;
	jsonHelper			: CMIF_JsonHelper;
	xmlHelper		    : CM_XmlHelperAgent;
	xmlElement		    : JadeXMLElement;
	invoiceIdentifier	: String;
	endpoint,lastEndPoint : CM_Endpoint;
	lastPart 	: CM_EWSActivityInvoiceAPI;
begin
	endpoint:=self.myWebServiceDefinition.allEndpoints[ETRow_NswCreateInvHeader];
	if endpoint = null then
		//NO create header endpoint set up
		return false;
	endif;
	url :=	 self.myWebServiceDefinition.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	
	url := url &amp; endpoint.endpoint;
	
	//if self.myInvoice.externalFinancialId &lt;&gt; null then
	if self.myInvoice.getExternalFinancialId() &lt;&gt; null then //08/12/2025	navkc1 JIRA 36262
		return true;
	endif;
	//if self.myInvoice.externalFinancialId &lt;&gt; null then
	if self.myInvoice.getExternalFinancialId() &lt;&gt; null then //08/12/2025	navkc1 JIRA 36262
		lastPart:=self.getLastEWSActivityPart();
		if lastPart &lt;&gt; null then
			lastEndPoint:=lastPart.getAPIEndpoint();
			if lastEndPoint &lt;&gt; null and  lastEndPoint.defName = ETRow_NswCreateInvLines or lastEndPoint.defName = ETRow_NswUpdateInvHeader then
				return true;
			endif;
		endif;
	endif;
	
	jsonPostData:=self.getNSWInvoiceHeaderBody;
	
	addtionalHeaders:=_headers &amp; CrLf &amp;  "Content-Type: application/json";
	resultString := self.doSendHTTPRequest(url, endpoint.verb, addtionalHeaders, jsonPostData, resultCode);	

	if resultCode = HttpResponseCreated then
		//send the InvoiceLines
		create xmlHelper  transient;
		create jsonHelper transient;
		create xml        transient;
		
		xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(resultString), xml);
		xmlElement := xml.findElementByTagName("InvoiceIdentifier");
		if xmlElement &lt;&gt; null then
			invoiceIdentifier := xmlElement.text();
		endif;
		
		if invoiceIdentifier = null then
			return false;
		endif;
		
		app.myTrxUA.trxUpdateInvoiceExternalFinID(self.myInvoice,invoiceIdentifier,app.myPassport);
		if app.myPassport.hasErrors then
			return false;
		endif;
		return true;
	endif;
	
	return false;
epilog
	delete xml;
	delete xmlHelper;
	delete jsonHelper;
end;</source>
        <access>protected</access>
        <Parameter name="_headers" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendNSWInvoiceLines" id="07e8b77f-3438-418a-9139-275f8b9c6384">
        <updating/>
        <source>sendNSWInvoiceLines(_headers  : String) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2024	jlier1	Initial creation 65959  CR 65949

*/
vars
	baseURL,
	headerID,
	url,addtionalHeaders, body : String;
	resultCode,startMatchLength  : Integer;
	resultString : String;
	match :JadeRegexMatch;
	pxyActivityHistory :CM_EWSActivityInvoiceAPI;
	endpoint,lastEndPoint : CM_Endpoint;
	lastPart 	: CM_EWSActivityInvoiceAPI;
	transientInvoice : CM_Invoice;
	pxyActivityPart			: CM_EWSActivityInvoiceAPIParts;	
	realActivityPart		: CM_EWSActivityInvoiceAPIParts;	
begin
	endpoint:=self.myWebServiceDefinition.allEndpoints[ETRow_NswCreateInvLines];
	if endpoint = null then
		//NO create header endpoint set up
		return false;
	endif;
	

	lastPart:=self.getLastEWSActivityPart();
	if lastPart &lt;&gt; null then
		lastEndPoint:=lastPart.getAPIEndpoint();
		if lastEndPoint &lt;&gt; null and lastEndPoint.defName = ETRow_NswUpdateInvHeader then
			return true;
		endif;
	endif;
	
	
	
	baseURL:=self.myWebServiceDefinition.baseEndpoint;
	if baseURL[baseURL.length:1] &lt;&gt; "/" then
		baseURL := baseURL &amp; "/";
	endif;
	url := baseURL &amp; endpoint.endpoint;
	//headerID:=self.myInvoice.externalFinancialId;
	headerID:=self.myInvoice.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	addtionalHeaders:=_headers &amp; CrLf &amp;  "Content-Type: multipart/mixed; boundary=batch_" &amp; headerID;
	
	body:=self.getNSWInvoiceLinesBody(headerID,baseURL);
	resultString := self.doSendHTTPRequest(url, endpoint.verb, addtionalHeaders, body, resultCode);	

	if resultCode = HttpResponseCreated or resultCode = HttpResponseOK then
		//Can be created but need to check the content that the batch was successful 
		JadeRegex@findFirst(resultString,"(?=HTTP\/1.1).*",true,false,match);
		if match &lt;&gt; null then
			//check the first batch result is created
			startMatchLength:="HTTP/1.1".length;
			if match.value.length &gt; startMatchLength + 4 then	
				resultCode:= match.value[startMatchLength+1:4].trimBlanks.Integer;
					
				if self.myEWSActivity &lt;&gt; null then
					beginLoad;
						pxyActivityHistory :=self.myEWSActivity.pxyCreateUpdateProxy();
					endLoad;
					pxyActivityHistory.setResponseCode(resultCode);
					if resultCode = HttpResponseCreated then
						pxyActivityHistory.fullMsgStatusStr:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SUCCESS;
					else		
						pxyActivityHistory.fullMsgStatusStr:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SEND_ERROR;
					endif;
					app.myTrxUA.trxUpdateEWSActivity(pxyActivityHistory, app.myPassport);
					
					realActivityPart:=self.myEWSActivity.allEWSMessageParts.last;
					if realActivityPart &lt;&gt; null then
						beginLoad;
							pxyActivityPart :=realActivityPart.pxyCreateUpdateProxy();
						endLoad;
						pxyActivityPart.setResponseCode(resultCode);
						if resultCode = HttpResponseCreated then
							pxyActivityPart.statusStr:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SUCCESS;
						else		
							pxyActivityPart.statusStr:=CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SEND_ERROR;
						endif;
						app.myTrxUA.trxUpdateEWSActivity(pxyActivityPart, app.myPassport);	
						
					endif;
				endif;
				if resultCode = HttpResponseCreated then
					return true;
				endif;
			endif;
		endif;
		return false;
	endif;
	
	return false;
epilog	
	delete match;
	delete pxyActivityHistory;
	delete transientInvoice;
	delete pxyActivityPart;
end;</source>
        <access>protected</access>
        <Parameter name="_headers" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendNSWUpdateInvoiceHeader" id="cf85ab79-b4d4-4a50-9da6-5089e1ab7fe0">
        <updating/>
        <source>sendNSWUpdateInvoiceHeader(_headers  : String) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2024	jlier1	Initial creation 65960

*/
constants
	InvoiceRecId =  "_invoiceRecId";
	DataAreaId  = "_dataAreaId";
vars
	endpoint : CM_Endpoint;	
	url : String;
	jdo : JadeDynamicObject;
	headerID,
	jsonPostData,
	resultString 		: String;
	resultCode 	: Integer;
begin
	endpoint:=self.myWebServiceDefinition.allEndpoints[ETRow_NswUpdateInvHeader];
	if endpoint = null then
		//NO create header endpoint set up
		return false;
	endif;
	url :=	 self.myWebServiceDefinition.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	
	url := url &amp; endpoint.endpoint;

	//headerID:=self.myInvoice.externalFinancialId;
	headerID:=self.myInvoice.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	
	create jdo transient;
	//jlier1 JIRA#33740 23/12/24
	jdo.addProperty(InvoiceRecId,Integer64);
	jdo.setPropertyValue(InvoiceRecId,headerID.Integer64);
	jdo.addProperty(DataAreaId,String);
	jdo.setPropertyValue(DataAreaId,self.myTerminal.code);
	
	jdo.deserializeJSON(jsonPostData);
	resultString := self.doSendHTTPRequest(url, endpoint.verb, _headers, jsonPostData, resultCode);	

	if resultCode = HttpResponseOK or resultCode = HttpResponseCreated or resultCode = HttpResponseNoContent then
		//update the invoice status from Posted Pending to Posted
		return true;
	endif;
	return false;
epilog
	delete jdo;
end;</source>
        <access>protected</access>
        <Parameter name="_headers" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyEWSActivity" id="fa1b99cb-d3f0-46fc-8957-7294ed490747">
        <updating/>
        <source>setMyEWSActivity(_ewsActivityMain : CM_EWSActivityInvoiceAPI) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)

*/

vars

begin
	self.myEWSActivity := _ewsActivityMain;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ewsActivityMain" type="CM_EWSActivityInvoiceAPI"/>
    </JadeMethod>
    <JadeMethod name="setMyInvoice" id="e6e00540-dcea-4d5f-907a-f8fdba5da2bd">
        <updating/>
        <source>setMyInvoice(_invoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)

*/

vars

begin
	self.myInvoice := _invoice;
	//05 September 2024	jlier1	Initial creation  CR 65949
	if self.myInvoice &lt;&gt; null then
		self.myTerminal:=_invoice.myTerminal;
	endif;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatus" id="d972d5bc-580f-424c-9175-c8c5c78f76f0">
        <source>updateInvoiceStatus(_status : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	jlier1	Initial creation 65960 : 65949 NSW | Dynamic Integration Development

*/

vars
	statuses		: CMIF_Array;
	cmifStatus 		: CMIF_InvoiceStatus;
	pxyInvoice 		: CM_Invoice;
begin
	if self.myInvoice = null then
		return;
	endif;
	beginLoad;
	pxyInvoice:=self.myInvoice.pxyCreateUpdateProxy;
	endLoad;
	create cmifStatus transient;
	cmifStatus.myInvoice := pxyInvoice;
	cmifStatus.newStatus := _status;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating invoice " &amp; self.myInvoice.sequenceNum.String &amp; " to status " &amp; _status.String, LogDEBUG);
	app.myTrxUA.trxUpdateInvoiceStatus(cmifStatus, app.myPassport);
	app.writeLog(method.qualifiedName &amp; Tab &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogDEBUG);
epilog
	delete cmifStatus;
	delete pxyInvoice;
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
</Class>
