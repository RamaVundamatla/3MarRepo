    <JadeMethod name="addObjectsToTable" id="227de6d0-197f-4f60-b9ba-323cb2ad7aa1">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	breakOut : Boolean;
	index : Integer;
	obj : Object;	
	dynaDict : DynaDictionary;

begin

	if self.myVoyage = null or self.myVoyage.allWorkPointOperatingHours.isEmpty then
		return;
	endif;
	
	create dynaDict transient;
	dynaDict.setMembership( CM_WorkPointOperatingHours );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::craneWorkPointId.name, false, true );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::exchangeStart.name, false, true );
	dynaDict.endKeys(true);	
	
	self.myVoyage.allWorkPointOperatingHours.copy(dynaDict);
	iter := dynaDict.createIterator;
	
	while iter.next( obj ) do
		opHr := obj.CM_WorkPointOperatingHours;
		if self.includeObject(opHr, app.myPassport) then
			self.addObjectToTable(opHr, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endwhile;
	

	//if crane or workpoint set, set the first op hr for it that we find as the top row
	if self.amInitialisingWithObject and self.tblData.rows &gt; self.tblData.fixedRows then
		if self.myCrane &lt;&gt; null then
			foreach index in (self.tblData.fixedRows + 1) to self.tblData.rows do
				opHr := self.tblData.accessRow(index).itemObject.CM_WorkPointOperatingHours;
				if opHr.myCrane = self.myCrane then
					self.tblData.topRow := index;
					break;
				endif;
			endforeach;
		elseif self.myWorkPoint &lt;&gt; null then
			foreach index in (self.tblData.fixedRows + 1) to self.tblData.rows do
				opHr := self.tblData.accessRow(index).itemObject.CM_WorkPointOperatingHours;
				if opHr.myWorkPoint = self.myWorkPoint then
					self.tblData.topRow := index;
					break;
				endif;
			endforeach;
		endif;
		//25.09.2018 cnwma1 TFS #41080
		if self.myUser &lt;&gt; null then
			foreach index in (self.tblData.fixedRows + 1) to self.tblData.rows do
				opHr := self.tblData.accessRow(index).itemObject.CM_WorkPointOperatingHours;
				if opHr.myUser = self.myUser then
					self.tblData.topRow := index;
					break;
				endif;
			endforeach;
		endif;
	endif;
		
epilog

	delete iter;
	delete dynaDict;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cmbCraneOpr_displayEntry" id="3d0d2922-27ee-4cf0-b309-003476a387ed">
