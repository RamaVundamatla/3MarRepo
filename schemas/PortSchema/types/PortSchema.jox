    <JadeMethod name="autoPlanAlertOverride" id="ecba0311-c39a-4f64-99d3-c0cdd93875e1">
        <updating/>
        <source>autoPlanAlertOverride(_terminal : CM_Terminal) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars

	agent 				: CM_YAAutoplanAgent;
	useOverStowNew		: Boolean;

begin
	
	// THIS IS THE ONLY PORTSCHEMA METHOD THAT DOES NOT USE PortSchema::checkYardAllocationLicensing()
	
	if _terminal = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'terminal has not been specified', null, null);
		return;
	endif;
	
	if self.myYAAgent = null then
		
		if not _terminal.isAutoPlanningEnabled() then
			return;
		endif;
		
		// Is system licensed for new autoplanning
		// If not raise exception.
		// ### JIRA 33505 30DEC2024 NAVAB1 Mod_YardPlanning is now part of base module
		/*
		if not app.getMyUser.canDo(_terminal, Mod_YardPlanning) then
			return;
		endif;
		*/
		
		if _terminal.isAutoPlanUseOverstowRules() then
			useOverStowNew := true;
		endif;

		create self.myYAAgent transient;
		self.myYAAgent.useOverstowRules := useOverStowNew;
		
	endif;

	agent := self.myYAAgent;
	
	agent.alertOverride := true;
	
	return;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="autoPlanForDischargeYA" id="1a072c1b-7f26-4db2-8562-0a292268c12f">
        <updating/>
        <source>autoPlanForDischargeYA(_terminal : CM_Terminal; _voyage : CM_Voyage; _wleSetOut : CM_WLESet input)  updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

	agent 			: CM_YAAutoplanAgent;

begin
	
	// Check licensing and create agent if necessary.
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return;
	endif;

	agent := self.myYAAgent;
	agent.initialiseForTrxStart();
	agent.autoPlanForDischarge(_terminal, _voyage, _wleSetOut);
	
	return;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_wleSetOut" type="CM_WLESet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanForFullTargetLocUseYA" id="5a14c4c2-3f43-4636-987e-c7ff7ed123f0">
        <updating/>
        <source>autoPlanForFullTargetLocUseYA(	_terminal : CM_Terminal; 
							_terminalArea : CM_TerminalArea; 
							_gridRow	: CM_GridRow;
							_gridColumn	: CM_GridColumn;
							_ti : CM_TrackedItem;
							_onlyCheckRealCargo : Boolean) : CM_LocationsController updating;
/*

Purpose:		This calls the autoplan agent to replan the box to a valid location that must be within a yard allocation for the boxe.

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2011	cnwdz2	Initial creation 27008

*/

vars

begin
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	self.myYAAgent.initialiseForTrxStart();
	self.myYAAgent.setIsOnlyCheckRealCargo(_onlyCheckRealCargo);
	if self.myYAAgent.autoPlanTiYA(_terminal, _terminalArea,_gridRow,_gridColumn, _ti, null) then
		return self.myYAAgent.getFoundLocation();
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_onlyCheckRealCargo" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanJobTiYA" id="b9fd6225-59a3-4324-a42d-8cab068705ca">
        <updating/>
        <source>autoPlanJobTiYA(	_terminal : CM_Terminal;
					_terminalArea : CM_TerminalArea;
					_gridRow	: CM_GridRow;
					_gridColumn	: CM_GridColumn;
					_ti : CM_TrackedItem;
					_job : CM_Job;
					_realCargo: Boolean;
					_multiRangeCmifs : ObjectArray input;
					_plannedToFullGCArea : Boolean output		// MTN 18897
					) : CM_LocationsController updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Apr 2009	cnwar2	Initial creation
06 Nov 2024	navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
*/

vars
	agent : CM_YAAutoplanAgent;
	lc : CM_LocationsController;
	invalidobj : Boolean;
begin
	if _terminal = null then
		return null;
	endif;
	
	on Exception do self.handleDeletedObject(exception,_terminal,invalidobj);
	//epr par 19911 15/6/09 
	if not _terminal.isAutoPlanningEnabled() then
		return null;
	endif;

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	agent := self.myYAAgent;
	agent.initialiseForTrxStart();
	agent.setIsOnlyCheckRealCargo(_realCargo);     // 25813
	if agent.autoPlanTiYA(_terminal, _terminalArea,_gridRow,_gridColumn, _ti, _job) then
		lc := agent.getFoundLocation();
		if lc = null
		and _multiRangeCmifs &lt;&gt; null
		and _ti &lt;&gt; null
		and _ti.canSplitTotalQuantity
		and not agent.allMultiRangeCMIFs.isEmpty then	
			agent.allMultiRangeCMIFs.copy(_multiRangeCmifs);
			agent.allMultiRangeCMIFs.clear();
		endif;
		if lc &lt;&gt; null then											// MTN-18897
			_plannedToFullGCArea := agent.isPlannedToFullGCArea;	// MTN-18897
		endif;														// MTN-18897
		return lc;
	endif;
	
	return null;
	
epilog

	if agent &lt;&gt; null and not agent.allMultiRangeCMIFs.isEmpty then
		agent.allMultiRangeCMIFs.purge();
	endif;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_realCargo" type="Boolean"/>
        <Parameter name="_multiRangeCmifs" type="ObjectArray" usage="input"/>
        <Parameter name="_plannedToFullGCArea" type="Boolean" usage="output"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanOverstowUsingYA" id="c30f0489-890f-446f-9d4f-a64a04fe8067">
        <updating/>
        <source>autoPlanOverstowUsingYA(	_terminal : CM_Terminal; 
							_terminalArea : CM_TerminalArea; 
							_gridRow	: CM_GridRow;
							_gridColumn	: CM_GridColumn;
							_ti : CM_TrackedItem; 
							_allLCsToIgnore : CM_LCSet;
							_onlyCheckRealCargo : Boolean) : CM_LocationsController updating;
/*

Purpose:		This calls the autoplan agent to plan the overstows to locations that must be within a yard allocation for the overstowed boxes.

				This is contrary to the method autoPlanOverstowYA which ignores yard allocations (very confusing) 

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars

begin
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;


	self.myYAAgent.initialiseForTrxStart();
	if _allLCsToIgnore &lt;&gt; null then
		
		_allLCsToIgnore.copy(self.myYAAgent.allLCsToIgnore);
	endif;
	self.myYAAgent.setIsFindOverstowLocation(true, _terminal.isAutoPlanOsIgnorePandQ);
	self.myYAAgent.setIsOnlyCheckRealCargo(_onlyCheckRealCargo);
	if self.myYAAgent.autoPlanTiYA(_terminal, _terminalArea,_gridRow,_gridColumn, _ti, null) then
		return self.myYAAgent.getFoundLocation();
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_allLCsToIgnore" type="CM_LCSet"/>
        <Parameter name="_onlyCheckRealCargo" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanOverstowYA" id="1f4d685e-dd4e-4ee6-b274-1cd3d1a90b87">
        <updating/>
        <source>autoPlanOverstowYA(_terminal : CM_Terminal; _terminalArea : CM_GridArea; _ti : CM_TrackedItem) : CM_LocationsController updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

	location : CM_LocationsController;


begin
	
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	self.myYAAgent.initialiseForTrxStart();
	if self.myYAAgent.searchForOverstowLocation(_ti, _terminal, _terminalArea) then
		if self.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty() and not self.myYAAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
			location := self.myYAAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.first;
		else
			location := self.myYAAgent.getFoundLocation();	
		endif;
		self.myYAAgent.addLogEntry(AP_Log_YA_Default,'Found overstow location ' &amp; location.getID(), false);
		write self.myYAAgent.getLoggingString();
		return location;
	endif;
	
	return null;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_GridArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanSenario" id="0085f4f7-3f82-4fa2-8faf-ef6637b5154b">
        <updating/>
        <source>autoPlanSenario(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _cmif : CMIF_YAAutoPlanSenario; _numberLocationsFound : Integer output) : StringArray512 updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

	agent  				: CM_YAAutoplanAgent;

begin

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	agent := self.myYAAgent;
	agent.initialiseForTrxStart();
	agent.autoPlanTiVerbose(_terminal, _terminalArea, _cmif);
	_numberLocationsFound := agent.numberOfLocationsFound;
	return agent.getLoggingArray(app.verboseLogging);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_cmif" type="CMIF_YAAutoPlanSenario"/>
        <Parameter name="_numberLocationsFound" type="Integer" usage="output"/>
        <ReturnType type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiToOutwardRail" id="3545d3e4-ea77-4734-9871-691639123ca3">
        <updating/>
        <source>autoPlanTiToOutwardRail(	_ti : CM_TrackedItem;
							_moveMode : Integer;
							_terminal : CM_Terminal; 
							_railArea : CM_Rail;
							_train : CM_Train;
							_wagon : CM_Wagon
							):CM_WagonController updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2013	cnwndl1	Initial creation	Par 31692	

*/

vars

	cmifAutoPlan : CMIF_YAAutoPlan;
	agent : CM_YAAutoplanAgent;
	wagonController : CM_WagonController;

begin

	if not _terminal.isAutoPlanningEnabled() then
		return null;
	endif;

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI( _ti );
	
	agent := app.myYAAgent;
	wagonController := agent.autoPlanTiToRail(_moveMode, _terminal, _railArea, _train, _wagon, _ti);
	
	return wagonController;
	
epilog

	delete cmifAutoPlan;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiYA" id="24d160b5-b00d-4323-bf2d-7dfe979888f8">
        <updating/>
        <source>autoPlanTiYA(_terminal : CM_Terminal;
			_terminalArea : CM_TerminalArea; 
			_ti : CM_TrackedItem) : CM_LocationsController updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

	agent 			: CM_YAAutoplanAgent;
	invalidTA			: Boolean;
	ta				: CM_TerminalArea;
	taEdition		: Integer;
begin
	
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;
	
	ta:=_terminalArea;
	on Exception do self.handleDeletedObject(exception,ta,invalidTA);
	
	if  ta &lt;&gt; null then
		taEdition:=ta.edition;
		if invalidTA then
			ta:=null;
		endif;
	endif;
	
	agent := self.myYAAgent;
	agent.initialiseForTrxStart();
	if agent.autoPlanTiYA(_terminal, ta,null,null, _ti, null) then
		return agent.getFoundLocation();
	endif;
	
	return null;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiYATest" id="9af839f7-5356-49fe-bb6a-6c2f97e00845">
        <updating/>
        <source>autoPlanTiYATest(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _ti : CM_TrackedItem; _raiseAlert: Boolean) : CM_LocationsController updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

	agent				: CM_YAAutoplanAgent;
begin

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;
	
	agent := self.myYAAgent;
	agent.initialiseForTrxStart();
	// PAR 19412 Set up AutoPlan agent so it will create an alert if required
	agent.setIsSenarioTesting(true, _raiseAlert);
	agent.alertOverride := _raiseAlert;

	if agent.autoPlanTiYA(_terminal, _terminalArea,null,null, _ti, null) then
		return agent.getFoundLocation();
	endif;

	return null;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_raiseAlert" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTiYATestMulti" id="11752caa-bc19-4584-aae0-70b9a4752a34">
        <updating/>
        <source>autoPlanTiYATestMulti(	_terminal		: CM_Terminal;
						_terminalArea	: CM_TerminalArea;
						_tiArray		: ObjectArray input;
						_strSuccesses,
						_strErrors		: String output;
						_noSuccesses,
						_noErrors		: Integer output) updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars

/*	agent				: CM_YAAutoplanAgent;
	location			: CM_LocationsController;
	obj					: Object;
	ti					: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	passport			: CM_Passport;
	str					: String;
	
*/	

begin

///////////////////////////////////////////////////////////////
//
//			03 Mar 2012	NDL	Par 29195	
//			This is now performed by CM_TestAutoPlanRoot::processAutoPlan		
//			called from the 'CMUI_TestAutoPlanForm'  via CMUI_Assistant::showTestAutoPlan
//
////////////////////////////////////////////////////////
	return;
/*

	// Check licensing.
	if not self.checkYardAllocationLicensing(_terminal) then
	 	return;
	endif;
	
	agent := self.myYAAgent;
	passport := app.myPassport;

	// Set up the move controller.
	create moveController transient;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.hazardSegregationValidated := true;//because it's considered when getting a valid autoplan location
	moveController.isForcedMove := true;
	
	//08 June 2011	NDL	Par 27362
	on Exception do agent.testPlanLockException(exception);	// catch Locks and Deadlocks
		
	// Put app in transaction state so system temporarily remembers where it thinks
	// it is going to put things.
	beginTransaction;
	
	foreach obj in _tiArray do
		ti := obj.CM_TrackedItem;
		// Auto plan the ti
		// Tell the agent we are only testing.
		agent.setIsSenarioTesting(true, false);
		agent.initialiseForTrxStart();
		agent.clearForMulti();
		passport.initialiseTransaction();	
		passport.useTIDictDeferUpdate := true;
		passport.useTITransactionDeferUpdate := true;
		passport.warningsAcknowledged := true;
		agent.autoPlanTiYA(_terminal, _terminalArea,null,null, ti, null);
		location := agent.getFoundLocation();
		// We have a location.
		if location &lt;&gt; null then
			// Plan move the ti there.
			moveController.setMyTrackedItem(ti);
			moveController.setMyToPrimaryLocation(location);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, passport);
			passport.doDeferredUpdates();
			// No errors so we can report on a successful autoplan.
			if passport.noErrors() then
				if not ti.isPlanned(PLANNING_MODE) then
					app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Item not planned', null, null);
					return;
				endif;
				if _strSuccesses &lt;&gt; null then
					_strSuccesses := _strSuccesses &amp; CrLf &amp; ti.id &amp; " will be queued to " &amp; location.getFullId(); 
				else
					_strSuccesses := ti.id &amp; " will be queued to " &amp; location.getFullId(); 
				endif;
				_noSuccesses := _noSuccesses + 1;
				continue;
			endif;
		endif;
		// We had problem so lets remember the details.
		_strErrors := _strErrors &amp; CrLf &amp; ti.id &amp; " could not be auto planned.";
		_noErrors := _noErrors+ 1;
	endforeach;
	return;
	
	
epilog

	// Throw it all away.
	abortTransaction;
	delete moveController;
	
	*/
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_tiArray" type="ObjectArray" usage="input"/>
        <Parameter name="_strSuccesses" type="String" usage="output"/>
        <Parameter name="_strErrors" type="String" usage="output"/>
        <Parameter name="_noSuccesses" type="Integer" usage="output"/>
        <Parameter name="_noErrors" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="autoPlanValidateMoveToYA" id="208a2e62-85cb-4495-b8e6-fa8fca6a91cb">
        <updating/>
        <source>autoPlanValidateMoveToYA(_terminal : CM_Terminal; _location : CM_YardController; _ti : CM_TrackedItem)  updating;
// -------------------------------------------
// Created 10 June 2005 by cnwdvb1
// -------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars
	useOverStowNew	: Boolean;

begin

	 if _terminal = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'terminal has not been specified', null, null);
		return;
	endif;
	
	if self.myYAAgent = null then
		if not _terminal.isAutoPlanningEnabled() then
			return;
		endif;
		
		// Is system licensed for new autoplanning
		// If not raise exception.
		// ### JIRA 33505 30DEC2024 NAVAB1 Mod_YardPlanning is now part of base module
		/*
		if not app.getMyUser.canDo(_terminal, Mod_YardPlanning) then
			app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_YardPlanning), null, null);
			return;
		endif;
		*/
		
		if _terminal.isAutoPlanUseOverstowRules() then
			useOverStowNew := true;
		endif;

		create self.myYAAgent transient;
		self.myYAAgent.useOverstowRules := useOverStowNew;
	endif;
	self.myYAAgent.initialiseForTrxStart();
	self.myYAAgent.validateTiForLocation(_location, _ti);

epilog
	//delete self.myYAAgent;			// 21/02/2011 cnwmh5
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
