    <JadeMethod name="doCmbBoom_UpdateProxy" id="d9a7451a-0769-494a-bade-accdeb438415">
        <source>doCmbBoom_UpdateProxy(_combo : CMUI_ComboBox; _inBoom : Boolean): Boolean protected;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	table		: CM_BaseTable;
	gateArea	: CM_GateArea;
	gateLane	: CM_GateAreaLaneController;
	
begin 
	table := _combo.parent.CM_BaseTable;
	
	if not table.row &gt; table.fixedRows then
		return true;
	endif;

	if self.mode &lt;&gt; Mode_Add and self.mode &lt;&gt; Mode_Update then
		return true;
	endif;
		
	if table = tblGateLanes then 
		gateLane := self.getSelected_GateLane; 
		if gateLane = null then 
			return false;
		endif;
		
		gateLane.setBoom(_combo.listObject.CM_Boom, _inBoom);
		table.setCellText(table.row, table.column, _combo.text);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
        <Parameter name="_inBoom" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
