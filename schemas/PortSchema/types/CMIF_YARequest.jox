        <source>isWeightCertified_Match(_yaData: CM_YADataBoolean): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2016	cnwdap1		Initial creation TFS #1949 VGM Process Requirements - Allocations
//
vars

	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsWeightCert );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	return _yaData.doesValueMatch(self.isWeightCertified);

epilog

end;</source>
