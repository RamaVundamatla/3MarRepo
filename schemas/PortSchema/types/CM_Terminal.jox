    <JadeMethod name="pxyCreateUpdateProxy" id="6d33c5f6-8152-4909-99c3-050de77821e4">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 March 2002 by cnwdf1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 11/05/2023	navpw1		TFS: 54049 (55840) - Added code to populate the myVbsProcess on the proxy terminal object

vars
	proxyTerminal		 : CM_Terminal;
	aGraphic,pxyGraphic	 : CM_Graphic;
	completedOK		  	 : Boolean;
	pxyPrenoteValidation : CM_TermPrenoteWeightCriteria;
begin
	proxyTerminal := inheritMethod();
	self.allCargoBOLTypes.copy(proxyTerminal.allCargoBOLTypes);
	self.allStateObjects.copy(proxyTerminal.allStateObjects);
	self.allTerminalsForRelease.copy(proxyTerminal.allTerminalsForRelease);
	self.allTerminalsForVoyageInland.copy(proxyTerminal.allTerminalsForVoyageInland);
	
	foreach aGraphic in self.allLayoutGraphics do
		// get a proxy copy of the graphics
		pxyGraphic := aGraphic.pxyCreateUpdateProxy();
		pxyGraphic.CM_LayoutGraphic.setTerminal(proxyTerminal,aGraphic.label); // sets inverse to proxy terminal
	endforeach;
	
	self.allRTAllocationCriteriaTypes.copy(proxyTerminal.allRTAllocationCriteriaTypes);

	//epr TFS 1882 17/5/16
	if self.myPrenoteWeightCriteria &lt;&gt; null then
		pxyPrenoteValidation:=self.myPrenoteWeightCriteria.pxyCreateUpdateProxy();
	else
		create pxyPrenoteValidation transient;
	endif;
	pxyPrenoteValidation.setMyTerminal(proxyTerminal);
	
	proxyTerminal.myVBSProcess := self.myVBSProcess;	// ### TFS 54049 (55840) 05May2023 NAVPW1
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTerminal;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTerminal;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rebuildAllVoyagesNew" id="c3a4fa7a-e871-4985-a450-722483613e84">
        <source>rebuildAllVoyagesNew();

vars
	voy : CM_Voyage;
begin
	self.allVoyagesNew.clear;
	foreach voy in self.allVoyagesByCode do
		self.allVoyagesNew.putAtKey(voy.code, voy.arrivedDT, voy);
	endforeach;
	foreach voy in self.allVoyagesByInwardCode do
		self.allVoyagesNew.putAtKey(voy.inwardCode, voy.arrivedDT, voy);
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="refreshHazardMoveDetails" id="b6235d6a-35c2-4fe9-8f99-1259397bc45f">
        <source>refreshHazardMoveDetails(_ruleType : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	28 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	hazardClass				: CM_HazardClass;
begin
	if _ruleType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid rule type passed in ('&amp; _ruleType.String &amp; ')');
		return;
	endif;
	
	foreach hazardClass in app.myRoot.allHazardClasses do
		hazardClass.refreshHazardMoveDetails(_ruleType, self);
	endforeach;
		

end;


</source>
        <Parameter name="_ruleType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeDiscrepancy" id="5a458c4a-f2f8-4fb0-9d82-b38ec3a6f3af">
        <source>removeDiscrepancy(discrep : CM_Discrepancy);
//Removes an entry from the Discrpencies date dict. If the entry
//is then empty, it deletes the collection as well.

vars
	discrepancyArray	:	CM_DiscrepancyArray;

begin
 	discrepancyArray := self.discrepancies[discrep.date.date];
 	if discrepancyArray = null then
 		return;	
	endif;

	if discrepancyArray.includes(discrep) then
		discrepancyArray.remove(discrep);
	endif;

	// If there are none left remove the ordColl
	if discrepancyArray.size = 0 then
		self.discrepancies.removeKey(discrep.date.date);
		//rs 13/04/2005 the array was not being deleted
		delete discrepancyArray;
	endif;

end;</source>
        <Parameter name="discrep" type="CM_Discrepancy"/>
    </JadeMethod>
