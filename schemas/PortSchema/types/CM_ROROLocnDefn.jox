        <Parameter name="_split" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLabelManuallyChanged" id="13d5f712-0a5c-4333-a9db-5f5293737377">
        <updating/>
        <source>setLabelManuallyChanged(_value : Boolean) updating;

/*

Purpose:		Set the labelManuallyChanged flag

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation #29073

