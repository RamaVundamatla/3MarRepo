    <JadeMethod name="doSave" id="ae7d1b33-00ae-4322-b571-4291e99e71a8">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	pxyMapping, realMapping : CM_InvoiceLineChargeMapping;
	ls : Boolean;
	cpu : Real;
	rate : CM_Rate; 
	user : String; 
	start : TimeStamp;
	theReturn : Integer;
begin
	if self.myCurrentParentObject = null then
		app.msgBox("Cannot update mapping, please select something to map.", "Mapping Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbChargeTypeMap.listIndex = -1 then
		app.msgBox("Cannot update mapping, please select something to map.", "Mapping Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	realMapping := self.myCurrentMapping;

	if realMapping &lt;&gt; null then	
		self.mode := self.Mode_Update;
		app.cmsBeginLoad(ls);
		pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineChargeMapping;
		app.cmsEndLoad(ls);
	else
		self.mode := self.Mode_Add;
		create pxyMapping transient;
	endif;
	
	pxyMapping.setProxy(
			self.myCurrentBank,
			self.myCurrentParentObject, 
			self.myCurrentInvLineType, 
			self.myCurrentCombinationObject, 
			self.cmbChargeTypeMap.itemData[self.cmbChargeTypeMap.listIndex], 
			self.cmbChargeTypeMap.itemObject[self.cmbChargeTypeMap.listIndex].CM_DebtorType, //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
			self.cmbChargeTypeCom.itemObject[self.cmbChargeTypeCom.listIndex].CM_DebtorType.code // PAR 17557
	);
	
	while true do
		if self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineChargeMap(pxyMapping, app.myPassport);
		else
			app.myTrxCA.trxCreateInvoiceLineChargeMap(pxyMapping, realMapping, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyMapping;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveCopy" id="8507dc7e-fd84-4c4d-98de-73648ccb806e">
        <updating/>
        <source>doSaveCopy() updating;
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	objSet : ObjectSet;
	maps : CM_InvLineChargingMapsDict;
	replace : Boolean;
	theReturn : Integer;
	newParent : CM_Object;
begin

	if cmbChargeType.listIndex = -1 then
		app.msgBox("Please do a query, before a copy.", "Copy Problem", MsgBox_Exclamation_Mark_Icon);
		self.frmCopy.visible := false;
		return;
	endif;
	
	newParent := self.cmbParentCopy.listObject.CM_Object;

	if newParent = null then
		app.msgBox("Please select a " &amp; self.cmbChargeType.text &amp; " to copy to.", "Copy Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;


	create objSet transient;
	create maps transient;
	
	if self.optCopySelected.value 
	or self.optReplaceSelect.value then
		self.tblData.getSelectedCellObjects(objSet);
	else
		self.tblData.getAllCellObjects(objSet);
	endif;

	if objSet.isEmpty then
		app.msgBox("Nothing to copy for " &amp; self.cmbChargeType.text &amp; " '" &amp; self.cmbParentObject.text &amp; "'." &amp; Cr &amp; Cr 
						&amp; "Copy not performed.", "Copy Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	objSet.copy(maps);
	replace := (self.optReplaceAll.value or self.optReplaceSelect.value);

	while true do
		app.myTrxUA.trxUpdateInvLineChrgMapCopy(self.myCurrentBank, newParent, maps, replace, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Charge Mapping", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	
	self.frmCopy.visible := false;
epilog
	delete objSet;
	delete maps;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDelete" id="2a223fcc-b5f1-47a2-8a22-14d3a3fee99e">
        <updating/>
        <source>doSaveDelete() updating;
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	objSet : ObjectSet;
	maps : CM_InvLineChargingMapsDict;
	theReturn : Integer;
	messageStr, tmpStr : String;
begin

	create objSet transient;
	create maps transient;
	
	if self.cmbChargeType.listIndex = -1 then
		app.msgBox("Please do a query before a delete.","Delete Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	messageStr := self.cmbChargeType.text &amp; " '" &amp; self.cmbParentObject.text &amp; "'";
	
	if self.optDeleteSelect.value  then
		tmpStr := "the SELECTED";
		self.tblData.getSelectedCellObjects(objSet);
	else
		tmpStr := "ALL";
		self.tblData.getAllCellObjects(objSet);
	endif;

	if objSet.isEmpty then
		app.msgBox("Nothing to delete for " &amp; messageStr &amp; "." &amp; Cr &amp; Cr 
						&amp; "Delete not performed.", "Delete Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if app.msgBox("Are you sure that you want to delete " &amp;  tmpStr &amp; " mappings for " &amp; Cr 
				&amp;  messageStr &amp; " ?", "Delete Confirmation", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_OK then
		self.frmDelete.visible := false;
		return;
	endif;
	
	doCopy(objSet, maps);

	while true do
		app.myTrxDA.trxDeleteInvoiceLineChargeMaps(self.myCurrentBank,  maps,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Charge Mapping", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	
	self.frmDelete.visible := false;
epilog
	delete objSet;
	delete maps;

end;</source>
    </JadeMethod>
