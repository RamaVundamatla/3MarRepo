    <JadeMethod name="doAction" id="6d1a28c9-63f9-4afb-bc21-d754011d9575">
        <updating/>
        <source>doAction(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/04/2018	jlgdap1		Initial creation TFS 37858 PEL1 Invoice Status Advancement
// 22 Oct 2019	jlgdi1		Added lines of code to create an audit trail
// 05 Jun 2025  navma1		MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  

vars
	invoice			 : CM_Invoice;
	invStatus 		 : CMIF_InvoiceStatus;
	now 			 : TimeStamp;
	invalid 		 : Boolean;	//11 Feb 2019	NDL	TFS 43318
	auditAgent 	     : CM_UpdateTransactionAuditAgent;
	invProcess		 : CM_InvoiceProcess;
begin
	invoice := self.myInvoice;
	if invoice = null then
		self.logMessage(method.qualifiedName &amp; " Invoice is null - returning");
		return true;
	endif;
	
	if not self.getAndLockValidObject(invoice, Share_Lock, invalid) then
		if invalid then	//11 Feb 2019	NDL	TFS 43318
			self.logMessage(method.qualifiedName &amp; " Invoice " &amp; invoice.String &amp; " has been deleted - returning");
		else
			self.logMessage(method.qualifiedName &amp; " Could not lock Invoice " &amp; invoice.sequenceNum.String &amp; " - returning");
		endif;
		return true;
	endif;
	
	invProcess := invoice.getMyInvoiceProcess();			//05.06.2025 navma1 #MTN-34114
	
	self.logMessage(method.qualifiedName &amp; " Changing invoice " &amp; invoice.sequenceNum.String &amp; 
					" from " &amp; app.getInvoiceStatusString(invProcess, invoice.status) &amp; // TFS 39618
					" to "   &amp; app.getInvoiceStatusString(invProcess, invoice.INVOICE_PENDING)); // TFS 39618

	create invStatus transient;
	invStatus.newStatus := CM_Invoice.INVOICE_PENDING;
	invStatus.myInvoice := invoice;
	if invoice.toDT.isValid() then
		invStatus.toDT := invoice.toDT;
	else
		now := app.actualTimeServer;
		invStatus.toDT := now;
	endif;

	if app.myAA &lt;&gt; null then 
		app.myAA.initialiseAudit();
	endif;
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	auditAgent := app.myUtilityUA.myUpdateAuditAgent;
	auditAgent.audUpdateGeneric(invoice, true);
	
	invoice.setForUpdateStatus(invStatus, true); // TFS 39618
	
	if app.myPassport.noErrors() then 
		auditAgent.audUpdateGeneric(invoice, false);
		invoice.causeEvent(invoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
	endif;
	
	self.logMessage(method.qualifiedName &amp; " Finished changing invoice " &amp; invoice.sequenceNum.String &amp; 
					" from " &amp; app.getInvoiceStatusString(invProcess, invoice.status) &amp; // TFS 39618
					" to "   &amp; app.getInvoiceStatusString(invProcess, invoice.INVOICE_PENDING)); // TFS 39618
	return true;
	
epilog
	delete invStatus;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
