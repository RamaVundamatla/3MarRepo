    <JadeMethod name="cmbHeadingBuild" id="676eb594-073e-4a25-a52c-704d29c700e8">
        <source>cmbHeadingBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	obj : Object;
	chapter : CM_HSCodeChapter;
	heading : CM_HSCodeHeading;
	idx : Integer;
	str : String;
	iter : Iterator;
	section : CM_HSCodeSection;
begin
	self.cmbHeading.clear;
	self.cmbHeading.sorted := false;
	self.cmbHeading.addItem(app.getErrorString(All_Headings));
	self.cmbHeading.itemObject[self.cmbHeading.newIndex] := null;
	self.cmbHeading.listIndex := 1;
	
	obj := self.cmbChapter.listObject;
	
	if obj = null or not obj.isKindOf(CM_HSCodeChapter) then
		iter:=app.myRoot.allHSHeadings.createIterator;
		section:=self.cmbSection.listObject.CM_HSCodeSection;
		if section = null then
			return;
		endif;
	else
		chapter := obj.CM_HSCodeChapter;
		iter:=chapter.allHSCodeHeadings.createIterator;
	endif;
	
	while iter.next(heading) do
		if section &lt;&gt; null and heading.getMySection &lt;&gt; section then
			continue;
		endif;
	
		idx := self.cmbHeading.addItem(heading.getDisplayString);
		self.cmbHeading.itemObject[idx] := heading;
	endwhile;
	
	self.cmbHeading.listIndex := 1;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbSectionBuild" id="c601de8b-d421-43e3-8825-a1aba0f97f54">
        <source>cmbSectionBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	section : CM_HSCodeSection;
	lastSection : CM_HSCodeSection;
	idx : Integer;
	str : String;
	iter : Iterator;
	hs : CM_HarmonizedSystem;
	lastChapter : String;
	
begin
	self.cmbSection.clear;
	
	iter := app.myRoot.allHSCodesActive.createIterator();
	
	while iter.next(hs) do
		if hs.id[1:2] = lastChapter then
			continue;
		endif;
		
		section := hs.getMySection();
		if section = null or section = lastSection then
			continue;
		endif;
		
		lastSection := section;
		lastChapter := hs.id[1:2];

		idx := self.cmbSection.addItem(section.getDisplayString);
		self.cmbSection.itemObject[idx] := section;
	endwhile;
	
	self.cmbSection.listIndex := -1;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbSection_closeup" id="8638cf34-eb8c-493c-935b-001cc9328a2e">
