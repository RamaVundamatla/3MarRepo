    <JadeMethod name="getNumberFulfilled" id="909a2cec-250c-4a9c-8741-d44d99bf5075">
        <source>getNumberFulfilled(): Integer;
// ---------------------------------------------------------------------------
// Created:     06 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutLine		: CM_BOLOutStockOrderLineTI;
begin
	bolOutLine := self.allBOLOutStockOrderTIs.first;
	if bolOutLine &lt;&gt; null and
	   bolOutLine.myTrackedItem &lt;&gt; null then
		return 1;
	else
		return 0;
	endif;
	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPercentFulfilled" id="fb84ee9d-6e95-4b45-91d2-a4a79c1ec6f7">
        <source>getPercentFulfilled(): Decimal;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutOrderLine			 : CM_BOLOutStockOrderLineTI;
begin
	bolOutOrderLine := self.allBOLOutStockOrderTIs.first;
	if (bolOutOrderLine.myTrackedItem = null) then
		return 0;
	else
		return 100.00;
	endif;

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
