    <JadeMethod name="getNestedLocationsYA" id="f4b9825c-4801-4de7-8dcd-d0da2e780ffb">
        <source>getNestedLocationsYA(_yaAgent : CM_YAAutoplanAgent input; _yardLocation : CM_YardController; _rtnValue : Integer output) : Boolean;
// -------------------------------------------
// Created 06 May 2005 by cnwdvb1
// -------------------------------------------
vars

	
	rtnValue	: Integer;

begin

	// Location is cool so far. See if it has nested allocations.
	// At this stage location has passed all tests.
	
	rtnValue :=  _yardLocation.getNestedLocationsYA(_yaAgent);
	
	if rtnValue  = YAOverlap_Never then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _yardLocation.getFullId() &amp; ' is covered by allocations with allow others never', true);
		return false;
	elseif rtnValue = YAOverlap_LastResort then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _yardLocation.getFullId() &amp; ' is covered by other allocations with allow other last resort. Continuing . . .', true);
		// Has nested locations. Saved these away to use later if necessary.
		return false;
	elseif rtnValue = YAOverlap_Sometimes then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _yardLocation.getFullId() &amp; ' is covered by allocations with allow sometimes', true);
		// Continue on as location is good enough.
	elseif rtnValue = YAOverlap_Always then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _yardLocation.getFullId() &amp; ' is covered by allocations with allow always', true);
		// Continue on as location is good enough.
	endif;
	
	// CCMS 1357
	// This failed overstow voyage rules but is allowed to continue
	// as a last resort due to configuration rule.
	if _yaAgent.myCurrentCMIFYAAutoPlan.allLCsTempLastResort.includes(_yardLocation) then
		_yaAgent.addLocationToAgent(_yardLocation, YAOverlap_LastResort);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _yardLocation.getFullId() &amp; ' added as a last resort (Overstow later voyages). Continuing . . .', true);
		rtnValue := YAOverlap_LastResort;
		return  false;
	endif;
	
	
	// Everything is good.
	
	// You only have to supply the first controller regardless of whether the box is a 20 or a 40.
	
	_yaAgent.addLocationToAgent(_yardLocation, CM_YAAutoplanAgent.Locations_Found);
	
	return true;
	
epilog
	
	// Wanna keep going for verbose
	if not _yaAgent.isSingleProcessing() then
		if rtnValue = YAOverlap_Never then
			return false;
		else
			return true;
		endif;
	endif;
	
	_rtnValue := rtnValue;
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_yardLocation" type="CM_YardController"/>
        <Parameter name="_rtnValue" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNonMatchingTIs" id="d5c50d39-0e6b-4241-8631-1e131f59dbd9">
        <source>getNonMatchingTIs(_tis : CM_TIByIdDict input; _cmifAutoPlan : CMIF_YAAutoPlanNormal input);
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpYC				: CM_YardController;
	tmpTI				: CM_TrackedItem;

begin

	// Run through all locations for this block.
	foreach tmpYC in self.allYardControllers discreteLock do
		
		foreach tmpTI in tmpYC.allTrackedItems discreteLock  do
			_cmifAutoPlan.attachTI(tmpTI);
			if not self.myYardAllocationIn.compareCriteriaToCMIF(null, _cmifAutoPlan) then
				_tis.addNoDuplicates(tmpTI,false);
			endif;
		endforeach;
		
	endforeach;
	
end;</source>
        <Parameter name="_tis" type="CM_TIByIdDict" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlanNormal" usage="input"/>
    </JadeMethod>
