    <JadeMethod name="erase" id="3ad1dce3-24b2-470d-9eba-77046b1d2fe8">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin	
	// delete the IN-TRANSIT-TO LC for this gate area
	if not self.isTransient then
		self.myInTransitToLocation.erase (_level);
	endif;

	inheritMethod(_level);
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllLaneControllers" id="e689ee83-e226-49f2-b537-84b2ad988697">
        <source>getAllLaneControllers(_coll :CM_ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col		:CM_GridColumn;
	lc		:CM_LocationsController;
begin
	foreach col in self.allGridColumns do
		foreach lc in col.allControllersByRow do
			_coll.add (lc);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="66cd12d4-f0c8-4d66-a326-e97b930444f8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_Area_in_out then
		// this is shown as a picture in the table so no need to return a value
		return null;	
	elseif _attrName = ETRow_Area_id then
		return self.id;
	elseif _attrName = ETRow_Area_comment then
		return self.comment;
	elseif _attrName = ETRow_Area_laneCount then
		return self.laneCount.String;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstAvailalableLane" id="acea0877-a728-4842-bd4c-57e6786fd50c">
        <source>getFirstAvailalableLane():CM_LaneController;
// ---------------------------------------------------------------------------
// Created:     27 May 2010 by cnwcs5
// Purpose:     par 24292 - Find a lane that has capacity for another vehicle
// Parameters:  None
// Returns:     Returns the first lane with available space for the receiver
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_LCArray;
	lc		:CM_LocationsController;
	lane	:CM_LaneController;
begin
	create coll transient;
	
	self.getAllLaneControllers (coll);
	
	foreach lc in coll do
		lane := lc.CM_LaneController;
		
		if lane.isUnavailable then
			continue;
		endif;
		
		if lane.capacity = 0 then
			// no limit on this lane
			return lane;
		endif;
		
		if lane.allVehicleMachines.size &lt; lane.capacity then
			// still has room for more vehicles
			return lane;
		endif;
	endforeach;
	
	return null;
epilog
	delete coll;
end;</source>
        <ReturnType type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="getLaneByNumber" id="b665b504-cf0b-4a1f-b692-503421b28987">
        <source>getLaneByNumber(_lane :Integer):CM_LaneController;
// ---------------------------------------------------------------------------
// Created:     30 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	:CM_GridRow;
begin
	row := self.getRowByNumber (_lane);
	
	if row = null then return null; endif;

	return row.allControllersByColumn[1].CM_LaneController;
epilog

end;</source>
        <Parameter name="_lane" type="Integer"/>
        <ReturnType type="CM_LaneController"/>
    </JadeMethod>
