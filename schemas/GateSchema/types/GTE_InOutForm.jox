        <updating/>
        <source>packTempF_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if pValue &lt;&gt; null then
