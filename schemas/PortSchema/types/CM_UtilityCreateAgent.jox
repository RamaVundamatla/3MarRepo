				_newEventType 	: CM_EventType output;
				_passport 		: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	terminalRoot : CM_SecurityRoleTerminalRoot;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valEventType(_pxyEventType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newEventType persistent;
	
	_newEventType.setForCreate(_pxyEventType);
	
	//09 Mar 2020	NDL	TFS 48784
	if _passport.noErrors then
		if _newEventType.canIncludeInSecurityRole then
			terminalRoot := CM_SecurityRoleTerminalRoot.firstInstance;
			if terminalRoot &lt;&gt; null then
				terminalRoot.addEventType( _newEventType );
			endif;
		endif;
	endif;
	
	// PAR 15654 - add auditing
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newEventType);
	endif;

end;</source>
