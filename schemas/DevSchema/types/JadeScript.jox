    <JadeMethod name="sh3TestCrLf" id="82ae842f-5961-46a9-9038-c0865c36fdaa">
        <source>sh3TestCrLf();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 23 June 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	str : String;
	//tempStr : String;
	pos : Integer;
begin
	str := "12345" &amp; CrLf &amp; "ABCDE";
	app.writeStatement( str);
	//terminate;
	if str.length &lt;&gt; 0 then
		pos := str.pos(CrLf, 1);
		while pos &gt; 0 do
			if pos + 2 &gt; str.length then 
				str := str[1:pos - 1];
				break;
			endif;
			str := str[1:pos] &amp; ' ' &amp; str[pos+2:end];
			pos := str.pos(CrLf, 1);
		endwhile;
		str.replaceChar(Cr.Character, ' ');
		str.replaceChar(Lf.Character, ' ');
	endif;
	app.writeStatement( str);
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3TestResourceUsed" id="4356aeb6-75c7-4aa5-901b-21d259ca2808">
        <source>sh3TestResourceUsed();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 01 March 2012
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	int : Integer;
begin
	self.sh3StandardInitialize();
	
	foreach ti in app.myPassport.myTerminal.allOnsiteTIsByCargoTypeId where ti.allTransactions.isNotEmpty() do
		
		if int &gt; 4 then
			break;
		endif;
		if ti.getAllToTaskCompleteResString() &lt;&gt; null then
			write ti.String &amp; Tab &amp; ti.id;
			//break;
			int := int +1;
		endif;
	endforeach;
		
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3TimeRangeIncludes" id="d3bb9d84-7392-4f74-9dac-c27abd4ecd62">
        <source>sh3TimeRangeIncludes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2021	navsh3	Initial creation

*/

vars
	fromTime,
	toTime		: Time;
	fromTS,
	toTS		: TimeStamp;
	fromDate,
	toDate		: Date;
	interval	: TimeStampInterval;
	
begin
	fromDate := "16/11/2021".Date;
	toDate	:= "16/11/2021".Date;
	
	fromTime := "07:00:00.000".Time;
	toTime := "14:00:00.000".Time;
	
	fromTS.setDate(fromDate);
	fromTS.setTime(fromTime);
	
	toTS.setDate(toDate);
	toTS.setTime(toTime);
	
	interval := toTS - fromTS;
	write interval;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sh3UnplanTI" id="4e094295-5ae0-45fc-b35f-6184e539e137">
        <source>sh3UnplanTI(_ti : CM_TrackedItem);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		30 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	moveControl : CMIF_MoveController;
begin
	create moveControl transient;
	while _ti.isPlanned(PLANNING_MODE) do
		moveControl.setMoveMode(PLANNING_MODE);
		moveControl.isForcedMove := true;
		moveControl.setMyTrackedItem(_ti);
		moveControl.setMyWorkListEntry(_ti.allWorklistEntries.last);
		app.myTrxUA.trxUpdateMoveTIUndo(moveControl, app.myPassport);
	//	self.assertNoTrxErrorsOrWarnings();
	endwhile;
epilog
	delete moveControl;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="sh3UnqueueTI" id="60ca9771-ca5f-4871-a6fa-3cc08a4ebb27">
        <source>sh3UnqueueTI(_ti : CM_TrackedItem);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		30 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	moveControl : CMIF_MoveController;
	queuedFutureMove : CM_FutureMoveQueued;
	futureMove		: CM_FutureMove;
	allFMs			: CM_FutureMoveArray;
	index: Integer;
begin
	create moveControl transient;
	create allFMs transient;
	_ti.allQueuedFutureMoves.copy(allFMs);
	//was causing an endless loops trying to unqueue entries with overstow tasks
	foreach index in 1 to allFMs.size reversed do 
		queuedFutureMove:= allFMs[index].CM_FutureMoveQueued;
		if queuedFutureMove.moveType = TI_FutureMoveOverstow then
			continue;
		endif;
		moveControl.setMoveMode(QUEUE_MODE);
		moveControl.isForcedMove := true;
		moveControl.setMyTrackedItem(_ti);
		moveControl.setMoveIndex(index);
		moveControl.setMyWorkListEntry(queuedFutureMove.myWorkListEntry);
		app.myTrxUA.trxUpdateMoveTIUndo(moveControl, app.myPassport);
		
	endforeach;
epilog
	delete moveControl;
	delete allFMs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="sh3WriteTerminalAreaTypes" id="24dbe81e-3d8a-4eec-8edc-f6338592ccc3">
        <source>sh3WriteTerminalAreaTypes();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 21 August 2012
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	ta : CM_TerminalAreaType;
begin
	self.sh3StandardInitialize();
	write 'Terminal Area Type Values and Descriptions';
	foreach ta in app.myRoot.allTerminalAreaTypes do
		write ta.type.String &amp; ' - ' &amp; ta.description;
