    </JadeMethod>
    <JadeMethod name="logMsg" id="9f4feaa2-04ba-48d6-9aef-dc1afa7a1a67">
        <source>logMsg(_msg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	self.lstLog.addItemAt(_msg, 1);
	inheritMethod(_msg);
	

epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
