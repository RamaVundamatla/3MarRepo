    <JadeMethod name="getTimeFormat" id="4365fedc-0391-4bf5-9800-74861f2ac18d">
        <source>getTimeFormat(pTimeFormatObj:TimeFormat io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the receiver to the specified
//				TimeFormat.
//
// Parameters:	pTimeFormatObj - The TimeFormat to update.
//
// Returns:		The TimeFormat as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pTimeFormatObj.amText			:=	self.amText;
	pTimeFormatObj.ampmIsSuffix		:=	self.ampmIsSuffix;
	pTimeFormatObj.format			:=	self.format;
	pTimeFormatObj.is12HourFormat	:=	self.is12HourFormat;
	pTimeFormatObj.pmText			:=	self.pmText;
	pTimeFormatObj.separator		:=	self.separator;
	pTimeFormatObj.showLeadingZeros	:=	self.showLeadingZeros;
	pTimeFormatObj.showSeconds		:=	self.showSeconds;
end;</source>
        <Parameter name="pTimeFormatObj" type="TimeFormat" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="65be342e-9da2-4de0-97dc-4aafdbc671bb">
        <updating/>
        <source>updateMe(pTimeFormatObj:TimeFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified TimeFormat to the
//				receiver.
//
// Parameters:	pTimeFormatObj - The TimeFormat, who's property values to copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.amText				:=	pTimeFormatObj.amText;
	self.ampmIsSuffix		:=	pTimeFormatObj.ampmIsSuffix;
	self.format				:=	pTimeFormatObj.format;
	self.is12HourFormat		:=	pTimeFormatObj.is12HourFormat;
	self.pmText				:=	pTimeFormatObj.pmText;
	self.separator			:=	pTimeFormatObj.separator;
	self.showLeadingZeros	:=	pTimeFormatObj.showLeadingZeros;
	self.showSeconds		:=	pTimeFormatObj.showSeconds;
end;</source>
        <Parameter name="pTimeFormatObj" type="TimeFormat"/>
    </JadeMethod>
</Class>
