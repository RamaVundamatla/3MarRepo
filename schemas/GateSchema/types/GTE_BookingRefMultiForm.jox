    <JadeMethod name="userNotify" id="d4f69c9a-790b-45cf-b1fb-b639aa9b4333">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     01 June 2001 by cnwrs2
//
// ---------------------------------------------------------------------------
// 08/02/2010	cnwcs5	par 22562 - do not select _object in table
// 17/06/2013	cnwcs5	par 31670 - 
vars
	termEvent		: Integer;
	invalidObject	: Boolean;
	bookingRefItem	: CM_BookingRefItem;
	obj				: Object;
	booking			: CM_BookingRef;
	
begin
	on Exception do app.handleDeletedObject(exception, _object, invalidObject);	//Par18495. For EDI action loading mode. Booking Reference can be created, deleted and re-created in on e EDI file.

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(_eventType);
	endif;
	
	if termEvent = TIEvent_PreNote_Add or termEvent = TIEvent_PreNote_Delete then					//+cnwml2 PAR21708
		//+cnwml2 PAR21708
		if not _object.isKindOf(CM_TrackedItem) then 
			return;
		endif;
		
		booking := _object.CM_TrackedItem.myBookingRef;

		if booking &lt;&gt; null then
			if self.btnShowBookItms.value then
			
			else
				self.zTblDataSysNotifyUpdate(Object_Update_Event, booking, _eventTag);
			endif;
		endif;
		
	elseif termEvent = Event_BookingRefAdd or termEvent = Event_BookingRefUpdate then
		if self.btnShowBookItms.value then
			if termEvent = Event_BookingRefAdd then
				foreach bookingRefItem in _object.CM_BookingRef.allBookingRefItems do
					self.zTblDataSysNotifyCreate(Object_Create_Event, bookingRefItem, _eventTag);
				endforeach;
				
			elseif termEvent = Event_BookingRefUpdate then
				foreach bookingRefItem in _object.CM_BookingRef.allBookingRefItems do
					self.zTblDataSysNotifyUpdate(Object_Update_Event, bookingRefItem, _eventTag);
				endforeach;
				
			else
				inheritMethod(_eventType, _object, _eventTag, _userInfo);
			endif;
		else
			if termEvent = Event_BookingRefAdd then
				self.zTblDataSysNotifyCreate(Object_Create_Event, _object, _eventTag);
				
			elseif termEvent = Event_BookingRefUpdate then
				self.zTblDataSysNotifyUpdate(Object_Update_Event, _object, _eventTag);
				
			else
				inheritMethod(_eventType, _object, _eventTag, _userInfo);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewEDIData" id="6fa2ff9f-b1b0-4536-afb8-096403bd606b">
        <source>viewEDIData(_ediData : CM_EDIData);
//
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	ediFileObj		: CM_EDIFile;
	tmpFile			: File;
	fileName		: String;
	str				: String;
	theLines : HugeStringArray;
	invalidFileName	: Boolean;
	fileEx			: FileException;
begin
	on FileException do self.fileExceptionHandler(fileEx, invalidFileName);

	if _ediData = null then
		return;
	endif;
	
	if _ediData.myEDIFile = null then // ediFileArray.isEmpty() then // ccms1117 cnwrs1 29 Apr 2010
		return;
	endif;
		
	create tmpFile;
	// ccms1117 cnwrs1 29 Apr 2010 and TFS 1937 check for null file name
	fileName := app.getFileName(_ediData.myEDIFile.fileName).trimBlanks();	 //PAR22336 - presentation client executed so no need for app.getTempDirFromSystemConfig
	if fileName = null then
		fileName := "File" &amp; _ediData.getOidString;
	endif;
	tmpFile.fileName	:=	app.getTempDir() &amp; fileName;
	
	if tmpFile.isAvailable() then
		tmpFile.purge();
	endif;

	tmpFile.mode := File.Mode_Output;
	tmpFile.open();
	// TFS 1937 the CM_EDIFile.fileName can be invalid, use an arbitrary but unique name instead for the temporary file
	if invalidFileName then
		tmpFile.fileName := app.getTempDir() &amp; "File" &amp; _ediData.getOidString;
		if tmpFile.isAvailable() then
			tmpFile.purge();
		endif;
		tmpFile.open();
	endif;
	
	ediFileObj	:=	_ediData.myEDIFile; // ediFileArray.first(); // ccms1117 cnwrs1 29 Apr 2010

	create theLines transient;
	ediFileObj.myEDIFileType.rawDataToHSA(ediFileObj, theLines);
	foreach str in theLines do
		tmpFile.writeLine(str);
	endforeach;

	tmpFile.close();
	
	if tmpFile.fileName &lt;&gt; null then
		app.createExternalProcess("notepad.exe " &amp; tmpFile.fileName, false);
	endif;
epilog
	delete tmpFile;
	delete theLines;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="3a4b587c-aed1-459c-aa54-13733e709021">
        <updating/>
        <source>zDoAdd() updating, protected;
/*
Date		Who		Reason
25 November 2008	cnwer1	Initial creation
*/
vars

begin	
	//+cnwml2 PAR23230
	//when the user attempts to add an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;


	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	
	if self.isEnhanced then
		self.myAssistant.GTE_Assistant.doAddEditBookRequest(null);	//PAR 20296 Sep 2009
		self.myProxyObject:=null;
		self.allProxyObjects.clear;
		return;
	endif;

	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="d8b35bb7-4297-4acd-aa7c-4030e7a0ffdc">
        <updating/>
        <source>zDoEdit() updating, protected;
/*
Date		Who		Reason
25 November 2008	cnwer1	Initial creation
*/

vars
	bookRef : CM_BookingRef;
	bookItem : CM_BookingRefItem;
begin
	//+cnwml2 PAR23230
	//when the user attempts to edit an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;

	if (self.allowUpdate = false) or
	   (self.mode &lt;&gt; Mode_View) then 
		//Must not be already editing an object
		return;
	endif;
	
	if self.isEnhanced then
		if self.btnShowBookItms.value then
		
			bookItem := tblData.allSelectedObjects.first.CM_BookingRefItem;
			if bookItem = null then
				app.msgBox('You must select a Booking Item in the table.','Update error',MsgBox_OK_Only);
				return;
			endif;
		
			self.myAssistant.GTE_Assistant.doAddEditBookRequest(bookItem.myBookingReference);	
			self.myProxyObject:=null;
			self.allProxyObjects.clear;
			return;
		else
			bookRef := tblData.allSelectedObjects.first.CM_BookingRef;
			if bookRef = null then
				app.msgBox('You must select a Booking in the table.','Update error',MsgBox_OK_Only);
				return;
			endif;
		
			self.myAssistant.GTE_Assistant.doAddEditBookRequest(bookRef);	//PAR 20296 Sep 2009
			self.myProxyObject:=null;
			self.allProxyObjects.clear;
			return;
		endif;
	else
		if self.btnShowBookItms.value then
			if self.myCurrentObject.isKindOf(CM_BookingRefItem) then
				self.myCurrentObject := self.myCurrentObject.CM_BookingRefItem.myBookingReference;
			endif;
		endif;
	endif;	

	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
