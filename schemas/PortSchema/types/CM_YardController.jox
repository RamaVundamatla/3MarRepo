    <JadeMethod name="hasMatchingRangeForTemp" id="01548930-64c6-43ae-bcdb-49ac0a7443f7">
        <source>hasMatchingRangeForTemp(_flashpoint : Real) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhanements
//
vars
	hazDetail : CM_TerminalAreaHazDetails;
	tempRange: CM_HazTempRange;

begin
	if self.allTerminalAreaHazDetails.isEmpty then
		return true;
	endif;
	
	foreach hazDetail in self.allTerminalAreaHazDetails do
		foreach tempRange in hazDetail.allHazTempRanges do
			if tempRange.lower &lt;= _flashpoint and tempRange.upper &gt;= _flashpoint then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_flashpoint" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
