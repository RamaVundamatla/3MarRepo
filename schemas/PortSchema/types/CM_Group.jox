    <JadeMethod name="getDisplayDetails" id="7a2ef829-eec1-4cea-9540-32948986bfeb">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		//return '('&amp;self.code&amp;')  '&amp;self.description;
		return self.code &amp; '  ' &amp; self.description;			//+cnwml2 PAR21662

	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
