    <JadeMethod name="trxUpdateEDICustomBolStop" id="8d40b7f7-0267-43e2-8636-7c699631f318">
        <updating/>
        <source>trxUpdateEDICustomBolStop(_pxyBol: CM_BOL input; _ediData: CM_EDIDataCustomStop; _ediCusStopTI: CM_EDICustomStopTI input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2017	cnwndl1	Initial creation	TFS 3857

*/

vars

	ediTI : CM_EDICustomStopTI;
	theRealBol : CM_BOL;
	expectedEdition : Integer;
	ediFileType : CM_EDIFileType;
	allFileLinesObj : StringArray512;
	ediFileObj : CM_EDIFile;
	theLines : HugeStringArray;
	fileLine : String;
	fileTypeString : String;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	app.setContinueCMExceptions(true);
	
	ediTI := _ediCusStopTI;

	beginTransaction;
	
	_pxyBol.raiseExceptionIfNotProxy(method); 
	_pxyBol.pxyGetRealObjectAndEdition(theRealBol, expectedEdition);

	ediFileType := ediTI.myEDIFile.myEDIFileType;		
	if ediFileType &lt;&gt; null	and not (ediFileType.allEDIActions.isEmpty) then
		//perform the edi actions and update customs entry number
		app.myUtilityUA.utlUpdateBolFromEDIAction(_pxyBol, ediTI, ediFileType, _passport);
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
	endif;
		
	if _passport.hasErrors then
		return;
	endif;
	
	ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
	
	app.myPassport.doDeferredUpdates();
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
	delete theLines;
	delete allFileLinesObj;
	
end;</source>
        <Parameter name="_pxyBol" type="CM_BOL" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIDataCustomStop"/>
        <Parameter name="_ediCusStopTI" type="CM_EDICustomStopTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDICustomStop" id="742a8c29-f829-4b6f-943c-c8649bf9f487">
        <updating/>
        <source>trxUpdateEDICustomStop(_pxyTI: CM_TrackedItem input; _ediData: CM_EDIDataCustomStop; _ediCusStopTI: CM_EDICustomStopTI input; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	17 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 17/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 12/06/2012	cnwrs1		Par 29798 fix up Import Cancellation to check Customs Entry number not CEDO
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 25 May 2018	jlgrh7 TFS #38667 PNL - Customs File - Unprocessed 0 items
vars

	ediTI				: CM_EDICustomStopTI;
	passport			: CM_Passport;
	error : CM_Error;
	gotLockException : Boolean;										//+TFS38667

	
begin
	passport := _passport;
	// Always initialize the activity first
	self.initialiseActivityWithPassport(passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, passport);
	//on LockException do agtPassportLockExHandler(exception, passport);																//-TFS38667
	on LockException do agtPassportSilLckExHandlerFlg(exception, 0, gotLockException, _passport);			//+TFS38667 to get lock flag

	_passport.useTIDictDeferUpdate := true; //Feb 2008 cnwrs1 to try and cleanup deadlocks
	_passport.useTITransactionDeferUpdate := true;

	app.setContinueCMExceptions(true);
	
	ediTI 				:= _ediCusStopTI;
	
	beginTransaction;				
																												//+TFS38667 moved previoud coding to the new utl method as we could get error and return in many places
	app.myUtilityUA.utlUpdateEDICustomStop(_pxyTI, 
																							_ediData,
																							_ediCusStopTI, 
																							_passport);

	app.myPassport.doDeferredUpdates();
	
	if passport.hasErrors then																													//+TFS38667
		foreach error in passport.allErrorWarnings do
			if error.myUserObject = null then
				error.setMyUserObject(ediTI);
			endif;
		endforeach;
	endif;
	
	if gotLockException then
	beginTransaction;	
		ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_LOCKERROR);
	commitTransaction;
	endif;																																								//+TFS38667 Ends
epilog
	self.finaliseActivityWithPassport(passport);
	
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIDataCustomStop"/>
        <Parameter name="_ediCusStopTI" type="CM_EDICustomStopTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
