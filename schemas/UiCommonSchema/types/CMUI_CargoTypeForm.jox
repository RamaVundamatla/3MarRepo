    <JadeMethod name="doDelete" id="abee8c44-b780-4e6b-b145-8d12b7988a74">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 10.JUN.2025  navsp1      JIRA-34555 MTN | Cargo Type warning form missing Save button
vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin
  	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCargoType(self.myCurrentObject.CM_CargoType, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.setMyCurrentCargoType(null);
			return true;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(CargoType), app.myPassport, ErrWarnMode_Delete+ErrWarnMode_CanAckWarnings);  //JIRA-34555
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="fa4de7b1-016a-4fed-919c-527134974c5a">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2022	navsp1	Initial creation - TFS 52786

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	methodStartTime	: TimeStamp;
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper() ; //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx); // ### TFS 51912 22Sep2021 NAVPW1 Needed as we use accessedRow below. Plus needed for columns of current row
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuEditAttributes" id="e6323659-1417-4d89-886d-11b827a9aa34">
        <updating/>
        <source>doMenuEditAttributes() updating;
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	form			: CMUI_ProductTypeEditForm;
	theTI			: CM_TrackedItem;
	currentProdAttr	: CM_ProductAttr;
	origProductType	: CM_Product;

begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	create origProductType transient;
	origProductType.setForUpdate(self.pxySystemProductType);
	
	create form;
	form.centreWindow;
	
	form.myProductType := self.pxySystemProductType;
	currentProdAttr := self.tblAttributes.accessRow(self.tblAttributes.row).itemObject.CM_ProductAttr;
	form.myCurrentProdAttr := currentProdAttr;
	
	form.myCargoType := null;	// when calling from CMUI_CargoTypeForm, always populate all attributes for editting. form.cargoType is used, when calling from GC_ProductMaint. PAR 21339 Oct 2009
	
	form.setMyTerminal(self.myTerminal);
	//form.caption := "Attributes";
	form.setFormParent( self );
	form.myForm := self;	// for saving isCodesEdit need to call CM_TableViewForm :: setIsCodesEdit()
	form.showModal;
	
	if form.modalResult &lt;&gt; IDOK then
		//restore system product before changes
		self.pxySystemProductType.setForUpdate(origProductType);
		
	else	// display new product type attributes
		self.displayAttributes(self.pxySystemProductType,self.cmbProductType.listData);
		if form.isCodesEdited then	// the warning will be given, when codes were edited
			self.setIsCodesEdited();
		endif;
		
	endif;
	
epilog
	delete origProductType;
	
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="00b7d144-067d-4c65-8db8-889904d681cb">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	tbl			: CM_ThumbnailTable;
begin
	
	inheritMethod();
	self.lblSysType.left := (self.tblDefaultValues.width / 2) - (self.lblSysType.width / 2);
	self.lblSysType.top := (self.tblDefaultValues.height / 2);

	self.resizeShtDamageContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fb85ee21-4945-48e2-8069-a938af443b15">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 22/03/2010	cnwdap1		PAR #22995 Allow Break-Bulk with no cargo subtypes to have reefer properties
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 16/03/2018	jlgrh7 		TFS #37634 JMT - Updating Cargo Type is removing previously defined Default Commodity Code
// 07/03/2019	jlgdap1		TFS 41570 PNL No PIN for Cargo Type
// 10/08/2022   navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
// 01/05/2023	jlizm1		TFS 55453 Cargo uniqueness by subtype
// 11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
// 06/09/2024	jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references

vars
	pxyCargoType		   	: CM_CargoType;
	id					   	: Integer;
	pxyDraw				   	: CM_DrawingAttribute;
	productType 		   	: Integer;
	defaultCommodityCode   	: String;
	selectedTerminals	   	: CM_TerminalSet;
	selectedCommodities	   	: CM_CommodityByCodeDict;
	isSubCargoTypeRequired 	: Boolean;
	selectedDamageCodes	   	: CM_ObjectSet;
	selectedDamagePos      	: CM_ObjectSet;
	selectedSealTypes	   	: CM_SealTypeSet;
	colour 				   	: Integer;
	behaviourType	   	   	: CM_TIBehaviourType;
	result 				   	: Integer;
	trackBy				   	: Integer;						// PAR #33606
	weightType			   	: CM_MeasurementType;			// PAR #33606
	volumeType			   	: CM_MeasurementType;			// PAR #33606
	defalutCommodity       	: CM_Commodity;					//+TFS37634
	populateDefaults       	: Boolean;
	cargoGroupUniqueness   	: Boolean;	 					//navnk20 20/05/2022 TFS 53508
	isCargoGroupRequired   	: Boolean;  					//10/08/2022 navds20 TFS 54219
	subtypeUniqueness		: Boolean;						// TFS 55453
	allowMultiOperators     : Boolean; //11/07/2023 navmv20 CR 58244 Task 58245
	
begin

	//change colour of drawing attribute 
	self.doTblEntDetailRowColChange();
	
	if self.mode = Mode_Add then
		create pxyCargoType transient;
		id := pxyCargoType.getNewId;
	elseif self.mode = Mode_Update then
		pxyCargoType := self.myProxyObject.CM_CargoType;
		id := pxyCargoType.id;
	else
		return false;
	endif;
	
	
	create selectedTerminals transient;
	self.mulSelectTerm.getSelected(selectedTerminals);		//PAR 19704. CCMS 1080 May 2009 cnwvu1
	pxyCargoType.addSelectedUserTerminals(selectedTerminals);
	
	create selectedDamageCodes transient;
	self.mulDmgeDefCode.getSelected(selectedDamageCodes);
	
	create selectedDamagePos transient;
	self.mulDmgePosition.getSelected(selectedDamagePos);
	
	//+cnwml2 PAR23715 SFW CCMS 1131
	create selectedSealTypes transient;
	self.mulSeals.getSelected(selectedSealTypes);
	self.setProxyCargoTypeTEU(pxyCargoType);	// PAR 33532
	
	//if id &lt; TI_CargoType_Max then																// PAR #33606
	if id &lt; TI_CargoType_Max and id &lt;&gt; TI_CargoType_Car and id &lt;&gt; TI_CargoType_Chassis then		// PAR #33606
		return self.doSaveSystemCargoType(pxyCargoType); //this will only update the drawing attribute
	endif;
	
	create pxyDraw transient;
	

	create selectedCommodities transient;
	self.mulSelectCommod.getSelected(selectedCommodities);	//PAR 19704. CCMS 1080 May 2009 cnwvu1
	
	if not self.doSaveDrawingAttributePxy(pxyDraw) then
		delete pxyDraw;//draw attribute value are invalid
	endif;
	
	if pxyDraw &lt;&gt; null then
		colour := pxyDraw.colour;
	endif;
	
	isSubCargoTypeRequired := self.tblEntDetail.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean;
	
	// PAR #22938 moved - ussed to be after setProxyCargoTyep call, but we need product type here to set 
	// system product attributes for vehicles
	if self.cmbProductType.listIndex &lt;&gt; -1 then
		productType :=self.cmbProductType.listData();
	else
		if self.myCurrentObject = null then	// when creating a new cargo type
			self.cmbProductType.listIndex := 1;	// go to the first item in the combobox
			productType := self.cmbProductType.listData();
		else
			productType := self.myCurrentObject.CM_CargoType.productType;
		endif;
	endif;
	// PAR #22938 set reefer properties if we're adding/updating a vehicle type
	// need to do this before setting proxy cargo type below, as this uses the product attributes
	// PAR #22995 also need to do for Break-Bulk with no Cargo Subtypes
	if productType = ProductType_Vehicle or ((productType = ProductType_BreakBulk or productType = ProductType_PieceBreakBulk)  
	and not isSubCargoTypeRequired) then
		self.setReeferPropsOnSystemProduct();
	endif;
	
	if productType = ProductType_CargoGroup and isSubCargoTypeRequired then					//29.Aug.2023 navsp1 TFS 58664
		isSubCargoTypeRequired := false;
	endif;
	
	pxyCargoType.allAttributesOnProduct.purge();
	self.setProxyCargoType(pxyCargoType, isSubCargoTypeRequired);	// defaults			
	
	defalutCommodity  := app.myRoot.allCommodities[self.tblEntDetail.getValueByName(ETRow_DefaultCommodityCode).String];				//+TFS37634
	if defalutCommodity &lt;&gt; null then
		defaultCommodityCode := defalutCommodity.code;
	endif;
	
	if pxyCargoType.myTIBehaviourType &lt;&gt; null then
		behaviourType := pxyCargoType.myTIBehaviourType;
	endif;
		
	if productType = ProductType_Vehicle then
		behaviourType := self.cmbBehaviourType.listObject.CM_TIBehaviourType;  //cnwjo3 ccms 1018
	endif;
	
	if pxyCargoType.productType = ProductType_Trailer and pxyCargoType.myTIBehaviourType = null then
		behaviourType := app.myRoot.allTIBehaviourTypes[TIBehaviourType_TermTrailer];
	endif;	
	
	trackBy := app.cargoTypeTrackByStringToEnum(self.tblEntDetail.getValueByName(ETRow_TrackBy).String);							// PAR #33606
	weightType := app.myRoot.allMeasurementTypesByShortName[self.tblEntDetail.getValueByName(ETRow_DefaultWeightType).String];		// PAR #33606
	volumeType := app.myRoot.allMeasurementTypesByShortName[self.tblEntDetail.getValueByName(ETRow_DefaultVolumeType).String];		// PAR #33606
	
	//Start navnk20 20/05/2022 TFS 53508
	if not self.tblEntDetail.getValueByName((ETRow_AllowDuplicates)).Boolean then
		cargoGroupUniqueness	:= false;
		subtypeUniqueness		:= false;
	else
		cargoGroupUniqueness := self.tblEntDetail.getValueByName((ETRow_UseCGForUniqueness)).Boolean;
		subtypeUniqueness := self.tblEntDetail.getValueByName((ETRow_UseSubTypeForUniqueness)).Boolean;
	endif;
	//End navnk20 20/05/2022 TFS 53508
	
	isCargoGroupRequired := self.tblEntDetail.getValueByName((ETRow_IsCargoGroupRequired)).Boolean; //09/08/2022 navds20 TFS 54219
	//11/07/2023 navmv20 CR 58244 Task 58245 - start
	if not isCargoGroupRequired then
		allowMultiOperators := false;
	else
		allowMultiOperators := self.tblEntDetail.getValueByName((ETRow_AllowMultiOperators)).Boolean;
	endif;
	//11/07/2023 navmv20 CR 58244 Task 58245 - end
	
	pxyCargoType.setProxy(id,
						self.tblEntDetail.getValueByName(ETRow_Abbreviation).String,
						self.tblEntDetail.getValueByName(ETRow_Description).String,
						productType,
						self.tblEntDetail.getValueByName(ETRow_IsWeighable).Integer = 1,
						self.tblEntDetail.getValueByName(ETRow_IsCheckMaxLift).Integer = 1,
						self.tblEntDetail.getValueByName(ETRow_IncludeInStorage).Integer = 1,
						self.tblEntDetail.getValueByName(ETRow_ShowDamageCodes).Integer = 1,
						self.tblEntDetail.getValueByName(ETRow_IsDynamicallyCreated).Integer = 1,// AER Nelson 12/05/2008
						false,
						self.tblEntDetail.getValueByName((ETRow_AllowDuplicates)).Integer = 1,
						colour, // PAR 34947
						self.cmbHandling.listObject.CM_HandlingType,
						self.cmbSubHandl.listObject.CM_HandlingSubType,	//31 Mar 2017
						self.tblEntDetail.getValueByName(ETRow_CreateBOL).Boolean,
						isSubCargoTypeRequired,
						self.tblEntDetail.getValueByName(ETRow_IsCommodityRequired).Boolean,
						self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntry).Boolean,
						defaultCommodityCode,
						selectedCommodities,
						selectedDamageCodes,
						selectedDamagePos,
						selectedSealTypes,				//+cnwml2 PAR23715 SFW CCMS 1131
						self.tblEntDetail.getValueByName(ETRow_UseTareCargoWeight).Boolean,
						self.tblEntDetail.getValueByName(ETRow_CanWeightBeCertified).Boolean,behaviourType,
						trackBy,																									// PAR #33606
						weightType,																									// PAR #33606
						volumeType,
						self.tblEntDetail.getValueByName(ETRow_ChgToStorageOnUnpack).Integer = 1,	//24 Apr 2015	NDL	Par 36111
						self.tblEntDetail.getValueByName((ETRow_AllowAutoVolumeCalc)).Integer = 1,	//_allowAutoVolumeCalc : Boolean	//10 Jun 2016	NDL	TFS 2141
						self.tblEntDetail.getValueByName((ETRow_AllowAutoWeightCalc)).Integer = 1,	//_allowAutoWeightCalc : Boolean	//18 Jan 2018	NDL	TFS 36697
						self.tblEntDetail.getValueByName((ETRow_CanGeneratePIN)).Integer = 1,		//_canGeneratePIN : Boolean 		// TFS 41570
						self.tblEntDetail.getValueByName((ETRow_RequiresWeighing)).Integer = 1,	//_requiresWeighing : Boolean	//05 Jul 2019	NDL	TFS 44965
						self.tblEntDetail.getValueByName((ETRow_SaveLocationActivity)).Integer = 1,	//_saveLocationActivity : Boolean // 13 Apr 2021	NDL	TFS 50906
						cargoGroupUniqueness,   //navnk20 18/05/2022 TFS 53508
						subtypeUniqueness,
						isCargoGroupRequired, //10/08/2022   navds20 54219
						allowMultiOperators, //11/07/2023 navmv20 CR 58244 Task 58245
						self.tblEntDetail.getValueByName(ETRow_AutoTareCargoWeightCalc).Boolean,	//navra1 - TFS 63624 - 15th Apr 2024
						self.tblEntDetail.getValueByName(ETRow_ExternalReference).String
						);	

	// for a user-defined cargo type that doesn't require Sub-cargo Type, the system product will be updated here
	if pxyCargoType.requiresSystemProductType() then	//dummy product should be here for this cargo type
		populateDefaults := ( pxyCargoType.mySystemProductType = null );	//14 Apr 2015	NDL	Par 35949
		self.setProxySystemProduct(pxyCargoType);	//PAR 19704, CCMS 1080 May 2009
		pxyCargoType.setSystemProductType(self.pxySystemProductType);	//PAR 21339 Oct 2009
		//already called and resulted in duplicate producat attributes in the string array
		/*if populateDefaults then		//14 Apr 2015	NDL	Par 35949
			self.setProxyCargoType(pxyCargoType, isSubCargoTypeRequired);
		endif;*/
	else
		pxyCargoType.setSystemProductType(null);
		if not pxyCargoType.isSubCargoTypeRequired then	// for system cargo types, trailers and vehicles, there are no prod attributes.
			pxyCargoType.allAttributesOnProduct.clear;
		endif;
	endif;

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateCargoType(pxyCargoType,  self.myCurrentObject, pxyDraw, self.pxySystemProductType, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, self.pxySystemProductType, app.myPassport);
		endif;
	
		if not app.myPassport.trxCompletedOK then
			// 27086 Feb 2011 cnwjre1 clean up the error dialog title
			result := app.showErrorWarningDialog(app.getErrorString(CM_Cargo_Type), app.myPassport, ErrWarnMode_AddUpdate);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
					
			return false;
		else
			return true;
		endif;
	endwhile;
	
epilog
	delete pxyDraw;
	delete selectedTerminals;
	delete selectedCommodities;
	delete selectedDamageCodes;
	delete selectedDamagePos;
	delete selectedSealTypes;
	if app.myPassport.trxCompletedOK() then	//ccms 1080 (Par17904). July 2006
		delete self.pxySystemProductType;
	endif;

	if self.mode = Mode_Add then
		if not app.myPassport.trxCompletedOK() then	//ccms 1080 (Par17904). July 2006
			pxyCargoType.setSystemProductType(null);	// when delete pxyCargoType, it deletes mySystemPRoductType, but here we need to save form.pxySystemProductType for second trial. PAR21339 Oct 2009
		endif;
		delete pxyCargoType;
		self.isCodesEdited := false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDrawingAttributePxy" id="db6caa28-5588-4a08-949d-4a306ab8b326">
        <source>doSaveDrawingAttributePxy(_pxyDraw : CM_DrawingAttribute input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	abbr,
	drawFont			: String;
	character			: Integer;
	drawColour			: Integer;
	table				: CM_EntryTable;
begin
	table := self.tblEntDetail;
	abbr := self.tblEntDetail.getValueByName(ETRow_Abbreviation).String;
	drawFont := table.getValueByName(ETRow_Font).String;
	character := table.getValueByName(ETRow_CharacterNumber).Integer;
	drawColour := table.getValueByName(ETRow_DrawColour).Integer;

	if character = null then // PAR 34947
		if abbr.length &gt; 0 then
			character := abbr[1:1].getWeightedAsciiValue();
		endif;
	endif;
	if drawFont = null then // PAR 34947
		drawFont := "Ariel";
	endif;
	
	_pxyDraw.setProxy('CargoType_' &amp; abbr,//abbreviation cannot be duplicate, so OK to use for code attr (key)
						drawFont,
						character,
						drawColour,
						app.myRoot);//no root required, hangs off cargo type			
	
	return true;
end;</source>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSystemCargoType" id="241a732d-3781-4737-93bd-d5f144bd9a93">
        <updating/>
        <source>doSaveSystemCargoType(_pxyCargoType : CM_CargoType input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     This will only update the drawing attribute of the system cargo type
//27/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 19/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk			 
// ----------   ----------  --------------------------------------------------
vars
	realDraw,
	pxyDraw				: CM_DrawingAttribute;
	errObj				: CM_Error;
	navObject			: CMUI_NavigatorObject;
	realCargoType		: CM_CargoType;
	ls,
	showDamageCodes,
	isCheckMaxLift,
	isWeighable,
	isDynamicallyCreated,
	isNotAvailableForEntry : Boolean;
	createBOL 			: Boolean;
	selectedDamageCodes,
	selectedDamagePos	: CM_ObjectSet;
	selectedCommodities	: CM_CommodityByCodeDict;
	useTareCargoWeight : Boolean;
	canWeightBeCertified : Boolean;
	includeInStorageCalc	: Boolean;
	behaviourType : CM_TIBehaviourType;
	selectedSealTypes	: CM_SealTypeSet;
	colour : Integer;
	requiresWeighing : Boolean;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	autoTareCargoWeightCalc : Boolean;			//navra1 - TFS 63624 - 15th Apr 2024
begin
	//if _pxyCargoType.id &gt; TI_CargoBOLType_Max then			// PAR #33606
	if not _pxyCargoType.isSystemCargoBOLType then				// PAR #33606
		app.raiseUnexpectedProgramError(class.name, method.name, 'User cargo type passed in');
		return false;
	endif;		
	
	realCargoType := _pxyCargoType.pxyGetRealObject.CM_CargoType;
	
	create selectedCommodities transient;		//PAR 21659. 17/02/2010 cnwvu1
	self.mulSelectCommod.getSelected(selectedCommodities);	
	
	//27/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	create selectedDamageCodes transient;
	self.mulDmgeDefCode.getSelected(selectedDamageCodes);
	
	create selectedDamagePos transient;
	self.mulDmgePosition.getSelected(selectedDamagePos);
	
	//29 Sep 2010	NDL	Par 25608
	create selectedSealTypes transient;
	self.mulSeals.getSelected(selectedSealTypes);
	
	if realCargoType = null then //this would basically mean the SYSTEM cargo type does not exist! 
		return false;
	endif;

	//cnwjo3 ccms 1018
	if _pxyCargoType.myTIBehaviourType &lt;&gt; null then
		behaviourType := _pxyCargoType.myTIBehaviourType;
	endif;
	
	//cnwjo3 ccms 1018
	if _pxyCargoType.productType = ProductType_Vehicle then
		behaviourType := self.cmbBehaviourType.listObject.CM_TIBehaviourType;
	endif;
	
	isWeighable 		:= self.tblEntDetail.getValueByName(ETRow_IsWeighable).Integer = 1;
	isCheckMaxLift		:= self.tblEntDetail.getValueByName(ETRow_IsCheckMaxLift).Integer = 1;
	showDamageCodes	 	:= self.tblEntDetail.getValueByName(ETRow_ShowDamageCodes).Integer = 1;
	isDynamicallyCreated := self.tblEntDetail.getValueByName(ETRow_IsDynamicallyCreated).Integer = 1;
	isNotAvailableForEntry	:= self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;	//Par 19704, CCMS 1080 May 2009
	useTareCargoWeight := self.tblEntDetail.getValueByName(ETRow_UseTareCargoWeight).Boolean;
	canWeightBeCertified :=	self.tblEntDetail.getValueByName(ETRow_CanWeightBeCertified).Boolean;
	includeInStorageCalc := self.tblEntDetail.getValueByName(ETRow_IncludeInStorage).Boolean;	//PAR 22253 17/02/2010
	createBOL := self.tblEntDetail.getValueByName(ETRow_CreateBOL).Integer = 1;
	requiresWeighing:= self.tblEntDetail.getValueByName((ETRow_RequiresWeighing)).Boolean; //epr TFS  44965 2/8/19
	autoTareCargoWeightCalc := self.tblEntDetail.getValueByName(ETRow_AutoTareCargoWeightCalc).Boolean;			//navra1 - TFS 63624 - 15th Apr 2024
	
	if _pxyCargoType.myDrawingAttribute = null then
		create pxyDraw transient;
	else
		pxyDraw := _pxyCargoType.myDrawingAttribute;
	endif;
	if not self.doSaveDrawingAttributePxy(pxyDraw) then
		delete pxyDraw;
	endif;
	if pxyDraw &lt;&gt; null then // PAR 34947
		 
		colour := pxyDraw.colour; // PAR 34947
	endif;
		
	
	
	_pxyCargoType.setExtraAttributesSystem(isWeighable, isCheckMaxLift, showDamageCodes, createBOL,isDynamicallyCreated, isNotAvailableForEntry,
											selectedCommodities, selectedDamagePos, selectedDamageCodes, useTareCargoWeight, canWeightBeCertified,
											includeInStorageCalc, behaviourType, selectedSealTypes, colour,requiresWeighing, autoTareCargoWeightCalc); // PAR 34947		//navra1 - TFS 63624 - 15th Apr 2024

											
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateCargoType(_pxyCargoType, pxyDraw, null, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('System Cargo Type - Update', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		errObj := app.myPassport.getFirstErrorWarning();
		if errObj &lt;&gt; null then
			navObject := errObj.myUserObject.CMUI_NavigatorObject;
			if navObject &lt;&gt; null then
				navObject.goToObject(errObj.myUserObject.Control, errObj.fieldName, true);
			endif;
		endif;
				
		return false;
		
	endwhile;										
		
	return true;
	
epilog
	if app.myPassport.trxCompletedOK() then	// PAR 22394 18/02/2010. If there is a validation message, we should keep pxyDraw for the second attempt to save, otherwise, pxyDraw is invalid
		delete pxyDraw;
	endif;
	delete selectedCommodities;
	delete selectedDamageCodes;
	delete selectedDamagePos;
	delete selectedSealTypes;
end;</source>
        <Parameter name="_pxyCargoType" type="CM_CargoType" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowContextMenuTblAttributes" id="b65e2f33-3c24-467a-969a-223fc3e18beb">
        <updating/>
        <source>doShowContextMenuTblAttributes( _menu : MenuItem; _tbl: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) : Boolean updating;
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	x1 : Real;
	y1 : Real;

begin

	if not (self.mode = self.Mode_Add or self.mode = self.Mode_Update) then
		return false;
	endif;
	
	//self.mnuEditAttrtHdr.userObject := _tbl;
	x1 := _x;
	y1 := _y;
	if (not _mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if _tbl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := _tbl.positionTop();
	    endif;
	endif;

	_conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	self.popupMenu(_menu, x1.Integer, y1.Integer);

	return false;
	
end;</source>
        <Parameter name="_menu" type="MenuItem"/>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblEntDetailRowColChange" id="a5afdc56-3d03-49cf-bd40-83f60b8920ab">
        <source>doTblEntDetailRowColChange();
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	col			: Integer;
	jCell		: JadeTableCell;
	theColour	: Integer;
begin
	col := CM_EntryTable.ColumnValue;
	tbl := self.tblEntDetail;
	theColour := tbl.getValueByName(ETRow_DrawColour).Integer;
	self.cmbChar.foreColor := theColour;
	tbl.accessCell(tbl.getRowByName(ETRow_Character), col).foreColor := theColour;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawCargoGraphic" id="28c8fdf6-3fe4-42b7-a74e-1c95d7a76f38">
        <source>drawCargoGraphic(_theGraphic : CM_TIBehaviourGraphic; _backColour : Integer) : Binary;
// --------------------------------------------------------------------------------
// Created:		8 February 2010 by cnwjo3
//
// Purpose:		Draw little thumbnail of graphic if necessary.  ccms 1018
//
vars
	theGraphic : CM_TIBehaviourGraphic;
	picture : Binary;
begin
	//cnwjo3 ccms 1018
	self.frmPolygon.caption := "";
	self.frmPolygon.borderStyle := 0;
	self.frmPolygon.width := 125;
	self.frmPolygon.height := 80;	
	self.frmPolygon.left := 0;
	self.frmPolygon.top := 0;
	self.frmPolygon.transparent := false;
	self.frmPolygon.backColor := _backColour;
	self.frmPolygon.autoRedraw := true;
	self.frmPolygon.clearGraphics;
	
	theGraphic := _theGraphic;
	
	if theGraphic &lt;&gt; null then
		theGraphic.drawGraphic(self.frmPolygon,1,0,0, false, 125,true,null,null, NullColour);
		picture := self.frmPolygon.createPicture(false,false,24);
	endif;
	
	return picture;
end;</source>
        <Parameter name="_theGraphic" type="CM_TIBehaviourGraphic"/>
        <Parameter name="_backColour" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
