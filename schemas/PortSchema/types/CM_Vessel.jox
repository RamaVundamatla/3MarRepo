    <JadeMethod name="setProxyForInaPortnetPKK" id="044a9339-df27-4dc1-86fe-db0c2ad7fef4">
        <updating/>
        <source>setProxyForInaPortnetPKK(	_cmifPKK : CMIF_IPNPKKItem;
							_terminal : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation 40523

*/

vars
	hmsVesselType : HMS_VesselType;
	i : Integer;
	pxyVDH : HMS_VesselDataHarbour;
	harbour : HMS_Harbour;
	tidalClassDefault : HMS_TidalClass;
	draftAft,
	draftFwd : Decimal[8,2];
begin
	self.name:=_cmifPKK.kapalNama[1:25];
	self.code:=self.name.removeInvalidChars.removeString(" ");
	self.code:=self.code.toUpper;
	i:=4;
	while i &lt; self.code.length do
		if app.myRoot.allVessels[self.code[1:i]] = null then
			self.code:=self.code[1:i];
			break;
		endif;
		i:=i+1;
	endwhile;
	//epr TFS 42606 17/12/18 don't set this to 0
	if _cmifPKK.imoNumber &lt;&gt; null and _cmifPKK.imoNumber.trimBlanks.Integer &lt;&gt; 0 then
		self.lloydsNumber:=_cmifPKK.imoNumber.Integer.String;
	endif;
	self.callSign :=_cmifPKK.callSign;
	self.myOperator:=_cmifPKK.getOperator;
	
	self.canCreateVoyages:=true;
	self.yearOfBuild:=_cmifPKK.tahunPembuatan.Integer;
	create self.myHMSVesselData transient;
	
	draftAft:=_cmifPKK.drBelakang.Decimal;
	draftFwd:=_cmifPKK.drDepan.Decimal;
	if draftAft &gt; DRAFT_UpperLimit then
			if draftFwd &lt; DRAFT_UpperLimit then 
				 draftAft:=draftFwd;
			else
					draftAft:=0.0;
			endif;
	endif;
	if draftFwd &gt; DRAFT_UpperLimit then
			if draftAft &lt; DRAFT_UpperLimit then 
				 draftFwd:=draftAft;
			else
					draftFwd:=0.0;
			endif;
	endif;
	
	self.myHMSVesselData.setProxy(app.myRoot,false,
									_cmifPKK.jenisTrayek = "TRAMPER",	//_isTramper : Boolean;		//11 Sep 2018	NDL	TFS 40778
									false,false,false,false,false,false,null,null,
									_cmifPKK.bendera,
									_cmifPKK.lebarKapal.Decimal,
									draftAft,
									draftFwd,
									_cmifPKK.loa.Decimal,
									_cmifPKK.drt.Integer,
									_cmifPKK.grt.Integer,
									null, //net reg tonnes
									0, //bow to fwd container,
									0, //bridge to bow,
									0, //bridge to stern
									0, //stern to aft container
									0, //stern to bunker,
									_cmifPKK.getShippingLine, //shipping line,
									_cmifPKK.getVesselType);
							
	harbour:=_terminal.myHarbour;
	foreach tidalClassDefault in app.myRoot.allTidalClasses do
		if tidalClassDefault.isNotAvailableForEntry then
			continue;
		endif;
		break;
	endforeach;
	
	if harbour &lt;&gt; null then
		create pxyVDH transient;								
		pxyVDH.setProxy(null,
						false,
						false,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						harbour,
						null,
						null,
						null,
						null,
						tidalClassDefault,
						tidalClassDefault);
		
		self.myHMSVesselData.allVesselDataForHarbour.add(pxyVDH);
	endif;
	create self.myGeneralCargoVesselStructure transient;
epilog

end;</source>
        <Parameter name="_cmifPKK" type="CMIF_IPNPKKItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyForVessel" id="a2b21c3a-19b7-47e7-94de-a8397f09a175">
        <updating/>
        <source>setProxyForVessel(	_bitmap 			: Binary;
					_code				: String;
					_name				: String;
					_callSign			: String;
					_classLabel			: String;
					_remarks			: String;
					_clonedFromVessel	: String;
					_lloydsNumber		: String;
					_dailyCost			: Integer;
					_despatchRate		: Integer;
					_craneClearance		: Integer;
					_vesselType			: Integer;
					_yearOfBuild		: Integer;
					_loaWithRampsDown	: Decimal; //ccms 1031
					_airDraft			: Decimal;
					_maxVesselBeam		: Decimal;
					_draftBow			: Decimal;
					_draftStern			: Decimal;
					_draftMid			: Decimal;
					_buildingLine		: Decimal;					
					_createVoyages		: Boolean;
					_isDedicatedOrMulti : Boolean;
					_operator			: CM_Operator;
					_trade 				: CM_Trade;
					_isBarge			: Boolean) updating;
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
27/04/09	cnwer1	CCMS 1058 	added default trade
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars

begin
	self.bitmap				:=	_bitmap;
	self.callSign			:=	_callSign;
	self.canCreateVoyages	:=	_createVoyages;
	self.classLabel			:=	_classLabel;
	self.clonedFromVessel	:=	_clonedFromVessel; //epr TFS 3614 12/4/17 changed length 
//	self.code				:=	_code;		// cnwrl1 14/05/2010 PAR 24216 - what it was
	self.code				:=	_code.toUpper;
	self.craneClearance		:=	_craneClearance;
	self.lloydsNumber		:=	_lloydsNumber;
	self.dailyCost			:=	_dailyCost;
	self.despatchRate		:=	_despatchRate;
	self.isDedicatedOrMulti	:=	_isDedicatedOrMulti;
	self.myOperator			:=	_operator;
	self.name				:=	_name;
	self.remarks			:=	_remarks.trimBlanks();
	self.vesselType			:=	_vesselType;
	self.myDefaultTrade		:=	_trade;
	self.yearOfBuild		:=  _yearOfBuild; //cnwas3 ccms 1031
	self.airDraft			:=  _airDraft;
	self.loaWithRampsDown	:=  _loaWithRampsDown;
	self.maxVesselBeam		:=	_maxVesselBeam;
	self.draftBow			:=	_draftBow;
	self.draftStern         :=	_draftStern;
    self.draftMid			:=	_draftMid;
    self.buildingLine		:=	_buildingLine;
	self.isBarge			:=  _isBarge;
	
	self.setMyRoot();
end;</source>
        <Parameter name="_bitmap" type="Binary"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_classLabel" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_clonedFromVessel" type="String"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_dailyCost" type="Integer"/>
        <Parameter name="_despatchRate" type="Integer"/>
        <Parameter name="_craneClearance" type="Integer"/>
        <Parameter name="_vesselType" type="Integer"/>
        <Parameter name="_yearOfBuild" type="Integer"/>
        <Parameter name="_loaWithRampsDown" type="Decimal"/>
        <Parameter name="_airDraft" type="Decimal"/>
        <Parameter name="_maxVesselBeam" type="Decimal"/>
        <Parameter name="_draftBow" type="Decimal"/>
        <Parameter name="_draftStern" type="Decimal"/>
        <Parameter name="_draftMid" type="Decimal"/>
        <Parameter name="_buildingLine" type="Decimal"/>
        <Parameter name="_createVoyages" type="Boolean"/>
        <Parameter name="_isDedicatedOrMulti" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_trade" type="CM_Trade"/>
        <Parameter name="_isBarge" type="Boolean"/>
    </JadeMethod>
