    <JadeMethod name="getCoparnRules" id="bb43c638-6a46-4f55-bf05-41c78c2c9fcf">
        <source>getCoparnRules() : CM_EDIPartyCoparnRules;
/*

Date		Who		Reason
12 September 2016	cnwer1	Initial creation TFS 2606
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars

begin
	if  self.myEDIData.CM_EDIDataReleaseRequest.isCoparnFile()  then							// par 29402
		return self.myEDIData.CM_EDIDataReleaseRequest.getEDIPartyCoparnRules (self.senderCode);
