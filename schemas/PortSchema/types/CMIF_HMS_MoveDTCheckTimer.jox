<Class name="CMIF_HMS_MoveDTCheckTimer" id="2550cf77-6990-46f4-b0d6-2ac9353d6387">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This timer checks for any movements that need confirmation
and raises the appropriate notifications</text>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="ofViewController" id="3c22fe5e-6a85-4cc6-8741-511df059a9bf">
        <embedded/>
        <type name="CMIF_HMS_ViewController"/>
        <Inverse name="CMIF_HMS_ViewController::myMoveCheckTimer"/>
    </ExplicitInverseRef>
    <JadeMethod name="checkMovementTimes" id="d048e961-bf43-4675-a9fe-1b6884d0ece4">
        <updating/>
        <source>checkMovementTimes() updating;

vars
    lockObject:				HMS_MovementTimeCheckLock;
    permMovement:			HMS_VoyageMovement;
    searchStartDT:			TimeStamp;
    searchEndDT:			TimeStamp;
    endOfSearchReached:		Boolean;
    now:					TimeStamp;
    xxHrsFromNow:			TimeStamp;
    offsetTime:				Time;
    iter:					Iterator;
    confirmationOffsetHrs:	Integer;
    searchDaysBack:			Integer;
    harbour : HMS_Harbour;
begin

	// This method checks all movement to see if there are any that require
	// 'actual time entry' or 'go ahead confirmation'. To do this, the client
	// must first get an exclusive lock a common system object (harbour.ofMoveTimeCheckLock)
	// This ensures that only one user can check the movements for update at 
	// any one point in time.


	//now:="22 February 2000, 00:00:00".TimeStamp; // Temp code for testing
	harbour := self.ofViewController.myHarbour;
	if harbour = null then
		return;
	endif;
		
	lockObject:= harbour.ofMoveTimeCheckLock;
	if lockObject = null then
	  	beginTransaction;
  		create lockObject;
  		lockObject.setMyHarbour(harbour);
  		commitTransaction;
  	endif;

	confirmationOffsetHrs:=harbour.movConfirmFromPlanInHrs;	
	searchDaysBack:=harbour.movConfirmSearchBackDays; 

	// Only check movements in the period 2 days prior to current time through to the current time + 1 hr
//	searchStartDT:=((now.date - searchDaysBack).Date.String &amp; "," &amp; now.Time.String).TimeStamp;
	searchStartDT.setDate(now.date - searchDaysBack);
//	offsetTime.setTime(1,0,0,0); 	
//	searchEndDT:=now + offsetTime; // Look forward to 1hr from now
	searchEndDT.cnEcAddHours(1);

	offsetTime.setTime(confirmationOffsetHrs,0,0,0); 
	xxHrsFromNow:=now + offsetTime; // Set time for confirmation to X hours prior to planned time

	iter:=harbour.allVoyageMovementsByStatusDate.createIterator;
	harbour.allVoyageMovementsByStatusDate.startKeyGeq(MovementStatus_Planned,searchStartDT, iter);
	unlock(harbour.allVoyageMovementsByStatusDate);
	endOfSearchReached:=false;
	while (iter.next(permMovement)) and endOfSearchReached=false do
		if permMovement.occursOnDTNEW&gt;xxHrsFromNow or permMovement.moveStatusNEW=MovementStatus_Actual then
			// End of search range has been reached
			endOfSearchReached:=true;
		else
			// Check movement 

			// Check if movement needs an actual time entering - ie planned time is after the current time
			// and no actual time has been entered. NOTE: If the movement need a planned time entering and 
			// it is also not yet confirmed, then these two activities will be handled by the same 
			// user confirmation process.
			if permMovement.occursOnDTNEW&lt;=now then
				// Movement should have taken place - ie. moveStatus = confirmed and moveDTActual&lt;&gt;null
				if permMovement.moveStatusNEW = MovementStatus_Actual then
                 	// Flag move for actual DT entry only if it is not already flagged with a current user
                    //if permMovement.allUsersForConfirmation.size=0 then
                    if permMovement.allUserCodesForConfirmation.size=0 then
                 		harbour.causeEvent(OpenActualConfirmWindow,true,permMovement); // need to pass ref to movement
					endif;
				endif;
			elseif permMovement.occursOnDTNEW&lt;xxHrsFromNow then
				// Check if movement needs confirmation - eg. planned time is less than XX hrs away
				// Movement should be confirmed
				if permMovement.moveStatusNEW&lt;&gt;MovementStatus_ConfirmedPlan then
					// Flag move for confirmation
					//if permMovement.allUsersForConfirmation.size=0 then
					if permMovement.allUserCodesForConfirmation.size=0 then
						harbour.causeEvent(OpenPlannedConfirmWindow,true,permMovement);
					endif;
				endif;				 
			endif;			
		endif;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="startTimer" id="0b03e3be-6344-48d4-b1eb-0f51b4279484">
        <updating/>
        <source>startTimer(_viewController : CMIF_HMS_ViewController) updating;

constants
	MINUTES = 30;
	MILLISECS_PER_MINUTE = 60000;
vars
	role	: CM_SecurityRole;
	array	: StringArray;
	theUser : CM_User;
    harbour : HMS_Harbour;	
begin
	harbour := _viewController.myHarbour;
	if harbour = null then
		return;
	endif;	
 	// This method starts a continuous timer that runs on each client that 
 	// checks all movements at a specific periodic 

 	// NB: Only start timer if current user belongs to a group that is registered to receive 
 	// confirmation notices
 	
/* 	array := harbour.ofSysDefaultPreference.HMS_SystemDefaultPreference.allSecurityRoleCodes;
 	theUser := app.getMyUser();
 	
 	foreach role in theUser.allSecurityRoles do
	 	if array.includes(role.name) then
 			//self.beginTimer(30000,Timer_Continuous,0); 
 			self.beginTimer(MINUTES * MILLISECS_PER_MINUTE,Timer_Continuous,0);
 			break; 
	 	endif;
	endforeach;*/
	 
end;</source>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="e9a28a2b-23a7-4286-bf8a-4239df61740e">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;

vars
 	lockObject:	HMS_MovementTimeCheckLock;
    harbour : HMS_Harbour;	
begin
	harbour := self.ofViewController.myHarbour;
	if harbour = null then
		return;
	endif;	

	// This directs a timer check to the 'checkMovmentTimes method if an exclusive 
	// lock can be obtained on the CM_HMS_MovementTimeCheckLock object - this ensures that 
	// only one client at a time is checking movement times
	lockObject:=harbour.ofMoveTimeCheckLock;
	if lockObject = null then
	  	beginTransaction;
  		create lockObject;
  		lockObject.setMyHarbour(harbour);
  		commitTransaction;
  	endif;
    if tryLock(lockObject,Exclusive_Lock,Transaction_Duration,LockTimeout_Immediate)=false then
    	// Another client has this object locked
 	else
    	// Exclusive lock has been obtained - check all movement times
 		checkMovementTimes;
    	// Release lock
    	unlock(lockObject);

    endif;



end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
