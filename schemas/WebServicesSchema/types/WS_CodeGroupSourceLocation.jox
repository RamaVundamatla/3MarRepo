<Class name="WS_CodeGroupSourceLocation" id="e231ac32-e218-4cea-96a7-700098d7880b">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Log group source location codes, system definable values</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allSourceLocations" id="168dda34-93f1-4de5-b601-482d36041963">
        <memberTypeInverse/>
        <type name="WS_SourceLocationArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="groupType" id="13dba332-e5c4-46e7-b644-dcff8b9cc6ca">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="name" id="fd34fe38-7822-4328-a752-c21726ee2081">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="cf00acd5-364b-4c12-a28d-80206ba1ab06">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allSourceLocations &lt;&gt; null and not self.allSourceLocations.isEmpty() then		//cnwmc5 - 19 Dec 2014 - PAR 35446
		self.allSourceLocations.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyCodeGroup" id="ae4e41ef-3ee0-4b51-b5cd-4fd5f1d315b3">
        <source>setProxyCodeGroup(_codeGroup : CM_CodeGroup input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwmc5	Initial creation

*/

vars
	wsSrcLoc		: WS_SourceLocation;
	wsSrcSubLoc		: WS_SourceSubLocation;
	wsSrcSubSubLoc	: WS_SourceSubSubLocation;
	
	srcLoc			: CM_SourceLocation;
	srcSubLoc		: CM_SourceSubLocation;
	srcSubSubLoc	: CM_SourceSubSubLocation;
	
begin
	_codeGroup.setProxy(CodeGroup_SourceLocation,
						self.name,
						app.myRoot);
	
	foreach wsSrcLoc in self.allSourceLocations do
		create srcLoc transient;
		srcLoc.setForProxy(	wsSrcLoc.code,
							wsSrcLoc.description,
							wsSrcLoc.isFSC,
							wsSrcLoc.notAvailableForEntry,
							_codeGroup);
		
		foreach wsSrcSubLoc in wsSrcLoc.allSourceSubLocations do
			create srcSubLoc transient;
			srcSubLoc.setForProxy(	wsSrcSubLoc.code,
									wsSrcSubLoc.description,
									wsSrcSubLoc.isFSC,
									wsSrcSubLoc.notAvailableForEntry,
									srcLoc);
									
			foreach wsSrcSubSubLoc in wsSrcSubLoc.allSourceSubSubLocations do
				create srcSubSubLoc transient;
				srcSubSubLoc.setForProxy(	wsSrcSubSubLoc.code,
											wsSrcSubSubLoc.description,
											wsSrcSubSubLoc.isFSC,
											wsSrcSubSubLoc.notAvailableForEntry,
											srcSubLoc);
			endforeach;
		endforeach;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="d5749f24-dee5-4269-8f9b-b9e13f8d0235">
        <updating/>
        <source>setProxyFromObject(_codeGroup: CM_CodeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwmc5	Initial creation

*/

vars
	wsSourceLocation	: WS_SourceLocation;
	
	sourceLocation		: CM_SourceLocation;
	code				: CM_Code;
	
begin
	inheritMethod(_codeGroup);
	
	foreach code in _codeGroup.allCodes do
		if not code.isKindOf(CM_SourceLocation) then
			continue;
		endif;
		
		sourceLocation := code.CM_SourceLocation;
		
		create wsSourceLocation transient;
		wsSourceLocation.setProxyFromObject(sourceLocation);
		self.allSourceLocations.add(wsSourceLocation);
	endforeach;
	
	self.groupType 	:= _codeGroup.groupType;
	self.name		:= _codeGroup.name;

epilog

end;</source>
        <Parameter name="_codeGroup" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="setUpdateProxyCodeGroup" id="84877511-b523-437c-a13a-e3e3e1763038">
        <source>setUpdateProxyCodeGroup(_pxyCodeGroup, _realCodeGroup : CM_CodeGroup input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwmc5	Initial creation

*/

vars
	wsSrcLoc		: WS_SourceLocation;
	wsSrcSubLoc		: WS_SourceSubLocation;
	wsSrcSubSubLoc	: WS_SourceSubSubLocation;
	
	srcLoc,
	pxySrcLoc		: CM_SourceLocation;
	srcSubLoc,
	pxySrcSubLoc	: CM_SourceSubLocation;
	srcSubSubLoc,
	pxySrcSubSubLoc	: CM_SourceSubSubLocation;
	
	load			: Boolean;
	
begin
	_pxyCodeGroup.setProxy(CodeGroup_SourceLocation,
						self.name,
						app.myRoot);
	
	app.cmsBeginLoad(load);
	
	foreach wsSrcLoc in self.allSourceLocations do
		if _realCodeGroup &lt;&gt; null then	//cnwmc5 - 19 Dec 2014 - PAR 35446
			srcLoc := _realCodeGroup.allCodes[wsSrcLoc.code].CM_SourceLocation;
		endif;							//cnwmc5 - 19 Dec 2014 - PAR 35446
		if srcLoc = null then
			create pxySrcLoc transient;
		else
			pxySrcLoc := srcLoc.pxyCreateUpdateProxy();
		endif;
		pxySrcLoc.setForProxy(	wsSrcLoc.code,
								wsSrcLoc.description,
								wsSrcLoc.isFSC,
								wsSrcLoc.notAvailableForEntry,
								_pxyCodeGroup);
		
		foreach wsSrcSubLoc in wsSrcLoc.allSourceSubLocations do
			if srcLoc &lt;&gt; null then		//cnwmc5 - 19 Dec 2014 - PAR 35446
				srcSubLoc := srcLoc.allSubLocations[wsSrcSubLoc.code].CM_SourceSubLocation;
			endif;						//cnwmc5 - 19 Dec 2014 - PAR 35446
			if srcSubLoc = null then
				create pxySrcSubLoc transient;
			else
				pxySrcSubLoc := srcSubLoc.pxyCreateUpdateProxy();
			endif;
			pxySrcSubLoc.setForProxy(	wsSrcSubLoc.code,
										wsSrcSubLoc.description,
										wsSrcSubLoc.isFSC,
										wsSrcSubLoc.notAvailableForEntry,
										pxySrcLoc);
			
			foreach wsSrcSubSubLoc in wsSrcSubLoc.allSourceSubSubLocations do
				if srcSubLoc &lt;&gt; null then	//cnwmc5 - 19 Dec 2014 - PAR 35446
					srcSubSubLoc := srcSubLoc.allSubSubLocations[wsSrcSubSubLoc.code].CM_SourceSubSubLocation;
				endif;						//cnwmc5 - 19 Dec 2014 - PAR 35446
				if srcSubSubLoc = null then
					create pxySrcSubSubLoc transient;
				else
					pxySrcSubSubLoc := srcSubSubLoc.pxyCreateUpdateProxy();
				endif;
				pxySrcSubSubLoc.setForProxy(wsSrcSubSubLoc.code,
											wsSrcSubSubLoc.description,
											wsSrcSubSubLoc.isFSC,
											wsSrcSubSubLoc.notAvailableForEntry,
											pxySrcSubLoc);
			endforeach;
		endforeach;
	endforeach;
	
epilog
	app.cmsEndLoad(load);
end;</source>
        <Parameter name="_pxyCodeGroup" type="CM_CodeGroup" usage="input"/>
        <Parameter name="_realCodeGroup" type="CM_CodeGroup" usage="input"/>
    </JadeMethod>
</Class>
