		self.myDrawingController.setLCWidthFt(8); 		// defaulting for portrait view
		self.myDrawingController.setLCXGridOffsetFt(1);
		self.myDrawingController.setLCHeightFt(10);		// defaulting for portrait view		
		self.myDrawingController.setWagonWidthFt(10);	// refers to a wagon piece, not the whole wagon
		self.myDrawingController.setWagonHeightFt(10);
		self.myDrawingController.setTIXGridOffsetFt(1);
		self.myDrawingController.setTrackWidthFt(4);
		self.myDrawingController.setTrackHeightFt(10);
		self.myDrawingController.setTrackXGridOffsetFt(3);
