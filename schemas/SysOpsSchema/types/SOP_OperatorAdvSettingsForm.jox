    <JadeMethod name="doDeleteCarrierCriteria" id="e09797cd-4d2f-450b-ab39-f91266314c57">
        <updating/>
        <source>doDeleteCarrierCriteria(_critToDelete : CM_OperatorCarrierCriteria io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	if _critToDelete = null then
		return;
	endif;
	
	app.myTrxDA.trxDeleteOpCarrierCriteria(_critToDelete, app.myPassport);
	
	self.populateCriteriaTable();
epilog

end;</source>
        <Parameter name="_critToDelete" type="CM_OperatorCarrierCriteria" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="1f0c1ae8-7905-4892-965e-665d822feb97">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2008 by cnwdad1
//
// Purpose:		Standard reimplementation to process modal form's "OK" button.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 23/08/2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//							method no longer called
// --------------------------------------------------------------------------------
vars
	operatorObj			: CM_Operator;
	allForwardersObj	: CM_ConsigneeConsignorSet;
	//25 Aug 2009	NDL CCMS 1609 Par 20521
	allStringObjs : CM_StringDict;
	stringObj : CM_String;
	allBookingRefDiscreps : StringArray;
	carrierCargoType : Integer;
begin
	operatorObj	:= self.aMyOperator;
	if operatorObj = null then
		app.msgBox("No Operator has been selected.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	create allForwardersObj transient;
	mulFF.getSelected(allForwardersObj);
	
	create allStringObjs transient;
	create allBookingRefDiscreps transient;
	mulBooking.getSelected(allStringObjs);
	foreach stringObj in allStringObjs do
		allBookingRefDiscreps.add(stringObj.CM_StringWithString.displayString);
	endforeach;
	
	if app.myPassport.trxCompletedOK() then
		inheritMethod();
	else
		app.showErrorWarningDialog(app.getString(Operator) &amp; " " &amp; app.getString(Advanced_Settings), app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window	
	endif;
epilog
	delete allForwardersObj;
	delete allBookingRefDiscreps;
	delete allStringObjs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="6a29a371-1785-4711-b62d-d6d14e3354ba">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25/08/2009	cnwndl1	Initial creationPar 20521 CCMS 1609
15/08/2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
*/

vars

begin
	inheritMethod();
	
	self.fldMain.top := 1;
	self.fldMain.left := 1;
	self.fldMain.width := self.width - 16;			// TFS 45836
	self.fldMain.height := self.height - 70;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveBookingDiscrep" id="f0193804-18eb-4b4c-a947-f7e48f4d43b1">
        <updating/>
        <source>doSaveBookingDiscrep() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	operator : CM_Operator;
	allStringObjs : CM_StringDict;
	stringObj : CM_String;
	allBookingRefDiscreps : StringArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	operator	:= self.aMyOperator;
	if operator = null then
		app.msgBox("No Operator has been selected.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	create allStringObjs transient;
	create allBookingRefDiscreps transient;
	mulBooking.getSelected(allStringObjs);
	foreach stringObj in allStringObjs do
		allBookingRefDiscreps.add(stringObj.CM_StringWithString.displayString);
	endforeach;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateOpBookingDiscrep(operator, allBookingRefDiscreps, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.modalResult := IDOK;
			self.unloadForm;
			break;
		else
			theResult := app.showErrorWarningDialog(app.getString(Operator) &amp; " " &amp; app.getString(Advanced_Settings), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	

epilog
	delete allBookingRefDiscreps;
	delete allStringObjs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveFreightFwdrs" id="7a6b1612-d0c5-4c88-b983-93eedd4eb701">
        <updating/>
        <source>doSaveFreightFwdrs() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	operator : CM_Operator;
	allForwarders : CM_ConsigneeConsignorSet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	operator := self.aMyOperator;
	if operator = null then
		app.msgBox("No Operator has been selected.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	create allForwarders transient;
	mulFF.getSelected(allForwarders);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateOpFreightFwdrs(operator, allForwarders, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.modalResult := IDOK;
			self.unloadForm;
			break;
		else
			theResult := app.showErrorWarningDialog(app.getString(Operator) &amp; " " &amp; app.getString(Advanced_Settings), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete allForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowCarrierCriteriaForm" id="0c6c6d22-3643-49ae-91c7-494be28d7e5b">
        <updating/>
        <source>doShowCarrierCriteriaForm(_opCarrier : CM_OperatorCarrierCriteria) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	form : SOP_OperatorCarrierCritForm;
	critTypeSelectArray : CM_YACriteriaTypeArray;

begin
	create critTypeSelectArray transient;
	critTypeSelectArray.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	critTypeSelectArray.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Product]);
	critTypeSelectArray.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ISO]);
	critTypeSelectArray.add(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType]);
	
	form := app.loadForm(	SOP_OperatorCarrierCritForm, 
							SOP_Assistant, 
							false, false, true, 
							self.myTerminal, null	).SOP_OperatorCarrierCritForm;
	if form = null then
		return;
	endif;

	form.setReferences( critTypeSelectArray, _opCarrier, self );
	form.showModal();
	
	//self.populateAttributes();
	
epilog
	delete critTypeSelectArray;
end;</source>
        <Parameter name="_opCarrier" type="CM_OperatorCarrierCriteria"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="2c43af8f-53cf-4053-b8e5-51dfd1f3b854">
        <source>getMyOperator() : CM_Operator;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	return self.aMyOperator;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaTable" id="8a817697-23dd-4142-983f-c267b4d5b273">
        <updating/>
        <source>populateCriteriaTable() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	crit : CM_OperatorCarrierCriteria;

begin
	self.setupTblCriteria();
	
	foreach crit in self.aMyOperator.allOperatorCarrierCriteria discreteLock do
		self.tblCriteria.addObject(crit);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setOpertator" id="37814155-924f-42b4-aef3-e650179f71de">
        <updating/>
        <source>setOpertator(_operatorObj:CM_Operator) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2008 by cnwdad1
//
// Purpose:		Sets a reference to the Operator object being maintained.
//
// Parameters:	_operatorObj - A reference to the Operator object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyOperator	:=	_operatorObj;
end;</source>
        <Parameter name="_operatorObj" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1653a6a8-0987-4fc9-8aeb-6c20f6d5bb8c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 21 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 15/08/2019	jlgdap1		TFS 45436 PEN Approved Carrier for ISO Type and Trailer Type
// 03 Oct 2019	jlgdi1	45802	Added btnAdd, btnUpdate and btnDelete in permission checking
vars
	allForwardersObj	: CM_ConsigneeConsignorSet;
	forwarderObj		: CM_ConsigneeConsignor;
	
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	strObjStr		: CM_StringWithString;
	str				: String;
	inclDict		: CM_StringDict;
	strDict			: CM_StringDict;
	
begin
	if self.aMyOperator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Operator has been selected.");
		self.unloadForm();
		return;
	endif;
	
	create allForwardersObj transient;
	self.aMyOperator.allFFsForBookRefUpdate.copy(allForwardersObj);
// The following was only required for the 7.5.3 and 7.6.2 hotfixes.
//	forwarderObj	:=	self.aMyOperator.getConfig(OperatorForwarder).CM_ConsigneeConsignor;
//	if forwarderObj &lt;&gt; null then
//		allForwardersObj.add(forwarderObj);
//	endif;
	
	self.handleMenusForModalDisplay();		// remove when not test form
	//inheritMethod();
	btnCancel.visible		:=	true;
	frmToolbarBtns.visible	:=	false;
	self.caption			:=	app.getString(Operator) &amp; " " &amp; self.aMyOperator.getDisplayDetails(true) &amp; " - " &amp; app.getString(Advanced_Settings);

	self.mulFF.availableHeading			:=	app.getErrorString(Available);
	self.mulFF.selectedHeading			:=	app.getErrorString(Selected);
	self.mulFF.myBaseForm				:=	self;
	self.mulFF.mySelectedListBox.sorted	:=	true;
	self.mulFF.multiSelect				:=	ListBox.MultiSelect_Extended;

	self.mulFF.formDisplayEntryMethodName	:=	SOP_OperatorAdvSettingsForm::displayFF.name; 
	self.mulFF.setAvailable(CM_Root.firstInstance.allConsigneeConsignors, false);
	self.mulFF.setSelected(allForwardersObj);
	self.mulFF.userInputEnabled	:=	true;
	//self.mulFF.setSelected(self.allSelectedItems);
	
	//25 Aug 2009	NDL	Par 20521 CCMS 1609
	self.mulBooking.availableHeading		:=	app.getErrorString(Available);
	self.mulBooking.selectedHeading			:=	app.getErrorString(Selected);
	self.mulBooking.myBaseForm				:=	self;
	self.mulBooking.mySelectedListBox.sorted:=	true;
	self.mulBooking.multiSelect				:=	ListBox.MultiSelect_Extended;

	create inclDict transient;
	create strDict transient;
	entTableDef := app.myController.getEntTableDef(ETDef_BookingRefDiscrep);
	foreach entTableRow in entTableDef.allEntTableRows do
		create strObjStr transient;
		str := entTableRow.getHeading(null,null,app.myCurrentLocale);
		strObjStr.set("~", str);
		if self.aMyOperator.allAttribForBookingRefDiscrep.includes(str) then
			inclDict.add(strObjStr);
		endif;	
		strDict.add(strObjStr);
	endforeach;
	
	self.mulBooking.formDisplayEntryMethodName := SOP_OperatorAdvSettingsForm::displayBooking.name; 
	self.mulBooking.setAvailable(strDict, true);
	self.mulBooking.setSelected(inclDict);	
	self.mulBooking.userInputEnabled :=	true;
	
	// TFS 45836 no more carrier multi-select
	/*self.mulCarrier.availableHeading := app.getErrorString(Available);
	self.mulCarrier.selectedHeading := app.getErrorString(Selected);
	self.mulCarrier.myBaseForm := self;
	self.mulCarrier.mySelectedListBox.sorted := true;
	self.mulCarrier.multiSelect := ListBox.MultiSelect_Extended;
	self.mulCarrier.formDisplayEntryMethodName := SOP_OperatorAdvSettingsForm::displayCarrier.name; 
	self.mulCarrier.setAvailable(CM_Root.firstInstance.allCarriers, false);
	self.mulCarrier.setSelected(null);
	self.mulCarrier.userInputEnabled := true;
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	self.myAssistant.comboBoxCargoBolType(self.cmbCargoType, TI_CargoType_Null, true, true, true, false);	*/
	self.setupTblCriteria();
	if self.aMyOperator &lt;&gt; null then
		self.populateCriteriaTable();
	endif;
	self.minimumHeight := 390;
	self.minimumWidth := 500;
	// TFS 45863 end

	self.centreWindow();
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(null, PmAdmOpereditMaint) then
		self.mulBooking.readOnly := true;
		self.mulFF.readOnly := true;
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
		self.btnDelete.enabled := false;
	endif;

	self.btnOk.visible := false;			// TFS 45836
epilog
	delete allForwardersObj;
	delete inclDict;
	delete strDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTblCriteria" id="0d3f8fa9-a386-404f-8054-c73047935114">
        <updating/>
        <source>setupTblCriteria() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	entTableDef : EntTableDef;

begin
	self.tblCriteria.rows := 0;
	self.tblCriteria.fixedRows := 1;
	self.tblCriteria.fixedColumns := 0;
	self.tblCriteria.selectMode := Table.SelectMode_Row;
	self.tblCriteria.accessMode := Table.AccessMode_Row;
	self.tblCriteria.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblCriteria.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblCriteria.defaultRowHeight := 17;
	self.tblCriteria.allSelectedObjects.clear;
	
	
	entTableDef := app.myController.getEntTableDef(ETDef_OperatorCarriers);
	self.tblCriteria.setMyEntTableDef( entTableDef );
	self.tblCriteria.setTblDataEntRowsFromDef(entTableDef);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCriteria_dblClick" id="74922edf-507d-4121-959e-3211f5a93a65">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCriteria_dblClick(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	if table.row &gt; table.fixedRows then
		self.doShowCarrierCriteriaForm(table.CM_DataTable.allSelectedObjects.first.CM_OperatorCarrierCriteria);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bc427cc5-5a40-43d8-9c08-366a3fb3c70c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 August 2019 14:26:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009688, locale);
	btnAdd.translateCaption(Xlat_0023692, locale);
	btnBookingOk.translateCaption(Xlat_0023693, locale);
	btnDelete.translateCaption(Xlat_0023694, locale);
	btnForwardOk.translateCaption(Xlat_0023695, locale);
	btnUpdate.translateCaption(Xlat_0023696, locale);
	lblBookSelect.translateCaption(Xlat_0014509, locale);
	lblFFSelect.translateCaption(Xlat_0014510, locale);
	shtBooking.translateCaption(Xlat_0014511, locale);
	shtCarrier.translateCaption(Xlat_0022937, locale);
	shtForward.translateCaption(Xlat_0011709, locale);
end;</source>
    </JadeMethod>
</GUIClass>
