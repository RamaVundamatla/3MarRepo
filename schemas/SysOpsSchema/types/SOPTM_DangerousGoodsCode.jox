    <JadeMethod name="setControlsForAddEdit" id="528df35f-05e1-4e4e-8fe3-982b179c3a62">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
vars
	theForm : SOP_TableMaintForm;
	hazClass : CM_HazardClass;
	undg : CM_UNDangerousGoods;							// PAR #36421
	str : String;										// PAR #36421
begin
  
 	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.lstSecClasses.displayCollection(app.myRoot.allHazardClasses, true, 0, null);		// PAR #36421
	theForm.lstSecClasses.clearSelected();														// PAR #36421

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_UNDangerousGoods);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Code);		
		hazClass:= theForm.myCurrentObject.CM_UNDangerousGoods.myHazardClass;
		undg := theForm.myCurrentObject.CM_UNDangerousGoods;									// PAR #36421
		foreach str in undg.allClassCodes do													// PAR #36421
			theForm.lstSecClasses.addSelectedObject(app.myRoot.allHazardClasses[str]);			// PAR #36421
		endforeach;																				// PAR #36421
	endif;

	//epr par 31299 18/3/13
	self.myForm.myAssistant.comboBoxHazardClass(theForm.comboBox1,hazClass);  //(self.myForm.comboBox1, null);

end;</source>
    </JadeMethod>
