    <JadeMethod name="changeScale" id="fda15022-2ef0-4855-9a3e-5239522ac692">
        <updating/>
        <source>changeScale(_increase : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MaxZoom = 1.5;
	MinZoom = .5;
vars
	newScale, pc : Decimal[12,2];
begin

	newScale := self.scaleFactor;
	if _increase then
		newScale := newScale + .1;
		if newScale &gt; MaxZoom then
			newScale := MaxZoom;
		endif;
	else
		newScale := newScale - .1;
		if newScale &lt; MinZoom then
			newScale := MinZoom;
		endif;
	endif;
	
	self.setScale(newScale);
	
epilog

end;</source>
        <Parameter name="_increase" type="Boolean"/>
    </JadeMethod>
