    <ImplicitInverseRef name="myVoyage" id="0472557e-d927-4a8d-9c49-4afc333065ef">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="fetchKPIs" id="3b554bfc-5b7b-4f70-a405-50b0ad195aeb">
        <updating/>
        <source>fetchKPIs(goodResponse: WS_RestKPITruckResponse io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navcs2	Initial creation

*/

vars

begin
	if self.myVoyage &lt;&gt; null then
		self.myVoyage.getKPIByType(1);
	endif;
	
epilog

end;</source>
        <Parameter name="goodResponse" type="WS_RestKPITruckResponse" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVoyageKPIs" id="22b143bb-bc95-46ed-88cc-9a4034d7502d">
        <source>getVoyageKPIs(_includeShifts, _includeDetail: Boolean; _bayCodes, _craneCodes, _deckCodes, _wpCodes : StringArray): WS_KPIVoyageArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	voyage 			: CM_Voyage;
	code			: String;
	kpi				: CM_KPIVoyageEntity;
	array			: WS_KPIVoyageArray;
	wsKpiTotal 		: WS_KPIVoyageTotals;
	wsKpiBay		: WS_KPIVoyageBay;
	wsKpiCrane		: WS_KPIVoyageCraneShift;
	wsKpiWp			: WS_KPIVoyageWorkPointShift;
	wsKpiDeck		: WS_KPIVoyageDeck;
	wsKpi			: WS_KPIVoyage;
begin
	create array transient;
	create wsKpiTotal transient;
	
	if self.myVoyage &lt;&gt; null then
		voyage := self.myVoyage;
		
		// Get Totals first as we always show this
		kpi := voyage.getKPI();
		wsKpiTotal.setProxyFromObject(kpi, _includeDetail);
		array.add(wsKpiTotal);
		
		foreach code in _bayCodes do
			kpi := voyage.getKPIVoyBayCraneByCode(code);
			if kpi = null then 
				break;
			endif;
			create wsKpiBay transient;
			wsKpiBay.setProxyFromObject(kpi, _includeDetail);
			array.add(wsKpiBay); 
		endforeach;
		
		foreach code in _craneCodes do
			kpi := voyage.getKPIVoyBayCraneByCode(code);
			if kpi = null then 
				break;
			endif;
			create wsKpiCrane transient;
			wsKpiCrane.setProxyFromObject(kpi, _includeDetail);
			array.add(wsKpiCrane);
		endforeach; 
		
		foreach code in _deckCodes do
			kpi := voyage.getKPIVoyDeckWPByCode(code);
			if kpi = null then 
				break;
			endif;
			create wsKpiWp transient;
			wsKpiWp.setProxyFromObject(kpi, _includeDetail);
			array.add(wsKpiWp); 
		endforeach;
		
		foreach code in _wpCodes do
			kpi := voyage.getKPIVoyDeckWPByCode(code);
			if kpi = null then 
				break;
			endif;
			create wsKpiWp transient;
			wsKpiWp.setProxyFromObject(kpi, _includeDetail);
			array.add(wsKpiWp); 
		endforeach;
		
		if _includeShifts then
			voyage.getKPIVoyWPShiftByCode(code);
		endif;
	endif;
	
	return array;
epilog
	
end;</source>
        <Parameter name="_includeShifts" type="Boolean"/>
        <Parameter name="_includeDetail" type="Boolean"/>
        <Parameter name="_bayCodes" type="StringArray"/>
        <Parameter name="_craneCodes" type="StringArray"/>
        <Parameter name="_deckCodes" type="StringArray"/>
        <Parameter name="_wpCodes" type="StringArray"/>
        <ReturnType type="WS_KPIVoyageArray"/>
    </JadeMethod>
