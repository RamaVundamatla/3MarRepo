    <JadeMethod name="getErrorsAsString" id="30fb18be-57b9-4dc9-8aae-7235a555015e">
        <source>getErrorsAsString(_numErrors : Integer) : String;
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO -  CR 64617 TASK 64637
*/


vars
	ediError : CM_EDIError;
	idx : Integer;
	str, retStr : String;
begin
	foreach ediError in self.allErrorWarnings do
		str := ediError.text;
		retStr := retStr &amp; str &amp; CrLf;
		
		idx += 1;
		if idx &gt;= _numErrors then
			break;
		endif;
	endforeach;
	
	return retStr;
epilog

end;</source>
        <Parameter name="_numErrors" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstEDIError" id="efecedea-3bb6-4ff3-8551-b0e15b926b61">
        <source>getFirstEDIError() : CM_EDIError;
/*

Date		Who		Reason
16 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	ediError : CM_EDIError;
begin
	foreach ediError in self.allErrorWarnings do
		if not ediError.warningOnly then
			return ediError;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_EDIError"/>
    </JadeMethod>
    <JadeMethod name="getFirstEDITrackedItemOfType" id="cd13ef3e-86e4-4651-886e-1a46e4f68258">
        <source>getFirstEDITrackedItemOfType(_type : Class) : CM_EDITrackedItem;
/*

Date		Who		Reason
26 April 2017	cnwer1	Initial creation TFS 4139

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems discreteLock do
		if ediTI.isKindOf(_type) then
			return ediTI;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Class"/>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstOpCode" id="5c48476f-3568-41cb-acf7-91b093b1783b">
        <source>getFirstOpCode() : String;
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64617 TASK 64637
*/

vars
	ti : CM_EDITrackedItem;
begin
	ti := self.allEDITrackedItems.first;
	
	if ti = null then
		return "";
	endif;
	
	return ti.getOperatorCode();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItemFields" id="02be7357-984a-4bbf-8936-ae2580c7f3a5">
        <source>getItemFields(_fields: CM_FieldByTypeSysNameDict input; _fieldClass: Class);
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars
	props : PropertyColl;
	prop : Property;
	field : CM_EDIItemField;
begin
	_fields.clear;
	
	props := self.class.allPropertiesUpTo(CM_Object);
	foreach prop in props do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;prop.name;
		if self.canUserSet(prop.name) then
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;prop.name;
			create field as _fieldClass transient;
			field.set(prop.name, true, prop.type.name, self.class.name);
			_fields.add(field);
		endif;
	endforeach;
epilog
	delete props;
end;</source>
        <Parameter name="_fields" type="CM_FieldByTypeSysNameDict" usage="input"/>
        <Parameter name="_fieldClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="getJMTInternalName" id="088344f5-7c10-4f07-9c86-55f66f43f633">
