/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Aug 2009	cnwmd1	Initial creation
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	task : CM_WorkOrderDtl;
	displayStr : String;
begin
	
	foreach task in self.allWoDtls discreteLock do			//28.05.2024 navma1 #64224
		if displayStr = null then
			displayStr := task.getDisplayString(false);
