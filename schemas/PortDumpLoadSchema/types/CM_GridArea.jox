<Class name="CM_GridArea">
    <JadeMethod name="exportPDXMLMyCollections" id="3c510b5a-6dab-4f6e-874a-514eff2f1550">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_GridArea::allGridColumnsByLabel.name then
		_file.writeLine('&lt;'&amp;CM_GridArea::allGridColumnsByLabel.name&amp;'&gt;');
		foreach obj in self.allGridColumnsByLabel do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_GridObject.exportPDXML(_file, _objArray, false, false);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_GridArea::allGridColumnsByLabel.name&amp;'&gt;');

	elseif _property.name = CM_GridArea::allGridRowsByLabel.name then
		_file.writeLine('&lt;'&amp;CM_GridArea::allGridRowsByLabel.name&amp;'&gt;');
		foreach obj in self.allGridRowsByLabel do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_GridObject.exportPDXML(_file, _objArray, false, false);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_GridArea::allGridRowsByLabel.name&amp;'&gt;');

	elseif _property.name = CM_GridArea::allGridControllersByRowColumn.name then
		_file.writeLine('&lt;'&amp;CM_GridArea::allGridControllersByRowColumn.name&amp;'&gt;');
		foreach obj in self.allGridControllersByRowColumn do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			_file.writeLine('&lt;row&gt;'&amp;obj.CM_GridController.row.String&amp;'&lt;/row&gt;');
			_file.writeLine('&lt;column&gt;'&amp;obj.CM_GridController.column.String&amp;'&lt;/column&gt;');
			obj.CM_GridController.exportPDXML(_file, _objArray, false, false);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_GridArea::allGridControllersByRowColumn.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="457e9954-b1c2-4d8e-a39a-c6496da1fa5d">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	proxyArray: ObjectArray;
	newObject: Object;
	newGridController: CM_GridController;	
begin
	create proxyArray transient;
	if _name = CM_GridArea::allGridColumnsByLabel.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, _name, proxyArray);
		foreach newObject in proxyArray do
			newObject.CM_GridColumn.setGridAreaForProxy(self);
		endforeach;

//	although this looks wrong it is intentional
//	alphebeticly the Rows will come after the gridcontrollers but
//	the load needs to process the columns and rows before the gridcontrollers
	elseif _name = CM_GridArea::allGridControllersByRowColumn.name then
//	elseif _name = CM_GridArea::allGridRowsByLabel.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, CM_GridArea::allGridRowsByLabel.name, proxyArray);
		foreach newObject in proxyArray do
			newObject.CM_GridRow.setGridAreaForProxy(self);
		endforeach;

//	although this looks wrong it is intentional see above
//	elseif _name = CM_GridArea::allGridControllersByRowColumn.name then
	elseif _name = CM_GridArea::allGridRowsByLabel.name then
		self.importPLXMLMyGridController(_collectionsBlock);
	endif;
epilog
	delete proxyArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollectionsOLD" id="9fc6f39f-8881-48ea-9585-f2ef4f67af04">
        <updating/>
        <source>importPLXMLMyCollectionsOLD(_collectionsBlock: String) updating;

vars
	aClass: Class;
	objBlock, objectBlock, theCode, theKey: String;
	newGridObject: CM_GridObject;
	newGridController: CM_GridController;
	blockLength, pos: Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp; " START.";
	objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_GridArea::allGridColumnsByLabel.name);
//write(class.name&amp;'::'&amp;method.name&amp;CM_GridArea::allGridColumnsByLabel.name);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' objBlock='&amp;objBlock;
			objectBlock := objBlock.cnEcGetNextTagValueOfName(theCode, pos);
//write class.name&amp;'::'&amp;method.name&amp;' objectBlock='&amp;objectBlock;

			create newGridObject as aClass transient;
			newGridObject.importPLXML(theCode, objectBlock);
//write class.name&amp;'::'&amp;method.name&amp;' column='&amp;newGridObject.CM_GridColumn.column.String&amp;' label='&amp;newGridObject.label;
			newGridObject.CM_GridColumn.setGridAreaForProxy(self);
//			self.allGridColumnsByLabel.add(newGridObject);
		endif;
	endwhile;

	objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_GridArea::allGridRowsByLabel.name);
//write(class.name&amp;'::'&amp;method.name&amp;CM_GridArea::allGridRowsByLabel.name);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
			objectBlock := objBlock.cnEcGetNextTagValueOfName(theCode, pos);
			create newGridObject as aClass transient;
			newGridObject.importPLXML(theCode, objectBlock);
//write class.name&amp;'::'&amp;method.name&amp;' row='&amp;newGridObject.CM_GridRow.row.String&amp;' label='&amp;newGridObject.label;
			newGridObject.CM_GridRow.setGridAreaForProxy(self);
//			self.allGridRowsByLabel.add(newGridObject);
		endif;
	endwhile;

	objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_GridArea::allGridControllersByRowColumn.name);
//write(class.name&amp;'::'&amp;method.name&amp;CM_GridArea::allGridControllersByRowColumn.name);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
			create newGridController as aClass transient;
			objectBlock := objBlock.cnEcGetNextTagValueOfName(theCode, pos);
			newGridController.importPLXML(theCode, objectBlock);
			newGridController.CM_GridController.setGridAreaForProxy(self, newGridController.row, newGridController.column, newGridController.ident, newGridController.width);
//			self.allGridControllersByRowColumn.add(newGridController);
		endif;
	endwhile;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyGridController" id="d7bcfb93-4ddc-44d6-80c7-8c600ccb1d34">
        <source>importPLXMLMyGridController(_collectionsBlock: String);

// this is called for each collection to return an array of proxyobject
//
vars
	aClass: Class;
	objBlock, objectBlock, theCode, theKey: String;
	newGridObject: CM_GridObject;
	newGridController: CM_GridController;
	blockLength, pos, tmpPos1: Integer;
	tmpPos2: Integer;
	row, column: Integer;
begin
	objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_GridArea::allGridControllersByRowColumn.name);
//write(class.name&amp;'::'&amp;method.name&amp;CM_GridArea::allGridControllersByRowColumn.name);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
			tmpPos1 := pos;
			row := objBlock.cnEcGetNextTagValueOfName('row', tmpPos1).Integer;
if row = null then
	//process.debug; commented out PAR 19975
endif;
			tmpPos2 := pos;
			column := objBlock.cnEcGetNextTagValueOfName('column', tmpPos2).Integer;
			create newGridController as aClass transient;
			objectBlock := objBlock.cnEcGetNextTagValueOfName(theCode, pos);
			newGridController.importPLXML(theCode, objectBlock);
//write class.name&amp;'::'&amp;method.name&amp;' name='&amp;newGridController.name&amp;' row='&amp;row.String&amp;' column='&amp;column.String;
			newGridController.CM_GridController.setGridAreaForProxy(self, row, column, newGridController.ident, newGridController.width);
//			self.allGridControllersByRowColumn.add(newGridController);
		endif;
	endwhile;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
</Class>
