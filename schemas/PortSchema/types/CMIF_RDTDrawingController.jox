    <JadeMethod name="gotoLocationByID" id="ea13d886-a6c7-4771-abaf-7aab1f2ea252">
        <updating/>
        <source>gotoLocationByID(_lc : CM_LocationsController; _ti : CM_TrackedItem; _mode : Integer; _calcBestZoom : Boolean) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _lc = null then
		return false;
	endif;
	
	self.myTargetTI := _ti;
	
	//write method.name &amp; '_lc id: ' &amp;  _lc.getFullId();
	
	if _calcBestZoom then
		self.calcBestZoom();
	endif;
		
	self.resetScrollOffsets();
	self.resizeDrawingFrames();
	
	self.reDrawAreaFromLocation(_lc, _mode);
	
	return true;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_calcBestZoom" type="Boolean"/>
