    <JadeMethod name="loadAvailableEmailFields" id="d5714b28-b978-44c0-a3d6-866a421d5718">
        <source>loadAvailableEmailFields(_entTableDef : EntTableDef);
/*

Purpose:
Load the list of all available email fields based on defined EntTableDef into the Listbox excluding selected fields.
  
Parameters:
Param #1	EntTableDef - list of all available fields to be shown in the Email Fields section of Package Configuration screen.

Return Value: 
None

Date				Who		Reason
07 February 2019	jlgdi1	Initial creation.  Code extracted from selectPackageType() method.
							Made the code reusable by just passing the EntTableDef.
*/

vars
	proxy : CM_Package;
	selectedFields : StringArray;
	entTableRow	: EntTableRow;
	strObjStr : CM_StringWithString;	
	displayStr : String;
	index : Integer;
begin
	self.allAvailableFields.clear; // ### JIRA 35466 28JUL2025 NAVAB1 with Filtering need a collection
	
	
	self.mulSelectFields.myAvailableListBox.clear();
	proxy := self.myProxyObject;
	if proxy = null then
		create selectedFields transient;
		self.mulSelectFields.getSelectedDisplayEntries(selectedFields);
	else
		if proxy.myEmailTemplate &lt;&gt; null then
			selectedFields := proxy.myEmailTemplate.allIncludedFields;
		endif;
	endif;
	
	foreach entTableRow in _entTableDef.allEntTableRows do
		create strObjStr transient;
		self.allAvailableFields.add(strObjStr); // ### JIRA 35466 28JUL2025 NAVAB1
		
		
		strObjStr.set("~", entTableRow.getHeading(null, null, app.myCurrentLocale));
		displayStr := self.mulSelectFields.displayEntry(strObjStr);
		if (selectedFields = null) or (not selectedFields.includes(displayStr)) then 
			index := self.mulSelectFields.myAvailableListBox.addItem(displayStr);
			self.mulSelectFields.myAvailableListBox.itemObject[index] := strObjStr;
		endif;
	endforeach;
	
	self.mulSelectFields.setAvailable(self.allAvailableFields, true); // ### JIRA 35466 28JUL2025 NAVAB1

epilog
	if (not self.isEdit) and (selectedFields &lt;&gt; null) then
		delete selectedFields;
	endif;
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="loadHistory" id="2c0edc09-835d-4b74-b99d-d8b1948a763c">
        <source>loadHistory() protected;

// Created by cnwdvb1 on 28 June 2006

vars
	row			: Integer;
	realPackage : CM_Package;
	history		: CM_PackageHistoryHdr;
	table		: CM_DataTable;
	
begin
	if not self.isEdit then
		self.shtPackageHist.enabled := false;
		return;
	endif;
	
	self.shtPackageHist.enabled := true;

	table := self.tblHistory;
	
	table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_PackageHistory));
	table.setMyDataClass(CM_PackageHistoryHdr);
	
	table.userInputEnabled 	:= false;
	table.selectMode 		:= Table.SelectMode_CurrentRow;
	table.selectionType 	:= CM_DataTable.SelectionType_Row;
	table.multiSelect 		:= CM_DataTable.MultiSelect_Simple;
	
	table.allTblDataSortColumns.clear();
	table.allTblDataSortDescending.clear();
	table.zAddSortColumn(ETRow_CreatedTs, true);
	table.setSortColumnsForMaxNumCols();
		
	if self.myProxyObject = null then
		return;
	endif;
	
	realPackage := self.myProxyObject.pxyGetRealObject();
	
	if realPackage = null then
		return;
	endif;
	
	foreach history in realPackage.allHistory do
		self.tblDataDisplayRow(history);
	endforeach;
	
	if table.rows &gt; table.fixedRows then
		table.selectRow(table.fixedRows + 1, false);		
	endif;
		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadReports" id="0501d34a-4608-4fac-902e-13f43e71648e">
        <source>loadReports() protected;

// Created by cnwdvb1 on 19 June 2006

vars

	user 	: CM_User;
	reportsAvail: CM_ReportTemplateByNameDict;
	rt: CM_ReportTemplate;
begin

	user := self.cmbUser.myObject.CM_User;
	if user = null then
		return;
	endif;
	
	create reportsAvail transient;
	if self.packageType = PackageVVR then
		foreach rt in user.allReportsToRunForUser where rt.myQryReport &lt;&gt; null do
			if rt.myQryReport.jrwViewName = "CM_TrackedItemView" or rt.myQryReport.jrwViewName = "CM_VehicleVisitView" then	// 20/3/18 MAP TFS37340
				reportsAvail.add(rt);
			endif;
		endforeach;
	else
		user.allReportsToRunForUser.copy(reportsAvail);
	endif;
	
	self.multiReports.setAvailable(reportsAvail, true);
epilog
	delete reportsAvail;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuExtractPackage_click" id="966fb03d-2bc5-4d11-aa78-2a2d01436bf9">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuExtractPackage_click(menuItem: MenuItem input) updating;

// Created by cnwdvb1 on 30 June 2006

vars

begin

	self.extractHistory();

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectCriteria" id="9d6e4ce0-07ee-4807-8121-84798ebd2a8f">
        <updating/>
        <source>selectCriteria() updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
01 Mar 2018	jlgmp6	TFS 37340	Initial creation	
21 Jun 2019	jlgka1	TFS 45245	JMT - Fixed Stackdump bug and Selection Criter
============================================================================*/


vars
	critForm		: CMUI_ObjectCriteriaLineForm;
	vvrCrit			: CM_VVRPackageCriteria;
	vvrObject		: CM_PackageVVR;
	//jlgka1 TFS 45245 --&gt;
	allowedTerminal : CM_Terminal;
	terminal 		: CM_Terminal;
	terminalSet		: CM_TerminalSet;
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	//jlgka1 TFS 45245 &lt;--
begin
	if self.myProxyObject = null then
		create vvrObject transient;
	else
		vvrObject := self.myProxyObject.CM_PackageVVR;
		vvrCrit := vvrObject.myVVRCriteria;
	endif;
	create critForm transient;
	critForm.setMyTerminal(self.getMyTerminal());
	
	//jlgka1 TFS 45245 --&gt;
	if critForm.myTerminal = null then		
		user := app.myPassport.myUser;
		create terminalSet transient;
		self.mulTerminal.getSelected(terminalSet);
		foreach terminal in terminalSet do
			userTerminal := user.allUserTerminals[terminal];
			if userTerminal &lt;&gt; null then	
				allowedTerminal := userTerminal.getMyTerminal();
				break;
			endif;	
		endforeach;	
		critForm.setMyTerminal(allowedTerminal);
	endif;
	//jlgka1 TFS 45245 &lt;--
	
	critForm.setBaseData(CM_ObjectMatchCriteria.VvrPackageInt,	//_context : Integer;
							vvrObject,	//_contextObj : CM_Object;
							vvrCrit,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							null,	//_myListForm : CMUI_ObjectCriteriaListForm
							self	//_myParentForm: CM_BaseForm
							);
	critForm.showModal();
	
	//jlgka1 TFS 45245 Refresh local variable references. 
	vvrCrit := vvrObject.myVVRCriteria;
	
	if vvrCrit &lt;&gt; null then
		self.txtCritDesc.text := vvrCrit.getCriteriaSummary(Comma_And_Space).trimBlanks();
	endif;
	self.myProxyObject := vvrObject;
epilog
	delete terminalSet;
	delete critForm;	
end;</source>
    </JadeMethod>
    <JadeMethod name="selectPackageType" id="0050386e-992a-4e90-a258-e2d491a975ac">
        <updating/>
        <source>selectPackageType(_packageType : Integer) protected, updating;

/*
Created by cnwdvb1 on 26 June 2006

Date		Who		Reason
22/03/2012	cnwcs5	CCMS POL 2144 / par 29312 - Extract BAPLIE by Operator
29/03/2012	cnwcs5	par 29318 - conversion for 29312
08/02/2019	jlgdi1	TFS# 432250	Email tab made available for Invoice Posted type of package.
					Set maxLength of txtCode to 30. Set maxLength of txtDescription to 60 (to avoid 
					'String too long' exception). Set scrollHorizontal of txtDescription to True 
					to enable inputting a preferred description upto max allowable length.
22 Apr 2025	navah1	Bug 34605: LINX - Invoice Package Reports - Email Fields					
*/

vars
	shipping	: CM_PackageSailing;
	email		: CM_EmailTemplate;
	proxy		: CM_Package;		// par 29312 - march 2012
	soleTerminal: CM_TerminalSet;
	entTableDef : EntTableDef;
	
begin
	if _packageType &lt;&gt; 0 then
		self.packageType := _packageType;
	endif;
	
	self.grpBaplieDtl.visible := false;
	self.grpCamsDtl.visible := false;		// 1/3/18 MAP TFS37340
	self.grpVVRDtl.visible := false;
	
	proxy := self.myProxyObject;
	if proxy &lt;&gt; null then
		self.txtCode.text 			:= proxy.code;
		self.txtDescription.text 	:= proxy.description;
		
		self.cmbUser.setObject(proxy.myUser);
		self.loadReports();
		self.multiReports.setSelected(proxy.allReportTemplates);
		
		email := proxy.myEmailTemplate;
		
		if proxy.isKindOf(CM_PackageInvoice) then																			//navra1 - CR 61910/Task 62303 - 15th Feb 2024
			self.chkSendToDebtorEmail.value 		:= proxy.CM_PackageInvoice.sendToDebtorEmail;							//navra1 - CR 61910/Task 62303 - 15th Feb 2024
			self.chkAttachExtAttOfInv.value 		:= proxy.CM_PackageInvoice.attachExtAttOfInv;							//navra1 - CR 61910/Task 62303 - 15th Feb 2024
			self.chkPrefixEmailSubWithInvNo.value 	:= proxy.CM_PackageInvoice.prefixEmailSubWithInvNumber;					//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		endif;																												//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		
		if email &lt;&gt; null then
			self.txtToAddress.text	:= email.getAllToAddressesOrNames(false);
			self.txtCcAddress.text	:= email.getAllCCAddressesOrNames(false);
			self.txtBccAddress.text	:= email.getAllBCCAddressesOrNames(false);
			self.txtSubject.text	:= email.subject;
			self.txtMessage.text	:= email.body;
		endif;
		
		if _packageType = 0 then
			self.cmbPackageType.listIndex 	:= self.cmbPackageType.findStringExact(1, self.getDisplayForPackageType(proxy.type));	// par 29312
			self.packageType 				:= proxy.type;
		endif;
	endif;
	
	self.shtFields.enabled := (self.packageType = PackageVVR) or (self.packageType = PackageInvoicePost);
	if self.packageType = PackageSailing then
		self.grpBaplieDtl.visible := true;
		
		if proxy &lt;&gt; null then
			shipping 				:= proxy.CM_PackageSailing;
			self.chkBaplie.value 	:= shipping.includeBaplie;
			
			if self.chkBaplie.value then
				self.doChkBaplie();
				self.cmbType.listIndex 		:= self.cmbType.findStringExact(1, self.getDisplayForExtractType(shipping.extractType));	// par 29312 - march 2012
				self.cmbFormat.listIndex 	:= self.cmbFormat.findStringExact(1, self.getDisplayForFileType(shipping.fileType));		// par 29312 - march 2012
				
				self.cmbOperator.setObject(shipping.myRecipient);
				self.cmbCargoOperator.setObject (shipping.myCargoOperator);	// par 29318/29312 - march 2012
				
				self.cmbTerminal.listIndex 	:= self.cmbTerminal.findObject(shipping.myTerminal);
			endif;
		endif;
		
		self.grpCamsDtl.visible := true;
		
		if proxy &lt;&gt; null then
			shipping := proxy.CM_PackageSailing;
			
			if shipping.myTerminalCams &lt;&gt; null then
				self.chkCams.value 				:= true;
				self.cmbTerminalCams.enabled 	:= true;
				self.cmbTerminalCams.listIndex 	:= self.cmbTerminalCams.findObject(shipping.myTerminalCams);
				
				if shipping.myCamProtocol &lt;&gt; null then
					self.cmbCamsProtocol.enabled := true;
					self.cmbCamsProtocol.listCollection(shipping.myTerminalCams.camProtocols, true, 0);
					self.cmbCamsProtocol.listIndex := self.cmbCamsProtocol.findObject(shipping.myCamProtocol);
				endif;
			endif;
		endif;
		
	elseif self.packageType = PackageVVR then
		self.grpVVRDtl.visible := true;
		self.mulTerminal.setupControl(app.getErrorString(Terminals), app.myRoot.allTerminals, CMUI_PackageConfigForm::displayEntryTerminal.name);
		
		if self.mulTerminal.myAvailableListBox.listCount = 1 and not self.isEdit then
			create soleTerminal transient;
			soleTerminal.add(app.myRoot.allTerminals.first());
			self.mulTerminal.setSelected(soleTerminal);
		endif;

		if proxy = null then		// 5/4/18 MAP TFS37856
			entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);
			loadAvailableEmailFields(entTableDef);
		endif;

		if self.myProxyObject &lt;&gt; null then
			self.mulTerminal.setSelected(proxy.CM_PackageVVR.allTerminals);

			if self.myProxyObject.CM_PackageVVR.myVVRCriteria &lt;&gt; null then
				self.txtCritDesc.text := self.myProxyObject.CM_PackageVVR.myVVRCriteria.getCriteriaSummary(Comma_And_Space).trimBlanks();
			endif;
		endif;

	elseif self.packageType = PackageInvoicePost then 
		//entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);			//19.05.2025 navah1 #34605
		entTableDef := app.myController.getEntTableDef(ETDef_InvoiceStatusEmail);   //19.05.2025 navah1 #34605
		loadAvailableEmailFields(entTableDef);
	endif;
epilog
	delete soleTerminal;
end;</source>
        <access>protected</access>
        <Parameter name="_packageType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="8c73ea36-3d0c-4de5-9025-b9f913c2bf33">
        <updating/>
        <source>setAttributes(_isEdit : Boolean; _packageType : Integer; _package : CM_Package) updating;
/*

Purpose:			Load attributes into form

Parameters:			


Date			Who		Reason
26 June 2006	cnwdvb1	Initial creation
25 January 2019	jlgzm1	TFS42936 create proxy task/scehdule for update
18 Feb 2019		jlgdi1	TFS 43250 - set the value of the attribute 'formDisplayEntryMethodName' of mulSelectFields
JIRA 35466 29JUL NAVAB1 convert to parent aSPECT.
*/
vars
	row				: Integer;
	debtorInvType	: CM_DebtorInvType;
	str				: String;
	multiSelect		: CMUI_MultiSelectGroupBox;
	table			: CM_DataTable;
	grpInvPack,
	grpBaplie,
	grpVVR			: CMUI_GroupBox;
	realTask 		: CM_AutoTask;
	realSchedule 	: CM_AutoSchedule;
	completedOK 	: Boolean;
	
	 drName : String;
	 mailingName : String;
	 descr : String;
begin

	self.isEdit := _isEdit;
	
	if _packageType &lt;&gt; 0 then
		self.packageType := _packageType;
	endif;
	
	multiSelect := self.multiReports;
	
	multiSelect.formDisplayEntryMethodName 	:= CMUI_PackageConfigForm::displayDetail.name; 
	multiSelect.availableHeading 			:= 'Available Report Templates';
	multiSelect.selectedHeading 			:= 'Selected Report Templates';
	multiSelect.myBaseForm					:= self;
	multiSelect.mySelectedListBox.sorted 	:= false;
	multiSelect.displayOrderBtns(true, true);
	multiSelect.multiSelect					:= ListBox.MultiSelect_Extended;
	
	self.doFillFileFormatCombo(self.cmbFormat);
	self.doFillExtractTypeCombo(self.cmbType);
	self.doFillPackageTypeCombo(self.cmbPackageType);
	
	self.cmbTerminal.listCollection(app.myRoot.allTerminals, true, 0);
	self.cmbTerminal.listIndex := 1;
	
	self.cmbTerminalCams.listCollection(app.myRoot.allTerminals, true, 0);
	self.cmbTerminalCams.listIndex := 1;
	
	self.cmbCamsProtocol.enabled := false;
	
	grpBaplie := self.grpBaplieDtl;

	multiSelect := self.mulSelectFields;
	multiSelect.formDisplayEntryMethodName := 'displayEntryEmailFields';
	
	if self.isEdit then
		self.cmbPackageType.enabled := false;
		self.myProxyObject 			:= app.createUpdateProxy(_package).CM_Package;
		
		self.selectPackageType(null);
	else
		self.cmbPackageType.enabled := true;
	endif;
	// 28218 CCMS 2120 Sep 2011
	if self.packageType = PackageInvoicePost then
		self.lblPackageType.visible := false;
		self.cmbPackageType.visible := false;
		
		grpInvPack	:= self.grpInvPackDtl;
		
//		grpInvPack.move (grpBaplie.left, grpBaplie.top, grpBaplie.width, grpBaplie.height);
		
		table := self.tblUsedBy;
		
//		table.height 	:= grpInvPack.height - table.top - 11;
//		table.width 	:= grpInvPack.width - 22;
		table.rows 		:= table.fixedRows;
		
		table.setCellText (1, 1, app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(CM_Business_Unit) &amp; Tab &amp; app.getErrorString(Invoice_type));		
		grpInvPack.visible 	:= true;
		
		if _package &lt;&gt; null then
			foreach debtorInvType in _package.CM_PackageInvoice.allDebtorInvTypes do
				//str := debtorInvType.myDebtor.name &amp; Tab &amp; debtorInvType.myInvoiceType.company.mailingName &amp; Tab &amp; debtorInvType.myInvoiceType.description;
				//27 Jul 2021	NDL	TFS 50517 - 1090 during testing
				drName := null;
				mailingName := null;
				descr := null;
				
				if debtorInvType.myDebtor &lt;&gt; null then
					drName := debtorInvType.myDebtor.name;
				endif;
				if debtorInvType.myInvoiceType &lt;&gt; null and debtorInvType.myInvoiceType.company &lt;&gt; null then
					mailingName := debtorInvType.myInvoiceType.company.mailingName;
				endif;
				if debtorInvType.myInvoiceType &lt;&gt; null then
					descr := debtorInvType.myInvoiceType.description;
				endif;
				str := drName &amp; Tab &amp; mailingName &amp; Tab &amp; descr;
				row := table.addItem(str);
			endforeach;
			//tfs42936
			realTask := _package.allTasks.first();
			if realTask &lt;&gt; null and realTask.isKindOf(CM_AutoTaskPackage) then
				self.myProxyAutoTask := app.createUpdateProxy(realTask).CM_AutoTaskPackage;
				realSchedule := realTask.allAutoSchedules.first();
				if realSchedule &lt;&gt; null then
					self.myProxyAutoSchedule := app.createUpdateProxy(realSchedule).CM_AutoSchedule; 
				endif;
			endif;
			
		endif;
	endif;
	
	self.loadHistory();
	completedOK := true;

epilog
	if not completedOK then
		delete self.myProxyObject;
		delete self.myProxyAutoTask;
		delete self.myProxyAutoSchedule;
	endif;
end;</source>
        <Parameter name="_isEdit" type="Boolean"/>
        <Parameter name="_packageType" type="Integer"/>
        <Parameter name="_package" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="setEmailTemplate" id="6f19fa79-46d8-4f2c-a81d-6eeebd5c9e26">
        <updating/>
        <source>setEmailTemplate() protected, updating;

// Created by cnwdvb1 on 26 June 2006

vars
	sa: StringArray;
begin


	self.myEmailTemplate := self.myProxyObject.myEmailTemplate;
	
	if self.myEmailTemplate = null then
		create self.myEmailTemplate transient;
	endif;
	
	self.myEmailTemplate.setProxy(null, null, null, null,
						   self.txtToAddress.text, 
						   self.txtCcAddress.text, 
						   self.txtBccAddress.text, 
						   self.txtSubject.text, 
						   self.txtMessage.text, 
						   false);
			   
	self.myEmailTemplate.allIncludedFields.clear();
	create sa transient;
	self.mulSelectFields.getSelectedDisplayEntries(sa);
	sa.copy(self.myEmailTemplate.allIncludedFields);

epilog
	delete sa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyForInvoice" id="cbf1542d-5643-4a26-82f4-8485b3cdafe6">
        <source>setProxyForInvoice() protected;
/*

Purpose:			set attribute values on the proxy objects for invoice

Date			Who		Reason
-- Sep 2011				Initial creation CCMS 2120 28218
01 Jan 2018		jlgzm1	set values for task, and schedule proxys
18 Feb 2019		jlgdi1	43250 - set the entTableDef of 'myEmailTemplate'
22 Apr 2025		navah1	Bug 34605: LINX - Invoice Package Reports - Email Fields
*/
vars

	packageInvoice : CM_PackageInvoice;
	autoTask		: CM_AutoTaskPackage;
	autoSchedule	: CM_AutoSchedule;
	desc			: String;

begin

	packageInvoice := self.myProxyObject.CM_PackageInvoice;
	autoTask := self.myProxyAutoTask;
	autoSchedule := self.myProxyAutoSchedule;
	
	self.allSelectedReports.clear();
	self.multiReports.getSelected(self.allSelectedReports);

	
	packageInvoice.setForProxy(self.txtCode.text,
								self.txtDescription.text,
								self.myEmailTemplate,
								self.allSelectedReports,
								self.cmbUser.myObject.CM_User,
								self.packageType,
								self.chkSendToDebtorEmail.value,				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
								self.chkAttachExtAttOfInv.value,				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
								self.chkPrefixEmailSubWithInvNo.value);			//navra1 - CR 61910/Task 62303 - 15th Feb 2024
	
	if autoTask &lt;&gt; null then
		desc := "Invoice Package " &amp; packageInvoice.description;
		autoTask.setValueForRow(ETRow_BgpAutoDescription, desc[1:30]);
		autoTask.setValueForRow(ETRow_BgpAutoUser, packageInvoice.myUser);
		if autoSchedule &lt;&gt; null then
			autoSchedule.setForEvent(desc, EventDataInvoicing);
		endif;
	endif;
	
	//self.myEmailTemplate.setEntTableName(ETDef_LlHeadings);		//19.05.2025 navah1 #34605
	self.myEmailTemplate.setEntTableName(ETDef_InvoiceStatusEmail); //19.05.2025 navah1 #34605
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyForReports" id="7475e73f-1e54-4d8e-bfba-96b1a4f5546a">
        <source>setProxyForReports() protected;

// Created by cnwdvb1 on 30 June 2006

vars

	packageReports : CM_PackageRpts;

begin

	packageReports := self.myProxyObject.CM_PackageRpts;
	
	self.allSelectedReports.clear();
	self.multiReports.getSelected(self.allSelectedReports);

	
	
	packageReports.setForProxy(			self.txtCode.text,
										self.txtDescription.text,
										self.myEmailTemplate,
										self.allSelectedReports,
										self.cmbUser.myObject.CM_User,
										self.packageType,
										null,				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
										null,				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
										null);				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyForSailing" id="bf5d6d37-5c82-4c67-87a6-ff5fd0a4dc23">
        <source>setProxyForSailing() protected;

// Created by cnwdvb1 on 26 June 2006
// 22/03/2012	cnwcs5	CCMS POL 2144 / par 29312 - Extract BAPLIE by Operator
// 04/08/2016	cnwdap1	TFS #2415 Default Extract Type to -1 so we know if it's been set to ACTUAL_BAYPLANS
//								(which has a value of 0)
vars
	packageSailing	: CM_PackageSailing;
	type,		
	format			: Integer;	
	camProtocol 	: CM_CamProtocol;
	camTerminal 	: CM_Terminal;
	combo			: CMUI_ComboBox;
	index			: Integer;
begin

	packageSailing := self.myProxyObject.CM_PackageSailing;
	
	self.allSelectedReports.clear();
	self.multiReports.getSelected(self.allSelectedReports);
	
	// Extract type
	combo := self.cmbType;
	index	:= combo.listIndex;
	
	if index &lt;&gt; - 1 then
		type := combo.itemData[index];
	else												// TFS #2415
		type := NULLINDEX;								// TFS #2415
	endif;
	
	// Extract format
	combo 	:= self.cmbFormat;
	index	:= combo.listIndex;
	
	if index &lt;&gt; - 1 then
		format := combo.itemData[index];
	endif;
	
	if chkCams.value = true then
		camProtocol := self.cmbCamsProtocol.listObject.CM_CamProtocol;
		camTerminal := self.cmbTerminalCams.listObject.CM_Terminal;
	endif;
	
	packageSailing.setForProxySailing(	self.txtCode.text,
										self.txtDescription.text,
										self.myEmailTemplate,
										self.allSelectedReports,
										self.cmbUser.myObject.CM_User,
										self.packageType,
										self.chkBaplie.value,
										type,
										format,
										self.cmbOperator.myObject.CM_Operator,
										self.cmbCargoOperator.myObject.CM_Operator,		// par 29312 - march 2012
										self.cmbTerminal.listObject.CM_Terminal,
										camProtocol,
										camTerminal);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyForVVR" id="9a0adf92-5d89-4628-8f1b-e799fd6deb3e">
        <updating/>
        <source>setProxyForVVR() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars
	packageVVR: CM_PackageVVR;
	terminals:	CM_TerminalSet;
begin
	packageVVR := self.myProxyObject.CM_PackageVVR;

	self.allSelectedReports.clear();
	self.multiReports.getSelected(self.allSelectedReports);

	create terminals transient;
	self.mulTerminal.getSelected(terminals);

	packageVVR.setForProxyVVR(self.txtCode.text,
										self.txtDescription.text,
										self.myEmailTemplate,
										self.allSelectedReports,
										self.cmbUser.myObject.CM_User,
										self.packageType,
										self.myProxyObject.CM_PackageVVR.myVVRCriteria,
										terminals);
	self.myEmailTemplate.setEntTableName(ETDef_LlHeadings);
epilog
	delete terminals;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f39fcbc0-26f0-44a5-a616-9f7e80a8b51c">
        <updating/>
        <source>setupForm() updating;

// Created by cnwdvb1 on 19 June 2006
//03 Sep 2025	navah1	Bug 35591: MTN | Invoice Package Email Fields Issue
vars

	user : CM_User;

begin
	
	inheritMethod();
	
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.fldMain.top := self.topMargin + self.frmToolbar.height;
	
	self.multiReports.cnEcResizeContents();

	self.mulTerminal.userInputEnabled := true;
	self.mulTerminal.formDisplayEntryMethodName := CMUI_PackageConfigForm::displayEntryTerminal.name;
	self.mulTerminal.setVisibleButtons(false, false, true);
	self.mulTerminal.visible := true;
	self.mulTerminal.caption := app.getErrorString(Terminals);
	self.mulTerminal.mySelectedListBox.sorted := false;
	self.mulTerminal.multiSelect := ListBox.MultiSelect_Extended;
	
	self.mulSelectFields.formDisplayEntryMethodName := 'displayEntryEmailFields';
	self.mulSelectFields.availableHeading := 'Fields available';
	self.mulSelectFields.selectedHeading  := 'Fields selected';
	self.mulSelectFields.userInputEnabled := true;
	self.mulSelectFields.displayOrderBtns(true, true);
	self.mulSelectFields.multiSelect := ListBox.MultiSelect_Extended;
	self.mulSelectFields.myAvailableListBox.sorted := true;
	self.mulSelectFields.mySelectedListBox.sorted := false;
	
	//03.09.2025 navah1 #35591 - Start
	/*
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.myEmailTemplate &lt;&gt; null and self.myProxyObject.myEmailTemplate.entTableName &lt;&gt; null then
		self.myAssistant.multiSelectEntityFields(self.mulSelectFields, self.myProxyObject.myEmailTemplate.entTableName, self.myProxyObject.myEmailTemplate.allIncludedFields);
	endif;
	*/
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.myEmailTemplate &lt;&gt; null then  
		if self.myProxyObject.type = PackageInvoicePost then  
			self.myAssistant.multiSelectEntityFields(self.mulSelectFields, ETDef_InvoiceStatusEmail, self.myProxyObject.myEmailTemplate.allIncludedFields);
		elseif self.myProxyObject.type = PackageVVR then 
			self.myAssistant.multiSelectEntityFields(self.mulSelectFields, ETDef_LlHeadings, self.myProxyObject.myEmailTemplate.allIncludedFields);
		endif;
	endif;
	//03.09.2025 navah1 #35591 - End

	self.txtCode.setFocus();
	
	self.beginClassNotification(CM_PackageHistoryHdr, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_PackageHistoryHdr, false, Object_Create_Event, Response_Continuous, 0);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectRecipients" id="58c69bb8-72ab-4744-a0ce-7ad7ffaac494">
        <updating/>
        <source>showSelectRecipients(_mode : Integer)updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	form 		: CMUI_RecipientSelector;
	strArr 		: HugeStringArray;
	str			: String;
	email		: CM_EmailEntity;
	controller	: CMIF_EmailTemplateController;
begin
	controller := self.myEmailController;
	
	if controller = null then
		create self.myEmailController transient;
		
		controller := self.myEmailController;
	endif;
	
	self.getEmailAddresses();	// 07/05/2010 cnwar2 #22273
	
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	
	form.myEmailController 	:= controller;
	form.mode 				:= _mode;
	form.centreWindow;
	form.showModal;

	if form.modalResult = IDOK then
		self.txtToAddress.text 	:= controller.allToAddresses.getAddresses();
		self.txtCcAddress.text 	:= controller.allCcAddresses.getAddresses();
		self.txtBccAddress.text := controller.allBccAddresses.getAddresses();				
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
