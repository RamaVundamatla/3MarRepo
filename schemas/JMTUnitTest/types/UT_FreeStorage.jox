    <JadeMethod name="tFreeStorageAnyCalendar01" id="9fe6b7d3-d6c9-4246-8fd5-2bd2475a3113">
        <source>tFreeStorageAnyCalendar01();
/*

Purpose:		Free storage testing. It is possible to include calendars of dates in the calculation of free storage expiry. These calendars are used in a particular way and are specified only at terminal level.
													Now at storage detail level any number of calendars can be added, this is more flexible as it means there can be calendars with just saturdays and a seperate one for just sundays. 
													Different cargo types can has initial days excluded for just saturday and not sunday or both saturday and sunday etc.
													This test will be based around the cargo having 3 days free storage. The test will then have a calendar of saturdays and a second calendar of sundays.
													the config will INCLUDE FIRST DAY.
													Then cargo will be received on a Thursday, on the Friday, satorday, sunday, monday etc and the date of free expiry can be checked.
													There will be no calendars at terminal level.
													
													3 free days. Actual discharge date. Include first day = TRUE.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
// ### TFS BUG 65740 21AUG2024 NAVAB1
*/

constants
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	FREEDAYS = 3;
vars
	ti				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	moveTS, now				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	trans : CM_TITransactionSet;
	calendars : CM_CalendarByCodeDict;
	calendar		: CM_Calendar;
	startDate, freeExp, expectedDate		: Date;
	bs : CM_LocationsController;
begin
	
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	// CALENDAR SATURDAYS
	create calendars transient;
	self.deleteCalendar("USAT", "UTSAT");
	calendar := self.createCalendar("USAT", "Unit test Saturdays", false, false, "UTSAT");
	startDate := moveTS.date.getNearestDay(SHIFT_Saturday);
	startDate := startDate.addDays(-7);
	self.addBulkCalendarDates(calendar, startDate, 3, "Saturdays");
	calendars.add(calendar);
	
	// CALENDAR SUNDAYS
	self.deleteCalendar("USUN", "UTSUN");
	calendar := self.createCalendar("USUN", "Unit test Sundays", false, false, "UTSUN");
	startDate := moveTS.date.getNearestDay(SHIFT_Sunday);
	startDate := startDate.addDays(-7);
	self.addBulkCalendarDates(calendar, startDate, 3, "Sundays");
	calendars.add(calendar);
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	bs := terminalArea.getMyLocationsController();
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	
	
	self.opts.purge();
	self.opts.addAssoc("AdditionaCalendars", calendars);
	
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,FREEDAYS,0,false,true,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// #########################################
	// ###### CREATE CARGO ON VOYAGE
	// #########################################
	
	numTiToCreate := 8;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	

	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
	endforeach;

	// #########################################
	// ##### Move cargo to Yard
	// #########################################
	self.opts.purge();

	
	// RECEIVED MONDAY FREE EXP SBE WEDNESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Monday, bs, 2);

	// RECEIVED TUESDAY FREE EXP SBE THURSDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Tuesday, bs, 2);
	
	// RECEIVED WEDNESDAY FREE EXP SBE FRIDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Wednesday, bs, 2);
	
	// RECEIVED THURSDAY FREE EXP SBE MONDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Thursday, bs, 4);
	
	// RECEIVED FRIDAY FREE EXP SBE TUESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Friday, bs, 4);

	// RECEIVED SATURDAY FREE EXP SBE WEDNESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Saturday, bs, 4);

	// RECEIVED SUNDAY FREE EXP SBE THURSDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Sunday, bs, 3);
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
epilog
	delete tiSet;
	delete cmifAgent;
	delete trans;
	delete calendars;
	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFreeStorageAnyCalendar02" id="89d08c08-7b83-4141-bcc9-0635943f740b">
        <source>tFreeStorageAnyCalendar02();
/*

Purpose:		Free storage testing. It is possible to include calendars of dates in the calculation of free storage expiry. These calendars are used in a particular way and are specified only at terminal level.
													Now at storage detail level any number of calendars can be added, this is more flexible as it means there can be calendars with just saturdays and a seperate one for just sundays. 
													Different cargo types can has initial days excluded for just saturday and not sunday or both saturday and sunday etc.
													This test will be based around the cargo having 3 days free storage. The test will then have a calendar of saturdays and a second calendar of sundays.
													the config will NOT INCLUDE FIRST DAY.
													Then cargo will be received on a Thursday, on the Friday, satorday, sunday, monday etc and the date of free expiry can be checked.
													There will be no calendars at terminal level.
													
													3 free days. Actual discharge date. Include first day = FALSE.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
// ### TFS BUG 65740 21AUG2024 NAVAB1
*/

constants
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	FREEDAYS = 3;
vars
	ti				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	moveTS, now				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	trans : CM_TITransactionSet;
	calendars : CM_CalendarByCodeDict;
	calendar		: CM_Calendar;
	startDate, freeExp, expectedDate		: Date;
	bs : CM_LocationsController;
begin
	
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	// CALENDAR SATURDAYS
	create calendars transient;
	self.deleteCalendar("USAT", "UTSAT");
	calendar := self.createCalendar("USAT", "Unit test Saturdays", false, false, "UTSAT");
	startDate := moveTS.date.getNearestDay(SHIFT_Saturday);
	startDate := startDate.addDays(-7);
	self.addBulkCalendarDates(calendar, startDate, 3, "Saturdays");
	calendars.add(calendar);
	
	// CALENDAR SUNDAYS
	self.deleteCalendar("USUN", "UTSUN");
	calendar := self.createCalendar("USUN", "Unit test Sundays", false, false, "UTSUN");
	startDate := moveTS.date.getNearestDay(SHIFT_Sunday);
	startDate := startDate.addDays(-7);
	self.addBulkCalendarDates(calendar, startDate, 3, "Sundays");
	calendars.add(calendar);
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	bs := terminalArea.getMyLocationsController();
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, false, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	
	
	self.opts.purge();
	self.opts.addAssoc("AdditionaCalendars", calendars);
	
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,FREEDAYS,0,false,true,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// #########################################
	// ###### CREATE CARGO ON VOYAGE
	// #########################################
	
	numTiToCreate := 8;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	

	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
	endforeach;

	// #########################################
	// ##### Move cargo to Yard
	// #########################################
	self.opts.purge();

	
	// RECEIVED MONDAY FREE EXP SBE THURSDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Monday, bs, 3);

	// RECEIVED TUESDAY FREE EXP SBE FRIDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Tuesday, bs, 3);
	
	// RECEIVED WEDNESDAY FREE EXP SBE MONDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Wednesday, bs, 5);
	
	// RECEIVED THURSDAY FREE EXP SBE TUESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Thursday, bs, 5);
	
	// RECEIVED FRIDAY FREE EXP SBE WEDNESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Friday, bs, 5);

	// RECEIVED SATURDAY FREE EXP SBE WEDNESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Saturday, bs, 4);

	// RECEIVED SUNDAY FREE EXP SBE WEDNESDAY
	self.moveAndCheckFreeExp(voyage, SHIFT_Sunday, bs, 3);
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
epilog
	delete tiSet;
	delete cmifAgent;
	delete trans;
	delete calendars;
	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMaintFutureStorageMapping" id="d855b908-e69c-48fb-a601-2576fd915e9a">
        <source>tMaintFutureStorageMapping();
// cnwmp6
// cnwjre1 test create, change, delete of future storage mapping, checking inverses
vars
	bank			: CM_Bank;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	storageDetail,
	detail1,
	detail2	: CM_StorageDetail;
	qrm		: CM_QuantityRangeMap;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	count			: Integer;

	ta1Code,
	ta2Code, 
	ta3Code,
	ta4Code		: String;
	ta,
	ta1, ta2,
	ta3, ta4	: CM_TerminalArea;
	tasg,
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	termAreas		: CM_TerminalAreaArray;
	
	ilt,
	invLineType1,
	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	invLineTypeArray	: CM_InvoiceLineDescArray;
	tmiMap			: CM_TranMapInvoiceLineMapping;
	
	fsm,
	fsm1,
	fsm2,
	fsm3	: CM_FutureStorageMapping;

begin

	self.deleteStorageConfig( false );

	bank := self.myBank;
	create invLineTypeArray transient;

	// create some storage details
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	// all options false/null
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, true);
	foreach storageDetail in storageConfig.allStorageDetails do
		count := count + 1;
		if count = 1 then
			detail1 := storageDetail;
		elseif count = 2 then
			detail2 := storageDetail;
		endif;
	endforeach;
	
	// create some terminal area storage groups
	ta1Code := "UTTAA1";
	ta2Code := "UTTAA2";
	ta3Code := "UTTAA3";
	ta4Code := "UTTAA4";
	self.deleteTerminalArea(ta1Code);
	self.deleteTerminalArea(ta2Code);
	self.deleteTerminalArea(ta3Code);
	self.deleteTerminalArea(ta4Code);
	
	ta1 := self.addBlockStack(ta1Code, 10, null);
	ta2 := self.addBlockStack(ta2Code, 10, null);
	ta3 := self.addBlockStack(ta3Code, 10, null);
	ta4 := self.addBlockStack(ta4Code, 10, null);
	
	self.deleteTerminalAreaStorageGroup(ta1Code);
	self.deleteTerminalAreaStorageGroup(ta2Code);
	
	create termAreas transient;
	termAreas.add(ta1);
	termAreas.add(ta2);
	
	tasg1 := self.addTerminalAreaStorageGroup(ta1Code, "first", termAreas);

	termAreas.clear();
	termAreas.add(ta3);
	termAreas.add(ta4);
	tasg2 := self.addTerminalAreaStorageGroup(ta2Code, "second", termAreas);
	
	// get some invoice line types
	invLineType1 := self.getInvoiceLineType("UT_ILD01");
	invLineType2 := self.getInvoiceLineType("UT_ILD02");
	invLineType3 := self.getInvoiceLineType("UT_ILD03");

	invLineTypeArray.add(invLineType1);
	///fsm1 := self.addFutureStorageMapping(tasg1, invLineType1, detail1);
	fsm1 := self.addFutureStorageMapping2(bank, tasg1, detail1, invLineType1.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm1, 'first FSM');
	///fsm2 := self.addFutureStorageMapping(tasg2, invLineType1, detail1);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm2 := self.addFutureStorageMapping2(bank, tasg2, detail1, invLineType2.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm2, 'second FSM');
	// test for duplicate check
	self.expectTrxError(QuantityRangeConflict);
	///fsm3 := self.addFutureStorageMapping(tasg1, invLineType1, detail1);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType1);
	fsm3 := self.addFutureStorageMapping2(bank, tasg1, detail1, invLineType1.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertTrxError(QuantityRangeConflict);
	self.clearExpectedTrxErrors();
	
	// update 2nd FSM to invLineType2
	///self.updateFutureStorageMapping(fsm2, invLineType2);
	qrm := fsm2.myQuantityMap.allQuantityRanges.first;
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail1, invLineType2.myCalculationType, qrm, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	///fsm3 := self.addFutureStorageMapping2(bank, tasg1, detail1, invLineType1.myCalculationType, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	///self.assertEqualMsg(fsm2.myInvoiceLineType, invLineType2, "2nd free storage mapping invoice line type ");
	ilt := null;
	count := 0;
	foreach qrm in fsm2.myQuantityMap.allQuantityRanges do
		count := count + 1;
		foreach tmiMap in qrm.allTMInvoiceLineMappings do
			count := count + 1;
			ilt := tmiMap.myTMInvoiceLineDesc;
		endforeach;
	endforeach;
	self.assertEqualMsg(count, 2, "mapping invoice item count after change");
	self.assertEqualMsg(ilt, invLineType2, "2nd free storage mapping invoice line type ");
	
	// delete FSM
	self.deleteFutureStorageMapping(fsm2);
	self.assertIsDeletedMsg(fsm2, "future mapping after delete");
	count := 0;
	foreach fsm in detail1.allFutureStorageMappings do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "storage detail mapping count after delete");
	// check that delete storage detail deletes fsm
	self.deleteStorageDetail(detail1);
	self.assertIsDeletedMsg(fsm1, "future mapping after storage detail delete");
	
	// create a new FSM then delete the area storage group
	///fsm3 := self.addFutureStorageMapping(tasg2, invLineType2, detail2);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm3 := self.addFutureStorageMapping2(bank, tasg2, detail2, invLineType2.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm3, 'third FSM');

	///fsm1 := self.addFutureStorageMapping(tasg1, invLineType1, detail2);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType1);
	fsm1 := self.addFutureStorageMapping2(bank, tasg1, detail2, invLineType1.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm1, 'fourth FSM');
	self.deleteTerminalAreaStorageGroup(tasg2.code);
	self.assertIsDeletedMsg(tasg2, "storage group delete");
	self.assertIsDeletedMsg(fsm3, "future mapping after storage group delete");

epilog
	self.deleteStorageConfig( true );
	delete triggers;
	delete termAreas;
	delete invLineTypeArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOpChangeReleaseStorage" id="e7b64687-bf55-4738-aae7-3777f52a2034">
        <updating/>
        <source>tOpChangeReleaseStorage() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 12SEP2025
ADO - JIRA 35987
*/

vars
	cStatus : CM_ContentsStatus;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	transTS, transTS1, transTS2 : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;

	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	pxyStorageTrigger	: CM_StorageTrigger;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
	storageCount : Integer;
begin

	self.deleteStorageConfig( false );

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// just imex change as a trigger
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, true, 5, 5, 0);	

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	transTS1.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		transTS1.setDate(tranDate);
		transTS1.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", transTS1);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		transTS1.setDate(editDate);
		transTS1.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", transTS1);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);


	// set Trans to 35 days ago
	// ##################
	tranDate := tranDate + 30;
	transTS.setDate(tranDate);

	// change operator from UTOP (debtor ABOPS) to UTO2 (debtor RDT) - should trigger storage
	self.opts.addAssoc("Operator", self.getOperator('UTO2'));
	self.opts.addAssoc("EffectiveTS",transTS);

	self.updateTrackedItem(cargo);

	storageCount := self.countTransactionsOfType(cargo, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 1, "Storage transactions after operator changes");
	
	
	// gate it out -  creates a second storage transaction 
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	storageCount := self.countTransactionsOfType(cargo, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 2, "Storage transactions after release");

	tran := cargo.getFirstTransOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(tran &lt;&gt; null, "First Storage is null");
	self.assertTrueMsg(tran.dateTime.date = transTS1.date, "First storage date time is wrong");
	tran := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(tran &lt;&gt; null, "Last Storage is null");
	self.assertTrueMsg(tran.dateTime.date = transTS2.date, "Last storage date time is wrong");
	
	
epilog
	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;
	
	self.deleteStorageConfig( true );

	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceivalDateOptionStorage" id="10e1b8f9-e74f-4958-99b3-51165d4e42af">
        <updating/>
        <source>tReceivalDateOptionStorage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/06/2023	navkc1	CR 58007 Task 58006: JADE - Storage Config - Unit Tests
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/
constants
	TRUCK 			: String = "UTTRUCK";
	TAREA			: String = "UTSTORE3";
	TrainInCode 	: String = "TR_58006";
	WagonInCode 	: String = "W_58006";
	WagonInCode2	: String = "W_58006-2";
	WagonClassCode 	: String = "PKUT";
	RailAreaId 		: String = "KC58006";
vars
	storageConfig 			: CM_StorageConfig;
	terminal				: CM_Terminal;
	bs						: CM_BlockStack;
	voy 					: CM_Voyage;
	pxyTi,
	ti,
	ti2 					: CM_TrackedItem;
	aPort 					: CM_Port;
	vvr 					: CM_VehicleVisitRecord;
	dualGate				: CM_Gate;
	pin						: CM_GateArea;
	pout					: CM_GateArea;
	operator				: CM_Operator;
	job 					: CM_Job;
	wle 					: CM_WorkListEntry;
	vehicle					: CM_Vehicle;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	transaction 			: CM_TITransaction;
	evtTran					: CM_EventTransaction;
	storageDetails 			: CM_StorageDetail;
	wagonMaster				: CM_WagonMaster;
	cargoType 				: CM_CargoType;
	train					: CM_Train;
	railArea				: CM_Rail;
	wagon,
	wagon2					: CM_Wagon;
	wagonCont				: CM_WagonController;
	railLine				: CM_RailLine;
	attach					: CMIF_InOutAttachment;
	attachments				: CMIF_InOutAttachmentArray;
	tisToUnpack 			: CM_TIArray;
	
	storedString,
	storedString2, tiId,
	childTiId				: String;
	correctDays 			: Boolean;
	today,
	backdate				: Date;
	dateTime				: TimeStamp;
	
	storageDtlCriteria		: IntegerArray;
	storageDtlCriteriaValue	: ObjectArray;
	tisString				: StringArray;
	
begin
	
	// Delete any existing Storage Config, and create a default one
	self.deleteStorageConfig(true);
	// Get terminal
	terminal := self.getMyTerminal();
	// Get storage Config
	storageConfig := terminal.myStorageConfig;
	// Set storage config include last day to false;
	beginTransaction;
		storageConfig.setPropertyValue("includeLastDay", false);
	commitTransaction;
	
	// Delete area
	bs:= self.getTerminalArea(TAREA).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	
	// Create a fresh area
	bs:= addBlockStack(TAREA, 100, null);
	// Set Port
	aPort := app.myRoot.allPorts["NZAKL"];
	// Create voyage
	voy :=self.createVesselVoyage3();
	
	// Create storage details
	create storageDtlCriteria transient;
	create storageDtlCriteriaValue transient;
	create tisString transient;
	
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCriteriaValue.add(self.getCargoType("CONT"));
	
	storageDetails := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCriteriaValue, 2, 0, false, false, 0, 0, false, null);
	self.assertNotNull(storageDetails);

	/*
	====
	ROAD
	====
	*/
	
	tisString.add("UTKIAT");	// For Road
	tisString.add("UTKIAT2");	// For Road
	
	// Delete existing TI
	foreach tiId in tisString do
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(ti, true);
		endif;
	endforeach;
	
	// Prepare data for Gate in TI
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	
	foreach tiId in tisString do
		// Gate in TI
		vvr := self.gateInContainer(TRUCK, tiId, "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem(tiId);
		vehicle := getVehicle(TRUCK);
		// Process vehicle
		self.moveVehicleToLane(vvr.vehicle, pin, 1);
		self.moveVehicleToYard(vvr.vehicle);
		self.workVehicle(vvr);
		
		// Simulate web to perform truck complete, and to create Truck Cargo Receive event transaction
		job := vvr.getMyJob();
		wle := job.workListEntries.getFirstUnactionedWLE();
		
		create truckUnLoaderController transient;
		truckUnLoaderController.setMyTerminal( terminal );
		truckUnLoaderController.setTruck( vehicle);
		truckUnLoaderController.setMyWle( wle);
		truckUnLoaderController.doTruckComplete(true, false, false);
		
		// Get out
		self.roadExit(vvr);
		
		beginTransaction;
		// Now we backdate the receival transaction to 10 days ago
		backdate := today - 10;	
		foreach transaction in ti.allTransactions do
			dateTime := transaction.dateTime;
			dateTime.setDate(backdate);
			transaction.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.setPropertyValue("receivedDT", dateTime);
		// Backdate the unload event transaction to 5 days ago
		backdate := today - 5;
		foreach evtTran in ti.allTruckEvents do
			dateTime := evtTran.dateTime;
			dateTime.setDate(backdate);
			evtTran.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//28.05.2024 navma1 #64224
		commitTransaction;
		delete truckUnLoaderController;
	endforeach;
	
	// Gate out UTKIAT
	ti := self.getTrackedItem("UTKIAT");
	self.assertNotNull(ti);
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #1 - Truck Receival based on - Actual RECEIVE
	==================================================
	Free storage 2 days
	Cargo gated in 10 days ago, unloaded from truck 5 days ago.
	Storage days should be 8 days
	*/
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 8 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 8 days, not " &amp; storedString);
	
	// Now we change the Storage Details Truck Receival to Actual UNLOAD
	beginTransaction;
	storageDetails.setPropertyValue("roadReceivalType", Storage_RoadActualUnload);
	commitTransaction;
	
	// Gate out UTKIAT2
	ti := self.getTrackedItem("UTKIAT2");
	self.assertNotNull(ti);
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	ti.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252			//22.05.2024 navma1 #64224
	commitTransaction;
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/* 
	=================================================
	Test #2 - Truck Receival based on - Actual UNLOAD
	=================================================
	Free storage 2 days
	Cargo gated in 10 days ago, unloaded from truck 5 days ago.
	Storage days should be 3 days
	*/
	
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 3 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 3 days, not " &amp; storedString);
	
	/*
	====
	SHIP
	====
	*/
	
	// Backdate the ship arrival
	backdate := today - 10;
	dateTime.setDate(backdate);
	beginTransaction;
		voy.setPropertyValue("arrivedDT", dateTime);
	commitTransaction;
	
	tisString.clear();
	tisString.add("UTKIAT3");
	tisString.add("UTKIAT4");
	// Delete existing TI
	foreach tiId in tisString do
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(ti, true);
		endif;
	endforeach;
	
	// Create Container On Ship and Move them to yard
	// Back date cargo date to 5 days ago 
	backdate := today - 5;
	
	foreach tiId in tisString do
		beginTransaction;
		if tiId = "UTKIAT3" then
			storageDetails.setPropertyValue("shipReceivalType", Voyage_Actual_Discharge);
		elseif tiId = "UTKIAT4" then
			storageDetails.setPropertyValue("shipReceivalType", Voyage_Arrival);
		endif;
		commitTransaction;
		ti := self.addContainerOnShip(tiId, operator, "2200", "GENL", null, voy, aPort.code, voy.code);
		self.move(ti, bs);
		beginTransaction;
		foreach transaction in ti.allTransactions do
			dateTime := transaction.dateTime;
			dateTime.setDate(backdate);
			transaction.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.setPropertyValue("receivedDT", dateTime);
		ti.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
		commitTransaction;
	endforeach;
	
	
	// Release UTKIAT3
	ti := self.getTrackedItem("UTKIAT3");
	self.deleteStops(ti);
	self.assertNotNull(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #3 - Ship Receival based on - Actual DISCHARGE
	==================================================
	Free storage 2 days
	Ship arrived 10 days ago, unloaded from ship 5 days ago.
	Storage days should be 3 days
	*/
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 3 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 3 days, not " &amp; storedString);
	
	// Now we change the Storage Details SHIP Receival to Actual ARRIVE
	beginTransaction;
	storageDetails.setPropertyValue("shipReceivalType", Voyage_Arrival);
	commitTransaction;
	
	// Release UTKIAT4
	ti := self.getTrackedItem("UTKIAT4");
	self.deleteStops(ti);
	self.assertNotNull(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #4 - Ship Receival based on - Actual ARRIVE
	==================================================
	Free storage 2 days
	Ship arrived 10 days ago, unloaded from ship 5 days ago.		
	*/
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 10 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 10 days, not " &amp; storedString);
	
	/*
	====
	RAIL
	====
	*/
	cargoType := self.getCargoType("CONT");
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
	
	tisString.clear();
	tisString.add("UTKIAT5");
	tisString.add("UTKIAT6");
	// Delete existing TI
	foreach tiId in tisString do
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(ti, true);
		endif;
	endforeach;
	
	train := self.addTrain(TrainInCode,null);
	railArea := self.addRailArea(RailAreaId, 2, 5);
	wagon := self.addWagonInRailArea(WagonInCode, WagonClassCode, railArea, train);
	wagon2 := self.addWagonInRailArea(WagonInCode2, WagonClassCode, railArea, train);
	
	// Create Container UTKIAT5
	pxyTi := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTi.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, "UTKIAT5", null, operator);
	pxyTi.zSetPxyImexStatus( TI_IMEX_STATUS_STORAGE );
	pxyTi.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	pxyTi.setWagon( wagon.id, wagon, wagon.myWagonClass, false );
	app.myTrxCA.trxCreateTrackedItem( pxyTi, ti, app.myPassport );
	
	// Create Container UTKIAT6
	pxyTi := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTi.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, "UTKIAT6", null, operator);
	pxyTi.zSetPxyImexStatus( TI_IMEX_STATUS_STORAGE );
	pxyTi.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	pxyTi.setWagon( wagon2.id, wagon2, wagon2.myWagonClass, false );
	app.myTrxCA.trxCreateTrackedItem( pxyTi, ti2, app.myPassport );
	
	// Move UTKIAT5 to Wagon
	wagonCont := wagon.allLocationsControllersArray[1];
	self.moveTiToWagon(ti, wagonCont);
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon1 set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Move UTKIAT6 to Wagon 2
	wagonCont := wagon2.allLocationsControllersArray[1];
	self.moveTiToWagon(ti2, wagonCont);
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon2, 02);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon2 set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Confirm train in
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Move TIs to Terminal
	self.move(ti, bs);
	self.move(ti2, bs);
	
	foreach tiId in tisString do
		beginTransaction;
		if tiId = "UTKIAT5" then
			storageDetails.setPropertyValue("railReceivalType", Storage_RailActualReceival);
		elseif tiId = "UTKIAT6" then
			storageDetails.setPropertyValue("railReceivalType", Storage_RailActualUnload);
		endif;
		commitTransaction;
		ti := self.getTrackedItem(tiId);
		// Backdate Tis arrival date - 10 days ago
		backdate := today - 10;
		beginTransaction;
		foreach transaction in ti.allTransactions do
			dateTime := transaction.dateTime;
			dateTime.setDate(backdate);
			transaction.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.setPropertyValue("receivedDT", dateTime);
		// back date Tis unload date - 5 days ago
		backdate := today - 5;
		foreach evtTran in ti.allWagonEvents do
			dateTime := evtTran.dateTime;
			dateTime.setDate(backdate);
			evtTran.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//22.05.2024 navma1 #64224
		commitTransaction;
	endforeach;
	
	// Release UTKIAT5
	ti := self.getTrackedItem("UTKIAT5");
	self.assertNotNull(ti);
	self.unqueueTI(ti);
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #5 - Rail Receival based on - Actual ARRIVE
	==================================================
	Free storage 2 days
	Rail arrived 10 days ago, unloaded from rail 5 days ago.
	Storage days should be 8 days
	*/
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 8 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 8 days, not " &amp; storedString);
	
	// Release UTKIAT6
	ti := self.getTrackedItem("UTKIAT6");
	self.assertNotNull(ti);
	self.unqueueTI(ti);
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #6 - Ship Receival based on - Actual UNLOAD
	==================================================
	Free storage 2 days
	Rail arrived 10 days ago, unloaded from rail 5 days ago.
	Storage days should be 3 days
	*/
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 3 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti.id &amp; " has wrong storage days. It should be 3 days, not " &amp; storedString);
	
	/*
	======
	UNPACK
	======
	*/
	tisString.clear();
	tisString.add("UTKIAT7");
	tisString.add("UTKIAT8");
	tisString.add("UTKIAT7C");
	tisString.add("UTKIAT8C");
	// Delete existing TI
	foreach tiId in tisString do
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(ti, true);
		endif;
	endforeach;
	
	// These are child item, we'll create them separetely
	tisString.remove("UTKIAT7C");
	tisString.remove("UTKIAT8C");

	// Create storage details for child item before we forget
	cargoType := self.getCargoType("UT_WIDGET");
	storageDtlCriteria.clear();
	storageDtlCriteriaValue.clear();
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCriteriaValue.add(cargoType);
	storageDetails := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCriteriaValue, 2, 0, false, false, 0, 0, false, null);
	self.assertNotNull(storageDetails);
		
	create attachments transient;
	
	foreach tiId in tisString do
		// Gate in TI
		vvr := self.gateInContainer(TRUCK, tiId, "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem(tiId);
		
		create attach transient;
		attachments.clear();
		childTiId := tiId &amp; "C";
		// Now we attach child item to container
		attach.set(terminal, cargoType.id, childTiId, "", 100);
		attach.operatorCode := ti.operatorCode;
		attach.imExStatus := ti.getImExStatus();
		attachments.add(attach);
		self.addContainerChildren(ti, attachments);
		
		// Process vehicle
		self.moveVehicleToLane(vvr.vehicle, pin, 1);
		self.moveVehicleToYard(vvr.vehicle);
		self.workVehicle(vvr);
		self.roadExit(vvr);
		
		// Now we backdate the parent container receival transaction to 10 days ago
		backdate := today - 10;	
		beginTransaction;
		foreach transaction in ti.allTransactions do
			dateTime := transaction.dateTime;
			dateTime.setDate(backdate);
			transaction.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti.setPropertyValue("receivedDT", dateTime);
		ti.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//22.05.2024 navma1 #64224
		commitTransaction;
		// Now we backdate the children receival transaction to 10 days ago
		ti2 := ti.allChildren.first();
		self.assertNotNull(ti2);
		beginTransaction;
		foreach transaction in ti2.allTransactions do
			dateTime := transaction.dateTime;
			dateTime.setDate(backdate);
			transaction.setPropertyValue("dateTime", dateTime);
		endforeach;
		ti2.setPropertyValue("receivedDT", dateTime);
		ti2.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
		commitTransaction;
		delete attach;
	endforeach;
	
	create tisToUnpack transient;
	// Now we unpack
	ti := self.getTrackedItem("UTKIAT7");
	self.assertNotNull(ti);
	ti2 := self.getTrackedItem("UTKIAT7C");
	self.assertNotNull(ti2);
	tisToUnpack.add(ti2);
	self.unpackContainer(ti, tisToUnpack);
	transaction := ti2.getLastTransOfType(TRANS_TYPE_UNPACK);
	self.assertNotNull(transaction);
	
	
	// Now we backdate the Unpack transaction to 5 days ago
	backdate := today - 5;
	dateTime := transaction.dateTime;
	dateTime.setDate(backdate);
	beginTransaction;
		storageDetails.setPropertyValue("unpackReceivalType", Storage_UnpackActualUnpack);
		transaction.setPropertyValue("dateTime", dateTime);
		ti.evaluateFreeStorageDays(null,true);		//22.05.2024 navma1 #64224
		ti2.evaluateFreeStorageDays(null,true);		//22.05.2024 navma1 #64224
	commitTransaction;
	// Now gate out the parent
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	// Now gate out the child
	self.deleteStops(ti2);
	vvr := self.gateOutGC(TRUCK, "", "UTDRIVER", ti2, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);

	/*
	==================================================
	Test #7 - Child Receive based on - Actual UNPACK
	==================================================
	Free storage 2 days
	Child arrived 10 days ago, unpacked 5 days ago.
	Storage days should be 3 days
	*/
	transaction := ti2.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	correctDays := storedString.pos("Stored for 3 days", 1) &lt;&gt; 0;
	self.assertTrueMsg(correctDays = true, ti2.id &amp; " has wrong storage days. It should be 3 days, not " &amp; storedString);
	
	tisToUnpack.clear();
	// Now we unpack
	ti := self.getTrackedItem("UTKIAT8");
	self.assertNotNull(ti);
	ti2 := self.getTrackedItem("UTKIAT8C");
	self.assertNotNull(ti2);
	tisToUnpack.add(ti2);
	self.unpackContainer(ti, tisToUnpack);
	transaction := ti2.getLastTransOfType(TRANS_TYPE_UNPACK);
	self.assertNotNull(transaction);
	
	// Now we backdate the Unpack transaction to 5 days ago
	backdate := today - 5;
	dateTime := transaction.dateTime;
	dateTime.setDate(backdate);
	beginTransaction;
		storageDetails.setPropertyValue("unpackReceivalType", Storage_UnpackSameAsParent);
		transaction.setPropertyValue("dateTime", dateTime);
		ti.evaluateFreeStorageDays(null,true);		//22.05.2024 navma1 #64224
		ti2.evaluateFreeStorageDays(null,true);		//22.05.2024 navma1 #64224
	commitTransaction;
	// Now gate out the parent
	self.deleteStops(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	// Now gate out the child
	self.deleteStops(ti2);
	vvr := self.gateOutGC(TRUCK, "", "UTDRIVER", ti2, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	/*
	==================================================
	Test #8 - Child Receive based on - Same as parent
	==================================================
	Child storage days should be the same as Parent
	*/
	// Get the storage days of parent
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString := transaction.getDisplayStringForAttribute("details", false);
	// Get  the storage days of child
	transaction := ti2.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	storedString2 := transaction.getDisplayStringForAttribute("details", false);
	// Both should be the same
	self.assertTrueMsg(storedString = storedString2, "Parent and Child storage days are incorrect. Parent : " &amp; storedString &amp; ". Child : " &amp; storedString2);
	
epilog


	delete storageDtlCriteria;
	delete storageDtlCriteriaValue;
	delete truckUnLoaderController;
	delete tisString;
	delete attach;
	delete attachments;
	delete tisToUnpack;
	// Clean up data
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode2 ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
end;</source>
    </JadeMethod>
    <JadeMethod name="tSSL52292" id="5c25023a-6184-4c35-a8ec-c4c63a252324">
        <source>tSSL52292();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2022	jlier1	Initial creation

*/

constants
	VesselName1 : String = "UT7032";
	VoyageName : String = "UT7032";
	BaseCargoId : String = "UT52292";
vars

	storageConfig	: CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;

	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	weekCalendar : CM_Calendar;
	compCalendar : CM_Calendar;
	
	date : Date;
	firstSaturday : Date;
	firstSunday : Date;
	index : Integer;
	mondayDischarge : Date;
	tuesdayHol : Date;
	gateOutFriday : Date;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	oper : CM_Operator;
	bs : CM_BlockStack;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	
	moveController : CMIF_MoveController;
	ts : TimeStamp;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	storageTrx : CM_Storage;
	roadRel : CM_ReleaseRoad;
	invLine : CM_InvoiceLine;
	expectedCharge : Decimal[16,4];
	charge : Decimal[16,4];
	term : CM_Terminal;
	stopTableTemplate : CM_StopTableTemplate;
	setStopsOn : IntegerArray;
	preventActions : IntegerArray;
	processActions : IntegerArray;
	allCargoTypes : IntegerArray;
	
begin
	self.deleteVehicle("UTFST");

	//Create the calendars and Storage configuration
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTWE", "UTWE");
	self.deleteCalendar("UTCO", "UTCO");
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	
	self.setTerminalConfig( StorageConfigType, CM_StorageConfigTypeSSL.firstInstance );
	
	firstSaturday := "16 Sep 2017".Date;
	firstSunday := "17 Sep 2017".Date;
	mondayDischarge := "18 Sep 2017".Date;
	tuesdayHol := mondayDischarge + 1 + 119;  // 17 weeks after discharge, should cripple this one.
	gateOutFriday := "13 Oct 2017".Date;
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	weekCalendar := self.createCalendar("UTWE", "UT w/e 7032", false, false, "UTWE");
	self.addBulkCalendarDates(weekCalendar, firstSaturday, 52, "Saturday");
	self.addBulkCalendarDates(weekCalendar, firstSunday, 52, "Sunday");
	
	compCalendar := self.createCalendar("UTCO", "UT compulsory 7032", false, false, "UTCO");
	self.addBulkCalendarDates(compCalendar, tuesdayHol, 2, "Tuesday Hol");

	create allCargoTypes transient;
	allCargoTypes.add(TI_CargoType_Container); //add containers will add an extra days free storage 
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, weekCalendar, compCalendar,allCargoTypes, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								5,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");
	
	//Create a Vessel, Voyage and cargo on board.

	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(VoyageName);
	deleteVessel(VesselName1);
	
	
	
	
	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	cargo := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 01  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "02", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "04", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "06", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	
	//discharge one piece per day for 7 days. Starting mondayDischarge date.
	
	deleteTerminalArea("UTBSL");
	bs := addBlockStack("UTBSL", 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, "No Blockstack created");
	
	create moveController transient;
	date := mondayDischarge;
	foreach index in 1 to 7 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	// Gate in a truck
	// Load up all of the cargo and Gate out.
	
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		invLine := storageTrx.allInvoiceLines.first;
		self.assertTrueMsg( not storageTrx.allInvoiceLines.isEmpty, "No Invoice Line found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 1800.00;
		elseif index = 2 then
			expectedCharge := 1700.00;
		elseif index = 3 then
			expectedCharge := 1600.00;
		elseif index = 4 then
			expectedCharge := 1500.00;
		elseif index = 5 then
			expectedCharge := 1400.00;
		elseif index = 6 then
			expectedCharge := 1100.00;
		elseif index = 7 then
			expectedCharge := 1100.00;
		else
			expectedCharge := 0.00;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Round 1, Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String);
	endforeach; 

epilog
	self.enableCashOnlyTerminal( term, false ); 

	self.setTerminalConfig( StorageConfigType, null );

	cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "20", null);
	if cargo &lt;&gt; null then
		self.deleteTrackedItem(cargo,false);
	endif;

	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;

	if truck &lt;&gt; null then
		self.deleteVehicle(truck);
	endif;
	self.resetDefaultTranMap();	
	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;
	delete moveController;
	delete setStopsOn;
	delete preventActions;
	delete processActions;
	delete allCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSSLCCMS7032" id="546e82b9-81f6-4f23-bd0b-638ef871eaf1">
        <source>tSSLCCMS7032();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2017	jlgndl1	Initial creation	TFS 7032 / 5623  NON SSL Version

*/

constants
	VesselName1 : String = "UT7032";
	VoyageName : String = "UT7032";
	BaseCargoId : String = "UTSSL7032";
vars

	storageConfig	: CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;

	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	weekCalendar : CM_Calendar;
	compCalendar : CM_Calendar;
	
	testStartDate : Date;
	date : Date;
	firstSaturday : Date;
	firstSunday : Date;
	index : Integer;
	mondayDischarge : Date;
	tuesdayHol : Date;
	gateOutFriday : Date;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	oper : CM_Operator;
	bs : CM_BlockStack;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	
	moveController : CMIF_MoveController;
	ts : TimeStamp;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	storageTrx : CM_Storage;
	roadRel : CM_ReleaseRoad;
	invLine : CM_InvoiceLine;
	expectedCharge : Decimal[16,4];
	charge : Decimal[16,4];
	stopTable : CM_StopsTable;
	term : CM_Terminal;
	stopTableTemplate : CM_StopTableTemplate;
	setStopsOn : IntegerArray;
	preventActions : IntegerArray;
	processActions : IntegerArray;

begin
	self.deleteVehicle("UTFST");

	self.setTerminalConfig( StorageConfigType, null ); // Should already be this way, but just in case.

	//Create the calendars and Storage configuration
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTWE", "UTWE");
	self.deleteCalendar("UTCO", "UTCO");
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	
	testStartDate := ( app.actualTimeAppServer.Date - 63 ); // A couple of months ago.
	date := testStartDate;
	while index &lt; 7 do
		if date.dayOfWeek = 6 then
			firstSaturday := date;
		elseif date.dayOfWeek = 7 then
			firstSunday := date;
			mondayDischarge := date + 29;
			tuesdayHol := mondayDischarge + 8;
		endif;
		index := index + 1;
		date := date + 1;
	endwhile;
	
	gateOutFriday := mondayDischarge + 18;
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	weekCalendar := self.createCalendar("UTWE", "UT w/e 7032", false, false, "UTWE");
	self.addBulkCalendarDates(weekCalendar, firstSaturday, 52, "Saturday");
	self.addBulkCalendarDates(weekCalendar, firstSunday, 52, "Sunday");
	
	compCalendar := self.createCalendar("UTCO", "UT compulsory 7032", false, false, "UTCO");
	self.addBulkCalendarDates(compCalendar, tuesdayHol, 2, "Tuesday Hol");

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, weekCalendar, compCalendar,null, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								5,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");
	
	//Create a Vessel, Voyage and cargo on board.
	
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(VoyageName);
	deleteVessel(VesselName1);
	
	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	cargo := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 01  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "02", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "04", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "06", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	
	//discharge one piece per day for 7 days. Starting mondayDischarge date.
	
	deleteTerminalArea("UTBSL");
	bs := addBlockStack("UTBSL", 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, "No Blockstack created");
	
	create moveController transient;
	date := mondayDischarge;
	foreach index in 1 to 7 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.setWeight(0); //epr TFS 8220 6/12/17
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	// Gate in a truck
	// Load up all of the cargo and Gate out.
	
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		invLine := storageTrx.allInvoiceLines.first;
		self.assertTrueMsg( not storageTrx.allInvoiceLines.isEmpty, "No Invoice Line found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 900.00;
		elseif index = 2 then
			expectedCharge := 800.00;
		elseif index = 3 then
			expectedCharge := 700.00;
		elseif index = 4 then
			expectedCharge := 600.00;
		elseif index = 5 then
			expectedCharge := 500.00;
		elseif index = 6 then
			expectedCharge := 500.00;
		elseif index = 7 then
			expectedCharge := 500.00;
		else
			expectedCharge := 0.00;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String);
	endforeach; 
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 2 );  //the escalating version 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 900.00;
		elseif index = 2 then
			expectedCharge := 750.00;
		elseif index = 3 then
			expectedCharge := 600.00;
		elseif index = 4 then
			expectedCharge := 450.00;
		elseif index = 5 then
			expectedCharge := 350.00;
		elseif index = 6 then
			expectedCharge := 350.00;
		elseif index = 7 then
			expectedCharge := 350.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Adjust freestorage days to 1 and run again with simple fixed rate of $100 / day.
	delete pxyStorageDetail;
	beginLoad;
	pxyStorageDetail := storageDetail.pxyCreateUpdateProxy();
	endLoad;
	
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								1,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxUA.trxUpdateStorageDetail( pxyStorageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail.freeStorageDays = 1, "Storage detail freeStorageDays not updated to 1");
	
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "11", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 11  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "12", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "13", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "14", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "15", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "16", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "17", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	date := mondayDischarge;
	foreach index in 11 to 17 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle(truck);
	self.opts.addAssoc("deliveryNumber", "998");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
		
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		//force an update to cause reassessment of freestorage days.
		self.updateTI(cargo);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 11 then
			expectedCharge := 1300.00;
		elseif index = 12 then
			expectedCharge := 1200.00;
		elseif index = 13 then
			expectedCharge := 1100.00;
		elseif index = 14 then
			expectedCharge := 1000.00;
		elseif index = 15 then
			expectedCharge := 900.00;
		elseif index = 16 then
			expectedCharge := 900.00;
		elseif index = 17 then
			expectedCharge := 900.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Next peice is for TFS 7185.
	//Create a Stop to Stop/Start Storage
	//Add a piece of Cargo and add the stop to it. 
	//Clear the stop and check that the 'Stop Completion Free Storage Days' are correctly added.
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "20", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 20  created");
	
	date := app.actualTimeAppServer.Date - 3;
	ts.setDate( date );
		
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
	moveController.setMyToPrimaryLocation(bs.myLocationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.transferType := VESSEL_TYPE_RORO;
	moveController.isNonCraneVoyageMove := true;
	moveController.setEffectiveTimeStampOverride( ts );
	moveController.quantity := 1;
	moveController.weight := 0;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.deleteStops(cargo);
	
	//Set up stop start storage stop
	stopTable := app.myRoot.allStopsTable[988];  //Storage Stop
	
	self.assertTrueMsg(stopTable &lt;&gt; null, "Failed to find stop '988' - setup");
	stopTableTemplate	:= stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsChildIgnore, false );
	self.opts.addAssoc( ETRow_IsChildOnly, false );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, false );
	self.opts.addAssoc( ETRow_IsCoastalOnly, false );
	self.opts.addAssoc( ETRow_IsFull, false );
	self.opts.addAssoc( ETRow_IsMT, false );
	
	create setStopsOn transient;	
	create preventActions transient;
	preventActions.add(StopPreventStorageCharges);
	create processActions transient;
	
	self.opts.addAssoc( ETRow_CheckStopAreas, preventActions );
	self.opts.addAssoc( ETRow_SetStopAreas, setStopsOn );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processActions );
	
	stopTableTemplate := stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopTable, term);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx = null, "Should NOT have found any storage trxs for '" &amp; cargo.id &amp; "' yet. (pre adding Storage Stop)");
	
	//set the stop, then remove the stop
	self.addStop( cargo, stopTable );
	self.deleteStopForTIById( cargo, stopTable.id );

	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx &lt;&gt; null, "Should have found storage trx for '" &amp; cargo.id &amp; "'. (post adding and removing Storage Stop)");
	self.assertTrueMsg(storageTrx.noCharge, "Latest storage trx for '" &amp; cargo.id &amp; "' should be no charge. (post adding and removing Storage Stop)");

epilog

	cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "20", null);
	if cargo &lt;&gt; null then
		self.deleteTrackedItem(cargo,false);
	endif;

	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;

	if truck &lt;&gt; null then
		self.deleteVehicle(truck);
	endif;
	self.resetDefaultTranMap();	
	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;
	delete moveController;
	delete setStopsOn;
	delete preventActions;
	delete processActions;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSSLCCMS7032A" id="62e6de1c-c4c8-4e88-9094-ca340051e459">
        <source>tSSLCCMS7032A();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2017	jlgndl1	Initial creation	SSL Version
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
*/

constants
	VesselName1 : String = "UT7032";
	VoyageName : String = "UT7032";
	BaseCargoId : String = "UTSSL7032";
vars

	storageConfig	: CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;

	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	weekCalendar : CM_Calendar;
	compCalendar : CM_Calendar;
	
	testStartDate : Date;
	date : Date;
	firstSaturday : Date;
	firstSunday : Date;
	index : Integer;
	mondayDischarge : Date;
	tuesdayHol : Date;
	gateOutFriday : Date;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	oper : CM_Operator;
	bs : CM_BlockStack;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	
	moveController : CMIF_MoveController;
	ts : TimeStamp;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	storageTrx : CM_Storage;
	roadRel : CM_ReleaseRoad;
	invLine : CM_InvoiceLine;
	expectedCharge : Decimal[16,4];
	charge : Decimal[16,4];
	stopTable : CM_StopsTable;
	term : CM_Terminal;
	stopTableTemplate : CM_StopTableTemplate;
	setStopsOn : IntegerArray;
	preventActions : IntegerArray;
	processActions : IntegerArray;
	
	cashInvType : CM_InvoiceDesc;
	allCargoTypes : IntegerArray;
begin
	self.deleteVehicle("UTFST");

	//Create the calendars and Storage configuration
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTWE", "UTWE");
	self.deleteCalendar("UTCO", "UTCO");
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	
	self.setTerminalConfig( StorageConfigType, CM_StorageConfigTypeSSL.firstInstance );
	
	firstSaturday := "16 Sep 2017".Date;
	firstSunday := "17 Sep 2017".Date;
	mondayDischarge := "18 Sep 2017".Date;
	tuesdayHol := mondayDischarge + 1 + 119;  // 17 weeks after discharge, should cripple this one.
	gateOutFriday := "13 Oct 2017".Date;
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	weekCalendar := self.createCalendar("UTWE", "UT w/e 7032", false, false, "UTWE");
	self.addBulkCalendarDates(weekCalendar, firstSaturday, 52, "Saturday");
	self.addBulkCalendarDates(weekCalendar, firstSunday, 52, "Sunday");
	
	compCalendar := self.createCalendar("UTCO", "UT compulsory 7032", false, false, "UTCO");
	self.addBulkCalendarDates(compCalendar, tuesdayHol, 2, "Tuesday Hol");

	create allCargoTypes transient;
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, weekCalendar, compCalendar,allCargoTypes, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								5,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");
	
	//Create a Vessel, Voyage and cargo on board.
	
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(VoyageName);
	deleteVessel(VesselName1);
	
	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	cargo := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 01  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "02", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "04", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "06", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	
	//discharge one piece per day for 7 days. Starting mondayDischarge date.
	
	deleteTerminalArea("UTBSL");
	bs := addBlockStack("UTBSL", 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, "No Blockstack created");
	
	create moveController transient;
	date := mondayDischarge;
	foreach index in 1 to 7 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	// Gate in a truck
	// Load up all of the cargo and Gate out.
	
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
		beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
		cargo.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
		commitTransaction;
	endforeach; 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		invLine := storageTrx.allInvoiceLines.first;
		self.assertTrueMsg( not storageTrx.allInvoiceLines.isEmpty, "No Invoice Line found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 1800.00;
		elseif index = 2 then
			expectedCharge := 1700.00;
		elseif index = 3 then
			expectedCharge := 1600.00;
		elseif index = 4 then
			expectedCharge := 1500.00;
		elseif index = 5 then
			expectedCharge := 1400.00;
		elseif index = 6 then
			expectedCharge := 1200.00;
		elseif index = 7 then
			expectedCharge := 1200.00;
		else
			expectedCharge := 0.00;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Round 1, Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String);
	endforeach; 
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 2 );  //the escalating version 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 2250.00;
		elseif index = 2 then
			expectedCharge := 2100.00;
		elseif index = 3 then
			expectedCharge := 1950.00;
		elseif index = 4 then
			expectedCharge := 1800.00;
		elseif index = 5 then
			expectedCharge := 1650.00;
		elseif index = 6 then
			expectedCharge := 1350.00;
		elseif index = 7 then
			expectedCharge := 1350.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Round 2, Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Adjust freestorage days to 1 and run again with simple fixed rate of $100 / day.
	delete pxyStorageDetail;
	beginLoad;
	pxyStorageDetail := storageDetail.pxyCreateUpdateProxy();
	endLoad;
	
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								1,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxUA.trxUpdateStorageDetail( pxyStorageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail.freeStorageDays = 1, "Storage detail freeStorageDays not updated to 1");
	
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "11", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 11  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "12", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "13", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "14", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "15", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "16", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "17", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	date := mondayDischarge;
	foreach index in 11 to 17 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle(truck);
	self.opts.addAssoc("deliveryNumber", "998");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
		
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		//force an update to cause reassessment of freestorage days.
		self.updateTI(cargo);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 11 then
			expectedCharge := 2200.00;
		elseif index = 12 then
			expectedCharge := 2100.00;
		elseif index = 13 then
			expectedCharge := 2000.00;
		elseif index = 14 then
			expectedCharge := 1900.00;
		elseif index = 15 then
			expectedCharge := 1800.00;
		elseif index = 16 then
			expectedCharge := 1600.00;
		elseif index = 17 then
			expectedCharge := 1600.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Round 3, Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Next peice is for TFS 7185.
	//Create a Stop to Stop/Start Storage
	//Add a piece of Cargo and add the stop to it. 
	//Clear the stop and check that the 'Stop Completion Free Storage Days' are correctly added.
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "20", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 20  created");
	
	date := app.actualTimeAppServer.Date - 3;
	ts.setDate( date );
		
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
	moveController.setMyToPrimaryLocation(bs.myLocationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.transferType := VESSEL_TYPE_RORO;
	moveController.isNonCraneVoyageMove := true;
	moveController.setEffectiveTimeStampOverride( ts );
	moveController.quantity := 1;
	moveController.weight := 0;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.deleteStops(cargo);
	
	//Set up stop start storage stop
	stopTable := app.myRoot.allStopsTable[988];  //Storage Stop
	
	self.assertTrueMsg(stopTable &lt;&gt; null, "Failed to find stop '988' - setup");
	stopTableTemplate	:= stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsChildIgnore, false );
	self.opts.addAssoc( ETRow_IsChildOnly, false );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, false );
	self.opts.addAssoc( ETRow_IsCoastalOnly, false );
	self.opts.addAssoc( ETRow_IsFull, false );
	self.opts.addAssoc( ETRow_IsMT, false );
	
	create setStopsOn transient;	
	create preventActions transient;
	preventActions.add(StopPreventStorageCharges);
	create processActions transient;
	
	self.opts.addAssoc( ETRow_CheckStopAreas, preventActions );
	self.opts.addAssoc( ETRow_SetStopAreas, setStopsOn );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processActions );
	
	stopTableTemplate := stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopTable, term);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx = null, "Should NOT have found any storage trxs for '" &amp; cargo.id &amp; "' yet. (pre adding Storage Stop)");
	
	//set the stop, then remove the stop
	self.addStop( cargo, stopTable );
	self.deleteStopForTIById( cargo, stopTable.id );

	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx &lt;&gt; null, "Should have found storage trx for '" &amp; cargo.id &amp; "'. (post adding and removing Storage Stop)");
	self.assertTrueMsg(storageTrx.noCharge, "Latest storage trx for '" &amp; cargo.id &amp; "' should be no charge. (post adding and removing Storage Stop)");

epilog

	self.enableCashOnlyTerminal( term, false ); 

	self.setTerminalConfig( StorageConfigType, null );

	cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "20", null);
	if cargo &lt;&gt; null then
		self.deleteTrackedItem(cargo,false);
	endif;

	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;

	if truck &lt;&gt; null then
		self.deleteVehicle(truck);
	endif;
	self.resetDefaultTranMap();	
	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;
	delete moveController;
	delete setStopsOn;
	delete preventActions;
	delete processActions;
	delete allCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSSLCCMS7032Deferred" id="d1eaa444-877f-4ae4-89d8-104b7cb6ec71">
        <source>tSSLCCMS7032Deferred();
/*

Purpose:			

Parameters:			Variant of "tSSLCCMS7032" using deferred charging.

Return Value:		

Date		Who		Reason
09 July 2021	navndl1	Initial creation	TFS 51443

*/

constants
	VesselName1 : String = "UT7032";
	VoyageName : String = "UT7032";
	BaseCargoId : String = "UTSSL7032";
vars

	storageConfig	: CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;

	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	weekCalendar : CM_Calendar;
	compCalendar : CM_Calendar;
	
	testStartDate : Date;
	date : Date;
	firstSaturday : Date;
	firstSunday : Date;
	index : Integer;
	mondayDischarge : Date;
	tuesdayHol : Date;
	gateOutFriday : Date;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	oper : CM_Operator;
	bs : CM_BlockStack;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	
	moveController : CMIF_MoveController;
	ts : TimeStamp;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	storageTrx : CM_Storage;
	roadRel : CM_ReleaseRoad;
	invLine : CM_InvoiceLine;
	expectedCharge : Decimal[16,4];
	charge : Decimal[16,4];
	stopTable : CM_StopsTable;
	term : CM_Terminal;
	stopTableTemplate : CM_StopTableTemplate;
	setStopsOn : IntegerArray;
	preventActions : IntegerArray;
	processActions : IntegerArray;
	
	bgpCont : BGP_DeferredChargingController;
	initiated : Boolean;

begin
	self.deleteVehicle("UTFST");

	self.setTerminalConfig( StorageConfigType, null ); // Should already be this way, but just in case.
	
	self.setTerminalConfig( DeferredCharging, true );

	bgpCont := BGP_DeferredChargingController.firstInstance;
	if bgpCont = null then
		self.assertTrueMsg( bgpCont &lt;&gt; null, "No BGP_DeferredChargingController found!" );
	endif;
	
	if not bgpCont.isRunning() then
		app.startApplicationWithParameter(bgpCont.schemaName, bgpCont.appName, bgpCont);
		initiated := true;
	endif;

	//Create the calendars and Storage configuration
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTWE", "UTWE");
	self.deleteCalendar("UTCO", "UTCO");
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	
	testStartDate := ( app.actualTimeAppServer.Date - 63 ); // A couple of months ago.
	date := testStartDate;
	while index &lt; 7 do
		if date.dayOfWeek = 6 then
			firstSaturday := date;
		elseif date.dayOfWeek = 7 then
			firstSunday := date;
			mondayDischarge := date + 29;
			tuesdayHol := mondayDischarge + 8;
		endif;
		index := index + 1;
		date := date + 1;
	endwhile;
	
	gateOutFriday := mondayDischarge + 18;
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	weekCalendar := self.createCalendar("UTWE", "UT w/e 7032", false, false, "UTWE");
	self.addBulkCalendarDates(weekCalendar, firstSaturday, 52, "Saturday");
	self.addBulkCalendarDates(weekCalendar, firstSunday, 52, "Sunday");
	
	compCalendar := self.createCalendar("UTCO", "UT compulsory 7032", false, false, "UTCO");
	self.addBulkCalendarDates(compCalendar, tuesdayHol, 2, "Tuesday Hol");

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, weekCalendar, compCalendar,null, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								5,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");
	
	//Create a Vessel, Voyage and cargo on board.
	
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(VoyageName);
	deleteVessel(VesselName1);
	
	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	cargo := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 01  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "02", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "04", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "06", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	
	//discharge one piece per day for 7 days. Starting mondayDischarge date.
	
	deleteTerminalArea("UTBSL");
	bs := addBlockStack("UTBSL", 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, "No Blockstack created");
	
	create moveController transient;
	date := mondayDischarge;
	foreach index in 1 to 7 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.setWeight(0); //epr TFS 8220 6/12/17
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	// Gate in a truck
	// Load up all of the cargo and Gate out.
	
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	foreach index in 1 to 7 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	process.sleep(1000); // to make sure the bgp deferrred processing has a chance to finish.
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		invLine := storageTrx.allInvoiceLines.first;
		self.assertTrueMsg( not storageTrx.allInvoiceLines.isEmpty, "No Invoice Line found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 900.00;
		elseif index = 2 then
			expectedCharge := 800.00;
		elseif index = 3 then
			expectedCharge := 700.00;
		elseif index = 4 then
			expectedCharge := 600.00;
		elseif index = 5 then
			expectedCharge := 500.00;
		elseif index = 6 then
			expectedCharge := 500.00;
		elseif index = 7 then
			expectedCharge := 500.00;
		else
			expectedCharge := 0.00;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String);
	endforeach; 
	
	//Load in our Invoice mapping for storage.
	self.createTFS7032TransMapStuff( 2 );  //the escalating version 
	
	foreach index in 1 to 7 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null, null);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 1 then
			expectedCharge := 900.00;
		elseif index = 2 then
			expectedCharge := 750.00;
		elseif index = 3 then
			expectedCharge := 600.00;
		elseif index = 4 then
			expectedCharge := 450.00;
		elseif index = 5 then
			expectedCharge := 350.00;
		elseif index = 6 then
			expectedCharge := 350.00;
		elseif index = 7 then
			expectedCharge := 350.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Adjust freestorage days to 1 and run again with simple fixed rate of $100 / day.
	delete pxyStorageDetail;
	beginLoad;
	pxyStorageDetail := storageDetail.pxyCreateUpdateProxy();
	endLoad;
	
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								1,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7032",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								includeFirstDay, //_includeFirstDay : Boolean;
								includeLastDay	//_includeLastDay : BOolean
								);
	
	app.myTrxUA.trxUpdateStorageDetail( pxyStorageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail.freeStorageDays = 1, "Storage detail freeStorageDays not updated to 1");
	
	self.createTFS7032TransMapStuff( 1 );  //the simple version 
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "11", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 11  created");
	cargo := self.addContainerOnShip( BaseCargoId &amp; "12", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "13", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "14", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "15", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "16", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "17", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	date := mondayDischarge;
	foreach index in 11 to 17 do
		ts.setDate( date );
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(bs.myLocationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.transferType := VESSEL_TYPE_RORO;
		moveController.isNonCraneVoyageMove := true;
		moveController.setEffectiveTimeStampOverride( ts );
		date := date + 1;
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		self.deleteStops(cargo);
	endforeach;
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle(truck);
	self.opts.addAssoc("deliveryNumber", "998");
	vvr := self.gateOutContainer("UTFST", "", "UTFSTDRIVER", cargo.CM_Container, true, singleGate , null); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(cargo);	//03 Oct 2017	NDL
	
	ts.setDate( gateOutFriday );
	foreach index in 11 to 17 do	
		cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null);
		moveController.setMyTrackedItem(cargo);	
		moveController.setMyOriginatingLocation(bs.myLocationsController);
		moveController.setMyToPrimaryLocation(truck.locationsController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setEffectiveTimeStampOverride( ts );
		moveController.quantity := 1;
		moveController.weight := 0;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endforeach;
	
	self.roadExit(vvr);	
	
	ts := ts.addSeconds(1); // ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1
	
	process.sleep(1000);  //to make sure the bgp has had a chance to process the charges.
	
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		roadRel := cargo.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
		beginTransaction;
		storageTrx.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		roadRel.setPropertyValue( CM_TITransaction::dateTime.name, ts );
		commitTransaction;
		self.reevalStorageTrans(cargo);
	endforeach; 
		
	foreach index in 11 to 17 do
		cargo := voyage.allOffsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; index.String, null, null);
		//force an update to cause reassessment of freestorage days.
		self.updateTI(cargo);
		self.reevalStorageTrans(cargo);
		storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
		self.assertTrueMsg( storageTrx &lt;&gt; null, "No Storage trx found for " &amp; cargo.id &amp; ".");
		charge := 0;
		foreach invLine in storageTrx.allInvoiceLines do
			charge := charge + invLine.lineTotal;
		endforeach;
		if index = 11 then
			expectedCharge := 1300.00;
		elseif index = 12 then
			expectedCharge := 1200.00;
		elseif index = 13 then
			expectedCharge := 1100.00;
		elseif index = 14 then
			expectedCharge := 1000.00;
		elseif index = 15 then
			expectedCharge := 900.00;
		elseif index = 16 then
			expectedCharge := 900.00;
		elseif index = 17 then
			expectedCharge := 900.00; 
		else
			continue;
		endif;
		self.assertTrueMsg( expectedCharge = charge, "Charge incorrect for " &amp; cargo.id &amp; ". Expected " &amp; expectedCharge.String &amp; ", got " &amp; charge.String); 
	endforeach; 
	
	//Next peice is for TFS 7185.
	//Create a Stop to Stop/Start Storage
	//Add a piece of Cargo and add the stop to it. 
	//Clear the stop and check that the 'Stop Completion Free Storage Days' are correctly added.
	
	cargo := self.addContainerOnShip( BaseCargoId &amp; "20", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertTrueMsg( cargo &lt;&gt; null, "No Cargo - 20  created");
	
	date := app.actualTimeAppServer.Date - 3;
	ts.setDate( date );
		
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyOriginatingLocation(cargo.myPrimaryActualLocation);
	moveController.setMyToPrimaryLocation(bs.myLocationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.transferType := VESSEL_TYPE_RORO;
	moveController.isNonCraneVoyageMove := true;
	moveController.setEffectiveTimeStampOverride( ts );
	moveController.quantity := 1;
	moveController.weight := 0;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.deleteStops(cargo);
	
	//Set up stop start storage stop
	stopTable := app.myRoot.allStopsTable[988];  //Storage Stop
	
	self.assertTrueMsg(stopTable &lt;&gt; null, "Failed to find stop '988' - setup");
	stopTableTemplate	:= stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsChildIgnore, false );
	self.opts.addAssoc( ETRow_IsChildOnly, false );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, false );
	self.opts.addAssoc( ETRow_IsCoastalOnly, false );
	self.opts.addAssoc( ETRow_IsFull, false );
	self.opts.addAssoc( ETRow_IsMT, false );
	
	create setStopsOn transient;	
	create preventActions transient;
	preventActions.add(StopPreventStorageCharges);
	create processActions transient;
	
	self.opts.addAssoc( ETRow_CheckStopAreas, preventActions );
	self.opts.addAssoc( ETRow_SetStopAreas, setStopsOn );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processActions );
	
	stopTableTemplate := stopTable.allStopTableTemplates[ term, stopTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopTable, term);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx = null, "Should NOT have found any storage trxs for '" &amp; cargo.id &amp; "' yet. (pre adding Storage Stop)");
	
	//set the stop, then remove the stop
	self.addStop( cargo, stopTable );
	self.deleteStopForTIById( cargo, stopTable.id );

	storageTrx := cargo.getLastTransOfClass( CM_Storage ).CM_Storage;
	self.assertTrueMsg(storageTrx &lt;&gt; null, "Should have found storage trx for '" &amp; cargo.id &amp; "'. (post adding and removing Storage Stop)");
	self.assertTrueMsg(storageTrx.noCharge, "Latest storage trx for '" &amp; cargo.id &amp; "' should be no charge. (post adding and removing Storage Stop)");

epilog

	if initiated then
		bgpCont.terminateProcessing( app.myPassport.getUserCode );
	endif;

	cargo := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "20", null);
	if cargo &lt;&gt; null then
		self.deleteTrackedItem(cargo,false);
	endif;

	if stopTableTemplate &lt;&gt; null then
		beginTransaction;
		delete stopTableTemplate;
		commitTransaction;
	endif;

	if truck &lt;&gt; null then
		self.deleteVehicle(truck);
	endif;
	self.resetDefaultTranMap();	
	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;
	delete moveController;
	delete setStopsOn;
	delete preventActions;
	delete processActions;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSSLCCMS7032_1" id="0e1162f6-c7da-4729-b9e6-97437dc58498">
        <source>tSSLCCMS7032_1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2017	jlgndl1	Initial creation

*/

vars

	fileContent : String;
	realConfig : CM_StorageConfig;
	loadFile : File;
	fileName : String;
	terminal : CM_Terminal;
	calendar : CM_Calendar;
	storageDetail : CM_StorageDetail;

begin

	fileContent := 
	'&lt;storageConfiguration&gt;
&lt;name&gt;StorageConfig&lt;/name&gt;
&lt;firstDayTimeCutoff&gt;00:00:00&lt;/firstDayTimeCutoff&gt;
&lt;includeFirstDay&gt;false&lt;/includeFirstDay&gt;
&lt;includeLastDay&gt;true&lt;/includeLastDay&gt;
&lt;lastDayTimeCutoff&gt;00:00:00&lt;/lastDayTimeCutoff&gt;
&lt;shipReceivalType&gt;0&lt;/shipReceivalType&gt;
&lt;shipReleaseType&gt;0&lt;/shipReleaseType&gt;
&lt;myWorkingDaysCalendar&gt;
&lt;CM_Calendar&gt;
&lt;code&gt;UTWE&lt;/code&gt;
&lt;description&gt;UT w/e 7032&lt;/description&gt;
&lt;/CM_Calendar&gt;
&lt;/myWorkingDaysCalendar&gt;
&lt;myCompulsoryCalendar&gt;
&lt;CM_Calendar&gt;
&lt;code&gt;UTCO&lt;/code&gt;
&lt;description&gt;UT compulsory 7032&lt;/description&gt;
&lt;/CM_Calendar&gt;
&lt;/myCompulsoryCalendar&gt;
&lt;allYACriteriaTypes&gt;
&lt;CM_YACriteriaType&gt;
&lt;description&gt;Cargo Type&lt;/description&gt;
&lt;isUsed&gt;true&lt;/isUsed&gt;
&lt;type&gt;2&lt;/type&gt;
&lt;/CM_YACriteriaType&gt;
&lt;/allYACriteriaTypes&gt;
&lt;allStorageDetails&gt;
&lt;CM_StorageDetail&gt;
&lt;chargeDays&gt;0&lt;/chargeDays&gt;
&lt;chargedDaysType&gt;3&lt;/chargedDaysType&gt;
&lt;chargedDaysWorking&gt;false&lt;/chargedDaysWorking&gt;
&lt;freeDaysType&gt;3&lt;/freeDaysType&gt;
&lt;freeDaysWorking&gt;false&lt;/freeDaysWorking&gt;
&lt;freeStorageDays&gt;5&lt;/freeStorageDays&gt;
&lt;noCharge&gt;false&lt;/noCharge&gt;
&lt;noStorageIfNotFullyReceived&gt;false&lt;/noStorageIfNotFullyReceived&gt;
&lt;receivalDateRule&gt;0&lt;/receivalDateRule&gt;
&lt;stopCompletionFreeDays&gt;0&lt;/stopCompletionFreeDays&gt;
&lt;futureStorageStop&gt;&lt;/futureStorageStop&gt;
&lt;allowMultiRangeSplit&gt;0&lt;/allowMultiRangeSplit&gt;
&lt;allowOthersOption&gt;0&lt;/allowOthersOption&gt;
&lt;code&gt;&lt;/code&gt;
&lt;color&gt;0&lt;/color&gt;
&lt;description&gt;UT TFS 7032&lt;/description&gt;
&lt;expiryDate&gt;&lt;/expiryDate&gt;
&lt;expiryType&gt;1&lt;/expiryType&gt;
&lt;/CM_StorageDetail&gt;
&lt;/allStorageDetails&gt;
&lt;/storageConfiguration&gt;';

	terminal := self.getTerminal();
	self.deleteStorageConfig( false );
	
	realConfig := terminal.myStorageConfig;
	self.assertTrueMsg( realConfig = null, "Failed to delete Storage Config pre test." );
	
	fileName := "C:\Temp\SC_LOAD_7032.xml";
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text;
	loadFile.openOutput(fileName);
	loadFile.writeString(fileContent);
	loadFile.close;
	delete loadFile;
	
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text;
	loadFile.fileName := fileName;
	
	app.myTrxCA.trxImportStorageConfig( loadFile, terminal, realConfig );
	realConfig := terminal.myStorageConfig;
	self.assertTrueMsg( realConfig &lt;&gt; null, "Failed to create Storage Config from file. " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
	calendar := realConfig.myWorkingDaysCalendar;
	self.assertTrueMsg( calendar &lt;&gt; null, "Failed to find working calendar after Storage Config loaded from file" );
	self.assertTrueMsg( calendar.code = "UTWE", "Linked to wrong working calendar after Storage Config loaded from file" );
	
	calendar := realConfig.getMyCompulsoryCalendar;
	self.assertTrueMsg( calendar &lt;&gt; null, "Failed to find compulsory calendar after Storage Config loaded from file" );
	self.assertTrueMsg( calendar.code = "UTCO", "Linked to wrong compulsory calendar after Storage Config loaded from file" );
	
	storageDetail := realConfig.allStorageDetails.first;
	self.assertTrueMsg( storageDetail &lt;&gt; null, "Failed to find Storage Detail in the Storage Config loaded from file" );
	self.assertTrueMsg( storageDetail.freeStorageDays = 5, "Storage Detail should have 5 free storage days" );
	self.assertTrueMsg( storageDetail.freeDaysType = CM_StorageDetail.Working_Compulsory_Days, "Storage Detail should have free day type set to Working and Compulsory Days " );
	self.assertTrueMsg( storageDetail.chargedDaysType = CM_StorageDetail.Working_Compulsory_Days, "Storage Detail should have charge day type set to Working and Compulsory Days " );

epilog

	self.deleteStorageConfig( true );
	delete loadFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStopCompletionFreeDays" id="c740b671-87d7-4552-9f4f-f790527d3e28">
        <source>tStopCompletionFreeDays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2017	jlgndl1	Initial creation	TFS 7185

*/

vars

	firstSaturday : Date;
	firstSunday : Date;
	index : Integer;
	firstMonday : Date;
	tuesdayHol : Date;
	nullTime : Time;
	storageConfig : CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail : CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff : Time;
	lastDayTimeCutoff : Time;
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;
	weekCalendar : CM_Calendar;
	compCalendar : CM_Calendar;
	
	testDate : Date;
	daysFree : Integer;
	expectdDaysFree : Integer;
	testNum : Integer;

begin

	//Create the calendars and Storage configuration
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTWE", "UTWE");
	self.deleteCalendar("UTCO", "UTCO");
	
	firstSaturday := ( "02/09/2017".Date );
	firstSunday := ( "03/09/2017".Date );
	firstMonday := ( "04/09/2017".Date );
	tuesdayHol := ( "05/09/2017".Date );
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	weekCalendar := self.createCalendar("UTWE", "UT w/e 7185", false, false, "UTWE");
	self.addBulkCalendarDates(weekCalendar, firstSaturday, 52, "Saturday");
	self.addBulkCalendarDates(weekCalendar, firstSunday, 52, "Sunday");
	
	compCalendar := self.createCalendar("UTCO", "UT compulsory 7185", false, false, "UTCO");
	self.addBulkCalendarDates(compCalendar, tuesdayHol, 2, "Tuesday Hol");

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, weekCalendar, compCalendar,null, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Calendar_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Calendar_Days,	//_freeDaysType : Integer;
								5,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								2,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 7185",	//_desc : String
								-1,	//_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer;
								false, //_includeFirstDay : Boolean;
								false //_includeLastDay : Boolean;
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");
	
	
	//Using 'CM_StorageDetail.Calendar_Days', I.e. the old behaviour, should always just give the declared number of days regardless of the
	// actual calendar configuration.
	testNum := 1;
	testDate := firstMonday + 2;	//First wednesday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	testNum := 2;
	testDate := firstSaturday + 6;	//Friday Start one day before the weekend 
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	testNum := 3;
	testDate := firstSaturday + 7;	//Saturdat Start on the first day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	testNum := 4;
	testDate := firstSunday + 7;	//Sunday Start on the last day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	testNum := 5;
	testDate := tuesdayHol + 7; // Tuesday start on the next holiday
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	testNum := 6;
	testDate := tuesdayHol + 6; //Monday one day before the next holidaya
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = storageDetail.stopCompletionFreeDays, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "'.");
	
	
	// Update  to use 'Calendar_Months', I.e. should always just increment the declared number of months regardless of the
	// actual calendar configuration.
	beginTransaction;
	storageDetail.setPropertyValue( CM_StorageDetail::freeDaysType.name, CM_StorageDetail.Calendar_Months );
	commitTransaction;
	expectdDaysFree := 61;  // Sept = 30 days + Oct -31 days 
	
	testNum := 7;
	testDate := firstMonday + 2;	//First wednesday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 8;
	testDate := firstSaturday + 6;	//Friday Start one day before the weekend 
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 9;
	testDate := firstSaturday + 7;	//Saturdat Start on the first day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 10;
	testDate := firstSunday + 7;	//Sunday Start on the last day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 11;
	testDate := tuesdayHol + 7; // Tuesday start on the next holiday
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 12;
	testDate := tuesdayHol + 6; //Monday one day before the next holidaya
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Calendar_Months', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	
	// Update  to use 'Working_Days', I.e. should increment the count to skip any days declared in the myWorkingDaysCalendar
	// so that weekends are skipped
	
	beginTransaction;
	storageDetail.setPropertyValue( CM_StorageDetail::freeDaysType.name, CM_StorageDetail.Working_Days );
	commitTransaction;
	 
	testNum := 13;
	testDate := firstMonday + 2;	//First wednesday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays;
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 14;
	testDate := firstMonday + 3;	//First thursday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 2;	// should be 2 weekend dates
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 15;
	testDate := firstSaturday + 6;	//Friday Start one day before the weekend 
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 2;	// should be 2 weekend days
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 16;
	testDate := firstSaturday + 7;	//Saturday Start on the first day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 2;	// should be 2 weekend days
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 17;
	testDate := firstSunday + 7;	//Sunday Start on the last day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 1; // should be one weekend day
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 18;
	testDate := tuesdayHol + 7; // Tuesday start on the next holiday
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays; // should ignore holidays
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 19;
	testDate := tuesdayHol + 6; //Monday one day before the next holidaya
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays; // should ignore holidays
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	
	// Update  to use 'Working_Compulsory_Days', I.e. should increment the count to skip any days declared in the myWorkingDaysCalendar
	// and or the Compulsory days (holidays calendar) so that weekends and holidays are skipped
	
	beginTransaction;
	storageDetail.setPropertyValue( CM_StorageDetail::freeDaysType.name, CM_StorageDetail.Working_Compulsory_Days );
	commitTransaction;
	
	testNum := 20;
	testDate := firstMonday + 2;	//First wednesday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays;
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 21;
	testDate := firstMonday + 3;	//First thursday, wont clash with any calendar days
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 2;	// should be 2 weekend dates
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 22;
	testDate := firstSaturday + 6;	//Friday Start one day before the weekend 
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 3;	// should be 2 weekend days and one holiday days
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 23;
	testDate := firstSaturday + 7;	//Saturday Start on the first day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 3;	// should be 2 weekend days and one holiday days
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 24;
	testDate := firstSunday + 7;	//Sunday Start on the last day of the weekend
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 2; // should be one weekend day and one holiday days
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 25;
	testDate := tuesdayHol + 7; // Tuesday start on the next holiday
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 1; // should be one holiday
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
	testNum := 26;
	testDate := tuesdayHol + 6; //Monday one day before the next holidaya
	daysFree := storageDetail.getStopCompletionFreeDays( testDate );
	expectdDaysFree := storageDetail.stopCompletionFreeDays + 1; // should be one holiday
	self.assertTrueMsg( daysFree = expectdDaysFree, "Test " &amp; testNum.String &amp; " - Storage detail using 'CM_StorageDetail.Working_Compulsory_Days', storageDetail.stopCompletionFreeDays = " &amp; storageDetail.stopCompletionFreeDays.String &amp; " and " &amp; testDate.String &amp; " returned '" &amp; daysFree.String &amp; "' expected '" &amp; expectdDaysFree.String &amp; "'.");
	
epilog

	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageBillingByTerminalArea1" id="1ed748ba-0087-4083-91e1-706cb2980df7">
        <source>tStorageBillingByTerminalArea1();
// NAVAB1
// cnwmp6
// cnwjre1
/*  CCMS DPH 2278 test future storage billing.  Set up terminal areas, terminal area groups, storage config to link these to invoice line descs,
		transaction map to charge regular storage (to confirm that future storage is not charged this way), cargo with multiple attributes to match storage config.
		Receive and release the cargo, back-date transactions and actors, run the background process to action the future actors, check the results.
22 Feb 2018	jlgsl4	TFS 37088 - use plannedDT instead of hireDT
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
*/

constants
	// inside
	BlockStackId1		: String = "UTSBTBS1";
	BlockStackId2		: String = "UTSBTBS2";
	// outside
	BlockStackId3		: String = "UTSBTBS3";
	BlockStackId4		: String = "UTSBTBS4";
	// inside
	TAGroup1			: String = "TAGROUP1";
	// outside
	TAGroup2			: String = "TAGROUP2";
	
vars
	count	: Integer;
	count2	: Integer;
	dateDifference	: Integer;
	tran 	: CM_TITransaction;
	actionTS,
	tranTS : TimeStamp;
	startTS,
	endTS	 : TimeStamp;	
	now		 : Date;
	tranDate : Date;
	expiryDate	: Date;
	bank		: CM_Bank;
	storageConfig	: CM_StorageConfig;
	storageDetail,
	detail1,
	detail2		: CM_StorageDetail;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	bs0,
	bs1, bs2,
	bs3, bs4	: CM_BlockStack;
	ti,
	ti1, ti2, ti3, ti4	: CM_TrackedItem;
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	termAreas		: CM_TerminalAreaArray;
	allTIs			: CM_TIArray;
	allFutureTIs	: CM_TIArray;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	invLineTypeArray	: CM_InvoiceLineDescArray;
	invLineType1,
	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	invLine			: CM_InvoiceLine;
	fsm1,
	fsm2	: CM_FutureStorageMapping;
	root	: CM_Root;
	futureActor	: CM_OfflineFutureActor;
	parent	: CM_Object;
	futureStorageTrx : CM_FutureStorage;
	controller : CMIF_TiTransactionResync;
	resultStr : String;
	
begin
	root := app.myRoot;
	self.cleanupOfflineActors();
	bank := self.myBank;
	
	self.deleteStorageConfig( false );

	create invLineTypeArray transient;
	// storage config
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	create triggers transient;
	calendar := self.setupCalendar();
	// all storage options false/null, days are working not calendar
	// 30 days free storage for GENL 20's and 35 days free for MT 20's
	storageConfig := self.setupStorageConfig3(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, true, true, deriveDebtorFrom, triggers, true);
	foreach storageDetail in storageConfig.allStorageDetails do
		count := count + 1;
		if count = 1 then
			detail1 := storageDetail;
		elseif count = 2 then
			detail2 := storageDetail;
		endif;
	endforeach;
	
	/* 11 Feb 2021 NDL TFS 50641
	stopTable := app.myRoot.allStopsTable.getAtKey( 930 );  // this one is marked as not available for entry.
	beginTransaction;
	detail1.setPropertyValue(CM_StorageDetail::myFutureStorageStop.name,stopTable);
	commitTransaction; */

	// terminal areas
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	assertNotNullMsg(bs1, BlockStackId1);
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	assertNotNullMsg(bs2, BlockStackId2);
	bs3 := self.addBlockStack(BlockStackId3, 99, null);
	assertNotNullMsg(bs3, BlockStackId3);
	bs4 := self.addBlockStack(BlockStackId4, 99, null);
	assertNotNullMsg(bs4, BlockStackId4);
	bs0 := self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs0 = null then
		bs0 := self.addBlockStack("UTSTORE", 99, null);
	endif;
	assertNotNullMsg(bs0, "UTSTORE");
	
	// terminal area groups
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	self.deleteTerminalAreaStorageGroup(TAGroup2);
	
	create termAreas transient;
	termAreas.add(bs1);
	termAreas.add(bs2);
	
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);
	
	termAreas.clear();
	termAreas.add(bs3);
	termAreas.add(bs4);
	tasg2 := self.addTerminalAreaStorageGroup(TAGroup2, "outside", termAreas);
	
	// invoice line descriptions
	invLineType1 := self.getInvoiceLineType("UT_ILTFSD5");
	invLineType2 := self.getInvoiceLineType("UT_ILTFSD5");
	invLineType3 := self.getInvoiceLineType("UT_ILTFSD5");

	// future storage mappings
	invLineTypeArray.add(invLineType1);
	fsm1 := self.addFutureStorageMapping2(bank, tasg2, detail1, invLineType1.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm1, 'inside FSM');
	
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail2, invLineType2.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm2, 'outside FSM');
	
	// transaction map for storage
	self.loadTranMapDaysSinceReceival();

	create allTIs transient;
	create allFutureTIs transient;
	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	allTIs.add(ti1);
	allFutureTIs.add(ti1);
	
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	allTIs.add(ti2);
	allFutureTIs.add(ti2);

	self.assertEqualMsg(ti1.freeStorageDays, 35, ti1.id &amp; " receive MT free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " receive GENL free storage days");
	// move to terminal areas included in the terminal area groups
	self.move(ti1, bs1);
	self.assertEqualMsg(ti1.myPrimaryActualLocation, bs1.allLocationsControllers.first, "Did not move ti1 to correct location");
	self.move(ti2, bs3);
	self.assertEqualMsg(ti2.myPrimaryActualLocation, bs3.allLocationsControllers.first, "Did not move ti2 to correct location");

	// third container covered by future storage but not stored in an area included in the storage groups
	cargoId := "UUTU7654GEN";
	commodity := "GENL";
	ti3 := self.receiveContainerIntoYard(cargoId, commodity);
	allTIs.add(ti3);
	allFutureTIs.add(ti3);
	// move to a terminal area NOT included in the terminal area groups
	self.move(ti3, bs0);
	self.assertEqualMsg(ti3.myPrimaryActualLocation, bs0.allLocationsControllers.first, "Did not move ti3 to correct location");

	// fourth container NOT covered by future storage (different commodity)
	cargoId := "UUTU1234UTA";
	commodity := "UT_A";
	ti4 := self.receiveContainerIntoYard(cargoId, commodity);
	allTIs.add(ti4);
	// move to a general terminal area
	self.move(ti4, bs0);
	self.assertEqualMsg(ti4.myPrimaryActualLocation, bs0.allLocationsControllers.first, "Did not move ti4 to correct location");

	// set the transaction dates to a start date of 1 Jan 2013 and modify the free storage expiry dates to match
	tranDate.setDate(1,1,2013);
	tranTS.setDate(tranDate);
	storageDetail := null;								//05.10.2022 navma1 #52967
	beginTransaction;
	foreach ti in allTIs do
		expiryDate := ti.getFutureStorageAnniversary(); // TFS 37088
		if expiryDate &lt;&gt; null then
			dateDifference := expiryDate - now;
		endif;
		foreach tran in ti.allTransactions do
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
			tran.setPropertyValue("dateTime", tranTS);
		endforeach;
		 //18/09/2023 navmv20 CR 58250 Task 58252
		ti.evaluateFreeStorageDays(null,true);		//22.05.2024 navma1 #64224
		if expiryDate &lt;&gt; null then
			expiryDate := tranDate + dateDifference;
			//ti.setFutureStorageAnniversary(expiryDate,storageDetail); // TFS 37088	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
			ti.setFutureStorageAnniversary(expiryDate,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
			actionTS.setTime('00:01'.Time);
			actionTS.setDate(expiryDate + 1);
			self.setFutureActorTS(ti, actionTS);
		endif;
	endforeach;
	commitTransaction;

	// action the CM_OfflineFutureActorInserters - should be a CM_FutureStorageProcess for each received cargo item
	self.processOfflineActors();
	
	// process the offline actors to create CM_FutureStorageProcess
	count := 0;
	foreach futureActor in root.allOfflineFutureActors do
		parent := futureActor.myParentObject;
		if parent.isKindOf(CM_TrackedItem) then
			if allTIs.includes(parent.CM_TrackedItem) then
				count := count + 1;
			endif;
		endif;
	endforeach;
	count2 := allFutureTIs.size;
	self.assertEqualMsg(count, allFutureTIs.size, "A CM_FutureStorageProcess for each received cargo item ");
	
	// process the CM_FutureStorageProcess as at 7 Feb 2013 starting at 1 Jan - there should be entries for 1 Feb and 6 Feb
	startTS.setTime("00:00".Time);
	startTS.setDate("1/01/2013".Date);
	endTS.setTime("23:59".Time);
	endTS.setDate("7/02/2013".Date);

	//10/09/2023 navmv20 CR 58250 Task 58252 - start
	foreach ti in allFutureTIs do
		self.verifyStorageTI(ti);
	endforeach;
	//10/09/2023 navmv20 CR 58250 Task 58252 - end
	
	// this should create CM_FutureStorage and new CM_OfflineFutureActorInserters for the next storage cycle
	self.processOfflineFutureActors(startTS, endTS);
	self.validateFutureStorage1(allFutureTIs, 1);

	// action the CM_OfflineFutureActorInserters - should be a CM_FutureStorageProcess for each processed cargo item
	self.processOfflineActors();
	// process the CM_FutureStorageProcess as at end 10  Mar 2013 starting at 1 Feb - there should be entries for 3 Mar and 9 Mar
	startTS.setTime("00:00".Time);
	startTS.setDate("1/02/2013".Date);
	endTS.setTime("23:59".Time);
	endTS.setDate("10/03/2013".Date);

	// this should create CM_FutureStorage and new CM_OfflineFutureActorInserters for the next storage cycle
	self.processOfflineFutureActors(startTS, endTS);
	self.validateFutureStorage1(allFutureTIs, 2);

//Start of Testing for TFS 47344	NDL	14 Nov 2019
	// Make resync use the transaction values for Future Storage Trx, not the ti values
	futureStorageTrx := ti2.getTransactionOfType(TRANS_TYPE_FUTURE_STORAGE).CM_FutureStorage;
	self.assertTrueMsg(futureStorageTrx &lt;&gt; null, "Future Storage transaction not found for " &amp; ti2.id);
	invLine := futureStorageTrx.allInvoiceLines.last();
	self.assertTrueMsg(invLine &lt;&gt; null and not invLine.voided, "Invoice Line for Future Storage Transaction not found or Voided, pre re-sync.");
	// now change the IMEX on the TI to 'Export' and re-sync without updating the transaction.( which would mean the TI would no longer
	// match the storage config criteria but the trx still does, so no change expected)
	self.opts.purge();
	self.opts.addAssoc( "IMEXStatus", TI_IMEX_STATUS_EXPORT );
	self.updateTI( ti2 );
	self.assertTrueMsg(ti2.getImExStatus = TI_IMEX_STATUS_EXPORT, "IMEX failed to update pre re-sync for " &amp; ti2.id);

	create controller transient;
	controller.myTrackedItem := ti2;
	controller.allTransactions.add( futureStorageTrx );
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
	resultStr := app.myPassport.getErrorsAndWarningsAsString;
	self.assertTrueMsg( resultStr = null, "1st Re-sync for " &amp; ti2.id &amp; " failed with " &amp; resultStr);
	delete controller;
	
	self.assertTrueMsg(not invLine.voided, "Invoice Line for Future Storage Transaction Voided, after 1st re-sync.");
	
	// now move the TI out of the area that the storage config covers and re-sync without updating the transaction.  Still no change
	// expected, because the term area on the trx still matches the storage config.
	self.move( ti2, bs0);	
	self.assertTrueMsg( ti2.myPrimaryActualLocation = bs0.myLocationsController, "Move pre re-sync for " &amp; ti2.id &amp; " failed");
	
	create controller transient;
	controller.myTrackedItem := ti2;
	controller.allTransactions.add( futureStorageTrx );
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
	resultStr := app.myPassport.getErrorsAndWarningsAsString;
	self.assertTrueMsg( resultStr = null, "2nd Re-sync for " &amp; ti2.id &amp; " failed with " &amp; resultStr);
	delete controller;
	
	self.assertTrueMsg(not invLine.voided, "Invoice Line for Future Storage Transaction Voided, after 2nd re-sync.");
//End of Testing for TFS 47344	NDL	14 Nov 2019	
	
	// gate out one of the containers
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.deleteVehicle("UTMAT");
	// container 1 is empty
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", ti1.CM_Container, true, singleGate , null); 
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check that there is no regular storage for this container and that any future actors have been deleted
	count := 0;
	foreach tran in ti1.allTransactions do
		if tran.class.name = "CM_Storage" then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "No regular storage transactions for released cargo item " &amp; ti1.id);
	count := 0;
	foreach futureActor in root.allOfflineFutureActors do
		if futureActor.myParentObject = ti1 then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "No future actors for released cargo item " &amp; ti1.id);
	
	// gate out the regular container and check that it does still get storage
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", ti4.CM_Container, true, singleGate , null); 
	self.workVehicle(vvr);
	self.roadExit(vvr);
	count := 0;
	foreach tran in ti4.allTransactions do
		if tran.class.name = "CM_Storage" then
			foreach invLine in tran.allInvoiceLines do
				if invLine.quantity &gt; 0 then
					count := count + 1;
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertTrueMsg(count &gt; 0, "At least one regular storage transaction for released cargo item " &amp; ti4.id);
	count := 0;

epilog
	delete triggers;
	delete termAreas;
	delete allTIs;
	delete allFutureTIs;
	delete invLineTypeArray;
	self.resetDefaultTranMap();
	delete controller;
	
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageBillingByTerminalArea2" id="e177b824-56b9-49d9-acc5-b766e64fc9f3">
        <source>tStorageBillingByTerminalArea2();
// NAVAB1
// cnwmp6
// cnwjre1
/*  CCMS DPH 2278 test future storage billing.  Set up terminal areas, terminal area groups, storage config to link these to invoice line descs,
		transaction map to charge regular storage (to confirm that future storage is not charged this way), cargo with multiple attributes to match storage config.
		Receive and release the cargo, back-date transactions and actors, run the background process to action the future actors, check the results.
	This tests the changes following 36275 and 37434 which allow the full quantity map/quantity range map processing to be done 
22 Feb 2018	jlgsl4	TFS 37088 - use plannedDT instead of hireDT
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
	*/

constants
	// inside
	BlockStackId1		: String = "UTSBTBS1";
	BlockStackId2		: String = "UTSBTBS2";
	// outside
	BlockStackId3		: String = "UTSBTBS3";
	BlockStackId4		: String = "UTSBTBS4";
	
	// inside
	TAGroup1			: String = "TAGROUP1";
	// outside
	TAGroup2			: String = "TAGROUP2";
	
vars
	count	: Integer;
	count2	: Integer;
	dateDifference	: Integer;
	tran 	: CM_TITransaction;
	actionTS,
	tranTS : TimeStamp;
	startTS,
	endTS	 : TimeStamp;	
	now		 : Date;
	tranDate : Date;
	expiryDate	: Date;
	bank		: CM_Bank;
	storageConfig	: CM_StorageConfig;
	storageDetail,
	detail1,
	detail2		: CM_StorageDetail;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	bs0,
	bs1, bs2,
	bs3, bs4	: CM_BlockStack;
	ti,
	ti1, ti2	: CM_TrackedItem;
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	termAreas		: CM_TerminalAreaArray;
	allTIs			: CM_TIArray;
	allFutureTIs	: CM_TIArray;
	debtor	: CM_Debtor;
	invLineTypeArray	: CM_InvoiceLineDescArray;
	services : CM_ServiceByNameDict;
	invType : CM_InvoiceDesc;	
	glCode	: CM_GLCode;
	calcType1		: CM_CalculationType;
	invLineType1,
	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	fsm1,
	fsm2	: CM_FutureStorageMapping;
	root	: CM_Root;
	futureActor	: CM_OfflineFutureActor;
	parent	: CM_Object;
	
begin
	self.deleteStorageConfig( false );
	root := app.myRoot;
	self.cleanupOfflineActors();
	bank := self.myBank;

	debtor := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).debtor;
	
	create invLineTypeArray transient;
	create services transient;
	// storage config
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	create triggers transient;
	calendar := self.setupCalendar();
	// all storage options false/null, days are working not calendar
	// 30 days free storage for GENL 20's and 35 days free for MT 20's
	storageConfig := self.setupStorageConfig3(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, true, true, deriveDebtorFrom, triggers, true);
	foreach storageDetail in storageConfig.allStorageDetails do
		count := count + 1;
		if count = 1 then
			detail1 := storageDetail;
		elseif count = 2 then
			detail2 := storageDetail;
		endif;
	endforeach;

	// terminal areas
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	assertNotNullMsg(bs1, BlockStackId1);
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	assertNotNullMsg(bs2, BlockStackId2);
	bs3 := self.addBlockStack(BlockStackId3, 99, null);
	assertNotNullMsg(bs3, BlockStackId3);
	bs4 := self.addBlockStack(BlockStackId4, 99, null);
	assertNotNullMsg(bs4, BlockStackId4);
	bs0 := self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs0 = null then
		bs0 := self.addBlockStack("UTSTORE", 99, null);
	endif;
	assertNotNullMsg(bs0, "UTSTORE");
	
	// terminal area groups
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	self.deleteTerminalAreaStorageGroup(TAGroup2);
	
	create termAreas transient;
	termAreas.add(bs1);
	termAreas.add(bs2);
	
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);
	
	termAreas.clear();
	termAreas.add(bs3);
	termAreas.add(bs4);
	tasg2 := self.addTerminalAreaStorageGroup(TAGroup2, "outside", termAreas);
	
	// invoice line descriptions
	glCode := bank.glCodes["UT_GL"];
	invType := self.getInvoiceType("UT_InvTypeStore");			// is a storage-type invoice type
	self.addIfNewServiceILD("UT_ServiceFSD9", "CCT06", "UT_ILTFSD9", glCode, invType);		// days since receival
	self.addIfNewServiceILD("UT_ServiceFSD10", "CCT06", "UT_ILTFSD10", glCode, invType);	// days since receival
	invLineType1 := self.getInvoiceLineType("UT_ILTFSD9");
	invLineType2 := self.getInvoiceLineType("UT_ILTFSD10");
	invLineType3 := self.getInvoiceLineType("UT_ILTFSD5");
	services.add(invLineType1.services.first);
	services.add(invLineType2.services.first);
	self.setRates(debtor, services);
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT04'];	// Cargo Weight Kilos
	// future storage mappings [NOTE: this WORKS creating one fsm with 2 qrms for each of the two ranges]
	invLineTypeArray.add(invLineType1);
	fsm1 := self.addFutureStorageMapping2(bank, tasg2, detail1, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 1999, invLineTypeArray);
//	fsm1 := self.addFutureStorageMapping2(bank, tasg2, detail1, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 30, invLineTypeArray);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm1 := self.addFutureStorageMapping2(bank, tasg2, detail1, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 2000, 999999, invLineTypeArray);
//	fsm1 := self.addFutureStorageMapping2(bank, tasg2, detail1, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 31, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm1, 'inside FSM');
	
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType1);
	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail2, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 1999, invLineTypeArray);
//	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail2, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 30, invLineTypeArray);
	invLineTypeArray.clear();
	invLineTypeArray.add(invLineType2);
	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail2, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 2000, 999999, invLineTypeArray);
//	fsm2 := self.addFutureStorageMapping2(bank, tasg1, detail2, calcType1, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 31, 999999, invLineTypeArray);
	self.assertNotNullMsg(fsm2, 'outside FSM');
	
	// transaction map for storage
	self.loadTranMapDaysSinceReceival();

	create allTIs transient;
	create allFutureTIs transient;
	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	allTIs.add(ti1);
	allFutureTIs.add(ti1);
	
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	beginTransaction;
	ti2.setTotalWeightWithoutTrans(1990.00);
	commitTransaction;
	allTIs.add(ti2);
	allFutureTIs.add(ti2);

	self.assertEqualMsg(ti1.freeStorageDays, 35, ti1.id &amp; " receive MT free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " receive GENL free storage days");
	// move to terminal areas included in the terminal area groups
	self.move(ti1, bs1);
	self.assertEqualMsg(ti1.myPrimaryActualLocation, bs1.allLocationsControllers.first, "Did not move ti1 to correct location");
	self.move(ti2, bs3);
	self.assertEqualMsg(ti2.myPrimaryActualLocation, bs3.allLocationsControllers.first, "Did not move ti2 to correct location");

	// set the transaction dates to a start date of 1 Jan 2013 and modify the free storage expiry dates to match
	tranDate.setDate(1,1,2013);
	tranTS.setDate(tranDate);
	storageDetail := null;								//05.10.2022 navma1 #52967
	beginTransaction;
	foreach ti in allTIs do
		expiryDate := ti.getFutureStorageAnniversary(); // TFS 37088
		if expiryDate &lt;&gt; null then
			dateDifference := expiryDate - now;
		endif;
		foreach tran in ti.allTransactions do
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
			tran.setPropertyValue("dateTime", tranTS);
		endforeach;
		//10/09/2023 navmv20 CR 58250 Task 58252 - start
		ti.evaluateFreeStorageDays(null,true);						//22.05.2024 navma1 #64224
		//10/09/2023 navmv20 CR 58250 Task 58252 - end
		if expiryDate &lt;&gt; null then
			expiryDate := tranDate + dateDifference;
			//ti.setFutureStorageAnniversary(expiryDate,storageDetail); // TFS 37088	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
			ti.setFutureStorageAnniversary(expiryDate,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
			actionTS.setTime('00:01'.Time);
			actionTS.setDate(expiryDate + 1);
			self.setFutureActorTS(ti, actionTS);
		endif;
	endforeach;
	commitTransaction;

	// action the CM_OfflineFutureActorInserters - should be a CM_FutureStorageProcess for each received cargo item
	self.processOfflineActors();
	
	// process the offline actors to create CM_FutureStorageProcess
	count := 0;
	foreach futureActor in root.allOfflineFutureActors do
		parent := futureActor.myParentObject;
		if parent.isKindOf(CM_TrackedItem) then
			if allTIs.includes(parent.CM_TrackedItem) then
				count := count + 1;
			endif;
		endif;
	endforeach;
	count2 := allFutureTIs.size;
	self.assertEqualMsg(count, allFutureTIs.size, "A CM_FutureStorageProcess for each received cargo item ");
	
	// process the CM_FutureStorageProcess as at 7 Feb 2013 starting at 1 Jan - there should be entries for 1 Feb and 6 Feb
	startTS.setTime("00:00".Time);
	startTS.setDate("1/01/2013".Date);
	endTS.setTime("23:59".Time);
	endTS.setDate("7/02/2013".Date);

	// this should create CM_FutureStorage and new CM_OfflineFutureActorInserters for the next storage cycle
	self.processOfflineFutureActors(startTS, endTS);
	self.validateFutureStorage2(allFutureTIs);


epilog
	delete triggers;
	delete termAreas;
	delete allTIs;
	delete allFutureTIs;
	delete invLineTypeArray;
	delete services;
	self.resetDefaultTranMap();
	
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigAttributes" id="1f7b7484-3aed-49bb-86b4-a63bce33a64e">
        <source>tStorageConfigAttributes();
// cnwns1
// cnwjre1	CCMS 1295 free storage days, matching test for each attribute, single values
vars
	cargoId		: String;
	commodity	: String;
	nullString	: String;
	value		: Any;
	match		: Boolean;
	root		: CM_Root;
	ti			: CM_TrackedItem;
	ya			: CM_YardAllocation;
	proxy,
	criteria	: CM_YACriteria;
	critType	: CM_YACriteriaType;
	types		: CM_YACritetriaTypeByTypeDict;
	status		: Integer;
	contentsStatus	: CM_ContentsStatus;
	iso		: CM_ISOType;
	group	: CM_ISOTypeGroup;
	product	: CM_Product;
	operator	: CM_Operator;
	consignee	: CM_ConsigneeConsignor;
	objSet	: ObjectSet;

begin
	root := app.myRoot;
	create types transient;
	types.add(root.allYACriteriaTypes[YACriteriaType_CargoType]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Commodity]);
	types.add(root.allYACriteriaTypes[YACriteriaType_CommodityGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISO]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISOGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Product]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsOverDimension]);
	types.add(root.allYACriteriaTypes[YACriteriaType_SubTerminal]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazardous]);
	types.add(root.allYACriteriaTypes[YACriteriaType_RequiresPower]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazAllLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazNotLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazOrLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Damaged]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsEmpty]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsReefer]);
	// CCMS DPH 2278 add operator, consignor, consignee and freight forwarder
	types.add(root.allYACriteriaTypes[YACriteriaType_OperatorItem]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Consignee]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Consignor]);
	types.add(root.allYACriteriaTypes[YACriteriaType_FreightForward]);
	
	// create arbitrary container
	cargoId := "UUTU9870GEN";
	commodity := "*UTA";
	ti := self.receiveContainerIntoYard(cargoId, commodity);
	// set consignee, consignor, freight forwarder and operator
	operator := self.getOperator('UTOP');
	self.opts.purge();
	self.opts.addAssoc('Consignee', 'UTCE1');
	self.opts.addAssoc('Consignor', 'UTCOE');
	self.opts.addAssoc('FreightForwarder', 'UTFF1');
	self.opts.addAssoc('Operator', operator);
	
	// check criteria value match for each attribute used in the storage config screen
	create objSet transient;
	create ya transient;
	foreach critType in types do
		value := null;
		objSet.clear();
		if critType.type= YACriteriaType_CargoType then
			objSet.add(ti.myCargoType);
			value := objSet;
		elseif critType.type = YACriteriaType_Commodity then
			objSet.add(ti.getCommodityObject());
			value := objSet;
		elseif critType.type =  YACriteriaType_CommodityGroup then
			objSet.add(ti.myCommodityGroup);
			value := objSet;
		elseif critType.type =  YACriteriaType_ContainerLength then
			value := ti.getActualLength().String;
		elseif critType.type =  YACriteriaType_ContentsStatus then
			status := ti.getContentsStatus();
			contentsStatus := root.allContentsStatuses[status];
			objSet.add(contentsStatus);
			value := objSet;
		elseif critType.type =  YACriteriaType_ImexStatus then
			objSet.add(ti.getImExStatusObject());
			value := objSet;
		elseif critType.type =  YACriteriaType_ISO then
			iso := app.myRoot.allISOTypes[ti.CM_Container.isoType];
			objSet.add(iso);
			value := objSet;
		elseif critType.type =  YACriteriaType_ISOGroup then
			group := app.myRoot.allISOTypeGroups[ti.CM_Container.isoGroup];
			objSet.add(group);
			value := objSet;
		elseif critType.type =  YACriteriaType_Product then
			product := ti.myProduct;
			if product &lt;&gt; null then
				objSet.add(product);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsOverDimension then
			value := self.getCritTypeValueBool(ti.isOverDimensions);
		elseif critType.type =  YACriteriaType_SubTerminal then
			if ti.mySubTerminal &lt;&gt; null then
				objSet.add(ti.mySubTerminal);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsHazardous then
			value := self.getCritTypeValueBool(ti.isHazardous);
		elseif critType.type =  YACriteriaType_RequiresPower then
			value := self.getCritTypeValueBool(ti.requiresPower);
		elseif critType.type =  YACriteriaType_IsHazAllLimited then
			value := self.getCritTypeValueBool(ti.isHazardousAllLimited);
		elseif critType.type =  YACriteriaType_IsHazNotLimited then
			value := self.getCritTypeValueBool(ti.isHazardousNotLimited);
		elseif critType.type =  YACriteriaType_IsHazOrLimited then
			value := self.getCritTypeValueBool(ti.isHazardousOrLimited);
		elseif critType.type =  YACriteriaType_Damaged then
			value := self.getCritTypeValueBool(ti.damaged);
		elseif critType.type =  YACriteriaType_IsEmpty then
			value := self.getCritTypeValueBool(ti.isEmpty);
		elseif critType.type =  YACriteriaType_OperatorItem then
			operator := ti.myOperator;
			if operator &lt;&gt; null then
				objSet.add(operator);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_Consignee then
			consignee := ti.getConsigneeObject;
			if consignee &lt;&gt; null then
				objSet.add(consignee);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_Consignor then
			consignee := ti.getConsignorObject;
			if consignee &lt;&gt; null then
				objSet.add(consignee);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_FreightForward then
			consignee := ti.myFreightForwarder;
			if consignee &lt;&gt; null then
				objSet.add(consignee);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type = YACriteriaType_IsReefer then
			value := self.getCritTypeValueBool(ti.isReefer);		
		endif;
	
		create proxy transient;
		proxy.setProxy(critType, value, null);
		proxy.setYardAllocation(ya);
		create criteria transient;
		criteria.setForCreate(proxy);
		
		match := criteria.isStorageDetailMatch(ti,null);
		self.assertTrueMsg(match, "Type " &amp; critType.description &amp; " " &amp; critType.class.name);
		
		delete proxy;
		delete criteria;
	endforeach;

epilog
	delete types;
	delete proxy;
	delete criteria;
	delete ya;
	delete objSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigAttributes2" id="e923d5ac-15b1-43dc-872f-7e6e892079f5">
        <source>tStorageConfigAttributes2();
// cnwns1
// cnwjre1 test values matching of each criteria type used in free storage days
//	multi-value matching
vars
	cargoId		: String;
	commodity	: String;
	nullString	: String;
	value		: Any;
	match		: Boolean;
	root		: CM_Root;
	ti			: CM_TrackedItem;
	ya			: CM_YardAllocation;
	proxy,
	criteria	: CM_YACriteria;
	critType	: CM_YACriteriaType;
	types		: CM_YACritetriaTypeByTypeDict;
	status		: Integer;
	cargoType	: CM_CargoType;
	cStatus,
	contentsStatus	: CM_ContentsStatus;
	imexStatus	: CM_IMEXStatus;
	iso2,
	iso		: CM_ISOType;
	group,
	group2	: CM_ISOTypeGroup;
	product	: CM_Product;
	objSet	: ObjectSet;

begin
	root := app.myRoot;
	create types transient;
	types.add(root.allYACriteriaTypes[YACriteriaType_CargoType]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Commodity]);
	types.add(root.allYACriteriaTypes[YACriteriaType_CommodityGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISO]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISOGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Product]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsOverDimension]);
	types.add(root.allYACriteriaTypes[YACriteriaType_SubTerminal]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazardous]);
	types.add(root.allYACriteriaTypes[YACriteriaType_RequiresPower]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazAllLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazNotLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazOrLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Damaged]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsEmpty]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsReefer]);
	
	// create arbitrary container
	cargoId := "UUTU9870GEN";
	commodity := "*UTA";
	ti := self.receiveContainerIntoYard(cargoId, commodity);
	
	// check criteria value match for each attribute used in the storage config screen
	create objSet transient;
	create ya transient;
	foreach critType in types do
		value := null;
		objSet.clear();
		if critType.type= YACriteriaType_CargoType then
			foreach cargoType in root.allCargoTypesById do
				if cargoType &lt;&gt; ti.myCargoType then
					objSet.add(cargoType);
					break;
				endif;
			endforeach;
			objSet.add(ti.myCargoType);
			value := objSet;
		elseif critType.type = YACriteriaType_Commodity then
			objSet.add(app.myRoot.allCommodities["GENL"]);	// note that the TI commodity IS the first so don't use that here
			objSet.add(ti.getCommodityObject());
			value := objSet;
		elseif critType.type =  YACriteriaType_CommodityGroup then
			objSet.add(root.allCommodityGroups.first);
			objSet.add(ti.myCommodityGroup);
			value := objSet;
		elseif critType.type =  YACriteriaType_ContainerLength then
			value := "45," &amp; ti.getActualLength().String;
		elseif critType.type =  YACriteriaType_ContentsStatus then
			status := ti.getContentsStatus();
			contentsStatus := root.allContentsStatuses[status];
			foreach cStatus in root.allContentsStatuses do
				if cStatus &lt;&gt; contentsStatus then
					objSet.add(cStatus);
					break;
				endif;
			endforeach;
			objSet.add(contentsStatus);
			value := objSet;
		elseif critType.type =  YACriteriaType_ImexStatus then
			foreach imexStatus in root.allImexStatuses do
				if imexStatus &lt;&gt; ti.getImExStatusObject then
					objSet.add(imexStatus);
					break;
				endif;
			endforeach;
			objSet.add(ti.getImExStatusObject());
			value := objSet;
		elseif critType.type =  YACriteriaType_ISO then
			iso := app.myRoot.allISOTypes[ti.CM_Container.isoType];
			foreach iso2 in root.allISOTypes do
				if iso2 &lt;&gt; iso then
					objSet.add(iso2);
					break;
				endif;
			endforeach;
			objSet.add(iso);
			value := objSet;
		elseif critType.type =  YACriteriaType_ISOGroup then
			group := root.allISOTypeGroups[ti.CM_Container.isoGroup];
			foreach group2 in root.allISOTypeGroups do
				if group2 &lt;&gt; group then
					objSet.add(group2);
					break;
				endif;
			endforeach;
			objSet.add(group);
			value := objSet;
		elseif critType.type =  YACriteriaType_Product then
			product := ti.myProduct;
			if product &lt;&gt; null then
				objSet.add(product);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsOverDimension then
			value := self.getCritTypeValueBool(ti.isOverDimensions);
		elseif critType.type =  YACriteriaType_SubTerminal then
			if ti.mySubTerminal &lt;&gt; null then
				objSet.add(ti.mySubTerminal);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsHazardous then
			value := self.getCritTypeValueBool(ti.isHazardous);
		elseif critType.type =  YACriteriaType_RequiresPower then
			value := self.getCritTypeValueBool(ti.requiresPower);
		elseif critType.type =  YACriteriaType_IsHazAllLimited then
			value := self.getCritTypeValueBool(ti.isHazardousAllLimited);
		elseif critType.type =  YACriteriaType_IsHazNotLimited then
			value := self.getCritTypeValueBool(ti.isHazardousNotLimited);
		elseif critType.type =  YACriteriaType_IsHazOrLimited then
			value := self.getCritTypeValueBool(ti.isHazardousOrLimited);
		elseif critType.type =  YACriteriaType_Damaged then
			value := self.getCritTypeValueBool(ti.damaged);
		elseif critType.type =  YACriteriaType_IsEmpty then
			value := self.getCritTypeValueBool(ti.isEmpty);
		elseif critType.type = YACriteriaType_IsReefer then
			value := self.getCritTypeValueBool(ti.isReefer);		
		endif;
	
		create proxy transient;
		proxy.setProxy(critType, value, null);
		proxy.setYardAllocation(ya);
		create criteria transient;
		criteria.setForCreate(proxy);
		
		match := criteria.isStorageDetailMatch(ti,null);
		self.assertTrueMsg(match, "Type " &amp; critType.description &amp; " " &amp; critType.class.name);
		
		delete proxy;
		delete criteria;
	endforeach;

epilog
	delete types;
	delete proxy;
	delete criteria;
	delete ya;
	delete objSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigAttributes3" id="1c2960b6-122f-462a-803f-706df92673fa">
        <source>tStorageConfigAttributes3();
// cnwns1
// cnwjre1 test values matching of each criteria type used in free storage days
//	wild-card matching, each non-Boolean as NOT a non-matching value - par 31221
vars
	cargoId		: String;
	commodity	: String;
	nullString	: String;
	value		: Any;
	match		: Boolean;
	root		: CM_Root;
	ti			: CM_TrackedItem;
	ya			: CM_YardAllocation;
	proxy,
	criteria	: CM_YACriteria;
	critType	: CM_YACriteriaType;
	types		: CM_YACritetriaTypeByTypeDict;
	status		: Integer;
	cargoType	: CM_CargoType;
	cStatus,
	contentsStatus	: CM_ContentsStatus;
	imexStatus	: CM_IMEXStatus;
	iso2,
	iso		: CM_ISOType;
	group,
	group2	: CM_ISOTypeGroup;
	product	: CM_Product;
	objSet	: ObjectSet;

begin
	root := app.myRoot;
	create types transient;
	types.add(root.allYACriteriaTypes[YACriteriaType_CargoType]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Commodity]);
	types.add(root.allYACriteriaTypes[YACriteriaType_CommodityGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISO]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISOGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Product]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsOverDimension]);
	types.add(root.allYACriteriaTypes[YACriteriaType_SubTerminal]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazardous]);
	types.add(root.allYACriteriaTypes[YACriteriaType_RequiresPower]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazAllLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazNotLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazOrLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Damaged]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsEmpty]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsReefer]);
	
	// create arbitrary container
	cargoId := "UUTU9870GEN";
	commodity := "*UTA";
	ti := self.receiveContainerIntoYard(cargoId, commodity);
	
	// check criteria value match for each attribute used in the storage config screen
	create objSet transient;
	create ya transient;
	foreach critType in types do
		value := null;
		objSet.clear();
		if critType.type= YACriteriaType_CargoType then
			foreach cargoType in root.allCargoTypesById do
				if cargoType &lt;&gt; ti.myCargoType then
					break;
				endif;
			endforeach;
			value := "!" &amp; cargoType.description;
		elseif critType.type = YACriteriaType_Commodity then
			value := "!ABC";
		elseif critType.type =  YACriteriaType_CommodityGroup then
			value := "!" &amp; root.allCommodityGroups.first.code;
		elseif critType.type =  YACriteriaType_ContainerLength then
			// no wild-cards
			value := "45," &amp; ti.getActualLength().String;
		elseif critType.type =  YACriteriaType_ContentsStatus then
			status := ti.getContentsStatus();
			contentsStatus := root.allContentsStatuses[status];
			foreach cStatus in root.allContentsStatuses do
				if cStatus &lt;&gt; contentsStatus then
					break;
				endif;
			endforeach;
			value := "!" &amp; cStatus.description;
		elseif critType.type =  YACriteriaType_ImexStatus then
			foreach imexStatus in root.allImexStatuses do
				if imexStatus &lt;&gt; ti.getImExStatusObject and
				   imexStatus.description &lt;&gt; null then
					break;
				endif;
			endforeach;
			value := "!" &amp; imexStatus.description;
		elseif critType.type =  YACriteriaType_ISO then
			iso := app.myRoot.allISOTypes[ti.CM_Container.isoType];
			foreach iso2 in root.allISOTypes do
				if iso2 &lt;&gt; iso then
					break;
				endif;
			endforeach;
			value := "!" &amp; iso2.code;
		elseif critType.type =  YACriteriaType_ISOGroup then
			group := root.allISOTypeGroups[ti.CM_Container.isoGroup];
			foreach group2 in root.allISOTypeGroups do
				if group2 &lt;&gt; group then
					break;
				endif;
			endforeach;
			value := "!" &amp; group2.code;
		elseif critType.type =  YACriteriaType_Product then
			product := ti.myProduct;
			if product &lt;&gt; null then
				objSet.add(product);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsOverDimension then
			value := self.getCritTypeValueBool(ti.isOverDimensions);
		elseif critType.type =  YACriteriaType_SubTerminal then
			if ti.mySubTerminal &lt;&gt; null then
				objSet.add(ti.mySubTerminal);
				value := objSet;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsHazardous then
			value := self.getCritTypeValueBool(ti.isHazardous);
		elseif critType.type =  YACriteriaType_RequiresPower then
			value := self.getCritTypeValueBool(ti.requiresPower);
		elseif critType.type =  YACriteriaType_IsHazAllLimited then
			value := self.getCritTypeValueBool(ti.isHazardousAllLimited);
		elseif critType.type =  YACriteriaType_IsHazNotLimited then
			value := self.getCritTypeValueBool(ti.isHazardousNotLimited);
		elseif critType.type =  YACriteriaType_IsHazOrLimited then
			value := self.getCritTypeValueBool(ti.isHazardousOrLimited);
		elseif critType.type =  YACriteriaType_Damaged then
			value := self.getCritTypeValueBool(ti.damaged);
		elseif critType.type =  YACriteriaType_IsEmpty then
			value := self.getCritTypeValueBool(ti.isEmpty);
		elseif critType.type = YACriteriaType_IsReefer then
			value := self.getCritTypeValueBool(ti.isReefer);		
		endif;
	
		create proxy transient;
		proxy.setProxy(critType, value, null);
		proxy.setYardAllocation(ya);
		create criteria transient;
		criteria.setForCreate(proxy);
		
		match := criteria.isStorageDetailMatch(ti,null);
		self.assertTrueMsg(match, "No storage detail match, Type " &amp; critType.description &amp; " " &amp; critType.class.name);
		
		delete proxy;
		delete criteria;
	endforeach;

epilog
	delete types;
	delete proxy;
	delete criteria;
	delete ya;
	delete objSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigAttributes4" id="7e35914f-7d75-4430-b5b4-7ef64e2998a6">
        <source>tStorageConfigAttributes4();
// cnwns1
// cnwjre1	CCMS 1295 free storage days, matching test for each attribute, single values
//	wild-card matching, each non-Boolean as "*" matching value - par 31221
vars
	cargoId		: String;
	commodity	: String;
	nullString	: String;
	value		: Any;
	match		: Boolean;
	root		: CM_Root;
	ti			: CM_TrackedItem;
	ya			: CM_YardAllocation;
	proxy,
	criteria	: CM_YACriteria;
	critType	: CM_YACriteriaType;
	types		: CM_YACritetriaTypeByTypeDict;
	status		: Integer;
	contentsStatus	: CM_ContentsStatus;
	iso		: CM_ISOType;
	group	: CM_ISOTypeGroup;
	product	: CM_Product;
	objSet	: ObjectSet;

begin
	root := app.myRoot;
	create types transient;
	types.add(root.allYACriteriaTypes[YACriteriaType_CargoType]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Commodity]);
	types.add(root.allYACriteriaTypes[YACriteriaType_CommodityGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISO]);
	types.add(root.allYACriteriaTypes[YACriteriaType_ISOGroup]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Product]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsOverDimension]);
	types.add(root.allYACriteriaTypes[YACriteriaType_SubTerminal]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazardous]);
	types.add(root.allYACriteriaTypes[YACriteriaType_RequiresPower]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazAllLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazNotLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsHazOrLimited]);
	types.add(root.allYACriteriaTypes[YACriteriaType_Damaged]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsEmpty]);
	types.add(root.allYACriteriaTypes[YACriteriaType_IsReefer]);
	
	// create arbitrary container
	cargoId := "UUTU9870GEN";
	commodity := "*UTA";
	ti := self.receiveContainerIntoYard(cargoId, commodity);
	
	// check criteria value match for each attribute used in the storage config screen
	create objSet transient;
	create ya transient;
	foreach critType in types do
		value := null;
		objSet.clear();
		if critType.type= YACriteriaType_CargoType then
			value := "*" &amp; ti.myCargoType.getYAIdentifier;
		elseif critType.type = YACriteriaType_Commodity then
			value := "*" &amp; ti.getCommodityObject().getYAIdentifier;
		elseif critType.type =  YACriteriaType_CommodityGroup then
			value := "*" &amp; ti.myCommodityGroup.getYAIdentifier;
		elseif critType.type =  YACriteriaType_ContainerLength then
			value := ti.getActualLength().String;
		elseif critType.type =  YACriteriaType_ContentsStatus then
			status := ti.getContentsStatus();
			contentsStatus := root.allContentsStatuses[status];
			value := "*" &amp; contentsStatus.getYAIdentifier;
		elseif critType.type =  YACriteriaType_ImexStatus then
			value := "*" &amp; ti.getImExStatusObject().getYAIdentifier;
		elseif critType.type =  YACriteriaType_ISO then
			iso := app.myRoot.allISOTypes[ti.CM_Container.isoType];
			value := "*" &amp; iso.getYAIdentifier;
		elseif critType.type =  YACriteriaType_ISOGroup then
			group := app.myRoot.allISOTypeGroups[ti.CM_Container.isoGroup];
			value := "*" &amp; group.getYAIdentifier;
		elseif critType.type =  YACriteriaType_Product then
			product := ti.myProduct;
			if product &lt;&gt; null then
				value := "*" &amp; product.getYAIdentifier;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsOverDimension then
			value := self.getCritTypeValueBool(ti.isOverDimensions);
		elseif critType.type =  YACriteriaType_SubTerminal then
			if ti.mySubTerminal &lt;&gt; null then
				objSet.add(ti.mySubTerminal);
				value := "*" &amp; ti.mySubTerminal.getYAIdentifier;
			else
				value := nullString;
			endif;
		elseif critType.type =  YACriteriaType_IsHazardous then
			value := self.getCritTypeValueBool(ti.isHazardous);
		elseif critType.type =  YACriteriaType_RequiresPower then
			value := self.getCritTypeValueBool(ti.requiresPower);
		elseif critType.type =  YACriteriaType_IsHazAllLimited then
			value := self.getCritTypeValueBool(ti.isHazardousAllLimited);
		elseif critType.type =  YACriteriaType_IsHazNotLimited then
			value := self.getCritTypeValueBool(ti.isHazardousNotLimited);
		elseif critType.type =  YACriteriaType_IsHazOrLimited then
			value := self.getCritTypeValueBool(ti.isHazardousOrLimited);
		elseif critType.type =  YACriteriaType_Damaged then
			value := self.getCritTypeValueBool(ti.damaged);
		elseif critType.type =  YACriteriaType_IsEmpty then
			value := self.getCritTypeValueBool(ti.isEmpty);
		elseif critType.type = YACriteriaType_IsReefer then
			value := self.getCritTypeValueBool(ti.isReefer);		
		endif;
	
		create proxy transient;
		proxy.setProxy(critType, value, null);
		proxy.setYardAllocation(ya);
		create criteria transient;
		criteria.setForCreate(proxy);
		
		match := criteria.isStorageDetailMatch(ti,null);
		if match = false then
			value := null;
		endif;
		self.assertTrueMsg(match, "Type " &amp; critType.description &amp; " " &amp; critType.class.name);
		
		delete proxy;
		delete criteria;
	endforeach;

epilog
	delete types;
	delete proxy;
	delete criteria;
	delete ya;
	delete objSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigDefaultCalendar" id="4dc84356-fe59-48de-a666-0f835b041f9c">
        <source>tStorageConfigDefaultCalendar();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with working days calendar and default values (calendar working/charged days)
//10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
vars
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	ti1, ti2	: CM_TrackedItem;
begin
	self.deleteStorageConfig( false );

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	// all options false/null
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, true);

	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	self.assertEqualMsg(ti1.freeStorageDays, 45, ti1.id &amp; " 1st free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " 2nd free storage days");
	
	// set the transaction dates to a known value just before the first holiday
	// holidays should be IGNORED in this test (test tStorageConfig2 uses them instead)
	tranDate.setDate(20,6,2012);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti1.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	foreach tran in ti2.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	commitTransaction;
	
	//10/09/2023 navmv20 CR 58250 Task 58252 - start //needs re-evaluation as transaction date is changed
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	ti1.evaluateFreeStorageDays(null,true);					//22.05.2024 navma1 #64224
	ti2.evaluateFreeStorageDays(null,true);					//22.05.2024 navma1 #64224
	commitTransaction;
	//10/09/2023 navmv20 CR 58250 Task 58252 - end

	self.assertEqualMsg(ti1.getFreeStorageExpiryDate, '4 August 2012'.Date, ti1.id &amp; " 1st free storage expiry");	// 45 days free after receival
	self.assertEqualMsg(ti2.getFreeStorageExpiryDate, '20 July 2012'.Date, ti2.id &amp; " 2nd free storage expiry");	// 30 days free after receival

epilog
	delete triggers;
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);
	

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigDefaultWorking" id="cc548272-9229-4935-aa79-274876e0154d">
        <source>tStorageConfigDefaultWorking();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with working days calendar and working free/charged days
//10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
vars
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	ti1, ti2	: CM_TrackedItem;
begin

	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	create triggers transient;
	calendar := self.setupCalendar();
	// all storage options false/null, days are working not calendar
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, true, true, deriveDebtorFrom, triggers, true);

	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	self.assertEqualMsg(ti1.freeStorageDays, 45, ti1.id &amp; " 1st free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " 2nd free storage days");
	
	// set the transaction dates to a known value just before the first holiday
	tranDate.setDate(20,6,2012);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti1.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	foreach tran in ti2.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	commitTransaction;
	
	//10/09/2023 navmv20 CR 58250 Task 58252 - start //needs re-evaluation as transaction date is changed
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	ti1.evaluateFreeStorageDays(null,true);  //22.05.2024 navma1 #64224
	ti2.evaluateFreeStorageDays(null,true);  //22.05.2024 navma1 #64224
	commitTransaction;
	//10/09/2023 navmv20 CR 58250 Task 58252 - end
	
	// free storage expiry dates are longer than in test 1 because of holidays and weekends
	self.assertEqualMsg(ti1.getFreeStorageExpiryDate, '27 August 2012'.Date, ti1.id &amp; " 1st free storage expiry");	// two holidays
	self.assertEqualMsg(ti2.getFreeStorageExpiryDate, '3 August 2012'.Date, ti2.id &amp; " 2nd free storage expiry");	// one holiday

epilog
	delete triggers;
	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigFirstCalendar" id="b71a75f4-1aaf-44cf-9ade-291b8c8bc332">
        <source>tStorageConfigFirstCalendar();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with working days calendar and default values (calendar working/charged days) except for first day being included
//10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
vars
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	ti1, ti2	: CM_TrackedItem;
begin
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	// all options false/null except first day
	includeFirstDay := true;
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, true);

	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	self.assertEqualMsg(ti1.freeStorageDays, 45, ti1.id &amp; " 1st free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " 2nd free storage days");
	
	// set the transaction dates to a known value just before the first holiday
	// holidays should be IGNORED in this test (test tStorageConfig2 uses them instead)
	tranDate.setDate(20,6,2012);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti1.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	foreach tran in ti2.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;

	//10/09/2023 navmv20 CR 58250 Task 58252 - start //needs re-evaluation as transaction date is changed
	ti1.evaluateFreeStorageDays(null,true);	//22.05.2024 navma1 #64224
	ti2.evaluateFreeStorageDays(null,true); //22.05.2024 navma1 #64224
	//10/09/2023 navmv20 CR 58250 Task 58252 - end
	commitTransaction;
	

	self.assertEqualMsg(ti1.getFreeStorageExpiryDate, '3 August 2012'.Date, ti1.id &amp; " 1st free storage expiry");	// 45 days free including receival
	self.assertEqualMsg(ti2.getFreeStorageExpiryDate, '19 July 2012'.Date, ti2.id &amp; " 2nd free storage expiry");	// 30 days free including receival

epilog
	delete triggers;
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);
	

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigFirstWorking" id="efde662b-3d1b-4bc4-baaf-aefab8668931">
        <source>tStorageConfigFirstWorking();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with working days calendar and working free/charged days, include first day
//10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
vars
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	cargoId		: String;
	commodity	: String;
	ti1, ti2	: CM_TrackedItem;
begin
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	create triggers transient;
	calendar := self.setupCalendar();
	// all storage options false/null, days are working not calendar, include first day
	includeFirstDay := true;
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, true, true, deriveDebtorFrom, triggers, true);

	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	cargoId := "UUTU9874GEN";
	commodity := "GENL";
	ti2 := self.receiveContainerIntoYard(cargoId, commodity);
	self.assertEqualMsg(ti1.freeStorageDays, 45, ti1.id &amp; " 1st free storage days");
	self.assertEqualMsg(ti2.freeStorageDays, 30, ti2.id &amp; " 2nd free storage days");
	
	// set the transaction dates to a known value just before the first holiday
	tranDate.setDate(20,6,2012);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti1.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	foreach tran in ti2.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	 //10/09/2023 navmv20 CR 58250 Task 58252 - start
	ti1.evaluateFreeStorageDays(null,true);					//22.05.2024 navma1 #64224
	ti2.evaluateFreeStorageDays(null,true);					//22.05.2024 navma1 #64224
	 //10/09/2023 navmv20 CR 58250 Task 58252 - end
	commitTransaction;
	// free storage expiry dates are longer than in test 1 because of holidays and weekends
	self.assertEqualMsg(ti1.getFreeStorageExpiryDate, '24 August 2012'.Date, ti1.id &amp; " 1st free storage expiry");	// two holidays
	self.assertEqualMsg(ti2.getFreeStorageExpiryDate, '2 August 2012'.Date, ti2.id &amp; " 2nd free storage expiry");	// one holiday

epilog
	delete triggers;
	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);
	

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigTrigger1" id="f986c89a-20df-463a-9d26-9f334d3a6b7f">
        <source>tStorageConfigTrigger1();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with all triggers, no free storage days reset ** 'all' triggers - still to be completed
///  ** do a version of this with half of the imex changes as triggers but all imex changes still done, the non-trigger changes should not result in a new storage transaction
vars
	tranTS : TimeStamp;
	now,
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	storageCount	: Integer;

	cargoId		: String;
	commodity	: String;
	ti1			: CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	subTerm1	: CM_SubTerminal;
	resetSubTermAreaDefined	: Boolean;
	subTerminalSettings : Boolean;
	terminal : CM_Terminal;
begin
	// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1
	terminal := self.getTerminal();
	subTerminalSettings := terminal.getConfig(IsSubTerminalsOn).Boolean;
	
	if not subTerminalSettings then
		beginTransaction;
		terminal.setConfig(IsSubTerminalsOn, true);
		commitTransaction;
	endif;
	
	self.deleteStorageConfig( false );
	if self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(false);	
	endif;
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	self.getAllStorageTriggers(triggers);

	// all options false/null - only the triggers are used here
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, false);

	// receive 20ft containers, empty and general

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	
	// set the transaction dates 20 days back
	
	tranDate := now-20;
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 0, "Initial storage transactions");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,false);
	
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 5, "Imex storage transactions");

	// change the sub terminal on tracked item, should create a new storage transaction
	// set the existing transaction dates back a day so a new storage transaction can be created
	
	tranDate := now-1;
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);

	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	subTerm1 := self.getTerminal.allSubTerminals["UT_Warehouse"];
	pxyTI.zSetPxySubTerminal( subTerm1 );
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(ti1.mySubTerminal = subTerm1, "Sub Term edit 1. Sub terminal not set to  '" &amp; subTerm1.code &amp; "' on '" &amp; ti1.id &amp; "'.");
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 6, "SubTerm storage transactions");
	
epilog
	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;
	delete pxyTI;
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( true );
	endif;
	
	// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1 - reset the sub terminal config
	beginTransaction;
	terminal.setConfig(IsSubTerminalsOn, subTerminalSettings);
	commitTransaction;	

	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigTrigger2" id="91ca0a31-66e5-4fe2-aef9-be9470a076d6">
        <source>tStorageConfigTrigger2();
// cnwns1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with only debtor trigger, no free storage days reset
// do imex changes - should be no extra storage
vars
	tranTS : TimeStamp;
	now,
	tranDate : Date;
	storageConfig	: CM_StorageConfig;
	pxyStorageTrigger	: CM_StorageTrigger;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	storageCount	: Integer;
	cargoId		: String;
	commodity	: String;
	ti1			: CM_TrackedItem;
begin

	self.deleteStorageConfig( false );

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();

	// just debtor change as a trigger
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageDebtor, false, null);
	triggers.add(pxyStorageTrigger);

	// all options false/null - only the triggers are used here
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, false);

	// receive 20ft container

	cargoId := "UUTU9876MT";
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity);
	
	// set the transaction dates 20 days back
	
	tranDate := now-20;
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 0, "Initial storage transactions");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,false);
	self.resetTransactionDate(ti1, tranTS);
	
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 0, "Storage transactions after IMEX changes");
	
	// change operator from UTOP (debtor ABOPS) to UTO2 (debtor RDT) - should trigger storage
	self.opts.addAssoc("Operator", self.getOperator('UTO2'));
	self.updateTrackedItem(ti1);

	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 1, "Storage transactions after operator changes");
	
epilog
	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;

	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageConfigTrigger3" id="9a36f8fd-04f2-4ba8-ba7c-8c02c98e2f2b">
        <source>tStorageConfigTrigger3();
// cnwndl1
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with all triggers, no free storage days reset, do pack/unpack
vars
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;

	container1	: CM_TrackedItem;
	packTIs, unpackTIs	: CM_TIArray;
	wh		: CM_IrregularBlockArea;
	cargo, cargo1	: CM_TrackedItem;

begin
	self.deleteStorageConfig( false );
	
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	self.getAllStorageTriggers(triggers);

	// all options false/null - only the triggers are used here
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, false);

	self.deleteContainer("TEST0000001");

	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	assertEqual(container1.totalWeight, "4000".Decimal);
	assertEqual(container1.weightCargo, null);
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertEqual(cargo.totalWeight, 2000.Decimal);
	assertEqual(cargo.weightCargo, 0.Decimal);
	cargo1 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertEqual(cargo1.totalWeight, 2000.Decimal);
	assertEqual(cargo1.weightCargo, 0.Decimal);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo);

	// first pack in 2  child containers
	create packTIs transient;
	packTIs.add(cargo);
	packTIs.add(cargo1);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 2, "Pack, container children incorrect");
	
	// unpack first container
	create unpackTIs transient;
	unpackTIs.add(cargo);
	self.unpackContainer(container1, unpackTIs);

	assertEqualMsg(container1.numChildren, 1, "Unpack, container children incorrect");
	
/*	
	// set the transaction dates 20 days back
	
	tranDate := now-20;
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);
	self.resetTransactionDate(ti2, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 0, "Initial storage transactions");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT);
	self.resetTransactionDate(ti1, tranTS);
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT);
	
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 5, "Final storage transactions");
*/
epilog
	delete unpackTIs;
	delete packTIs;
	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;

	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );

end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageDateForSplitCargo" id="95eb2854-4b20-4745-8001-1a04065192fc">
        <source>tStorageDateForSplitCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2020	jlgndl1	Initial creation	TFS 48528
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods

*/

constants

	VesselName1 : String = "UTFS";
	VoyageName : String = "UTFS01";
	BaseCargoId : String = "UTFS_";
	Cargo_Type : String = "UTREBAR";
	
vars

	oper : CM_Operator;
	term : CM_Terminal;
	testStartDate : Date;
	date : Date;
	index : Integer;
	mondayDischarge : Date;
	gateOutFriday : Date;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	bs : CM_BlockStack;
	bs2 : CM_BlockStack;
	moveController : CMIF_MoveController;
	ts : TimeStamp;
	cargoOnShip : CM_TrackedItem;
	singleGate : CM_Gate;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	cargoType : CM_CargoType;
	lc : CM_LocationsController;
	splitCargo : CM_TrackedItem;
	nowDate : Date;
	toTruckCargo : CM_TrackedItem;
	receivalTrans : CM_TITransaction;
	storageExpDetail : CM_StorageExpiryDetail; //14/09/2023 navmv20 CR 58250 Task 58252
	debtorType : CM_DebtorType;
	triggers : CM_StorageTriggerByType;
	pxyStorageTrigger : CM_StorageTrigger;
begin
	self.deleteVehicle("UTFST");

	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	aPort := app.myRoot.allPorts[term.getConfig(PortDestCode).String];
	
	deleteTerminalArea("UTBSL");
	deleteTerminalArea("UTBSM");
	
	self.deleteVehicle("UTFST");
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(VoyageName);
	deleteVessel(VesselName1);
	deleteCargo(BaseCargoId &amp; "01", cargoType);
	
	// ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1 - create a matching storage detail so that the free days works
	// STORAGE TRIGGERS
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageTAGroup, false, null);
	triggers.add(pxyStorageTrigger);

	// STORAGE CONFIG
	debtorType := app.myRoot.allDebtorTypes["SDT1"];	
	self.setupStorageConfig4(null,false,false,0,0,true,false,debtorType,triggers,true);
		
	
	
	nowDate := app.actualTimeAppServer.Date;
	testStartDate := ( nowDate - 63 ); // A couple of months ago.
	date := testStartDate;
	while index &lt; 7 do
		if date.dayOfWeek = 7 then
			mondayDischarge := date + 8;
		endif;
		index := index + 1;
		date := date + 1;
	endwhile;
	
	gateOutFriday := mondayDischarge + 11;
	
	//Create a Vessel, Voyage and cargo on board.
	
	bs := addBlockStack("UTBSL", 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, "No Blockstack created (UTBSL)");
	
	bs2 := addBlockStack("UTBSM", 100, null);
	self.assertTrueMsg( bs2 &lt;&gt; null, "No Blockstack created (UTBSM)");
	
	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	lc := voyage.myShipBlockStack;
	
	//create cargo on ship
	cargoOnShip := self.addCargoBreakBulkAtLocation(BaseCargoId &amp; "01", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargoOnShip);
	assertEqual(cargoOnShip.totalQuantity, 50);
	beginTransaction;
	cargoOnShip.evaluateFreeStorageDays(null,true);  //14/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
	cargoOnShip.setFreeStorageDays(5);
	commitTransaction;
	ts	:= cargoOnShip.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = nowDate + 5, "On ship cargo  free stortage date s/be 'now' Plus the 'free storage'(Test 1). Should be " &amp; (nowDate + 5).String &amp; " is " &amp; date.String); // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1
	
	//split off and discharge some of the cargo.
	create moveController transient;
	
	ts.setDate( mondayDischarge );
	moveController.setMyTrackedItem(cargoOnShip);	
	moveController.setMyOriginatingLocation(cargoOnShip.myPrimaryActualLocation);
	moveController.setMyToPrimaryLocation(bs.myLocationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.transferType := VESSEL_TYPE_RORO;
	moveController.isNonCraneVoyageMove := true;
	moveController.setEffectiveTimeStampOverride( ts );
	date := date + 1;
	moveController.quantity := 20;
	moveController.setWeight(20);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	splitCargo := moveController.myTrackedItem;
	delete moveController;
	ts	:= cargoOnShip.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = nowDate + 5, "On ship cargo 'free stortage date' s/be 'now' Plus the 'free storage'(Test 2). Should be " &amp; (nowDate + 5).String &amp; " is " &amp; date.String); // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1 // nothing has changed its still on the ship.
	
	ts	:= splitCargo.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = mondayDischarge + 5, "Split cargo 'free stortage date' s/be 'received date' Plus the 'free storage'(Test 3). Should be " &amp; (mondayDischarge + 5).String &amp; " is " &amp; date.String); // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1 // the split cargo (split to bring ashore), it has a receival trx plus free storage days
	
	
	// Gate in a truck
	// Load up a quarter of the split cargo and Gate out.
	
	self.deleteStops(splitCargo);
	
	create moveController transient;	
	ts.setDate( gateOutFriday );	
	moveController.setMyTrackedItem(splitCargo);	
	moveController.setMyOriginatingLocation(bs.myLocationsController);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.setEffectiveTimeStampOverride( ts );
	moveController.quantity := 5;
	moveController.weight := 5;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	toTruckCargo := moveController.myTrackedItem;
	delete moveController;
	
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutGC( "UTFST", "", "UTFSTDRIVER", toTruckCargo, singleGate , null ); 
	truck := vvr.vehicle;
	self.assertTrueMsg( truck &lt;&gt; null, "No Truck created");
	
	self.deleteStops(toTruckCargo);	
	
	create moveController transient;	
	ts.setDate( gateOutFriday );	
	moveController.setMyTrackedItem(toTruckCargo);	
	moveController.setMyOriginatingLocation(bs2.myLocationsController);
	moveController.setMyToPrimaryLocation(truck.locationsController);
	moveController.setMoveMode(REAL_MODE);
	moveController.setEffectiveTimeStampOverride( ts );
	moveController.quantity := 5;
	moveController.weight := 5;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	toTruckCargo := moveController.myTrackedItem;
	delete moveController;
			
	self.roadExit(vvr);	
	
	ts := toTruckCargo.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = mondayDischarge + 5, "Split cargo 'free storage date' s/be 'received date' Plus the 'free storage'(Test 4)");  // double split cargo (split to bring ashore, split to load to truck), it has a receival trx plus free storage days
	
	//now logically delete the receive trx and try again, to simulate TFS 48528 
	receivalTrans := toTruckCargo.findLastReceivalTrans();
	beginTransaction;
	receivalTrans.setPropertyValue( "deleted", true );
	commitTransaction;
	
	ts	:= toTruckCargo.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = nowDate + 5, "Double Split cargo (no receival trx) 'free storage date' s/be 'now' Plus the 'free storage'(Test 5)"); // no receival and split goes to parent receival date + free staorage

	//now logically delete the split parents create trx, to exercise the other option, i.e. the split parent creation time
	receivalTrans := splitCargo.findLastReceivalTrans();
	beginTransaction;
	receivalTrans.setPropertyValue( "deleted", true );
	commitTransaction;
	
	ts	:= toTruckCargo.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	date := ts.Date;
	self.assertTrueMsg( date = nowDate + 5, "Dounble split cargo ( no receival trx, parent has no receival either ) 'free storage date' s/be 'now' Plus the 'free storage'(Test 6)"); // no receival and split goes to parent creation date + free staorage

	
epilog
	triggers.purge();
	delete triggers;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalculationOthers" id="0458eff8-d3b7-4404-b425-fc9f2804f982">
        <updating/>
        <source>tStorageDaysCalculationOthers() updating;
/*

Purpose:			
		This UT test the storage days calculation for other customers that uses INV_CALC_TYPE_DAYS_SINCE_RECVL
Parameters:			

Return Value:		

Date		Who		Reason
01/08/2023	navkc1	CR 59342  Task 59500: Jade - Storage Charging for Additional Storage
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods

*/
constants
	TRUCK 			: String = "UTTRUCK";
	TAREA			: String = "UTSTORE3";
vars
	storageConfig 			: CM_StorageConfig;
	terminal				: CM_Terminal;
	bs						: CM_BlockStack;
	voy 					: CM_Voyage;
	ti 						: CM_TrackedItem;
	aPort 					: CM_Port;
	vvr 					: CM_VehicleVisitRecord;
	dualGate				: CM_Gate;
	pin						: CM_GateArea;
	pout					: CM_GateArea;
	operator				: CM_Operator;
	vehicle					: CM_Vehicle;
	transaction 			: CM_TITransaction;
	storageDetails 			: CM_StorageDetail;
	bank					: CM_Bank;
	storageConfigType 		: CM_StorageConfigType;
	invType					: CM_InvoiceDesc;
	calType1				: CM_CalculationType;
	theService 				: CM_Service;
	services 				: CM_ServiceByNameDict;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  			: CM_InvoiceLineDesc;
	fileContent : String;
	fileName	: String;
	mapName		: String;
	cargoMap	: CM_TranMap;
	
	tiId					: String;
	today,
	backdate				: Date;
	dateTime				: TimeStamp;
	days					: Integer;
	originalTime			: Time;
	midnight				: Time;

	storageDtlCriteria		: IntegerArray;
	storageDtlCriteriaValue	: ObjectArray;
begin
	create services transient;
	
	// Delete any existing Storage Config, and create a default one
	self.deleteStorageConfig(true);
	// Get terminal
	terminal := self.getMyTerminal();
	// Get storage Config
	storageConfig := terminal.myStorageConfig;
	// Set to include First and Last day - This is the configuration PNL is currently using.
	beginTransaction;
		storageConfig.setPropertyValue("includeFirstDay", true);
		storageConfig.setPropertyValue("includeLastDay", true);
	commitTransaction;
	
	// Delete area
	bs:= self.getTerminalArea(TAREA).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	
	// ==================================================
	// Delete transaction mapping and invoice stuff start
	// ==================================================
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);
	// ==================================================
	// Delete transaction mapping and invoice stuff end
	// ==================================================
	
	// =====================================================================
	// Create Transaction Mapping &amp; Invoice stuff for Storage charges starts
	// =====================================================================
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	fileName := "CargoLoaded";
	mapName := "UT_Storage";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,00 to 5,UT_LineTypeStore1' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,06 to 9,UT_LineTypeStore2' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,10 to 15,UT_LineTypeStore3' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,16 to MAX,UT_LineTypeStore4' &amp; CrLf;

	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	
	originalTime := bank.onsiteStorageChargeTime;
	beginTransaction;
	bank.setPropertyValue("onsiteStorageChargeTime", midnight);
	commitTransaction;
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	// =====================================================================
	// Create Transaction Mapping &amp; Invoice stuff for Storage charges ends
	// =====================================================================
	
	// Create a fresh area
	bs:= addBlockStack(TAREA, 100, null);
	// Set Port
	aPort := app.myRoot.allPorts["NZAKL"];
	// Create voyage
	voy :=self.createVesselVoyage3();
	
	// Create storage details
	create storageDtlCriteria transient;
	create storageDtlCriteriaValue transient;
	
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCriteriaValue.add(self.getCargoType("CONT"));
	
	// Free 3 storage days
	storageDetails := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCriteriaValue, 3, 0, false, false, 0, 0, false, null);
	self.assertNotNull(storageDetails);
	
	// This is our TI ID UTKIAT
	tiId := "UTKIAT";
	
	ti := self.getTrackedItem(tiId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
	endif;
	
	// Prepare data for Gate in TI
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	
	// Gate in TI UTKIAT
	vvr := self.gateInContainer(TRUCK, tiId, "2200", operator.code, "MT", dualGate);
	ti := self.getTrackedItem(tiId);
	vehicle := getVehicle(TRUCK);
	
	// Process vehicle
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);

	// Get out
	self.roadExit(vvr);
	
	// Now we backdate the all transactions to 7 days ago
	beginTransaction;
	backdate := today - 7;	
	foreach transaction in ti.allTransactions do
		dateTime := transaction.dateTime;
		dateTime.setDate(backdate);
		transaction.setPropertyValue("dateTime", dateTime);
	endforeach;
	ti.setPropertyValue("receivedDT", dateTime);
	ti.evaluateFreeStorageDays(null,true); //15/09/2023 navmv20 CR 58250 Task 58252	//22.05.2024 navma1 #64224
	commitTransaction;
	
	// Gate out UTKIAT
	ti := self.getTrackedItem("UTKIAT");
	self.assertNotNull(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	bank := self.myBank;
	self.assertNotNull(bank);
	
	storageConfigType := terminal.getMyStorageConfigType();
	self.assertNotNull(storageConfigType);
	
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	
	days := storageConfigType.evaluateDaysOnsiteAtCalendar(	bank, 
															transaction.getStartDateTime(INV_CALC_TYPE_DAYS_SINCE_RECVL), 
															transaction.dateTime, 
															transaction.getChargedDaysWorking(), 
															transaction.getChargedDaysWorkingAndComp(), 
															transaction).Integer;
	// The expected storage day for this TI is 5
	// =======
	// Example 
	// =======
	// Cargo is received on 01/07/2023
	// We have Free Storage 3 days, Include First and Last day
	// Which means Free storage ends on 03/07/2023
	// Cargo is then release on 08/07/2023
	// Storage days is from 04/07/2023 to 08/07/2023 = 5 days;
	self.assertEqualMsg(days, 5, "Storage days incorrect");
 
epilog
	delete storageDtlCriteria;
	delete storageDtlCriteriaValue;
	delete services;
	beginTransaction;
		bank.setPropertyValue("onsiteStorageChargeTime", originalTime);
	commitTransaction;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalculationPNL" id="d9d13305-1a84-4373-9cb5-dff51905914c">
        <updating/>
        <source>tStorageDaysCalculationPNL() updating;
/*

Purpose:			
		This UT test the storage days calculation for PNL. They are using INV_CALC_TYPE_DAYS_ONSITE_AT
Parameters:			

Return Value:		

Date		Who		Reason
01/08/2023	navkc1	CR 59342  Task 59500: Jade - Storage Charging for Additional Storage
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors

*/
constants
	TRUCK 			: String = "UTTRUCK";
	TAREA			: String = "UTSTORE3";
vars
	storageConfig 			: CM_StorageConfig;
	terminal				: CM_Terminal;
	bs						: CM_BlockStack;
	voy 					: CM_Voyage;
	ti 						: CM_TrackedItem;
	aPort 					: CM_Port;
	vvr 					: CM_VehicleVisitRecord;
	dualGate				: CM_Gate;
	pin						: CM_GateArea;
	pout					: CM_GateArea;
	operator				: CM_Operator;
	vehicle					: CM_Vehicle;
	transaction 			: CM_TITransaction;
	storageDetails 			: CM_StorageDetail;
	bank					: CM_Bank;
	storageConfigType 		: CM_StorageConfigType;
	invType					: CM_InvoiceDesc;
	calType1				: CM_CalculationType;
	theService 				: CM_Service;
	services 				: CM_ServiceByNameDict;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  			: CM_InvoiceLineDesc;
	fileContent : String;
	fileName	: String;
	mapName		: String;
	cargoMap	: CM_TranMap;
	
	tiId					: String;
	today,
	backdate				: Date;
	dateTime				: TimeStamp;
	days					: Integer;
	originalTime			: Time;
	midnight				: Time;
	changedTime				: Time;

	storageDtlCriteria		: IntegerArray;
	storageDtlCriteriaValue	: ObjectArray;
begin
	create services transient;
	
	// Delete any existing Storage Config, and create a default one
	self.deleteStorageConfig(true);
	// Get terminal
	terminal := self.getMyTerminal();
	// Get storage Config
	storageConfig := terminal.myStorageConfig;
	// Set to include First and Last day - This is the configuration PNL is currently using.
	beginTransaction;
		storageConfig.setPropertyValue("includeFirstDay", true);
		storageConfig.setPropertyValue("includeLastDay", true);
	commitTransaction;
	
	// Delete area
	bs:= self.getTerminalArea(TAREA).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	
	// ==================================================
	// Delete transaction mapping and invoice stuff start
	// ==================================================
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);
	// ==================================================
	// Delete transaction mapping and invoice stuff end
	// ==================================================
	
	// =====================================================================
	// Create Transaction Mapping &amp; Invoice stuff for Storage charges starts
	// =====================================================================
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT07'];	// INV_CALC_TYPE_DAYS_ONSITE_AT;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_ONSITE_AT not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	fileName := "CargoLoaded";
	mapName := "UT_Storage";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT07 Days Onsite At »,00 to 5,UT_LineTypeStore1' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT07 Days Onsite At »,06 to 9,UT_LineTypeStore2' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT07 Days Onsite At »,10 to 15,UT_LineTypeStore3' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT07 Days Onsite At »,16 to MAX,UT_LineTypeStore4' &amp; CrLf;

	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	
	originalTime := bank.onsiteStorageChargeTime;
	midnight.setTime(00, 01, 0,0);
	beginTransaction;
	bank.setPropertyValue("onsiteStorageChargeTime", midnight);
	commitTransaction;
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	// =====================================================================
	// Create Transaction Mapping &amp; Invoice stuff for Storage charges ends
	// =====================================================================
	
	// Create a fresh area
	bs:= addBlockStack(TAREA, 100, null);
	// Set Port
	aPort := app.myRoot.allPorts["NZAKL"];
	// Create voyage
	voy :=self.createVesselVoyage3();
	
	// Create storage details
	create storageDtlCriteria transient;
	create storageDtlCriteriaValue transient;
	
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCriteriaValue.add(self.getCargoType("CONT"));
	
	// Free 3 storage days
	storageDetails := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCriteriaValue, 3, 0, false, false, 0, 0, false, null);
	self.assertNotNull(storageDetails);
	
	// This is our TI ID UTKIAT
	tiId := "UTKIAT";
	
	ti := self.getTrackedItem(tiId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
	endif;
	
	// Prepare data for Gate in TI
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	
	// Gate in TI UTKIAT
	vvr := self.gateInContainer(TRUCK, tiId, "2200", operator.code, "MT", dualGate);
	ti := self.getTrackedItem(tiId);
	vehicle := getVehicle(TRUCK);
	
	// Process vehicle
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);

	// Get out
	self.roadExit(vvr);
	
	// Now we backdate the all transactions to 7 days ago
	beginTransaction;
	backdate := today - 7;	
	foreach transaction in ti.allTransactions do
		dateTime := transaction.dateTime;
		dateTime.setDate(backdate);
		transaction.setPropertyValue("dateTime", dateTime);
	endforeach;
	ti.setPropertyValue("receivedDT", dateTime);
	ti.evaluateFreeStorageDays(null,true); //14/09/2023 navmv20 CR 58250 Task 58252	//22.05.2024 navma1 #64224
	commitTransaction;
	
	// Gate out UTKIAT
	ti := self.getTrackedItem("UTKIAT");
	self.assertNotNull(ti);
	vvr := self.gateOutContainer(TRUCK, "", "UTDRIVER", ti.CM_Container, true, dualGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	bank := self.myBank;
	self.assertNotNull(bank);
	
	storageConfigType := terminal.getMyStorageConfigType();
	self.assertNotNull(storageConfigType);
	
	transaction := ti.getLastTransOfType(TRANS_TYPE_STORAGE);
	self.assertNotNull(transaction);
	
	changedTime.setTime(01, 0, 0, 0);
	dateTime.setDate(transaction.dateTime.date());
	dateTime.setTime(changedTime);
	beginTransaction;
		transaction.setPropertyValue("dateTime", dateTime);
	commitTransaction;
	
	days := storageConfigType.evaluateDaysOnsiteAtCalendar(	bank, 
															transaction.getStartDateTime(INV_CALC_TYPE_DAYS_ONSITE_AT), 
															transaction.dateTime, 
															transaction.getChargedDaysWorking(), 
															transaction.getChargedDaysWorkingAndComp(), 
															transaction).Integer;
	// The expected storage day for this TI is 5
	// =======
	// Example 
	// =======
	// Cargo is received on 01/07/2023
	// We have Free Storage 3 days, Include First and Last day
	// Which means Free storage ends on 03/07/2023
	// Cargo is then release on 08/07/2023
	// Storage days is from 04/07/2023 to 08/07/2023 = 5 days;
	self.assertEqualMsg(days, 5, "Storage days incorrect");
 
epilog
	delete storageDtlCriteria;
	delete storageDtlCriteriaValue;
	delete services;
	beginTransaction;
		bank.setPropertyValue("onsiteStorageChargeTime", originalTime);
	commitTransaction;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageTriggerUnpackAsChild" id="a315d665-da34-4ee6-88d1-9e9d6a073fd2">
        <source>tStorageTriggerUnpackAsChild();
/*

Purpose:		JIRA 33744. Test the storage trigger Unpack As Child

Date		Who		Reason
21 January 2025	navab1	Initial creation

*/

constants
	CARGOTYPEDESC 		= "UT_ABPULP";
	PARENTID = "PARU2501210";
	CHILDID = "CHILD250121-100";
vars
	ti				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	cargoType 		: CM_CargoType;
	transaction		: CM_TITransaction;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	opCode : String;
	container1 : CM_Container;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	tis : CM_TIArray;
	now : TimeStamp;
begin
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( UnpackAsChild, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	
	// #########################################
	// #### PARENT and CHILD
	// #########################################
	
	self.deleteContainer(PARENTID);
	self.deleteCargo(CHILDID,cargoType);
	
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	container1 := self.addContainerOpts(PARENTID, "2200", "GENL", self.getOperator(opCode)).CM_Container;	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	create attach transient;
	attach.set(getTerminal, cargoType.id, CHILDID, "", 100); 
	attach.operatorCode := opCode;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
	self.addContainerChildren(container1.CM_Container, attachments);
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	
	ti := container1.allChildren.first;
	create tis transient;
	tis.add(ti);
	
	now := now.addDays(-20);
	
	beginTransaction;
	transaction := ti.getTransactionOfType(TRANS_TYPE_CREATED);
	transaction.setPropertyValue("dateTime",now);
	container1.setReceivedDT(now);
	ti.setReceivedDT(now);
	
	ti.evaluateFreeStorageDays(now.date, false);
	commitTransaction;
	self.unpackContainer(container1,tis);
	
	transaction := ti.getTransactionOfType(TRANS_TYPE_STORAGE);
	
	self.assertTrueMsg(transaction &lt;&gt; null, "Storage transaction not created by trigger");
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	self.deleteContainer(PARENTID);
	self.deleteCargo(CHILDID,cargoType);
	
epilog
	if attachments &lt;&gt; null then
		attachments.purge;
	endif;
	delete attachments;
	delete tis;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageTriggerUnpackAsChild2" id="a985f143-5fbd-401e-bb01-026f3b901a2e">
        <source>tStorageTriggerUnpackAsChild2();
/*

Purpose:			Repeats the same test as tStorageTriggerUnpackAsChild but using the trxUpdateUnpackCargo method
					instead of trxUpdatePackUnpack

Parameters:			

Return Value:		

Date				Who		Reason
09 July 2025		jlizm1	Initial creation MTN 35183 Storage transaction not created during unpack

*/

constants
	CARGOTYPEDESC 	= "UT_ABPULP";
	PARENTID 		= "PARU2501210";
	CHILDID 		= "CHILD250121-100";
	
vars
	ti				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	cargoType 		: CM_CargoType;
	transaction		: CM_TITransaction;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	opCode : String;
	container1 : CM_Container;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	tis : CM_TIArray;
	now : TimeStamp;
	bs	: CM_BlockStack;
	lc	: CM_LocationsController;
	
begin
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( UnpackAsChild, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	
	// #########################################
	// #### PARENT and CHILD
	// #########################################
	
	self.deleteContainer(PARENTID);
	self.deleteCargo(CHILDID,cargoType);
	
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	container1 := self.addContainerOpts(PARENTID, "2200", "GENL", self.getOperator(opCode)).CM_Container;	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	create attach transient;
	attach.set(getTerminal, cargoType.id, CHILDID, "", 100); 
	attach.operatorCode := opCode;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
	self.addContainerChildren(container1.CM_Container, attachments);
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	
	ti := container1.allChildren.first;
	create tis transient;
	tis.add(ti);
	
	bs := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString].CM_BlockStack;
	if bs = null then
		bs := self.addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 1000, null);
	endif;
	lc := bs.myLocationsController;
	
	now := now.addDays(-20);
	
	beginTransaction;
	transaction := ti.getTransactionOfType(TRANS_TYPE_CREATED);
	transaction.setPropertyValue("dateTime",now);
	container1.setReceivedDT(now);
	ti.setReceivedDT(now);
	ti.evaluateFreeStorageDays(now.date, false);
	commitTransaction;
	
	app.myTrxUA.trxUpdateUnpackCargo(ti, lc, ti.totalQuantity, ti.totalWeight, false, null, app.myPassport);
	
	transaction := ti.getTransactionOfType(TRANS_TYPE_STORAGE);
	
	self.assertTrueMsg(transaction &lt;&gt; null, "Storage transaction not created by trigger");
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	self.deleteContainer(PARENTID);
	self.deleteCargo(CHILDID,cargoType);
	
epilog
	if attachments &lt;&gt; null then
		attachments.purge;
	endif;
	delete attachments;
	delete tis;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTest9b" id="aeb54591-2a4f-496d-941b-43cc0256174d">
        <updating/>
        <source>tTest9b() updating;
// cnwns1

/*

Purpose:			Test using storage config with use last days only but with no free storage days
					(This should be the same as the no-config test of tTest9a - repeating the UT_Invoicing firstLastStorage test here)

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2012	cnwjre1	Initial creation

*/

vars

	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
begin

	self.deleteStorageConfig( false );

	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, false, 0, 0, 0);	// TFS 2570

	self.importExportStorage2(false, storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tTest9c" id="063debf9-7f70-4f86-9d6e-27272e94f7d0">
        <updating/>
        <source>tTest9c() updating;
// cnwns1

/*

Purpose:			Test using storage config with use first and last days only but with no free storage days
					(This should be the same as the no-config test with the 'true' option set)

Parameters:			

Return Value:		


