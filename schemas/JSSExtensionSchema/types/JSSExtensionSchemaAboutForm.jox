    <JadeMethod name="load" id="cebc2258-6404-42e2-b164-fe9d4a6c4f94">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		18 February 2000 -  load
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	lblSchemaVersion.caption	:=	" " &amp; JSS_SCHEMA_VERSION;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
