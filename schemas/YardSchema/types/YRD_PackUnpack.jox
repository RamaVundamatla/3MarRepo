    <JadeMethod name="doUnpackSelected" id="74f986c5-cbbc-4633-89bf-36eab3b5da89">
        <updating/>
        <source>doUnpackSelected() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// 21/07/2014	cnwma1		PAR #34021 - Unpack does not clear data from previous voyage
// 23/11/2015   cnwma1      PAR #37201 - Impossible to Unpack items from cntr packed in the 8.4.2
vars
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	foundRow			: Boolean;
begin
	tbl := self.tblPacked;
	numRows := tbl.rows;
	if numRows = tbl.fixedRows then
		return;
	endif;
	//unpacking an item removes it from the packed table, and puts it in the unpacked table, so the number of
	//rows in tblPacked will be changing each time we unpack one of the selected items (they can multi-select) 
	//hence the need for the while loop
	while true do : trueLoop
		foundRow := false;
		foreach row in tbl.fixedRows to numRows do : rowLoop
			if tbl.accessRow(row).selected then
				foundRow := true;	
				if (not self.unpackItem(row)) then
					break trueLoop;
				else
					break rowLoop;
				endif;
			endif;
		endforeach;
		
		if foundRow = false then //no more rows are selected
			break trueLoop;
		endif;
		numRows := tbl.rows;
			
	endwhile;
	
	if self.tblPacked.rows = self.tblPacked.fixedRows then
		// 05 May 2015	NDL	Par 36160 - remove "SuppressImexUpdateOnPack" check
		// 02/03/2009 cnwar2 #18775 - new config to prevent auto updating of imex or commodity
	//	if self.myTerminal.getConfig(SuppressImexUpdateOnPack).Boolean then
	//		self.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);
	//	else
			self.setContentsImExStatus(TI_CONTENTS_STATUS_EMPTY, TI_IMEX_STATUS_STORAGE);
	//	endif;
		
		// 22/07/2014	cnwma1		PAR #34021
		self.tblContainer.setValueByName(ETRow_AllowableTimeOffPower,null);
		self.tblContainer.setValueByName(ETRow_CurtainsIn,false);
		self.tblContainer.setValueByName(ETRow_CO2,null);
		self.tblContainer.setValueByName(ETRow_O2,null);
		self.tblContainer.setValueByName(ETRow_Humidity,null);
		self.tblContainer.setValueByName(ETRow_Ventilation,null);
		self.tblContainer.setValueByName(ETRow_CarriageTemp,null);
		// 22/07/2014	cnwma1		PAR #34021
		self.tblContainer.setValueByName(ETRow_BookingReference,null);	// cnwma1 23/11/2015 PAR #37201
		self.tblContainer.setValueByName(ETRow_BookingItem,null);		// cnwma1 23/11/2015 PAR #37201
		
		self.allWarnings.clear();
		
	else
		// 05 May 2015	NDL	Par 36160 - remove "SuppressImexUpdateOnPack" check
		// 02/03/2009 cnwar2 #18775 - new config to prevent auto updating of imex or commodity
	//	if self.myTerminal.getConfig(SuppressImexUpdateOnPack).Boolean then
	//		self.setContentsStatus(TI_CONTENTS_STATUS_LCL);
	//	else
			self.setContentsImExStatus(TI_CONTENTS_STATUS_LCL, self.theTIimexStatus);
	//	endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotes" id="a297da23-e4dd-4357-88ed-cd1086122b98">
        <updating/>
        <source>doUserNotes(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     29 December 2005	cnwhjg1
//
// Purpose:     
// 13 Apr 2024	navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
// ----------   ----------  --------------------------------------------------
vars

	event		: Integer;
	anObject : Object;
	theTI : CM_TrackedItem;
begin
	
	event := self.myTerminal.getEventFromTerminalEvent(_eventType);
	
// was not adding stuff moved into current teminal area.
// ### to use new EVENT_TI_MOVE_FROM_LOCATION and EVENT_TI_MOVE_TO_LOCATION notes.
// ### NOTE actual TI update is handled when TI is added to screen.

	if _eventType = CMUI_AttachBreakBulkModal.LCLCargosCreated			//13.04.2024 navnk30 #63247
		and _userInfo &lt;&gt; null
		and _userInfo.isKindOf(CM_TISet) then
		self.displayTableTrackedItem(_userInfo.CM_TISet);
	elseif event = EVENT_TI_MOVE_FROM_LOCATION 
	or event = EVENT_TI_MOVE_TO_LOCATION then
		if _userInfo &lt;&gt; null then
			if _userInfo.isKindOf(CM_TrackedItem) then
				theTI := _userInfo.CM_TrackedItem;
			endif;
			
		endif;
	
		self.doTblDataUserNoteTI(_theObject.CM_TerminalArea, theTI, event);
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
