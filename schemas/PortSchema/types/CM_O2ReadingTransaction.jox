<Class name="CM_O2ReadingTransaction" id="4c3cc272-d928-4c07-b110-88a499e05490">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="myO2Reading" id="258bd151-8a3c-4b1d-8dc1-ae7667478978">
        <embedded/>
        <type name="CM_O2Reading"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneForTrackedItemRefs" id="4761e67a-8bb8-4e8c-aca8-1b0878057f61">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_O2ReadingTransaction) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	inheritMethod(_ti, _orginalTransaction);

	self.myO2Reading := _orginalTransaction.myO2Reading.cloneSelf(self.isTransient);
	self.myO2Reading.cloneForTrackedItemRefs(_ti);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_O2ReadingTransaction"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c1befde0-13f8-4575-b826-16e9df47dc19">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20 January 2026	navdap1		Initial creation TFS 
//
vars
	o2 : CM_O2Reading;
	detail : String;

begin
	if _attrName = ETRow_Details or _attrName = ETRow_CO2 then
		if self.deleted then
			return self.getDeletedDetails();
		else
			o2 := self.myO2Reading;
			if o2 &lt;&gt; null then
				detail := o2.o2.asStringJMT;
			endif;
			return detail;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="18e57587-2a22-4b9c-a744-72bd9736a026">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/01/2026	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.setMyO2Reading(_tiTransCntrl.CMIF_O2TransController.myO2Reading);
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyO2Reading" id="daaf560e-5c16-4cba-b6e3-1601e80502fe">
        <updating/>
        <source>setMyO2Reading(_o2Reading : CM_O2Reading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.myO2Reading := _o2Reading;
epilog

end;</source>
        <Parameter name="_o2Reading" type="CM_O2Reading"/>
    </JadeMethod>
</Class>
