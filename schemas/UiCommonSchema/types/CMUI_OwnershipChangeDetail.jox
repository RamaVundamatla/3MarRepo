    <JadeMethod name="createProxies" id="ec759f77-2f95-410f-9e6a-990bde80c603">
        <updating/>
        <source>createProxies()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars
	pxy, real : CM_OwnershipChangeDetail;
begin
	delete self.myProxyDetail;
	self.detailsSet.purge();
	
	self.myProxyDetail := app.createUpdateProxy(self.myOwnershipChangeDetail).CM_OwnershipChangeDetail;
	
	foreach real in self.myOwnershipChangeDetail.allSubDetails discreteLock do
		pxy := app.createUpdateProxy(real).CM_OwnershipChangeDetail;
		self.detailsSet.add(pxy);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayContentTotals" id="9e5f2539-b9f1-4e43-96cb-b3255473c5e6">
        <source>displayContentTotals(_currentDetail : CM_OwnershipChangeDetail);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars
	trackdItem  : CM_TrackedItem;
	ownershipChangeDetail 	: CM_OwnershipChangeDetail;
	col, row , quantity, contentQuantity : Integer;
	weight, volume, volumeM3, weightKG, contentWeight, contentVolume : Decimal [23,4];
	indicator : String;
	table : CM_DataTable;
	ct : CM_CargoType;
begin
	table := self.tblData;
	col := table.getColumnByRowName(ETRow_Include);
	trackdItem := _currentDetail.myTrackedItem;
	 // ### TFS BUG 60193 01SEP2023 NAVAB1
	if trackdItem.isCargoGroupItem then
		trackdItem := trackdItem.CM_CargoGroup.allAssignedTrackedItems.first;
		ct := trackdItem.myCargoType;
		
		// ### TFS 60508 15SEP2023 NAVAB1 - moved this loop inside this IF
		foreach row in 2 to table.rows do

			table.accessRow(row);
			ownershipChangeDetail := table.accessedRow.itemObject.CM_OwnershipChangeDetail;
			table.accessCell(row,col);
			if table.accessedCell.text = true.cnEcGetTableCheckBoxValue then
				quantity := quantity + ownershipChangeDetail.transferredQuantity;
				weight 	:= weight	 + ownershipChangeDetail.transferredWeight;
				volume  := volume 	+ 	ownershipChangeDetail.transferredVolume;
				ownershipChangeDetail.setInclude(true);

			else
				ownershipChangeDetail.setInclude(false);
			endif;
			
		endforeach;
	else // ### TFS 60508 15SEP2023 NAVAB1
		ct := trackdItem.myCargoType;
		ownershipChangeDetail := self.myProxyDetail;
		quantity := quantity + ownershipChangeDetail.transferredQuantity;
		weight 	:= weight	 + ownershipChangeDetail.transferredWeight;
		volume  := volume 	+ 	ownershipChangeDetail.transferredVolume;
	endif;
	
	// ### TFS BUG 64115 13MAY2024 NAVAB1 rewrote, based on CMUI_CustomDocDetail
	self.lblDisplayContentQuantity.caption	:= quantity.String;	
	self.lblDisplayContentWeight.caption := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,weight).String &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; // ### TFS BUG 62187 14FEB2024 NAVAB1 //27/01/2025	navkc1 JIRA Bug MTN-33535
	self.lblDisplayContentVolume.caption := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,volume).String &amp; " " &amp; self.myMeasurementTypeForVolume.shortName; // ### TFS BUG 62187 14FEB2024 NAVAB1 //27/01/2025	navkc1 JIRA Bug MTN-33535
	
	volumeM3 := self.txtTransferVolume.getConvertedValue();
	if volumeM3 = volume then
		self.lblDisplayContentVolume.foreColor := Green;
	else
		self.lblDisplayContentVolume.foreColor := Red;
		contentVolume := (volumeM3 - volume) * -1;
		indicator := "";
		if contentVolume &gt; 0 then
			indicator := "+";
		endif;
		
		self.lblDisplayContentVolume.caption :=  self.lblDisplayContentVolume.caption &amp; " ( " &amp; indicator &amp;  app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,contentVolume).String &amp; " " &amp; self.myMeasurementTypeForVolume.shortName &amp; ")" ; // app.getVolumeForDefaultDisplay(contentVolume).String &amp; " )"; //27/01/2025	navkc1 JIRA Bug MTN-33535
	endif;
	
	
	weightKG := self.txtTransferWeight.getConvertedValue();
	if weightKG = weight then
		self.lblDisplayContentWeight.foreColor := Green;
			
	else
		self.lblDisplayContentWeight.foreColor := Red;
		contentWeight := (weightKG - weight) * -1;
		indicator := "";
		if contentWeight &gt; 0 then
			indicator := "+";
		endif;
		
		self.lblDisplayContentWeight.caption :=  self.lblDisplayContentWeight.caption &amp; " ( " &amp; indicator &amp; app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,contentWeight).String &amp; " " &amp; self.myMeasurementTypeForWeight.shortName &amp; ")" ; //27/01/2025	navkc1 JIRA Bug MTN-33535
	endif;			

	if self.txtTransferQuantity.text.Integer = quantity then
		self.lblDisplayContentQuantity.foreColor := Green;
	else
		self.lblDisplayContentQuantity.foreColor := Red;
		contentQuantity := (self.txtTransferQuantity.text.Integer - quantity) * -1;
		indicator := "";
		if contentQuantity &gt; 0 then
			indicator := "+";
		endif;
		self.lblDisplayContentQuantity.caption :=  self.lblDisplayContentQuantity.caption &amp; " ( " &amp; indicator &amp; contentQuantity.String &amp; " )";
	endif;	

	self.displayStatus();
epilog

end;</source>
        <Parameter name="_currentDetail" type="CM_OwnershipChangeDetail"/>
    </JadeMethod>
    <JadeMethod name="displayOwnershipDetail" id="c0acaf95-89c2-4eb7-8abb-4f57052d6432">
        <updating/>
        <source>displayOwnershipDetail()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
07 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	weight, volume,
	totalWeight, totalVolume: String; //07 Aug 2023 navmv20 CR 59440 Task 59441
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
	cooDetail : CM_OwnershipChangeDetail;
	col, row , quantity,transferedQuantity : Integer;
	weight1, volume1,transferedweight, transferedvolume, portion: Decimal [23,4]; //07 Aug 2023 navmv20 CR 59440 Task 59441
	ct : CM_CargoType;
	ti, subTI : CM_TrackedItem;
begin 
	if self.myOwnershipChangeDetail &lt;&gt; null then
		self.setCaption(self.caption &amp; " " &amp; self.myOwnershipChangeDetail.auditId());
		
		ti := self.myOwnershipChangeDetail.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.isCargoGroupItem() then
				subTI := ti.CM_CargoGroup.allAssignedTrackedItems.first;
			else
				subTI := ti;
			endif;
			if subTI = null then
				self.txtTransferQuantity.enabled := false;
				self.txtTransferVolume.enabled := false;
				self.txtTransferWeight.enabled := false;
				return;
			endif;

			ct := subTI.myCargoType;
			
			if ct.isBulk() then
				self.txtTransferQuantity.text			:= self.myOwnershipChangeDetail.transferredQuantity.String;
				self.txtTransferQuantity.enabled := false;
				self.lblDisplayCurrentQuantity.caption := self.totalQuantity.String; // ### TFS BUG 62187 14FEB2024 NAVAB1

				weightMeasurement := self.myMeasurementTypeForWeight;
				weight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  self.myOwnershipChangeDetail.transferredWeight);
				totalWeight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  ti.totalWeight); 
				self.txtTransferWeight.setValues(weight &amp; Space &amp; weightMeasurement.shortName);
				self.txtTransferCargoWeight.setValues("0" &amp; Space &amp; weightMeasurement.shortName);
				self.lblDisplayCurrentWeight.caption	:= totalWeight.asStringJMT() &amp; Space &amp; weightMeasurement.shortName; 

				volumeMeasurement := self.myMeasurementTypeForVolume;
				totalVolume := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  ti.totalVolume); 
				volume := app.convertMeasurementForDisplay(volumeMeasurement.shortName, self.myOwnershipChangeDetail.transferredVolume);
				self.txtTransferVolume.setValues(volume &amp; Space &amp; volumeMeasurement.shortName);
				self.txtTransferCargoVolume.setValues("0" &amp; Space &amp; volumeMeasurement.shortName);
				self.lblDisplayCurrentVolume.caption	:= totalVolume.asStringJMT() &amp; Space &amp; volumeMeasurement.shortName; 

				if ct.isTrackByWeight then

					self.txtTransferWeight.enabled := true;
					self.txtTransferVolume.enabled := false;
					self.txtTransferWeight.setFocus();
				else
					self.txtTransferWeight.enabled := false;
					self.txtTransferVolume.enabled := true;
					self.txtTransferVolume.setFocus();
				
				endif;
			else
				self.lblDisplayCurrentQuantity.caption := self.totalQuantity.String; 
				self.txtTransferQuantity.text			:= self.myOwnershipChangeDetail.transferredQuantity.String;
				self.txtTransferQuantity.enabled := true;
				self.txtTransferQuantity.setFocus();

				// ### TFS BUG 62187 14FEB2024 NAVAB1
				//portion := self.myOwnershipChangeDetail.transferredQuantity / self.totalQuantity;		//20.07.2024 navrv30 Bug 64858
				//self.lblDisplayCurrentWeight.caption	:= self.totalWeight.String; // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.lblDisplayCurrentWeight.caption := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,self.totalWeight) &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
				self.txtTransferWeight.setValue( self.myOwnershipChangeDetail.transferredWeight); // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.txtTransferWeight.enabled := false;

				// ### TFS BUG 64115 13MAY2024 NAVAB1
				//portion := self.myOwnershipChangeDetail.transferredQuantity / self.totalQuantity;		//20.07.2024 navrv30 Bug 64858
				//self.lblDisplayCurrentVolume.caption	:= self.totalVolume.String;
				self.txtTransferVolume.setValue( self.myOwnershipChangeDetail.transferredVolume); 
				self.txtTransferVolume.enabled := false;
				self.lblDisplayCurrentVolume.caption	:= app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,self.totalVolume)&amp; " " &amp; self.myMeasurementTypeForVolume.shortName;//27/01/2025	navkc1 JIRA Bug MTN-33535
				/*
				self.txtTransferVolume.text			:= null;
				self.lblDisplayCurrentVolume.caption	:= self.totalVolume.String; // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.txtTransferVolume.enabled := false;
				*/
			endif;
	
			/*
			ct := subTI.myCargoType;
			
			if ct.isBulk() then
				self.txtTransferQuantity.text			:= null;
				self.txtTransferQuantity.enabled := false;
				self.lblDisplayCurrentQuantity.caption	:= null;
			
				if ct.isTrackByWeight then

					weightMeasurement := self.myMeasurementTypeForWeight;
					weight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  self.myOwnershipChangeDetail.transferredWeight);
					//totalWeight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  ti.totalWeight); //07 Aug 2023 navmv20 CR 59440 Task 59441
					totalWeight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  self.totalWeight); //11/08/2023 navmv20 Bug 59697
					self.txtTransferWeight.setValues(weight &amp; Space &amp; weightMeasurement.shortName);
					self.txtTransferCargoWeight.setValues("0" &amp; Space &amp; weightMeasurement.shortName);
					//self.lblDisplayCurrentWeight.caption	:= weight.asStringJMT() &amp; Space &amp; weightMeasurement.shortName; //07 Aug 2023 navmv20 CR 59440 Task 59441
					self.lblDisplayCurrentWeight.caption	:= totalWeight.asStringJMT() &amp; Space &amp; weightMeasurement.shortName; //07 Aug 2023 navmv20 CR 59440 Task 59441
					self.txtTransferWeight.enabled := true;
					self.txtTransferVolume.enabled := false;
					self.txtTransferWeight.setFocus();
				else
					volumeMeasurement := self.myMeasurementTypeForVolume;
					//totalVolume := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  ti.totalVolume); //07 Aug 2023 navmv20 CR 59440 Task 59441
					totalVolume := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  self.totalVolume); //11/08/2023 navmv20 Bug 59697
					volume := app.convertMeasurementForDisplay(volumeMeasurement.shortName, self.myOwnershipChangeDetail.transferredVolume);
					self.txtTransferVolume.setValues(volume &amp; Space &amp; volumeMeasurement.shortName);
					self.txtTransferCargoVolume.setValues("0" &amp; Space &amp; volumeMeasurement.shortName);
					//self.lblDisplayCurrentVolume.caption	:= volume.asStringJMT() &amp; Space &amp; volumeMeasurement.shortName; //07 Aug 2023 navmv20 CR 59440 Task 59441
					self.lblDisplayCurrentVolume.caption	:= totalVolume.asStringJMT() &amp; Space &amp; volumeMeasurement.shortName; //07 Aug 2023 navmv20 CR 59440 Task 59441
					self.txtTransferWeight.enabled := false;
					self.txtTransferVolume.enabled := true;
					self.txtTransferVolume.setFocus();
				
				endif;
			else
				//self.lblDisplayCurrentQuantity.caption	:= ti.totalQuantity.String; //11/08/2023 navmv20 Bug 59697
				self.lblDisplayCurrentQuantity.caption := self.totalQuantity.String; //11/08/2023 navmv20 Bug 59697
				self.txtTransferQuantity.text			:= self.myOwnershipChangeDetail.transferredQuantity.String;
				self.txtTransferQuantity.enabled := true;
				self.txtTransferQuantity.setFocus();

				self.lblDisplayCurrentWeight.caption	:= null;
				self.txtTransferWeight.text			:= null;
				self.txtTransferWeight.enabled := false;

				self.txtTransferVolume.text			:= null;
				self.lblDisplayCurrentVolume.caption	:= null;
				self.txtTransferVolume.enabled := false;
			endif;
			*/
		endif;
	endif;
	
	if self.myOwnershipChangeDetail.allSubDetails.isNotEmpty() then
		self.displaySubDetails();
	endif;

	self.displayContentTotals(self.myOwnershipChangeDetail); // ### TFS BUG 59667 31AUG2023 NAVAB1
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="1c1911cf-dde2-4921-a295-f4f0e1338f49">
        <source>displayStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed
*/

vars
	ownershipChangeDetail : CM_OwnershipChangeDetail;
	col, row , quantity,transferedQuantity : Integer;
	weight, volume,transferedweight, transferedvolume : Decimal [23,4];
	weightStr, volumeStr, transferedWeightStr, transferedVolumeStr : String; //14/09/2023 navmv20 Bug 60217
begin
	
	// ### TFS 60508 15SEP2023 NAVAB1 - handle non cargo group, single items
	if self.myOwnershipChangeDetail &lt;&gt; null
	and (self.myOwnershipChangeDetail.allSubDetails.isEmpty() 
		and self.detailsSet.isEmpty()) //31/10/2024	navkc1 JIRA Bug MTN-32860 - also check whether we have proxies subdetails. If it does it's a cargo group
	then
		quantity := self.myOwnershipChangeDetail.myTrackedItem.totalQuantity;
		weight 	:= self.myOwnershipChangeDetail.myTrackedItem.totalWeight;
		volume  := 	self.myOwnershipChangeDetail.myTrackedItem.totalVolume;
		transferedQuantity := self.myProxyDetail.transferredQuantity;
		transferedweight 	:= self.myProxyDetail.transferredWeight;
		transferedvolume :=	self.myProxyDetail.transferredVolume;
		
	else
		
		col := tblData.getColumnByHeading(ETRow_Include);
		foreach row in 2 to self.tblData.rows do
		
			tblData.accessRow(row);
			ownershipChangeDetail := tblData.accessedRow.itemObject.CM_OwnershipChangeDetail;
			tblData.accessCell(row,col);
			if tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue then
				if ownershipChangeDetail.myTrackedItem &lt;&gt; null then
					quantity := quantity + ownershipChangeDetail.myTrackedItem.totalQuantity;
					weight 	:= weight	 + ownershipChangeDetail.myTrackedItem.totalWeight;
					volume  := volume 	+ 	ownershipChangeDetail.myTrackedItem.totalVolume;
					transferedQuantity := transferedQuantity + ownershipChangeDetail.transferredQuantity;
					transferedweight 	:= transferedweight	 + ownershipChangeDetail.transferredWeight;
					transferedvolume  := transferedvolume 	+ 	ownershipChangeDetail.transferredVolume;
				endif;
			endif;
		endforeach;
	endif;
	
	//14/09/2023 navmv20 Bug 60217 - start
	//weightStr := app.getWeightForDefaultDisplay(weight);
	weightStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,weight) &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//volumeStr := app.getVolumeForDefaultDisplay(volume);
	volumeStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,volume) &amp; " " &amp; self.myMeasurementTypeForVolume.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//transferedWeightStr := app.getWeightForDefaultDisplay(transferedweight);
	transferedWeightStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,transferedweight) &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//transferedVolumeStr := app.getVolumeForDefaultDisplay(transferedvolume);
	transferedVolumeStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,transferedvolume) &amp; " " &amp; self.myMeasurementTypeForVolume.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//14/09/2023 navmv20 Bug 60217 - end
	
	
	//14/09/2023 navmv20 Bug 60217 - start
	/*self.statusBar.caption :=  " Current Quantity " &amp; quantity.String 
		&amp;" Current Weight "&amp; weight.String &amp; " Current Volume "&amp; volume.String &amp;" | "&amp; " Transfer Quantity " &amp;transferedQuantity.String 
		&amp;" Transfer Weight "&amp; transferedweight.String &amp; " Transfer Volume "&amp;transferedvolume.String;*/
	self.statusBar.caption :=  " Current Quantity " &amp; quantity.asStringJMT() &amp;
		" Current Weight " &amp; weightStr &amp; 
		" Current Volume "&amp; volumeStr &amp; " | " &amp; 
		" Transfer Quantity " &amp;transferedQuantity.asStringJMT() &amp;
		" Transfer Weight "&amp; transferedWeightStr &amp; 
		" Transfer Volume "&amp;transferedVolumeStr;
	//14/09/2023 navmv20 Bug 60217 - end
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySubDetail" id="d7be7b0d-97d7-4a46-b407-c82e11f139d6">
        <source>displaySubDetail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars
	weightStr, volumeStr : String;
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
	trackdItem  : CM_TrackedItem;
	ownershipChangeDetail 	: CM_OwnershipChangeDetail;
	col, row , quantity,transferedQuantity : Integer;
	weight, volume,transferedweight, transferedvolume, contentWeight, contentVolume : Decimal [23,4];
	indicator : String;
	table : CM_DataTable;
	include, includeClicked, updateable : Boolean;
	ct : CM_CargoType;
begin
	table := self.tblData;
	if table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	col := table.getColumnByRowName(ETRow_Include);
	includeClicked := false;
	if col = table.column then // clicked 'include' column
		table.accessCell(table.row,col);
		include := table.accessedCell.text = true.cnEcGetTableCheckBoxValue ;
		includeClicked := true;
	endif;
	
	ownershipChangeDetail := table.allSelectedObjects.first.CM_OwnershipChangeDetail;
	
	trackdItem := ownershipChangeDetail.myTrackedItem;
	if trackdItem &lt;&gt; null then
		ct := trackdItem.myCargoType;
		updateable := ct.allowDuplicates and not self.cooHeaderIsApproved; // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		self.lblDisplayCargoCurrentQuantity.caption := trackdItem.totalQuantity.String;
		self.txtTransferCargoQuantity.text := ownershipChangeDetail.transferredQuantity.String;

		self.lblDisplayCargoCurrentVolume.caption	:= trackdItem.totalVolume.String;
		volumeMeasurement :=  self.myMeasurementTypeForVolume;
		
		volumeStr := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  ownershipChangeDetail.transferredVolume);
		self.txtTransferCargoVolume.setValues(volumeStr &amp; Space &amp; volumeMeasurement.shortName);
		self.txtTransferCargoVolume.enabled := updateable;

		weightMeasurement := self.myMeasurementTypeForWeight;
		weightStr := app.convertMeasurementForDisplay(weightMeasurement.shortName, ownershipChangeDetail.transferredWeight);
		self.txtTransferCargoWeight.setValues(weightStr &amp; Space &amp; weightMeasurement.shortName);

		self.lblDisplayCargoCurrentWeight.caption	:= trackdItem.totalWeight.String;
		self.txtTransferCargoWeight.enabled := updateable;
		
		if ct.isBulk() then
			if ct.isBulkByVolume then
				self.txtTransferCargoQuantity.enabled := false;
				self.txtTransferCargoWeight.enabled := false;
				self.txtTransferCargoVolume.enabled := updateable;
			else
				self.txtTransferCargoQuantity.enabled := false;
				self.txtTransferCargoWeight.enabled := updateable;
				self.txtTransferCargoVolume.enabled := false;
			endif;
		else
				self.txtTransferCargoQuantity.enabled := updateable;
				self.txtTransferCargoWeight.enabled := false;
				self.txtTransferCargoVolume.enabled := false;

		endif;
		
		
/*		
		if ct.isBulk() then
			self.lblDisplayCargoCurrentQuantity.caption := null;
			self.txtTransferCargoQuantity.text := null;
			self.txtTransferCargoQuantity.enabled := false;
			
			if ct.isBulkByVolume then
				self.lblDisplayCargoCurrentVolume.caption	:= trackdItem.totalVolume.String;
				volumeMeasurement :=  self.myMeasurementTypeForVolume;
				
				volumeStr := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  ownershipChangeDetail.transferredVolume);
				self.txtTransferCargoVolume.setValues(volumeStr &amp; Space &amp; volumeMeasurement.shortName);
				self.txtTransferCargoVolume.enabled := updateable;

				self.lblDisplayCargoCurrentWeight.caption	:= null;
				self.txtTransferCargoWeight.text := null;
				self.txtTransferCargoWeight.enabled := false;
			else
				weightMeasurement := self.myMeasurementTypeForWeight;
				weightStr := app.convertMeasurementForDisplay(weightMeasurement.shortName, ownershipChangeDetail.transferredWeight);
				self.txtTransferCargoWeight.setValues(weightStr &amp; Space &amp; weightMeasurement.shortName);

				self.lblDisplayCargoCurrentWeight.caption	:= trackdItem.totalWeight.String;
				self.txtTransferCargoWeight.enabled := updateable;

				self.lblDisplayCargoCurrentVolume.caption	:= null;
				self.txtTransferCargoVolume.text := null;
				self.txtTransferCargoVolume.enabled := false;
			endif;
		
		else
			self.lblDisplayCargoCurrentQuantity.caption := trackdItem.totalQuantity.String;
			self.txtTransferCargoQuantity.text :=ownershipChangeDetail.transferredQuantity.String;
			self.txtTransferCargoQuantity.enabled := updateable;
			
			self.lblDisplayCargoCurrentWeight.caption	:= null;
			self.txtTransferCargoWeight.text := null;
			self.txtTransferCargoWeight.enabled := false;

			self.lblDisplayCargoCurrentVolume.caption	:= null;
			self.txtTransferCargoVolume.text := null;
			self.txtTransferCargoVolume.enabled := false;
		
		endif;
		*/
	endif;
	if includeClicked then
		self.displayContentTotals(self.myOwnershipChangeDetail);
	endif;
	
	self.btnCargoUpdate.enabled := updateable;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySubDetails" id="be4de612-3bf5-44c5-866c-1194dc498a2d">
        <source>displaySubDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	ownershipChangeDetail : CM_OwnershipChangeDetail;
	theDataLine : String;
	trackedItem : CM_TrackedItem;
	cargoGroup 	: CM_CargoGroup;
	ti         : CM_TrackedItem;
	pxyOwnershipDetail,detail : CM_OwnershipChangeDetail;
	tiSet : CM_TISet; //11/08/2023 navmv20 Bug 59697
begin
	create tiSet transient; //24/03/2025	navkc1 JIRA Story MTN-34256 - Fixed transient leak
	
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	if self.myOwnershipChangeDetail.myTrackedItem.isKindOf(CM_CargoGroup)  then
		if self.detailsSet.isEmpty then // Create sub details
			cargoGroup := self.myOwnershipChangeDetail.myTrackedItem.CM_CargoGroup;
			//tiSet := cargoGroup.getOnSiteOnShipTIs(); //11/08/2023 navmv20 Bug 59697 
			cargoGroup.getOnSiteOnShipTIs(tiSet); //24/03/2025	navkc1 JIRA Story MTN-34256 - fix transient leak
			//foreach trackedItem in cargoGroup.allAssignedTrackedItems do //11/08/2023 navmv20 Bug 59697
			foreach trackedItem in tiSet do //11/08/2023 navmv20 Bug 59697
					create pxyOwnershipDetail transient;
					pxyOwnershipDetail.setProxy(trackedItem.totalWeight,trackedItem.totalVolume,trackedItem.totalQuantity,true,null,self.myOwnershipChangeDetail,trackedItem);
					self.detailsSet.add(pxyOwnershipDetail);
					tblData.addObject(pxyOwnershipDetail);				
				
			endforeach;
		else // display sub details
			foreach ownershipChangeDetail in self.detailsSet discreteLock do
				tblData.addObject(ownershipChangeDetail);				
			endforeach;
		endif;
	else
// ### TFS 60508 15SEP2023 NAVAB1		self.doClear();
	endif;
	
epilog
	delete tiSet; //24/03/2025	navkc1 JIRA Story MTN-34256 - fix transient leak
end;</source>
    </JadeMethod>
    <JadeMethod name="doClear" id="f2f69e5b-fc3a-4c36-9d2b-ca9570af2b5e">
        <source>doClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars

begin
	self.txtTransferCargoVolume.text := "";
	self.txtTransferCargoWeight.text := "";
	self.txtTransferCargoQuantity.text := "";
	self.lblDisplayCargoCurrentQuantity.caption := "";
	self.lblDisplayCargoCurrentVolume.caption	 := "";
	self.lblDisplayCargoCurrentWeight.caption	:= "";
	self.lblDisplayContentVolume.caption		:="";
	self.lblDisplayContentWeight.caption	:= "";
	self.lblDisplayContentQuantity.caption	:= "";
	self.tblData.allSelectedObjects.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMeasurementVolume" id="b31aac59-92a3-4fb3-8eb9-2f99f1c9c661">
        <updating/>
        <source>doMeasurementVolume() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;

begin
	self.txtTransferVolume.setup(Type_Volume, self.backColor);
	self.txtTransferCargoVolume.setup(Type_Volume, self.backColor);
	self.myMeasurementTypeForVolume :=  app.getDefaultMeasurementForType(Type_Volume);
	
	ti := self.myOwnershipChangeDetail.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		ti :=  ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
		
		if ct &lt;&gt; null then
			if ct.isBulk then
			//and ct.isTrackByVolume   then //27/01/2025	navkc1 JIRA Bug MTN-33535
				if ct.myVolumeMeasurementType &lt;&gt; null then
					self.myMeasurementTypeForVolume :=  ct.myVolumeMeasurementType;
				endif;
			
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMeasurementWeight" id="b7ef7cb1-ec1c-4b79-974a-a246416b3de4">
        <updating/>
        <source>doMeasurementWeight() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	self.txtTransferWeight.setup(Type_Weight, self.backColor);
	self.txtTransferCargoWeight.setup(Type_Weight, self.backColor);
	self.myMeasurementTypeForWeight := app.getDefaultMeasurementForType(Type_Weight);
	
	ti := self.myOwnershipChangeDetail.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		ti :=  ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
		
		if ct &lt;&gt; null then
			if ct.isBulk then
			//and not ct.isTrackByVolume   then //27/01/2025	navkc1 JIRA Bug MTN-33535
				if ct.myWeightMeasurementType &lt;&gt; null then
					self.myMeasurementTypeForWeight := ct.myWeightMeasurementType;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="238169c9-4d2e-47d2-a2e8-2382abe13327">
        <updating/>
        <source>doMnuColumnOrganiserClick(menuItem:MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail

*/
vars

begin
	self.tblData.showColumnOrganiserFrm(self.myTerminal, null);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="706bfebc-37dd-4787-810a-e135a55f94e6">
        <updating/>
        <source>doSave()updating;
/*
Purpose:			

Date		Who		Reason
26JUL2023	NAVAB1	 CR 58230 TASK 58232
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
*/

vars
	pxyOwnershipDetail : CM_OwnershipChangeDetail;
	ti, myTrackedItem : CM_TrackedItem;
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail;
	theReturn : Integer;
	storageDetail : CM_StorageDetail;
	weight, volume : Decimal [23,4];
	quantity : Integer;
	includeMainDtl : Boolean; //09/08/2023 navmv20 CR 59391 Task 59417
begin
	
	// put in the main detail
	pxyOwnershipDetail := self.myProxyDetail;
	
	// ### JIRA 33441 20NOV2024 NAVAB1 - we are now adjusting the weight and volume based on the transfer quantity so now we should save all as they are in the UI
	volume := self.txtTransferVolume.getConvertedValue();
	weight := self.txtTransferWeight.getConvertedValue();
	quantity := self.txtTransferQuantity.text.Integer;

	includeMainDtl := self.chkIncludeDetail.value; //09/08/2023 navmv20 CR 59391 Task 59417
	//pxyOwnershipDetail.setProxyTransfers(weight,volume,quantity,true); ///09/08/2023 navmv20 CR 59391 Task 59417
	pxyOwnershipDetail.setProxyTransfers(weight,volume,quantity,includeMainDtl); ///09/08/2023 navmv20 CR 59391 Task 59417
	

// ### TFS BUG 64115 13MAY2024 NAVAB1
	if self.mode = CMUI_CustomDocsMaint.Cargo_Review_Mode then
		self.unloadForm();
		return;
	endif;
	
	create cmifOwnershipChangeDtl transient;
	// put all the sub items in, whether 'included' or not.
	self.detailsSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails.add(pxyOwnershipDetail);
	
	
	while true do
		app.myTrxUA.trxUpdateOwnershipChangeDtls(cmifOwnershipChangeDtl,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.createProxies();
			self.displaySubDetails();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownership_change_details), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	

epilog
	delete cmifOwnershipChangeDtl;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="ef5e1982-1241-43c7-9653-53007396db41">
        <source>doSelectAll();
/*
Purpose:			

Date		Who		Reason
14 May 2024	navab1	BUG 64115
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	col, row : Integer;
	include : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	include := self.chkSelectAll.value;
	col := self.tblData.getColumnByRowName(ETRow_Include);

	if col  &gt; 0 then
	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do			
				self.tblData.accessRow(row);
				self.tblData.accessCell(row,col);
				self.tblData.accessedCell.text := include.cnReturnTickDisplayValue();
		endforeach;
	endif;
	
	self.displayContentTotals(self.myOwnershipChangeDetail); 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSelectAll" id="fea2a2e8-e590-41b5-8c67-979eb5aa4a1d">
        <source>doSetSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues

*/

vars
	col, row : Integer;	
	uncheck : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	self.chkSelectAll.value := false;
	col := self.tblData.getColumnByRowName(ETRow_Include);
	
	if col  &gt; 0 then	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
			if self.tblData.accessCell(row, 1).text = "0" then
				uncheck := true;
				break;
			endif;
		endforeach;
		if not uncheck then
			self.chkSelectAll.value := true;
		endif;
	endif;		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblCOODetailContMenu" id="702bcdb1-3ff0-44f1-9d4d-66a414eca475">
        <updating/>
        <source>doTblCOODetailContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuInspectObject.visible := app.isAllowedToInspect();  // ### TFS 60004 24AUG2023 NAVAB1 ///09/08/2023 navmv20 CR 59391 Task 59417
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
