    <JadeMethod name="deployCardinalBins" id="7083cc0a-0122-4818-b7fe-7ae9f43517d1">
        <source>deployCardinalBins();

vars
	b:Binary;
	f,g,h:File; ff:FileFolder; fn:FileNode;
	m:Machine;
	u:String;
begin
	if app.msgBox("You are about to deploy to all production machines." &amp; CrLf &amp; CrLf &amp; "Continue?", "Caution!", MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		write "Aborted";
		return;
	endif;
	write CrLf &amp; "Starting";
	
	create ff; create g;	create h;
	g.usePresentationFileSystem := false;
	g.mode := File.Mode_Output;	
	g.kind := File.Kind_Binary;
	h.usePresentationFileSystem := false;

	ff.fileName := "\\cnwchcm24\cnwjbl$\Tools\circ\pending";
	foreach fn in ff.files where fn.isKindOf(File) do
		f := fn.File;
		f.usePresentationFileSystem := false;
		f.kind := File.Kind_Binary;
		g.fileName := "c:\cardinal\bin\" &amp; f.name;
		write "writing " &amp; g.fileName;
		b := f.readBinary(f.fileLength);
		g.writeBinary(b);
		g.lastModifiedTime := f.lastModifiedTime;
		g.close;
	endforeach;

	foreach m in Machine.instances do		
		if m.hostName = "cnwchcs113" or m.hostName = "wynchcs238" then  // these machines are currently dead, so don't bother
			continue;
		endif;
		
		h.fileName:="\\cnwchcs118\jobs\" &amp; m.hostName &amp; "\creatorin\SyncCardinalBin_1.job";
		h.writeLine("SyncCardinalBin,,,,,,,,");
		h.close;
		//Sometimes the job does not *actually* get done so put two jobs
		/*h.fileName:="\\cnwchcs118\jobs\" &amp; m.hostName &amp; "\creatorin\SyncCardinalBin_2.job";
		h.writeLine("SyncCardinalBin,,,,,,,,");
		h.close;/**/
	endforeach;
	
	write "Finished";
epilog
	delete ff; delete g; delete h;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayMachines" id="cc7f7083-0bf2-4643-ab0c-d30b05acb830">
        <source>displayMachines();

vars
	machine : Machine;
	f:File;
	ts:TimeStamp;
	s,alias:String;
begin
	foreach machine in Machine.instances do
		s:=machine.hostName.toLower &amp; " (aliases:";
		foreach alias in machine.hostNameAliases do
			s:=s &amp; " " &amp; alias;
		endforeach;
		write s &amp; ")";
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="hkBranchbuild" id="d6e782b1-7412-4c04-8fe6-4340692b1411">
        <source>hkBranchbuild();

//	creates a .grp file for branchbuild everyday when it is the time
// DRAFT

vars
	weekday:Integer;
	branchBuilds: StringArray512;
	s:String;
	f:File;
begin
	app.logMessage(method.qualifiedName &amp; " Starting...");
	
	weekday := app.actualTime.date.dayOfWeek;
	
	//!remove when finish testing!
	weekday:= 5;
	
	create branchBuilds transient;
	if weekday = 1 then		branchBuilds.add(hkLoadLatestHotfixForVersion("7012A"));
	elseif weekday = 2 then	branchBuilds.add(hkLoadLatestHotfixForVersion("7010A"));
	elseif weekday = 3 then	branchBuilds.add(hkLoadLatestHotfixForVersion("7012U"));
	elseif weekday = 4 then	branchBuilds.add(hkLoadLatestHotfixForVersion("7105U"));
	elseif weekday = 5 then	branchBuilds.add(hkLoadLatestHotfixForVersion("7010U"));
							branchBuilds.add(hkLoadLatestHotfixForVersion("7011A"));
	elseif weekday = 6 then	branchBuilds.add(hkLoadLatestHotfixForVersion("7106A"));
							branchBuilds.add(hkLoadLatestHotfixForVersion("7106U"));
	elseif weekday = 0 then branchBuilds.add(hkLoadLatestHotfixForVersion("7011U"));
							branchBuilds.add(hkLoadLatestHotfixForVersion("7104U"));
	endif;
	
	create f;
	f.usePresentationFileSystem := false;
	f.mode := File.Mode_Output;
	foreach s in branchBuilds do
		f.fileName := "\\cnwchcs118\jobs\buildjobs\creatorin\branchbuild_" &amp; s.asFastbuildId &amp; "_" &amp; app.actualTime.date.format("ddMMyyyy").String &amp; "_" &amp; app.actualTime.time.format("HHmmss").String &amp; ".grpjob";
		f.writeLine("autotestconfig,,\\cnwchcs118\t$\svnrepocache\jade\plant\TestSuites\suiteconfig\AllRps.grp;" &amp; s &amp; ";Daily,,,,,,");
		f.close;
	endforeach;
epilog
	app.logMessage(method.qualifiedName &amp; " Finished");
	delete branchBuilds;
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="hkCirc" id="e90874a4-8f8a-4596-a1d2-c7595d5ee266">
        <source>hkCirc();

vars
	m:Machine;
	f,g:File; fn:FileNode; ff:FileFolder;
	s,miscPath:String;
