    <JadeMethod name="hasROB" id="a04b41d5-a714-4a4e-9c2a-34fff1f69681">
        <source>hasROB(_ediProposed : Boolean): Boolean;
/*
Purpose:			
Date		Who		Reason
08 February 2012	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
		if slotLC &lt;&gt; null then
			if slotLC.hasROB(_ediProposed) then
				return true;
			endif;
		endif;
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_ediProposed" type="Boolean"/>
        <ReturnType type="Boolean"/>
