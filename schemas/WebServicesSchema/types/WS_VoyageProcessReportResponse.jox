<Class name="WS_VoyageProcessReportResponse" id="dbf05c42-f1bc-42aa-9aa0-58d6375b7452">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allVoyageProcessReports" id="97e5ee89-d47b-49d6-83bb-3290a249bd61">
        <memberTypeInverse/>
        <type name="WS_VoyageProcessReportArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="addReportOutputFromAgent" id="9f41b0e3-50ac-4da5-8e2b-118a1ac83e45">
        <updating/>
        <source>addReportOutputFromAgent(agent : WebService_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2018	jlgndl1	Initial creation

*/

vars

	voyageProcessReport : WS_VoyageProcessReport;

begin

	create voyageProcessReport transient;
	self.allVoyageProcessReports.add( voyageProcessReport );
	
	voyageProcessReport.setReportOutputFromAgent( agent );

epilog

end;</source>
        <Parameter name="agent" type="WebService_ReportAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="610f35d5-5774-4abc-9772-99fcc399f55d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2018	jlgndl1	Initial creation

*/

vars

begin

	self.allVoyageProcessReports.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunAdditionalVoyageReports" id="466a4cb0-b4c5-45bc-8348-0303a9aad363">
        <updating/>
        <source>doRunAdditionalVoyageReports( 	_request : WS_VoyageProcessReportRequest;
								_voyage : CM_Voyage input;
								_webServiceService : JMTUserInterfaceService
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240
29 May      2019    cnwma1	Bug 44963: PEL1 - WP Error When Trying to See List of Pre-Invoices
*/

vars

	voyageProcessReport : CM_VoyageProcessReport;
	invoice : CM_Invoice;

begin

	foreach voyageProcessReport in _voyage.myVoyageProcess.allAdditionalReports do
		if voyageProcessReport.isVoyageView then
			self.doRunVoyageReport( _voyage, _webServiceService, voyageProcessReport );
		elseif voyageProcessReport.isInvoiceView then
			foreach invoice in _voyage.allInvoices discreteLock do  //29.05.2019 cnwma1 #44963
				if not invoice.status.isOneOf(CM_Invoice.INVOICE_PENDING, CM_Invoice.INVOICE_POSTED) then
					continue;
				endif;
				if invoice.invoiceType.description &lt;&gt; "NOTA KAPAL"  then //epr 10/2/19 differences between d &amp; wmast
					continue;
				endif;
				self.doRunInvoiceReport(invoice,_request.isTaxInvoice,_webServiceService,voyageProcessReport);		
			endforeach;
			
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_request" type="WS_VoyageProcessReportRequest"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_webServiceService" type="JMTUserInterfaceService"/>
    </JadeMethod>
    <JadeMethod name="doRunCashReceiptEstimate" id="327a7804-59a7-4aae-9ccd-7b9d5ad9a559">
        <updating/>
        <source>doRunCashReceiptEstimate(	_cashReceipt : CM_CashReceipt input;
							_webServiceService : JMTUserInterfaceService  ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlger1	Initial creation 42345

*/

vars
	reportAgent 		: WebService_ReportAgent;
	failedDAC			: CM_DataAccessController;		// TFS 40030
	noOutput	: Boolean;	//20 Feb 2019	NDL	TFS 43240
begin
	if _cashReceipt.allCashPayments.isEmpty() then
		return;
	endif;
	if not _cashReceipt.getDebtor.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
		return;
	endif;
	

	create reportAgent transient;
	reportAgent.initRunnerForCashReceipt(_cashReceipt); //20.6.2018 cnwma1 TFS #38815
	if reportAgent.myJRWReport = null then
		return;
	endif;
	// standard voyage report run
	reportAgent.runReportForWeb( noOutput );
	if  noOutput  then		
		return;
	endif;
	self.addReportOutputFromAgent(reportAgent);	//17 Sep 2018	NDL	TFS 40889
	
	if reportAgent.reportOutputFileName &lt;&gt; null then	// 04 Mar 2019	NDL	TFS 43603
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryFile(_webServiceService, reportAgent); //27/07/2010 cnwdz2 24674
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryImages(_webServiceService, reportAgent); // 09/02/2016 cnwma1	36654
	endif;
epilog
	delete reportAgent;
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_webServiceService" type="JMTUserInterfaceService"/>
    </JadeMethod>
    <JadeMethod name="doRunInvoiceReport" id="f8c8ce31-d53e-4963-b62d-3b3a8e41cc0a">
        <updating/>
        <source>doRunInvoiceReport(	_invoice : CM_Invoice input;
					_isTaxInvoice : Boolean;
					_webServiceService : JMTUserInterfaceService;
					_voyageProcessReport : CM_VoyageProcessReport ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlger1	Initial creation 42345
29 May      2019    cnwma1	Bug 44963: PEL1 - WP Error When Trying to See List of Pre-Invoices
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports
*/

vars
	reportAgent 		: WebService_ReportAgent;
	failedDAC			: CM_DataAccessController;		// TFS 40030
	noOutput : Boolean;	//20 Feb 2019	NDL	TFS 43240
begin
	// PEL UAT WP Testing 20SEP18
	if _invoice.invoiceLines.isEmpty() then
		return;
	endif;

	if not _invoice.status.isOneOf(CM_Invoice.INVOICE_PENDING, CM_Invoice.INVOICE_POSTED, CM_Invoice.INVOICE_PREPEND) then
		return;
	endif;
	
	if _isTaxInvoice and _invoice.status = CM_Invoice.INVOICE_PREPEND then
		return;
	endif;
	
	if not _invoice.debtor.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then   //29.05.2019 cnwma1 #44963 &gt;&gt; Moved down after status checks
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Invoice " &amp; _invoice.sequenceNum.String &amp; " is not accessible to " &amp; app.getMyUserCode &amp; " - skipping", LogINFO);
		return;
	endif;
	
	create reportAgent transient;
	reportAgent.initRunnerFromVoyageInvoice(_invoice,not _isTaxInvoice, _voyageProcessReport,null ); //12.09.2019 cnwma1 TFS #46507
	
	if reportAgent.myJRWReport = null then
		return;
	endif;
	
	reportAgent.runReportForWeb( noOutput );
	
	//20 Feb 2019	NDL	TFS 43240 - to handle one report in the collection of reports having no output.
	if  noOutput  then	
		return;
	endif;

	self.addReportOutputFromAgent(reportAgent);	//17 Sep 2018	NDL	TFS 40889
	if reportAgent.reportOutputFileName &lt;&gt; null then	// 04 Mar 2019	NDL	TFS 43603
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryFile(_webServiceService, reportAgent);
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryImages(_webServiceService, reportAgent);
	endif;
epilog
	delete reportAgent;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_isTaxInvoice" type="Boolean"/>
        <Parameter name="_webServiceService" type="JMTUserInterfaceService"/>
        <Parameter name="_voyageProcessReport" type="CM_VoyageProcessReport"/>
    </JadeMethod>
    <JadeMethod name="doRunVoyageReport" id="cbf5b037-857a-4c1d-8cee-d71559dc251f">
        <updating/>
        <source>doRunVoyageReport(	_voyage : CM_Voyage input;
					_webServiceService : JMTUserInterfaceService;
					_voyageProcessReport : CM_VoyageProcessReport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports
*/

vars

	reportAgent 		: WebService_ReportAgent;
	noOutput : Boolean;	//20 Feb 2019	NDL	TFS 43240
	
begin

	create reportAgent transient;
	reportAgent.initRunnerForVoyageViewReport( _voyage, _voyageProcessReport,null ); //12.09.2019 cnwma1 TFS #46507
	
	if reportAgent.myJRWReport = null then
		return;
	endif;
	reportAgent.runReportForWeb( noOutput );
	
	//20 Feb 2019	NDL	TFS 43240 - to handle one report in the collection of reports having no output.
	if  noOutput then
		return;
	endif;

	self.addReportOutputFromAgent(reportAgent);	
	if reportAgent.reportOutputFileName &lt;&gt; null then	// 04 Mar 2019	NDL	TFS 43603
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryFile(_webServiceService, reportAgent);
		_webServiceService.myWebServiceAgent.doCreateVirtualDirectoryImages(_webServiceService, reportAgent);
	endif;
	
epilog

	delete reportAgent;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_webServiceService" type="JMTUserInterfaceService"/>
        <Parameter name="_voyageProcessReport" type="CM_VoyageProcessReport"/>
    </JadeMethod>
</Class>
