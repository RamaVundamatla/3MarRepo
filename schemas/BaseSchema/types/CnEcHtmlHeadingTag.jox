    <DbClassMap file="basehtml"/>
    <PrimAttribute name="headingAlign" id="b87e83a9-d5e5-4125-9823-56d8a74f7109">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="headingLevel" id="0c40dc2d-c404-4896-9908-e7927e9bda06">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="headingValue" id="96405eec-e78a-48ec-ac97-8a7fac18b665">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="13855dc0-6478-45e6-8f93-9a994914fbda">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.headingAlign &lt;&gt; null then
		htmlString	:=	' ALIGN="' &amp; self.headingAlign &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; '&gt;' &amp; CrLf &amp; self.headingValue &amp; inheritMethod() &amp; self.buildChildTags();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="000cf789-4671-4cb5-8c32-d96ffe5f2f92">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.getTagOpen() &amp; self.buildTagBody() &amp; self.getTagClose() &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTagClose" id="bcee1284-b1b1-4969-b2eb-010daa74e1e7">
        <source>getTagClose():String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Returns a closing tag for the receiver.
//
// Parameters:	None
//
// Returns:		The closing tag.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "&lt;/H" &amp; self.headingLevel.String &amp; "&gt;";
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTagOpen" id="11b39eb3-7214-489c-975a-5c3e117858cc">
        <source>getTagOpen():String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Returns an opening tag for the receiver.
//
// Parameters:	None
//
// Returns:		The closing tag.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "&lt;H" &amp; self.headingLevel.String;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="ad0b5af8-2fc7-45cf-a032-c33ab62c0351">
        <source>isValidAlign(pAlign: String): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_CENTER
	or pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Heading tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidLevel" id="43dfbf95-0d2d-4565-8ac3-d1c25541af67">
        <source>isValidLevel(pLevel:Integer):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Validates the receiver's level setting.
//
// Parameters:	pLevel - The receiver's level setting.
//
// Returns:		True if the level setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pLevel &gt;= 1 or pLevel &lt;= 6 then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22002, "H" &amp; pLevel.String &amp; " is not a valid HTML Heading tag level");
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pLevel" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHeadingAlign" id="f70ef066-bc44-45e4-8ee2-c666ab57b6d0">
        <updating/>
        <source>setHeadingAlign(pAlign: String) updating;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Set the receiver's alignment setting.
//
// Parameters:	pAlign - The alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidAlign(pAlign) then
		self.headingAlign	:=	pAlign;
	endif;
end;</source>
        <Parameter name="pAlign" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeadingLevel" id="6a17ea65-e5b3-4b7a-90f2-e5ff8b22ab1f">
        <updating/>
        <source>setHeadingLevel(pLevel:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Set the receiver's heading level.
//
// Parameters:	pLevel - The heading level.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidLevel(pLevel) then
		self.headingLevel	:=	pLevel;
	endif;
end;</source>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
</Class>
