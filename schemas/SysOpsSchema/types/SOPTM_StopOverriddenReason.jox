    <JadeMethod name="doSave" id="0435b5ec-ff47-4b67-9c83-d9cf4a1ac2a9">
        <updating/>
        <source>doSave() : Boolean updating;

/*
Date			Who		Reason
19 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	lCode				: String;
	lDescription		: String;
	proxyStopReason		: CM_StopOverridenReason;
	theForm 			: SOP_TableMaintForm;
	
begin
	theForm	:= self.myForm;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_StopOverridenReason transient;
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'Proxy object is null for update' );
			return false;
		endif;
	endif;
	
	proxyStopReason	:= theForm.myProxyObject.CM_StopOverridenReason;
	lCode			:= theForm.tblInput1.getValueByName( ETRow_Code ).String;
	lDescription	:= theForm.tblInput1.getValueByName( ETRow_Description ).String;
	proxyStopReason.setProxy( lCode, lDescription );
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateStopOverriddenReason( proxyStopReason, theForm.myCurrentObject, app.myPassport );
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateStopOverriddenReason( proxyStopReason, app.myPassport );
	else
		app.raiseUnexpectedProgramError( class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')' );
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
