    <JadeMethod name="showBulkPrintForm" id="0b040545-128e-4622-902d-513f5bef9565">
        <source>showBulkPrintForm(	_printObject :CM_Object;
					_modeView : Integer;
					_modeViewSub : Integer;
					_modeViewBy : Integer;
					_parentForm : CM_BaseForm	) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars
	form : SHP_BulkPrint;

begin
	if not _printObject.isKindOf(CM_GeneralCargoController) and not _printObject.isKindOf(CM_GeneralCargoVesselStructure) and not _printObject.isKindOf(CM_GeneralCargoVoyageStructure) then
		return IDCANCEL;
	endif;

	form := app.loadForm(SHP_BulkPrint, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_BulkPrint;
	
	if form = null then
		return IDCANCEL;
	endif;
	
	form.initDetails(_printObject, _modeView, _modeViewSub, _modeViewBy, _parentForm);

	return form.showModal;
epilog

end;</source>
        <Parameter name="_printObject" type="CM_Object"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSub" type="Integer"/>
        <Parameter name="_modeViewBy" type="Integer"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showCCPallette" id="c3a1f40f-631c-4880-a3d8-e6ed66c2b372">
        <source>showCCPallette(_parentForm : SHP_VoyageAreaForm2; _voyage : CM_Voyage;_masterMenuAction : CMUI_MenuAction; _description : String; _isExport : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars
	theForm : CMUI_VoyageAllocationsListForm;
	theExportForm : CMUI_VoyageAllocsLoadListForm;
	parentForm : SHP_VoyageAreaForm2;
begin
	parentForm := _parentForm;
	
	//new way uses two forms.	//24 Jan 2012	NDL	Par 28896
	if _isExport then
	
		theExportForm := app.loadForm(CMUI_VoyageAllocsLoadListForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_VoyageAllocsLoadListForm;
		if theExportForm = null then
			return;
		endif;	
		
		theExportForm.myVoyage := _voyage;	
		theExportForm.setFormParent(_parentForm);
		theExportForm.setParentForm(_parentForm);
		parentForm.setMyCCPalette(theExportForm);
		
		theExportForm.show();
		
	else

		theForm := app.loadForm(CMUI_VoyageAllocationsListForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_VoyageAllocationsListForm;
		if theForm = null then
			return;
		endif;	
		
		
		theForm.myVoyage := _voyage;	
		theForm.isExport := false;	
		theForm.setFormParent(_parentForm);
		theForm.setParentForm(_parentForm);
		parentForm.setMyCCPalette(theForm);
		theForm.initTblCCAllocation(ETDef_DischargeCCPalette);
		
		theForm.doChangeIMEX(_isExport);
		theForm.show();

	endif;
		
	/* old way 
	
	
	theForm := app.loadForm(CMUI_VoyageAllocationsListForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_VoyageAllocationsListForm;
	if theForm = null then
		return;
	endif;	
	
	
	theForm.myVoyage := _voyage;	
	theForm.isExport := _isExport;
	//theForm.setYardAllocation(yas);	
	theForm.setFormParent(_parentForm);
	theForm.setParentForm(_parentForm);
	//theForm.setParent(_parentForm);
	parentForm.setMyCCPalette(theForm);
	if _isExport then
		theForm.initTblCCAllocation(ETDef_ColourCodingPallette);
	else
		theForm.initTblCCAllocation(ETDef_DischargeCCPalette);
	endif;
	theForm.doChangeIMEX(_isExport); //+cnwas3 par 27507
	theForm.show();	
		
	*/
	
epilog

	//delete yas;
end;</source>
        <Parameter name="_parentForm" type="SHP_VoyageAreaForm2"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isExport" type="Boolean"/>
    </JadeMethod>
