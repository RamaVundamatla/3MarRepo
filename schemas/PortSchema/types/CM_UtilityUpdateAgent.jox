    <JadeMethod name="utlUpdateTerminalAreasGraphic" id="a6af6d97-0898-4a11-a2c9-2ea88f2670fb">
        <source>utlUpdateTerminalAreasGraphic(_layoutGraphic : CMIF_LayoutGraphics;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		The interface object has an array of terminal areas and an array of point arrays, one for each TA
// ---------------------------------------------------------------------------

vars
	realLayoutGraphic,pxyLayoutGraphic : CM_LayoutGraphic;
	anObject,aPointObject : Object;
	thePoints : PointArray;
	aTerminalArea,pxyTA : CM_TerminalArea;
	expectedEdition, idx : Integer;
begin
	foreach anObject in _layoutGraphic.allObjects do
		idx := idx + 1;
		if anObject = null then
			continue;
		endif;
		if not anObject.isKindOf(CM_TerminalArea) then
			continue;
		endif;
		aTerminalArea := anObject.CM_TerminalArea;
		
		aPointObject := _layoutGraphic.allPointPolygons[idx];
		if aPointObject = null then
			continue;
		endif;
		thePoints := aPointObject.PointArray;
		
//		pxyLayoutGraphic := aTerminalArea.myLayoutGraphic.pxyCreateUpdateProxy();
		pxyTA := aTerminalArea.pxyCreateUpdateProxy();
		pxyLayoutGraphic := pxyTA.myLayoutGraphic;
		// in V6 we used the left, top, orientation etc. to draw the rotated polygon
		// in V7 we do not use these, we simple save the new polygon settings
		// when V6 was converted to V7 we did not convert the polygon to not use the left, top etc
		// so on the first save zero out all the old V6 attributes
		pxyLayoutGraphic.setProxy(0,0,aTerminalArea,pxyLayoutGraphic.drawLineColour,0,0,0,thePoints,pxyLayoutGraphic.label,_passport.myTerminal);
		
		self.utlUpdateLayoutGraphic(pxyLayoutGraphic,_passport);
		if not _passport.noErrors then
			break;
		else
			delete pxyLayoutGraphic;
			delete pxyTA;
		endif;

	endforeach;
epilog
	delete pxyLayoutGraphic;		
	delete pxyTA;
end;</source>
        <Parameter name="_layoutGraphic" type="CMIF_LayoutGraphics"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalDBLoadConfig" id="3caa148c-6788-4e0d-8935-13196bfd80e9">
        <updating/>
        <source>utlUpdateTerminalDBLoadConfig(_terminal : CM_Terminal; _nameValuePairs : CM_NameValuePairDict; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2023	navra1	Initial creation for 58278

*/

vars
	pairIter : CM_NameValuePair;	
begin
	self.initialiseActivity();
	
	if _nameValuePairs = null then
		return;
	endif;
	
	app.setContinueCMExceptions(false);	
	
	exclusiveLock(_terminal);
	
	self.myUpdateAuditAgent.audUpdateGeneric(_terminal, true);
	
	foreach pairIter in _nameValuePairs do
		_terminal.addOrEditDBLoadOption(pairIter);		
	endforeach;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminal,false);
	endif;		
	
epilog
	delete pairIter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_nameValuePairs" type="CM_NameValuePairDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalGraphics" id="623a703e-e252-4a55-9336-c519a1fb0939">
        <source>utlUpdateTerminalGraphics(pProxyTerminal:CM_Terminal; realTerminal:CM_Terminal input; _passport : CM_Passport input);

vars
	cancelSave,aOK:Boolean;
	expectedEdition:Integer;
	pxyGraphic,realGraphic,realGraphicNew,tmpGraphic : CM_Graphic;
	theObjects:	ObjectSet;
begin
	
	// ###############
	// TERMINAL GRAPHICS
	if _passport.noErrors then
		// all of the graphics are proxied too
		// check for deletes
		aOK := false;
		create theObjects transient;
		foreach realGraphic in realTerminal.allLayoutGraphics do
			// if the real has no linked proxy then it must die!
			if realGraphic.pxyGetProxyObject = null then
				theObjects.add(realGraphic);
			endif;
		endforeach;
		while not theObjects.isEmpty do
			tmpGraphic := theObjects.first.CM_LayoutGraphic;
			app.myUtilityDA.utlDeleteLayoutGraphic(tmpGraphic.CM_LayoutGraphic,_passport);
			if not _passport.noErrors then
				break;
			endif;
			theObjects.remove(tmpGraphic);
		endwhile;
		delete theObjects;
		
		if _passport.noErrors then
			foreach pxyGraphic in pProxyTerminal.allLayoutGraphics do
				if pxyGraphic.pxyGetRealObject &lt;&gt; null then
					self.utlUpdateLayoutGraphic(pxyGraphic.CM_LayoutGraphic,_passport);
				else
					// if the real has no linked proxy then it must be born!
					app.myUtilityCA.utlCreateLayoutGraphic(pxyGraphic.CM_LayoutGraphic,realGraphicNew,_passport);
					aOK := true;
				endif;
				if not _passport.noErrors then
					break;
				endif;
			endforeach;
		endif;
		
	endif;
	if _passport.noErrors then
		// do not reorder if we have added a new graphic
		if not aOK then
			realTerminal.doOrderLayoutGraphicsSet(pProxyTerminal.allLayoutGraphics);
		endif;
	endif;

epilog
	
end;</source>
        <Parameter name="pProxyTerminal" type="CM_Terminal"/>
        <Parameter name="realTerminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
