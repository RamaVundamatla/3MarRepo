<CollClass name="ObjectSet">
    <JadeMethod name="cnEcGetMemberClass" id="92f7f477-0bc4-47d0-9a4f-062ec0366d29">
        <source>cnEcGetMemberClass():Class;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Class of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Class of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetMemberType().Class;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
</CollClass>
