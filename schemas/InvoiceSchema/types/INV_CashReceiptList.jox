    <JadeMethod name="txtCashPayment2nd_gotFocus" id="23e64d13-b1f0-4c98-b3a8-9071df9b99c4">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCashPayment2nd_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jsn 2020 cnwma1	Bug 48211: JMT - 4 x Issues relating to cash credit totals.

*/

vars

begin
	
	if self.myProxyCashReceipt = null then
		return;
	endif;
	self.txtCashPayment2nd.text := null;
	self.lblPayC2.caption       := null;

	self.txtCashPayment.text := self.lblCashPayReqd2.caption.asDecimalFromCurrencyString.String;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCashPayment2nd_lostFocus" id="b1143919-ee96-4853-a3a7-60877d606b1d">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCashPayment2nd_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
					33437 auto-adjust the other payment amount, copied from INV_CashReceiptMulti
15 Aug 2018	jlgrh7  TFS #40269 GUQ - Currency rate converter/currency type maintenance
18 Oct 2017	jlgrh7  TFS40904  GUQ - Read only Label currency Translation not Available on JMT#851.220
21 Oct 2019 cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
10 Jan 2020 cnwma1	Bug 48211: JMT - 4 x Issues relating to cash credit totals.
*/

vars
	secondCashValue,
	cashPaymentAmount,
	cashToPay,
	converted			: Decimal[23, 6];
begin
	self.lblPayC2.caption := "";	
	secondCashValue 	  := textbox.text.asDecimalJMT;
	
	if secondCashValue= null then //10.01.2020 cnwma1 #48211
		return;
	endif;
	
	
	cashToPay := self.lblCashPayReqd2.caption.asDecimalFromCurrencyString();
	
	
	if self.convertMultiplyRate &lt;&gt; 0 then
		converted := (secondCashValue * self.convertMultiplyRate).roundedTo(2);    //21.10.2019 cnwma1 TFS #47081	
				
		if converted &lt;&gt; 0 then																										
			if converted &gt; cashToPay then										 //10.01.2020 cnwma1 #48211
				app.raiseCMException( Cannot_pay_more_cash, null, null );
				return ;
			endif;
		
			self.lblPayC2.caption 	  			:= converted.roundedTo(2).String;
			self.cashPaymentSecondary			:= converted;
		
			cashPaymentAmount 					:= cashToPay - converted;
			self.cashRequiredToClearCharges     := cashPaymentAmount;
			self.txtCashPayment.text 			:= cashPaymentAmount.String;
		endif;
	endif;
	
	
end;
</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
