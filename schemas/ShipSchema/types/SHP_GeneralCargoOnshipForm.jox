    <JadeMethod name="doSearch" id="a90b8a40-3020-44b1-9539-7476a32a2c02">
        <updating/>
        <source>doSearch() updating, protected;
// BOL, Stowage and Cargo searches

//04/12/12	PJS 	Voyage Rationalisation
vars

begin
	// set search properties
	if self.searchType = Search_BOL then
	//	self.filterBOLNumber := txtSearchBOL.text.trimBlanks();
		self.filterBOL := cmbSearchBOL.listObject.CM_BOL;
		self.filterBOLCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
		self.filterBOLCommodity := cmbSearchCommod.myObject.CM_Commodity;
		self.filterBOLMarks := txtSearchMarks.text.trimBlanks();
		self.filterBOLOperator:= cmbSearchOper.myObject.CM_Operator;
		self.filterBOLReconciled := cmbReconciled.text;	//30787
	elseif self.searchType = Search_BOL_Detail then
	//	self.filterBOLNumber := txtSearchBOL.text.trimBlanks();
		self.filterBOL := cmbSearchBOL.listObject.CM_BOL;  //30787
		self.filterBOLCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
		self.filterBOLCommodity := cmbSearchCommod.myObject.CM_Commodity;
		self.filterBOLMarks := txtSearchMarks.text.trimBlanks();	
	elseif self.searchType = Search_BOL_Item then
		self.filterBOLItemId := txtSearchId.text.trimBlanks();
		self.filterBOLItemLocation := txtSearchLocn.text.trimBlanks();
	//	self.filterBOLItemBOLNumber := txtSearchBOL.text.trimBlanks();
		self.filterBOLItemCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
		self.filterBOLItemMarks := txtSearchMarks.text.trimBlanks();
		self.filterBOLItemCommodity := cmbSearchCommod.myObject.CM_Commodity;
		self.filterBOLItemOperator := cmbSearchOper.myObject.CM_Operator;
	elseif self.searchType = Search_COB then
		self.filterCOBItemId := txtSearchId.text.trimBlanks();
		self.filterCOBLocation := txtSearchLocn.text.trimBlanks();
	//	self.filterCOBBOLNumber := txtSearchBOL.text.trimBlanks();
		self.filterCOBCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
		self.filterCOBMarks := txtSearchMarks.text.trimBlanks();
		self.filterCOBCommodity := cmbSearchCommod.myObject.CM_Commodity;
		self.filterCOBOperator := cmbSearchOper.myObject.CM_Operator;
	elseif self.searchType = Search_Stowage_Item then
		self.filterStowItemId := txtSearchId.text.trimBlanks();
		self.filterStowItemLocation := txtSearchLocn.text.trimBlanks();
		//self.filterStowItemBOLNumber := txtSearchBOL.text.trimBlanks();
		self.filterStowItemCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
		self.filterStowItemMarks := txtSearchMarks.text.trimBlanks();
		self.filterStowItemCommodity := cmbSearchCommod.myObject.CM_Commodity;
		self.filterStowItemOperator := cmbSearchOper.myObject.CM_Operator;
//	elseif self.searchType = Search_Stowage then
//		self.filterStowageLocation := txtSearchLocn.text.trimBlanks();
//		self.filterStowageCargoType := cmbSearchCType.listObject.CM_CargoBOLType;
//		self.filterStowageMarks := txtSearchMarks.text.trimBlanks();
//		self.filterStowageCommodity := cmbSearchCommod.myObject.CM_Commodity;
	endif;

	// refresh tables using these 
	if self.searchType = Search_BOL then
		self.showBOLsForVoyage();
	elseif  self.searchType = Search_BOL_Detail then	//30787
		self.showBOLsForVoyage();
	elseif self.searchType = Search_BOL_Item then
		self.showBOLCargo();
	elseif self.searchType = Search_COB then
		self.showCargoOnBoard();
	elseif self.searchType = Search_Stowage_Item then
		self.showStowageCargo();
//	elseif self.searchType = Search_Stowage then
		// not yet implemented
	endif;
	
	self.displaySearchSelection();
	
	self.showHideSearch();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectVoyage" id="43ab7fdf-8a5a-48a3-bdc3-8e1b8c64d3b7">
        <updating/>
        <source>doSelectVoyage() updating, protected;
// on voyage select and refresh - gets all details for this voyage and display them
vars
	msg : String;
	formCaption : String;

begin



	if self.myCurrentVoyage &lt;&gt; null then
		//epr TFS 2362 4/8/16
		msg := self.baseCaption &amp; ' ' &amp; self.myCurrentVoyage.getDisplayDetails(false); // TFS 2198 Caption to caption
		self.setCaption(msg);
		self.setNavigatorHeading(msg);
	endif;
	self.myCurrentBOL := null;
	self.myCurrentBOLDetail := null;
	self.myCurrentTrackedItem := null;
	self.myCurrentHatch := null;
	self.myCurrentTable := null;
	self.resetSearch();	
	self.resetAllFilters();
	self.tblBOL.clearAllSelected();
	self.tblBOLItems.clearAllSelected();
	self.tblCargo.clearAllSelected();
	//self.btnCargoType.value := false; //- cnwmd1, Par 22846
	
	self.doNotableClear();
	self.addNotableObject(self.myCurrentVoyage);
	
	self.showBOLsForVoyage();
	self.showCargoOnBoard();
	self.showStowage();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelection" id="07ade751-a874-4555-b465-e7e2dbe55b6b">
        <updating/>
        <source>doSelection()updating;
/*
Date		Who		Reason
21 Aug 2024 navah1	Bug 64204(12350): MTN - Table row limit reached on Voyage BOL maintenance cannot be closed 
*/
vars
	voyage : CM_Voyage;
begin



	if self.cmbVoyages.listIndex &lt;&gt; - 1 then
		voyage := self.cmbVoyages.itemObject[self.cmbVoyages.listIndex].CM_Voyage;
		self.myCurrentVoyage := voyage;
		//self.doSelectVoyage();												  // 30.10.2024 navah1 #64204	(12350)				
	endif;
	
	//+ cnwmd1 Par 22846
	if self.frmQuery.visible then
		self.allCargoTypes.clear;
		self.lstCargoTypes.allSelectedObjects.copy(self.allCargoTypes);
		//self.btnCOBSReset_click(self.btnCOBSReset);							  // 30.10.2024 navah1 #64204	(12350)
	endif;
	
	self.searchType := Search_COB;  								  		      // 30.10.2024 navah1 #64204	(12350)
	self.doSelectVoyage();     					 							      // 30.10.2024 navah1 #64204	(12350)
	self.displaySearchSelection();									     	      // 30.10.2024 navah1 #64204	(12350)
	self.showHideSelector();


end;</source>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="e6cf9d94-477b-4e5e-a5f4-c5043a462944">
        <source>doSendToReport();
// TFS 1904, to BOL transaction report
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	objects			: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	// get selected BOL, if none just exit
	obj := self.tblBOL.accessRow(self.tblBOL.row).itemObject.CM_Object;
	if obj = null then
		return;
	endif;

	// we want reports which use CM_TransactionView and either of the two collection paths below, as these are BOL transaction reports
	create pathList transient;
	pathList.add("allTfrsByCargoId");
	pathList.add("allTfrsByLastBol");
	if app.getReportToSendItems(CM_TransactionView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		
		create objects transient;
		objects.add(obj);
		
		app.sendItemsToReport(CM_JRWBOLTfrTransactions, objects, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete objects;
	delete pathList;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doShowBOLStopsForm" id="f3f26a64-d046-4b08-a69e-380b403c36e4">
        <source>doShowBOLStopsForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars
	realBOL	: CM_BOLIn;
	coll	:CM_ObjectSet;
	obj		: Object;
begin
	if (not CM_BOLIn.hasInstance(self.myCurrentBOL)) then
		return;
	endif;
	
	realBOL	:= self.myCurrentBOL.CM_BOLIn;
	
	create coll transient;
	coll.add(realBOL);
	
	self.myAssistant.showStopsForm_BOL(realBOL, coll, true);
epilog
	delete coll;
end;</source>
