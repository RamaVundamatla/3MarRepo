// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lstObj, obj : Object;
	criType : CM_YACriteriaType;
begin
	lstObj := self.cmbDefaultColour.listObject;
	
	self.cmbDefaultColour.clear();
	self.cmbDefaultColour.listIndex := -1;
	
	if _objSelectedArray = null then
		return;
	endif;
	
	if _objSelectedArray.isEmpty() then
		return;
	endif;
	
	foreach obj in _objSelectedArray  discreteLock do
		criType := obj.CM_YACriteriaType;
		self.cmbDefaultColour.addItemObject(criType.description,criType);
	endforeach;
	
	if lstObj &lt;&gt; null and self.cmbDefaultColour.findObject(lstObj) &gt; 0 then
		self.cmbDefaultColour.listObject := lstObj;
	endif;
epilog

end;</source>
        <Parameter name="_objSelectedArray" type="ObjectArray"/>
        <Parameter name="_doClear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="e733f76c-98d1-4487-a71e-9768fa771e08">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2009	cnwjk3	SFW1030

*/

vars
	objSelectedArray : ObjectArray;
begin
	inheritMethod(_control);
	

	
	if _control = self.mltFields.myAddSelectedBtn or
	   _control = self.mltFields.myAddAllBtn or		
	   _control = self.mltFields.myRemoveSelectedBtn or
	   _control = self.mltFields.myRemoveAllBtn then
		   
		create objSelectedArray transient;
		
		// Store the currently selected items
		self.mltFields.getSelected(objSelectedArray);
		
		self.doCmbDefaultForColourBuild(objSelectedArray, false);
		
	endif;	
epilog
	delete objSelectedArray;
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="81348ef0-499d-4b28-9f56-dfed568a8a0d">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	opCriteriaColl, groupLabelCriteriaColl : CM_YACriteriaTypeArray;
	pxyYARail : CM_YARailConfig;
	theReturn : Integer;
begin
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	self.mltFields.getSelected(opCriteriaColl);
	
	if self.myYARailConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Terminal " &amp; self.myTerminal.code &amp; " has no rail YA Config.");
		return;
	else
		pxyYARail := app.createUpdateProxy(self.myYARailConfig).CM_YARailConfig;
	endif;
	
	pxyYARail.setProxyRail(opCriteriaColl, groupLabelCriteriaColl, Red, self.cmbDefaultColour.listObject.CM_YACriteriaType, null);
	
	while true do
		app.myTrxUA.trxUpdateYAIMEXConfig(pxyYARail, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Rail_configuration),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	self.doSaveConfig();
	if not app.myPassport.trxCompletedOK() then//cnwas3 par 22983
		return;
	endif;
	if self.doSaveHook() then
		app.msgBox(app.getErrorString(SAVE_COMPLETE), app.getErrorString(Rail_configuration),  MsgBox_Information_Icon);
	endif;
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
	delete pxyYARail;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveConfig" id="7cf82827-1160-46c9-88a6-a7941f6405a3">
        <updating/>
        <source>doSaveConfig() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/10/2010		cnwdap1			PAR #23794 Release Requests on Rail Load List setting
// 25/07/2022		jlika1			FS 53741 EUP  - Max Wagon Payload
// ---------------------------------------------------------------------------

vars
	railSettings : CMIF_RailSettings;
	theReturn : Integer;
begin
	create railSettings transient;

	railSettings.myTerminal := self.myTerminal;
	
	railSettings.trainAutoNumber :=  self.chkAutoTrainNum.value;
	railSettings.trainAutoNumberPrefix := self.txtAutoNumPrefix.text;
	railSettings.railPostDepartVisHrs := self.txtRailPost.text.Integer;	// 05 Nov 2009	NDL	Par 21519
	railSettings.trainManifestReportIn := self.txtTrainManIn.text;
	railSettings.trainManifestReportOut := self.txtTrainManOut.text;
	railSettings.useOutwardRailConfirm := self.chkOutwardRailCo.value;
	railSettings.noTLMovesToWagons := self.chknoTLonWagons.value;
	//railSettings.defRailCarrier := self.cmbRailCarrier.text;//par 20917 begin
	if self.cmbRailCarrier.listObject &lt;&gt; null then
		railSettings.defRailCarrier := self.cmbRailCarrier.listObject.CM_Carrier.code;
	endif;//par 20917 rejected qual change
	railSettings.defRailOpsArea := self.txtRailArea.text;
	railSettings.defWagonClass := self.cmbWagonClass.text;//par 20917 end
	railSettings.customsEDIonTrain := self.chkRunEDI.value;	//01 Dec 2009	NDL Par 21519
	
	//16 Apr 2010	NDL	Par 23787
	railSettings.hHAlwaysCargoFullID := self.chkHHContIdFull.value;
	railSettings.hHCargoMustPrenote := self.chkHHContPrenote.value;
	railSettings.hHWarnPrenoteHazDiffer := self.chkHHWarnHaz.value;
	railSettings.hHAlwaysWagonFullID := self.chkHHWagIdFull.value;
	railSettings.hHWagonUseReversedID := self.chkHHWagIdRev.value;
	
	// PAR #23794 Release Requests on Rail Load List setting
	railSettings.showRelReqOnRailLoadList := self.chkRelReqRail.value;
	
	railSettings.railDisallowOutwardQueue := self.chkOutQing.value; // PAR 25526
	
	railSettings.railTrackClearErr := self.chkTrkError.value;	// 24 Nov 2010	NDL	Par 23883
	railSettings.railAutoSwitch := self.chkAutoSwitch.value;	// 25 Nov 2010	NDL	Par 25422
	
	railSettings.allowWagonWeightsToBeUpd := self.chkAllowWagonWeightsToBeUpd.value;
	railSettings.raiseErrorMaxLoadWeight := self.chkRaiseErrorMaxLoadWeight.value;
	
	
	while true do
		app.myTrxUA.trxUpdateRailSettings(railSettings, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Terminal_Configuration), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete railSettings;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveHook" id="be0932c2-a1b7-4fbc-8fb4-07008f73a8cf">
        <updating/>
        <source>doSaveHook() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realHookCode, proxyHookCode	: CM_HookCode;
	cmif			: CMIF_HookCode;
	mode : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create cmif transient;
	
	if self.myHookCode &lt;&gt; null then
		proxyHookCode := app.createUpdateProxy(self.myHookCode).CM_HookCode;
		mode := 2;
	else
		create proxyHookCode transient;
		mode := 1;
	endif;

	cmif.myProxyHookCode := proxyHookCode;
	cmif.code := self.txtCodeHook.text[1:30];
	cmif.allLinkObjects.add(app.myRoot);
	cmif.myHookType := app.myRoot.allHookTypes[HookType_WagonClass];
	cmif.jadeCode := self.txtJadeEditor.text;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if mode = 1 then
			app.myTrxCA.trxCreateHookCode(cmif, realHookCode, app.myPassport);
		else
			app.myTrxUA.trxUpdateHookCode(cmif, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Hook Code Maintenance', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.highlightSyntaxErrors (app.myPassport);
		return false;
		
	endwhile;
	
	return true;
	
epilog
	delete proxyHookCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldMain_click" id="aafe2684-0b20-42bd-8cf9-07dc3fcde02f">
        <controlMethod name="Folder::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_click(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if folder.topSheet = self.shtHook and not self.zShownHookMessage then
		if app.myRoot.allTerminals.size &gt; 1 then
			app.msgBox(app.getErrorString(Aware_that_wagon_hook_code_ter), app.getErrorString(HMS_ChkPointDescr_UserHookCode), MsgBox_Information_Icon);
			self.zShownHookMessage := true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="highlightSyntaxErrors" id="b01e6c9e-5be5-4fb4-905f-565596abf40c">
        <source>highlightSyntaxErrors(_passport :CM_Passport)protected;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by concms1
// Purpose:     PAR 16762 - highlight any syntax errors
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error		:CM_Error;
	sa			:StringArray;
	pos, length	:Integer;
begin
	foreach error in _passport.allErrorWarnings do
		if error.errorCode = ERR_SYNTAX_ERROR_LONG then
			self.txtJadeEditor.selLength := null;

			if error.fieldName &lt;&gt; null then
				delete sa;
				sa := error.fieldName.getTokens;
				
				if sa.size = 2 then
					pos		:= sa[1].Integer;
					length	:= sa[2].Integer;
					
					if length &gt; 0 then
						self.txtJadeEditor.selStart	:= pos;
						self.txtJadeEditor.selLength	:= length;
					endif;
				endif;
				return;
			endif;
		endif;
	endforeach;
epilog
	delete sa;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="initJadeEditor" id="2cb9d42e-c8b1-4062-9dd0-1fd7d65164d8">
        <updating/>
        <source>initJadeEditor() updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

begin


	
	self.txtJadeEditor.initializeJadeEditor(false);
	self.txtJadeEditor.configureFor_Jade;
	self.txtJadeEditor.setCurrentSchema(rootSchema.getSchema(PortSchemaName));
	self.txtJadeEditor.tabWidth	:= 4;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="a5bf3a2f-dde0-40b0-97cc-4f33c1c0e5a9">
        <updating/>
        <source>populateForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29/08/2008	consw1	Initial creation
22/10/2010	cnwdap1	PAR #23794 Release Requests on Rail Load List setting
26/04/2016  cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
25/07/2022	jlika1	TFS 53741 EUP  - Max Wagon Payload
*/

vars
	hookCode : CM_HookCode;
	criteriaTypes: ObjectArray;
	hookType : CM_HookType;
	tmpConfig	: CMIF_ConfigTerminal; //par 20917
	criteriaType : CM_YACriteriaType;
begin
	
	self.mltFields.userInputEnabled 			:= true;
	self.mltFields.formDisplayEntryMethodName 	:= CMUI_YAIMEXConfigForm::displayCriteria.name;
	self.mltFields.displayOrderBtns(true, true);
	self.mltFields.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltFields.myAvailableListBox.sorted 	:= true;		
	self.mltFields.mySelectedListBox.sorted 	:= false;
	self.mltFields.setTabIndex();
	self.mltFields.myBaseForm := self;

	// PAR 19462
	create criteriaTypes transient;
	// PAR 35833  app.myRoot.allYACriteriaTypes.copy(criteriaTypes);
	foreach criteriaType in app.myRoot.allYACriteriaTypes discreteLock where criteriaType.isForCargo()  do// PAR 35833 
		if criteriaType.isUsed then						//26/04/2016 cnwma1 PAR #36914 TFS1768 
			criteriaTypes.add(criteriaType);// PAR 35833 
		endif;
	endforeach;// PAR 35833 
	
	criteriaTypes.remove(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]); // PAR 22051
	
	self.mltFields.setAvailable(criteriaTypes, true); 
	self.mltFields.setSelected(self.myYARailConfig.allOpCriteria);

	self.mltFields.setFocus();
	
	
	// ### HOOK CODE
	self.initJadeEditor();
	self.myHookCode  := app.myRoot.myWagonClassHookCode;

	if self.myHookCode &lt;&gt; null then
		self.txtCodeHook.text 			:= self.myHookCode.code;
		self.txtJadeEditor.text 		:= self.myHookCode.getCurrentJadeCode();
	else
	
		self.txtCodeHook.text := app.getErrorString(CM_Default);
		hookType := app.myRoot.allHookTypes[HookType_WagonClass];
		self.txtJadeEditor.text := hookType.hookMethodTemplate;

	endif;
	
	if tmpConfig = null then																					//par 20917 begin
		create tmpConfig transient;
		tmpConfig.setFromPersistentData(self.myTerminal);
	endif;
	self.myAssistant.comboBoxWagonClass(self.cmbWagonClass, app.myRoot.allWagonClasses[tmpConfig.defWagonClass]);
	self.myAssistant.comboBoxCarrierRail(self.cmbRailCarrier, app.myRoot.allCarriers[tmpConfig.defRailCarrier]);
	self.cmbWagonClass.text := self.myTerminal.getConfig(DefWagonClass).String;
	self.cmbRailCarrier.text := self.myTerminal.getConfig(DefRailCarrier).String;
	self.txtRailArea.text:=self.myTerminal.getConfig(DefRailOpsArea).String;//par 20917 end
	// ### CONFIGURATION
	self.chkAutoTrainNum.value := self.myTerminal.getConfig(TrainAutoNumber).Boolean;
	self.txtAutoNumPrefix.text := self.myTerminal.getConfig(TrainAutoNumberPrefix).String;
	self.txtRailPost.text := self.myTerminal.getConfig(RailPostDepartVisHrs).String;	// 05 Nov 2009	NDL	Par 21519
	self.txtTrainManIn.text :=   self.myTerminal.getConfig(TrainManifestReportIn).String;
	self.txtTrainManOut.text :=   self.myTerminal.getConfig(TrainManifestReportOut).String;
	self.chkOutwardRailCo.value  := self.myTerminal.getConfig(UseOutwardRailConfirm).Boolean;
	self.chknoTLonWagons.value  := self.myTerminal.getConfig(RailNoTwinLiftMoves).Boolean;
	self.chkRunEDI.value  := self.myTerminal.getConfig(CustomsEDIonTrain).Boolean;	//01 Dec 2009	NDL Par 21519
	self.chkAllowWagonWeightsToBeUpd.value  := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;	
	self.chkRaiseErrorMaxLoadWeight.value  := self.myTerminal.getConfig(RaiseErrorMaxLoadWeight).Boolean;	
	
	//Hand held config
	
	self.chkHHContIdFull.value:=self.myTerminal.getConfig(RailHHAlwaysCargoFullID).Boolean;
	self.chkHHContPrenote.value:=self.myTerminal.getConfig(RailHHCargoMustPrenote).Boolean;
	self.chkHHWarnHaz.value:=self.myTerminal.getConfig(RailHHWarnPrenoteHazDiffer).Boolean;
	//self.chkHHShowArrival.value:=self.myTerminal.getConfig(
	self.chkHHWagIdFull.value:=self.myTerminal.getConfig(RailHHAlwaysWagonFullID).Boolean;
	self.chkHHWagIdRev.value:=self.myTerminal.getConfig(RailHHWagonUseReversedID).Boolean;

	self.myAssistant.comboBoxToDoTasks(self.cmbRailInToDo, tmpConfig.railHHToDoTask );
	
	// PAR #23794 Show Release Requests on Rail Load List setting
	self.chkRelReqRail.value := self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean;
	self.chkOutQing.value := self.myTerminal.getConfig(RailDisallowOutwardQueue).Boolean;
	
	self.chkTrkError.value := self.myTerminal.getConfig(RailTrackClearErr).Boolean;	// 24 Nov 2010	NDL	Par 23883
	self.chkAutoSwitch.value := self.myTerminal.getConfig(RailAutoSwitch).Boolean;	// 25 Nov 2010	NDL	Par 25422
	
epilog
	delete criteriaTypes;
	delete tmpConfig;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="03e42aa6-39fe-4b14-8ca1-00dfc5eeca00">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
// 14/03/2017 cnwrh7         TFS2207       #TFS3508	Rail Configuration - 14008 (Invalid Property Value)

vars
	yaConfig 					: CM_YAConfig;
	objSelectedArray : ObjectArray;
	idx								: Integer;																//+TFS3508
begin
	inheritMethod();
	
	self.minimumWidth := 566;	// 24 Nov 2010	NDL	Par 23883
	self.minimumHeight := 433;	// 24 Nov 2010	NDL	Par 23883
	
	yaConfig := self.myTerminal.myYAConfig;
	if yaConfig = null then	// 19 Sep 2009	NDL
		yaConfig := createYAConfig;
	endif;
	if self.myYARailConfig = null then
		self.myYARailConfig := yaConfig.allYARailConfigs[TI_IMEX_STATUS_IMPORT].CM_YARailConfig;
	endif;
	
	self.populateForm();

//	self.shtHandHelds.visible := process.isCnwab1(); // This is for 781 MSL configuration. GUI has been done but no updating at the moment
	
	
	create objSelectedArray transient;
		
	// Store the currently selected items
	self.mltFields.getSelected(objSelectedArray);
	self.doCmbDefaultForColourBuild(objSelectedArray, true);
	idx := self.cmbDefaultColour.findObject(self.myYARailConfig.myYACriteriaTypeForColour);					//+TFS3508
	if idx &gt;0 then																																												
		self.cmbDefaultColour.listObject := self.myYARailConfig.myYACriteriaTypeForColour;
	endif;
	self.cmbDefaultColour.lostFocus(self.cmbDefaultColour);																							//+TFS3508
	self.setNavigatorHeading(self.caption);
	
	
	if process.isNDLref 
//	or process.isNDS
//	or global.cnwer1
//	or app.isSpecial
	then
		// testing
		btnNDLTest.enabled := true;
		btnNDLTest.visible := true;
	else 
		btnNDLTest.enabled := false;
		btnNDLTest.visible := false;
	endif; 
	
	//cnwjo3, don't allow for saving if user does not have permissions
//	if (not app.getMyUser.canDo(self.myTerminal, PmAdmRailConfigMaint)) then	
//		self.btnSave.enabled := false;
//	endif;


	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mltFields.readOnly:= false;
		self.shtAllocation.disableAllChildren();
		self.shtConfig.disableAllChildren();
		self.shtHandHelds.disableAllChildren();
		self.shtHook.disableAllChildren();
	endif;
	
	
epilog
	delete objSelectedArray;		// PAR #27874

end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="501d0163-966d-40a6-bfe8-3ec47d238cbb">
        <updating/>
        <source>skipToAttribute( _attributeName : String; _shtName : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2012	cnwndl1	Initial creation

*/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	folder : Folder;

begin

	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;
		folder := tmpSheet.parent.Folder;
		folder.topSheet := tmpSheet;
	endforeach;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5e4b5e82-6aa5-4a59-a7c0-7654d4f5e50e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 August 2022 07:49:21.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012379, locale);
	btnCancel.translateCaption(Xlat_0012380, locale);
	btnNDLTest.translateCaption(Xlat_0013604, locale);
	btnSave.translateCaption(Xlat_0012381, locale);
	chkAllowWagonWeightsToBeUpd.translateCaption(Xlat_0024975, locale);
	chkAutoSwitch.translateCaption(Xlat_0016346, locale);
	chkAutoTrainNum.translateCaption(Xlat_0012382, locale);
	chkHHContIdFull.translateCaption(Xlat_0014202, locale);
	chkHHContPrenote.translateCaption(Xlat_0013605, locale);
	chkHHWagIdFull.translateCaption(Xlat_0014203, locale);
	chkHHWagIdRev.translateCaption(Xlat_0014661, locale);
	chkHHWarnHaz.translateCaption(Xlat_0013606, locale);
	chkOutQing.translateCaption(Xlat_0016347, locale);
	chkOutwardRailCo.translateCaption(Xlat_0012389, locale);
	chkRaiseErrorMaxLoadWeight.translateCaption(Xlat_0024976, locale);
	chkRelReqRail.translateCaption(Xlat_0016348, locale);
	chkRunEDI.translateCaption(Xlat_0013607, locale);
	chkTrkError.translateCaption(Xlat_0016349, locale);
	chknoTLonWagons.translateCaption(Xlat_0012390, locale);
	lRailArea.translateCaption(Xlat_0013608, locale);
	lRailCarrier.translateCaption(Xlat_0013609, locale);
	lWagonClass.translateCaption(Xlat_0013610, locale);
	lblAutoNumPrefix.translateCaption(Xlat_0014662, locale);
	lblCodeHook.translateCaption(Xlat_0012392, locale);
	lblDefault.translateCaption(Xlat_0012393, locale);
	lblRailPost.translateCaption(Xlat_0013611, locale);
	lblRailToDoTask.translateCaption(Xlat_0013612, locale);
