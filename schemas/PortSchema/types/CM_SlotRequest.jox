    <JadeMethod name="getAttrEmpty" id="bf9234ab-8330-4132-859e-c29ef4adf955">
        <source>getAttrEmpty() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation

*/

vars
	criteria : CM_YACriteria;	
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;
	intValue : Integer;
begin
	
	if self.useVoyageAllocations  then 
		criteria := self.getAttrByType(YACriteriaType_IsEmpty); // PAR 35325 
		if criteria &lt;&gt; null then
			intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 36032
			if intValue = CM_YADataBoolean.VALUE_FALSE then
				return false;
			elseif intValue = CM_YADataBoolean.VALUE_TRUE then
				return true;
			elseif intValue = CM_YADataBoolean.VALUE_EITHER then
				// do nothing here... try the other options
			endif;						
		endif;

		// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup);
		criteria := self.getAttrByType(YACriteriaType_CommodityGroup); // PAR 23263 
		if criteria &lt;&gt; null then
			commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;	
			if commGroup &lt;&gt; null then
				return commGroup.isEmptyCommodity();
			endif;
		else
			// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity);
			criteria := self.getAttrByType(YACriteriaType_Commodity); // PAR 23263 
			if criteria &lt;&gt; null then
				comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;	
				if comm &lt;&gt; null then
					return comm.isEmpty;
				endif;
			endif;
		endif;		
	else
		return self.empty;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
