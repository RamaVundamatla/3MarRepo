    <JadeMethod name="cloneSelf" id="292e506d-f758-4ab5-862c-3cc5f4d62fb5">
        <source>cloneSelf( _transient : Boolean ): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	CCMS 1023

*/

vars

	clone	: SelfType;
	element	: CM_XTABGrouping;
	field	: CM_XTABField;
	
begin

	clone := inheritMethod( _transient );
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	clone.myBankToCharge := self.myBankToCharge;
	clone.mySelectorQuery := self.mySelectorQuery;
	
	foreach field in self.allFields do
		clone.allFields.add( field.cloneSelf( _transient ) );
	endforeach;
	
	foreach element in self.allGroupings do
		clone.allGroupings.add( element.cloneSelf( _transient ) );
	endforeach;
	
	return clone;
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="erase" id="365c4dd0-5721-4937-a46b-788fbddba6a5">
