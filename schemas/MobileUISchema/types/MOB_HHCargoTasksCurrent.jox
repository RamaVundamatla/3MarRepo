    <JadeMethod name="changeTask" id="c6c65ec6-1991-429a-b1ea-4b10a7da88ff">
        <source>changeTask();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	todoTask : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;

begin


	todoTask := self.cmbTasks.itemObject[self.cmbTasks.listIndex].CM_ToDoTask;
	
	if todoTask = null then
		self.btnOne.enabled := false;
		self.lblDescription.caption := null;
		self.txtRemarks.text := null;
	else
		self.btnOne.enabled := true;
		taskDesc := todoTask.toDoTaskDesc;
		self.lblDescription.caption := taskDesc.description;
		self.txtRemarks.text := todoTask.remarks;
	endif;

epilog

end;</source>
