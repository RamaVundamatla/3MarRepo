    </JadeMethod>
    <JadeMethod name="searchForLocationIn" id="d6acce34-16ea-424e-82f6-8519bc024079">
        <source>searchForLocationIn(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 18 March 2005 by cnwdvb1
// -------------------------------------------
vars

	locationCell,emptiestCell: CM_YALocationCell;
	yardController			: CM_YardController;
	num1 : Integer;
	num2 : Integer;
begin
	// If decking by lane, use the base method
	if self.myDeckingOptions.allDeckingRulesIn.first.areaRule = DeckingRule_ByRow then
		return inheritMethod(_yaAgent);
	endif;
	
	if not self.initSearchForLC(_yaAgent) then
		return false;
	endif;
	
	// If decking by position need to fill the lanes evenly. Find the lane with the most spare space
	foreach locationCell in self.myDeckingOptions.allYALocationCellsIn discreteLock do
	/*	if emptiestCell = null or 
		locationCell.myYardController.CM_RoRoController.getSpareLength &gt; emptiestCell.myYardController.CM_RoRoController.getSpareLength then
			emptiestCell := locationCell;
		endif; */
		//11 Jul 2013	NDL	Par 32037
		if emptiestCell = null or 
		locationCell.myYardController.CM_RoRoController.getSpareLengthWithTap( num1, _yaAgent ) &gt; emptiestCell.myYardController.CM_RoRoController.getSpareLengthWithTap( num2, _yaAgent) then
			emptiestCell := locationCell;
		endif;
	endforeach;
	return self.searchLCIn(emptiestCell,_yaAgent);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
