<Class name="CM_ITSInterfaceRequest" id="8113bb3b-5ef6-44da-b3e0-85b05c35eb37">
    <superclass name="CM_ITSInterfaceMessage"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Request messages that JMT will action.</text>
    <DbClassMap file="jmtinterface"/>
    <JadeMethod name="isToBeActioned" id="1e66efaf-e43d-4083-8ad1-19091ac7c4f9">
        <condition/>
        <source>isToBeActioned():Boolean condition;
// -----------------------------------------------------------------------------
// Created:		11 November 2009 by consw1
//
// Purpose:		Indicates Request is waiting to be processed by JMT.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	if self.isReset then
		return false;
	endif;

	return self.processedTS = null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4e6363c6-ec6d-4cdc-a00b-81c4f5cf1e7c">
        <updating/>
        <source>setForCreate(_pxyObject: CM_ITSInterfaceRequest; _passport : CM_Passport input) updating, abstract;</source>
        <abstract/>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
