    <JadeMethod name="moveLogToVoyage" id="4d624cdb-8cf7-4063-8ef7-2dd89b6c9c54">
        <source>moveLogToVoyage();
//--------------------------------------------------
// Created:	02 February 2004 By: cnwgd1
//--------------------------------------------------
//'4496.4426'.asOid.CM_LogVoyageController.inspect;
//'4023.6646106'.asOid.CM_TrackedItem.inspect;
//CM_LogVoyage/4050.317

vars
	ti : CM_TrackedItem;
	moveControl : CMIF_MoveController;
begin
	ti := '4023.275377285'.asOid.CM_TrackedItem;
	app.initialize();
	app.myPassport.setMyTerminal('2351.13'.asOid.CM_Terminal);
	app.myPassport.setMyUserFromCode('SUPERUSER');

	create moveControl transient;

	moveControl.isSystemMove 	:= true;
	moveControl.isForcedMove 	:= true;
	moveControl.setMoveMode(REAL_MODE);
	moveControl.setMyToPrimaryLocation('4496.228501'.asOid.CM_LogVoyageController);
	
	moveControl.setMyTrackedItem(ti);
	moveControl.setMyOriginatingLocation('4353.535337'.asOid.CM_LogController);
	beginTransaction;
//	ti.changeVoyage('4480.9071'.asOid.CM_Voyage, app.myPassport);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl, app.myPassport);
	commitTransaction;

epilog
	delete moveControl;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveLogsToVoyage" id="6070fd0b-a0f2-4e06-9859-1214b9ab3c53">
        <source>moveLogsToVoyage();
//
// 23 Jan 2017	cnwrs1	Par 38593 move logs to a voyage that are stuck
//
vars
	ti : CM_TrackedItem;
	moveControl : CMIF_MoveController;
	logController : CM_LogController;
	logVoyController : CM_LogVoyageController;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	tiArray : CM_TIArray;
begin
	create moveControl transient;
	create tiArray transient;
	voyage := terminal.allVoyagesByCode ["17022", null];
	logVoyController := '4496.233528'.asOid.CM_LogVoyageController;
	terminal := app.myRoot.allTerminals["PCX"];
//	logController := "4353.543463".asOid.CM_LogController;
	logController := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, "E"].CM_LogArea.allRowControllersById['02'].CM_LogController;
	foreach ti in logController.allTrackedItems do
		tiArray.add(ti);
	endforeach;
	foreach ti in tiArray do
	//	ti := '4023.281953220'.asOid.CM_TrackedItem;
		app.myPassport.setMyTerminal(ti.myTerminal);
		app.myPassport.setMyUserFromCode('SUPERUSER');
	
		moveControl.isSystemMove := true;
		moveControl.isForcedMove := true;
		moveControl.setMoveMode(REAL_MODE);
		moveControl.setMyToPrimaryLocation(logVoyController);
		
		moveControl.setMyTrackedItem(ti);
		moveControl.setMyOriginatingLocation(ti.myPrimaryActualLocation);
		beginTransaction;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl, app.myPassport);
		commitTransaction;
	endforeach;
epilog
	delete tiArray;
	delete moveControl;
end;</source>
    </JadeMethod>
