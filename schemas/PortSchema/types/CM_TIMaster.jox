    <JadeMethod name="isOnsite" id="efe5f2cc-f5c7-46a2-bee6-983ecb9f67e3">
        <source>isOnsite(_terminal : CM_Terminal) : CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
begin
	if _terminal = null then
		return null;
	endif;
	
	tmpTI := self.getCurrentTIForTerminal(_terminal); //allTis.last; // get current TI
	
	if tmpTI = null then
		return null;
	endif;

	if tmpTI.isOnSite then
		return tmpTI.myPrimaryActualLocation;
	else
		return null;
	endif;
epilog

end;</source>
